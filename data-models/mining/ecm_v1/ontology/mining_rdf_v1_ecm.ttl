# --- Attribute Properties ---
ind:benefitDistributionId rdf:type rdf:Property ;
    rdfs:label 'Benefit Distribution Id' ;
    rdfs:comment 'Unique identifier for the benefit distribution transaction. Primary key for the benefit distribution record.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beneficiaryTrustFundId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Trust Fund Id' ;
    rdfs:comment 'Reference to the trust fund or community foundation receiving this benefit distribution. Used when benefits are paid into a managed fund rather than directly to community representatives.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BeneficiaryTrustFund .

ind:benefitSharingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Benefit Sharing Agreement Id' ;
    rdfs:comment 'Reference to the parent benefit-sharing agreement under which this distribution is made. Links to the master agreement governing benefit-sharing obligations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitSharingAgreement .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Foreign key linking to product.commodity. Business justification: Benefit distributions are often calculated using commodity-specific formulas (e.g., "$2 per tonne of coal", "1.5% of copper revenue"). Essential for accurate benefit calculation, audit trail of commod' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:costCentreId rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Benefit distributions are posted to cost centers for financial accounting. Existing cost_centre_code is denormalized; FK enables proper cost allocation and AISC unit cost calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:mineSiteId rdf:type rdf:Property ;
    rdfs:label 'Mine Site Id' ;
    rdfs:comment 'Reference to the mine site or operation from which this benefit distribution originates. Links the distribution to the specific mining operation generating the benefit obligation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MineSite .

ind:performanceActualId rdf:type rdf:Property ;
    rdfs:label 'Performance Actual Id' ;
    rdfs:comment 'Foreign key linking to sales.performance_actual. Business justification: Benefit-sharing payments in mining are calculated from actual sales revenue and production volumes. The calculation_period_revenue field on benefit_distribution directly corresponds to sales performan' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceActual .

ind:stakeholderId rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Id' ;
    rdfs:comment 'Reference to the community entity receiving this benefit distribution. Identifies the specific community, indigenous group, or local authority entitled to the benefit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:authorisationDate rdf:type rdf:Property ;
    rdfs:label 'Authorisation Date' ;
    rdfs:comment 'Date on which the benefit distribution was formally authorised for disbursement. Precedes the actual distribution date.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisationReference rdf:type rdf:Property ;
    rdfs:label 'Authorisation Reference' ;
    rdfs:comment 'Reference to the internal approval or authorisation document that approved this distribution. Links to workflow approval ID or board resolution number.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisedBy rdf:type rdf:Property ;
    rdfs:label 'Authorised By' ;
    rdfs:comment 'Name or identifier of the person or committee who authorised this benefit distribution. Provides accountability for distribution decisions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCategory rdf:type rdf:Property ;
    rdfs:label 'Benefit Category' ;
    rdfs:comment 'High-level categorization of the benefit for reporting and analytics. Groups benefit types into strategic categories aligned with social licence to operate objectives.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Classification of the type of benefit being distributed. Distinguishes between monetary payments, in-kind contributions, and specific purpose funds. [ENUM-REF-CANDIDATE: royalty_payment|revenue_share|infrastructure_contribution|employment_fund|education_fund|health_fund|in_kind_service|land_compensation|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Description of the formula or basis used to calculate the benefit amount (e.g., percentage of revenue, fixed annual amount, per-tonne royalty). Provides transparency for benefit calculation methodology.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationPeriodProductionVolume rdf:type rdf:Property ;
    rdfs:label 'Calculation Period Production Volume' ;
    rdfs:comment 'Total production volume (in tonnes or other unit) for the reporting period used in benefit calculation. Applicable when benefit is calculated per unit of production.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationPeriodRevenue rdf:type rdf:Property ;
    rdfs:label 'Calculation Period Revenue' ;
    rdfs:comment 'Total revenue for the reporting period used in benefit calculation. Applicable when benefit is calculated as a percentage of revenue. Confidential business data.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this benefit distribution record was first created in the system. Audit trail for data lineage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the monetary value amount. Supports multi-currency benefit distributions across international operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaised rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised' ;
    rdfs:comment 'Indicates whether the beneficiary has raised a dispute or grievance regarding this distribution. True when formal dispute is logged.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'Reference number of the grievance or dispute case related to this distribution. Links to the community grievance management system.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'The date on which the benefit was distributed or disbursed to the beneficiary community or trust fund. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'The mechanism or channel through which the benefit was distributed to the beneficiary. Distinguishes between financial instruments and direct service delivery. [ENUM-REF-CANDIDATE: bank_transfer|cheque|cash|trust_fund_deposit|direct_service|infrastructure_delivery|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this benefit distribution event, used for audit trail and community reporting. Format: site code (3 letters), year (4 digits), sequence (6 digits).' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle status of the benefit distribution. Tracks progression from planning through to receipt confirmation or dispute resolution.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccountCode rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Code' ;
    rdfs:comment 'General ledger account code for posting this benefit distribution expense. Links to the chart of accounts for financial consolidation.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inKindDescription rdf:type rdf:Property ;
    rdfs:label 'In Kind Description' ;
    rdfs:comment 'Detailed description of in-kind benefits provided (e.g., infrastructure construction, equipment donation, training programs). Null for pure monetary distributions.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this benefit distribution record was last updated. Audit trail for data lineage and change tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Identifier of the user or system process that last modified this record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Monetary Value Amount' ;
    rdfs:comment 'The monetary value of the benefit distribution. For cash payments, this is the disbursed amount. For in-kind benefits, this is the fair market value equivalent.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes capturing additional context, special circumstances, or clarifications related to this benefit distribution event.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment system reference number for monetary distributions. Links to bank transfer, cheque number, or ERP payment document for reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Production Volume Unit' ;
    rdfs:comment 'Unit of measure for the calculation period production volume. Aligns with commodity-specific measurement standards.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmation Date' ;
    rdfs:comment 'Date on which the beneficiary formally acknowledged receipt of the benefit. Used to close the distribution audit trail.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptConfirmationReceived rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmation Received' ;
    rdfs:comment 'Indicates whether formal receipt confirmation has been received from the beneficiary. True when signed acknowledgment or receipt document is on file.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Receipt Document Reference' ;
    rdfs:comment 'Reference to the stored receipt document, signed acknowledgment, or confirmation letter. Points to document management system location.' ;
    rdfs:domain ind:BenefitDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period to which this benefit distribution applies. Defines the temporal scope of the benefit calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period to which this benefit distribution applies. Used for periodic benefit-sharing calculations and compliance reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:beneficiaryStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Benefit sharing agreements are formal arrangements with specific stakeholder communities. Currently beneficiary is stored as text (beneficiary_community_name, beneficiary_community_type). Normalizing ' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:companyRepresentativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Company Representative Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Benefit sharing agreements require a named company employee as signatory and ongoing relationship manager for payment authorization, dispute resolution, and review coordination. Critical for audit tra' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:linkedLandCompensationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Linked Land Compensation Agreement Id' ;
    rdfs:comment 'Reference to a related land compensation agreement, if this benefit sharing agreement was negotiated in conjunction with land access arrangements.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandCompensationAgreement .

ind:oreReserveId rdf:type rdf:Property ;
    rdfs:label 'Ore Reserve Id' ;
    rdfs:comment 'Foreign key linking to exploration.ore_reserve. Business justification: Ore reserves determine benefit sharing calculations (royalty percentages, payment triggers based on production). Agreement administration, payment scheduling, and periodic reviews require linking agre' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OreReserve .

ind:orebodyId rdf:type rdf:Property ;
    rdfs:label 'Orebody Id' ;
    rdfs:comment 'Foreign key linking to geology.orebody. Business justification: Benefit sharing agreements are tied to specific orebodies. Royalty calculations and benefit distributions are based on production from identified orebodies. Real business process: community benefit di' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Orebody .

ind:profitCentreId rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_centre. Business justification: Benefit sharing obligations are tracked at mine site (profit centre) level for segment reporting, life-of-mine cost forecasting, and AISC guidance calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCentre .

ind:tenementId rdf:type rdf:Property ;
    rdfs:label 'Tenement Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement. Business justification: Benefit sharing agreements are tied to specific tenements for royalty calculation based on production from that tenement. Critical for financial distribution, royalty tracking, and community benefit a' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenement .

ind:agreementCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Code' ;
    rdfs:comment 'Externally-known unique business identifier for the benefit sharing agreement, typically used in legal documents and reporting.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the benefit sharing agreement. [ENUM-REF-CANDIDATE: draft|under_negotiation|approved|active|suspended|terminated|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Full legal title or name of the benefit sharing agreement as documented in the signed contract.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Primary classification of the benefit sharing arrangement mechanism.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the agreement was formally approved by company executive leadership or board.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or title of the executive or governance body that approved the agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCalculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Benefit Calculation Methodology' ;
    rdfs:comment 'Detailed description of the formula or methodology used to calculate benefit amounts, including base metrics (revenue, production volume, profit) and calculation frequency.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Community Representative Name' ;
    rdfs:comment 'Name of the primary community representative or leader authorized to act on behalf of the beneficiary community.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Consultation Process Description' ;
    rdfs:comment 'Summary of the consultation and negotiation process undertaken with the community, including dates and methods (town halls, focus groups, traditional decision-making processes).' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Description of the agreed process for resolving disputes arising from the agreement (mediation, arbitration, traditional justice systems).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the benefit sharing agreement becomes legally binding and benefit obligations commence.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentQuotaPercentage rdf:type rdf:Property ;
    rdfs:label 'Employment Quota Percentage' ;
    rdfs:comment 'Minimum percentage of workforce positions reserved for members of the beneficiary community, if applicable.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedBeneficiariesCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Beneficiaries Count' ;
    rdfs:comment 'Estimated number of individuals or households in the beneficiary community expected to receive direct or indirect benefits.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the benefit sharing agreement terminates or expires, if applicable. Null for agreements tied to Life of Mine (LOM).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpicDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Fpic Documentation Reference' ;
    rdfs:comment 'Reference to the document or record that evidences the FPIC process and outcome.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freePriorInformedConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Free Prior Informed Consent Obtained' ;
    rdfs:comment 'Flag indicating whether Free, Prior and Informed Consent was obtained from indigenous or traditional communities as per international standards.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic area or administrative region where the beneficiary community is located.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceStructure rdf:type rdf:Property ;
    rdfs:label 'Governance Structure' ;
    rdfs:comment 'Description of the joint governance or oversight body established to administer the agreement, including representation from company and community.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infrastructureContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Infrastructure Contribution Amount' ;
    rdfs:comment 'Total monetary value committed for infrastructure development (roads, schools, clinics, water systems) for the beneficiary community.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Legal Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal agreement document stored in the document management system.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localProcurementTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Local Procurement Target Percentage' ;
    rdfs:comment 'Target percentage of procurement spend to be directed to local suppliers from the beneficiary community, if applicable.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of the agreement terms.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which benefit payments are made to the beneficiary community.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Payment Trigger' ;
    rdfs:comment 'Event or schedule that triggers benefit payments or delivery under this agreement.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which the company must report benefit delivery performance to the community and governance body.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewSchedule rdf:type rdf:Property ;
    rdfs:label 'Review Schedule' ;
    rdfs:comment 'Frequency at which the agreement terms are formally reviewed and potentially renegotiated by both parties.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltySharePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Share Percentage' ;
    rdfs:comment 'Percentage of mining royalties or revenue to be shared with the beneficiary community, if applicable to this agreement type.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialLicenceToOperateIndicator rdf:type rdf:Property ;
    rdfs:label 'Social Licence To Operate Indicator' ;
    rdfs:comment 'Flag indicating whether this agreement is considered critical to maintaining the social licence to operate at the associated mine site.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trustFundContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Trust Fund Contribution Amount' ;
    rdfs:comment 'Total monetary value committed to a community trust fund or endowment under this agreement.' ;
    rdfs:domain ind:BenefitSharingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentEvidenceId rdf:type rdf:Property ;
    rdfs:label 'Commitment Evidence Id' ;
    rdfs:comment 'Unique identifier for the commitment evidence record. Primary key for the commitment evidence entity.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentId rdf:type rdf:Property ;
    rdfs:label 'Commitment Id' ;
    rdfs:comment 'Reference to the parent community commitment that this evidence supports. Links to the commitment being fulfilled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commitment .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this evidence record. Establishes accountability for data changes in the audit trail.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCommitmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Commitment Employee Id' ;
    rdfs:comment 'Reference to the system user who submitted the evidence. Establishes accountability and audit trail for evidence submission.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Reference to the mine site where the commitment is being fulfilled. Enables site-level compliance tracking and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mine .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the evidence document. Controls access and disclosure in accordance with information security and stakeholder privacy requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the submitted evidence document. Supports document management and accessibility requirements. [ENUM-REF-CANDIDATE: pdf|docx|xlsx|jpg|png|mp4|zip — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'File path, URL, or document management system reference pointing to the physical evidence artifact. Enables retrieval of supporting documentation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSizeMb rdf:type rdf:Property ;
    rdfs:label 'Document Size Mb' ;
    rdfs:comment 'Size of the evidence document file in megabytes. Used for storage management and system performance optimization.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Detailed narrative describing the evidence content, context, and how it demonstrates fulfillment of the commitment. Provides business context for reviewers and auditors.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidencePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Period End Date' ;
    rdfs:comment 'End date of the period that this evidence covers. Defines the temporal scope of the evidence for compliance tracking.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidencePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Period Start Date' ;
    rdfs:comment 'Start date of the period that this evidence covers. Defines the temporal scope of the evidence for compliance tracking.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference Number' ;
    rdfs:comment 'Business identifier for the evidence submission. Externally-known unique code used for tracking and audit purposes.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Status' ;
    rdfs:comment 'Current state of the evidence in the verification workflow. Tracks progression from submission through verification to final acceptance or rejection.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Classification of the evidence submission format. Categorizes the nature of proof provided to demonstrate commitment fulfillment.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Lender Reporting Flag' ;
    rdfs:comment 'Indicates whether this evidence must be included in lender covenant compliance reports. Supports project finance and Equator Principles reporting requirements.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this evidence must be included in regulatory compliance reports. Supports Environmental Impact Statement (EIS) and mining permit compliance reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation of why evidence was rejected. Provides feedback to submitters and supports process improvement. Populated only when verification_outcome is rejected.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Date' ;
    rdfs:comment 'Date when stakeholders were notified of the evidence submission. Tracks compliance with transparency commitments and grievance mechanism requirements.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stakeholderNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Notification Required Flag' ;
    rdfs:comment 'Indicates whether affected stakeholders must be notified of this evidence submission. Supports transparency and social licence to operate (SLO) requirements.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the evidence was formally submitted for verification. Key business event timestamp for compliance tracking and audit trail.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the evidence was submitted into the system. Provides granular audit trail for regulatory reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedByDepartment rdf:type rdf:Property ;
    rdfs:label 'Submitted By Department' ;
    rdfs:comment 'Organizational department or business unit of the submitter. Enables departmental accountability tracking and reporting.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByName rdf:type rdf:Property ;
    rdfs:label 'Submitted By Name' ;
    rdfs:comment 'Full name of the person who submitted the evidence. Provides human-readable identification for reporting and audit purposes.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedByRole rdf:type rdf:Property ;
    rdfs:label 'Submitted By Role' ;
    rdfs:comment 'Job title or role of the person who submitted the evidence. Provides context on authority and responsibility level of submitter.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerifierAccreditation rdf:type rdf:Property ;
    rdfs:label 'Third Party Verifier Accreditation' ;
    rdfs:comment 'Professional accreditation or certification held by the third-party verifier. Demonstrates verifier competence and independence for regulatory and lender reporting.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyVerifierOrganisation rdf:type rdf:Property ;
    rdfs:label 'Third Party Verifier Organisation' ;
    rdfs:comment 'Name of external organization that provided independent verification. Applicable when evidence_type is third_party_verification. Enhances credibility for stakeholder reporting.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the evidence was formally verified and accepted. Key milestone for compliance reporting and commitment tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Approach used to verify the evidence. Documents the verification methodology for audit trail and quality assurance purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed comments from the verifier explaining the verification decision, findings, and any conditions or recommendations. Critical for audit trail and continuous improvement.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Final determination of the verification process. Records whether the evidence successfully demonstrates commitment fulfillment.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Full name of the person who verified the evidence. Provides human-readable identification for audit trail and reporting.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierRole rdf:type rdf:Property ;
    rdfs:label 'Verifier Role' ;
    rdfs:comment 'Job title or role of the person who verified the evidence. Demonstrates appropriate authority level for verification decisions.' ;
    rdfs:domain ind:CommitmentEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementPlanId rdf:type rdf:Property ;
    rdfs:label 'Engagement Plan Id' ;
    rdfs:comment 'Foreign key linking to community.engagement_plan. Business justification: Commitments can arise from engagement plans as part of structured stakeholder engagement processes. The commitment.commitment_source attribute indicates multiple sources; engagement plans are one such' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementPlan .

ind:landCompensationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Land Compensation Agreement Id' ;
    rdfs:comment 'Foreign key linking to community.land_compensation_agreement. Business justification: Land compensation agreements generate formal commitments to landowners and communities. The commitment.agreement_reference string attribute should be normalized to a proper FK. This FK is optional (nu' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandCompensationAgreement .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Community commitments require a named employee as accountable manager for delivery tracking, stakeholder communication, and evidence submission. Enables performance tracking and workload balancing acr' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:socialImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Social Impact Assessment Id' ;
    rdfs:comment 'Foreign key linking to community.social_impact_assessment. Business justification: Many community commitments arise from Social Impact Assessments (SIAs). Currently sia_reference_number is a text field. Adding FK enables tracking which commitments originated from which SIA, supports' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SocialImpactAssessment .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Actual financial cost incurred to fulfill this commitment. Expressed in the currency specified in the currency code field. Null if commitment is not yet completed or costs are not yet finalized.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the executive or manager who approved this commitment on behalf of the company. Used for accountability and governance tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentCategory rdf:type rdf:Property ;
    rdfs:label 'Commitment Category' ;
    rdfs:comment 'Classification of the commitment by its binding nature. Regulatory commitments arise from government approvals and permits, contractual commitments from signed agreements, voluntary commitments from company initiatives, and public statement commitments from formal company communications.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'The date on which the commitment was formally made or agreed. This is the business event date when the obligation was established.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Commitment Description' ;
    rdfs:comment 'Detailed description of the commitment including the specific obligation, deliverable, or action that the company has committed to undertake for the community or stakeholder.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentSource rdf:type rdf:Property ;
    rdfs:label 'Commitment Source' ;
    rdfs:comment 'The origin or source document from which this commitment arose. Examples include Social Impact Assessment (SIA) reports, Environmental Impact Statement (EIS), community consultation records, land compensation agreements, regulatory approval conditions, benefit-sharing agreements, or public statements by company leadership.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the commitment indicating whether it is in draft, active and pending action, in progress, completed and fulfilled, overdue, cancelled, or deferred to a later date. [ENUM-REF-CANDIDATE: draft|active|in_progress|completed|overdue|cancelled|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the commitment by the nature of the obligation. Categories include financial contributions, infrastructure development, employment guarantees, training programs, environmental protection, health and safety measures, cultural heritage preservation, resettlement support, benefit-sharing arrangements, and other commitments. [ENUM-REF-CANDIDATE: financial|infrastructure|employment|training|environmental|health_safety|cultural_heritage|resettlement|benefit_sharing|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The actual date on which the commitment was fulfilled and completed. Null if the commitment is not yet completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Estimated percentage of completion for this commitment, expressed as a value between 0.00 and 100.00. Used for progress tracking and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The target date by which this commitment must be fulfilled or completed. Used for tracking overdue commitments and reporting compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this commitment requires escalation to senior management or executive leadership due to delays, risks, or stakeholder concerns. True if escalation is required, False otherwise.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated financial cost or budget allocated to fulfill this commitment. Expressed in the currency specified in the currency code field.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Location' ;
    rdfs:comment 'File path, URL, or document management system reference where supporting evidence and documentation for this commitment is stored.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfFulfilment rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Fulfilment' ;
    rdfs:comment 'Description or reference to the evidence, documentation, or proof that demonstrates this commitment has been fulfilled. May include report references, photos, receipts, certificates, or stakeholder sign-offs.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of this commitment based on its importance, urgency, regulatory significance, or stakeholder sensitivity. Used for resource allocation and management focus.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this commitment for tracking and reporting purposes. Used in stakeholder communications and regulatory submissions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryConditionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Condition Reference' ;
    rdfs:comment 'Reference number or identifier of the specific regulatory approval condition, permit condition, or consent requirement that mandates this commitment. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this commitment requires formal reporting to regulators, stakeholders, or in public disclosures. True if reporting is required, False otherwise.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRecipient rdf:type rdf:Property ;
    rdfs:label 'Reporting Recipient' ;
    rdfs:comment 'Name or identifier of the party or authority to whom progress or completion of this commitment must be reported. Examples include regulatory agencies, community representatives, or board committees.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Name of the department, division, or business unit responsible for delivering this commitment. Examples include Community Relations, Environment, Operations, Human Resources, or Procurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date when this commitment was last reviewed for progress, status, or ongoing relevance. Used for periodic commitment audits.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the risk to social licence to operate (SLO) or stakeholder relations if this commitment is not fulfilled. Used for prioritization and escalation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sia Reference Number' ;
    rdfs:comment 'Reference number of the Social Impact Assessment (SIA) from which this commitment originated. Links commitment to the impact assessment process.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference number, identifier, or location of the source document where this commitment is formally recorded. Used for audit trail and evidence of commitment origin.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Acceptance Status' ;
    rdfs:comment 'Status indicating whether the stakeholder or community has accepted the fulfilment of this commitment. Options include accepted, pending review, disputed, or not applicable.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderFeedback rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Feedback' ;
    rdfs:comment 'Free-text field capturing feedback, comments, or concerns raised by stakeholders regarding the fulfilment or progress of this commitment.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCommunity rdf:type rdf:Property ;
    rdfs:label 'Target Community' ;
    rdfs:comment 'Name or identifier of the specific community, stakeholder group, or geographic area that is the beneficiary or subject of this commitment.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title or name of the commitment that summarizes the obligation in business-friendly language.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthProgramId rdf:type rdf:Property ;
    rdfs:label 'Health Program Id' ;
    rdfs:comment 'Unique identifier for the community health program record. Primary key.' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementVendorId rdf:type rdf:Property ;
    rdfs:label 'Procurement Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Mining companies contract health service vendors (clinics, NGOs, medical suppliers) to deliver community health programs. The implementing_partner text field should be formalized as FK to vendor for p' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementVendor .

ind:programManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Health programs require a named employee as program manager for partner coordination, outcome tracking, and IFC PS4 compliance reporting. Enables performance tracking and workload balancing across com' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Target Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Community health programs are delivered to specific target communities who are stakeholders. Currently target_community is text. Normalizing to FK enables tracking which stakeholder communities benefi' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:actualBeneficiariesCount rdf:type rdf:Property ;
    rdfs:label 'Actual Beneficiaries Count' ;
    rdfs:comment 'Actual number of individuals who have received services or benefits from the health program to date.' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program budget amount.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocation rdf:type rdf:Property ;
    rdfs:label 'Document Location' ;
    rdfs:comment 'File path, URL, or document management system reference where the full program documentation, agreements, and reports are stored.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Planned or actual date when the health program concludes or concluded.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalHealthLinkage rdf:type rdf:Property ;
    rdfs:label 'Environmental Health Linkage' ;
    rdfs:comment 'Description of any linkages between the health program and environmental impacts of mining operations (e.g., dust control, water quality, vector control).' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Primary source of financial support for the program (company CSR budget, benefit-sharing agreement, government grant, donor contribution, joint funding).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthFocusArea rdf:type rdf:Property ;
    rdfs:label 'Health Focus Area' ;
    rdfs:comment 'Primary health domain or disease category that the program addresses (malaria, HIV/AIDS, nutrition, maternal health, mental health, water and sanitation).' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifcPs4Alignment rdf:type rdf:Property ;
    rdfs:label 'Ifc Ps4 Alignment' ;
    rdfs:comment 'Description of how the program aligns with IFC Performance Standard 4 obligations on Community Health, Safety and Security.' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyPerformanceIndicators rdf:type rdf:Property ;
    rdfs:label 'Key Performance Indicators' ;
    rdfs:comment 'List or description of measurable KPIs used to track program effectiveness (e.g., vaccination coverage rate, malaria incidence reduction, maternal mortality ratio).' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the implementing partner organization (NGO, government agency, healthcare provider, community organization, international agency).' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Program Budget Amount' ;
    rdfs:comment 'Total allocated budget for the health program over its full funding period.' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code assigned to the health program for external reference and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full descriptive name of the community health program.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programObjectives rdf:type rdf:Property ;
    rdfs:label 'Program Objectives' ;
    rdfs:comment 'Detailed description of the health outcomes, goals, and objectives the program aims to achieve in the target community.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the health program indicating its operational state.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Summary of identified risks to program delivery (e.g., political instability, funding shortfalls, partner capacity constraints) and mitigation measures.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Date' ;
    rdfs:comment 'Date when community stakeholders were consulted or engaged in the design or approval of the health program.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the health program officially commenced or is scheduled to commence.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityPlan rdf:type rdf:Property ;
    rdfs:label 'Sustainability Plan' ;
    rdfs:comment 'Description of the strategy or plan to ensure the health program continues to deliver benefits beyond the mining operations direct involvement.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeneficiariesCount rdf:type rdf:Property ;
    rdfs:label 'Target Beneficiaries Count' ;
    rdfs:comment 'Estimated number of individuals in the community expected to directly benefit from the health program.' ;
    rdfs:domain ind:HealthProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investmentProgramId rdf:type rdf:Property ;
    rdfs:label 'Investment Program Id' ;
    rdfs:comment 'Unique identifier for the community investment program record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentProgram .

ind:generalLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger_account. Business justification: Community investment programs post to specific GL accounts (CSR expenditure, community investment) for financial statement classification and external sustainability reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedgerAccount .

ind:csrStrategyAlignment rdf:type rdf:Property ;
    rdfs:label 'Csr Strategy Alignment' ;
    rdfs:comment 'Description of how this community investment program aligns with the mining operation\'s broader Corporate Social Responsibility strategy, sustainability commitments, and social licence to operate objectives.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactConsideration rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Consideration' ;
    rdfs:comment 'Description of environmental considerations, assessments, or mitigation measures incorporated into the design and delivery of the community investment program.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBeneficiaries rdf:type rdf:Property ;
    rdfs:label 'Estimated Beneficiaries' ;
    rdfs:comment 'Estimated number of individuals or households expected to directly benefit from the community investment program.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Category of community investment program indicating the primary focus area: education (schools, scholarships, training), health (clinics, medical services), infrastructure (roads, water, electricity), livelihood (employment, enterprise development), environment (conservation, rehabilitation), or cultural (heritage preservation, cultural activities).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Sustainability Indicator' ;
    rdfs:comment 'Key performance indicator or metric used to measure the long-term sustainability and impact of the community investment program beyond the mining operation\'s involvement.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'Total allocated budget for the community investment program across its entire lifecycle, expressed in the operating currency.' ;
    rdfs:domain ind:InvestmentProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meetingId rdf:type rdf:Property ;
    rdfs:label 'Meeting Id' ;
    rdfs:comment 'Unique identifier for the community meeting record. Primary key for the community meeting entity.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discussedAssetId rdf:type rdf:Property ;
    rdfs:label 'Discussed Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Community consultation meetings often discuss specific equipment activities (haul trucks using public roads, drill rigs operating near villages, blasting equipment timing, conveyor noise). Stakeholder' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:facilitatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facilitator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When company employees facilitate community meetings (common in Mining), tracking the facilitator enables performance assessment, continuity planning, and cultural competency development for community' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agendaSummary rdf:type rdf:Property ;
    rdfs:label 'Agenda Summary' ;
    rdfs:comment 'High-level summary of the meeting agenda items and topics discussed. Provides context for the consultation session.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of community members and stakeholders who attended the meeting. Used for engagement metrics and Social Licence to Operate (SLO) reporting.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentsMade rdf:type rdf:Property ;
    rdfs:label 'Commitments Made' ;
    rdfs:comment 'Summary of commitments, promises, or action items that the company agreed to during the meeting. Forms the basis for follow-up tracking and accountability.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyRepresentativeCount rdf:type rdf:Property ;
    rdfs:label 'Company Representative Count' ;
    rdfs:comment 'Number of company employees and representatives who attended the meeting on behalf of the mining operation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consultationPhase rdf:type rdf:Property ;
    rdfs:label 'Consultation Phase' ;
    rdfs:comment 'The Life of Mine (LOM) phase during which the community meeting was conducted. Aligns engagement activities with project lifecycle stages.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'The precise date and time when the community meeting concluded. Used for duration calculation and resource planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementTopicCategory rdf:type rdf:Property ;
    rdfs:label 'Engagement Topic Category' ;
    rdfs:comment 'Primary thematic category of the meeting content. Used for topic-based analysis and reporting of stakeholder concerns.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorOrganization rdf:type rdf:Property ;
    rdfs:label 'Facilitator Organization' ;
    rdfs:comment 'The organization or company that the facilitator represents (e.g., mining company, independent consultant, government agency).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Status' ;
    rdfs:comment 'Current status of follow-up actions and commitments arising from the meeting. Tracks closure of action items for Social Licence to Operate (SLO) compliance.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which follow-up actions and commitments from the meeting should be completed. Used for action tracking and accountability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governmentOfficialPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Government Official Present Flag' ;
    rdfs:comment 'Indicates whether government officials or regulatory representatives attended the meeting. Important for regulatory compliance and stakeholder mapping.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceLoggedFlag rdf:type rdf:Property ;
    rdfs:label 'Grievance Logged Flag' ;
    rdfs:comment 'Indicates whether any formal grievances were logged or escalated during this meeting. Triggers grievance mechanism workflow.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyIssuesRaised rdf:type rdf:Property ;
    rdfs:label 'Key Issues Raised' ;
    rdfs:comment 'Summary of the primary concerns, questions, and issues raised by community stakeholders during the meeting. Critical for grievance tracking and Social Licence to Operate (SLO) management.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageUsed rdf:type rdf:Property ;
    rdfs:label 'Language Used' ;
    rdfs:comment 'Primary language(s) used during the community meeting. Important for cultural sensitivity and accessibility compliance.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the individual who last modified this community meeting record. Audit trail for accountability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'The full physical address of the meeting venue. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCoordinates rdf:type rdf:Property ;
    rdfs:label 'Location Coordinates' ;
    rdfs:comment 'Geographic coordinates (latitude, longitude) of the meeting venue in decimal degrees format. Used for Geographic Information System (GIS) mapping and spatial analysis.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'The name of the venue or facility where the community meeting was held (e.g., community hall, mine site office, village center).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Media Present Flag' ;
    rdfs:comment 'Indicates whether media representatives (press, journalists, broadcasters) were present at the meeting. Important for public relations and communications management.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'The calendar date on which the community meeting was held or is scheduled to be held. Principal business event timestamp for consultation tracking.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle status of the community meeting. Tracks progression from planning through completion or cancellation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the community meeting format. Determines the engagement approach and documentation requirements for Social Licence to Operate (SLO) compliance.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Minutes Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the official meeting minutes document. Links to the document management system for full meeting record retrieval.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sloRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Slo Risk Level' ;
    rdfs:comment 'Assessment of the Social Licence to Operate (SLO) risk level based on issues raised and stakeholder sentiment during the meeting. Used for risk management and escalation.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'The precise date and time when the community meeting commenced. Used for duration calculation and scheduling coordination.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:translationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Translation Provided Flag' ;
    rdfs:comment 'Indicates whether translation or interpretation services were provided during the meeting to accommodate non-native speakers.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the individual who created this community meeting record in the system. Audit trail for accountability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Compensation Payment Id' ;
    rdfs:comment 'Unique identifier for each compensation payment transaction. Primary key for the compensation payment record.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentCompensationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Compensation Payment Id' ;
    rdfs:comment 'Reference to the original compensation payment record if this payment is a reversal, correction, or adjustment. Creates an audit chain for payment modifications.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompensationPayment .

ind:bankTransferReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transfer Reference' ;
    rdfs:comment 'The unique transaction reference or confirmation number provided by the banking system for electronic fund transfers. Used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The net monetary value actually disbursed to the payee after all deductions, withholdings, and adjustments. Represents the final amount received by the payee.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Payee Bank Account Number' ;
    rdfs:comment 'The bank account number of the payee to which the compensation payment was transferred. Sensitive financial information requiring restricted access.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeBankBranchCode rdf:type rdf:Property ;
    rdfs:label 'Payee Bank Branch Code' ;
    rdfs:comment 'The branch or routing code for the payee\'s bank account. Required for domestic and international payment processing.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeBankName rdf:type rdf:Property ;
    rdfs:label 'Payee Bank Name' ;
    rdfs:comment 'The name of the financial institution holding the payee\'s account. Used for payment routing and verification.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross monetary value of the compensation payment disbursed, before any deductions or adjustments. Represents the total amount transferred to the payee.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the compensation payment was disbursed to the payee. Represents the actual transaction date, not the scheduled or planned date.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-text description providing additional context about the compensation payment, including purpose, special conditions, or notes for the payee.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFailureReason rdf:type rdf:Property ;
    rdfs:label 'Payment Failure Reason' ;
    rdfs:comment 'Description of the reason why the payment failed, if applicable. Captures technical or business reasons for payment rejection or failure.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The financial instrument or mechanism used to disburse the compensation payment. Indicates how the funds were transferred to the payee.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'The end date of the period covered by this compensation payment. Defines the temporal scope of the compensation obligation being fulfilled.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this compensation payment. Used for periodic payments (e.g., monthly, quarterly, annual compensation).' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the compensation payment transaction. Tracks the payment from scheduling through completion or failure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Categorizes the nature of the compensation payment within the agreement lifecycle. Distinguishes between initial, ongoing, final, and adjustment payments.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'The project or capital program code associated with this compensation payment. Links payment to specific mining projects or development initiatives.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmation Status' ;
    rdfs:comment 'Indicates whether the payee has confirmed receipt of the compensation payment. Critical for audit trail and dispute resolution.' ;
    rdfs:domain ind:CompensationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which this compensation payment was reconciled in the financial system. Marks the completion of the financial control process.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Indicates whether this payment has been reconciled against the general ledger and agreement obligations. Critical for financial audit and compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why this compensation payment was reversed or cancelled after initial processing. Critical for audit trail and dispute resolution.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'The amount of tax withheld from the gross payment amount as required by local tax regulations. Represents statutory deductions before net disbursement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:culturalHeritageSiteId rdf:type rdf:Property ;
    rdfs:label 'Cultural Heritage Site Id' ;
    rdfs:comment 'Unique identifier for the cultural heritage site record. Primary key for the cultural heritage site master register.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CulturalHeritageSite .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Foreign key linking to exploration.prospect. Business justification: Cultural heritage sites within or near prospects require management during exploration. Drill pad siting, access road design, and FPIC consultation depend on this spatial relationship. Real business p' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:accessProtocol rdf:type rdf:Property ;
    rdfs:label 'Access Protocol' ;
    rdfs:comment 'Cultural protocols or procedures that must be followed when accessing or working near the heritage site. May include requirements for traditional owner accompaniment, gender restrictions, or ceremonial permissions.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Coordinate Accuracy Meters' ;
    rdfs:comment 'The estimated accuracy of the GPS coordinates in meters. Indicates the precision of the site location for buffer zone calculations and spatial planning.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinateDatum rdf:type rdf:Property ;
    rdfs:label 'Coordinate Datum' ;
    rdfs:comment 'The geodetic datum used for the GPS coordinates, typically WGS84 or local survey datum. Required for accurate spatial integration with mine planning systems.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalGroupAffiliation rdf:type rdf:Property ;
    rdfs:label 'Cultural Group Affiliation' ;
    rdfs:comment 'The Indigenous or traditional cultural group(s) to whom this heritage site holds cultural significance. May include multiple groups with shared or overlapping cultural connections. Confidential to respect cultural sensitivities.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the heritage site was first identified or discovered during exploration, survey, or mining activities. Tracks when the site entered the heritage register.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpicDate rdf:type rdf:Property ;
    rdfs:label 'Fpic Date' ;
    rdfs:comment 'Date when Free Prior and Informed Consent was obtained from the affiliated cultural group. Documents the timing of consent for audit and compliance purposes.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fpicObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Fpic Obtained Flag' ;
    rdfs:comment 'Indicates whether Free Prior and Informed Consent has been obtained from the affiliated cultural group for any activities that may affect this heritage site. Critical for social licence to operate compliance.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heritageAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Heritage Agreement Reference' ;
    rdfs:comment 'Reference to any heritage protection agreement, cultural heritage management plan, or memorandum of understanding with traditional owners that governs management of this site.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageSurveyReference rdf:type rdf:Property ;
    rdfs:label 'Heritage Survey Reference' ;
    rdfs:comment 'Reference number or identifier of the heritage survey, archaeological assessment, or ethnographic study that identified and documented this site. Links to survey reports and assessment documentation.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent physical inspection or monitoring visit to the heritage site. Used to schedule periodic monitoring and ensure ongoing protection compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the heritage site location in decimal degrees. Confidential to prevent unauthorized access or disturbance to culturally sensitive sites.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the heritage site location in decimal degrees. Confidential to prevent unauthorized access or disturbance to culturally sensitive sites.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Management Restrictions' ;
    rdfs:comment 'Specific management requirements, access restrictions, or operational constraints that must be observed to protect the heritage site. May include seasonal access restrictions, cultural protocols, or activity prohibitions.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next heritage site inspection or monitoring visit. Ensures regular monitoring frequency is maintained per heritage management plan commitments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noGoZoneRadiusMeters rdf:type rdf:Property ;
    rdfs:label 'No Go Zone Radius Meters' ;
    rdfs:comment 'The buffer distance in meters around the heritage site within which mining activities, ground disturbance, or access is prohibited. Used to create exclusion zones in mine planning systems.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protectionStatus rdf:type rdf:Property ;
    rdfs:label 'Protection Status' ;
    rdfs:comment 'The legal or regulatory protection status assigned to the heritage site by government heritage authorities or through agreement with traditional owners. Determines access restrictions and mining exclusion zones.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the heritage site was formally registered in the company heritage management system or with statutory heritage authorities. Marks the start of formal protection obligations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryListingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Listing Reference' ;
    rdfs:comment 'Reference number or identifier if the site is listed on a statutory heritage register maintained by government heritage authorities. Links to official heritage protection instruments.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceDescription rdf:type rdf:Property ;
    rdfs:label 'Significance Description' ;
    rdfs:comment 'Detailed description of the cultural, spiritual, historical, or archaeological significance of the site. Explains why the site is important to the affiliated cultural group and what values it embodies. Confidential to protect sacred knowledge.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Site Area Hectares' ;
    rdfs:comment 'The spatial extent of the heritage site in hectares. Used to calculate buffer zones, exclusion areas, and spatial overlap with mining tenements in GIS systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCondition rdf:type rdf:Property ;
    rdfs:label 'Site Condition' ;
    rdfs:comment 'Current physical condition of the heritage site based on most recent inspection or monitoring. Tracks degradation, damage, or disturbance over time to inform protection measures.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'The name or designation of the cultural heritage site as recognized by the affiliated cultural group or heritage authority. May include traditional language names.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Site Reference Number' ;
    rdfs:comment 'External reference number or code assigned to the heritage site by heritage authorities, archaeological surveys, or internal site numbering systems. Used for cross-referencing with heritage registers and survey reports.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the heritage site record indicating its protection state and management activity level. Active sites require ongoing monitoring and protection measures. [ENUM-REF-CANDIDATE: active|protected|restricted|under assessment|damaged|destroyed|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the cultural heritage site based on its primary cultural or archaeological significance. Determines protection protocols and management requirements. [ENUM-REF-CANDIDATE: sacred site|archaeological site|burial ground|ceremonial area|rock art|historical structure|artifact scatter — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDate rdf:type rdf:Property ;
    rdfs:label 'Survey Date' ;
    rdfs:comment 'The date when the heritage survey or assessment that identified this site was conducted. Important for tracking survey currency and determining if re-assessment is required.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyorName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Name' ;
    rdfs:comment 'Name of the qualified archaeologist, anthropologist, or heritage consultant who conducted the survey and documented the site. Used for professional accountability and follow-up inquiries.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorOrganisation rdf:type rdf:Property ;
    rdfs:label 'Surveyor Organisation' ;
    rdfs:comment 'The consulting firm, university, or heritage authority that employed the surveyor and conducted the heritage assessment. Used for report retrieval and quality assurance.' ;
    rdfs:domain ind:CulturalHeritageSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Engagement plans require a named company employee as accountable officer for stakeholder engagement execution, reporting, and escalation. Enables performance tracking and succession planning for commu' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitSharingArrangement rdf:type rdf:Property ;
    rdfs:label 'Benefit Sharing Arrangement' ;
    rdfs:comment 'Description of benefit-sharing arrangements and community investment programs associated with this engagement plan including royalty agreements, employment commitments, and local procurement initiatives.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated for executing the engagement plan activities including meetings, events, materials, and community investment programs.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'Primary language(s) to be used for stakeholder communication and engagement materials to ensure accessibility and cultural appropriateness.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Cultural Considerations' ;
    rdfs:comment 'Documentation of specific cultural protocols, sensitivities, and considerations that must be observed during stakeholder engagement to ensure respectful and appropriate interaction.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementFrequency rdf:type rdf:Property ;
    rdfs:label 'Engagement Frequency' ;
    rdfs:comment 'Planned frequency of engagement activities with target stakeholder groups defining the cadence of interaction and communication. [ENUM-REF-CANDIDATE: daily|weekly|fortnightly|monthly|quarterly|semi_annual|annual|ad_hoc|event_driven — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementMethods rdf:type rdf:Property ;
    rdfs:label 'Engagement Methods' ;
    rdfs:comment 'Description of the engagement methods and channels to be employed including community meetings, site visits, surveys, focus groups, public consultations, grievance mechanisms, and digital communication platforms.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementObjectives rdf:type rdf:Property ;
    rdfs:label 'Engagement Objectives' ;
    rdfs:comment 'Detailed description of the strategic objectives and intended outcomes of the stakeholder engagement plan aligned to Social Impact Assessment (SIA) commitments and social licence to operate requirements.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Plan Status' ;
    rdfs:comment 'Current lifecycle status of the engagement plan indicating its approval and execution state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpicProcessRequired rdf:type rdf:Property ;
    rdfs:label 'Fpic Process Required' ;
    rdfs:comment 'Indicates whether Free Prior and Informed Consent process is required for this engagement plan in accordance with indigenous peoples rights and international standards.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceMechanismLinked rdf:type rdf:Property ;
    rdfs:label 'Grievance Mechanism Linked' ;
    rdfs:comment 'Indicates whether this engagement plan is linked to and supports the operation of a formal grievance mechanism for stakeholder feedback and complaint resolution.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indigenousEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Indigenous Engagement Flag' ;
    rdfs:comment 'Indicates whether this engagement plan specifically addresses engagement with indigenous peoples and requires Free Prior and Informed Consent (FPIC) processes.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landCompensationLinked rdf:type rdf:Property ;
    rdfs:label 'Land Compensation Linked' ;
    rdfs:comment 'Indicates whether this engagement plan is associated with land acquisition, resettlement, or compensation agreements requiring specific stakeholder consultation and negotiation.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The date when the engagement plan was last reviewed and assessed for effectiveness and alignment with current stakeholder needs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier code for the engagement plan used for external reference and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Descriptive title of the stakeholder engagement plan identifying its purpose and scope.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the engagement plan based on its strategic purpose and scope within the community relations framework.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'The date when the engagement plan period concludes. May be null for ongoing engagement plans without defined end dates.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'The date when the engagement plan period commences and planned activities begin execution.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating the engagement plan to ensure continued relevance and effectiveness.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siaCommitmentAlignment rdf:type rdf:Property ;
    rdfs:label 'Sia Commitment Alignment' ;
    rdfs:comment 'Description of how this engagement plan aligns with and fulfills specific commitments made in the Social Impact Assessment and Environmental Impact Statement (EIS).' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successMetrics rdf:type rdf:Property ;
    rdfs:label 'Success Metrics' ;
    rdfs:comment 'Definition of success metrics and Key Performance Indicators (KPIs) used to measure the effectiveness of the engagement plan including participation rates, satisfaction scores, and grievance resolution times.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStakeholderGroups rdf:type rdf:Property ;
    rdfs:label 'Target Stakeholder Groups' ;
    rdfs:comment 'Identification of the specific stakeholder groups and communities targeted by this engagement plan including indigenous communities, local residents, government authorities, NGOs, and other affected parties.' ;
    rdfs:domain ind:EngagementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpicProcessId rdf:type rdf:Property ;
    rdfs:label 'Fpic Process Id' ;
    rdfs:comment 'Unique identifier for the FPIC process record. Primary key.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:explorationLicenceId rdf:type rdf:Property ;
    rdfs:label 'Exploration Licence Id' ;
    rdfs:comment 'Foreign key linking to exploration.licence. Business justification: FPIC processes are required for exploration licences in indigenous territories. Regulatory compliance, social licence, and legal defensibility depend on tracking which FPIC process applies to which li' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licence .

ind:indigenousGroupStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Indigenous Group Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: FPIC (Free, Prior and Informed Consent) processes are conducted with specific indigenous peoples/groups who are critical stakeholders. Currently indigenous_group_name is text. Normalizing to FK ensure' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:activityRequiringConsent rdf:type rdf:Property ;
    rdfs:label 'Activity Requiring Consent' ;
    rdfs:comment 'Description of the mining activity or project phase requiring FPIC (e.g., exploration drilling, mine development, infrastructure construction, land access).' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the mining activity requiring consent.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisedSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Authorised Signatory Name' ;
    rdfs:comment 'Name of the authorised representative or elder who signed the consent agreement on behalf of the indigenous group.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisedSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Authorised Signatory Title' ;
    rdfs:comment 'Title or role of the authorised signatory within the indigenous group governance structure (e.g., Chief, Elder, Council Representative).' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsAttachedToConsent rdf:type rdf:Property ;
    rdfs:label 'Conditions Attached To Consent' ;
    rdfs:comment 'Specific conditions, requirements, or mitigation measures that the indigenous group has attached to their consent decision.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Consent Decision Date' ;
    rdfs:comment 'Date on which the indigenous group formally provided or withheld consent for the proposed activity.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current status of the FPIC process indicating whether consent has been given, withheld, or is under negotiation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Completion Date' ;
    rdfs:comment 'Date when the consultation phase of the FPIC process was completed.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:culturalHeritageProvisions rdf:type rdf:Property ;
    rdfs:label 'Cultural Heritage Provisions' ;
    rdfs:comment 'Specific provisions agreed to protect cultural heritage sites, sacred areas, and traditional practices within the affected territory.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceMechanismLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Grievance Mechanism Linked Flag' ;
    rdfs:comment 'Indicates whether a grievance mechanism has been established and communicated to the indigenous group as part of the FPIC process.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:independentFacilitatorName rdf:type rdf:Property ;
    rdfs:label 'Independent Facilitator Name' ;
    rdfs:comment 'Name of the independent third-party facilitator or mediator engaged to support the FPIC process, if applicable.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informationDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Information Disclosure Date' ;
    rdfs:comment 'Date when comprehensive project information was disclosed to the indigenous group in culturally appropriate formats and languages.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interpreterProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Provided Flag' ;
    rdfs:comment 'Indicates whether professional interpreters were provided to facilitate communication during the FPIC process.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether the FPIC process and agreement have undergone legal review for compliance with national and international standards.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processInitiationDate rdf:type rdf:Property ;
    rdfs:label 'Process Initiation Date' ;
    rdfs:comment 'Date when the FPIC consultation process was formally initiated with the indigenous group.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Process Reference Number' ;
    rdfs:comment 'Externally-known unique reference code for the FPIC process, used in regulatory reporting and stakeholder communications.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference number for any regulatory submission or disclosure related to this FPIC process (e.g., environmental approval, mining permit application).' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTriggerConditions rdf:type rdf:Property ;
    rdfs:label 'Review Trigger Conditions' ;
    rdfs:comment 'Conditions or events that would trigger a review or renewal of the FPIC process (e.g., material project changes, new impacts identified, time-based review).' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalTerritoryName rdf:type rdf:Property ;
    rdfs:label 'Traditional Territory Name' ;
    rdfs:comment 'Name of the traditional lands, territories, or resources affected by the proposed mining activity.' ;
    rdfs:domain ind:FpicProcess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceId rdf:type rdf:Property ;
    rdfs:label 'Grievance Id' ;
    rdfs:comment 'Unique identifier for the grievance record. Primary key for the grievance entity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grievance .

ind:complainantStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Complainant Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Grievances are lodged BY stakeholders (community members, landowners, traditional owners). The grievance currently stores complainant details as denormalized attributes. Adding complainant_stakeholder' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to hse.corrective_action. Business justification: Community grievances (dust, noise, water quality complaints) generate HSE corrective actions in mining operations. Tracks which corrective action addresses each grievance for closure verification and ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:drillProgramId rdf:type rdf:Property ;
    rdfs:label 'Drill Program Id' ;
    rdfs:comment 'Foreign key linking to exploration.drill_program. Business justification: Drilling activities generate community grievances (noise, dust, water contamination, access disruption). Tracking which drill program caused which grievance is essential for root cause analysis, corre' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrillProgram .

ind:implicatedAssetId rdf:type rdf:Property ;
    rdfs:label 'Implicated Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Mining operations track community grievances about specific equipment (noise from haul trucks, dust from drill rigs, vibration from blasting equipment near settlements). Grievance management systems r' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date when the grievance receipt was formally acknowledged to the complainant. Required under IFC Performance Standard 1 grievance mechanism protocols.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityImplicated rdf:type rdf:Property ;
    rdfs:label 'Activity Implicated' ;
    rdfs:comment 'Specific mining operation, activity, or project phase implicated in the grievance (e.g., drilling, blasting, haulage, construction, exploration).' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date when the grievance was resolved and resolution communicated to the complainant.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the grievance was assigned to a case officer for investigation and resolution.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the grievance case was formally closed after resolution confirmation or withdrawal.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Monetary compensation amount paid or agreed to resolve the grievance, if applicable. Recorded in the operating currency of the site.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation amount (e.g., USD, AUD, ZAR).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Complainant Satisfaction Rating' ;
    rdfs:comment 'Complainant feedback on satisfaction with the grievance handling process and resolution outcome. Collected post-resolution for grievance mechanism effectiveness monitoring.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Current escalation level of the grievance within the organizational hierarchy or external dispute resolution mechanisms.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceCategory rdf:type rdf:Property ;
    rdfs:label 'Grievance Category' ;
    rdfs:comment 'Primary category or type of grievance. Classifies the nature of the complaint for routing, analysis, and reporting. [ENUM-REF-CANDIDATE: noise|dust|water|land_access|employment|cultural_heritage|compensation|blasting|traffic|health_safety|resettlement|environmental_damage|human_rights — promote to reference product]' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceDescription rdf:type rdf:Property ;
    rdfs:label 'Grievance Description' ;
    rdfs:comment 'Detailed narrative description of the grievance as provided by the complainant. Captures the nature of the concern, impact experienced, and complainant expectations.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Status' ;
    rdfs:comment 'Current lifecycle status of the grievance in the resolution process. Tracks progression from receipt through investigation to closure. [ENUM-REF-CANDIDATE: received|under_investigation|pending_response|resolved|closed|withdrawn|escalated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the grievance investigation was completed and findings documented.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when formal investigation of the grievance commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the grievance was lodged anonymously. True if complainant identity is withheld, False if disclosed.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatGrievance rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Grievance' ;
    rdfs:comment 'Indicates whether this grievance is a repeat or recurrence of a previously lodged grievance by the same complainant or community. True if repeat, False if first occurrence.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Description of the specific location or area where the grievance issue occurred or is experienced. May reference mine infrastructure, community areas, or access routes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodgementChannel rdf:type rdf:Property ;
    rdfs:label 'Lodgement Channel' ;
    rdfs:comment 'Channel or method through which the grievance was lodged. Tracks accessibility and effectiveness of grievance mechanism entry points. [ENUM-REF-CANDIDATE: in_person|phone|email|web_portal|community_meeting|suggestion_box|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodgementDate rdf:type rdf:Property ;
    rdfs:label 'Lodgement Date' ;
    rdfs:comment 'Date when the grievance was formally lodged or received by the company. Principal business event timestamp for the grievance lifecycle.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lodgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lodgement Timestamp' ;
    rdfs:comment 'Precise timestamp when the grievance was lodged, including time of day. Used for SLA tracking and response time calculations.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresExternalMediation rdf:type rdf:Property ;
    rdfs:label 'Requires External Mediation' ;
    rdfs:comment 'Indicates whether the grievance requires or has been referred to external mediation or dispute resolution mechanisms. True if external mediation needed, False otherwise.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the actions taken to resolve the grievance, including remedial measures, compensation provided, or operational changes implemented.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome classification of the grievance resolution process. Indicates whether the grievance was resolved to complainant satisfaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityClassification rdf:type rdf:Property ;
    rdfs:label 'Severity Classification' ;
    rdfs:comment 'Severity or priority level assigned to the grievance based on impact assessment. Determines response timeframes and escalation requirements per IFC Performance Standards.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing additional detail on the grievance type. Allows for more granular categorization within primary categories.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date for grievance resolution based on severity classification and Service Level Agreement (SLA) commitments under the grievance mechanism.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grievanceActionId rdf:type rdf:Property ;
    rdfs:label 'Grievance Action Id' ;
    rdfs:comment 'Unique identifier for each grievance action record. Primary key for the grievance action entity.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Grievance resolution actions often involve specific equipment (relocating haul routes away from villages, modifying drill rig operating hours, installing dust suppression on conveyors). Action trackin' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:hseCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Hse Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to hse.corrective_action. Business justification: Specific grievance actions often reference or trigger HSE corrective actions (e.g., install additional dust monitors, increase water cart frequency). Links community relations response to operational ' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date when this grievance action was taken or initiated. Represents the principal business event timestamp for this action record.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative description of the action taken, including steps performed, parties involved, and any observations made during the action execution.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionLocation rdf:type rdf:Property ;
    rdfs:label 'Action Location' ;
    rdfs:comment 'Physical location where the action was conducted (e.g., mine site, community hall, complainant residence, office). Relevant for site inspections and mediation meetings.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the action, typically formatted as a sequential or hierarchical code within the parent grievance (e.g., GRV-2024-001-A01).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOutcome rdf:type rdf:Property ;
    rdfs:label 'Action Outcome' ;
    rdfs:comment 'Summary of the result or finding from this action. Documents what was discovered, agreed, or resolved through this specific response activity.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionSequence rdf:type rdf:Property ;
    rdfs:label 'Action Sequence' ;
    rdfs:comment 'Sequential order of this action within the parent grievance case, enabling chronological tracking of all response activities.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of this grievance action, tracking whether the action has been initiated, is underway, or has been finalized.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise date and time when this grievance action was executed, providing granular tracking for time-sensitive response activities.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Category of action taken in response to the grievance. Defines the nature of the response activity undertaken by the grievance management team. [ENUM-REF-CANDIDATE: acknowledgement|investigation|site_inspection|mediation|stakeholder_consultation|resolution_offer|closure|escalation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when this action was completed, enabling measurement of grievance handling timeliness and SLA compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual financial cost incurred for this action, captured after completion. Used for budget tracking and cost-benefit analysis of grievance management programs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complainantAcceptanceFlag rdf:type rdf:Property ;
    rdfs:label 'Complainant Acceptance Flag' ;
    rdfs:comment 'Indicates whether the complainant accepted the resolution or outcome proposed through this action. Key metric for measuring social licence to operate and grievance mechanism effectiveness.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complainantFeedback rdf:type rdf:Property ;
    rdfs:label 'Complainant Feedback' ;
    rdfs:comment 'Free-text feedback or comments provided by the complainant regarding this action or its outcome, captured to support continuous improvement of grievance handling processes.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complainantNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Complainant Notification Date' ;
    rdfs:comment 'Date when the complainant was informed of this action and its outcome, supporting compliance with grievance mechanism response time commitments.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complainantNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Complainant Notified Flag' ;
    rdfs:comment 'Indicates whether the complainant was formally notified of this action and its outcome. Critical for transparency and procedural fairness tracking.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Explanation of why escalation was required, documenting the complexity, sensitivity, or unresolved nature of the grievance that necessitates higher-level intervention.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated financial cost associated with this action, including compensation offers, remediation expenses, or operational costs. Enables financial tracking of grievance resolution.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceCollected rdf:type rdf:Property ;
    rdfs:label 'Evidence Collected' ;
    rdfs:comment 'Description of evidence, documentation, or materials collected during this action (e.g., photographs, witness statements, site measurements, agreements). Supports audit trail and legal defensibility.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether this action requires subsequent follow-up actions or monitoring to ensure sustained resolution or compliance with commitments made.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether this action or its outcome requires legal review due to potential liability, contractual implications, or regulatory compliance considerations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this record, supporting accountability and audit trail requirements.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeCategory rdf:type rdf:Property ;
    rdfs:label 'Outcome Category' ;
    rdfs:comment 'Categorical classification of the action outcome, enabling structured reporting on grievance resolution effectiveness and patterns.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Full name of the officer responsible for executing this grievance action, captured for audit trail and accountability purposes.' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the operational system from which this grievance action record originated (e.g., IsoMetrix, custom grievance management system, community engagement platform).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholdersConsulted rdf:type rdf:Property ;
    rdfs:label 'Stakeholders Consulted' ;
    rdfs:comment 'List or description of stakeholders consulted during this action (e.g., community leaders, government officials, technical experts, legal counsel).' ;
    rdfs:domain ind:GrievanceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or committed date by which this action should be completed, supporting Service Level Agreement (SLA) tracking for grievance response times.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heritageIncidentId rdf:type rdf:Property ;
    rdfs:label 'Heritage Incident Id' ;
    rdfs:comment 'Unique identifier for the cultural heritage incident record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeritageIncident .

ind:affectedStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Affected Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Heritage incidents impact specific traditional owner groups who are registered as stakeholders. The heritage_incident.traditional_owner_group string attribute should be normalized to a proper FK linki' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:causativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Causative Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Cultural heritage disturbances are typically caused by specific equipment operations (excavator uncovering artefacts, dozer disturbing sacred site, drill rig impacting burial ground). Heritage inciden' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:hseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Id' ;
    rdfs:comment 'Foreign key linking to hse.incident. Business justification: Cultural heritage incidents (artefact disturbance, site damage) are HSE incidents in mining operations. Integrated incident management systems require linking heritage incidents to parent HSE incident' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description of the specific mining or exploration activity that resulted in the heritage incident.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaImpactedHectares rdf:type rdf:Property ;
    rdfs:label 'Area Impacted Hectares' ;
    rdfs:comment 'Total area of the heritage site impacted by the disturbance, measured in hectares.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:artefactsDisturbedCount rdf:type rdf:Property ;
    rdfs:label 'Artefacts Disturbed Count' ;
    rdfs:comment 'Number of cultural artefacts disturbed, damaged, or removed during the incident, if quantifiable.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heritageSiteName rdf:type rdf:Property ;
    rdfs:label 'Heritage Site Name' ;
    rdfs:comment 'Name or designation of the cultural heritage site or area affected by the incident.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageSiteReference rdf:type rdf:Property ;
    rdfs:label 'Heritage Site Reference' ;
    rdfs:comment 'Reference identifier or code for the registered cultural heritage site or area that was impacted, as documented in heritage surveys or registers.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageType rdf:type rdf:Property ;
    rdfs:label 'Heritage Type' ;
    rdfs:comment 'Classification of the type of cultural heritage impacted (e.g., archaeological site, sacred site, burial ground, rock art, artefact). [ENUM-REF-CANDIDATE: archaeological|sacred_site|burial_ground|rock_art|artefact|cultural_landscape|historical_structure|intangible_heritage — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate actions taken upon discovery of the incident to stop further disturbance and secure the site.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactDescription rdf:type rdf:Property ;
    rdfs:label 'Impact Description' ;
    rdfs:comment 'Comprehensive description of the nature and extent of the disturbance or damage to the cultural heritage site or artefact.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the cultural heritage disturbance or impact occurred or was discovered.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the heritage incident, used for regulatory reporting and traditional owner communication.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the heritage incident investigation and remediation process.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Precise date and time when the cultural heritage disturbance or impact occurred or was discovered.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationOutcome rdf:type rdf:Property ;
    rdfs:label 'Investigation Outcome' ;
    rdfs:comment 'Summary of the investigation findings, including root cause analysis and determination of responsibility.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the formal investigation into the heritage incident.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Notification Date' ;
    rdfs:comment 'Date when the regulatory authority was formally notified of the heritage incident.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulator Notified Flag' ;
    rdfs:comment 'Indicates whether the relevant regulatory authority has been formally notified of the heritage incident as required by law.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the government or regulatory body notified and overseeing the incident response and investigation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Date when remediation or restoration activities were completed.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationMeasures rdf:type rdf:Property ;
    rdfs:label 'Remediation Measures' ;
    rdfs:comment 'Description of remediation, restoration, or mitigation measures implemented or planned to address the heritage impact.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation or restoration activities for the impacted heritage site.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who first reported or discovered the heritage incident.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause or contributing factors that led to the heritage incident.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalOwnerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Notification Date' ;
    rdfs:comment 'Date when traditional owners were formally notified of the heritage incident.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:traditionalOwnerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Notified Flag' ;
    rdfs:comment 'Indicates whether the traditional owners or indigenous custodians have been formally notified of the heritage incident.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workStoppageDate rdf:type rdf:Property ;
    rdfs:label 'Work Stoppage Date' ;
    rdfs:comment 'Date when work stoppage was issued for the affected area, if applicable.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workStoppageIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Work Stoppage Issued Flag' ;
    rdfs:comment 'Indicates whether a work stoppage order was issued for the affected area following the incident.' ;
    rdfs:domain ind:HeritageIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investmentProjectId rdf:type rdf:Property ;
    rdfs:label 'Investment Project Id' ;
    rdfs:comment 'Unique identifier for the community investment project. Primary key.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Investment projects require a named employee as project officer for execution accountability, stakeholder coordination, milestone tracking, and benefit verification. Critical for workload management a' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure Amount' ;
    rdfs:comment 'Total actual expenditure incurred to date on the investment project in the reporting currency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alignmentWithSdg rdf:type rdf:Property ;
    rdfs:label 'Alignment With Sdg' ;
    rdfs:comment 'United Nations Sustainable Development Goals that this investment project contributes to (e.g., SDG 1, SDG 4, SDG 8).' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total budget amount approved for the investment project in the reporting currency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryCount rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Count' ;
    rdfs:comment 'Estimated or actual number of individuals or households directly benefiting from the investment project.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverables rdf:type rdf:Property ;
    rdfs:label 'Deliverables' ;
    rdfs:comment 'Description of the tangible outputs and deliverables expected from the investment project.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLocation rdf:type rdf:Property ;
    rdfs:label 'Geographic Location' ;
    rdfs:comment 'Geographic description or coordinates of the project location (village, district, region).' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Summary of key project milestones and their current completion status.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeIndicators rdf:type rdf:Property ;
    rdfs:label 'Outcome Indicators' ;
    rdfs:comment 'Key performance indicators and metrics used to measure the social impact and success of the investment project.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipType rdf:type rdf:Property ;
    rdfs:label 'Partnership Type' ;
    rdfs:comment 'Type of partnership arrangement for project delivery (sole, joint venture, NGO partnership, government partnership, community-led).' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCategory rdf:type rdf:Property ;
    rdfs:label 'Project Category' ;
    rdfs:comment 'Classification of the investment project by type of community benefit (infrastructure, education, health, economic development, environmental, cultural, capacity building). [ENUM-REF-CANDIDATE: infrastructure|education|health|economic_development|environmental|cultural|capacity_building — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Project Completion Date' ;
    rdfs:comment 'Planned or actual completion date of the investment project.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectScope rdf:type rdf:Property ;
    rdfs:label 'Project Scope' ;
    rdfs:comment 'Detailed description of the project scope, objectives, and activities to be undertaken.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Planned or actual start date of the investment project.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the investment project (planned, approved, in progress, on hold, completed, cancelled).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectTitle rdf:type rdf:Property ;
    rdfs:label 'Project Title' ;
    rdfs:comment 'The official name or title of the community investment project.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this investment project record was first created in the system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this investment project record was last updated in the system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Financial or calendar period for which project progress and expenditure are reported.' ;
    rdfs:domain ind:InvestmentProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landownerStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Landowner Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Land compensation agreements are with specific landowners or communities who should be registered stakeholders. Currently stored as text fields (landowner_name, landowner_contact, community_name). Nor' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Land compensation for mine development is capitalized to project WBS elements as pre-production capital expenditure, enabling tracking against capital budget and asset under construction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:agreementDurationYears rdf:type rdf:Property ;
    rdfs:label 'Agreement Duration Years' ;
    rdfs:comment 'Duration of the agreement in years, indicating the period during which land access rights are granted and compensation obligations apply.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementReference rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this land compensation agreement for tracking and legal purposes.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation amount (e.g., USD, AUD, ZAR).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Form of compensation provided to landowners or affected communities, including monetary payments, goods, services, or livelihood support programs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current status of the mining company\'s compliance with the terms and obligations of the land compensation agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Description of the nature, cause, and current state of any dispute or grievance raised by the landowner or community regarding this agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any disputes, grievances, or legal challenges related to this land compensation agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the agreement was formally signed and executed by all parties.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this land compensation agreement is currently active and in force (True) or has been terminated, expired, or superseded (False).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Land Area Hectares' ;
    rdfs:comment 'Total area of land in hectares subject to disturbance, access, or acquisition under this compensation agreement.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landParcelReference rdf:type rdf:Property ;
    rdfs:label 'Land Parcel Reference' ;
    rdfs:comment 'Official cadastral reference, lot number, or geographic identifier for the land parcel covered by this compensation agreement.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landUseType rdf:type rdf:Property ;
    rdfs:label 'Land Use Type' ;
    rdfs:comment 'Primary use or designation of the land prior to mining activities, relevant for determining compensation basis and restoration obligations.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent compensation payment made to the landowner or community under this agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this land compensation agreement record was most recently modified or updated.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:livelihoodProgramDetails rdf:type rdf:Property ;
    rdfs:label 'Livelihood Program Details' ;
    rdfs:comment 'Description of livelihood restoration or alternative income generation programs provided to affected parties to maintain or improve their standard of living.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date on which formal negotiations with the landowner or community commenced for this compensation agreement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Timing and frequency of compensation payments as stipulated in the agreement terms.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationObligations rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Obligations' ;
    rdfs:comment 'Description of land rehabilitation, restoration, or remediation obligations the mining company must fulfill upon completion of activities or agreement termination.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Any special terms, conditions, or obligations attached to the agreement, such as environmental restoration requirements, cultural heritage protections, or access restrictions.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPaidToDate rdf:type rdf:Property ;
    rdfs:label 'Total Paid To Date' ;
    rdfs:comment 'Cumulative total of all compensation payments made to the landowner or community since the agreement\'s execution.' ;
    rdfs:domain ind:LandCompensationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localContentActualId rdf:type rdf:Property ;
    rdfs:label 'Local Content Actual Id' ;
    rdfs:comment 'Unique identifier for the local content actual performance record.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLocalEmploymentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Local Employment Headcount' ;
    rdfs:comment 'The actual number of local employees employed during the reporting period.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLocalSupplierSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Local Supplier Spend Amount' ;
    rdfs:comment 'The actual amount spent on local suppliers during the reporting period.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference to the corrective action plan document or record addressing local content performance gaps.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required to address non-compliance or underperformance against local content commitments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The source system or process from which the actual local content performance data was extracted (e.g., SAP HR, Pronto Xi Procurement, manual survey).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentVarianceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Employment Variance Headcount' ;
    rdfs:comment 'The variance between actual and target local employment headcount (actual minus target).' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employmentVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Employment Variance Percentage' ;
    rdfs:comment 'The variance between actual and target local employment percentage (actual minus target).' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localEmploymentPercentageAchieved rdf:type rdf:Property ;
    rdfs:label 'Local Employment Percentage Achieved' ;
    rdfs:comment 'The percentage of local employment achieved relative to total workforce during the reporting period.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localSpendPercentageAchieved rdf:type rdf:Property ;
    rdfs:label 'Local Spend Percentage Achieved' ;
    rdfs:comment 'The percentage of local supplier spend achieved relative to total procurement spend during the reporting period.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Variance Amount' ;
    rdfs:comment 'The variance between actual and target local supplier spend amount (actual minus target).' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Spend Variance Percentage' ;
    rdfs:comment 'The variance between actual and target local spend percentage (actual minus target).' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'The name of the individual or department that submitted the local content performance report.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocalEmploymentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Target Local Employment Headcount' ;
    rdfs:comment 'The target number of local employees as per the commitment or agreement.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLocalEmploymentPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Local Employment Percentage' ;
    rdfs:comment 'The target percentage of local employment as per the commitment or agreement.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLocalSpendPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Local Spend Percentage' ;
    rdfs:comment 'The target percentage of local supplier spend as per the commitment or agreement.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLocalSupplierSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Target Local Supplier Spend Amount' ;
    rdfs:comment 'The target amount to be spent on local suppliers as per the commitment or agreement.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProcurementSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Procurement Spend Amount' ;
    rdfs:comment 'The total procurement spend during the reporting period, used as the denominator for local spend percentage calculations.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWorkforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Workforce Headcount' ;
    rdfs:comment 'The total workforce headcount during the reporting period, used as the denominator for local employment percentage calculations.' ;
    rdfs:domain ind:LocalContentActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'A detailed explanation of any significant variance between actual and target local content performance, including root causes and corrective actions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The name of the individual or organization that verified the local content performance data.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localEmploymentCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Local Employment Commitment Id' ;
    rdfs:comment 'Unique identifier for the local employment commitment record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocalEmploymentCommitment .

ind:capitalProjectId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Id' ;
    rdfs:comment 'Identifier of the capital project or expansion associated with this commitment, if applicable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'Most recent actual performance figure against the commitment target.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Starting or baseline figure for the commitment metric at the time the commitment was made (e.g., current local employment percentage).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Effective Date' ;
    rdfs:comment 'Date from which the commitment becomes binding and performance tracking begins.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Expiry Date' ;
    rdfs:comment 'Date on which the commitment period ends or the commitment is fulfilled, nullable for ongoing commitments.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentReference rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference' ;
    rdfs:comment 'External business reference number or code for the commitment, used in agreements and reporting.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpicRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fpic Required Flag' ;
    rdfs:comment 'Indicates whether Free Prior and Informed Consent was required for this commitment under indigenous rights frameworks.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fpicStatus rdf:type rdf:Property ;
    rdfs:label 'Fpic Status' ;
    rdfs:comment 'Status of Free Prior and Informed Consent process for this commitment.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indigenousPeoplesFlag rdf:type rdf:Property ;
    rdfs:label 'Indigenous Peoples Flag' ;
    rdfs:comment 'Indicates whether the commitment specifically targets indigenous or traditional owner communities.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the period over which the commitment is measured and reported.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the period over which the commitment is measured and reported.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationActions rdf:type rdf:Property ;
    rdfs:label 'Mitigation Actions' ;
    rdfs:comment 'Description of actions being taken to address underperformance or barriers to meeting the commitment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Variance Percentage' ;
    rdfs:comment 'Percentage variance between actual and target values, calculated as ((actual - target) / target) * 100.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryConditionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Condition Flag' ;
    rdfs:comment 'Indicates whether the commitment is a regulatory or permit condition (true) or a voluntary commitment (false).' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Description of the reporting obligation, including recipient (community, regulator, board) and format.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialLicenceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Social Licence Risk Level' ;
    rdfs:comment 'Risk level to social licence if the commitment is not met, assessed by community relations team.' ;
    rdfs:domain ind:LocalEmploymentCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Target figure or goal for the commitment metric (e.g., 70% local employment, 50 apprenticeships).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit in which the baseline, target, and actual values are expressed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Resettlement Household Id' ;
    rdfs:comment 'Unique identifier for the resettlement household record. Primary key for tracking individual households through the resettlement lifecycle.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalLandParcelId rdf:type rdf:Property ;
    rdfs:label 'Original Land Parcel Id' ;
    rdfs:comment 'Cadastral or land registry identifier for the households original land parcel.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandParcel .

ind:resettlementPlanId rdf:type rdf:Property ;
    rdfs:label 'Resettlement Plan Id' ;
    rdfs:comment 'Reference to the overarching resettlement program under which this household is being resettled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResettlementPlan .

ind:allocatedLandAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Allocated Land Area Hectares' ;
    rdfs:comment 'Total area of replacement land allocated to the household at the resettlement site, measured in hectares.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedPlotNumber rdf:type rdf:Property ;
    rdfs:label 'Allocated Plot Number' ;
    rdfs:comment 'Unique plot or housing unit number allocated to the household at the resettlement site.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Asset Inventory Value' ;
    rdfs:comment 'Total assessed value of household assets including crops, trees, improvements, and other fixed assets subject to compensation.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineAnnualIncome rdf:type rdf:Property ;
    rdfs:label 'Baseline Annual Income' ;
    rdfs:comment 'Estimated total annual household income at baseline prior to resettlement, used for livelihood restoration monitoring.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Compensation Amount' ;
    rdfs:comment 'Total cash compensation amount payable to the household for land, structures, and assets.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:censusDate rdf:type rdf:Property ;
    rdfs:label 'Census Date' ;
    rdfs:comment 'Date on which the household census and asset inventory were conducted, establishing the cut-off date for entitlement eligibility.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Compensation Payment Date' ;
    rdfs:comment 'Date on which final cash compensation was paid to the household.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Payment Status' ;
    rdfs:comment 'Status of cash compensation payments to the household.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary phone number for contacting the household head for monitoring, assistance, and communication purposes.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current status of the households eligibility for resettlement entitlements based on census and verification processes.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementCategory rdf:type rdf:Property ;
    rdfs:label 'Entitlement Category' ;
    rdfs:comment 'Primary category of resettlement entitlement package offered to the household based on impact and preference.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceLodgedFlag rdf:type rdf:Property ;
    rdfs:label 'Grievance Lodged Flag' ;
    rdfs:comment 'Indicates whether the household has lodged any grievance related to the resettlement process or entitlements.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Resolution Status' ;
    rdfs:comment 'Current status of any grievances lodged by the household through the grievance redress mechanism.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdHeadName rdf:type rdf:Property ;
    rdfs:label 'Household Head Name' ;
    rdfs:comment 'Full legal name of the head of household as recorded in the census and used for entitlement registration.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdHeadNationalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Household Head National Identifier' ;
    rdfs:comment 'Government-issued national identification number of the household head for legal verification and entitlement processing.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Household Reference Number' ;
    rdfs:comment 'Externally-known unique reference code assigned to the household for tracking and communication purposes throughout the resettlement process.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Total number of individuals residing in the household at the time of census enumeration.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incomeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Income Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for baseline income and compensation amounts.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indigenousHouseholdFlag rdf:type rdf:Property ;
    rdfs:label 'Indigenous Household Flag' ;
    rdfs:comment 'Indicates whether the household is identified as indigenous or belonging to a traditional community requiring culturally appropriate resettlement measures.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landTenureType rdf:type rdf:Property ;
    rdfs:label 'Land Tenure Type' ;
    rdfs:comment 'Type of land tenure or occupancy right held by the household at the original location, determining entitlement eligibility.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMonitoringDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Date' ;
    rdfs:comment 'Date of the most recent post-resettlement monitoring visit or survey conducted with the household.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:livelihoodRestorationPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Livelihood Restoration Plan Status' ;
    rdfs:comment 'Status of livelihood restoration activities and support measures for the household.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPhase rdf:type rdf:Property ;
    rdfs:label 'Monitoring Phase' ;
    rdfs:comment 'Current phase of post-resettlement monitoring for tracking household outcomes and livelihood restoration progress.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAddress rdf:type rdf:Property ;
    rdfs:label 'Original Address' ;
    rdfs:comment 'Full address of the households original residence prior to resettlement, used for asset verification and entitlement calculation.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalVillageName rdf:type rdf:Property ;
    rdfs:label 'Original Village Name' ;
    rdfs:comment 'Name of the village or settlement from which the household is being displaced.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLivelihoodSource rdf:type rdf:Property ;
    rdfs:label 'Primary Livelihood Source' ;
    rdfs:comment 'Main source of household income or livelihood at baseline, used for livelihood restoration planning. [ENUM-REF-CANDIDATE: agriculture|livestock|fishing|mining|trade|wage_employment|artisan|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationDate rdf:type rdf:Property ;
    rdfs:label 'Relocation Date' ;
    rdfs:comment 'Actual date on which the household physically relocated from the original location to the resettlement site.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relocationStatus rdf:type rdf:Property ;
    rdfs:label 'Relocation Status' ;
    rdfs:comment 'Current status of the households physical relocation process.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementSiteName rdf:type rdf:Property ;
    rdfs:label 'Resettlement Site Name' ;
    rdfs:comment 'Name of the resettlement site or host community where the household has been allocated a plot or housing unit.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureReplacementValue rdf:type rdf:Property ;
    rdfs:label 'Structure Replacement Value' ;
    rdfs:comment 'Assessed replacement cost of the households dwelling structure at full replacement value without depreciation.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structureType rdf:type rdf:Property ;
    rdfs:label 'Structure Type' ;
    rdfs:comment 'Classification of the households dwelling structure at the original location, used for replacement cost calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEntitlementValue rdf:type rdf:Property ;
    rdfs:label 'Total Entitlement Value' ;
    rdfs:comment 'Total calculated value of all resettlement entitlements due to the household including compensation, assistance, and support measures.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vulnerabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Category' ;
    rdfs:comment 'Primary category of vulnerability for households requiring additional assistance or enhanced entitlements.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerableHouseholdFlag rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Household Flag' ;
    rdfs:comment 'Indicates whether the household is classified as vulnerable based on criteria such as female-headed, elderly, disabled members, or extreme poverty.' ;
    rdfs:domain ind:ResettlementHousehold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadConsultantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Consultant Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When resettlement planning is led by internal staff (common for smaller plans or monitoring phases), tracking the lead consultant ensures accountability, competency verification, and IFC PS5 complianc' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedHouseholdsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Households Count' ;
    rdfs:comment 'Total number of households requiring resettlement or economic displacement compensation under this plan.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedPersonsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Persons Count' ;
    rdfs:comment 'Total number of individuals (persons) impacted by the resettlement plan, including all household members.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Name of the government department, ministry, or agency responsible for approving the resettlement plan.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationFramework rdf:type rdf:Property ;
    rdfs:label 'Compensation Framework' ;
    rdfs:comment 'Description of the compensation methodology, including valuation approach, entitlement matrix, and payment mechanisms for land, assets, and livelihoods.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceMechanismReference rdf:type rdf:Property ;
    rdfs:label 'Grievance Mechanism Reference' ;
    rdfs:comment 'Reference to the grievance mechanism established for affected persons to raise complaints and seek redress related to resettlement.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifcPs5ComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ifc Ps5 Compliance Status' ;
    rdfs:comment 'Assessment of whether the resettlement plan meets IFC Performance Standard 5 requirements for land acquisition and involuntary resettlement, critical for project financing.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'Planned or actual date when all resettlement activities, including livelihood restoration and monitoring, are completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'Planned or actual date when resettlement plan implementation activities commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indigenousPeoplesAffectedFlag rdf:type rdf:Property ;
    rdfs:label 'Indigenous Peoples Affected Flag' ;
    rdfs:comment 'Indicates whether indigenous peoples or ethnic minorities are among the affected population, triggering additional consultation and consent requirements.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landAreaAcquiredHectares rdf:type rdf:Property ;
    rdfs:label 'Land Area Acquired Hectares' ;
    rdfs:comment 'Total land area in hectares acquired from affected communities for mining operations, triggering this resettlement plan.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:livelihoodRestorationStrategy rdf:type rdf:Property ;
    rdfs:label 'Livelihood Restoration Strategy' ;
    rdfs:comment 'Summary of the strategy to restore or improve livelihoods and income levels of displaced persons, including training, employment, and business support programs.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Frequency of monitoring and reporting on resettlement plan implementation progress and livelihood restoration outcomes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMonitoringDate rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Date' ;
    rdfs:comment 'Scheduled date for the next monitoring assessment of resettlement plan implementation and outcomes.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Plan Document Location' ;
    rdfs:comment 'File path or document management system reference to the full resettlement plan document and supporting annexes.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the resettlement plan, used in regulatory submissions and stakeholder communications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the resettlement plan in the regulatory approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|under consultation|submitted for approval|approved|implementation in progress|completed|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when the resettlement plan received formal approval from the government regulatory authority.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of the resettlement plan in the government regulatory approval process.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date when the resettlement plan was formally submitted to the relevant government authority for review and approval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resettlementSiteCoordinates rdf:type rdf:Property ;
    rdfs:label 'Resettlement Site Coordinates' ;
    rdfs:comment 'Geographic coordinates (latitude, longitude) of the resettlement site for GIS mapping and monitoring.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Resettlement Site Location' ;
    rdfs:comment 'Geographic location description of the resettlement site, including district, region, and proximity to services.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementType rdf:type rdf:Property ;
    rdfs:label 'Resettlement Type' ;
    rdfs:comment 'Classification of resettlement impact: physical relocation (households must move), economic displacement (loss of livelihood without relocation), or combined.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCompensationBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Compensation Budget Amount' ;
    rdfs:comment 'Total budgeted amount allocated for all compensation payments, livelihood restoration, and resettlement implementation costs.' ;
    rdfs:domain ind:ResettlementPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Security Incident Id' ;
    rdfs:comment 'Unique identifier for the security incident record. Primary key.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigatingOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigating Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Security incidents require a named employee as investigating officer for root cause analysis, VPSHR compliance assessment, and follow-up action coordination. Critical for accountability and competency' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:involvedAssetId rdf:type rdf:Property ;
    rdfs:label 'Involved Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Security incidents at mine sites frequently involve equipment (theft of light vehicles, damage to parked haul trucks, unauthorized use of dozers, fuel theft from excavators). Security investigation an' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:involvedStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Involved Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Security incidents involving community members should link to the stakeholder register for proper tracking and relationship management. The security_incident.parties_involved string attribute suggests' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:communityAreaFlag rdf:type rdf:Property ;
    rdfs:label 'Community Area Flag' ;
    rdfs:comment 'Indicates whether the incident occurred in a community area adjacent to mine operations (True) or within mine operational boundaries (False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communityMemberInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Community Member Involved Flag' ;
    rdfs:comment 'Indicates whether community members were involved in the security incident (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Loss Amount' ;
    rdfs:comment 'Estimated financial loss resulting from the security incident, including theft, property damage, and operational disruption.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatalitiesReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Fatalities Reported Flag' ;
    rdfs:comment 'Indicates whether any fatalities occurred as a result of the security incident (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'Description of follow-up actions taken or planned in response to the security incident, including corrective measures, stakeholder engagement, and policy changes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the security incident. Categories include illegal mining (artisanal and small-scale mining intrusions), trespass, theft, civil unrest, security force interactions with community members, and vandalism.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuriesReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Injuries Reported Flag' ;
    rdfs:comment 'Indicates whether any injuries were reported as a result of the security incident (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Classification of the severity of injuries sustained during the incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement authorities were notified of the security incident (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementReference rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Reference' ;
    rdfs:comment 'Reference number or case identifier assigned by law enforcement authorities for the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Loss Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated loss amount.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Media Coverage Flag' ;
    rdfs:comment 'Indicates whether the security incident received media coverage or public attention (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfFatalities rdf:type rdf:Property ;
    rdfs:label 'Number Of Fatalities' ;
    rdfs:comment 'Total count of fatalities resulting from the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfIndividualsInvolved rdf:type rdf:Property ;
    rdfs:label 'Number Of Individuals Involved' ;
    rdfs:comment 'Count of individuals involved in the security incident, including perpetrators, victims, and witnesses.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfInjuries rdf:type rdf:Property ;
    rdfs:label 'Number Of Injuries' ;
    rdfs:comment 'Total count of individuals injured during the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partiesInvolved rdf:type rdf:Property ;
    rdfs:label 'Parties Involved' ;
    rdfs:comment 'Description of the parties involved in the security incident, including community members, security personnel, contractors, or other stakeholders.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyDamageDescription rdf:type rdf:Property ;
    rdfs:label 'Property Damage Description' ;
    rdfs:comment 'Description of property damage sustained during the incident, including affected assets and estimated impact.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyDamageFlag rdf:type rdf:Property ;
    rdfs:label 'Property Damage Flag' ;
    rdfs:comment 'Indicates whether property damage occurred during the security incident (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory report submitted in relation to the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the security incident requires formal reporting to regulatory authorities (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the individual who reported the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByRole rdf:type rdf:Property ;
    rdfs:label 'Reported By Role' ;
    rdfs:comment 'Role or position of the individual who reported the security incident.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the security incident was officially reported to management or authorities.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityForceType rdf:type rdf:Property ;
    rdfs:label 'Security Force Type' ;
    rdfs:comment 'Type of security force that responded to the incident: private security contractors, public security (police/military), mine internal security, or joint response.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityResponseDescription rdf:type rdf:Property ;
    rdfs:label 'Security Response Description' ;
    rdfs:comment 'Detailed description of the security response actions taken in response to the incident, including personnel deployed, tactics used, and timeline of response.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useOfForceDescription rdf:type rdf:Property ;
    rdfs:label 'Use Of Force Description' ;
    rdfs:comment 'Detailed description of the type and level of force used during the security response, if applicable.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useOfForceFlag rdf:type rdf:Property ;
    rdfs:label 'Use Of Force Flag' ;
    rdfs:comment 'Indicates whether force was used by security personnel during the incident response (True/False).' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vpshrAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Vpshr Assessment Notes' ;
    rdfs:comment 'Detailed notes and findings from the VPSHR compliance assessment, including any violations or areas of concern.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vpshrComplianceAssessment rdf:type rdf:Property ;
    rdfs:label 'Vpshr Compliance Assessment' ;
    rdfs:comment 'Assessment of whether the security response and incident handling complied with the Voluntary Principles on Security and Human Rights framework.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitId rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Id' ;
    rdfs:comment 'Foreign key linking to hse.environmental_permit. Business justification: SIAs reference environmental permits as they assess combined social-environmental impacts of permitted activities. Regulatory requirement in mining jurisdictions for integrated impact assessment. Link' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalPermit .

ind:leadAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Assessor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: When SIAs are conducted by internal staff (common for baseline updates and monitoring), tracking the lead assessor ensures accountability, quality control, and competency verification for regulatory c' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resourceEstimateId rdf:type rdf:Property ;
    rdfs:label 'Resource Estimate Id' ;
    rdfs:comment 'Foreign key linking to exploration.resource_estimate. Business justification: Resource estimates trigger SIA updates and inform impact magnitude predictions (employment, infrastructure, resettlement scale). Project approval and financing require linking SIAs to the resource est' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceEstimate .

ind:resourceStatementId rdf:type rdf:Property ;
    rdfs:label 'Resource Statement Id' ;
    rdfs:comment 'Foreign key linking to geology.resource_statement. Business justification: Resource statements trigger SIA requirements under mining regulations. Regulatory submissions link resource declarations to impact assessments for approval. Real business process: regulatory complianc' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceStatement .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to hse.risk_assessment. Business justification: SIAs incorporate HSE risk assessments for activities affecting communities (blasting, dust, noise, water discharge). Standard practice in mining to integrate technical risk assessment into social impa' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:affectedCommunities rdf:type rdf:Property ;
    rdfs:label 'Affected Communities' ;
    rdfs:comment 'List or description of communities, indigenous groups, and stakeholder populations identified as directly or indirectly affected by the project.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name of the regulatory body, government agency, or internal authority that approved the social impact assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'Date on which the social impact assessment report was finalized and delivered.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'External reference number or document identifier assigned to this SIA for regulatory and internal tracking purposes.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Detailed description of the scope of the social impact assessment, including geographic boundaries, communities covered, and aspects evaluated.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'Date on which the social impact assessment fieldwork and data collection commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the social impact assessment: draft, under review, approved, submitted to regulators, rejected, active (being implemented), or closed. [ENUM-REF-CANDIDATE: draft|under_review|approved|submitted|rejected|active|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTitle rdf:type rdf:Property ;
    rdfs:label 'Assessment Title' ;
    rdfs:comment 'The formal title or name of the social impact assessment document.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'The category of social impact assessment being conducted: baseline study, impact assessment, management plan, monitoring report, closure assessment, or cumulative impact assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineSocialConditions rdf:type rdf:Property ;
    rdfs:label 'Baseline Social Conditions' ;
    rdfs:comment 'Summary of the baseline social, economic, and cultural conditions of affected communities prior to project activities, including demographics, livelihoods, infrastructure, and cultural heritage.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freePriorInformedConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Free Prior Informed Consent Required' ;
    rdfs:comment 'Indicates whether Free, Prior, and Informed Consent (FPIC) is required from indigenous communities as part of the social impact assessment and project approval process.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactSignificanceRating rdf:type rdf:Property ;
    rdfs:label 'Impact Significance Rating' ;
    rdfs:comment 'Overall significance rating of the identified social impacts based on magnitude, duration, reversibility, and affected population: negligible, minor, moderate, major, or critical.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indigenousPeoplesInvolved rdf:type rdf:Property ;
    rdfs:label 'Indigenous Peoples Involved' ;
    rdfs:comment 'Indicates whether indigenous peoples or traditional landowners are among the affected stakeholders, triggering additional consultation and consent requirements.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Mitigation Measures' ;
    rdfs:comment 'Detailed description of mitigation, management, and enhancement measures proposed to address identified negative impacts and maximize positive impacts.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringCommitments rdf:type rdf:Property ;
    rdfs:label 'Monitoring Commitments' ;
    rdfs:comment 'Description of ongoing monitoring and reporting commitments to track the effectiveness of mitigation measures and the evolution of social impacts over the project lifecycle.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negativeImpactsIdentified rdf:type rdf:Property ;
    rdfs:label 'Negative Impacts Identified' ;
    rdfs:comment 'Description of anticipated negative social impacts such as displacement, loss of livelihoods, cultural disruption, increased cost of living, health and safety risks, and social conflict.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positiveImpactsIdentified rdf:type rdf:Property ;
    rdfs:label 'Positive Impacts Identified' ;
    rdfs:comment 'Description of anticipated positive social impacts such as employment opportunities, infrastructure development, local procurement, and community investment benefits.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Resettlement Action Plan Reference' ;
    rdfs:comment 'Reference number or identifier of the associated Resettlement Action Plan (RAP) if resettlement is required.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resettlementRequired rdf:type rdf:Property ;
    rdfs:label 'Resettlement Required' ;
    rdfs:comment 'Indicates whether physical or economic displacement and resettlement of communities is required as a result of the project, triggering a Resettlement Action Plan (RAP).' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderEngagementSummary rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Engagement Summary' ;
    rdfs:comment 'Summary of stakeholder consultation and engagement activities conducted during the assessment, including community meetings, focus groups, and feedback received.' ;
    rdfs:domain ind:SocialImpactAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialLicenceIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Social Licence Indicator Id' ;
    rdfs:comment 'Unique identifier for the social licence to operate indicator measurement record.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionRequired rdf:type rdf:Property ;
    rdfs:label 'Action Required' ;
    rdfs:comment 'Indicates whether immediate action or intervention is required based on this social licence indicator measurement.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'The name of the individual or lead assessor who conducted or coordinated this social licence indicator measurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganisation rdf:type rdf:Property ;
    rdfs:label 'Assessor Organisation' ;
    rdfs:comment 'The name of the organisation that conducted the assessment, particularly relevant for third-party assessments.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percent' ;
    rdfs:comment 'The statistical confidence level associated with this measurement, indicating the reliability of the results.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Indicator Category' ;
    rdfs:comment 'The category of the indicator, classifying whether it measures perception, behaviour, outcome, or impact.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorType rdf:type rdf:Property ;
    rdfs:label 'Indicator Type' ;
    rdfs:comment 'The type of social licence to operate indicator being measured, such as trust level, acceptance level, approval level, grievance rate, engagement participation rate, or community sentiment.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indigenousPeoplesIncluded rdf:type rdf:Property ;
    rdfs:label 'Indigenous Peoples Included' ;
    rdfs:comment 'Indicates whether indigenous peoples were included in this social licence indicator measurement.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'A summary of the key findings from this social licence indicator measurement, highlighting significant insights or concerns.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginOfErrorPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Of Error Percent' ;
    rdfs:comment 'The margin of error associated with this measurement, indicating the range of uncertainty in the results.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The specific date when the measurement or assessment was conducted.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The frequency at which this social licence indicator is measured, such as monthly, quarterly, semi-annually, annually, or ad-hoc.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to measure this social licence indicator, such as survey, focus group, third-party assessment, community meeting, stakeholder interview, or media analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMeasurementDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Measurement Due Date' ;
    rdfs:comment 'The scheduled date for the next measurement of this social licence indicator.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousPeriodScore rdf:type rdf:Property ;
    rdfs:label 'Previous Period Score' ;
    rdfs:comment 'The score from the previous measurement period for comparison and trend analysis.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'The qualitative rating assigned to this social licence indicator based on the score, such as excellent, good, fair, poor, or critical.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'The recommended actions or interventions to address issues identified in this social licence indicator measurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'The reference number or identifier of the detailed report or documentation associated with this social licence indicator measurement.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'The percentage of invited participants who responded or participated in the measurement activity.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The number of respondents, participants, or data points included in the measurement of this indicator.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'The numerical score or rating assigned to this social licence indicator, typically on a standardized scale (e.g., 0-100 or 1-5).' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreScaleMaximum rdf:type rdf:Property ;
    rdfs:label 'Score Scale Maximum' ;
    rdfs:comment 'The maximum value of the scale used for this indicator score.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreScaleMinimum rdf:type rdf:Property ;
    rdfs:label 'Score Scale Minimum' ;
    rdfs:comment 'The minimum value of the scale used for this indicator score.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stakeholderGroupsIncluded rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Groups Included' ;
    rdfs:comment 'The stakeholder groups that participated in or were assessed as part of this measurement, such as indigenous peoples, local residents, business owners, or NGOs.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetScore rdf:type rdf:Property ;
    rdfs:label 'Target Score' ;
    rdfs:comment 'The target or desired score for this social licence indicator as defined by the community relations strategy.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyVerified rdf:type rdf:Property ;
    rdfs:label 'Third Party Verified' ;
    rdfs:comment 'Indicates whether this social licence indicator measurement was verified or validated by an independent third party.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The direction of the trend for this indicator compared to previous measurement periods, indicating whether the social licence is improving, stable, or declining.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromPreviousPeriod rdf:type rdf:Property ;
    rdfs:label 'Variance From Previous Period' ;
    rdfs:comment 'The numerical variance between the current score and the previous period score, indicating the magnitude of change.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'The numerical variance between the current score and the target score, indicating performance against objectives.' ;
    rdfs:domain ind:SocialLicenceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for formal communications with the stakeholder organisation or representative.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Name of the primary contact person or representative for the stakeholder entity. May be a community elder, tribal leader, NGO director, or government official.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the stakeholder contact person or organisation office.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementFrequencyRequired rdf:type rdf:Property ;
    rdfs:label 'Engagement Frequency Required' ;
    rdfs:comment 'Minimum required frequency of formal engagement with the stakeholder based on their influence level, interest level, and regulatory requirements. High-influence indigenous groups may require monthly engagement, while tertiary stakeholders may only need annual updates.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current state of engagement relationship with the stakeholder. Active indicates ongoing engagement, inactive for dormant relationships, pending for newly identified stakeholders awaiting first contact, suspended for temporarily paused engagement, closed for permanently concluded relationships.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpicObtainedDate rdf:type rdf:Property ;
    rdfs:label 'Fpic Obtained Date' ;
    rdfs:comment 'Date on which Free Prior and Informed Consent was formally obtained from the indigenous stakeholder group. Critical compliance milestone for indigenous engagement.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grievanceMechanismRegistered rdf:type rdf:Property ;
    rdfs:label 'Grievance Mechanism Registered' ;
    rdfs:comment 'Indicates whether the stakeholder has been formally registered in the grievance and complaints management system and informed of their rights to raise concerns.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indigenousStatus rdf:type rdf:Property ;
    rdfs:label 'Indigenous Status' ;
    rdfs:comment 'Indicates whether the stakeholder is an indigenous or aboriginal group with native title or traditional ownership rights. Critical for compliance with indigenous rights frameworks and free prior informed consent protocols.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:influenceLevel rdf:type rdf:Property ;
    rdfs:label 'Influence Level' ;
    rdfs:comment 'Assessment of the stakeholder\'s ability to affect project outcomes, regulatory approvals, or social licence to operate. High influence stakeholders can significantly impact operations through regulatory authority, community mobilisation, or media influence.' ;
    rdfs:domain ind:Community ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestLevel rdf:type rdf:Property ;
    rdfs:label 'Interest Level' ;
    rdfs:comment 'Assessment of the stakeholder\'s level of concern or interest in mining operations and their outcomes. High interest indicates direct impact on livelihoods, land, or community wellbeing.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landCompensationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Land Compensation Agreement Status' ;
    rdfs:comment 'Status of land compensation or benefit-sharing agreements with the stakeholder. Not applicable for stakeholders without land claims, in negotiation for active discussions, executed for signed agreements, completed for fully delivered compensation, disputed for contested arrangements.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Date' ;
    rdfs:comment 'Date of the most recent formal engagement activity with the stakeholder, including meetings, consultations, community forums, or site visits.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when the stakeholder record was last modified or updated with new information.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaProfile rdf:type rdf:Property ;
    rdfs:label 'Media Profile' ;
    rdfs:comment 'Assessment of the stakeholder\'s media presence and ability to influence public opinion. High media profile stakeholders can generate significant press coverage and shape public perception of mining operations.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Engagement Date' ;
    rdfs:comment 'Date of the next planned engagement activity with the stakeholder. Used for engagement planning and ensuring regular consultation frequency.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oppositionLevel rdf:type rdf:Property ;
    rdfs:label 'Opposition Level' ;
    rdfs:comment 'Current stance of the stakeholder toward mining operations. Supportive indicates endorsement, neutral indicates no strong position, concerned indicates reservations but not opposition, opposed indicates disagreement with operations, actively opposed indicates organised resistance or advocacy against the project.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationSize rdf:type rdf:Property ;
    rdfs:label 'Population Size' ;
    rdfs:comment 'Estimated number of individuals represented by this stakeholder entity. For communities, total population count. For organisations, number of members or constituents represented.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalAddress rdf:type rdf:Property ;
    rdfs:label 'Postal Address' ;
    rdfs:comment 'Full postal address for written correspondence with the stakeholder entity or representative.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'Stakeholder\'s preferred method for receiving communications and engagement. In-person meetings and community forums are common for indigenous and local communities, while email and phone may be preferred by NGOs and government bodies. [ENUM-REF-CANDIDATE: in_person_meeting|community_forum|phone|email|letter|radio|sms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Primary language spoken by the stakeholder community or organisation. Critical for culturally appropriate communication and translation requirements.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proximityToOperationsKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Operations Km' ;
    rdfs:comment 'Distance in kilometers from the stakeholder\'s primary location to the nearest mine site boundary. Used to assess direct impact zones and prioritise engagement intensity.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialInvestmentRecipient rdf:type rdf:Property ;
    rdfs:label 'Social Investment Recipient' ;
    rdfs:comment 'Indicates whether the stakeholder is a recipient of community investment programs such as education, health, infrastructure, or livelihood support initiatives funded by the mining operation.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:socialLicenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Social Licence Risk Rating' ;
    rdfs:comment 'Assessment of the risk this stakeholder poses to the mining operation\'s social licence to operate. Critical rating indicates stakeholder opposition could halt operations, high indicates significant project delays possible, medium indicates manageable concerns, low indicates supportive or neutral stance.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderCategory rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Category' ;
    rdfs:comment 'Hierarchical classification based on proximity to operations and impact level. Primary stakeholders are directly affected by mining activities, secondary are indirectly affected, key stakeholders have significant influence, tertiary have minimal direct impact.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderName rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Name' ;
    rdfs:comment 'Full legal or registered name of the stakeholder entity or individual. For indigenous groups, traditional community names. For NGOs and government bodies, official registered name.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderType rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Type' ;
    rdfs:comment 'Primary classification of the stakeholder entity. Distinguishes between local communities, indigenous groups, individual landowners, non-governmental organisations, government bodies, and advocacy organisations.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalOwnerStatus rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Status' ;
    rdfs:comment 'Indicates whether the stakeholder holds traditional ownership or native title rights over land affected by mining operations. Used to identify parties requiring specific consultation and consent protocols.' ;
    rdfs:domain ind:Stakeholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderContactId rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Contact Id' ;
    rdfs:comment 'Unique identifier for the stakeholder contact record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StakeholderContact .

ind:agreementSignatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Agreement Signatory Flag' ;
    rdfs:comment 'Indicates whether this contact person is authorised to sign formal agreements, compensation arrangements, or benefit-sharing contracts on behalf of their organisation.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorisationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorisation Level' ;
    rdfs:comment 'Level of authority this contact person holds for signing agreements, making decisions, or representing their organisation in formal negotiations.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationRecipientFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Recipient Flag' ;
    rdfs:comment 'Indicates whether this contact person is a recipient of land compensation, resettlement payments, or other financial benefits from the mining operation.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date on which the contact person provided consent to be contacted and have their information stored in the stakeholder engagement system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentToContactFlag rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact Flag' ;
    rdfs:comment 'Indicates whether the contact person has provided explicit consent to be contacted for engagement purposes. Ensures compliance with privacy and data protection regulations.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactFamilyName rdf:type rdf:Property ;
    rdfs:label 'Contact Family Name' ;
    rdfs:comment 'Family name (surname) of the contact person.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFullName rdf:type rdf:Property ;
    rdfs:label 'Contact Full Name' ;
    rdfs:comment 'Full legal name of the individual contact person representing the stakeholder organisation or community group.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactGivenName rdf:type rdf:Property ;
    rdfs:label 'Contact Given Name' ;
    rdfs:comment 'Given name (first name) of the contact person.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current status of the contact person in the stakeholder engagement system. Tracks whether the contact is actively engaged or no longer available.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact person based on their role in stakeholder engagement (e.g., primary liaison, secondary contact, emergency contact, technical advisor, legal representative).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalProtocolNotes rdf:type rdf:Property ;
    rdfs:label 'Cultural Protocol Notes' ;
    rdfs:comment 'Free-text notes documenting cultural protocols, customs, or sensitivities to observe when engaging with this contact person (e.g., gender-specific engagement requirements, ceremonial considerations, appropriate meeting times).' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date on which this contact record is scheduled for review or deletion in accordance with data retention policies and privacy regulations.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatusWithCompany rdf:type rdf:Property ;
    rdfs:label 'Employment Status With Company' ;
    rdfs:comment 'Indicates whether the contact person is currently or was previously employed by the mining company, or is a contractor. Used to identify potential conflicts of interest or dual relationships.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementHistorySummary rdf:type rdf:Property ;
    rdfs:label 'Engagement History Summary' ;
    rdfs:comment 'High-level summary of past engagement activities, meetings, and interactions with this contact person. Provides context for relationship continuity.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender of the contact person. Captured to support culturally appropriate engagement practices and gender-sensitive consultation requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpreterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Required Flag' ;
    rdfs:comment 'Indicates whether an interpreter or translator is required for effective communication with this contact person.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent engagement activity or communication with this contact person. Used to track relationship currency and identify contacts requiring re-engagement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile telephone number for the contact person, used for urgent or field-based communication.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Contact Date' ;
    rdfs:comment 'Date of the next planned engagement activity or meeting with this contact person. Supports proactive relationship management.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officePhone rdf:type rdf:Property ;
    rdfs:label 'Office Phone' ;
    rdfs:comment 'Office or business telephone number for the contact person.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Preferred method of communication for this contact person (e.g., email, phone, in-person meetings, postal mail).' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Preferred language for communication with this contact person. Uses ISO 639-1 two-letter language codes (e.g., EN, FR, ES) or full language names for indigenous languages.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredMeetingLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Meeting Location' ;
    rdfs:comment 'Preferred location for face-to-face meetings with this contact person (e.g., community hall, mine site office, traditional meeting place).' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for contacting this individual. Main channel for formal communication and engagement correspondence.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for reaching the contact person. Includes country code and area code.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Qualitative score (1-10) assessing the strength and quality of the relationship with this contact person. Used for social licence to operate risk assessment.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'Job title or role of the contact person within their organisation or community group (e.g., Chief, Elder, President, Community Liaison Officer).' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternative email address for the contact person, used for backup communication or personal correspondence.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Flag' ;
    rdfs:comment 'Indicates whether the contact person is recognised as a traditional owner or custodian of land affected by mining operations. Critical for land access and compensation negotiations.' ;
    rdfs:domain ind:StakeholderContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Unique identifier for the bank account record. Primary key.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterpartyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Id' ;
    rdfs:comment 'Reference to the customer or counterparty who owns this bank account. Links to steel mills, smelters, energy companies, commodity traders, and other offtake partners.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Must match customer legal name for payment reconciliation and anti-money laundering compliance.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The bank account number used for payment processing and financial settlement. May be domestic account number or IBAN depending on jurisdiction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current operational status of the bank account record. Only active accounts can be used for payment processing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the bank account type. Corporate and current accounts are most common for commodity trading settlements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line1' ;
    rdfs:comment 'First line of the bank branch physical address. Required for letter of credit documentation and compliance verification.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Bank Address Line2' ;
    rdfs:comment 'Second line of the bank branch physical address for additional location details.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCity rdf:type rdf:Property ;
    rdfs:label 'Bank City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the bank location. Critical for compliance with international trade finance regulations and sanctions screening.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full legal name of the financial institution holding the account.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankPostalCode rdf:type rdf:Property ;
    rdfs:label 'Bank Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the bank branch address.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStateProvince rdf:type rdf:Property ;
    rdfs:label 'Bank State Province' ;
    rdfs:comment 'State or province of the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this bank account becomes valid for payment processing. Supports time-bound account changes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this bank account remains valid. Null indicates no expiration. Used for account closure or replacement scenarios.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for cross-border payments. Used primarily for European and international commodity transactions under CIF and FOB terms.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediaryBankName rdf:type rdf:Property ;
    rdfs:label 'Intermediary Bank Name' ;
    rdfs:comment 'Name of intermediary or correspondent bank used for routing international payments when direct settlement is not available.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intermediarySwiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Intermediary Swift Bic Code' ;
    rdfs:comment 'SWIFT BIC code of the intermediary bank for multi-hop international wire transfers.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary bank account for the customer. Used as default for payment routing in ERP systems.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctionsScreened rdf:type rdf:Property ;
    rdfs:label 'Is Sanctions Screened' ;
    rdfs:comment 'Indicates whether the bank and account holder have been screened against international sanctions lists (OFAC, UN, EU). Mandatory for international commodity trading compliance.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'Pipe-separated list of payment methods supported by this account. Critical for FOB and CIF transaction settlement routing.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Domestic routing number for bank transfers. Format varies by country (ABA routing number in USA, sort code in UK, BSB in Australia).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date of most recent sanctions screening. Must be refreshed periodically per compliance policy.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special payment routing instructions, reference codes, or beneficiary notifications required by the customer or bank.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBicCode rdf:type rdf:Property ;
    rdfs:label 'Swift Bic Code' ;
    rdfs:comment 'SWIFT BIC code identifying the bank and branch for international wire transfers and letter of credit processing in commodity sales.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of bank account verification process. Verified accounts have passed validation checks including test deposits or third-party verification services.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialInteractionId rdf:type rdf:Property ;
    rdfs:label 'Commercial Interaction Id' ;
    rdfs:comment 'Unique identifier for the commercial interaction record. Primary key for the commercial interaction entity.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCounterpartyContactCounterpartyContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Counterparty Contact Counterparty Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty_contact. Business justification: Commercial interactions are conducted with specific contact persons at the counterparty organization. The current design stores contact name and role as text fields, which is denormalized. Adding FK t' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyContact .

ind:additionalCounterpartyParticipants rdf:type rdf:Property ;
    rdfs:label 'Additional Counterparty Participants' ;
    rdfs:comment 'Comma-separated list of additional counterparty representatives who participated in the commercial interaction. Supports relationship breadth analysis.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:additionalInternalParticipants rdf:type rdf:Property ;
    rdfs:label 'Additional Internal Participants' ;
    rdfs:comment 'Comma-separated list of additional internal employees who participated in the commercial interaction. Supports multi-stakeholder engagement tracking.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDiscussed rdf:type rdf:Property ;
    rdfs:label 'Commodity Discussed' ;
    rdfs:comment 'Primary mineral commodity or product that was the focus of the commercial interaction. Aligns with the mining company\'s core product portfolio. [ENUM-REF-CANDIDATE: iron_ore|copper|coal|lithium|nickel|mixed|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Flag' ;
    rdfs:comment 'Indicates whether contract renewal, extension, or renegotiation was discussed during the interaction. True if contract terms were addressed.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpOwner rdf:type rdf:Property ;
    rdfs:label 'Follow Up Owner' ;
    rdfs:comment 'Name or identifier of the internal employee responsible for executing the follow-up actions. Ensures accountability for post-interaction deliverables.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The date on which the commercial interaction occurred or is scheduled to occur. Primary business event date for the interaction.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interaction Duration Minutes' ;
    rdfs:comment 'Total duration of the commercial interaction measured in minutes. Supports time allocation analysis and meeting efficiency tracking.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction End Timestamp' ;
    rdfs:comment 'Precise timestamp when the commercial interaction concluded. Used for calculating interaction duration and resource allocation.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionLocation rdf:type rdf:Property ;
    rdfs:label 'Interaction Location' ;
    rdfs:comment 'Physical or virtual location where the commercial interaction took place. May include mine site names, office locations, or virtual meeting platform identifiers.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionMode rdf:type rdf:Property ;
    rdfs:label 'Interaction Mode' ;
    rdfs:comment 'The communication channel or medium through which the commercial interaction was conducted. Distinguishes between face-to-face, remote, and written interactions.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNotes rdf:type rdf:Property ;
    rdfs:label 'Interaction Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, observations, relationship insights, or qualitative details from the commercial interaction.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Interaction Outcome' ;
    rdfs:comment 'Summary of the results, decisions, agreements, or conclusions reached during the commercial interaction. Captures the business impact and next steps.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionPriority rdf:type rdf:Property ;
    rdfs:label 'Interaction Priority' ;
    rdfs:comment 'Business priority level assigned to the commercial interaction based on strategic importance, revenue impact, or relationship criticality.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Reference Number' ;
    rdfs:comment 'Business-facing unique reference number for the commercial interaction, used for tracking and reporting purposes. Format: CI-YYYYMMDD.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the commercial interaction commenced. Used for detailed scheduling and duration tracking.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the commercial interaction. Tracks the progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the commercial interaction type. Defines the nature and purpose of the engagement with the counterparty.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketIntelligenceFlag rdf:type rdf:Property ;
    rdfs:label 'Market Intelligence Flag' ;
    rdfs:comment 'Indicates whether market trends, competitor insights, demand forecasts, or industry intelligence were exchanged during the interaction. True if market intelligence was shared.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Next Interaction Date' ;
    rdfs:comment 'Scheduled or proposed date for the next commercial interaction with the counterparty. Supports relationship cadence planning and pipeline management.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcomeClassification rdf:type rdf:Property ;
    rdfs:label 'Outcome Classification' ;
    rdfs:comment 'Qualitative assessment of the interaction outcome from a commercial relationship perspective. Supports pipeline health and account management scoring.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceNegotiationFlag rdf:type rdf:Property ;
    rdfs:label 'Price Negotiation Flag' ;
    rdfs:comment 'Indicates whether pricing terms, benchmark adjustments, or commercial rates were discussed or negotiated during the interaction. True if pricing was a topic.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategicAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Flag' ;
    rdfs:comment 'Indicates whether the counterparty is classified as a strategic or key account requiring executive-level relationship management. True for strategic accounts.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:topicsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Topics Discussed' ;
    rdfs:comment 'Detailed narrative of the key topics, agenda items, and discussion points covered during the commercial interaction. Supports knowledge management and continuity.' ;
    rdfs:domain ind:CommercialInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Parent Counterparty Id' ;
    rdfs:comment 'Identifier of the parent or ultimate holding company if this counterparty is part of a corporate group. Enables consolidated credit management and group-level reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:abn rdf:type rdf:Property ;
    rdfs:label 'Abn' ;
    rdfs:comment '11-digit Australian Business Number issued by the Australian Taxation Office for entities registered in Australia.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acn rdf:type rdf:Property ;
    rdfs:label 'Acn' ;
    rdfs:comment '9-digit Australian Company Number issued by ASIC to companies registered under the Corporations Act 2001.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Business classification of the counterparty based on their primary industry and role in the commodity supply chain. Determines applicable commercial terms and risk profiles.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyStatus rdf:type rdf:Property ;
    rdfs:label 'Counterparty Status' ;
    rdfs:comment 'Current operational status of the counterparty relationship. Active counterparties are eligible for new transactions; suspended or blacklisted counterparties are restricted.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where the counterparty is legally incorporated or registered.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum credit exposure limit approved for the counterparty, expressed in United States Dollars. Governs the total value of outstanding receivables and open orders.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Current credit rating assigned to the counterparty by the specified rating agency. Influences credit limits, payment terms, and security requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Name of the credit rating agency that issued the counterparty\'s credit rating. Used for credit risk assessment and exposure management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment '9-digit unique identifier assigned by Dun & Bradstreet for global business entity identification and credit assessment.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermPreference rdf:type rdf:Property ;
    rdfs:label 'Incoterm Preference' ;
    rdfs:comment 'Preferred Incoterm for commodity sales contracts. FOB (Free on Board) and CIF (Cost Insurance and Freight) are most common in mining. Defines responsibility for freight, insurance, and risk transfer.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method for delivering invoices to the counterparty. EDI and portal integrations enable automated accounts payable processing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSanctionedEntity rdf:type rdf:Property ;
    rdfs:label 'Is Sanctioned Entity' ;
    rdfs:comment 'Boolean flag indicating whether the counterparty appears on any international sanctions lists (OFAC, UN, EU). True indicates the entity is sanctioned and transactions are prohibited.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completion Date' ;
    rdfs:comment 'Date when the most recent KYC due diligence process was successfully completed. Used to track KYC refresh requirements.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'Date when the current KYC certification expires and requires renewal. Typically 12-24 months from completion date depending on risk classification.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the Know Your Customer due diligence process. Completed KYC is mandatory before executing commodity sales contracts.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the counterparty as it appears on incorporation documents and contracts. Used for legal agreements and regulatory reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier code used for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms expressed as number of days from invoice date. Common values include 30, 60, or 90 days. Negotiated based on credit rating and relationship strength.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredCommodityGrades rdf:type rdf:Property ;
    rdfs:label 'Preferred Commodity Grades' ;
    rdfs:comment 'Comma-separated list of preferred mineral grades or product specifications that the counterparty typically purchases. Examples: 62% Fe iron ore fines, 99.99% copper cathode, premium coking coal.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDischargePorts rdf:type rdf:Property ;
    rdfs:label 'Preferred Discharge Ports' ;
    rdfs:comment 'Comma-separated list of preferred destination ports where the counterparty receives commodity deliveries. Aligns with their processing facilities and distribution networks.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLoadingPorts rdf:type rdf:Property ;
    rdfs:label 'Preferred Loading Ports' ;
    rdfs:comment 'Comma-separated list of preferred mine or port loading locations for commodity shipments. Reflects counterparty\'s logistics network and freight optimization preferences.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVesselSizeDwt rdf:type rdf:Property ;
    rdfs:label 'Preferred Vessel Size Dwt' ;
    rdfs:comment 'Preferred shipping vessel size category for bulk commodity deliveries, based on port infrastructure and logistics capabilities. Influences freight terms and delivery scheduling.' ;
    rdfs:domain ind:Counterparty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Primary email address for commercial communications with the counterparty. Used for contract correspondence, invoices, and operational notifications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the counterparty, including country code. Used for urgent commercial and operational communications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the counterparty as recorded with the incorporation authority.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the official registered address, typically containing building, suite, or floor information.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or locality component of the counterparty\'s registered address.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code for the country component of the counterparty\'s registered address.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the counterparty\'s registered address.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region component of the counterparty\'s registered address.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormatPreference rdf:type rdf:Property ;
    rdfs:label 'Reporting Format Preference' ;
    rdfs:comment 'Preferred format for delivery of commercial reports, certificates of analysis, and shipping documentation. Supports integration with counterparty\'s procurement systems.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number or VAT registration number issued by the counterparty\'s tax authority. Required for tax reporting and withholding compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Commercial trading name or brand name used by the counterparty in day-to-day business operations. May differ from legal name.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyContactId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contact Id' ;
    rdfs:comment 'Unique identifier for the counterparty contact person. Primary key for the counterparty contact entity.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each customer contact has an assigned relationship manager from the mining company\'s commercial team. Drives account planning, territory management, communication routing, and escalation protocols. St' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:counterpartyContactStatus rdf:type rdf:Property ;
    rdfs:label 'Counterparty Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact person within the counterparty relationship. Active contacts are available for business communications; inactive contacts have left the organisation or role.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Authority' ;
    rdfs:comment 'Indicates whether this contact person has authority to approve credit terms, payment schedules, or financial arrangements.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organisational department or division to which the contact person belongs (e.g., Procurement, Trading, Operations, Finance).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary business email address for the contact person. Used for commercial correspondence, contract negotiations, and operational communications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Facsimile number for the contact person, if applicable for formal document transmission.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the contact person.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete name of the contact person as it should appear in formal correspondence and documentation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact person has authority to make binding commercial decisions on behalf of the counterparty organisation.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact person is the primary or main point of contact for the counterparty organisation.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official position or role title of the contact person within their organisation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the contact person.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsCoordinator rdf:type rdf:Property ;
    rdfs:label 'Logistics Coordinator' ;
    rdfs:comment 'Indicates whether this contact person coordinates shipping, delivery schedules, and logistics arrangements.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the contact person, if applicable.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile or cellular telephone number for the contact person, used for urgent communications and field coordination.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary business telephone number for the contact person, including country and area codes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Method' ;
    rdfs:comment 'The contact person\'s preferred channel for business communications and correspondence.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal title or honorific used when addressing the contact person.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Email Address' ;
    rdfs:comment 'Alternative email address for the contact person, used for backup communication or specific functional purposes.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingAuthority rdf:type rdf:Property ;
    rdfs:label 'Signing Authority' ;
    rdfs:comment 'Indicates whether this contact person has legal authority to sign contracts, purchase orders, or other binding commercial documents.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalLiaison rdf:type rdf:Property ;
    rdfs:label 'Technical Liaison' ;
    rdfs:comment 'Indicates whether this contact person serves as the technical liaison for product specifications, quality requirements, and technical compliance matters.' ;
    rdfs:domain ind:CounterpartyContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact person\'s primary business location, used for scheduling meetings and coordinating communications across global operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Document Id' ;
    rdfs:comment 'Unique identifier for the counterparty document record. Primary key for the counterparty document entity.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:letterOfCreditId rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Id' ;
    rdfs:comment 'Foreign key linking to customer.letter_of_credit. Business justification: Letters of credit generate supporting documents including LC amendments, SWIFT MT700 messages, beneficiary certificates, inspection certificates, and bank confirmations. These documents are stored in ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LetterOfCredit .

ind:procurementContractId rdf:type rdf:Property ;
    rdfs:label 'Procurement Contract Id' ;
    rdfs:comment 'Reference to the sales contract or offtake agreement to which this document is attached or supports. Nullable if document is not contract-specific.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementContract .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Regulatory or contractual compliance requirement that this document satisfies (e.g., KYC, AML, credit insurance, parent guarantee clause).' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Scheduled date when the document is eligible for secure disposal or archival per retention policy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and any special conditions or clauses relevant to credit review and contractual compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNotes rdf:type rdf:Property ;
    rdfs:label 'Document Notes' ;
    rdfs:comment 'Free-text notes capturing additional context, special conditions, or observations related to the document.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to the document for tracking and retrieval purposes.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document indicating its validity and usability for credit and compliance purposes. [ENUM-REF-CANDIDATE: draft|pending_verification|verified|active|expired|revoked|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full title or name of the document as it appears on the original document.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document type. Indicates the nature and purpose of the document held against the counterparty. [ENUM-REF-CANDIDATE: parent_company_guarantee|insurance_certificate|trade_reference|financial_statement|board_resolution|power_of_attorney|credit_report|kyc_documentation|compliance_certificate|tax_clearance|bank_reference|legal_opinion — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentValueAmount rdf:type rdf:Property ;
    rdfs:label 'Document Value Amount' ;
    rdfs:comment 'Monetary value or coverage amount associated with the document (e.g., guarantee amount, insurance coverage limit). Nullable for documents without monetary value.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Value Currency' ;
    rdfs:comment 'Currency code (ISO 4217) for the document value amount.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date when the document was originally issued or executed by the issuing party.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingPartyCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Party Country' ;
    rdfs:comment 'Country code (ISO 3166-1 alpha-3) of the jurisdiction where the issuing party is domiciled or registered.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingPartyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Party Name' ;
    rdfs:comment 'Name of the organization or individual that issued or executed the document (e.g., parent company, insurance provider, bank, legal authority).' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Legal Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction or governing law under which the document is enforceable (e.g., country or state code).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory, legal, or internal policy requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which the document must be reviewed for continued validity and compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or digital location where the original or certified copy of the document is stored.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageReference rdf:type rdf:Property ;
    rdfs:label 'Storage Reference' ;
    rdfs:comment 'Reference identifier, file path, or URI pointing to the stored document in the document management system or physical archive.' ;
    rdfs:domain ind:CounterpartyDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the counterparty hierarchy relationship record. Primary key for this entity.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Child Counterparty Id' ;
    rdfs:comment 'Identifier of the subsidiary, child entity, or lower-level counterparty in the hierarchy relationship. References the counterparty entity that is owned or controlled by the parent.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:primaryUltimateParentCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Counterparty Id' ;
    rdfs:comment 'Identifier of the ultimate beneficial owner or top-level parent entity in the corporate group structure. Used for consolidated credit exposure and group-level reporting across all subsidiaries.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:consolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Flag' ;
    rdfs:comment 'Indicates whether the child counterparty should be included in consolidated financial reporting and group-level credit exposure calculations for the parent entity.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Mechanism by which the parent exercises control over the child counterparty. Direct control is through direct ownership; indirect is through intermediary entities; joint is shared control with other parties.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAggregationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Aggregation Flag' ;
    rdfs:comment 'Indicates whether credit exposure from this child counterparty should be aggregated with the parent for group credit limit monitoring and risk assessment purposes.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the organizational hierarchy tree, with 1 representing the ultimate parent and increasing numbers representing deeper subsidiary levels. Enables depth-based queries and reporting.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier for the child counterparty in this relationship. 20-character alphanumeric code used for global entity identification in financial transactions.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership or control that the parent counterparty holds in the child counterparty. Used to determine consolidation requirements and credit exposure allocation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipNotes rdf:type rdf:Property ;
    rdfs:label 'Relationship Notes' ;
    rdfs:comment 'Free-text notes providing additional context about the hierarchical relationship, including special arrangements, control mechanisms, or commercial considerations relevant to credit and trading decisions.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Source of information used to establish the hierarchical relationship. Indicates the reliability and verification level of the relationship data.' ;
    rdfs:domain ind:CounterpartyHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchical relationship. Active relationships are used for credit aggregation and group reporting; inactive relationships are historical.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the hierarchical relationship between the parent and child counterparties. Defines the nature of corporate control or affiliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Counterparty Preference Id' ;
    rdfs:comment 'Unique identifier for the counterparty preference record.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredPaymentTermPaymentTermId rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Term Payment Term Id' ;
    rdfs:comment 'Foreign key linking to customer.payment_term. Business justification: Counterparty preferences include preferred payment terms, currently stored as free text. The payment_term table is the master reference for payment terms with full details (days, discount, penalties, ' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:secondaryContactCounterpartyContactId rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Counterparty Contact Id' ;
    rdfs:comment 'Reference to the secondary or backup relationship manager for this counterparty.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CounterpartyContact .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether counterparty prefers automatic contract renewal at expiry (True) or manual renegotiation (False).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonFootprintDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Disclosure Flag' ;
    rdfs:comment 'Indicates whether counterparty requires carbon footprint disclosure for shipped products (True/False).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demurrageToleranceHours rdf:type rdf:Property ;
    rdfs:label 'Demurrage Tolerance Hours' ;
    rdfs:comment 'Counterparty\'s acceptable demurrage tolerance in hours before penalties apply. Supports port operations planning.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Invoice Email Address' ;
    rdfs:comment 'Email address for invoice delivery when email is the preferred delivery method.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumShipmentQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Shipment Quantity Tonnes' ;
    rdfs:comment 'Counterparty\'s maximum acceptable shipment quantity in metric tonnes, often constrained by port or storage capacity.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShipmentQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Minimum Shipment Quantity Tonnes' ;
    rdfs:comment 'Counterparty\'s minimum acceptable shipment quantity in metric tonnes. Supports order planning and vessel utilization.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferenceNotes rdf:type rdf:Property ;
    rdfs:label 'Preference Notes' ;
    rdfs:comment 'Free-text notes capturing additional preference details, special instructions, or context not covered by structured fields.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current status of the preference record (active, inactive, pending review, superseded by newer preferences).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Category of preference being captured (commercial terms, operational requirements, logistics, communication, reporting, invoicing).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredAssayMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Assay Method' ;
    rdfs:comment 'Counterparty\'s preferred laboratory assay method or standard for quality determination (e.g., ISO 3082 for iron ore, ISO 1171 for coal ash content).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommodityGrade rdf:type rdf:Property ;
    rdfs:label 'Preferred Commodity Grade' ;
    rdfs:comment 'Counterparty\'s preferred commodity grade specification (e.g., Fe 62%, Cu 25%, thermal coal 6000 kcal/kg). Supports tailored product offerings and contract negotiations.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Preferred Contract Duration Months' ;
    rdfs:comment 'Counterparty\'s preferred contract duration in months for long-term offtake agreements.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredDischargePort rdf:type rdf:Property ;
    rdfs:label 'Preferred Discharge Port' ;
    rdfs:comment 'Counterparty\'s preferred destination port for cargo discharge. Enables end-to-end supply chain planning.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDisputeResolution rdf:type rdf:Property ;
    rdfs:label 'Preferred Dispute Resolution' ;
    rdfs:comment 'Counterparty\'s preferred method for resolving commercial disputes (arbitration, litigation, mediation, negotiation).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredIncoterm rdf:type rdf:Property ;
    rdfs:label 'Preferred Incoterm' ;
    rdfs:comment 'Counterparty\'s preferred International Commercial Terms (Incoterms) for defining responsibilities in shipping. FOB (Free on Board), CIF (Cost Insurance and Freight), CFR (Cost and Freight), EXW (Ex Works), FCA (Free Carrier), CPT (Carriage Paid To), CIP (Carriage and Insurance Paid To), DAP (Delivered at Place), DPU (Delivered at Place Unloaded), DDP (Delivered Duty Paid). [ENUM-REF-CANDIDATE: FOB|CIF|CFR|EXW|FCA|CPT|CIP|DAP|DPU|DDP — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Preferred Jurisdiction' ;
    rdfs:comment 'Counterparty\'s preferred legal jurisdiction for contract governance (e.g., English Law, Singapore Law, New York Law).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLaycanWindowDays rdf:type rdf:Property ;
    rdfs:label 'Preferred Laycan Window Days' ;
    rdfs:comment 'Counterparty\'s preferred laycan (laydays and cancelling date) window in days for vessel arrival. Supports shipping schedule coordination.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLoadingPort rdf:type rdf:Property ;
    rdfs:label 'Preferred Loading Port' ;
    rdfs:comment 'Counterparty\'s preferred port of loading for shipments. Supports logistics planning and freight optimization.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPriceIndex rdf:type rdf:Property ;
    rdfs:label 'Preferred Price Index' ;
    rdfs:comment 'Counterparty\'s preferred commodity price index for index-linked contracts (e.g., Platts Iron Ore Index, LME Copper, ICE Newcastle Coal). Supports pricing formula alignment.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPricingBasis rdf:type rdf:Property ;
    rdfs:label 'Preferred Pricing Basis' ;
    rdfs:comment 'Counterparty\'s preferred pricing mechanism (spot market, long-term contract, index-linked, fixed price, provisional pricing with final adjustment).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSamplingProtocol rdf:type rdf:Property ;
    rdfs:label 'Preferred Sampling Protocol' ;
    rdfs:comment 'Counterparty\'s preferred sampling protocol for quality assurance (e.g., ISO 3081 for iron ore sampling, ISO 13909 for coal sampling).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShipmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Preferred Shipment Frequency' ;
    rdfs:comment 'Counterparty\'s preferred frequency for receiving shipments. Supports production planning and logistics scheduling.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVesselSize rdf:type rdf:Property ;
    rdfs:label 'Preferred Vessel Size' ;
    rdfs:comment 'Counterparty\'s preferred vessel size category for shipment logistics. Capesize (150,000+ DWT), Panamax (60,000-80,000 DWT), Handymax (40,000-60,000 DWT), Handysize (10,000-40,000 DWT), VLOC (Very Large Ore Carrier 200,000+ DWT), Supramax (50,000-60,000 DWT).' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificateRequirement rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Requirement' ;
    rdfs:comment 'Indicates whether counterparty requires quality certificates (assay results, chemical analysis) with each shipment.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Requirement' ;
    rdfs:comment 'Indicates whether counterparty requires sustainability and ESG (Environmental, Social, Governance) reporting with shipments.' ;
    rdfs:domain ind:CounterpartyPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitId rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Id' ;
    rdfs:comment 'Unique identifier for the credit limit record. Primary key for the credit limit entity.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit capacity available for new transactions. Calculated as limit_amount minus utilisation_amount. Negative values indicate over-limit exposure requiring management intervention.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Amount' ;
    rdfs:comment 'Value of the collateral or credit enhancement securing this credit limit. Typically expressed in the same currency as the credit limit. For parent guarantees this may be the guaranteed amount, for standby LCs this is the LC face value.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralReference rdf:type rdf:Property ;
    rdfs:label 'Collateral Reference' ;
    rdfs:comment 'Reference number or identifier for the collateral instrument securing this credit limit. For standby LCs this is the LC number, for guarantees this is the guarantee reference, for cash deposits this is the deposit account reference.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralType rdf:type rdf:Property ;
    rdfs:label 'Collateral Type' ;
    rdfs:comment 'Type of credit enhancement or collateral arrangement securing the credit limit. Parent guarantees are common for subsidiary buyers, standby letters of credit (LC) provide bank-backed security, cash deposits are held as security, bank guarantees are issued by financial institutions, insurance bonds are provided by credit insurers, and asset pledges involve physical or financial assets as security. [ENUM-REF-CANDIDATE: none|parent_guarantee|standby_lc|cash_deposit|bank_guarantee|insurance_bond|asset_pledge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Number' ;
    rdfs:comment 'Business identifier for the credit limit agreement. Externally visible reference number used in credit management communications and approvals.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Status' ;
    rdfs:comment 'Current lifecycle status of the credit limit. Draft limits are being prepared, pending approval limits await credit committee authorization, active limits are in force, suspended limits are temporarily blocked due to payment issues or risk concerns, expired limits have passed their validity date, cancelled limits have been terminated, and under review limits are being reassessed due to changed circumstances. [ENUM-REF-CANDIDATE: draft|pending_approval|active|suspended|expired|cancelled|under_review — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitType rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Type' ;
    rdfs:comment 'Classification of the credit limit based on its purpose and duration. Master limits are ongoing, temporary limits are short-term extensions, project-specific limits are tied to individual mining projects or shipments, seasonal limits accommodate cyclical demand, spot trade limits cover one-off transactions, and offtake agreement limits are tied to long-term supply contracts.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDays rdf:type rdf:Property ;
    rdfs:label 'Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which payment must be received to qualify for the early payment discount. Typically shorter than the full payment terms (e.g., 10 days for discount vs 30 days net).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount offered to the customer for early payment within a specified discount period. For example, 2% discount if paid within 10 days (2/10 net 30 terms). Incentivizes prompt payment and reduces Days Sales Outstanding (DSO).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Percentage' ;
    rdfs:comment 'Percentage of the credit limit covered by credit insurance. Typically ranges from 80% to 95%, with the mining company retaining a deductible or co-insurance portion to align incentives for credit risk management.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number for the credit insurance policy covering this counterparty exposure, if applicable. Credit insurance protects against non-payment risk and is common for high-value or high-risk commodity trading relationships.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Annual percentage rate charged on overdue balances as a penalty for late payment. Applied to the outstanding amount for each day or month beyond the payment due date. Helps enforce payment discipline and compensates for financing costs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Amount' ;
    rdfs:comment 'Maximum approved credit exposure amount that the counterparty is authorized to utilize. Represents the total outstanding receivables (invoiced but unpaid) that the customer may accumulate before further shipments are blocked.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this credit limit record was last modified. Updated whenever any attribute of the credit limit is changed, supporting change tracking and audit requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Internal risk category assigned to the counterparty based on credit assessment, payment history, financial health, and market conditions. Low risk counterparties have strong financials and payment track record, medium risk have acceptable credit profiles, high risk require enhanced monitoring, watch list indicates deteriorating conditions, and default indicates payment failure or insolvency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilisationAmount rdf:type rdf:Property ;
    rdfs:label 'Utilisation Amount' ;
    rdfs:comment 'Current outstanding receivables balance against this credit limit. Calculated in real-time as the sum of all unpaid invoices and open deliveries. When utilisation approaches or exceeds the limit amount, shipment blocks are triggered.' ;
    rdfs:domain ind:CreditLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditReviewId rdf:type rdf:Property ;
    rdfs:label 'Credit Review Id' ;
    rdfs:comment 'Unique identifier for the credit review record. Primary key.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Employee identifier of the credit analyst who performed the review, for audit trail and accountability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Additional notes or conditions recorded by the credit committee or approver at the time of approval, including any modifications to the recommendation or special conditions.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalOutcome rdf:type rdf:Property ;
    rdfs:label 'Approval Outcome' ;
    rdfs:comment 'The final decision by the credit committee: approved as recommended (no changes), approved with modifications (limit or terms adjusted), rejected (recommendation not accepted), or deferred (requires additional information).' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedCreditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Limit Usd' ;
    rdfs:comment 'The final approved credit limit for this counterparty in United States Dollars (USD) following credit committee approval. This becomes the new active limit upon approval.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the credit committee member or senior risk officer who approved the review outcome.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Collateral Required Flag' ;
    rdfs:comment 'Indicates whether collateral or security is required for transactions with this counterparty (True) or not (False), based on the credit review outcome.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCreditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Current Credit Limit Usd' ;
    rdfs:comment 'The existing approved credit limit for this counterparty in United States Dollars (USD), representing the maximum exposure the company is willing to accept prior to this review.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRatio rdf:type rdf:Property ;
    rdfs:label 'Current Ratio' ;
    rdfs:comment 'The counterparty\'s current assets divided by current liabilities, a liquidity metric indicating short-term financial health.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'The credit rating assigned by the external rating agency (e.g., Aaa, Baa2 for Moody\'s; AAA, BBB+ for S&P/Fitch). Free text to accommodate different agency scales.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingAgency rdf:type rdf:Property ;
    rdfs:label 'External Rating Agency' ;
    rdfs:comment 'The primary external credit rating agency whose rating is referenced in this review (Moody\'s, Standard & Poor\'s, Fitch, DBRS, Japan Credit Rating, or Other).' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingDate rdf:type rdf:Property ;
    rdfs:label 'External Rating Date' ;
    rdfs:comment 'The date on which the external credit rating was issued or last updated by the rating agency.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialStatementDate rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Date' ;
    rdfs:comment 'The as-of date of the counterparty\'s financial statements used as the basis for the financial analysis in this credit review.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestCoverageRatio rdf:type rdf:Property ;
    rdfs:label 'Interest Coverage Ratio' ;
    rdfs:comment 'The counterparty\'s EBIT (Earnings Before Interest and Tax) divided by interest expense, indicating ability to service debt obligations.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalCreditRating rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Rating' ;
    rdfs:comment 'The internal credit rating assigned to the counterparty by the mining company\'s credit risk team, using a scale aligned with external agency methodologies (AAA highest quality, D default). [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalRatingOutlook rdf:type rdf:Property ;
    rdfs:label 'Internal Rating Outlook' ;
    rdfs:comment 'The outlook for the internal credit rating: positive (potential upgrade), stable (no change expected), negative (potential downgrade), developing (uncertain direction).' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leverageRatio rdf:type rdf:Property ;
    rdfs:label 'Leverage Ratio' ;
    rdfs:comment 'The counterparty\'s total debt to equity ratio or net debt to EBITDA ratio, a key financial metric analyzed during the credit review to assess financial risk.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitChangeReason rdf:type rdf:Property ;
    rdfs:label 'Limit Change Reason' ;
    rdfs:comment 'Business justification for any recommended change to the credit limit, including references to financial performance, market conditions, or strategic relationship considerations.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossGivenDefaultPct rdf:type rdf:Property ;
    rdfs:label 'Loss Given Default Pct' ;
    rdfs:comment 'The estimated loss severity in the event of default, expressed as a percentage of exposure at default (0.00 to 100.00), used for IFRS 9 ECL calculation.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The recommended payment terms for this counterparty based on the credit review (e.g., Net 30, Net 60, Letter of Credit at Sight, Cash in Advance).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfDefaultPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Default Pct' ;
    rdfs:comment 'The estimated probability of default over a 12-month horizon, expressed as a percentage (0.00 to 100.00), used for IFRS 9 Expected Credit Loss (ECL) calculation.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedCreditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Recommended Credit Limit Usd' ;
    rdfs:comment 'The credit limit recommended by the credit analyst based on this review, in United States Dollars (USD). May be higher, lower, or equal to the current limit.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the credit review, typically formatted as CR-YYYYNNNNNN for external reference and audit trail.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle state of the credit review: draft (initial preparation), in_progress (under analysis), pending_approval (submitted to credit committee), approved (finalized and active), rejected (not accepted), superseded (replaced by newer review).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the review trigger: periodic (scheduled), event-driven (material change in counterparty financials), ad-hoc (management request), annual (mandatory yearly), pre-contract (new customer onboarding), limit increase (customer requests higher exposure), or downgrade trigger (external rating agency downgrade). [ENUM-REF-CANDIDATE: periodic|event_driven|ad_hoc|annual|pre_contract|limit_increase|downgrade_trigger — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the credit analyst or risk officer who conducted the review.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCommentary rdf:type rdf:Property ;
    rdfs:label 'Risk Commentary' ;
    rdfs:comment 'Detailed qualitative assessment of the counterparty\'s credit risk, including analysis of financial position, industry outlook, management quality, and any material risk factors identified during the review.' ;
    rdfs:domain ind:CreditReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique identifier for the customer segment classification record. Primary key.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeMaximumTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Maximum Tonnes' ;
    rdfs:comment 'Maximum annual offtake volume in metric tonnes that defines the upper bound of this segments volume band. Null indicates no upper limit.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVolumeMinimumTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Minimum Tonnes' ;
    rdfs:comment 'Minimum annual offtake volume in metric tonnes that defines the lower bound of this segments volume band.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityFocus rdf:type rdf:Property ;
    rdfs:label 'Commodity Focus' ;
    rdfs:comment 'Primary mineral commodity or commodity group that this customer segment purchases. Examples include iron ore, copper concentrate, metallurgical coal, thermal coal, lithium, nickel.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTypePreference rdf:type rdf:Property ;
    rdfs:label 'Contract Type Preference' ;
    rdfs:comment 'Typical contract structure preference for customers in this segment. Long-Term Offtake for multi-year commitments, Annual Framework for yearly agreements, Quarterly for short-term contracts, Spot for transactional purchases, Mixed for diversified approach.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the customers primary country of operation or delivery destination.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRiskRating rdf:type rdf:Property ;
    rdfs:label 'Credit Risk Rating' ;
    rdfs:comment 'Internal credit risk assessment rating for this customer segment. AAA represents lowest risk, D represents default or highest risk. Used for credit limit determination and commercial terms. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversificationTargetFlag rdf:type rdf:Property ;
    rdfs:label 'Diversification Target Flag' ;
    rdfs:comment 'Boolean indicator whether this customer segment is targeted for portfolio diversification efforts to reduce concentration risk. True indicates diversification target.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endUseIndustry rdf:type rdf:Property ;
    rdfs:label 'End Use Industry' ;
    rdfs:comment 'Primary industry sector in which the customer operates and consumes the mineral commodities. Critical for understanding demand drivers and market positioning. [ENUM-REF-CANDIDATE: Steel|Energy|Battery Materials|Smelting|Manufacturing|Construction|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCategory rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Category' ;
    rdfs:comment 'Standard payment terms category applicable to this customer segment. Defines credit period and payment security requirements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Commercial pricing approach applied to this customer segment. Premium for strategic long-term partners, Standard for preferred customers, Competitive for market-rate buyers, Spot Market for transactional pricing, and Negotiated for bespoke arrangements.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySpecificationTier rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Tier' ;
    rdfs:comment 'Product quality specification tier typically required by customers in this segment. Premium Grade for highest purity/lowest impurities, Standard Grade for typical commercial specifications, Commercial Grade for broader tolerance ranges, Spot Grade for variable quality spot market material.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipManager rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager' ;
    rdfs:comment 'Name of the commercial relationship manager or account executive responsible for managing customers in this segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code representing the segment classification for system processing and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed textual description of the customer segment, including defining characteristics, strategic rationale, and commercial treatment guidelines.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment classification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of this customer segment classification. Active indicates current use, Under Review for segments being reassessed, Suspended for temporarily inactive segments, Archived for historical segments no longer in use.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Tier' ;
    rdfs:comment 'Service level commitment tier for this customer segment. Platinum receives highest priority for supply allocation, logistics coordination, and technical support. Standard receives baseline service.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Flag' ;
    rdfs:comment 'Boolean indicator whether this customer segment is designated as a strategic priority for business development and relationship investment. True indicates strategic priority status.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Strategic tier classification indicating the commercial importance and relationship depth. Tier 1 Strategic represents highest-value long-term partnerships, Tier 2 Preferred for regular preferred customers, Tier 3 Spot for transactional buyers, and Tier 4 Inactive for dormant relationships.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeBand rdf:type rdf:Property ;
    rdfs:label 'Volume Band' ;
    rdfs:comment 'Classification of customer based on annual offtake volume ranges. Very High represents multi-million tonne buyers, High for significant volume, Medium for regular buyers, Low for small-scale, and Minimal for occasional spot purchases.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDestinationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination Id' ;
    rdfs:comment 'Unique identifier for the delivery destination record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryDestination .

ind:siteManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Delivery destinations (ports, customer facilities) require a designated site manager or logistics coordinator from the mining company for operational coordination, quality disputes, demurrage manageme' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address or location descriptor for the delivery destination facility.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as building, terminal, or berth number.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthName rdf:type rdf:Property ;
    rdfs:label 'Berth Name' ;
    rdfs:comment 'Specific berth or wharf name within the port terminal where vessels dock for loading or unloading. Null for non-maritime destinations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berthNumber rdf:type rdf:Property ;
    rdfs:label 'Berth Number' ;
    rdfs:comment 'Alphanumeric identifier for the specific berth position. Null for non-maritime destinations.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the delivery destination is located.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityTypesAccepted rdf:type rdf:Property ;
    rdfs:label 'Commodity Types Accepted' ;
    rdfs:comment 'Pipe-separated list of commodity types that this destination is approved to receive (e.g., iron_ore, coal, copper_concentrate, lithium_spodumene, nickel_ore). [ENUM-REF-CANDIDATE: iron_ore|coal|copper_concentrate|lithium_spodumene|lithium_hydroxide|nickel_ore|bauxite|manganese — promote to reference product]' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorSystemAvailable rdf:type rdf:Property ;
    rdfs:label 'Conveyor System Available' ;
    rdfs:comment 'Indicates whether the destination has conveyor belt infrastructure for direct commodity transfer.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsClearanceAvailable rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Available' ;
    rdfs:comment 'Indicates whether customs clearance services are available at this destination for international shipments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDestinationStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination Status' ;
    rdfs:comment 'Current operational status of the delivery destination indicating whether it is available for commodity shipments.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Code' ;
    rdfs:comment 'Unique business identifier for the delivery destination, typically a port code, terminal code, or facility identifier used in shipping documentation and logistics systems.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationName rdf:type rdf:Property ;
    rdfs:label 'Destination Name' ;
    rdfs:comment 'Full business name of the delivery destination (e.g., Port of Qingdao Terminal 3, Rio Tinto Smelter Intake Point, Baosteel Stockyard).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Classification of the delivery destination based on facility type and operational purpose.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Environmental Restrictions' ;
    rdfs:comment 'Description of any environmental restrictions, dust control requirements, or operational constraints applicable to this destination.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsApplicable rdf:type rdf:Property ;
    rdfs:label 'Incoterms Applicable' ;
    rdfs:comment 'Pipe-separated list of International Commercial Terms (Incoterms) applicable to this destination (e.g., FOB, CIF, CFR, DAP, DDP). [ENUM-REF-CANDIDATE: FOB|CIF|CFR|DAP|DDP|EXW|FCA|CPT|CIP|DAT|DPU — promote to reference product]' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingRateTph rdf:type rdf:Property ;
    rdfs:label 'Loading Rate Tph' ;
    rdfs:comment 'Typical or maximum loading rate in tonnes per hour for commodity discharge or loading operations at this destination.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselBeamM rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Beam M' ;
    rdfs:comment 'Maximum vessel beam (width) in meters that the berth can accommodate.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselDraftM rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Draft M' ;
    rdfs:comment 'Maximum allowable vessel draft in meters that the berth or port can accommodate, critical for vessel selection and cargo planning.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVesselLoaM rdf:type rdf:Property ;
    rdfs:label 'Maximum Vessel Loa M' ;
    rdfs:comment 'Maximum vessel length overall (LOA) in meters that the berth can accommodate.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours or schedule for the destination (e.g., 24/7, business_hours_only, daylight_only).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portCode rdf:type rdf:Property ;
    rdfs:label 'Port Code' ;
    rdfs:comment 'Five-letter UN/LOCODE port identifier for maritime destinations (e.g., CNQIN for Qingdao, AUHED for Port Hedland). Null for non-port destinations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery destination address.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:railAccessAvailable rdf:type rdf:Property ;
    rdfs:label 'Rail Access Available' ;
    rdfs:comment 'Indicates whether the destination has direct rail access for commodity delivery.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region or state/province where the destination is located (e.g., Western Australia, Shandong Province, Queensland).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadAccessAvailable rdf:type rdf:Property ;
    rdfs:label 'Road Access Available' ;
    rdfs:comment 'Indicates whether the destination has road access for truck-based commodity delivery.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Tonnes' ;
    rdfs:comment 'Total storage or stockpile capacity in tonnes available at the destination for commodity inventory.' ;
    rdfs:domain ind:DeliveryDestination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kycRecordId rdf:type rdf:Property ;
    rdfs:label 'Kyc Record Id' ;
    rdfs:comment 'Unique identifier for the KYC compliance record.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adverseMediaScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Date' ;
    rdfs:comment 'Date when the most recent adverse media screening was performed.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adverseMediaScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Adverse Media Screening Result' ;
    rdfs:comment 'Result of screening for negative news or adverse media coverage related to the counterparty, including allegations of financial crime, corruption, or sanctions violations.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'Overall AML risk rating assigned to the counterparty based on risk assessment factors including jurisdiction, business nature, transaction patterns, and PEP status.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialOwnershipDocumented rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Documented' ;
    rdfs:comment 'Indicates whether beneficial ownership documentation has been collected and verified, identifying individuals who ultimately own or control the counterparty entity.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnershipVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficial Ownership Verification Date' ;
    rdfs:comment 'Date when beneficial ownership documentation was last verified.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessRelationshipPurpose rdf:type rdf:Property ;
    rdfs:label 'Business Relationship Purpose' ;
    rdfs:comment 'Documented purpose and intended nature of the business relationship with the counterparty, including expected transaction types and volumes.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments or notes regarding the KYC verification process, risk factors, or special considerations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Document Repository Reference' ;
    rdfs:comment 'Reference identifier or path to the secure document repository where KYC supporting documents are stored.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationComplete rdf:type rdf:Property ;
    rdfs:label 'Documentation Complete' ;
    rdfs:comment 'Indicates whether all required KYC documentation has been collected and is complete.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceLevel rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Level' ;
    rdfs:comment 'Level of customer due diligence applied based on risk assessment: standard for normal risk, enhanced for high-risk counterparties, simplified for low-risk entities.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the counterparty: document review, in-person verification, electronic verification, or third-party verification service.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Risk Level' ;
    rdfs:comment 'Risk level associated with the counterparty\'s country of incorporation or primary operating jurisdiction, based on FATF assessments and international AML standards.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Review Date' ;
    rdfs:comment 'Date when the counterparty\'s transaction activity was last reviewed as part of ongoing monitoring.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ongoingMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Ongoing Monitoring Flag' ;
    rdfs:comment 'Indicates whether the counterparty is subject to ongoing transaction monitoring and periodic review as part of continuous KYC compliance.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pepClassification rdf:type rdf:Property ;
    rdfs:label 'Pep Classification' ;
    rdfs:comment 'Classification of the PEP status: domestic PEP, foreign PEP, international organization official, family member of PEP, close associate of PEP, or not applicable.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pepFlag rdf:type rdf:Property ;
    rdfs:label 'Pep Flag' ;
    rdfs:comment 'Indicates whether the counterparty or its beneficial owners are identified as Politically Exposed Persons, requiring enhanced due diligence.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this KYC record requires reporting to regulatory authorities due to suspicious activity or high-risk classification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Date' ;
    rdfs:comment 'Date when the AML risk assessment was last performed or updated.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Result' ;
    rdfs:comment 'Result of screening against international sanctions lists including OFAC, UN, EU, and other jurisdictional sanctions databases.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfFundsVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds Verified' ;
    rdfs:comment 'Indicates whether the source of funds for the counterparty has been verified as part of enhanced due diligence.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfWealthVerified rdf:type rdf:Property ;
    rdfs:label 'Source Of Wealth Verified' ;
    rdfs:comment 'Indicates whether the source of wealth for the counterparty has been verified, typically required for high-risk or PEP counterparties.' ;
    rdfs:domain ind:KycRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this KYC record was last updated or modified.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Account Id' ;
    rdfs:comment 'Foreign key linking to customer.bank_account. Business justification: Letters of credit are issued by the buyer\'s bank against a specific bank account. The counterparty (buyer) has one or more bank accounts registered in the bank_account table. Linking the LC to the spe' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:loadingPortDeliveryDestinationId rdf:type rdf:Property ;
    rdfs:label 'Loading Port Delivery Destination Id' ;
    rdfs:comment 'Foreign key linking to customer.delivery_destination. Business justification: Letters of credit specify loading and discharge ports for commodity shipments. Currently stored as text fields, these should reference delivery_destination master data. Loading port is the origin port' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryDestination .

ind:advisingBankName rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Name' ;
    rdfs:comment 'Name of the financial institution that advises or confirms the letter of credit to the beneficiary (seller).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisingBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Advising Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the advising bank for international payment routing.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments that have been made to this letter of credit since its original issuance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Legal name of the applicant (the buyer or importer) who requested the issuing bank to open this letter of credit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableAmount rdf:type rdf:Property ;
    rdfs:label 'Available Amount' ;
    rdfs:comment 'Remaining monetary amount available for drawing under this letter of credit (LC amount minus utilised amount).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Legal name of the beneficiary (the mining company or seller) entitled to draw payment under this letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed description of the mineral commodity or product covered by this letter of credit (e.g., iron ore fines, copper concentrate, metallurgical coal).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargePort rdf:type rdf:Property ;
    rdfs:label 'Discharge Port' ;
    rdfs:comment 'Name of the destination port or location where the commodity shipment must be discharged as specified in the letter of credit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRequirements rdf:type rdf:Property ;
    rdfs:label 'Document Requirements' ;
    rdfs:comment 'Comprehensive list of documents required for presentation to the bank to draw payment under this letter of credit (e.g., bill of lading, commercial invoice, certificate of origin, assay certificate, packing list, insurance certificate).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRules rdf:type rdf:Property ;
    rdfs:label 'Governing Rules' ;
    rdfs:comment 'International rules and practices governing this letter of credit (e.g., UCP 600, ISP98 for standby letters of credit, eUCP for electronic presentation).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the delivery terms and risk transfer point for the commodity shipment (e.g., FOB, CIF, CFR). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankName rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Name' ;
    rdfs:comment 'Name of the financial institution that issued the letter of credit on behalf of the buyer.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the issuing bank for international payment routing.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment made to this letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latestShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Shipment Date' ;
    rdfs:comment 'The last permissible date by which the commodity shipment must be dispatched as stipulated in the letter of credit terms.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lcAmount rdf:type rdf:Property ;
    rdfs:label 'Lc Amount' ;
    rdfs:comment 'Total monetary value of the letter of credit available for drawing by the beneficiary.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcNumber rdf:type rdf:Property ;
    rdfs:label 'Lc Number' ;
    rdfs:comment 'The externally-known unique alphanumeric identifier assigned by the issuing bank to this letter of credit instrument.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcType rdf:type rdf:Property ;
    rdfs:label 'Lc Type' ;
    rdfs:comment 'Classification of the letter of credit instrument based on its terms and conditions (irrevocable, revocable, confirmed, unconfirmed, transferable, standby).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:letterOfCreditStatus rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Status' ;
    rdfs:comment 'Current lifecycle status of the letter of credit (draft, active, partially utilised, fully utilised, expired, cancelled).' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialShipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Partial Shipment Allowed' ;
    rdfs:comment 'Indicates whether partial shipments of the commodity are permitted under the terms of this letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presentationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Presentation Period Days' ;
    rdfs:comment 'Maximum number of days after the shipment date within which documents must be presented to the bank for payment.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the commodity to be shipped under this letter of credit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the commodity quantity (e.g., MT for metric tonnes, DMT for dry metric tonnes, WMT for wet metric tonnes).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentPeriodFrom rdf:type rdf:Property ;
    rdfs:label 'Shipment Period From' ;
    rdfs:comment 'Start date of the permissible shipment period window specified in the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentPeriodTo rdf:type rdf:Property ;
    rdfs:label 'Shipment Period To' ;
    rdfs:comment 'End date of the permissible shipment period window specified in the letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenorDays rdf:type rdf:Property ;
    rdfs:label 'Tenor Days' ;
    rdfs:comment 'Number of days after presentation of compliant documents before payment is due, applicable for deferred payment or usance letters of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Tolerance Percentage' ;
    rdfs:comment 'Permissible variance percentage (plus or minus) allowed for quantity and/or amount under the letter of credit terms.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transhipmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Transhipment Allowed' ;
    rdfs:comment 'Indicates whether transhipment (transfer of goods from one vessel to another during transit) is permitted under this letter of credit.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilisedAmount rdf:type rdf:Property ;
    rdfs:label 'Utilised Amount' ;
    rdfs:comment 'Cumulative monetary amount that has been drawn or utilised against this letter of credit to date.' ;
    rdfs:domain ind:LetterOfCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermId rdf:type rdf:Property ;
    rdfs:label 'Payment Term Id' ;
    rdfs:comment 'Unique identifier for the payment term record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTerm .

ind:applicableCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity types to which this payment term applies (e.g., iron_ore, copper_concentrate, coal, lithium, nickel). Null if applicable to all commodities.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Organizational authority level required to approve the use of this payment term in a new offtake agreement. Higher-risk terms (e.g., extended payment days, open account) require senior approval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankGuaranteeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Required Flag' ;
    rdfs:comment 'Indicates whether a bank guarantee or performance bond is required from the counterparty when this payment term is used. True if guarantee is mandatory.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Required Flag' ;
    rdfs:comment 'Indicates whether credit insurance or trade finance insurance must be in place for transactions using this payment term. True if insurance is mandatory.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentaryRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentary Requirements' ;
    rdfs:comment 'List of documents required to be presented for payment under this term (e.g., Bill of Lading, Commercial Invoice, Certificate of Origin, Quality Certificate, Weight Certificate). Particularly relevant for LC and documentary collection terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the payment due date before late payment penalties are applied. Provides a buffer period for payment processing delays. Null if no grace period applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Installment Allowed Flag' ;
    rdfs:comment 'Indicates whether payment may be made in multiple installments rather than a single lump sum. True if installment payments are permitted under this term.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Number of installments into which payment may be divided if installment_allowed_flag is true. Null if installments are not allowed.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:letterOfCreditType rdf:type rdf:Property ;
    rdfs:label 'Letter Of Credit Type' ;
    rdfs:comment 'Specific type of Letter of Credit if payment_method is letter_of_credit. Irrevocable and confirmed LCs are preferred for high-value commodity transactions. Null if payment method is not LC. [ENUM-REF-CANDIDATE: irrevocable|revocable|confirmed|unconfirmed|sight|deferred|transferable|standby — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Transaction Value' ;
    rdfs:comment 'Maximum invoice or shipment value (in the currency specified by currency_code) for which this payment term may be applied without additional credit approval. Null if no maximum applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Value' ;
    rdfs:comment 'Minimum invoice or shipment value (in the currency specified by currency_code) for which this payment term may be applied. Used to enforce stricter terms for smaller transactions. Null if no minimum applies.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBasis rdf:type rdf:Property ;
    rdfs:label 'Payment Basis' ;
    rdfs:comment 'The reference event from which payment days are calculated. Common bases in mining commodity sales include Bill of Lading (B/L) date for FOB (Free on Board) terms and delivery date for CIF (Cost Insurance and Freight) terms.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDays rdf:type rdf:Property ;
    rdfs:label 'Payment Days' ;
    rdfs:comment 'Number of days from the reference event (e.g., Bill of Lading date, invoice date, shipment date) until payment is due. Standard terms in mining include 30, 60, 90, or 120 days.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to this payment term for cash flow planning and treasury operations. High priority terms (e.g., cash in advance, short-dated LCs) receive expedited processing.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermCode rdf:type rdf:Property ;
    rdfs:label 'Payment Term Code' ;
    rdfs:comment 'Standardized short code identifying the payment term (e.g., NET30, NET60, LC90, COD). Used as the business key across offtake agreements and invoicing systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Term Description' ;
    rdfs:comment 'Detailed explanation of the payment term including conditions, calculation basis, and any special clauses applicable to commodity trading.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermName rdf:type rdf:Property ;
    rdfs:label 'Payment Term Name' ;
    rdfs:comment 'Full descriptive name of the payment term (e.g., Net 30 Days from Bill of Lading Date, 90 Days Letter of Credit).' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Term Status' ;
    rdfs:comment 'Current lifecycle status of the payment term. Active terms are available for use in new agreements. Deprecated terms are retained for historical reference but not available for new contracts.' ;
    rdfs:domain ind:PaymentTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Credit and counterparty risk rating associated with this payment term. Cash in advance and confirmed LCs are low risk; extended open account terms are high risk.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset_class. Business justification: The asset table currently stores asset_class as a STRING attribute, but a dedicated asset_class master table exists with PK asset_class_id. This is a classic denormalization pattern that should be nor' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetClass .

ind:parentAssetId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Id' ;
    rdfs:comment 'Reference to the parent asset in a multi-component asset hierarchy (e.g., an engine assembly belonging to a haul truck). Enables parent-child asset relationship modelling for complex equipment units. Null for top-level assets.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:ppeIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Ppe Issuance Id' ;
    rdfs:comment 'Foreign key linking to hse.ppe_issuance. Business justification: Certain equipment requires specialized PPE (hearing protection for drill rigs, fall protection for elevated platforms, respiratory protection for enclosed cabs). Asset records should link to the PPE i' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpeIssuance .

ind:projectContractId rdf:type rdf:Property ;
    rdfs:label 'Project Contract Id' ;
    rdfs:comment 'Foreign key linking to project.project_contract. Business justification: Equipment procurement contracts (haul trucks, excavators, processing equipment) are managed as project contracts. Business process: equipment supply agreement tracking, warranty management, and contra' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectContract .

ind:saleableProductId rdf:type rdf:Property ;
    rdfs:label 'Saleable Product Id' ;
    rdfs:comment 'Foreign key linking to product.saleable_product. Business justification: Mining assets are often dedicated to specific product streams (iron ore haul trucks, coal handling equipment). Production planning, asset allocation, and performance reporting require tracking which p' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SaleableProduct .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Foreign key linking to hse.training_record. Business justification: Specific equipment classes require operator certification (haul truck licenses, dozer tickets, drill rig competencies). Assets should reference the required training/competency record to enforce that ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRecord .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original capital expenditure (CAPEX) purchase price of the asset in the reporting currency. Used for depreciation calculations, asset register valuation, and capital replacement planning under IAS 16 and IFRS.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable descriptive name of the asset, typically combining equipment type and fleet number (e.g., \'Haul Truck HT-042\', \'SAG Mill 01\'). Used in reporting, dashboards, and work orders.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date the asset was formally commissioned and placed into operational service at the mine site. Marks the start of the asset\'s operational lifecycle for maintenance scheduling, warranty tracking, and depreciation under IFRS.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code to which the asset\'s operating expenditure (OPEX) and maintenance costs are allocated. Enables financial reporting by asset and supports OPEX tracking against budget.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Maintenance criticality classification of the asset based on its impact on production, safety, and environmental compliance if it fails. Drives maintenance strategy selection, spare parts stocking levels, and Overall Equipment Effectiveness (OEE) prioritisation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date the asset was permanently removed from operational service and decommissioned. Null for assets still in service. Used for asset lifecycle reporting, capital replacement planning, and mine rehabilitation cost estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eamAssetCode rdf:type rdf:Property ;
    rdfs:label 'Eam Asset Code' ;
    rdfs:comment 'Source system identifier for the asset record in Infor EAM. Used for system-of-record traceability and integration with maintenance work orders, preventive maintenance schedules, and asset lifecycle management.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enginePowerKw rdf:type rdf:Property ;
    rdfs:label 'Engine Power Kw' ;
    rdfs:comment 'OEM-rated engine or motor power output of the asset in kilowatts (kW). Used for fuel consumption benchmarking, energy efficiency analysis, and equipment selection for mine planning. Null for non-powered assets.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetNumber rdf:type rdf:Property ;
    rdfs:label 'Fleet Number' ;
    rdfs:comment 'Operational fleet number assigned to the asset at the mine site. Used by operators, dispatchers, and Fleet Management System (FMS) to identify and track the asset in the field. Sourced from Caterpillar MineStar and Infor EAM.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTankCapacityLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Tank Capacity Litres' ;
    rdfs:comment 'Maximum fuel tank capacity of the asset in litres. Used for fuel logistics planning, refuelling scheduling, and fuel consumption rate benchmarking. Null for electric or non-fuel-powered assets.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary energy source or fuel type powering the asset. Used for fuel consumption tracking, emissions reporting under GRI Mining and Metals Sector Supplement, and fleet electrification planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMobile rdf:type rdf:Property ;
    rdfs:label 'Is Mobile' ;
    rdfs:comment 'Indicates whether the asset is a mobile mining unit (True) such as a haul truck, excavator, or drill rig, or a fixed plant asset (False) such as a conveyor, crusher, or mill. Drives different tracking, reporting, and maintenance workflows.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or rebuild performed on the asset. Used to assess remaining component life, plan future overhauls, and calculate Mean Time Between Failures (MTBF) in the maintenance management system.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufactureYear rdf:type rdf:Property ;
    rdfs:label 'Manufacture Year' ;
    rdfs:comment 'Calendar year in which the asset was manufactured by the OEM. Used to calculate asset age, depreciation schedules, and Life of Mine (LOM) planning for fleet replacement.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'OEM model designation of the asset (e.g., CAT 793F, Komatsu 930E, Sandvik DR461i). Used for spare parts management, maintenance procedures, and performance benchmarking against OEM specifications.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Service Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance service for the asset as scheduled in Infor EAM. Used for maintenance planning, production scheduling, and availability forecasting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerKm rdf:type rdf:Property ;
    rdfs:label 'Odometer Km' ;
    rdfs:comment 'Current cumulative odometer reading in kilometres for mobile assets. Used alongside SMR hours for maintenance scheduling, tyre life management, and haul road condition monitoring. Null for fixed plant assets.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Operating Weight Tonnes' ;
    rdfs:comment 'OEM-rated operating weight of the asset in metric tonnes. Used for road and haul route load limit compliance, ground bearing pressure calculations, and mine infrastructure design.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational lifecycle status of the asset indicating whether it is available for production, undergoing maintenance, on standby, or permanently decommissioned. Drives availability calculations and maintenance scheduling in Infor EAM and MineStar.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the asset is company-owned, leased under a finance or operating lease, short-term hired, or contractor-supplied. Drives financial treatment under IFRS 16 and determines maintenance responsibility.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Tonnes' ;
    rdfs:comment 'OEM-rated maximum payload capacity of the asset in metric tonnes. Applicable to haul trucks, loaders, and material handling equipment. Used for production planning, haulage cycle optimisation, and OEE calculations. Null for fixed plant assets.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaTag rdf:type rdf:Property ;
    rdfs:label 'Scada Tag' ;
    rdfs:comment 'SCADA tag identifier used to link the asset to its real-time process data streams in the OSIsoft PI System historian. Applicable primarily to fixed plant assets such as conveyors, crushers, mills, and processing equipment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Original Equipment Manufacturer (OEM) serial number uniquely identifying the physical asset unit. Used for warranty tracking, OEM service records, and regulatory compliance. Sourced from Infor EAM.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Code identifying the mine site where the asset is currently assigned and operated. Enables site-level fleet reporting, OEE benchmarking, and cross-site asset utilisation analysis. Sourced from SAP S/4HANA Plant Master.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smrHours rdf:type rdf:Property ;
    rdfs:label 'Smr Hours' ;
    rdfs:comment 'Current cumulative Service Meter Reading (SMR) in engine hours recorded on the asset. Used as the primary trigger for preventive maintenance scheduling, component life tracking, and MTBF calculations in Infor EAM.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tag rdf:type rdf:Property ;
    rdfs:label 'Tag' ;
    rdfs:comment 'Internal asset tag or barcode label affixed to the physical asset for inventory and maintenance identification. Distinct from fleet number and serial number. Sourced from Infor EAM.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telematicsUnitCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Unit Code' ;
    rdfs:comment 'Identifier of the onboard telematics or GPS tracking unit installed on the asset. Used to link real-time positional and operational data from Caterpillar MineStar and OSIsoft PI System for fleet management and equipment health monitoring.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'OEM-specified or engineering-assessed useful operational life of the asset in years. Used for straight-line depreciation calculations, Life of Mine (LOM) fleet planning, and capital replacement scheduling under IAS 16.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the OEM warranty for the asset expires. Used to trigger warranty claim processes, plan post-warranty maintenance strategies, and manage OEM service agreements in Infor EAM and Pronto Xi.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure (WBS) element associated with the asset for capital expenditure (CAPEX) tracking and project cost allocation. Used for mine development and capital project reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLifeYears rdf:type rdf:Property ;
    rdfs:label 'Asset Life Years' ;
    rdfs:comment 'Expected useful life of the asset class expressed in calendar years for financial depreciation and LOM planning purposes. Used alongside useful_life_operating_hours to determine the binding depreciation constraint. Supports CAPEX modelling and NPV/IRR analysis.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the nominal_capacity field (e.g., t for payload tonnes, t/h for throughput tonnes per hour, m3 for bucket/bowl volume, mm for drill hole diameter, kW for power rating). Ensures correct interpretation of capacity values across equipment types. [ENUM-REF-CANDIDATE: t|t/h|m3|m3/h|mm|kW|MW|m|km/h — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetCategory rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Category' ;
    rdfs:comment 'Capital expenditure (CAPEX) budget category under which assets of this class are typically funded. Sustaining CAPEX covers replacement of existing capacity; expansion CAPEX covers new capacity additions. Used for capital allocation, LOM planning, and financial reporting under IFRS.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the asset class within the equipment classification hierarchy (e.g., HT-320T for 320-tonne haul truck class, SAG-36FT for 36-foot SAG mill class). Used as the business key across ERP, EAM, and FMS systems.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classDescription rdf:type rdf:Property ;
    rdfs:label 'Class Description' ;
    rdfs:comment 'Detailed narrative description of the asset class including its primary function, operational context within the mine, and key distinguishing characteristics. Supports procurement specifications and capital budgeting documentation.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Human-readable name of the asset class describing the equipment type and key specification (e.g., \'Ultra-Class Haul Truck 320T\', \'Semi-Autogenous Grinding Mill 36ft\', \'Rotary Blasthole Drill 270mm\'). Used in reports, dashboards, and maintenance planning documents.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classStatus rdf:type rdf:Property ;
    rdfs:label 'Class Status' ;
    rdfs:comment 'Current lifecycle status of the asset class record. Active classes are in current use for fleet planning and procurement. Phasing_out classes are being replaced by newer models. Retired classes are no longer procured but may still have operating assets. Controls visibility in procurement and planning systems.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionFactorKgPerHr rdf:type rdf:Property ;
    rdfs:label 'Co2 Emission Factor Kg Per Hr' ;
    rdfs:comment 'Carbon dioxide (CO2) emission factor for assets of this class in kilograms per operating hour, derived from OEM fuel consumption specifications and applicable emission conversion factors. Used for Scope 1 greenhouse gas emissions reporting under GRI, ICMM, and regulatory environmental disclosure requirements.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Equipment Flag' ;
    rdfs:comment 'Indicates whether this asset class is designated as critical equipment whose failure would cause significant production loss, safety risk, or environmental incident. Critical equipment classes receive priority maintenance resourcing, enhanced spare parts stockholding, and elevated monitoring frequency in OSIsoft PI System.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting depreciation method applied to assets of this class for financial reporting and capital budgeting purposes. Units_of_production is common for mining equipment tied to ore tonnes mined. Aligns with IAS 16 and IFRS reporting requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Functional equipment type within the fleet category (e.g., haul_truck, excavator, blasthole_drill, dozer, grader, water_cart, light_vehicle, conveyor, crusher, sag_mill, ball_mill, hpgr, flotation_cell, thickener, stacker, reclaimer). [ENUM-REF-CANDIDATE: haul_truck|excavator|blasthole_drill|dozer|grader|water_cart|light_vehicle|conveyor|crusher|sag_mill|ball_mill|hpgr|flotation_cell|thickener|stacker|reclaimer — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCategory rdf:type rdf:Property ;
    rdfs:label 'Fleet Category' ;
    rdfs:comment 'Top-level classification distinguishing between mobile fleet assets (haul trucks, excavators, drills, dozers, graders, water carts, light vehicles) and fixed plant assets (conveyors, crushers, mills, flotation cells, thickeners). Drives maintenance strategy, depreciation treatment, and fleet sizing models.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionRateLPerHr rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Rate L Per Hr' ;
    rdfs:comment 'Standard OEM-rated fuel consumption rate for assets of this class in litres per operating hour under typical mine operating conditions. Used for fuel budget forecasting, OPEX modelling, carbon emissions estimation, and fleet energy management reporting.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether assets of this class involve or carry hazardous materials (e.g., explosives transport vehicles, acid handling equipment in SX-EW circuits, cyanide dosing systems in leaching). Triggers mandatory HSE compliance controls, PPE requirements, and IsoMetrix risk assessment workflows.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inforEamClassCode rdf:type rdf:Property ;
    rdfs:label 'Infor Eam Class Code' ;
    rdfs:comment 'Corresponding asset class identifier in the Infor EAM system used for asset lifecycle management, preventive maintenance scheduling, and work order management. Enables bi-directional data reconciliation between the lakehouse silver layer and the operational EAM system.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategyType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Type' ;
    rdfs:comment 'Primary maintenance strategy applied to assets of this class: time_based (fixed interval PM schedules), condition_based (triggered by measured condition thresholds), predictive (AI/ML-driven failure prediction from sensor data), or run_to_failure (for low-criticality components). Drives maintenance planning in Infor EAM and CMMS scheduling.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorOverhaulIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Major Overhaul Interval Hours' ;
    rdfs:comment 'Operating hour interval at which a major component overhaul or rebuild is required for assets of this class (e.g., 20,000 hours for engine rebuild, 40,000 hours for full structural overhaul). Drives long-range maintenance CAPEX planning and LOM cost modelling.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minestarEquipmentClassCode rdf:type rdf:Property ;
    rdfs:label 'Minestar Equipment Class Code' ;
    rdfs:comment 'Equipment class identifier as defined in the Caterpillar MineStar Fleet Management System (FMS). Used to align telematics data, productivity metrics, and equipment health signals from MineStar with the enterprise asset class master.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalCapacity rdf:type rdf:Property ;
    rdfs:label 'Nominal Capacity' ;
    rdfs:comment 'Principal quantitative capacity specification for the asset class expressed in the relevant unit of measure (e.g., payload tonnes for haul trucks, throughput tonnes per hour for mills and crushers, bucket capacity m³ for excavators, hole diameter mm for drills). The principal numeric fact defining the class\'s productive capability.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemCategory rdf:type rdf:Property ;
    rdfs:label 'Oem Category' ;
    rdfs:comment 'Original Equipment Manufacturer (OEM) product category or model family designation as defined by the manufacturer (e.g., Caterpillar 793, Komatsu 930E, Liebherr T 284, Sandvik DR416i). Used for OEM warranty tracking, parts compatibility, and service agreement alignment.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemName rdf:type rdf:Property ;
    rdfs:label 'Oem Name' ;
    rdfs:comment 'Name of the original equipment manufacturer for this asset class (e.g., Caterpillar, Komatsu, Liebherr, Sandvik, Metso, FLSmidth). Used for vendor relationship management, warranty claims, and procurement sourcing strategies.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Hours' ;
    rdfs:comment 'Standard preventive maintenance (PM) service interval in operating hours for assets of this class (e.g., 250 hours for minor service, 1000 hours for major service). Defines the base PM scheduling cadence in the CMMS and Infor EAM maintenance plans.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Installed engine or motor power rating for the asset class in kilowatts (kW) as specified by the OEM. Used for energy consumption modelling, fuel burn estimation, electrical infrastructure planning, and OPEX forecasting.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementCostUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Usd' ;
    rdfs:comment 'Current estimated replacement cost for a single asset unit of this class in US dollars. Used for insurance valuation, capital budgeting, CAPEX planning, and NPV/IRR analysis in LOM financial models. Classified as confidential due to commercial sensitivity in procurement negotiations.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetClassCode rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Class Code' ;
    rdfs:comment 'Corresponding asset class code (ANLKL) in SAP S/4HANA Fixed Asset Accounting (FI-AA) module. Used to reconcile the equipment master data with the financial asset register and ensure consistent depreciation treatment across ERP and EAM systems.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCapacityTier rdf:type rdf:Property ;
    rdfs:label 'Size Capacity Tier' ;
    rdfs:comment 'Standardised size and capacity tier classification for the asset class used in fleet sizing models and capital budgeting (e.g., ultra_class for 300T+ haul trucks, large for 150-299T, medium for 90-149T). Enables fleet mix optimisation and benchmarking across mine sites.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Target Availability Pct' ;
    rdfs:comment 'Target physical availability percentage for assets of this class expressed as a percentage (e.g., 85.00 for 85%). Physical availability is the proportion of scheduled time the equipment is mechanically available for operation. Used as the benchmark for OEE calculations and maintenance performance KPIs.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMtbfHours rdf:type rdf:Property ;
    rdfs:label 'Target Mtbf Hours' ;
    rdfs:comment 'Target Mean Time Between Failures (MTBF) in operating hours for assets of this class. MTBF is the average operating time between unplanned mechanical failures. Used to set maintenance performance benchmarks, evaluate reliability improvement initiatives, and support predictive maintenance model calibration.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMttrHours rdf:type rdf:Property ;
    rdfs:label 'Target Mttr Hours' ;
    rdfs:comment 'Target Mean Time To Repair (MTTR) in hours for assets of this class. MTTR measures the average time required to restore equipment to operational status following an unplanned failure. Used to benchmark maintenance crew efficiency and spare parts availability strategies.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOeePct rdf:type rdf:Property ;
    rdfs:label 'Target Oee Pct' ;
    rdfs:comment 'Target Overall Equipment Effectiveness (OEE) percentage for assets of this class, representing the combined product of availability, utilisation, and performance rate (e.g., 65.00 for 65%). OEE is the primary productivity benchmark for mining equipment classes used in production reporting and capital justification.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Target Utilisation Pct' ;
    rdfs:comment 'Target utilisation percentage for assets of this class expressed as a percentage of available hours actually used for productive work (e.g., 75.00 for 75%). Distinct from availability — utilisation measures productive use of available time. Used in fleet sizing models and production planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Enabled Flag' ;
    rdfs:comment 'Indicates whether assets of this class are equipped with telematics and real-time monitoring capability integrated with Caterpillar MineStar or OSIsoft PI System. Determines data availability for real-time OEE tracking, predictive maintenance, and fuel consumption monitoring.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usefulLifeOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Useful Life Operating Hours' ;
    rdfs:comment 'Expected useful life of the asset class expressed in total operating hours as defined by OEM specifications and mine engineering standards (e.g., 80,000 hours for a large haul truck, 120,000 hours for a SAG mill). Drives depreciation schedules, LOM capital replacement planning, and fleet renewal strategies.' ;
    rdfs:domain ind:AssetClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Asset Lifecycle Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each asset lifecycle event record in the silver layer. Primary key for the asset_lifecycle_event data product.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousSiteId rdf:type rdf:Property ;
    rdfs:label 'Previous Site Id' ;
    rdfs:comment 'Reference to the mine site from which the asset was relocated, applicable when event_type is \'relocation\'. Enables tracking of inter-site asset movements for fleet optimisation and fixed asset register updates.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Reference to the internal department, crew, or external contractor responsible for executing the lifecycle event. Links to the workforce or vendor master. Critical for accountability tracking and contractor cost allocation.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'SAP Plant Maintenance or Infor EAM work order number associated with this lifecycle event. Provides traceability to the originating maintenance work order for audit and cost reconciliation purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assetConditionRating rdf:type rdf:Property ;
    rdfs:label 'Asset Condition Rating' ;
    rdfs:comment 'Assessed physical condition of the asset immediately following the lifecycle event, as determined by the maintenance engineer or inspector. Used for insurance valuation, capital planning, and remaining useful life estimation. Ratings: excellent = like-new post-rebuild; good = minor wear; fair = moderate wear requiring monitoring; poor = significant degradation; critical = imminent failure risk.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetHoursAtEvent rdf:type rdf:Property ;
    rdfs:label 'Asset Hours At Event' ;
    rdfs:comment 'Total cumulative operating hours recorded on the asset at the time of the lifecycle event (e.g., engine hours at rebuild). Used to calculate Mean Time Between Failures (MTBF), validate rebuild intervals, and benchmark against OEM recommended service intervals.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookValueAtEvent rdf:type rdf:Property ;
    rdfs:label 'Book Value At Event' ;
    rdfs:comment 'Net book value of the asset on the fixed asset register at the time of the lifecycle event, in the reporting currency. Used for CAPEX capitalisation decisions, impairment testing, and disposal gain/loss calculations.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentReplaced rdf:type rdf:Property ;
    rdfs:label 'Component Replaced' ;
    rdfs:comment 'Description of the specific major component replaced or rebuilt during this lifecycle event (e.g., \'Engine Assembly - CAT 3516C\', \'Transmission - Allison 6000 Series\', \'Hydraulic Pump Assembly\', \'Bucket Assembly\'). Applicable for component_replacement and major_rebuild event types.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Component Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the replaced or installed major component (e.g., engine serial number, transmission serial number). Enables component-level traceability, warranty tracking, and OEM service history management.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'SAP cost centre code to which the lifecycle event cost is allocated. Enables departmental cost tracking, budget variance analysis, and OPEX/CAPEX reporting by operational area.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costClassification rdf:type rdf:Property ;
    rdfs:label 'Cost Classification' ;
    rdfs:comment 'Financial classification of the cost incurred for this lifecycle event. CAPEX (Capital Expenditure) = costs that extend asset life or add capability, capitalised to the fixed asset register; OPEX (Operating Expenditure) = costs expensed in the period. Critical for fixed asset register reconciliation, tax treatment, and financial reporting under IFRS.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the event_cost amount (e.g., AUD, USD, ZAR). Required for multi-currency operations across international mining jurisdictions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the external party involved in an ownership change event (e.g., lessor name for lease return, buyer name for asset sale, OEM vendor for major rebuild contract). Applicable when event_type is \'ownership_change\' or \'major_rebuild\'.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamEventNumber rdf:type rdf:Property ;
    rdfs:label 'Eam Event Number' ;
    rdfs:comment 'Externally-known business identifier for the lifecycle event as recorded in Infor EAM (e.g., work order number, event reference number). Used for cross-system reconciliation with SAP Fixed Asset Register and insurance systems.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCost rdf:type rdf:Property ;
    rdfs:label 'Event Cost' ;
    rdfs:comment 'Total cost incurred for this lifecycle event in the reporting currency. Includes labour, materials, contractor fees, and overheads. Used for CAPEX/OPEX tracking, insurance valuation, and All-In Sustaining Cost (AISC) calculations.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The actual calendar date on which the lifecycle event occurred or was formally executed (e.g., commissioning date, rebuild completion date, decommissioning date). This is the principal real-world business event date used for fixed asset register updates and insurance valuation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Precise date and time when the lifecycle event work was completed and the asset was returned to service or formally closed. Used to calculate event duration and Mean Time To Repair (MTTR) impact.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text field for additional technical or operational notes recorded by the maintenance engineer or planner regarding this lifecycle event (e.g., observed failure mode, special conditions, deviations from standard procedure, OEM recommendations).' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Precise date and time when the lifecycle event work commenced (e.g., when the rebuild began, when the asset was powered down for decommissioning). Used for duration calculation and OEE impact analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current workflow status of the lifecycle event. Planned = scheduled but not yet started; in_progress = work underway; completed = event fully executed and closed; cancelled = event voided before execution; on_hold = temporarily suspended pending approval or parts.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the significant lifecycle milestone for the asset. Commissioning = first entry into service; major_rebuild = engine, transmission, or hydraulic system overhaul; component_replacement = scheduled or unscheduled part swap; mid_life_refurbishment = comprehensive mid-cycle restoration; relocation = transfer between mine sites or operational areas; standby_mothballing = temporary suspension of operations; ownership_change = lease return or sale; decommissioning_disposal = permanent retirement and disposal. [ENUM-REF-CANDIDATE: commissioning|major_rebuild|component_replacement|mid_life_refurbishment|relocation|standby_mothballing|ownership_change|decommissioning_disposal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Required' ;
    rdfs:comment 'Indicates whether a formal Health, Safety and Environment (HSE) clearance or permit was required to execute this lifecycle event (e.g., confined space entry permit for major rebuild, environmental permit for decommissioning). Supports ISO 45001 and ISO 14001 compliance tracking.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Hse Permit Number' ;
    rdfs:comment 'Reference number of the HSE permit or work clearance certificate issued for this lifecycle event (e.g., Permit to Work number, Isolation Certificate number). Populated when hse_clearance_required is true. Traceable to IsoMetrix HSE system.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValuation rdf:type rdf:Property ;
    rdfs:label 'Insurance Valuation' ;
    rdfs:comment 'Updated insurance replacement value of the asset following this lifecycle event, in the reporting currency. Revised after major rebuilds, refurbishments, or condition assessments. Used for insurance policy management and asset register reconciliation.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerKmAtEvent rdf:type rdf:Property ;
    rdfs:label 'Odometer Km At Event' ;
    rdfs:comment 'Total cumulative distance in kilometres recorded on the asset at the time of the lifecycle event. Applicable for mobile mining equipment (haul trucks, light vehicles). Complements operating hours for maintenance interval tracking.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipTransferType rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Type' ;
    rdfs:comment 'Specifies the nature of the ownership change when event_type is \'ownership_change\'. Lease_return = asset returned to lessor at end of lease term; sale = asset sold to third party; purchase = asset acquired; internal_transfer = transfer between legal entities within the mining group.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEventDate rdf:type rdf:Property ;
    rdfs:label 'Planned Event Date' ;
    rdfs:comment 'The originally scheduled date for the lifecycle event as per the maintenance or capital plan. Compared against event_date to measure schedule adherence and support Life of Mine (LOM) capital planning.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingUsefulLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Months' ;
    rdfs:comment 'Updated estimate of the asset\'s remaining useful life in months following this lifecycle event, as assessed by the maintenance engineer. Revised after major rebuilds, refurbishments, or condition assessments. Critical for capital planning, depreciation schedules, and Life of Mine (LOM) fleet replacement planning.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the internal team, maintenance crew, or external contractor responsible for executing the lifecycle event (e.g., \'OEM Rebuild Team - Caterpillar\', \'Site Maintenance Crew A\'). Retained for reporting without requiring a join.' ;
    rdfs:domain ind:AssetLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRegisterId rdf:type rdf:Property ;
    rdfs:label 'Component Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each serialised component record in the master register. Primary key for the component_register data product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComponentRegister .

ind:componentClass rdf:type rdf:Property ;
    rdfs:label 'Component Class' ;
    rdfs:comment 'High-level engineering classification grouping components by their functional and failure mode characteristics. Used to apply appropriate condition monitoring strategies and maintenance standards.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Descriptive name of the component (e.g., \'Engine Assembly\', \'Final Drive LH\', \'SAG Mill Liner Set\', \'Hydraulic Pump Main\'). Human-readable label used in maintenance planning and reporting.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentNumber rdf:type rdf:Property ;
    rdfs:label 'Component Number' ;
    rdfs:comment 'Unique business-facing identifier for the component record within the Infor EAM system. Used for cross-referencing with maintenance work orders and procurement records.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the component. Drives inventory availability, maintenance scheduling, and rebuild/replace decision workflows within Infor EAM.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the major replaceable component category. Drives applicable life limits, rebuild standards, and condition monitoring protocols. [ENUM-REF-CANDIDATE: engine|transmission|final_drive|hydraulic_pump|get|mill_liner|conveyor_drive|differential|torque_converter|alternator|pump|motor|gearbox|brake_assembly|suspension — promote to reference product]' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Date' ;
    rdfs:comment 'Date on which the most recent condition assessment was performed for this component. Used to determine assessment currency and trigger re-inspection schedules.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment Method' ;
    rdfs:comment 'Technique used to determine the current condition rating of the component. Supports traceability of condition data and selection of appropriate monitoring strategies.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Current assessed condition rating of the component based on inspection, oil analysis, vibration monitoring, or visual assessment. Drives condition-based maintenance (CBM) decisions and rebuild/replace recommendations.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamComponentCode rdf:type rdf:Property ;
    rdfs:label 'Eam Component Code' ;
    rdfs:comment 'Source system identifier for this component record within Infor EAM. Enables data lineage traceability and reconciliation between the Silver layer data product and the operational system of record.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursAtInstallation rdf:type rdf:Property ;
    rdfs:label 'Hours At Installation' ;
    rdfs:comment 'Accumulated hours recorded on this component at the time of its most recent installation onto the parent asset. Used to calculate hours accrued during the current installation period.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursSinceNew rdf:type rdf:Property ;
    rdfs:label 'Hours Since New' ;
    rdfs:comment 'Accumulated operating hours on this component since it was manufactured new. Includes all installation periods across its full lifecycle. Key metric for life-to-date tracking and OEM warranty assessment.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursSinceRebuild rdf:type rdf:Property ;
    rdfs:label 'Hours Since Rebuild' ;
    rdfs:comment 'Accumulated operating hours on this component since its most recent rebuild or remanufacture. Primary metric for condition-based maintenance triggers and rebuild interval management.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date on which this component was most recently installed onto the parent asset. Used to calculate time-in-service and trigger scheduled replacement intervals.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCriticalComponent rdf:type rdf:Property ;
    rdfs:label 'Is Critical Component' ;
    rdfs:comment 'Indicates whether this component is classified as safety-critical or production-critical under the site\'s critical equipment register. Critical components require enhanced inspection frequencies and mandatory hold points per ISO 45001.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which this component was originally manufactured. Used for age-based life assessments, warranty eligibility determination, and calendar-based replacement planning.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxRebuildLimit rdf:type rdf:Property ;
    rdfs:label 'Max Rebuild Limit' ;
    rdfs:comment 'OEM or engineering-approved maximum number of rebuilds permitted for this component type before mandatory condemnation and replacement. Enforces safe life limits.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'OEM model or specification number for this component. Distinguishes variants within the same component type (e.g., different engine ratings or transmission ratios) for compatibility verification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemPartNumber rdf:type rdf:Property ;
    rdfs:label 'Oem Part Number' ;
    rdfs:comment 'Original Equipment Manufacturer (OEM) catalogue part number for this component. Used for procurement, warranty claims, and interchangeability verification against approved parts lists.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oilSampleReference rdf:type rdf:Property ;
    rdfs:label 'Oil Sample Reference' ;
    rdfs:comment 'Laboratory reference number for the most recent oil or fluid analysis sample taken from this component. Links to LabWare LIMS for detailed oil analysis results used in condition-based maintenance decisions.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Standardised code identifying the specific mounting position on the parent asset where this component is installed (e.g., \'LH_FRONT\', \'DRIVE_1\', \'MILL_FEED_END\'). Enables position-specific wear pattern analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebuildCost rdf:type rdf:Property ;
    rdfs:label 'Rebuild Cost' ;
    rdfs:comment 'Actual cost incurred for the most recent rebuild of this component in the site operating currency. Used for rebuild/replace economic analysis and OPEX reporting. Sourced from SAP S/4HANA PM/CO.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebuildCount rdf:type rdf:Property ;
    rdfs:label 'Rebuild Count' ;
    rdfs:comment 'Total number of times this component has been rebuilt or remanufactured over its lifetime. Used in rebuild/replace decision analysis and to assess cumulative fatigue against OEM rebuild limits.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebuildReplaceDecision rdf:type rdf:Property ;
    rdfs:label 'Rebuild Replace Decision' ;
    rdfs:comment 'Current engineering or maintenance decision on the disposition of this component at end of its current service life. Informs CAPEX/OPEX planning and component exchange pool management.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingLifeHours rdf:type rdf:Property ;
    rdfs:label 'Remaining Life Hours' ;
    rdfs:comment 'Estimated remaining operating hours before this component reaches its target life limit or requires rebuild/replacement. Calculated as target_life_hours minus hours_since_rebuild. Drives proactive maintenance scheduling.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date on which this component was most recently removed from the parent asset. Null if the component is currently installed. Used to calculate actual service life per installation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementCost rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost' ;
    rdfs:comment 'Current estimated cost to replace this component with a new OEM unit. Used in rebuild/replace decision analysis and CAPEX budget planning. Sourced from Pronto Xi procurement catalogue.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLifeHours rdf:type rdf:Property ;
    rdfs:label 'Target Life Hours' ;
    rdfs:comment 'OEM or site-defined target operating hours for this component before scheduled replacement or rebuild. Basis for component life planning and budget forecasting within the Life of Mine (LOM) plan.' ;
    rdfs:domain ind:ComponentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchInstructionId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Instruction Id' ;
    rdfs:comment 'Unique identifier for the dispatch instruction record. Primary key for the dispatch instruction entity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchInstruction .

ind:haulRouteId rdf:type rdf:Property ;
    rdfs:label 'Haul Route Id' ;
    rdfs:comment 'Reference to the assigned haul route that the equipment must follow from source to target location. Null for non-haulage instructions (park, standby, fuel).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulRoute .

ind:primaryDispatcherEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dispatcher Employee Id' ;
    rdfs:comment 'Reference to the human dispatcher who issued this instruction. Null if the instruction was generated by an automated dispatch optimization algorithm.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Reference to the production shift during which this dispatch instruction was issued and executed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:targetLocationId rdf:type rdf:Property ;
    rdfs:label 'Target Location Id' ;
    rdfs:comment 'Reference to the destination location for this dispatch instruction (e.g., crusher, ROM pad, waste dump, parking area, fuel station).' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:tsfId rdf:type rdf:Property ;
    rdfs:label 'Tsf Id' ;
    rdfs:comment 'Reference to the origin location for this dispatch instruction (e.g., shovel face, ROM pad, waste dump, stockpile, fuel station).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tsf .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the equipment operator acknowledged receipt of the dispatch instruction via the in-cab terminal or mobile device. Null if not yet acknowledged.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Minutes' ;
    rdfs:comment 'Actual total cycle time in minutes including loading, hauling, dumping, and return travel. Used for Overall Equipment Effectiveness (OEE) calculation and productivity benchmarking.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Travel Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken by the equipment to travel from source to target location. Used for dispatch optimization model calibration and route performance analysis.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the dispatch instruction was completed (e.g., load delivered, dump completed, equipment parked). Null if not yet completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Outcome' ;
    rdfs:comment 'Final compliance outcome indicating whether the operator followed the dispatch instruction as issued. Critical for truck-shovel match factor optimization and operator performance tracking.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchAlgorithmCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Algorithm Code' ;
    rdfs:comment 'Identifier of the automated dispatch optimization engine or algorithm that generated this instruction (e.g., MineStar Dispatch, Wenco, Modular). Null if issued by a human dispatcher.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchZone rdf:type rdf:Property ;
    rdfs:label 'Dispatch Zone' ;
    rdfs:comment 'Operational zone or area within the mine site where this dispatch instruction applies (e.g., Pit 3, ROM Area, Waste Dump North). Used for zone-based dispatch optimization.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Cycle Time Minutes' ;
    rdfs:comment 'Estimated total cycle time in minutes including loading, hauling, dumping, and return travel. Used for truck-shovel match factor optimization and queue time minimization.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for the equipment to travel from source to target location along the assigned haul route, calculated by the dispatch optimization engine based on route distance, grade, and equipment performance characteristics.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedPayloadTonnes rdf:type rdf:Property ;
    rdfs:label 'Expected Payload Tonnes' ;
    rdfs:comment 'Expected payload weight in tonnes that the equipment will carry for this dispatch instruction. Used for truck-shovel match factor calculation and production forecasting.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Fuel level of the equipment as a percentage of tank capacity at the time the dispatch instruction was issued. Used to trigger fuel dispatch instructions.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulRouteName rdf:type rdf:Property ;
    rdfs:label 'Haul Route Name' ;
    rdfs:comment 'Human-readable name or code of the assigned haul route (e.g., Route P3-C1, Haul Road 12A).' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Business-facing unique identifier for the dispatch instruction, typically generated by the Fleet Management System (FMS) dispatcher or automated dispatch optimization engine.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch instruction. Tracks progression from issuance through operator acknowledgement to final compliance outcome. [ENUM-REF-CANDIDATE: issued|acknowledged|in_progress|completed|overridden|timed_out|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Type of routing decision or operational command issued to the fleet asset. Defines the primary action the operator must execute. [ENUM-REF-CANDIDATE: load|dump|park|fuel|standby|queue|relocate|maintenance|emergency — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyDispatch rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Dispatch' ;
    rdfs:comment 'Boolean flag indicating whether this dispatch instruction was issued as an emergency response (e.g., equipment breakdown, safety incident, production bottleneck). Emergency dispatches override normal dispatch optimization rules.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date and time when the dispatch instruction was issued by the dispatcher or automated dispatch optimization engine. Primary business event timestamp for real-time fleet productivity tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Type of material being hauled or handled in this dispatch instruction. Critical for production reconciliation and material movement tracking. [ENUM-REF-CANDIDATE: ore|waste|overburden|coal|concentrate|tailings|fuel|water — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation provided by the operator or dispatcher for why the dispatch instruction was overridden or not followed. Null if instruction was complied with.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized code categorizing the reason for dispatch instruction override. Used for root cause analysis of dispatch compliance issues. [ENUM-REF-CANDIDATE: safety|equipment_failure|road_condition|weather|operational_priority|dispatcher_override|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Queue Time Minutes' ;
    rdfs:comment 'Time in minutes that the equipment spent waiting in queue at the source or target location. Critical metric for queue time minimization and dispatch optimization.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roadCondition rdf:type rdf:Property ;
    rdfs:label 'Road Condition' ;
    rdfs:comment 'Condition of the haul road at the time the dispatch instruction was issued. Affects travel time, safety, and route selection. [ENUM-REF-CANDIDATE: good|fair|poor|wet|icy|under_maintenance|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLocationName rdf:type rdf:Property ;
    rdfs:label 'Source Location Name' ;
    rdfs:comment 'Human-readable name of the source location (e.g., Pit 3 Shovel 12, ROM Pad A, Waste Dump North).' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Execution Timestamp' ;
    rdfs:comment 'Date and time when the operator began executing the dispatch instruction (e.g., started moving toward source location). Null if not yet started.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetLocationName rdf:type rdf:Property ;
    rdfs:label 'Target Location Name' ;
    rdfs:comment 'Human-readable name of the target location (e.g., Primary Crusher, ROM Pad B, Waste Dump East, Parking Bay 5).' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Timeout Timestamp' ;
    rdfs:comment 'Date and time when the dispatch instruction expired due to operator non-compliance or system timeout. Null if instruction did not time out.' ;
    rdfs:domain ind:DispatchInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Weather condition at the time the dispatch instruction was issued. Impacts travel time estimates and route selection. [ENUM-REF-CANDIDATE: clear|rain|fog|dust|snow|wind|extreme_heat — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment downtime event record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewId rdf:type rdf:Property ;
    rdfs:label 'Crew Id' ;
    rdfs:comment 'Reference to the shift crew or maintenance team responsible for managing or responding to this downtime event. Used for crew-level performance analysis and accountability tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:primaryDowntimeReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Downtime Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee (operator, supervisor, or maintenance technician) who initially reported or logged the downtime event. Supports accountability tracking and communication workflows.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Unplanned downtime repairs often trigger emergency parts procurement; linking downtime events to purchase orders enables cost tracking, procurement response time analysis, and maintenance cost allocat' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementPurchaseOrder .

ind:tertiaryDowntimeApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Downtime Approved By Employee Id' ;
    rdfs:comment 'Reference to the supervisor or maintenance superintendent who approved the closure of this downtime event and the return of the equipment to service. Supports governance, audit trail, and regulatory compliance requirements.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualRepairHours rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Hours' ;
    rdfs:comment 'Actual number of labour hours expended to complete the repair or maintenance activity for this downtime event. Recorded upon event closure. Used to calculate Mean Time To Repair (MTTR) and to benchmark against estimated_repair_hours for continuous improvement.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Standardised code identifying the specific equipment component or sub-assembly that failed or required attention (e.g., engine assembly, hydraulic pump, front suspension, conveyor idler, crusher liner). Aligned with the equipment Bill of Materials (BOM) in SAP S/4HANA MM and Infor EAM component hierarchy.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Human-readable description of the specific equipment component or sub-assembly that failed or was serviced during this downtime event. Complements component_code with a plain-language label for reporting and communication purposes.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the downtime event was first detected. Operator_report indicates the equipment operator raised the fault. SCADA_alarm indicates detection via OSIsoft PI System or PLC alarm. FMS_alert indicates detection via Caterpillar MineStar Fleet Management System. Condition_monitoring indicates detection via predictive maintenance sensors. Scheduled_inspection indicates detection during a planned inspection round. Third_party_report indicates detection reported by a contractor or external party.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event type. Unplanned breakdown indicates an unexpected mechanical or electrical failure. Planned maintenance covers scheduled preventive or corrective maintenance windows. Standby covers equipment waiting for work assignment. Weather delay covers stoppages due to adverse environmental conditions. Operational delay covers delays caused by operational constraints such as blasting exclusion zones. Process delay covers upstream or downstream process bottlenecks.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardised reason code identifying the specific cause of the downtime event (e.g., engine failure, tyre change, hydraulic leak, conveyor belt tear, electrical fault). Sourced from Infor EAM failure code library and Caterpillar MineStar reason code catalogue. [ENUM-REF-CANDIDATE: engine_failure|tyre_change|hydraulic_leak|conveyor_belt_tear|electrical_fault|structural_damage|operator_error|fuel_system|cooling_system|brake_system — promote to reference product]' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStatus rdf:type rdf:Property ;
    rdfs:label 'Downtime Status' ;
    rdfs:comment 'Current lifecycle status of the downtime event record. Open indicates the event has been logged but resolution has not commenced. In_progress indicates maintenance or corrective action is underway. Resolved indicates the equipment has been returned to service. Cancelled indicates the event was logged in error. Pending_approval indicates the event record is awaiting supervisory sign-off.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed duration of the downtime event expressed in whole minutes, calculated as the difference between end_timestamp and start_timestamp. Stored as a business field to support direct reporting and MTTR calculations without requiring timestamp arithmetic at query time. Null if end_timestamp is not yet recorded.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the equipment was returned to operational service and the downtime event concluded. Null if the event is still open or in progress. Used in conjunction with start_timestamp to calculate actual downtime duration.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether this downtime event resulted in or had the potential to cause an environmental impact (e.g., hydraulic fluid spill, dust emission exceedance, tailings pump failure). True triggers environmental notification and reporting obligations under ISO 14001 and site Environmental Impact Statement (EIS) conditions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRepairHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Hours' ;
    rdfs:comment 'Estimated number of labour hours required to complete the repair or maintenance activity associated with this downtime event, as assessed at the time of event creation. Used for maintenance scheduling, resource planning, and comparison against actual repair duration to improve future estimates.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-text narrative description of the downtime event as recorded by the operator or maintenance technician at the time of reporting. Captures contextual details not covered by structured fields, including observed symptoms, environmental conditions, and initial diagnosis. Sourced from Infor EAM notification text or Caterpillar MineStar operator notes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known business identifier for the downtime event, formatted as DT-YYYY-NNNNNN. Used for cross-referencing with Infor EAM work orders, MineStar dispatch logs, and SAP PM notifications. Supports traceability across operational systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Describes the specific manner in which the equipment failed or the mechanism of the downtime (e.g., fatigue fracture, corrosion, overheating, wear, contamination, misalignment). Aligned with ISO 14224 failure mode taxonomy and used in Reliability Centred Maintenance (RCM) analysis. [ENUM-REF-CANDIDATE: fatigue_fracture|corrosion|overheating|wear|contamination|misalignment|vibration|leakage|blockage|electrical_short — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'SAP S/4HANA PM or Infor EAM functional location code identifying the specific physical location or system hierarchy node where the equipment was positioned at the time of the downtime event (e.g., pit bench, crusher circuit, conveyor section). Supports spatial analysis of downtime patterns.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether this downtime event was caused by or resulted in a safety incident, near-miss, or equipment condition that posed a risk to personnel. True triggers mandatory notification to the Health, Safety and Environment (HSE) team and may require IsoMetrix incident reporting. Supports Lost Time Injury Frequency Rate (LTIFR) and Total Recordable Injury Frequency Rate (TRIFR) compliance reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Maintenance Cost' ;
    rdfs:comment 'Total direct cost incurred to resolve this downtime event, including labour, parts, and consumables as captured in Infor EAM and SAP S/4HANA CO. Expressed in the site operating currency. Used for Operating Expenditure (OPEX) tracking, cost-per-hour analysis, and maintenance budget variance reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity associated with this downtime event. Corrective maintenance addresses failures after they occur. Preventive maintenance is time-based scheduled work. Predictive maintenance is triggered by condition monitoring data. Condition-based maintenance is triggered by measured parameter thresholds. Emergency maintenance addresses safety-critical failures requiring immediate response. Null for non-maintenance downtime categories.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Impact Category' ;
    rdfs:comment 'Classification of how this downtime event impacts the Overall Equipment Effectiveness (OEE) calculation. Availability losses arise from unplanned breakdowns and planned maintenance. Performance losses arise from reduced speed or throughput. Quality losses arise from off-spec production. Used to decompose OEE into its three constituent factors for targeted improvement initiatives.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactHours rdf:type rdf:Property ;
    rdfs:label 'Production Impact Hours' ;
    rdfs:comment 'Estimated or actual number of production hours lost as a direct consequence of this downtime event. Accounts for the impact on the production schedule and is used to quantify the effect on Overall Equipment Effectiveness (OEE) and Life of Mine (LOM) plan adherence. Sourced from Caterpillar MineStar productivity tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionTonnesLost rdf:type rdf:Property ;
    rdfs:label 'Production Tonnes Lost' ;
    rdfs:comment 'Estimated tonnage of ore or material (Run of Mine — ROM) that was not moved or processed as a direct result of this downtime event. Used to quantify the financial and operational impact of equipment unavailability on the mine production schedule.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text description of the corrective actions taken to resolve the downtime event and return the equipment to service. Recorded by the maintenance technician upon event closure. Supports knowledge management, recurring fault analysis, and Standard Operating Procedure (SOP) improvement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToServiceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return To Service Timestamp' ;
    rdfs:comment 'The precise date and time at which the equipment was formally cleared and returned to operational service following resolution of the downtime event. May differ from end_timestamp if post-repair inspection or commissioning steps are required before the equipment is released to operations.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Status' ;
    rdfs:comment 'Status of the formal Root Cause Analysis (RCA) investigation for this downtime event. Not_required for minor or routine events. Pending indicates RCA has been triggered but not yet commenced. In_progress indicates investigation is underway. Completed indicates findings have been documented and corrective actions assigned. Mandatory for critical and high-priority events per site maintenance governance standards.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift during which the downtime event commenced (day, afternoon, or night). Stored directly on the event to support shift-level reporting without requiring a join to the shift master when shift_id is unavailable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the equipment became unavailable or the downtime event commenced. This is the principal real-world event time used for Mean Time Between Failures (MTBF) and Mean Time To Repair (MTTR) calculations. Sourced from Caterpillar MineStar or OSIsoft PI System historian.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillActivityId rdf:type rdf:Property ;
    rdfs:label 'Drill Activity Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual drill rig activity event record in the silver layer lakehouse. Primary key for the drill_activity data product.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillHoleId rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Id' ;
    rdfs:comment 'Unique identifier for the individual drill hole associated with this activity, as assigned in the drill pattern or geology system. Used to link drill activity to assay results, blast design, and geological models.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrillHole .

ind:drillPatternId rdf:type rdf:Property ;
    rdfs:label 'Drill Pattern Id' ;
    rdfs:comment 'Reference to the drill pattern design record that governs the spatial layout, burden, spacing, and sub-drill parameters for this activity. Sourced from Hexagon MinePlan or Deswik drill-and-blast design.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrillPattern .

ind:miningBlockId rdf:type rdf:Property ;
    rdfs:label 'Mining Block Id' ;
    rdfs:comment 'Reference to the mining block or bench where this drill activity occurred. Supports grade control integration and production reconciliation against the mine plan.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MiningBlock .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Reference to the employee record of the drill rig operator who performed this activity. Used for workforce productivity tracking, competency compliance, and shift attribution.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity End Timestamp' ;
    rdfs:comment 'The date and time when the drill rig completed the activity event. Used to calculate activity duration and productive drilling time per shift.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityReference rdf:type rdf:Property ;
    rdfs:label 'Activity Reference' ;
    rdfs:comment 'Externally-known business identifier for the drill activity event, sourced from MineStar or the drill monitoring system. Used for cross-system traceability and drill-and-blast planning references.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Start Timestamp' ;
    rdfs:comment 'The date and time when the drill rig commenced the activity event (e.g., start of collar setup, start of drilling). Principal real-world event timestamp sourced from MineStar telemetry.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle state of the drill activity event. Tracks progression from planned through execution to completion or cancellation. Used for real-time production monitoring and drill-and-blast scheduling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDepthM rdf:type rdf:Property ;
    rdfs:label 'Actual Depth M' ;
    rdfs:comment 'The actual total depth drilled in metres for this activity, as recorded by the drill monitoring system or MineStar. Compared against planned depth to assess drill execution accuracy and identify refusal or over-drill events.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Air Pressure Kpa' ;
    rdfs:comment 'The average air pressure applied during drilling in kilopascals, sourced from drill monitoring sensors or OSIsoft PI historian. Used for DTH and rotary drill performance analysis and equipment health monitoring.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchLevel rdf:type rdf:Property ;
    rdfs:label 'Bench Level' ;
    rdfs:comment 'The mine bench level designation where this drill activity was performed (e.g., \'BL_1050\', \'RL_980\'). Used for spatial organisation of drill activities within the open pit or underground mine design.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Bit Serial Number' ;
    rdfs:comment 'The serial number of the specific drill bit used during this activity. Enables bit life tracking, wear analysis, and consumable cost allocation per hole or per shift.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitType rdf:type rdf:Property ;
    rdfs:label 'Bit Type' ;
    rdfs:comment 'The type of drill bit used during this activity. Bit type selection is driven by rock hardness, hole diameter, and drilling method. Impacts penetration rate, bit life, and consumable cost tracking.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collarEastingM rdf:type rdf:Property ;
    rdfs:label 'Collar Easting M' ;
    rdfs:comment 'Easting coordinate (X) of the drill hole collar position in metres, referenced to the mine grid coordinate system. Critical for spatial integration with GIS, geological models, and blast design.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarElevationM rdf:type rdf:Property ;
    rdfs:label 'Collar Elevation M' ;
    rdfs:comment 'Elevation (Z) of the drill hole collar position in metres above sea level or mine datum. Used for bench level verification, sub-drill calculation, and geological model integration.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarNorthingM rdf:type rdf:Property ;
    rdfs:label 'Collar Northing M' ;
    rdfs:comment 'Northing coordinate (Y) of the drill hole collar position in metres, referenced to the mine grid coordinate system. Used for spatial positioning in geological models and blast pattern verification.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationFromPlanM rdf:type rdf:Property ;
    rdfs:label 'Deviation From Plan M' ;
    rdfs:comment 'The measured deviation of the actual drill hole collar position from the planned collar position in metres. Indicates drill execution accuracy and is used for blast design quality assurance and fragmentation outcome prediction.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillMethod rdf:type rdf:Property ;
    rdfs:label 'Drill Method' ;
    rdfs:comment 'The drilling method employed for this activity. Rotary and DTH (Down-The-Hole) are common for blast hole drilling; RC (Reverse Circulation) and diamond core are used for grade control and exploration. Drives equipment selection and cost classification.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumedLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Litres' ;
    rdfs:comment 'Total fuel consumed by the drill rig during this activity in litres. Sourced from MineStar fuel management or onboard sensors. Used for OPEX tracking, carbon emissions reporting, and equipment efficiency benchmarking.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holeAzimuthDeg rdf:type rdf:Property ;
    rdfs:label 'Hole Azimuth Deg' ;
    rdfs:comment 'The azimuth bearing of the drill hole in degrees from true north. Used in conjunction with inclination to define the 3D trajectory of the hole for blast design and geological logging.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holeDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Hole Diameter Mm' ;
    rdfs:comment 'The diameter of the drill hole in millimetres. Determines explosive charge capacity, blast fragmentation outcomes, and is a key parameter in blast design and drill bit selection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holeInclinationDeg rdf:type rdf:Property ;
    rdfs:label 'Hole Inclination Deg' ;
    rdfs:comment 'The inclination angle of the drill hole from vertical in degrees. Angled holes are used in pre-split and controlled blasting designs. Sourced from drill monitoring system or survey.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSampleCollected rdf:type rdf:Property ;
    rdfs:label 'Is Sample Collected' ;
    rdfs:comment 'Indicates whether a drill chip or core sample was collected during this activity for assay or geological logging. When true, a corresponding sample record should exist in the LIMS (Laboratory Information Management System).' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metresDrilled rdf:type rdf:Property ;
    rdfs:label 'Metres Drilled' ;
    rdfs:comment 'Total metres drilled during this activity event. A primary production quantity metric for drill rig productivity reporting, shift targets, and LOM (Life of Mine) progress tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penetrationRateMPerHr rdf:type rdf:Property ;
    rdfs:label 'Penetration Rate M Per Hr' ;
    rdfs:comment 'The rate at which the drill bit advances through rock, measured in metres per hour. A key productivity metric for drill rig performance benchmarking, bit selection optimisation, and rock hardness inference.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitName rdf:type rdf:Property ;
    rdfs:label 'Pit Name' ;
    rdfs:comment 'The name or code of the open pit, underground stope area, or mine section where this drill activity was performed. Supports spatial aggregation of drill productivity by mine area.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepthM rdf:type rdf:Property ;
    rdfs:label 'Planned Depth M' ;
    rdfs:comment 'The designed total depth of the drill hole in metres as specified in the drill pattern or blast design. Used for variance analysis against actual drilled depth and drill-and-blast planning.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pulldownForceKn rdf:type rdf:Property ;
    rdfs:label 'Pulldown Force Kn' ;
    rdfs:comment 'The average pulldown (crowd) force applied to the drill bit in kilonewtons during this activity. Influences penetration rate, bit wear, and rock hardness index calculation.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refusalDepthM rdf:type rdf:Property ;
    rdfs:label 'Refusal Depth M' ;
    rdfs:comment 'The depth in metres at which the drill rig encountered refusal (inability to advance further due to extremely hard rock or obstruction). Null if no refusal occurred. Used for geotechnical assessment and blast design adjustment.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rockHardnessIndex rdf:type rdf:Property ;
    rdfs:label 'Rock Hardness Index' ;
    rdfs:comment 'A numeric index representing the hardness of the rock encountered during drilling, derived from drill monitoring parameters (e.g., specific energy, penetration rate, rotary torque). Used for geology grade control integration, blast design optimisation, and comminution planning.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rockType rdf:type rdf:Property ;
    rdfs:label 'Rock Type' ;
    rdfs:comment 'Geological classification of the dominant rock type encountered during drilling (e.g., fresh rock, transitional, oxide, sulphide, waste, ore). Sourced from geological logging or drill monitoring inference. Supports grade control and blast design. [ENUM-REF-CANDIDATE: fresh|transitional|oxide|sulphide|waste|ore|overburden|gangue — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotarySpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Rotary Speed Rpm' ;
    rdfs:comment 'The average rotary speed of the drill string in revolutions per minute during this activity. A key operational parameter for drill performance optimisation and rock hardness inference.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleReference rdf:type rdf:Property ;
    rdfs:label 'Sample Reference' ;
    rdfs:comment 'The sample identifier assigned to the drill chip or core sample collected during this activity, as registered in LabWare LIMS. Enables traceability between drill activity and assay results for grade control and resource estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterEncountered rdf:type rdf:Property ;
    rdfs:label 'Water Encountered' ;
    rdfs:comment 'Indicates whether groundwater or surface water was encountered during drilling. Relevant for blast hole charging decisions, dewatering planning, and geotechnical risk assessment.' ;
    rdfs:domain ind:DrillActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment inspection record in the silver layer lakehouse. Primary key for this data product. Entity role: TRANSACTION_HEADER — a discrete, lifecycle-managed business event (pre-start or periodic inspection) with regulatory standing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistId rdf:type rdf:Property ;
    rdfs:label 'Checklist Id' ;
    rdfs:comment 'Reference to the versioned checklist template applied during this inspection, specific to the equipment class (e.g., haul truck pre-start checklist v3.2). Ensures traceability of which checklist version was in force at the time of inspection.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:inspectionSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspection Supervisor Employee Id' ;
    rdfs:comment 'Reference to the supervisor who reviewed and approved the inspection record. Required for statutory and post-incident inspections. Null for self-certified pre-start inspections where supervisor sign-off is not mandated.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the person who conducted the inspection (operator, maintainer, or supervisor). Used for competency verification and regulatory accountability. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the supervising officer approved the inspection record. Null if not yet approved or approval not required. Supports regulatory audit trails for statutory inspections.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checklistItemsCompleted rdf:type rdf:Property ;
    rdfs:label 'Checklist Items Completed' ;
    rdfs:comment 'Number of checklist items that were assessed and recorded during this inspection. A value less than checklist_items_total may indicate an incomplete inspection, which is a compliance risk for pre-start and statutory inspections.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistItemsTotal rdf:type rdf:Property ;
    rdfs:label 'Checklist Items Total' ;
    rdfs:comment 'Total number of checklist items included in the inspection for this equipment class and inspection type. Used to calculate completion rate and to validate that all mandatory items were assessed.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether one or more defect findings from this inspection require a corrective action to be raised. True triggers work order generation in Infor EAM and/or a corrective action task in IsoMetrix. Critical for HSE compliance workflow integration.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectCountCritical rdf:type rdf:Property ;
    rdfs:label 'Defect Count Critical' ;
    rdfs:comment 'Number of checklist items rated as critical severity during this inspection. Critical defects require immediate equipment shutdown and corrective action before operation can resume. A value greater than zero should result in a fail overall result.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountMajor rdf:type rdf:Property ;
    rdfs:label 'Defect Count Major' ;
    rdfs:comment 'Number of checklist items rated as major severity during this inspection. Major defects require corrective action within a defined timeframe but may allow conditional operation under specified controls.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectCountMinor rdf:type rdf:Property ;
    rdfs:label 'Defect Count Minor' ;
    rdfs:comment 'Number of checklist items rated as minor severity during this inspection. Minor defects are recorded for monitoring and scheduled maintenance but do not prevent equipment operation.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Class' ;
    rdfs:comment 'Classification of the equipment type being inspected. Determines which checklist template applies and which regulatory requirements govern the inspection. Sourced from the equipment master register in Infor EAM and Caterpillar MineStar. [ENUM-REF-CANDIDATE: haul_truck|drill|shovel|excavator|dozer|grader|conveyor|crusher|processing_plant|light_vehicle — promote to reference product]' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentGrounded rdf:type rdf:Property ;
    rdfs:label 'Equipment Grounded' ;
    rdfs:comment 'Indicates whether the equipment was taken out of service (grounded) as a result of this inspection. True means the equipment must not be operated until corrective action is completed and a return-to-service inspection is passed. Directly impacts fleet availability and OEE calculations.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentHoursAtInspection rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours At Inspection' ;
    rdfs:comment 'Engine or operating hours recorded on the equipment at the time of inspection. Used to determine whether periodic maintenance-based inspections are due and to track equipment utilisation context at the time of the inspection. Sourced from Caterpillar MineStar telematics.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag' ;
    rdfs:comment 'Human-readable fleet number or asset tag of the equipment being inspected (e.g., HT-042, DR-007). Denormalized from the equipment master for operational convenience and to support inspection records even when the equipment master FK is temporarily unavailable.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Method by which the inspection was captured and submitted. Mobile app refers to field-based digital capture. Paper form indicates a manual record subsequently digitised. Desktop portal is a web-based entry. Integrated OBC (on-board computer) refers to direct capture from Caterpillar MineStar on-board systems.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the inspection record as assigned by the source system (IsoMetrix or Infor EAM). Used for cross-system reference, regulatory submissions, and audit trails. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current workflow state of the inspection record. Draft indicates the inspection is in progress or not yet submitted. Submitted means the inspector has completed and lodged the record. Approved indicates supervisor sign-off. Rejected means the record was returned for correction. Cancelled applies to inspections that were voided. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection by its regulatory or operational trigger. Pre-start inspections are legally mandated before equipment operation in most mining jurisdictions. Periodic inspections occur at scheduled intervals. Post-incident inspections follow a safety event. Statutory inspections are required by specific mining regulations. Return-to-service inspections occur after maintenance or repair.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorComments rdf:type rdf:Property ;
    rdfs:label 'Inspector Comments' ;
    rdfs:comment 'Free-text narrative comments provided by the inspector to describe defect findings, operational context, or observations not captured by the structured checklist items. Supports incident investigation and root cause analysis.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCompetencyCode rdf:type rdf:Property ;
    rdfs:label 'Inspector Competency Code' ;
    rdfs:comment 'Competency or certification code held by the inspector that authorises them to conduct this class of inspection (e.g., operator licence number, statutory inspector certificate). Required for regulatory compliance verification. Sourced from SAP HR competency records.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorRole rdf:type rdf:Property ;
    rdfs:label 'Inspector Role' ;
    rdfs:comment 'Role of the person conducting the inspection. Operators conduct pre-start checks. Maintainers conduct post-maintenance checks. Supervisors conduct periodic and statutory inspections. Statutory inspectors are government-appointed or certified inspectors. Third-party inspectors are external contractors.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Aggregate pass/fail outcome of the inspection. Pass indicates all checklist items met the required standard. Fail indicates one or more critical or major defects were found that prevent safe operation. Conditional pass indicates minor defects noted but equipment may operate under specified conditions pending corrective action.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photographic evidence items attached to this inspection record to document defect findings. Supports regulatory audit requirements and insurance claims. Photos are stored in the document management system with references captured at the checklist item level.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'The specific mining safety regulation or standard under which this inspection is mandated or conducted. Enables jurisdiction-specific compliance reporting and regulatory submissions. [ENUM-REF-CANDIDATE: MSHA_30CFR56|MSHA_30CFR57|WHS_ACT|DMIRS_WA|MINES_ACT_QLD|ISO_45001 — promote to reference product]' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native primary key or record identifier of this inspection in the originating source system (IsoMetrix, Infor EAM, or mobile app). Enables back-referencing to the source system for reconciliation and audit purposes.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fleet Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each fleet assignment record in the MineStar Fleet Management System. Primary key for the fleet_assignment data product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetAssignment .

ind:mineAreaId rdf:type rdf:Property ;
    rdfs:label 'Mine Area Id' ;
    rdfs:comment 'Reference to the mine area, pit, bench, or processing circuit to which the fleet asset is operationally assigned. Links to the mine location/area master.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MineArea .

ind:primaryFleetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fleet Employee Id' ;
    rdfs:comment 'Reference to the responsible supervisor or shift boss accountable for this fleet assignment. Links to the workforce/employee master.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Reference to the mine production schedule that this fleet assignment supports. Links to the production schedule in mine.production_schedule.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSchedule .

ind:assignmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Minutes' ;
    rdfs:comment 'The actual elapsed duration of the fleet assignment in minutes, calculated from assignment start to end timestamps. Stored as a business field for shift reporting and OEE (Overall Equipment Effectiveness) analysis without requiring real-time computation.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'The date and time when the fleet asset completed or was released from its operational assignment. Null if the assignment is still active. Used to calculate assignment duration and shift utilisation.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known business identifier for the fleet assignment, generated by MineStar Fleet Management System. Used for cross-system referencing, dispatch communications, and operational reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'The date and time when the fleet asset commenced its operational assignment at the designated mine area or task. This is the principal real-world event time for the assignment lifecycle.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the fleet assignment. \'planned\' indicates a future assignment not yet commenced; \'active\' indicates the equipment is currently deployed; \'completed\' indicates the assignment has concluded; \'cancelled\' indicates the assignment was voided before commencement; \'suspended\' indicates a temporary halt due to breakdown, weather, or safety hold.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCode rdf:type rdf:Property ;
    rdfs:label 'Delay Code' ;
    rdfs:comment 'The standardised delay classification code recorded when the fleet asset experienced a non-productive delay during the assignment (e.g., mechanical breakdown, waiting for blast, road block, operator break). Sourced from MineStar delay recording. [ENUM-REF-CANDIDATE: promote to reference product with delay_code and delay_description]' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'The total duration in minutes of recorded delays experienced by the fleet asset during this assignment. Used in conjunction with delay_code for availability and utilisation analysis and OEE (Overall Equipment Effectiveness) reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'The mine location code identifying where material is being delivered (ROM pad, waste dump, crusher, stockpile, processing plant). Used for material tracking and haulage cycle analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPriority rdf:type rdf:Property ;
    rdfs:label 'Dispatch Priority' ;
    rdfs:comment 'Numeric priority ranking assigned by the MineStar dispatch system to determine the order in which fleet assets are assigned to tasks. Lower values indicate higher priority. Used for optimising fleet utilisation and meeting production targets.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distanceTravelledKm rdf:type rdf:Property ;
    rdfs:label 'Distance Travelled Km' ;
    rdfs:comment 'The total distance in kilometres travelled by the mobile fleet asset during this assignment, sourced from MineStar GPS telematics. Used for haulage cycle analysis, tyre management, and maintenance scheduling.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'The number of engine operating hours accumulated by the fleet asset during this assignment, sourced from MineStar telematics. Used for maintenance scheduling, MTBF (Mean Time Between Failures) calculation, and asset lifecycle management.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Time Minutes' ;
    rdfs:comment 'The total number of minutes the fleet asset was in an idle state (engine running but not performing productive work) during this assignment. Used for OEE (Overall Equipment Effectiveness) analysis and identifying productivity improvement opportunities.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPlannedAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Planned Assignment' ;
    rdfs:comment 'Indicates whether this fleet assignment was pre-planned in the mine production schedule (True) or was an ad-hoc/reactive dispatch by the shift supervisor (False). Used to measure schedule adherence and dispatch planning effectiveness.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minestarAssignmentRef rdf:type rdf:Property ;
    rdfs:label 'Minestar Assignment Ref' ;
    rdfs:comment 'The native assignment reference or dispatch ID from the Caterpillar MineStar Fleet Management System. Used for traceability and reconciliation back to the source system of record.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadTonnes rdf:type rdf:Property ;
    rdfs:label 'Payload Tonnes' ;
    rdfs:comment 'The actual payload weight in metric tonnes carried or processed during this fleet assignment, as recorded by on-board payload monitoring systems. Applicable primarily to haul truck assignments. Used for production reconciliation and truck factor analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Minutes' ;
    rdfs:comment 'The planned duration of the fleet assignment in minutes as per the mine production schedule or dispatch plan. Used to measure schedule adherence and identify variance between planned and actual assignment durations.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'The originally scheduled end date and time for the fleet assignment as per the mine production schedule or dispatch plan. Used to measure schedule adherence.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'The originally scheduled start date and time for the fleet assignment as per the mine production schedule or dispatch plan. Used to measure schedule adherence and dispatch efficiency.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'The calendar date of the shift during which this fleet assignment occurs. Used as the primary date dimension for daily production reporting and shift-based performance analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'The mine location code identifying where material is being loaded or work is being performed (dig face, blast block, stockpile). Used for material tracking and production reconciliation in MineStar.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorNotes rdf:type rdf:Property ;
    rdfs:label 'Supervisor Notes' ;
    rdfs:comment 'Free-text operational notes recorded by the shift supervisor regarding this fleet assignment, including any special instructions, safety observations, or operational exceptions. Sourced from MineStar dispatch comments.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPayloadTonnes rdf:type rdf:Property ;
    rdfs:label 'Target Payload Tonnes' ;
    rdfs:comment 'The target or design payload weight in metric tonnes for the fleet asset during this assignment, based on equipment specifications and mine planning targets. Used to measure payload efficiency and identify overloading or underloading.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'The primary operational task type assigned to the mobile fleet asset during this assignment. Classifies the nature of work being performed. [ENUM-REF-CANDIDATE: haulage|drilling|dozing|blasting_support|loading|grading|water_cart|ancillary — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each fuel dispensing event or shift-end fuel measurement record in the silver layer lakehouse.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFuelAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Fuel Asset Id' ;
    rdfs:comment 'Reference to the mining fleet or fixed plant asset (haul truck, drill, shovel, dozer, etc.) that consumed the fuel. Links to the equipment master register in the equipment domain.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:anomalyReason rdf:type rdf:Property ;
    rdfs:label 'Anomaly Reason' ;
    rdfs:comment 'Free-text or coded description of the reason the transaction was flagged as an anomaly (e.g., \'Quantity exceeds tank capacity\', \'Location outside mine boundary\', \'Duplicate transaction within 30 minutes\'). Populated only when is_anomaly_flagged is True.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eEmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Kg' ;
    rdfs:comment 'Calculated Scope 1 greenhouse gas emissions in kilograms of CO2 equivalent for this fuel consumption event, derived by applying the applicable emissions factor for the fuel type to the quantity dispensed. Used for GRI and ICMM carbon reporting.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Dispensing Location Code' ;
    rdfs:comment 'Reference to the physical location where fuel was dispensed (fuel bay, ROM pad field refuelling point, tank farm). Links to the site location master.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingMethod rdf:type rdf:Property ;
    rdfs:label 'Dispensing Method' ;
    rdfs:comment 'Physical method by which fuel was delivered to the asset: fixed_bay (permanent fuel bay infrastructure), bowser (mobile tank truck field refuelling), drum (manual drum dispensing for remote equipment), or pipeline (direct pipeline connection at processing plant).' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsFactorKgPerLitre rdf:type rdf:Property ;
    rdfs:label 'Emissions Factor Kg Per Litre' ;
    rdfs:comment 'The greenhouse gas emissions factor applied to this transaction, in kg CO2e per litre, specific to the fuel type. Captured at transaction time to preserve the factor version used for regulatory reporting and audit purposes.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHoursAtFill rdf:type rdf:Property ;
    rdfs:label 'Engine Hours At Fill' ;
    rdfs:comment 'Cumulative engine hours recorded on the asset at the time of the fuelling event. Used to calculate fuel consumption per engine hour, track MTBF intervals, and schedule preventive maintenance in Infor EAM.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelBurnRateLPerHr rdf:type rdf:Property ;
    rdfs:label 'Fuel Burn Rate L Per Hr' ;
    rdfs:comment 'Instantaneous or average fuel consumption rate in litres per engine hour at the time of the fuelling event or measurement period. Sourced from MineStar telematics. Used for OEE analysis and fleet fuel efficiency benchmarking.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelDocketNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Docket Number' ;
    rdfs:comment 'Physical or electronic docket/receipt number issued at the point of dispensing. Used for three-way reconciliation between FMS records, physical dockets, and SAP purchase orders.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'WGS84 decimal latitude of the fuelling event location as recorded by MineStar telematics or the FMS. Used for GIS-based fuel consumption heat mapping and field refuelling route optimisation.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'WGS84 decimal longitude of the fuelling event location as recorded by MineStar telematics or the FMS. Used in conjunction with gps_latitude for spatial analysis of fuel consumption patterns.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAnomalyFlagged rdf:type rdf:Property ;
    rdfs:label 'Is Anomaly Flagged' ;
    rdfs:comment 'Boolean flag set to True when the fuel transaction has been identified as a potential anomaly by automated detection rules (e.g., quantity dispensed exceeds tank capacity, fill rate outside normal range, location mismatch). Triggers investigation workflow for fuel theft detection.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mineSiteCode rdf:type rdf:Property ;
    rdfs:label 'Mine Site Code' ;
    rdfs:comment 'Alphanumeric code identifying the mine site where the fuelling event occurred (e.g., PILBARA-01, HUNTER-VALLEY-02). Supports multi-site OPEX reporting and C1 cash cost benchmarking across operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerKmAtFill rdf:type rdf:Property ;
    rdfs:label 'Odometer Km At Fill' ;
    rdfs:comment 'Cumulative distance travelled in kilometres recorded on the asset at the time of the fuelling event. Applicable to mobile fleet (haul trucks, light vehicles). Null for fixed plant or tracked equipment without odometers.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDispensedLitres rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed Litres' ;
    rdfs:comment 'Volume of fuel dispensed during this transaction, measured in litres to three decimal places. The primary quantitative fact for OPEX cost allocation, C1 cash cost per tonne calculation, and Scope 1 emissions accounting.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native primary key or transaction identifier from the originating source system (MineStar, FMS, PI System, or Infor EAM). Retained for data lineage, deduplication, and reconciliation back to the system of record.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankCapacityLitres rdf:type rdf:Property ;
    rdfs:label 'Tank Capacity Litres' ;
    rdfs:comment 'Maximum rated fuel tank capacity of the asset in litres. Used to calculate fill percentage and validate that dispensed quantity does not exceed physical tank capacity.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankLevelAfterLitres rdf:type rdf:Property ;
    rdfs:label 'Tank Level After Litres' ;
    rdfs:comment 'Fuel level in the asset\'s onboard tank immediately after the dispensing event, in litres. Used with tank_level_before_litres to validate dispensed quantity and detect discrepancies indicative of fuel theft.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankLevelBeforeLitres rdf:type rdf:Property ;
    rdfs:label 'Tank Level Before Litres' ;
    rdfs:comment 'Fuel level in the asset\'s onboard tank immediately before the dispensing event, in litres. Used with tank_level_after_litres to validate dispensed quantity and detect fuel theft or leakage anomalies.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFuelCost rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Cost' ;
    rdfs:comment 'Total monetary cost of fuel dispensed in this transaction (quantity_dispensed_litres × unit_cost_per_litre), in the site operating currency. Used for OPEX cost allocation to fleet and C1 cash cost per tonne reporting. Note: this is a transaction-level cost capture, not a derived aggregate.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the Fuel Management System (FMS) or MineStar to identify this dispensing event or measurement. Used for reconciliation with source systems and audit trails.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current workflow state of the fuel transaction record. Confirmed transactions are included in OPEX and emissions reporting. Voided or disputed records are excluded from cost allocation until resolved.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the fuel dispensing event commenced or the shift-end measurement was recorded. This is the principal real-world event time used for time-series analysis and Scope 1 emissions accounting.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classifies the nature of the fuel record: a discrete refuelling event at a fuel bay (refuel), a periodic shift-end fuel measurement (shift_measurement), a manual tank dip reading (tank_dip), a field refuelling by bowser (field_refuel), or a bulk fuel transfer between storage tanks (bulk_transfer).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCostPerLitre rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Per Litre' ;
    rdfs:comment 'Contracted or spot price paid per litre of fuel at the time of the transaction, in the site operating currency. Confidential commercial pricing data. Used for OPEX cost allocation and C1 cash cost per tonne calculation.' ;
    rdfs:domain ind:FuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Infor EAM work order number to which this fuel consumption is charged, if the fuelling is associated with a specific maintenance or operational work order. Enables work-order-level OPEX tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oeeRecordId rdf:type rdf:Property ;
    rdfs:label 'Oee Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each OEE composite metric record. Primary key for the oee_record data product in the equipment domain.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Actual Cycle Time Sec' ;
    rdfs:comment 'The measured average time per production unit (e.g., haul cycle, crusher pass) achieved during the period. Compared against ideal_cycle_time_sec to derive Performance Rate. Sourced from MineStar dispatch and OSIsoft PI process historian.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOperatingTimeHrs rdf:type rdf:Property ;
    rdfs:label 'Actual Operating Time Hrs' ;
    rdfs:comment 'Actual hours the asset was in productive operation during the period, after deducting unplanned downtime and breakdowns. Core input to OEE Availability Rate calculation. Sourced from MineStar equipment health and OSIsoft PI historian.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityRate rdf:type rdf:Property ;
    rdfs:label 'Availability Rate' ;
    rdfs:comment 'The ratio of actual operating time to planned operating time, expressed as a decimal (e.g., 0.9250 = 92.50%). First component of the OEE composite metric. Calculated as actual_operating_time_hrs / planned_operating_time_hrs. Stored as a raw rate for precision; percentage display handled in reporting layer.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumptionL rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption L' ;
    rdfs:comment 'Total diesel fuel consumed by the asset during the period, measured in litres. Used for fuel efficiency analysis, OPEX cost allocation, and carbon emissions reporting. Sourced from MineStar fuel management or SAP MM fuel issue records.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyTPerL rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency T Per L' ;
    rdfs:comment 'Ratio of actual throughput in tonnes to fuel consumed in litres during the period. Key OPEX efficiency metric for haul trucks and mobile fleet. Enables benchmarking across fleet and identification of underperforming units.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idealCycleTimeSec rdf:type rdf:Property ;
    rdfs:label 'Ideal Cycle Time Sec' ;
    rdfs:comment 'The theoretical minimum time required to produce one unit (e.g., one haul cycle, one crusher pass) under optimal conditions. Used as the benchmark denominator in OEE Performance Rate calculation. Sourced from engineering design specifications or MineStar baseline models.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Reconciled' ;
    rdfs:comment 'Indicates whether this OEE record has been through the production reconciliation process and validated against shift reports and source system data. Unreconciled records are provisional and should not be used for OPEX reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadCount rdf:type rdf:Property ;
    rdfs:label 'Load Count' ;
    rdfs:comment 'Total number of discrete load cycles (e.g., truck loads, shovel passes) completed by the asset during the period. Used for cycle time analysis and Performance Rate validation. Sourced from MineStar dispatch system.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oeeRate rdf:type rdf:Property ;
    rdfs:label 'Oee Rate' ;
    rdfs:comment 'The composite OEE metric expressed as a decimal (e.g., 0.7500 = 75.00%), calculated as the multiplicative product of availability_rate × performance_rate × quality_rate. This is the primary KPI for fleet performance benchmarking, bottleneck identification, and OPEX reporting. Stored as a pre-reconciled rate from the production reconciliation system.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeTargetRate rdf:type rdf:Property ;
    rdfs:label 'Oee Target Rate' ;
    rdfs:comment 'The budgeted or contractually agreed OEE target rate for this asset type and period, expressed as a decimal. Used for variance analysis between actual OEE and planned OEE in OPEX reporting and fleet performance benchmarking.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadAvgT rdf:type rdf:Property ;
    rdfs:label 'Payload Avg T' ;
    rdfs:comment 'Average payload per load cycle in dry metric tonnes during the period. Used to assess truck loading efficiency against rated payload capacity. Sourced from MineStar payload monitoring system (VIMS/PLM).' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRate rdf:type rdf:Property ;
    rdfs:label 'Performance Rate' ;
    rdfs:comment 'The ratio of actual production speed to ideal production speed during operating time, expressed as a decimal (e.g., 0.8750 = 87.50%). Second component of the OEE composite metric. Calculated as (ideal_cycle_time_sec × total_units_produced) / actual_operating_time_hrs. Stored as raw rate.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Timestamp' ;
    rdfs:comment 'The exact date and time marking the end of the production period for which OEE is calculated. Combined with period_start_timestamp to derive total period duration.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Start Timestamp' ;
    rdfs:comment 'The exact date and time marking the beginning of the production period (shift or sub-shift interval) for which OEE is calculated. Principal business event timestamp for this record. Sourced from MineStar shift dispatch or OSIsoft PI historian.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDowntimeHrs rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hrs' ;
    rdfs:comment 'Total hours the asset was taken out of service for scheduled preventive maintenance, inspections, or planned shutdowns during the period. Excluded from planned operating time in OEE Availability calculation.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOperatingTimeHrs rdf:type rdf:Property ;
    rdfs:label 'Planned Operating Time Hrs' ;
    rdfs:comment 'Total scheduled hours the asset was planned to be in productive operation during the period, excluding planned maintenance windows and scheduled downtime. Core input to OEE Availability Rate calculation. Sourced from MineStar shift schedule.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Calendar date associated with this OEE record, representing the production day. Used for daily and monthly OEE trend reporting and OPEX period alignment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityRate rdf:type rdf:Property ;
    rdfs:label 'Quality Rate' ;
    rdfs:comment 'The ratio of good units produced to total units produced, expressed as a decimal (e.g., 0.9900 = 99.00%). Third component of the OEE composite metric. Calculated as (total_units_produced - reject_unit_count) / total_units_produced. For mobile fleet assets where quality is not applicable, this defaults to 1.0000.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Date and time when this OEE record was formally reconciled and approved in the production reconciliation system. Null if is_reconciled is false.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Externally-known business identifier for this OEE record, formatted as OEE-YYYY-MM-NNNNNN. Used for cross-system referencing between MineStar, OSIsoft PI, and SAP PM reporting.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of this OEE record within the production reconciliation workflow. Draft records are provisional; approved records are used for OPEX reporting and fleet benchmarking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectUnitCount rdf:type rdf:Property ;
    rdfs:label 'Reject Unit Count' ;
    rdfs:comment 'Number of production units that did not meet quality specification during the period (e.g., crusher throughput below grade spec, off-spec concentrate batches). Core input to OEE Quality Rate calculation. Applicable primarily to fixed plant assets; set to zero for mobile fleet where quality is not directly measured.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedAvgKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Avg Kmh' ;
    rdfs:comment 'Average travel speed of the mobile asset during the period, in km/h. Used for haul road performance analysis, speed compliance monitoring, and Performance Rate benchmarking. Sourced from MineStar telematics.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputActualT rdf:type rdf:Property ;
    rdfs:label 'Throughput Actual T' ;
    rdfs:comment 'Actual mass of material (ore or waste) processed or moved by the asset during the period, measured in dry metric tonnes. Primary quantitative production outcome for the period. Sourced from MineStar payload monitoring or OSIsoft PI belt scale historian.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputTargetT rdf:type rdf:Property ;
    rdfs:label 'Throughput Target T' ;
    rdfs:comment 'Planned or budgeted throughput in dry metric tonnes for this asset during the period. Used for production variance analysis and OEE Performance Rate benchmarking against mine plan.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitsProduced rdf:type rdf:Property ;
    rdfs:label 'Total Units Produced' ;
    rdfs:comment 'Total count of production units (e.g., haul cycles completed, tonnes crushed, loads dispatched) achieved during the period. Used in Performance Rate and Quality Rate calculations. Sourced from MineStar dispatch or OSIsoft PI throughput counters.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unplannedDowntimeHrs rdf:type rdf:Property ;
    rdfs:label 'Unplanned Downtime Hrs' ;
    rdfs:comment 'Total hours the asset was unavailable due to unplanned breakdowns, mechanical failures, or unscheduled stoppages during the period. Key driver of Availability Rate degradation. Sourced from Infor EAM work order records.' ;
    rdfs:domain ind:OeeRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadCycleId rdf:type rdf:Property ;
    rdfs:label 'Payload Cycle Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual truck payload cycle record (load-haul-dump event) as captured by Caterpillar MineStar Payload Management.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dumpLocationId rdf:type rdf:Property ;
    rdfs:label 'Dump Location Id' ;
    rdfs:comment 'Reference to the destination location where the truck dumped its load during this cycle (e.g., ROM pad, crusher, waste dump, stockpile). Links to the mine operations location master.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:loadLocationId rdf:type rdf:Property ;
    rdfs:label 'Load Location Id' ;
    rdfs:comment 'Reference to the spatial location (bench, face, or dig block) where the truck was loaded during this cycle, linking to the mine operations location or mining block master.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:primaryPayloadAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Payload Asset Id' ;
    rdfs:comment 'Reference to the haul truck or loader asset that performed this payload cycle, linking to the equipment master register in the equipment domain.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:cycleEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cycle End Timestamp' ;
    rdfs:comment 'The date and time (ISO 8601 with timezone offset) when the payload cycle was completed, typically recorded as the moment the truck completed the dump and cleared the dump point in MineStar.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleReference rdf:type rdf:Property ;
    rdfs:label 'Cycle Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by MineStar Payload Management to uniquely identify this load-haul-dump cycle for cross-system reconciliation and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cycle Start Timestamp' ;
    rdfs:comment 'The date and time (ISO 8601 with timezone offset) when the payload cycle commenced, typically recorded as the moment the truck arrived at the load point or the loading sequence began in MineStar.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the payload cycle record. Completed indicates a full load-haul-dump sequence was executed. Partial indicates the cycle was interrupted. Aborted indicates the cycle was terminated before dump. Cancelled indicates the cycle was voided.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Minutes' ;
    rdfs:comment 'Total elapsed time for the complete load-haul-dump cycle in minutes, from arrival at the load point to completion of the dump. Sourced from MineStar cycle time tracking. Key input for haulage productivity analysis and OEE (Overall Equipment Effectiveness) calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the data quality status of this payload cycle record as assessed during ingestion into the Silver layer. Valid indicates the record passed all quality checks. Suspect indicates anomalies detected (e.g., payload outside expected range). Invalid indicates the record failed quality checks. Corrected indicates the record was manually reviewed and adjusted.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dumpLocationName rdf:type rdf:Property ;
    rdfs:label 'Dump Location Name' ;
    rdfs:comment 'Human-readable name or code of the dump destination (e.g., ROM Pad 1, Primary Crusher, Waste Dump North, Stockpile A). Used for material routing analysis and ROM tonnage reconciliation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dumpTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dump Time Minutes' ;
    rdfs:comment 'Time in minutes taken to complete the dump operation at the dump point during this cycle, from arrival at the dump to departure. Used to identify dump point congestion and assess dump efficiency.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulDistanceEmptyM rdf:type rdf:Property ;
    rdfs:label 'Haul Distance Empty M' ;
    rdfs:comment 'Distance in metres travelled by the truck empty from the dump point back to the load point during this cycle, as recorded by MineStar GPS/telematics. Used for total cycle distance calculation and fuel consumption analysis.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulDistanceLoadedM rdf:type rdf:Property ;
    rdfs:label 'Haul Distance Loaded M' ;
    rdfs:comment 'Distance in metres travelled by the truck from the load point to the dump point while carrying a full load during this cycle, as recorded by MineStar GPS/telematics. Used for haulage cost modelling and route optimisation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulTimeLoadedMinutes rdf:type rdf:Property ;
    rdfs:label 'Haul Time Loaded Minutes' ;
    rdfs:comment 'Time in minutes the truck spent travelling from the load point to the dump point while carrying a full load during this cycle. Used for haulage route analysis and cycle time optimisation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadLocationName rdf:type rdf:Property ;
    rdfs:label 'Load Location Name' ;
    rdfs:comment 'Human-readable name or code of the load point where the truck was loaded (e.g., pit bench designation, dig block identifier, ROM pad zone). Used for spatial haulage analysis and ore source tracking.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Load Time Minutes' ;
    rdfs:comment 'Time in minutes taken to load the truck at the dig face or load point during this cycle, from first bucket to last bucket. Used to assess loader productivity and number of passes per load.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minestarCycleCode rdf:type rdf:Property ;
    rdfs:label 'Minestar Cycle Code' ;
    rdfs:comment 'The native cycle identifier assigned by Caterpillar MineStar Payload Management system at the source. Retained for traceability and reconciliation back to the operational system of record.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPasses rdf:type rdf:Property ;
    rdfs:label 'Number Of Passes' ;
    rdfs:comment 'The number of bucket or dipper passes (swings) made by the loading unit to fill the truck to the target payload during this cycle. Used to assess loader efficiency and optimise pass-matching strategy.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Full name of the equipment operator who performed this payload cycle as recorded in MineStar at the time of the cycle. Retained for operational reporting and shift reconciliation where the operator ID may not be immediately resolvable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreGradeIndicator rdf:type rdf:Property ;
    rdfs:label 'Ore Grade Indicator' ;
    rdfs:comment 'The estimated or assigned grade classification of the material hauled in this cycle (e.g., high-grade, medium-grade, low-grade, cut-off-grade) as determined by the grade control model at the time of loading. Used for ore quality tracking and mill feed grade management.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overloadFlag rdf:type rdf:Property ;
    rdfs:label 'Overload Flag' ;
    rdfs:comment 'Indicates whether the truck was loaded beyond its rated payload capacity (overloaded) during this cycle as determined by MineStar payload monitoring. True indicates an overload event. Used for truck health monitoring, tyre management, and compliance with OEM load limits.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payloadMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Payload Measurement Method' ;
    rdfs:comment 'The method used to measure the payload weight for this cycle. Onboard scale uses the truck\'s integrated weighing system. Strut pressure uses suspension strut pressure sensors. Load cell uses a fixed weighbridge. Estimated indicates a calculated value. Manual indicates a manually entered value. Affects data quality confidence for ROM reconciliation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadVarianceTonnes rdf:type rdf:Property ;
    rdfs:label 'Payload Variance Tonnes' ;
    rdfs:comment 'The difference between the actual payload weight and the target payload weight in metric tonnes (actual minus target). Positive values indicate overloading; negative values indicate underloading. Used for truck health monitoring and haulage efficiency analysis. Note: this is a raw recorded field from MineStar, not a derived KPI.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Payload Weight Tonnes' ;
    rdfs:comment 'The measured weight of material loaded onto the truck during this cycle, expressed in metric tonnes as recorded by the on-board payload measurement system (OBMS) in MineStar. This is the principal quantitative fact for the cycle and the primary input to ROM tonnage reconciliation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Return Time Minutes' ;
    rdfs:comment 'Time in minutes the truck spent travelling empty from the dump point back to the load point during this cycle. Used for haulage route analysis and cycle time component breakdown.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckFleetNumber rdf:type rdf:Property ;
    rdfs:label 'Truck Fleet Number' ;
    rdfs:comment 'Human-readable fleet identification number assigned to the haul truck or loader (e.g., HT-042, LD-017) as registered in the Fleet Management System (FMS). Used for operational reporting and shift reconciliation.' ;
    rdfs:domain ind:PayloadCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemetryEventId rdf:type rdf:Property ;
    rdfs:label 'Telemetry Event Id' ;
    rdfs:comment 'Primary key for telemetry_event' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'Ambient air temperature in degrees Celsius recorded by the equipment\'s external temperature sensor at the time of the telemetry event. Used for equipment performance normalisation and heat stress risk assessment under ISO 45001.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryVoltageV rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage V' ;
    rdfs:comment 'Onboard electrical system battery voltage in volts at the time of the telemetry event. Low voltage readings indicate potential electrical system faults and are used to trigger preventive maintenance actions in Infor EAM.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brakeApplied rdf:type rdf:Property ;
    rdfs:label 'Brake Applied' ;
    rdfs:comment 'Indicates whether the service brake was applied at the time of the telemetry event. Used for operator behaviour analysis, brake wear monitoring, and safety compliance reporting under ISO 45001.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coolantTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Coolant Temperature C' ;
    rdfs:comment 'Engine coolant temperature in degrees Celsius at the time of the telemetry event. A critical health indicator; values exceeding thresholds trigger predictive maintenance alerts and potential equipment shutdown.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Altitude of the equipment above mean sea level in metres at the time of the telemetry event. Used for bench-level positioning, grade resistance calculations, and mine design alignment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineLoadPct rdf:type rdf:Property ;
    rdfs:label 'Engine Load Pct' ;
    rdfs:comment 'Engine load as a percentage of maximum rated capacity at the time of the telemetry event. Indicates whether the equipment is operating within design parameters. Used for OEE and fuel consumption analysis.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Instantaneous engine speed in revolutions per minute at the time of the telemetry event. Used for engine load analysis, fuel efficiency monitoring, and predictive maintenance trigger detection.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Status' ;
    rdfs:comment 'The operational state of the equipment at the moment of this telemetry event as reported by the Fleet Management System (FMS). Supports Overall Equipment Effectiveness (OEE) and utilisation calculations. [ENUM-REF-CANDIDATE: operating|idle|standby|down|tramming|loading|dumping — promote to reference product]' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (UTC) at which the sensor snapshot or event trigger was recorded by the onboard telematics system. Sub-minute frequency. This is the principal real-world event time, distinct from ingestion audit timestamps.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:faultCode rdf:type rdf:Property ;
    rdfs:label 'Fault Code' ;
    rdfs:comment 'Diagnostic fault or alarm code generated by the equipment\'s onboard diagnostic system (OBD/J1939) at the time of the event. Null for periodic snapshots with no active fault. Used to trigger work orders in Infor EAM and predictive maintenance workflows.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faultSeverity rdf:type rdf:Property ;
    rdfs:label 'Fault Severity' ;
    rdfs:comment 'Severity classification of the fault code raised at the time of this telemetry event. Critical and high severity faults may trigger immediate equipment shutdown or dispatch of maintenance crew. Null when no fault is active.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionRateLph rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Rate Lph' ;
    rdfs:comment 'Instantaneous fuel burn rate in litres per hour as reported by the onboard fuel flow sensor at the time of the telemetry event. Used for OPEX (Operating Expenditure) monitoring and All-In Sustaining Cost (AISC) calculations.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelPct rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Pct' ;
    rdfs:comment 'Current fuel tank level expressed as a percentage of total tank capacity at the time of the telemetry event. Used for fuel management, dispatch planning, and refuelling schedule optimisation. Distinct from discrete fuel dispensing events recorded in fuel_consumption.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geofenceBreach rdf:type rdf:Property ;
    rdfs:label 'Geofence Breach' ;
    rdfs:comment 'Indicates whether the equipment was in breach of an active geofence boundary at the time of this telemetry event. True when the equipment has entered a restricted or exclusion zone without authorisation. Supports safety compliance and HSE reporting.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Compass bearing of the equipment direction of travel in degrees (0–360) at the time of the telemetry event. Used for directional analysis and geofence zone entry/exit detection.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Pressure Kpa' ;
    rdfs:comment 'Hydraulic system pressure in kilopascals at the time of the telemetry event. Used for monitoring hydraulic system health on shovels, drills, and haul trucks. Anomalies indicate potential hydraulic failure.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingested Timestamp' ;
    rdfs:comment 'The date and time at which this telemetry record was received and loaded into the lakehouse silver layer from the source system (MineStar, Wenco, Modular Mining, or OSIsoft PI). Used for data latency monitoring and pipeline audit.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payloadWeightT rdf:type rdf:Property ;
    rdfs:label 'Payload Weight T' ;
    rdfs:comment 'Instantaneous payload weight in metric tonnes as measured by the onboard payload monitoring system at the time of the telemetry event. Used for haulage productivity analysis, truck factor compliance, and ROM (Run of Mine) tonnage tracking.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalQuality rdf:type rdf:Property ;
    rdfs:label 'Signal Quality' ;
    rdfs:comment 'Quality classification of the wireless or satellite communication signal at the time the telemetry event was transmitted. Used to assess data reliability and identify underground or remote areas with poor connectivity.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'Instantaneous travel speed of the equipment in kilometres per hour at the time of the telemetry event. Used for speed limit compliance monitoring, operator behaviour analysis, and haulage cycle time analysis.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionGear rdf:type rdf:Property ;
    rdfs:label 'Transmission Gear' ;
    rdfs:comment 'Current transmission gear position of the equipment at the time of the telemetry event. Used for operator behaviour analysis, ramp grade compliance, and drivetrain health monitoring.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tyrePressureFrontLeftKpa rdf:type rdf:Property ;
    rdfs:label 'Tyre Pressure Front Left Kpa' ;
    rdfs:comment 'Tyre pressure of the front-left tyre in kilopascals at the time of the telemetry event. Tyre pressure monitoring is critical for haul truck safety and tyre life management on large mining vehicles.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyrePressureFrontRightKpa rdf:type rdf:Property ;
    rdfs:label 'Tyre Pressure Front Right Kpa' ;
    rdfs:comment 'Tyre pressure of the front-right tyre in kilopascals at the time of the telemetry event. Tyre pressure monitoring is critical for haul truck safety and tyre life management on large mining vehicles.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyrePressureRearLeftKpa rdf:type rdf:Property ;
    rdfs:label 'Tyre Pressure Rear Left Kpa' ;
    rdfs:comment 'Tyre pressure of the rear-left tyre in kilopascals at the time of the telemetry event. Rear tyres on haul trucks carry the majority of loaded payload weight and are subject to higher wear and failure risk.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyrePressureRearRightKpa rdf:type rdf:Property ;
    rdfs:label 'Tyre Pressure Rear Right Kpa' ;
    rdfs:comment 'Tyre pressure of the rear-right tyre in kilopascals at the time of the telemetry event. Rear tyres on haul trucks carry the majority of loaded payload weight and are subject to higher wear and failure risk.' ;
    rdfs:domain ind:TelemetryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyreRecordId rdf:type rdf:Property ;
    rdfs:label 'Tyre Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each tyre lifecycle record in the tyre management system. Primary key for the tyre_record data product.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedHours rdf:type rdf:Property ;
    rdfs:label 'Accumulated Hours' ;
    rdfs:comment 'Total engine/operating hours accumulated on this tyre across its entire service life (including prior fitments if retreaded or rotated). Sourced from Caterpillar MineStar or Infor EAM. Key metric for tyre life forecasting and TKPH compliance.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedKm rdf:type rdf:Property ;
    rdfs:label 'Accumulated Km' ;
    rdfs:comment 'Total kilometres travelled by the tyre across its entire service life. Sourced from fleet management telematics. Used alongside accumulated_hours for tyre life benchmarking and rotation scheduling.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationCode rdf:type rdf:Property ;
    rdfs:label 'Application Code' ;
    rdfs:comment 'TRA/ISO application category code indicating the equipment type the tyre is designed for: E=Earthmover/Off-the-Road, L=Loader, G=Grader, C=Compactor, IND=Industrial. Drives TKPH rating selection and procurement.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:axlePosition rdf:type rdf:Property ;
    rdfs:label 'Axle Position' ;
    rdfs:comment 'Axle group on which the tyre is mounted (front, rear, tag/pusher, or all for single-axle equipment). Complements position_code for load distribution and wear analysis.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundGrade rdf:type rdf:Property ;
    rdfs:label 'Compound Grade' ;
    rdfs:comment 'OEM-designated rubber compound or product line grade (e.g., E4, L5, VSDP, XLDD2). Indicates the tyre construction and application suitability for specific haul road conditions.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerHour rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hour' ;
    rdfs:comment 'Calculated cost per operating hour in the operating currency, derived from purchase_cost divided by accumulated_hours at removal or current point in service. Key performance indicator for tyre vendor comparison and OPEX benchmarking.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used for end-of-life tyre disposal. Null if tyre is still in service. Supports environmental compliance reporting under ISO 14001 and regulatory waste management obligations. Retreaded tyres re-enter service and generate a new tyre_record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Eam Asset Number' ;
    rdfs:comment 'Infor EAM asset number assigned to this tyre as a tracked asset. Provides the cross-reference key between the tyre management system (Kal Tire TOMS / Klinge) and the Infor EAM asset register for maintenance cost allocation.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulRoadCondition rdf:type rdf:Property ;
    rdfs:label 'Haul Road Condition' ;
    rdfs:comment 'Assessed condition rating of the primary haul road on which this tyre operated at time of removal. Contextualises tyre wear and damage patterns; poor haul road conditions are a leading cause of premature tyre failure in open-cut mining.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflationPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Inflation Pressure Kpa' ;
    rdfs:comment 'Most recently recorded tyre inflation pressure in kilopascals (kPa) at the last inspection. Correct inflation is critical for tyre life, fuel efficiency, and safety. Compared against OEM-recommended cold inflation pressure.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRetreaded rdf:type rdf:Property ;
    rdfs:label 'Is Retreaded' ;
    rdfs:comment 'Indicates whether the tyre currently in service is a retreaded carcass (True) or a new tyre (False). Retreaded tyres typically have different cost profiles and performance expectations.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadRatingKg rdf:type rdf:Property ;
    rdfs:label 'Load Rating Kg' ;
    rdfs:comment 'Maximum static load capacity in kilograms as specified by the OEM for this tyre at the recommended inflation pressure. Used to validate tyre fitment against vehicle gross vehicle mass (GVM) requirements.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemBrand rdf:type rdf:Property ;
    rdfs:label 'Oem Brand' ;
    rdfs:comment 'Tyre manufacturer brand name (e.g., Bridgestone, Michelin, Goodyear, Titan). Used for vendor performance comparison and procurement decisions.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original purchase cost of the tyre in the operating currency. Used as the basis for cost per hour (CPH) and cost per kilometre calculations. Represents a significant component of mobile fleet Operating Expenditure (OPEX) at 10-15% of total.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP or Pronto Xi purchase order number under which this tyre was procured. Enables traceability from tyre record back to procurement contract and vendor invoice for cost allocation and warranty claims.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Recommended Pressure Kpa' ;
    rdfs:comment 'OEM-recommended cold inflation pressure in kilopascals (kPa) for this tyre size and load rating. Reference value for pressure compliance checks and deviation alerting.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Timestamp when this tyre record was first created in the system, representing the record audit creation time. Supports data lineage, audit trail, and Silver layer ingestion tracking.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason code for tyre removal from service. Drives failure mode analysis, vendor performance benchmarking, and haul road condition assessment. [ENUM-REF-CANDIDATE: worn|damaged|rotated|scrapped|puncture|sidewall_failure|heat_separation|scheduled_change|bead_damage|cut — promote to reference product]' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retreadCount rdf:type rdf:Property ;
    rdfs:label 'Retread Count' ;
    rdfs:comment 'Number of times this tyre carcass has been retreaded. Tracks carcass reuse for cost optimisation and quality assurance. OEM carcass inspection standards typically limit retreads to 1-2 cycles for large OTR tyres.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeSpecification rdf:type rdf:Property ;
    rdfs:label 'Size Specification' ;
    rdfs:comment 'Standard tyre size designation in OEM format (e.g., 40.00R57, 27.00R49, 37.00R57). Encodes width, aspect ratio, and rim diameter per TRA/ETRTO standards. Critical for procurement and fitment compatibility.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedRatingKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Rating Kmh' ;
    rdfs:comment 'Maximum permissible operating speed in kilometres per hour as specified by the OEM. Relevant for haul road speed limit compliance and tyre selection for high-speed haulage applications.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tkphActual rdf:type rdf:Property ;
    rdfs:label 'Tkph Actual' ;
    rdfs:comment 'Calculated actual TKPH value based on the haul truck payload, haul road distance, and cycle time recorded by Caterpillar MineStar. Compared against tkph_rating to assess thermal overload risk.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tkphRating rdf:type rdf:Property ;
    rdfs:label 'Tkph Rating' ;
    rdfs:comment 'OEM-specified Tonne-Kilometres Per Hour (TKPH) rating for the tyre, representing the maximum thermal load the tyre can sustain. Compliance with TKPH rating is critical to prevent heat-related tyre failures in open-cut mining haul cycles.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treadDepthCurrentMm rdf:type rdf:Property ;
    rdfs:label 'Tread Depth Current Mm' ;
    rdfs:comment 'Most recent tread depth measurement in millimetres recorded at the last inspection. Used to assess remaining tyre life and trigger rotation or replacement decisions.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treadDepthNewMm rdf:type rdf:Property ;
    rdfs:label 'Tread Depth New Mm' ;
    rdfs:comment 'Original tread depth in millimetres when the tyre was new, as specified by the OEM. Baseline reference for calculating tread wear percentage and remaining tread life.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treadDepthRemovalMm rdf:type rdf:Property ;
    rdfs:label 'Tread Depth Removal Mm' ;
    rdfs:comment 'Tread depth in millimetres measured at the time of tyre removal. Null if tyre is still in service. Used to determine whether the tyre reached its designed wear limit or was removed prematurely.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tyreStatus rdf:type rdf:Property ;
    rdfs:label 'Tyre Status' ;
    rdfs:comment 'Current lifecycle state of the tyre. Tracks whether the tyre is actively mounted, held in the tyre bay, undergoing repair/retread, scrapped, or disposed. Supports inventory management and lifecycle cost analysis.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tyreType rdf:type rdf:Property ;
    rdfs:label 'Tyre Type' ;
    rdfs:comment 'Tyre construction category indicating internal structure. Radial is standard for large haul trucks; bias ply used on some older or smaller equipment; solid and foam-filled used in specific underground or loader applications.' ;
    rdfs:domain ind:TyreRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilisationRecordId rdf:type rdf:Property ;
    rdfs:label 'Utilisation Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each shift-level or daily utilisation record. Primary key for the utilisation_record data product in the equipment domain.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the utilisation record was formally approved by the shift supervisor or production controller. Marks the record as authoritative for inclusion in production and fleet performance reports.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleCount rdf:type rdf:Property ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Number of complete operational cycles (e.g., load-haul-dump cycles for trucks, drill-hole completions for drills) performed by the asset during the period. Used for productivity rate analysis and equipment wear modelling.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayHours rdf:type rdf:Property ;
    rdfs:label 'Delay Hours' ;
    rdfs:comment 'Hours lost to operational delays not attributable to maintenance (e.g., blast delays, traffic management, shift change, fuelling, operator fatigue breaks). Captured separately to support delay category analysis.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total hours the asset was unavailable for production due to planned or unplanned maintenance, breakdowns, or inspections. Used in MTBF and MTTR calculations and physical availability reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelBurnRateLph rdf:type rdf:Property ;
    rdfs:label 'Fuel Burn Rate Lph' ;
    rdfs:comment 'Average fuel consumption rate in litres per operating hour during the period. Benchmarked against OEM specifications to identify engine inefficiency, overloading, or operator behaviour issues.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleHours rdf:type rdf:Property ;
    rdfs:label 'Idle Hours' ;
    rdfs:comment 'Hours the asset was powered on and available but not performing productive work (e.g., waiting for trucks, queuing at crusher). Key metric for identifying operational inefficiencies and fleet sizing opportunities.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeeScore rdf:type rdf:Property ;
    rdfs:label 'Oee Score' ;
    rdfs:comment 'Composite OEE (Overall Equipment Effectiveness) score for the asset during the period, expressed as a percentage. Combines availability, performance, and quality dimensions. Sourced from MineStar or calculated during silver layer processing.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingZone rdf:type rdf:Property ;
    rdfs:label 'Operating Zone' ;
    rdfs:comment 'Mine area or operational zone where the asset was primarily deployed during the period (e.g., pit bench level, ROM pad, processing plant, waste dump). Supports spatial productivity analysis and fleet allocation optimisation.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Physical Availability Pct' ;
    rdfs:comment 'Percentage of scheduled hours during which the asset was mechanically available (not in maintenance downtime). Calculated as ((scheduled_hours - downtime_hours) / scheduled_hours) * 100. Distinct from utilisation — measures mechanical readiness.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Hours' ;
    rdfs:comment 'Hours the asset was unavailable due to scheduled preventive maintenance activities. Subset of downtime_hours. Used to distinguish planned versus unplanned downtime for maintenance strategy analysis.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDelayCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Delay Category' ;
    rdfs:comment 'The dominant category of delay or downtime that most impacted utilisation during the period (e.g., blast exclusion, fuelling, shift change, mechanical breakdown, weather, traffic). [ENUM-REF-CANDIDATE: blast_exclusion|fuelling|shift_change|mechanical_breakdown|weather|traffic|operator_fatigue|waiting_for_instructions|road_conditions|other — promote to reference product]' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance Hours' ;
    rdfs:comment 'Difference in total hours between the MineStar FMS automated record and the manually submitted shift report. Non-zero values trigger investigation. Supports data quality management and audit compliance.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'Calendar date for which this utilisation record applies. Used for daily aggregation, trend analysis, and LOM (Life of Mine) planning.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Granularity of the utilisation record indicating whether it represents a single shift, a daily roll-up, or a weekly summary. Determines the time horizon of the hours captured.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total hours the asset was scheduled to be available for production during the shift or day, as defined in the mine production schedule. Denominator for physical availability calculations.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftReportReference rdf:type rdf:Property ;
    rdfs:label 'Shift Report Reference' ;
    rdfs:comment 'Reference number or identifier of the paper or digital shift report against which this utilisation record was reconciled. Provides audit traceability between MineStar FMS data and manual shift supervisor records.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyHours rdf:type rdf:Property ;
    rdfs:label 'Standby Hours' ;
    rdfs:comment 'Hours the asset was available and ready for deployment but not assigned to a task (e.g., awaiting operator, weather hold, blast exclusion zone). Distinguishes planned non-productive time from idle time.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unplannedMaintenanceHours rdf:type rdf:Property ;
    rdfs:label 'Unplanned Maintenance Hours' ;
    rdfs:comment 'Hours the asset was unavailable due to unexpected breakdowns or corrective maintenance. Subset of downtime_hours. High values indicate reliability issues and drive MTBF and MTTR analysis.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useOfAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Use Of Availability Pct' ;
    rdfs:comment 'Ratio of operating hours to available hours (scheduled minus downtime), expressed as a percentage. Measures how effectively the operations team uses the mechanically available asset. Complements physical availability to form the OEE framework.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilisationPct rdf:type rdf:Property ;
    rdfs:label 'Utilisation Pct' ;
    rdfs:comment 'Ratio of operating hours to scheduled hours expressed as a percentage. Primary KPI for fleet productivity and LOM (Life of Mine) planning. Calculated as (operating_hours / scheduled_hours) * 100.' ;
    rdfs:domain ind:UtilisationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:explorationBudgetId rdf:type rdf:Property ;
    rdfs:label 'Exploration Budget Id' ;
    rdfs:comment 'Unique identifier for the exploration budget record. Primary key for the exploration budget entity.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capexBudgetId rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.capex_budget. Business justification: Exploration budgets for capital activities (e.g., drill rig purchases, infrastructure) link to capex_budget for consolidated capital planning, board approvals, and capital allocation reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexBudget .

ind:opexBudgetId rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.opex_budget. Business justification: Exploration budgets for operational activities (drilling, assays, field work) link to opex_budget for operating cost control, variance analysis, and AISC reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpexBudget .

ind:updatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Budget change audit trails require employee attribution for financial governance and SOX compliance. Essential for tracking who modified budget allocations. Replaces user text field.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure' ;
    rdfs:comment 'Actual amount spent against this budget to date. Used for variance analysis and budget performance monitoring.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The formally approved budget amount for this exploration programme or activity. Represents the authorized spending limit.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Classification of budget as capital expenditure or operating expenditure. Critical for financial reporting and tax treatment under IFRS 6.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Unique business identifier for the exploration budget. Used for external reporting and cross-system reference.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the exploration budget allocation. Provides human-readable identification of the budget purpose.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the exploration budget. Tracks budget through approval workflow and operational lifecycle. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalisationEligible rdf:type rdf:Property ;
    rdfs:label 'Capitalisation Eligible' ;
    rdfs:comment 'Indicates whether expenditure under this budget is eligible for capitalisation under IFRS 6. True if expenditure can be capitalized as exploration and evaluation asset, false if must be expensed.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Amount of budget that has been committed through purchase orders or contracts but not yet spent. Represents encumbered funds.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:explorationStage rdf:type rdf:Property ;
    rdfs:label 'Exploration Stage' ;
    rdfs:comment 'Stage of exploration maturity this budget supports. Greenfield represents early-stage exploration, brownfield represents near-mine exploration, resource definition focuses on JORC resource estimation, pre-feasibility and feasibility support economic studies.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialYear rdf:type rdf:Property ;
    rdfs:label 'Financial Year' ;
    rdfs:comment 'The financial year this budget applies to, formatted as FY followed by four-digit year (e.g., FY2024). Aligns with corporate financial planning cycles.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointVentureSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Share Percentage' ;
    rdfs:comment 'Percentage share of exploration budget attributable to the company in joint venture arrangements. Used to calculate net budget exposure and funding obligations.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumExpenditureCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment' ;
    rdfs:comment 'Statutory minimum expenditure required to maintain exploration license or tenement rights. Critical for regulatory compliance and license retention.' ;
    rdfs:domain ind:ExplorationBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between approved budget and actual expenditure. Positive values indicate under-spend, negative values indicate over-spend.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version type of the budget record. Original represents initial approved budget, revised reflects formal amendments, forecast represents updated projections, supplementary indicates additional allocations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP WBS element code linking this budget to a specific project or programme phase. Enables project-based budget tracking and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentPersonId rdf:type rdf:Property ;
    rdfs:label 'Competent Person Id' ;
    rdfs:comment 'Unique identifier for the competent person record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetentPerson .

ind:commodityExpertise rdf:type rdf:Property ;
    rdfs:label 'Commodity Expertise' ;
    rdfs:comment 'Comma-separated list of mineral commodities for which the CP/QP has demonstrated expertise and experience (e.g., iron ore, copper, gold, lithium, nickel, coal).' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentPersonStatus rdf:type rdf:Property ;
    rdfs:label 'Competent Person Status' ;
    rdfs:comment 'Current operational status of the Competent Person record in the master register. Active CPs are eligible to sign off on resource/reserve statements.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the CP/QP consent expires and must be renewed for continued use of their statement in public disclosures.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'The name of the organization currently employing the Competent Person. Used to assess independence and potential conflicts of interest.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Declaration Effective From' ;
    rdfs:comment 'The start date from which the CP/QP declaration and sign-off is effective for resource/reserve reporting purposes.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationEffectiveTo rdf:type rdf:Property ;
    rdfs:label 'Declaration Effective To' ;
    rdfs:comment 'The end date of the CP/QP declaration effective period. Nullable for ongoing declarations.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplineExpertise rdf:type rdf:Property ;
    rdfs:label 'Discipline Expertise' ;
    rdfs:comment 'The technical discipline(s) in which the CP/QP is qualified (e.g., geology, mining engineering, metallurgy, geophysics, resource estimation, mine planning).' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerType rdf:type rdf:Property ;
    rdfs:label 'Employer Type' ;
    rdfs:comment 'Classification of the CP/QP\'s employer type, used to determine independence status for regulatory reporting.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiveYearExperienceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Five Year Experience Confirmed' ;
    rdfs:comment 'Boolean flag confirming that the CP/QP has at least five years of relevant experience in the style of mineralization and type of deposit under consideration, as required by JORC/NI 43-101/SAMREC.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:independenceStatus rdf:type rdf:Property ;
    rdfs:label 'Independence Status' ;
    rdfs:comment 'Indicates whether the CP/QP is independent of the issuer/company. Independent means the person is not an employee, officer, or director of the company and does not have material financial interest. Required disclosure under ASX, TSX, and SEC rules.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The expiry date of the CP/QP\'s professional indemnity insurance policy, if applicable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'The date on which the CP/QP credentials, membership status, and experience were last verified by the company\'s compliance team.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipGrade rdf:type rdf:Property ;
    rdfs:label 'Membership Grade' ;
    rdfs:comment 'The grade or class of membership held (e.g., Fellow, Member, Associate) which determines eligibility to act as a Competent Person.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'The unique membership or registration number issued by the professional body to the Competent Person.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current standing of the CP/QP membership with their professional body. Must be \'current\' for the person to sign off on resource/reserve statements.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'The date by which the next verification of CP/QP credentials and membership status must be completed to maintain compliance.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalBody rdf:type rdf:Property ;
    rdfs:label 'Professional Body' ;
    rdfs:comment 'The recognized professional organization through which the CP/QP is accredited. AusIMM (Australasian Institute of Mining and Metallurgy), AIG (Australian Institute of Geoscientists), CIM (Canadian Institute of Mining, Metallurgy and Petroleum), SACNASP (South African Council for Natural Scientific Professions), SME (Society for Mining, Metallurgy & Exploration), IMMM (Institute of Materials, Minerals and Mining).' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalIndemnityInsurance rdf:type rdf:Property ;
    rdfs:label 'Professional Indemnity Insurance' ;
    rdfs:comment 'Boolean flag indicating whether the CP/QP holds current professional indemnity insurance, which may be required by some professional bodies and reporting jurisdictions.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationDegree rdf:type rdf:Property ;
    rdfs:label 'Qualification Degree' ;
    rdfs:comment 'The highest relevant academic degree held by the CP/QP (e.g., Bachelor of Science in Geology, Master of Engineering in Mining).' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationInstitution rdf:type rdf:Property ;
    rdfs:label 'Qualification Institution' ;
    rdfs:comment 'The name of the educational institution that awarded the CP/QP\'s highest relevant degree.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country in which the CP/QP is registered with their professional body. [ENUM-REF-CANDIDATE: AUS|CAN|ZAF|USA|GBR|CHL|PER|BRA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCodeAuthority rdf:type rdf:Property ;
    rdfs:label 'Reporting Code Authority' ;
    rdfs:comment 'The mineral resource reporting code under which the CP/QP is authorized to sign off. JORC (Australia), NI 43-101 (Canada), SAMREC (South Africa), PERC (Europe), CRIRSCO (international umbrella).' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Signature Authority Level' ;
    rdfs:comment 'The level of reporting the CP/QP is authorized to sign off on: mineral resources only, ore reserves only, both, or exploration results only.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsExperience rdf:type rdf:Property ;
    rdfs:label 'Years Experience' ;
    rdfs:comment 'Total number of years of relevant experience in the mineral industry. Must be at least 5 years to qualify as a Competent Person under JORC/NI 43-101/SAMREC.' ;
    rdfs:domain ind:CompetentPerson ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillingContractorId rdf:type rdf:Property ;
    rdfs:label 'Drilling Contractor Id' ;
    rdfs:comment 'Reference to the drilling contractor organization responsible for executing this hole. Used for contractor performance evaluation, cost tracking, and quality assurance.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:loggedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Logged By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Geological logging requires qualified geologist assignment for QA/QC and competency tracking. Essential for resource estimate validation and training needs analysis. Replaces text field.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetCommodityId rdf:type rdf:Property ;
    rdfs:label 'Target Commodity Id' ;
    rdfs:comment 'Foreign key linking to product.commodity. Business justification: Individual drill holes target specific commodities - determines sampling protocol, assay suite selection, and QAQC standards (e.g., gold requires fire assay, base metals use multi-element ICP). Normal' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Free-text description of the reason for early termination or abandonment of the drill hole. Common reasons include equipment failure, ground conditions (cavity, water ingress), deviation beyond acceptable limits, or program budget constraints. Populated only when hole_status is abandoned.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAzimuth rdf:type rdf:Property ;
    rdfs:label 'Actual Azimuth' ;
    rdfs:comment 'The actual measured horizontal direction of the drill hole at the collar, measured in degrees clockwise from grid north (0-360). Captured from downhole survey or collar survey after drilling commences. May differ from planned azimuth due to setup adjustments or ground conditions.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDepth rdf:type rdf:Property ;
    rdfs:label 'Actual Depth' ;
    rdfs:comment 'The actual total depth achieved by the drill hole measured along the hole trajectory from collar to end-of-hole, measured in meters. May differ from planned depth due to early termination, ground conditions, or program adjustments.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDip rdf:type rdf:Property ;
    rdfs:label 'Actual Dip' ;
    rdfs:comment 'The actual measured vertical angle of the drill hole at the collar, measured in degrees from horizontal. Captured from downhole survey or collar survey after drilling commences. May differ from planned dip due to setup adjustments or ground conditions.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarEasting rdf:type rdf:Property ;
    rdfs:label 'Collar Easting' ;
    rdfs:comment 'The easting (X) coordinate of the drill hole collar in the local mine grid coordinate system, measured in meters. This is the authoritative spatial reference for the hole location used in resource modeling and mine planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarLatitude rdf:type rdf:Property ;
    rdfs:label 'Collar Latitude' ;
    rdfs:comment 'The latitude of the drill hole collar in WGS84 geographic coordinate system, measured in decimal degrees. Used for global positioning, regulatory reporting, and integration with external GIS systems.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarLongitude rdf:type rdf:Property ;
    rdfs:label 'Collar Longitude' ;
    rdfs:comment 'The longitude of the drill hole collar in WGS84 geographic coordinate system, measured in decimal degrees. Used for global positioning, regulatory reporting, and integration with external GIS systems.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarNorthing rdf:type rdf:Property ;
    rdfs:label 'Collar Northing' ;
    rdfs:comment 'The northing (Y) coordinate of the drill hole collar in the local mine grid coordinate system, measured in meters. Used in conjunction with easting and RL to define the three-dimensional collar position.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collarRl rdf:type rdf:Property ;
    rdfs:label 'Collar Rl' ;
    rdfs:comment 'The elevation (Z) coordinate of the drill hole collar in the local mine grid coordinate system, measured in meters above the site datum. RL (Reduced Level) is the mining industry standard term for elevation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coreDiameter rdf:type rdf:Property ;
    rdfs:label 'Core Diameter' ;
    rdfs:comment 'The nominal diameter of the drill core recovered, applicable only to diamond core drilling. Standard sizes include PQ (85mm), HQ (63.5mm), NQ (47.6mm), BQ (36.4mm). Used for sample volume calculations and metallurgical testwork planning. [ENUM-REF-CANDIDATE: PQ|HQ|NQ|BQ|NQ2|HQ3|NMLC|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'The drilling method used for this hole. RC (Reverse Circulation) provides chip samples; diamond core provides continuous core samples; RAB (Rotary Air Blast) and aircore are used for shallow reconnaissance; percussion and rotary are used for specific geological conditions; directional drilling is used for underground or complex geometries. [ENUM-REF-CANDIDATE: RC|diamond_core|RAB|aircore|percussion|rotary|directional — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holeCode rdf:type rdf:Property ;
    rdfs:label 'Hole Code' ;
    rdfs:comment 'Unique business identifier for the drill hole collar, typically assigned by the exploration team following site naming conventions. This is the externally-known collar identifier used in geological reports, assay certificates, and JORC/NI 43-101/SAMREC resource statements.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holePurpose rdf:type rdf:Property ;
    rdfs:label 'Hole Purpose' ;
    rdfs:comment 'The primary objective of the drill hole. Exploration holes target new mineralization; infill holes increase resource confidence; geotechnical holes assess rock mechanics for mine design; sterilisation holes confirm absence of mineralization in infrastructure footprints; hydrogeological holes assess groundwater; metallurgical holes provide samples for processing testwork.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holeStatus rdf:type rdf:Property ;
    rdfs:label 'Hole Status' ;
    rdfs:comment 'Current lifecycle status of the drill hole. Planned holes are scheduled but not started; in-progress holes are actively being drilled; completed holes have reached target depth and been logged; abandoned holes were terminated early due to technical issues; suspended holes are temporarily halted; surveyed holes have had final downhole survey completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggedDate rdf:type rdf:Property ;
    rdfs:label 'Logged Date' ;
    rdfs:comment 'The date the geological logging of the drill hole was completed. Used for workflow tracking and data currency assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAzimuth rdf:type rdf:Property ;
    rdfs:label 'Planned Azimuth' ;
    rdfs:comment 'The planned horizontal direction of the drill hole at the collar, measured in degrees clockwise from grid north (0-360). Azimuth defines the compass bearing of the hole trajectory.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDepth rdf:type rdf:Property ;
    rdfs:label 'Planned Depth' ;
    rdfs:comment 'The planned total depth of the drill hole measured along the hole trajectory from collar to end-of-hole, measured in meters. Defines the target depth for the drilling contractor.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDip rdf:type rdf:Property ;
    rdfs:label 'Planned Dip' ;
    rdfs:comment 'The planned vertical angle of the drill hole at the collar, measured in degrees from horizontal. Positive values indicate downward inclination; negative values indicate upward inclination. A vertical hole has a dip of -90 degrees.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preCollarDepth rdf:type rdf:Property ;
    rdfs:label 'Pre Collar Depth' ;
    rdfs:comment 'The depth of pre-collar drilling (typically RC or aircore) completed before switching to diamond core drilling, measured in meters. Used in two-stage drilling programs to reduce diamond drilling costs through overburden.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaqcStatus rdf:type rdf:Property ;
    rdfs:label 'Qaqc Status' ;
    rdfs:comment 'The overall quality assurance and quality control status for this drill hole, based on review of sampling procedures, assay QAQC results, survey accuracy, and logging completeness. Passed holes are suitable for resource estimation; failed holes require remediation or exclusion.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryPercentage rdf:type rdf:Property ;
    rdfs:label 'Recovery Percentage' ;
    rdfs:comment 'The average percentage of core recovered relative to the drilled interval, applicable to diamond core drilling. High recovery (>95%) indicates competent ground and good drilling practice; low recovery may indicate fractured ground, voids, or drilling issues. Critical for resource confidence classification.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleInterval rdf:type rdf:Property ;
    rdfs:label 'Sample Interval' ;
    rdfs:comment 'The standard length interval used for sampling this drill hole, measured in meters. Typically 1m for RC drilling and variable (0.5-1.5m) for diamond core based on geological contacts. Used for sample planning and assay result interpretation.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'The method used to survey the drill hole trajectory. Gyroscopic surveys are most accurate and unaffected by magnetic interference; magnetic surveys are cost-effective but affected by magnetic ore bodies; electronic multi-shot provides continuous trajectory; differential GPS and total station are used for collar positioning. [ENUM-REF-CANDIDATE: gyroscopic|magnetic|electronic_multi_shot|single_shot|differential_gps|total_station|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeology rdf:type rdf:Property ;
    rdfs:label 'Target Geology' ;
    rdfs:comment 'Free-text description of the geological target or formation being intersected by this drill hole. Includes target lithology, structure, or mineralization style. Used for geological interpretation and targeting review.' ;
    rdfs:domain ind:DrillHole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillHoleSurveyId rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Survey Id' ;
    rdfs:comment 'Unique identifier for the drill hole survey measurement record.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surveyor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Downhole surveys require certified surveyors for accuracy validation and competency compliance. Links survey quality to workforce qualifications. Removes denormalized name field.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calculatedEasting rdf:type rdf:Property ;
    rdfs:label 'Calculated Easting' ;
    rdfs:comment 'Calculated easting coordinate at this survey depth based on collar position, azimuth, and dip measurements.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedElevation rdf:type rdf:Property ;
    rdfs:label 'Calculated Elevation' ;
    rdfs:comment 'Calculated elevation (reduced level) at this survey depth based on collar elevation and dip measurements.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedNorthing rdf:type rdf:Property ;
    rdfs:label 'Calculated Northing' ;
    rdfs:comment 'Calculated northing coordinate at this survey depth based on collar position, azimuth, and dip measurements.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration of the survey instrument prior to this measurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Spatial reference system or coordinate system used for azimuth and spatial calculations (e.g., WGS84, local mine grid, UTM zone).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFromPlanned rdf:type rdf:Property ;
    rdfs:label 'Deviation From Planned' ;
    rdfs:comment 'Calculated horizontal deviation distance from the planned drill hole trajectory at this survey depth, measured in meters.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Instrument Serial Number' ;
    rdfs:comment 'Serial number of the specific survey instrument used for this measurement, enabling traceability and calibration verification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:magneticDeclination rdf:type rdf:Property ;
    rdfs:label 'Magnetic Declination' ;
    rdfs:comment 'Magnetic declination correction applied to convert magnetic azimuth to true azimuth at the survey location and date. Positive values indicate eastward declination.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:magneticFieldStrength rdf:type rdf:Property ;
    rdfs:label 'Magnetic Field Strength' ;
    rdfs:comment 'Magnetic field strength measured at the survey point in nanoTesla. High magnetic interference may affect magnetic survey instrument accuracy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredAzimuth rdf:type rdf:Property ;
    rdfs:label 'Measured Azimuth' ;
    rdfs:comment 'Horizontal angle of the drill hole at this survey point, measured in degrees clockwise from true north (0-360).' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredDip rdf:type rdf:Property ;
    rdfs:label 'Measured Dip' ;
    rdfs:comment 'Vertical angle of the drill hole at this survey point, measured in degrees from horizontal. Negative values indicate downward inclination.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCompany rdf:type rdf:Property ;
    rdfs:label 'Survey Company' ;
    rdfs:comment 'Name of the company or contractor that performed the downhole survey, if external.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyDepth rdf:type rdf:Property ;
    rdfs:label 'Survey Depth' ;
    rdfs:comment 'Depth down the hole at which this survey measurement was taken, measured in meters from the collar.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Survey Instrument Type' ;
    rdfs:comment 'Type of downhole survey instrument used to capture this measurement. Gyroscope instruments are preferred for accuracy in magnetic environments.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyQualityCode rdf:type rdf:Property ;
    rdfs:label 'Survey Quality Code' ;
    rdfs:comment 'Quality assessment code indicating the reliability and verification status of this survey measurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyRunNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Run Number' ;
    rdfs:comment 'Sequential number identifying the survey run or trip down the hole. Multiple runs may be performed for verification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current workflow status of this survey measurement record in the data validation and approval process.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtSurvey rdf:type rdf:Property ;
    rdfs:label 'Temperature At Survey' ;
    rdfs:comment 'Temperature recorded at the survey depth during measurement, in degrees Celsius. Temperature can affect instrument accuracy.' ;
    rdfs:domain ind:DrillHoleSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or identifier of the geologist or data manager who validated and approved this survey measurement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which this survey measurement was validated and approved for use in resource estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Id' ;
    rdfs:comment 'Foreign key linking to hse.emergency_response_plan. Business justification: Drilling programs must reference site emergency response plans (medical evacuation, spill response, rig fire). Operational requirement for contractor mobilization and safety induction. Plan ID include' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:hseAuditId rdf:type rdf:Property ;
    rdfs:label 'Hse Audit Id' ;
    rdfs:comment 'Foreign key linking to hse.audit. Business justification: Drilling programs are subject to HSE audits (contractor safety compliance, environmental permit adherence). Audit findings link to program for corrective action tracking and contractor performance eva' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:primaryDrillRigAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Drill Rig Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Drill programs assign a primary rig during planning for resource scheduling, budget estimation, and contractor mobilization. This supports program planning, rig availability forecasting, and contracto' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actualHoleCount rdf:type rdf:Property ;
    rdfs:label 'Actual Hole Count' ;
    rdfs:comment 'Total number of drill holes actually completed as part of this program. Used for program performance tracking and variance analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualMetreage rdf:type rdf:Property ;
    rdfs:label 'Actual Metreage' ;
    rdfs:comment 'Total actual drilling metreage (in metres) completed for the program. Used for cost reconciliation and performance tracking against plan.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillingContractorName rdf:type rdf:Property ;
    rdfs:label 'Drilling Contractor Name' ;
    rdfs:comment 'Name of the drilling contractor or service provider engaged to execute the drilling program.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillingMethod rdf:type rdf:Property ;
    rdfs:label 'Drilling Method' ;
    rdfs:comment 'Primary drilling technique employed in the program: diamond core (DD), reverse circulation (RC), rotary air blast (RAB), percussion, or sonic drilling. Determines sample quality and cost profile.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Environmental Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the environmental approval, permit, or Environmental Impact Statement (EIS) under which the drilling program is authorized.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureClassification rdf:type rdf:Property ;
    rdfs:label 'Expenditure Classification' ;
    rdfs:comment 'Classification of the drilling program expenditure as Capital Expenditure (CAPEX), Operating Expenditure (OPEX), or mixed. Critical for financial reporting and tax treatment under IFRS 6.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Count' ;
    rdfs:comment 'Total number of recordable Health, Safety, and Environment incidents that occurred during the execution of the drilling program. Used for safety performance tracking and LTIFR/TRIFR calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHoleCount rdf:type rdf:Property ;
    rdfs:label 'Planned Hole Count' ;
    rdfs:comment 'Total number of drill holes planned for this program as per the approved drilling plan.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedMetreage rdf:type rdf:Property ;
    rdfs:label 'Planned Metreage' ;
    rdfs:comment 'Total planned drilling metreage (in metres) for the program as per the approved drilling plan. Critical for budget estimation and contractor scoping.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Planned or actual date when drilling operations concluded for this program. Used for program duration tracking and contractor demobilization planning.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programObjective rdf:type rdf:Property ;
    rdfs:label 'Program Objective' ;
    rdfs:comment 'Detailed description of the strategic and technical objectives of the drilling program, including target resource category upgrade, geological model validation, or feasibility study support.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Planned or actual date when drilling operations commenced for this program. Critical for Life of Mine (LOM) planning and resource update scheduling.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaqcProtocolApplied rdf:type rdf:Property ;
    rdfs:label 'Qaqc Protocol Applied' ;
    rdfs:comment 'Indicates whether a formal QAQC protocol (including certified reference materials, blanks, and duplicates) was applied during the drilling program to ensure sample integrity and assay reliability.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehabilitationCompleted rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Completed' ;
    rdfs:comment 'Indicates whether site rehabilitation (drill pad restoration, collar capping, and environmental remediation) has been completed following the conclusion of the drilling program.' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehabilitationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Completion Date' ;
    rdfs:comment 'Date when site rehabilitation activities were completed and the drill site was returned to its pre-disturbance condition or approved final land use.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date when the Competent Person formally approved the drilling program results for inclusion in resource and reserve reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffStatus rdf:type rdf:Property ;
    rdfs:label 'Sign Off Status' ;
    rdfs:comment 'Approval status of the drilling program results by the Competent Person: pending (awaiting review), in_review (under technical review), approved (signed off for resource update), or rejected (requires additional work).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResourceCategory rdf:type rdf:Property ;
    rdfs:label 'Target Resource Category' ;
    rdfs:comment 'JORC/NI 43-101/SAMREC resource classification category that the drilling program aims to achieve or upgrade: inferred (lowest confidence), indicated (moderate confidence), or measured (highest confidence).' ;
    rdfs:domain ind:DrillProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureId rdf:type rdf:Property ;
    rdfs:label 'Expenditure Id' ;
    rdfs:comment 'Primary key for expenditure' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Exploration expenditure requires delegated authority tracking for financial controls and audit compliance. Links spending to authorized employees. Replaces text field with FK.' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary value of the expenditure or budget allocation in the specified currency.' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version identifier for the budget, enabling tracking of multiple budget revisions throughout the financial year (e.g., V1, V2, V3).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'The minimum statutory expenditure commitment amount required for the licence or programme in the specified financial period, used for compliance tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The SAP financial document number (e.g., invoice number, journal entry number) associated with this expenditure, enabling traceability to source documents.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureCategory rdf:type rdf:Property ;
    rdfs:label 'Expenditure Category' ;
    rdfs:comment 'Classification of the expenditure type: drilling, geophysics, geochemistry, geological mapping, assaying, camp and logistics costs, feasibility studies, or other exploration-related activities. [ENUM-REF-CANDIDATE: drilling|geophysics|geochemistry|mapping|assaying|camp_costs|studies|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureDate rdf:type rdf:Property ;
    rdfs:label 'Expenditure Date' ;
    rdfs:comment 'The date on which the actual expenditure was incurred or the budget was allocated, serving as the principal business event timestamp for this record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureDescription rdf:type rdf:Property ;
    rdfs:label 'Expenditure Description' ;
    rdfs:comment 'Free-text description providing additional context about the nature of the expenditure or budget allocation, including specific activities or deliverables.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriod rdf:type rdf:Property ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'The financial period (month) within the financial year, formatted as P01 through P12, enabling monthly budget vs actual tracking.' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the expenditure transaction was posted to the general ledger in the SAP system, distinct from the expenditure date for audit and reconciliation purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapCostObjectReference rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Object Reference' ;
    rdfs:comment 'The SAP internal order, WBS element, or cost centre code used as the cost object for this expenditure in the ERP system.' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryExpenditureComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Statutory Expenditure Compliance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this expenditure contributes toward satisfying minimum statutory expenditure commitments required under the exploration licence conditions.' ;
    rdfs:domain ind:Expenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geochemicalSurveyId rdf:type rdf:Property ;
    rdfs:label 'Geochemical Survey Id' ;
    rdfs:comment 'Unique identifier for the geochemical survey campaign. Primary key.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Foreign key linking to hse.environmental_monitoring. Business justification: Geochemical surveys may trigger environmental monitoring (soil contamination detection, water quality baseline). Survey results inform monitoring program design and regulatory reporting. Environmental' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalMonitoring .

ind:financeExplorationExpenditureId rdf:type rdf:Property ;
    rdfs:label 'Finance Exploration Expenditure Id' ;
    rdfs:comment 'Foreign key linking to finance.exploration_expenditure. Business justification: Geochemical surveys are exploration activities with direct costs. Finance tracks survey expenditure for IFRS6 compliance, area-of-interest accounting, and technical feasibility assessment.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExplorationExpenditure .

ind:surveyEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Survey Equipment Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Geochemical surveys use specific equipment (soil augers, portable XRF analyzers, sampling rigs). Linking survey to equipment supports calibration tracking, data quality validation, equipment performan' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:analyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Analytical Method' ;
    rdfs:comment 'Laboratory analytical technique used for sample analysis (e.g., ICP-MS, ICP-OES, Fire Assay, XRF). Defines detection capabilities and data quality parameters.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anomaliesIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Anomalies Identified Count' ;
    rdfs:comment 'Number of discrete geochemical anomalies identified from this survey that exceed the anomaly threshold and warrant further investigation.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anomalyThresholdPpm rdf:type rdf:Property ;
    rdfs:label 'Anomaly Threshold Ppm' ;
    rdfs:comment 'Geochemical concentration threshold in parts per million (ppm) above which results are classified as anomalous and warrant follow-up investigation.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Reporting standard or code to which the survey data and interpretation must comply (e.g., JORC Code 2012, NI 43-101, SAMREC Code). Critical for public disclosure and resource estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the external contractor or service provider engaged to conduct the field sampling program. Null if conducted by internal exploration team.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Overall assessment of the geochemical data quality based on QAQC results, sample recovery, and analytical performance. Influences confidence in interpretation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitPpm rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Ppm' ;
    rdfs:comment 'Lower detection limit of the analytical method in parts per million (ppm) for the target commodity. Critical for interpreting anomaly significance.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Recommended Flag' ;
    rdfs:comment 'Indicates whether the survey results warrant follow-up exploration activities such as detailed sampling, geophysics, or drilling based on anomaly significance.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geologicalSetting rdf:type rdf:Property ;
    rdfs:label 'Geological Setting' ;
    rdfs:comment 'Description of the regional geological environment and rock types within the survey area. Provides context for geochemical anomaly interpretation.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologistResponsible rdf:type rdf:Property ;
    rdfs:label 'Geologist Responsible' ;
    rdfs:comment 'Name of the qualified geologist or exploration manager responsible for survey design, execution oversight, and data interpretation.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gridSpacingM rdf:type rdf:Property ;
    rdfs:label 'Grid Spacing M' ;
    rdfs:comment 'Spacing between sample collection points in meters, defining the resolution and density of the geochemical survey grid.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaqcProtocol rdf:type rdf:Property ;
    rdfs:label 'Qaqc Protocol' ;
    rdfs:comment 'Quality assurance and quality control procedures applied during sampling and analysis, including standards, blanks, and duplicates insertion rates.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document reference or identifier for the technical report containing detailed survey methodology, results, and interpretation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDepthCm rdf:type rdf:Property ;
    rdfs:label 'Sample Depth Cm' ;
    rdfs:comment 'Standard depth in centimeters at which samples were collected below surface. Critical for data interpretation and comparison across surveys.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleMedium rdf:type rdf:Property ;
    rdfs:label 'Sample Medium' ;
    rdfs:comment 'Physical material type collected for geochemical analysis. Defines the sampling substrate and influences interpretation methodology. [ENUM-REF-CANDIDATE: soil|sediment|rock|vegetation|termite_mound|lag|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAreaKm2 rdf:type rdf:Property ;
    rdfs:label 'Survey Area Km2' ;
    rdfs:comment 'Total geographic area covered by the geochemical survey in square kilometers. Used for planning, cost estimation, and resource allocation.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the geochemical survey for tracking and reporting purposes across systems.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyEndDate rdf:type rdf:Property ;
    rdfs:label 'Survey End Date' ;
    rdfs:comment 'Date when field sampling activities for this geochemical survey campaign were completed. Null if survey is still in progress.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyName rdf:type rdf:Property ;
    rdfs:label 'Survey Name' ;
    rdfs:comment 'Business name or designation assigned to the geochemical survey campaign for identification and reference purposes.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyObjective rdf:type rdf:Property ;
    rdfs:label 'Survey Objective' ;
    rdfs:comment 'Primary exploration objective or purpose of the geochemical survey (e.g., regional reconnaissance, target generation, drill target refinement, resource extension).' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStartDate rdf:type rdf:Property ;
    rdfs:label 'Survey Start Date' ;
    rdfs:comment 'Date when field sampling activities for this geochemical survey campaign commenced.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the geochemical survey methodology employed. Defines the sampling medium and approach used for geochemical anomaly detection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSamplesCollected rdf:type rdf:Property ;
    rdfs:label 'Total Samples Collected' ;
    rdfs:comment 'Total number of geochemical samples collected during this survey campaign. Used for quality control and cost tracking.' ;
    rdfs:domain ind:GeochemicalSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'General weather and environmental conditions during the survey period that may have affected sampling quality or access (e.g., wet season, dry season, extreme heat).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologicalLogId rdf:type rdf:Property ;
    rdfs:label 'Geological Log Id' ;
    rdfs:comment 'Unique identifier for the geological log record. Primary key for the geological log entity. Inferred role: EVENT_LOG (append-only geological observations per drill hole interval).' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alterationIntensity rdf:type rdf:Property ;
    rdfs:label 'Alteration Intensity' ;
    rdfs:comment 'Qualitative assessment of the intensity or degree of alteration observed: none, weak, moderate, strong, or pervasive. Used in conjunction with alteration_type for resource modeling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alterationType rdf:type rdf:Property ;
    rdfs:label 'Alteration Type' ;
    rdfs:comment 'Type of hydrothermal or weathering alteration observed in the interval (e.g., silicification, chloritisation, sericitisation, hematisation). Critical for understanding mineralization processes and JORC Table 1 Section 1 reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colour rdf:type rdf:Property ;
    rdfs:label 'Colour' ;
    rdfs:comment 'Primary colour of the rock observed in the interval (e.g., grey, red, green, black, white). May indicate oxidation state, alteration, or lithology.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreCondition rdf:type rdf:Property ;
    rdfs:label 'Core Condition' ;
    rdfs:comment 'Overall condition of the drill core: excellent, good, fair, poor, or very_poor. Reflects core integrity and quality for geological interpretation.' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthFrom rdf:type rdf:Property ;
    rdfs:label 'Depth From' ;
    rdfs:comment 'Starting depth of the logged interval in meters below surface or collar. Used to define the from-to interval for geological observations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthTo rdf:type rdf:Property ;
    rdfs:label 'Depth To' ;
    rdfs:comment 'Ending depth of the logged interval in meters below surface or collar. Used to define the from-to interval for geological observations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grainSize rdf:type rdf:Property ;
    rdfs:label 'Grain Size' ;
    rdfs:comment 'Classification of the grain size of the rock: very_fine, fine, medium, coarse, or very_coarse. Relevant for sedimentary and some igneous rocks.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardness rdf:type rdf:Property ;
    rdfs:label 'Hardness' ;
    rdfs:comment 'Qualitative assessment of rock hardness: very_soft, soft, medium, hard, or very_hard. Relevant for drilling performance and geotechnical assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalLength rdf:type rdf:Property ;
    rdfs:label 'Interval Length' ;
    rdfs:comment 'Length of the logged interval in meters, calculated as depth_to minus depth_from. Represents the sample or observation interval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithologyCode rdf:type rdf:Property ;
    rdfs:label 'Lithology Code' ;
    rdfs:comment 'Standardized code representing the primary rock type observed in this interval (e.g., BIF for Banded Iron Formation, GRN for Granite, SHL for Shale). Follows site-specific or regional lithology coding standards.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lithologyDescription rdf:type rdf:Property ;
    rdfs:label 'Lithology Description' ;
    rdfs:comment 'Detailed textual description of the rock type, including texture, grain size, composition, and any distinguishing features observed by the geologist.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggingDate rdf:type rdf:Property ;
    rdfs:label 'Logging Date' ;
    rdfs:comment 'Date when the geological logging was performed. Represents the EVENT_TIMESTAMP for this observation. Critical for data lineage and JORC Table 1 Section 1 reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loggingMethod rdf:type rdf:Property ;
    rdfs:label 'Logging Method' ;
    rdfs:comment 'Method used to perform the geological logging: visual (traditional manual logging), digital (tablet-based logging), or photographic (image-based logging with subsequent interpretation).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mineralisationIntensity rdf:type rdf:Property ;
    rdfs:label 'Mineralisation Intensity' ;
    rdfs:comment 'Qualitative assessment of the intensity or abundance of visible mineralization: none, trace, minor, moderate, or strong. Used for preliminary grade estimation and targeting.' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mineralisationStyle rdf:type rdf:Property ;
    rdfs:label 'Mineralisation Style' ;
    rdfs:comment 'Description of the style and form of mineralization observed (e.g., disseminated, vein-hosted, massive sulfide, replacement, stockwork). Critical for understanding ore body geometry and JORC reporting.' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oxidationState rdf:type rdf:Property ;
    rdfs:label 'Oxidation State' ;
    rdfs:comment 'Oxidation state of the mineralization: oxide (fully oxidized), transitional (partially oxidized), or fresh_sulfide (unoxidized). Critical for metallurgical processing and resource classification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryPercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Percent' ;
    rdfs:comment 'Percentage of core recovered from the drilled interval, calculated as recovered core length divided by drilled interval length. Critical quality indicator for drill hole data and JORC Table 1 Section 1 reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rqdPercent rdf:type rdf:Property ;
    rdfs:label 'Rqd Percent' ;
    rdfs:comment 'Rock Quality Designation expressed as a percentage, calculated as the sum of core pieces greater than 10cm divided by the interval length. Standard geotechnical measure of rock mass quality ranging from 0 to 100 percent.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Collected Flag' ;
    rdfs:comment 'Boolean flag indicating whether a physical sample was collected from this interval for assay analysis. True if sample was collected, False otherwise.' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:structureOrientation rdf:type rdf:Property ;
    rdfs:label 'Structure Orientation' ;
    rdfs:comment 'Orientation of structural features recorded as dip direction and dip angle (e.g., 045/60 meaning dipping 60 degrees towards 045 azimuth). Critical for structural modeling and geotechnical assessment.' ;
    rdfs:domain ind:GeologicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:texture rdf:type rdf:Property ;
    rdfs:label 'Texture' ;
    rdfs:comment 'Description of the rock texture (e.g., massive, foliated, banded, brecciated, porphyritic). Provides information on rock formation and deformation history.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veinType rdf:type rdf:Property ;
    rdfs:label 'Vein Type' ;
    rdfs:comment 'Description of vein mineralogy and characteristics (e.g., quartz vein, calcite vein, sulfide vein). Critical for understanding mineralization style and ore genesis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veiningPercent rdf:type rdf:Property ;
    rdfs:label 'Veining Percent' ;
    rdfs:comment 'Estimated percentage of the interval occupied by veins. Important for understanding mineralization distribution and structural controls.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatheringDegree rdf:type rdf:Property ;
    rdfs:label 'Weathering Degree' ;
    rdfs:comment 'Degree of weathering observed in the rock: fresh, slightly_weathered, moderately_weathered, highly_weathered, or completely_weathered. Important for understanding near-surface ore characteristics and geotechnical properties.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceId rdf:type rdf:Property ;
    rdfs:label 'Licence Id' ;
    rdfs:comment 'Primary key for licence' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRentFee rdf:type rdf:Property ;
    rdfs:label 'Annual Rent Fee' ;
    rdfs:comment 'Annual rental or holding fee payable to the regulatory authority to maintain the exploration licence. Typically calculated per hectare or as a flat fee.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the original application for the exploration licence was submitted to the regulatory authority.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaSquareKm rdf:type rdf:Property ;
    rdfs:label 'Area Square Km' ;
    rdfs:comment 'Total surface area covered by the exploration licence measured in square kilometres. Alternative measurement for international reporting and comparison.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityRights rdf:type rdf:Property ;
    rdfs:label 'Commodity Rights' ;
    rdfs:comment 'List of minerals and commodities for which exploration rights have been granted under this licence. May include iron ore, copper, gold, lithium, nickel, coal, or all minerals depending on jurisdiction.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Approval Required Flag' ;
    rdfs:comment 'Indicates whether separate environmental impact assessment or approval is required before commencing exploration activities. True if required, False otherwise.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Expenditure Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all expenditure commitment amounts. Ensures consistent financial reporting across jurisdictions.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Heritage Site Flag' ;
    rdfs:comment 'Indicates whether the licence area contains or overlaps with registered cultural heritage sites, archaeological sites, or sacred sites. True if heritage sites are present, False otherwise.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holderRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Holder Registration Number' ;
    rdfs:comment 'Company registration number, business number, or other official identifier of the licence holder as registered with the corporate regulator.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointVentureFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Flag' ;
    rdfs:comment 'Indicates whether the exploration licence is held under a joint venture arrangement with multiple parties. True if joint venture, False if sole holder.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date on which the exploration licence was most recently renewed. Null if the licence has never been renewed.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumRenewalsAllowed rdf:type rdf:Property ;
    rdfs:label 'Maximum Renewals Allowed' ;
    rdfs:comment 'Maximum number of renewals permitted under the applicable mining legislation. Once reached, the licence cannot be renewed further and must either be converted to a mining lease or surrendered.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumExpenditureCommitmentYear1 rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment Year 1' ;
    rdfs:comment 'Mandatory minimum exploration expenditure required in the first year of the licence term to maintain tenure. Failure to meet this commitment may result in penalties or licence forfeiture.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumExpenditureCommitmentYear2 rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment Year 2' ;
    rdfs:comment 'Mandatory minimum exploration expenditure required in the second year of the licence term to maintain tenure.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumExpenditureCommitmentYear3 rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment Year 3' ;
    rdfs:comment 'Mandatory minimum exploration expenditure required in the third year of the licence term to maintain tenure.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumExpenditureCommitmentYear4 rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment Year 4' ;
    rdfs:comment 'Mandatory minimum exploration expenditure required in the fourth year of the licence term to maintain tenure.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumExpenditureCommitmentYear5 rdf:type rdf:Property ;
    rdfs:label 'Minimum Expenditure Commitment Year 5' ;
    rdfs:comment 'Mandatory minimum exploration expenditure required in the fifth year of the licence term to maintain tenure.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReportingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reporting Due Date' ;
    rdfs:comment 'Date by which the next regulatory report or expenditure statement is due. Critical for compliance tracking and avoiding penalties.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryConditions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Conditions' ;
    rdfs:comment 'Special conditions, restrictions, or obligations imposed by the regulatory authority as part of the licence grant. May include environmental protection measures, heritage site restrictions, or community consultation requirements.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Count' ;
    rdfs:comment 'Number of times the exploration licence has been renewed since original grant. Used to track tenure history and assess remaining renewal opportunities.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligibility Flag' ;
    rdfs:comment 'Indicates whether the exploration licence is eligible for renewal based on compliance with expenditure commitments and regulatory conditions. True if eligible, False if not.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rent Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the annual rent fee.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityBondAmount rdf:type rdf:Property ;
    rdfs:label 'Security Bond Amount' ;
    rdfs:comment 'Financial security or bond amount required to be lodged with the regulatory authority to cover potential rehabilitation costs and ensure compliance with licence conditions.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityBondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Security Bond Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the security bond amount.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mineralisationInterceptId rdf:type rdf:Property ;
    rdfs:label 'Mineralisation Intercept Id' ;
    rdfs:comment 'Unique identifier for the calculated mineralisation intercept record. Primary key for this data product.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Calculated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: JORC compliance requires named competent persons for intercept calculations. Links results to qualified employees for audit and competency verification. Replaces text field.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date when this intercept result was publicly announced to the stock exchange. Critical for continuous disclosure compliance and investor relations.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:announcementReference rdf:type rdf:Property ;
    rdfs:label 'Announcement Reference' ;
    rdfs:comment 'Reference number or identifier of the ASX/TSX/stock exchange market announcement in which this intercept was publicly disclosed. Links to investor communications.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'Date when the mineralisation intercept was calculated. Critical for audit trail and version control of exploration results.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Methodology used to calculate the composite grade from individual assay intervals (e.g., length-weighted average, grade-thickness product, nearest neighbour, inverse distance weighting).' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cappingGrade rdf:type rdf:Property ;
    rdfs:label 'Capping Grade' ;
    rdfs:comment 'Maximum grade threshold applied to limit the influence of extreme high-grade outliers on the composite grade calculation. Nullable if no capping was applied.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodity rdf:type rdf:Property ;
    rdfs:label 'Commodity' ;
    rdfs:comment 'Primary mineral commodity of interest for this intercept (e.g., iron ore, copper, gold, lithium, nickel, coal). Determines the grade calculation methodology and reporting standards. [ENUM-REF-CANDIDATE: iron_ore|copper|gold|lithium|nickel|coal|zinc|lead|silver|uranium — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeGrade rdf:type rdf:Property ;
    rdfs:label 'Composite Grade' ;
    rdfs:comment 'Weighted average grade of the target commodity across the intercept interval, calculated from individual assay intervals. Expressed in commodity-specific units (e.g., % for iron ore, g/t for gold, ppm for lithium).' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffGrade rdf:type rdf:Property ;
    rdfs:label 'Cutoff Grade' ;
    rdfs:comment 'Minimum economic grade threshold applied to define the mineralisation intercept. Assay intervals below this grade are excluded from the composite calculation. Critical parameter for JORC/NI 43-101 disclosure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downholeWidth rdf:type rdf:Property ;
    rdfs:label 'Downhole Width' ;
    rdfs:comment 'Length of the mineralisation intercept measured along the drill hole axis, calculated as to_depth minus from_depth. Represents the drilled thickness.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fromDepth rdf:type rdf:Property ;
    rdfs:label 'From Depth' ;
    rdfs:comment 'Starting depth of the mineralisation intercept measured in metres from the drill hole collar. Represents the top of the mineralised zone.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geologicalDomain rdf:type rdf:Property ;
    rdfs:label 'Geological Domain' ;
    rdfs:comment 'Geological unit or domain code assigned to this intercept based on lithology, alteration, or mineralisation style. Used for resource domain modeling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeUnit rdf:type rdf:Property ;
    rdfs:label 'Grade Unit' ;
    rdfs:comment 'Unit of measure for the composite grade value. Common units include percent (%), grams per tonne (g/t), parts per million (ppm), ounces per tonne (oz/t), or kilograms per tonne (kg/t).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptNumber rdf:type rdf:Property ;
    rdfs:label 'Intercept Number' ;
    rdfs:comment 'Sequential or business-assigned identifier for the intercept within the drill hole, used for reporting and cross-referencing in market announcements.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interceptStatus rdf:type rdf:Property ;
    rdfs:label 'Intercept Status' ;
    rdfs:comment 'Current lifecycle status of the intercept calculation. Tracks progression from initial calculation through validation, approval, and public disclosure.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDilution rdf:type rdf:Property ;
    rdfs:label 'Internal Dilution' ;
    rdfs:comment 'Maximum continuous length of sub-cutoff grade material allowed within the intercept without breaking the composite. Represents waste material included in the mineralised zone.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInterceptWidth rdf:type rdf:Property ;
    rdfs:label 'Minimum Intercept Width' ;
    rdfs:comment 'Minimum downhole width threshold applied to define a reportable intercept. Intercepts narrower than this threshold are excluded from reporting.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfSamples rdf:type rdf:Property ;
    rdfs:label 'Number Of Samples' ;
    rdfs:comment 'Count of individual assay samples included in the composite grade calculation for this intercept. Indicates the data density supporting the result.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Name of the broader exploration or mining project to which this intercept belongs. Enables project-level rollup and resource aggregation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingStandard rdf:type rdf:Property ;
    rdfs:label 'Reporting Standard' ;
    rdfs:comment 'International mineral resource reporting code applied to this intercept calculation (e.g., JORC 2012, NI 43-101, SAMREC, SEC S-K 1300, PERC). Determines disclosure requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toDepth rdf:type rdf:Property ;
    rdfs:label 'To Depth' ;
    rdfs:comment 'Ending depth of the mineralisation intercept measured in metres from the drill hole collar. Represents the bottom of the mineralised zone.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trueWidth rdf:type rdf:Property ;
    rdfs:label 'True Width' ;
    rdfs:comment 'Estimated true thickness of the mineralisation perpendicular to the orebody orientation, adjusted for drill hole angle and orebody dip. Critical metric for resource estimation.' ;
    rdfs:domain ind:MineralisationIntercept ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectValuationId rdf:type rdf:Property ;
    rdfs:label 'Project Valuation Id' ;
    rdfs:comment 'Foreign key linking to finance.project_valuation. Business justification: Ore reserves are the basis for mine project valuations. Every project valuation references a specific reserve estimate for NPV calculation, life-of-mine planning, and investment committee approvals.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectValuation .

ind:targetSaleableProductId rdf:type rdf:Property ;
    rdfs:label 'Target Saleable Product Id' ;
    rdfs:comment 'Foreign key linking to product.saleable_product. Business justification: Ore reserves in operating/near-production mines are converted to specific saleable products in life-of-mine plans - required for NPV modeling, offtake contract planning, and production scheduling. Lin' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SaleableProduct .

ind:averageGrade rdf:type rdf:Property ;
    rdfs:label 'Average Grade' ;
    rdfs:comment 'Weighted average grade of the valuable mineral or metal in the ore reserve, calculated after application of dilution and mining recovery factors.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Average Grade Unit' ;
    rdfs:comment 'Unit of measure for the average grade, typically percentage (%) for bulk commodities or grams per tonne (g/t) for precious metals.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Board Sign Off Date' ;
    rdfs:comment 'Date on which the ore reserve statement was formally endorsed and signed off by the company board of directors for regulatory reporting and public disclosure.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commodityPriceAssumption rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Assumption' ;
    rdfs:comment 'The assumed commodity price used in the economic evaluation to determine the viability of the ore reserve.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Currency' ;
    rdfs:comment 'The currency in which the commodity price assumption is expressed, using ISO 4217 three-letter currency code.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containedMetal rdf:type rdf:Property ;
    rdfs:label 'Contained Metal' ;
    rdfs:comment 'Total quantity of contained metal or mineral in the ore reserve, calculated as reserve tonnage multiplied by average grade.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containedMetalUnit rdf:type rdf:Property ;
    rdfs:label 'Contained Metal Unit' ;
    rdfs:comment 'Unit of measure for the contained metal, typically tonnes, kilograms, or ounces depending on the commodity.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutOffGrade rdf:type rdf:Property ;
    rdfs:label 'Cut Off Grade' ;
    rdfs:comment 'The minimum economic grade threshold applied to define ore from waste. Material below this grade is classified as waste and excluded from the ore reserve tonnage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutOffGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Cut Off Grade Unit' ;
    rdfs:comment 'Unit of measure for the cut-off grade, typically percentage (%) for bulk commodities or grams per tonne (g/t) for precious metals.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dilutionFactor rdf:type rdf:Property ;
    rdfs:label 'Dilution Factor' ;
    rdfs:comment 'Percentage or factor representing the expected dilution of ore grade due to unplanned inclusion of waste material during mining operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which the ore reserve statement was publicly disclosed to the market and regulatory authorities.' ;
    rdfs:domain ind:Exploration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:economicAssumptions rdf:type rdf:Property ;
    rdfs:label 'Economic Assumptions' ;
    rdfs:comment 'Summary of key economic assumptions used in the ore reserve calculation, including commodity prices, exchange rates, operating costs, and capital costs.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomYears rdf:type rdf:Property ;
    rdfs:label 'Lom Years' ;
    rdfs:comment 'Estimated life of mine in years based on the ore reserve tonnage and planned annual production rate.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metallurgicalRecoveryFactor rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Recovery Factor' ;
    rdfs:comment 'Percentage or factor representing the expected proportion of contained metal that will be recovered during mineral processing and beneficiation.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:miningMethod rdf:type rdf:Property ;
    rdfs:label 'Mining Method' ;
    rdfs:comment 'The planned mining method to be applied for extraction of the ore reserve, which influences dilution, recovery, and economic viability. [ENUM-REF-CANDIDATE: Open Pit|Underground|SLC|Block Cave|Longwall|Room and Pillar|Cut and Fill|Sublevel Stoping — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:miningRecoveryFactor rdf:type rdf:Property ;
    rdfs:label 'Mining Recovery Factor' ;
    rdfs:comment 'Percentage or factor representing the expected proportion of in-situ ore that will be successfully extracted during mining operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifyingFactorsApplied rdf:type rdf:Property ;
    rdfs:label 'Modifying Factors Applied' ;
    rdfs:comment 'Description of the modifying factors applied to convert the Mineral Resource to an Ore Reserve, including mining, metallurgical, economic, marketing, legal, environmental, social, and governmental considerations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional notes, comments, or qualifications related to the ore reserve estimate, including material risks, uncertainties, or assumptions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveClassification rdf:type rdf:Property ;
    rdfs:label 'Reserve Classification' ;
    rdfs:comment 'Classification category of the ore reserve: Proved Reserve (highest confidence, derived from Measured Resource) or Probable Reserve (derived from Indicated Resource).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCode rdf:type rdf:Property ;
    rdfs:label 'Reserve Code' ;
    rdfs:comment 'Unique business code or identifier for the ore reserve used in reporting and planning systems.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveName rdf:type rdf:Property ;
    rdfs:label 'Reserve Name' ;
    rdfs:comment 'Business name or designation of the ore reserve, typically referencing the deposit or mining area.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveStatus rdf:type rdf:Property ;
    rdfs:label 'Reserve Status' ;
    rdfs:comment 'Current lifecycle status of the ore reserve statement, indicating whether it is in draft, approved for use, publicly disclosed, superseded by a newer estimate, or archived.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveTonnage rdf:type rdf:Property ;
    rdfs:label 'Reserve Tonnage' ;
    rdfs:comment 'Total tonnage of ore in the reserve after application of modifying factors including dilution, mining recovery, and cut-off grade.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveTonnageUnit rdf:type rdf:Property ;
    rdfs:label 'Reserve Tonnage Unit' ;
    rdfs:comment 'Unit of measure for the ore reserve tonnage.' ;
    rdfs:domain ind:OreReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stripRatio rdf:type rdf:Property ;
    rdfs:label 'Strip Ratio' ;
    rdfs:comment 'Ratio of waste material (overburden) to ore that must be removed to access the ore reserve, applicable to open pit mining operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCommodityId rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity Id' ;
    rdfs:comment 'Foreign key linking to product.commodity. Business justification: Prospects target specific commodities (iron ore, copper, lithium) - fundamental to exploration strategy, resource classification, and statutory reporting. Normalizes existing primary_commodity text fi' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:responsibleGeologistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Geologist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Prospects require assigned geologists for exploration planning, resource estimation sign-off, and accountability. Critical for workforce planning and competency management. Removes denormalized text f' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaHectares rdf:type rdf:Property ;
    rdfs:label 'Area Hectares' ;
    rdfs:comment 'Total surface area of the prospect or area of interest, measured in hectares.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLatitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the prospect centroid in decimal degrees (WGS84 datum).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidLongitude rdf:type rdf:Property ;
    rdfs:label 'Centroid Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the prospect centroid in decimal degrees (WGS84 datum).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffGradePercent rdf:type rdf:Property ;
    rdfs:label 'Cutoff Grade Percent' ;
    rdfs:comment 'Minimum economic grade threshold used for resource estimation and prospect evaluation, expressed as a percentage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillHoleCount rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Count' ;
    rdfs:comment 'Total number of drill holes completed within the prospect area to date.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Status' ;
    rdfs:comment 'Status of environmental impact assessment and regulatory clearance for exploration activities in the prospect area.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedGradePercent rdf:type rdf:Property ;
    rdfs:label 'Estimated Grade Percent' ;
    rdfs:comment 'Current estimated average grade of the primary commodity in the prospect, expressed as a percentage. Confidential business data.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTonnageMt rdf:type rdf:Property ;
    rdfs:label 'Estimated Tonnage Mt' ;
    rdfs:comment 'Current estimated total tonnage of mineralized material in the prospect, expressed in million tonnes. Confidential business data.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geologicalConfidence rdf:type rdf:Property ;
    rdfs:label 'Geological Confidence' ;
    rdfs:comment 'Qualitative assessment of geological confidence in the prospect based on data density, quality, and geological understanding.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologicalProvince rdf:type rdf:Property ;
    rdfs:label 'Geological Province' ;
    rdfs:comment 'Name of the regional geological province or terrane in which the prospect is located.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Status' ;
    rdfs:comment 'Status of cultural heritage and indigenous land use clearance for exploration activities in the prospect area.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent drilling activity conducted in the prospect.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastResourceEstimateDate rdf:type rdf:Property ;
    rdfs:label 'Last Resource Estimate Date' ;
    rdfs:comment 'Date of the most recent mineral resource estimate prepared for this prospect.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localGridEasting rdf:type rdf:Property ;
    rdfs:label 'Local Grid Easting' ;
    rdfs:comment 'Easting coordinate of the prospect centroid in the local mine grid or project coordinate system, measured in meters.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localGridNorthing rdf:type rdf:Property ;
    rdfs:label 'Local Grid Northing' ;
    rdfs:comment 'Northing coordinate of the prospect centroid in the local mine grid or project coordinate system, measured in meters.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mineralizationStyle rdf:type rdf:Property ;
    rdfs:label 'Mineralization Style' ;
    rdfs:comment 'Type or style of mineralization present in the prospect (e.g., porphyry, epithermal, sediment-hosted, banded iron formation, pegmatite).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPlannedActivity rdf:type rdf:Property ;
    rdfs:label 'Next Planned Activity' ;
    rdfs:comment 'Description of the next planned exploration activity or program for the prospect (e.g., drilling campaign, geophysical survey, feasibility study).' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectCode rdf:type rdf:Property ;
    rdfs:label 'Prospect Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the prospect for identification in exploration systems and reporting.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectName rdf:type rdf:Property ;
    rdfs:label 'Prospect Name' ;
    rdfs:comment 'Business name or designation of the exploration prospect or target area.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectStatus rdf:type rdf:Property ;
    rdfs:label 'Prospect Status' ;
    rdfs:comment 'Current operational status of the exploration prospect in its lifecycle.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceClassification rdf:type rdf:Property ;
    rdfs:label 'Resource Classification' ;
    rdfs:comment 'Highest level of mineral resource classification achieved for this prospect under JORC, NI 43-101, or SAMREC standards. None if no resource has been estimated.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryCommodity rdf:type rdf:Property ;
    rdfs:label 'Secondary Commodity' ;
    rdfs:comment 'Secondary or by-product mineral commodity of interest in the prospect area, if applicable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralDomain rdf:type rdf:Property ;
    rdfs:label 'Structural Domain' ;
    rdfs:comment 'Structural geological domain or zone characterizing the prospect area (e.g., fault block, fold belt, shear zone).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDepthMaxM rdf:type rdf:Property ;
    rdfs:label 'Target Depth Max M' ;
    rdfs:comment 'Maximum depth below surface at which mineralization is targeted or expected, measured in meters.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDepthMinM rdf:type rdf:Property ;
    rdfs:label 'Target Depth Min M' ;
    rdfs:comment 'Minimum depth below surface at which mineralization is targeted or expected, measured in meters.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMetersDrilled rdf:type rdf:Property ;
    rdfs:label 'Total Meters Drilled' ;
    rdfs:comment 'Cumulative total length of all drilling completed in the prospect, measured in meters.' ;
    rdfs:domain ind:Prospect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Resource Disclosure Id' ;
    rdfs:comment 'Unique identifier for the mineral resource and ore reserve disclosure record. Primary key.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOfftakeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sales Offtake Agreement Id' ;
    rdfs:comment 'Foreign key linking to sales.offtake_agreement. Business justification: Public resource disclosures to exchanges often reference material offtake agreements as they impact project economics and reserve viability. ASX/TSX reporting rules require disclosure of material comm' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfftakeAgreement .

ind:supersededDisclosureResourceDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Superseded Disclosure Resource Disclosure Id' ;
    rdfs:comment 'Reference to the previous resource_disclosure_id that this disclosure supersedes or replaces (null if this is an initial disclosure).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceDisclosure .

ind:announcementUrl rdf:type rdf:Property ;
    rdfs:label 'Announcement Url' ;
    rdfs:comment 'The web URL where the public disclosure announcement or filing can be accessed (e.g., ASX announcement platform, SEDAR, SEC EDGAR).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'The date on which the company board of directors approved the disclosure for public release.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competentPersonSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Competent Person Signoff Date' ;
    rdfs:comment 'The date on which the Competent Person formally signed off or consented to the disclosure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureNotes rdf:type rdf:Property ;
    rdfs:label 'Disclosure Notes' ;
    rdfs:comment 'Free-text field capturing additional context, assumptions, qualifications, or explanatory notes accompanying the disclosure (e.g., changes in methodology, material assumptions, forward-looking statements).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this disclosure by the company or regulatory body (e.g., ASX announcement number, SEC filing reference).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the disclosure: draft (in preparation), pending_approval (awaiting board or competent person sign-off), approved (authorized for release), published (publicly released), superseded (replaced by newer disclosure), withdrawn (retracted).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Classification of the disclosure event: initial (first-time disclosure), update (routine update), annual (annual reporting cycle), material_change (triggered by significant change), restatement (correction of prior disclosure), withdrawal (retraction of prior disclosure).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeOrRegulator rdf:type rdf:Property ;
    rdfs:label 'Exchange Or Regulator' ;
    rdfs:comment 'The stock exchange or regulatory body to which this disclosure was submitted: ASX (Australian Securities Exchange), TSX (Toronto Stock Exchange), NYSE (New York Stock Exchange), LSE (London Stock Exchange), JSE (Johannesburg Stock Exchange), SEC (U.S. Securities and Exchange Commission), ASIC (Australian Securities and Investments Commission). [ENUM-REF-CANDIDATE: ASX|TSX|NYSE|LSE|JSE|SEC|ASIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Material Change Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this disclosure represents a material change (10% or greater change in resource or reserve tonnage or grade) compared to the previous disclosure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingEntityName rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Name' ;
    rdfs:comment 'The legal name of the company or entity making the disclosure (typically the listed parent company or operating subsidiary).' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCutoffGrade rdf:type rdf:Property ;
    rdfs:label 'Reserve Cutoff Grade' ;
    rdfs:comment 'The minimum economic grade (percentage or grams per tonne) used to define the boundary of the ore reserve estimate, incorporating mining, processing, and economic factors.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceCutoffGrade rdf:type rdf:Property ;
    rdfs:label 'Resource Cutoff Grade' ;
    rdfs:comment 'The minimum economic grade (percentage or grams per tonne) used to define the boundary of the mineral resource estimate. Material below this grade is excluded from the resource.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalReportReference rdf:type rdf:Property ;
    rdfs:label 'Technical Report Reference' ;
    rdfs:comment 'Reference identifier or title of the supporting technical report (e.g., NI 43-101 Technical Report, JORC Table 1, SEC Technical Report Summary) that provides detailed documentation of the resource and reserve estimates.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalIndicatedResourceTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Indicated Resource Tonnes' ;
    rdfs:comment 'Total tonnage (in metric tonnes) of Indicated Mineral Resource disclosed in this statement. Indicated Resource is a medium confidence resource category.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInferredResourceTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Inferred Resource Tonnes' ;
    rdfs:comment 'Total tonnage (in metric tonnes) of Inferred Mineral Resource disclosed in this statement. Inferred Resource is the lowest confidence resource category.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMeasuredResourceTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Measured Resource Tonnes' ;
    rdfs:comment 'Total tonnage (in metric tonnes) of Measured Mineral Resource disclosed in this statement. Measured Resource is the highest confidence resource category.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProbableReserveTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Probable Reserve Tonnes' ;
    rdfs:comment 'Total tonnage (in metric tonnes) of Probable Ore Reserve disclosed in this statement. Probable Reserve is derived from Measured and/or Indicated Resource.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalProvedReserveTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Proved Reserve Tonnes' ;
    rdfs:comment 'Total tonnage (in metric tonnes) of Proved Ore Reserve disclosed in this statement. Proved Reserve is the highest confidence reserve category, derived from Measured Resource.' ;
    rdfs:domain ind:ResourceDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockModelReference rdf:type rdf:Property ;
    rdfs:label 'Block Model Reference' ;
    rdfs:comment 'Reference identifier or file name of the geological block model used as the basis for this resource estimate.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockModelVersion rdf:type rdf:Property ;
    rdfs:label 'Block Model Version' ;
    rdfs:comment 'Version number or identifier of the block model used for this estimate.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityAssumption rdf:type rdf:Property ;
    rdfs:label 'Density Assumption' ;
    rdfs:comment 'Assumed bulk density (tonnes per cubic metre) used in tonnage calculations for the resource estimate.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimateConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Estimate Confidence Level' ;
    rdfs:comment 'Overall confidence level in the resource estimate based on data quality, density, and geological understanding.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateName rdf:type rdf:Property ;
    rdfs:label 'Estimate Name' ;
    rdfs:comment 'Business name or title of the resource estimate, typically referencing the deposit, prospect, or project name.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateStatus rdf:type rdf:Property ;
    rdfs:label 'Estimate Status' ;
    rdfs:comment 'Current lifecycle status of the resource estimate within the approval and governance workflow.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateType rdf:type rdf:Property ;
    rdfs:label 'Estimate Type' ;
    rdfs:comment 'Classification of the estimate within the project lifecycle (e.g., initial, updated, revised, final).' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimationMethod rdf:type rdf:Property ;
    rdfs:label 'Estimation Method' ;
    rdfs:comment 'The geostatistical or geometric method used to estimate grades and tonnages (e.g., kriging, inverse distance weighting, nearest neighbour). [ENUM-REF-CANDIDATE: Ordinary Kriging|Indicator Kriging|Multiple Indicator Kriging|Inverse Distance Weighting|Nearest Neighbour|Polygonal|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metallurgicalRecoveryAssumption rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Recovery Assumption' ;
    rdfs:comment 'Assumed metallurgical recovery rate (percentage) used in economic assessment for reasonable prospects of eventual economic extraction.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:miningMethodAssumption rdf:type rdf:Property ;
    rdfs:label 'Mining Method Assumption' ;
    rdfs:comment 'The assumed mining method used in determining reasonable prospects for eventual economic extraction (e.g., open pit, underground, sub-level caving).' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date on which this resource estimate was publicly disclosed to the market or regulatory authorities.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Total number of assay samples used in the estimation process.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tonnage rdf:type rdf:Property ;
    rdfs:label 'Tonnage' ;
    rdfs:comment 'Total estimated tonnage of mineralized material in the resource category, typically expressed in million tonnes (Mt) or thousand tonnes (kt).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnageUnit rdf:type rdf:Property ;
    rdfs:label 'Tonnage Unit' ;
    rdfs:comment 'Unit of measure for tonnage: tonnes (t), thousand tonnes (kt), million tonnes (Mt), or billion tonnes (Gt).' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMetresDrilled rdf:type rdf:Property ;
    rdfs:label 'Total Metres Drilled' ;
    rdfs:comment 'Total metres of drilling completed and used as the basis for this resource estimate.' ;
    rdfs:domain ind:ResourceEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:explorationSampleId rdf:type rdf:Property ;
    rdfs:label 'Exploration Sample Id' ;
    rdfs:comment 'Unique identifier for the exploration sample record. Primary key for the sample entity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExplorationSample .

ind:chemicalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Chemical Register Id' ;
    rdfs:comment 'Foreign key linking to hse.chemical_register. Business justification: Exploration samples may contain or require hazardous materials (acid digestion, cyanide leach testing). Chemical handling and disposal requires register linkage for SDS access and regulatory complianc' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChemicalRegister .

ind:collectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collected By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: JORC/NI 43-101 compliance requires chain-of-custody tracking to specific qualified employees. Critical for audit trails and competency verification. Replaces text field with FK.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collectionEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Collection Equipment Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Exploration samples (soil, rock chip, channel) are collected using specific equipment (augers, excavators, portable drills). Tracking collection equipment supports QA/QC protocols, method validation, ' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:parentSampleExplorationSampleId rdf:type rdf:Property ;
    rdfs:label 'Parent Sample Exploration Sample Id' ;
    rdfs:comment 'Reference to the original sample from which this sample was derived (e.g., for duplicates, replicates, or sub-samples). Null for primary field samples.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExplorationSample .

ind:alterationCode rdf:type rdf:Property ;
    rdfs:label 'Alteration Code' ;
    rdfs:comment 'Code representing the type and intensity of hydrothermal or weathering alteration observed in the sample. Important for understanding mineralization controls.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current physical location or custody status of the sample. Critical for sample tracking, security, and audit compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the sample was physically collected from the field or drill site. Critical for chain of custody and temporal analysis of exploration programs.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The technique or equipment used to collect the sample from the field. Critical for understanding sample quality, representativeness, and potential biases.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Batch Number' ;
    rdfs:comment 'Identifier for the batch or shipment in which this sample was sent to the laboratory. Used for tracking, logistics, and grouping samples for analysis.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'Date when the sample was dispatched from the field or core facility to the analytical laboratory. Part of chain of custody documentation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eastingM rdf:type rdf:Property ;
    rdfs:label 'Easting M' ;
    rdfs:comment 'Easting coordinate of the sample collection point in meters, typically in a projected coordinate system (e.g., UTM). Used for spatial analysis and resource modeling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fromDepthM rdf:type rdf:Property ;
    rdfs:label 'From Depth M' ;
    rdfs:comment 'Starting depth in meters of the sample interval measured from drill hole collar. Null for surface samples. Used with to_depth_m to define the sample interval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geologistComments rdf:type rdf:Property ;
    rdfs:label 'Geologist Comments' ;
    rdfs:comment 'Free-text field for geologist observations, notes, or interpretations recorded during sample collection or logging. Captures qualitative information not represented in coded fields.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComposite rdf:type rdf:Property ;
    rdfs:label 'Is Composite' ;
    rdfs:comment 'Flag indicating whether this sample is a composite created by combining multiple individual samples. Composites are used for resource estimation and grade control.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthM rdf:type rdf:Property ;
    rdfs:label 'Length M' ;
    rdfs:comment 'Physical length of the sample interval in meters. For drill samples, typically calculated as to_depth_m minus from_depth_m. Critical for understanding sample support and compositing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mineralizationCode rdf:type rdf:Property ;
    rdfs:label 'Mineralization Code' ;
    rdfs:comment 'Code representing the style, type, or intensity of mineralization observed in the sample. Used for targeting and geological interpretation.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:northingM rdf:type rdf:Property ;
    rdfs:label 'Northing M' ;
    rdfs:comment 'Northing coordinate of the sample collection point in meters, typically in a projected coordinate system (e.g., UTM). Used for spatial analysis and resource modeling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparationInstructions rdf:type rdf:Property ;
    rdfs:label 'Preparation Instructions' ;
    rdfs:comment 'Specific instructions for laboratory sample preparation including crushing, grinding, splitting, and sub-sampling protocols. May reference standard preparation codes or custom procedures.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcReferenceMaterial rdf:type rdf:Property ;
    rdfs:label 'Qaqc Reference Material' ;
    rdfs:comment 'Identifier of the certified reference material (CRM) or standard used for this QAQC sample. Null for routine samples. Used to validate laboratory accuracy.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcType rdf:type rdf:Property ;
    rdfs:label 'Qaqc Type' ;
    rdfs:comment 'Classification of the sample for quality assurance and quality control purposes. Routine samples are normal field samples; duplicates, blanks, standards, and replicates are control samples inserted to monitor analytical accuracy and precision.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Externally-known unique sample identifier assigned during collection. Used for laboratory tracking, chain of custody, and cross-referencing with assay results. Typically follows site-specific numbering conventions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the sample in the exploration workflow. Tracks progression from field collection through laboratory analysis to final data integration. [ENUM-REF-CANDIDATE: collected|dispatched|at_laboratory|prepared|assayed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the physical sample based on collection method and material form. Determines handling, preparation, and analytical protocols. [ENUM-REF-CANDIDATE: drill_core_half|drill_core_quarter|rc_chips|channel|soil|rock_chip|stream_sediment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenementCode rdf:type rdf:Property ;
    rdfs:label 'Tenement Code' ;
    rdfs:comment 'Identifier of the mining tenement, exploration license, or land parcel where the sample was collected. Critical for regulatory compliance and resource reporting.' ;
    rdfs:domain ind:ExplorationSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toDepthM rdf:type rdf:Property ;
    rdfs:label 'To Depth M' ;
    rdfs:comment 'Ending depth in meters of the sample interval measured from drill hole collar. Null for surface samples. Used with from_depth_m to define the sample interval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Total weight of the sample in kilograms as collected in the field. Used for quality control, recovery calculations, and preparation planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Unique identifier for the exploration survey program. Primary key.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Geophysical surveys (magnetic, EM, gravity, IP) use specialized equipment that requires calibration tracking and maintenance records. Linking survey to asset supports data quality validation, equipmen' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:acquisitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition End Date' ;
    rdfs:comment 'Date when field data acquisition or sample collection was completed for this survey program. Null if survey is ongoing.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Start Date' ;
    rdfs:comment 'Date when field data acquisition or sample collection commenced for this survey program.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anomalyCount rdf:type rdf:Property ;
    rdfs:label 'Anomaly Count' ;
    rdfs:comment 'Number of discrete anomalies identified from the survey that meet the anomaly threshold criteria and are recommended for follow-up investigation or drilling.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anomalyThreshold rdf:type rdf:Property ;
    rdfs:label 'Anomaly Threshold' ;
    rdfs:comment 'Statistical or empirical criteria used to define anomalous values that warrant follow-up investigation (e.g., \'mean + 2 standard deviations\', \'>100 ppb Au\'). Used for target generation.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaKm2 rdf:type rdf:Property ;
    rdfs:label 'Area Km2' ;
    rdfs:comment 'Total area covered by the survey program in square kilometers. Used for cost estimation and coverage analysis.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataFormat rdf:type rdf:Property ;
    rdfs:label 'Data Format' ;
    rdfs:comment 'File format and structure of the raw survey data (e.g., \'XYZ ASCII\', \'Geosoft GDB\', \'CSV\', \'LAS\', \'SEGY\'). Critical for data integration and processing workflows.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Data Storage Location' ;
    rdfs:comment 'File path, database location, or cloud storage URI where the raw and processed survey data files are stored. Used for data retrieval and audit trail.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'Minimum detectable concentration or signal threshold for the survey method. For geochemical: analytical detection limits (e.g., \'0.01 ppm Au\'). For geophysical: instrument sensitivity specifications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillTargetsGenerated rdf:type rdf:Property ;
    rdfs:label 'Drill Targets Generated' ;
    rdfs:comment 'Number of drill targets prioritized from this survey for inclusion in future drilling programs. Subset of total anomalies that pass economic and technical filters.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interpretationStatus rdf:type rdf:Property ;
    rdfs:label 'Interpretation Status' ;
    rdfs:comment 'Current state of geological interpretation and anomaly identification: pending (not started), in_progress (geologist reviewing), completed (interpretation finished), peer_reviewed (technical review done), approved (sign-off for drill targeting).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSpacingM rdf:type rdf:Property ;
    rdfs:label 'Line Spacing M' ;
    rdfs:comment 'Distance in meters between survey lines for geophysical surveys (e.g., airborne flight lines, ground traverse lines). Null for geochemical grid surveys.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current state of data processing workflow: raw (unprocessed field data), in_progress (undergoing corrections and transformations), completed (processing finished), validated (QC approved), archived (final data stored).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleIntervalM rdf:type rdf:Property ;
    rdfs:label 'Sample Interval M' ;
    rdfs:comment 'Distance in meters between individual sample collection points along a line or within a grid. Applicable to both geophysical station spacing and geochemical sample spacing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLineKm rdf:type rdf:Property ;
    rdfs:label 'Total Line Km' ;
    rdfs:comment 'Total length of survey lines flown or traversed in kilometers for geophysical surveys. Null for grid-based geochemical surveys.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to processing.processing_plant. Business justification: Capital budgets are allocated to specific processing plants for expansion, sustaining capex, and asset replacement projects. Enables plant-level capex tracking, project portfolio management, and capit' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Cumulative actual expenditure posted to this WBS element in SAP FI/CO as at the reporting date. Represents invoiced and goods-receipted costs capitalised to the asset under construction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aiscContributionUsd rdf:type rdf:Property ;
    rdfs:label 'Aisc Contribution Usd' ;
    rdfs:comment 'The sustaining CAPEX component of this budget expressed in USD per unit of production, contributing to the AISC metric reported to investors. Applies only to sustaining capital categories per World Gold Council AISC guidance.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Revision Number' ;
    rdfs:comment 'Sequential revision number indicating how many times the original approved budget has been formally revised (0 = original approval, 1 = first revision, etc.). Supports audit trail of capital budget changes.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capexCategory rdf:type rdf:Property ;
    rdfs:label 'Capex Category' ;
    rdfs:comment 'Classification of the CAPEX type: Sustaining (maintaining existing assets), Growth (expanding capacity), Exploration (IFRS 6 qualifying expenditure), Rehabilitation (mine closure obligations), or IT (technology infrastructure). Drives AISC reporting and NPV/IRR modelling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalisationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalisation Date' ;
    rdfs:comment 'Date on which the asset under construction is expected to be or was transferred to a fixed asset and capitalised in SAP AM. Triggers commencement of depreciation under IAS 16.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Contingency allowance included within the approved budget to cover unforeseen scope, geotechnical, or market risks. Reported separately to the board to distinguish base estimate from risk provision.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Weighted average cost of capital (WACC) or hurdle rate applied in the DCF model for NPV calculation, expressed as a percentage. Approved by the board for capital project evaluation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate applied to convert budget amounts from the transaction currency to the group reporting currency (e.g., USD to AUD). Sourced from SAP FI exchange rate tables at the time of budget approval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month 1–12) within the fiscal year for which this budget line applies. Supports monthly capital phasing and cash flow forecasting in SAP CO.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year (e.g., 2024) for which this CAPEX budget is approved and tracked. Aligns with the company\'s financial reporting calendar in SAP FI.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastAtCompletionAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast At Completion Amount' ;
    rdfs:comment 'Total projected cost at project completion, calculated as actual spend plus forecast to complete. Key metric for capital overrun/underrun reporting to the board and NPV/IRR sensitivity analysis.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastToCompleteAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast To Complete Amount' ;
    rdfs:comment 'Estimated remaining expenditure required to complete the project scope from the current reporting date. Used in earned value management and LOM capital cash flow forecasting.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrPct rdf:type rdf:Property ;
    rdfs:label 'Irr Pct' ;
    rdfs:comment 'Internal Rate of Return of the capital project expressed as a percentage, derived from the approved DCF model. Used alongside NPV for capital project ranking and board investment approval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLomCapital rdf:type rdf:Property ;
    rdfs:label 'Is Lom Capital' ;
    rdfs:comment 'Indicates whether this CAPEX budget line is included in the approved Life of Mine capital plan. True = included in LOM plan; False = ad hoc or supplementary capital not in the LOM baseline.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSustainingCapex rdf:type rdf:Property ;
    rdfs:label 'Is Sustaining Capex' ;
    rdfs:comment 'Indicates whether this budget is classified as sustaining CAPEX for AISC reporting purposes per World Gold Council guidance. True = sustaining capital included in AISC; False = growth or non-sustaining capital.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lomPlanYear rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Year' ;
    rdfs:comment 'The Life of Mine plan year in which this CAPEX budget is scheduled, enabling alignment of capital expenditure with the long-term mine production schedule and NPV/IRR modelling horizon.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npvAmount rdf:type rdf:Property ;
    rdfs:label 'Npv Amount' ;
    rdfs:comment 'Net Present Value of the capital project calculated using the approved discount rate in the DCF model. Key investment decision metric used in board capital allocation governance and project ranking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexCapexSplitPct rdf:type rdf:Property ;
    rdfs:label 'Opex Capex Split Pct' ;
    rdfs:comment 'Percentage of the total project cost classified as CAPEX (versus OPEX) for accounting and tax purposes. Relevant for mixed-nature projects where capitalisation criteria under IAS 16 or IFRS 6 apply to only a portion of spend.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectEndDate rdf:type rdf:Property ;
    rdfs:label 'Project End Date' ;
    rdfs:comment 'Planned or actual completion date of the capital project or WBS phase. Drives capital phasing in LOM plans and determines the depreciation commencement date under IAS 16.' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'The lifecycle phase of the capital project to which this budget applies. Supports IFRS 6 exploration accounting and LOM capital phasing. [ENUM-REF-CANDIDATE: Exploration|Feasibility|Construction|Commissioning|Operations|Closure — promote to reference product if additional phases are required]' ;
    rdfs:domain ind:CapexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'Most recent board-approved revised budget amount after formal budget revision cycles (e.g., mid-year reforecast). Null if no revision has been approved. Supports variance analysis against original budget.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Narrative description of the reason for the most recent budget revision (e.g., scope change, geotechnical risk materialisation, commodity price impact on equipment costs). Required for capital governance audit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational source system from which this CAPEX budget record was extracted (e.g., \'SAP-S4HANA-PROD\'). Supports data lineage and multi-system reconciliation in the lakehouse.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowForecastId rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Forecast Id' ;
    rdfs:comment 'Unique identifier for the cash flow forecast record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashFlowForecast .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'FK to finance.legal_entity' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryCashForecastPreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cash Forecast Prepared By Employee Id' ;
    rdfs:comment 'Employee identifier of the treasury or finance analyst who prepared this cash flow forecast.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetDisposalAmount rdf:type rdf:Property ;
    rdfs:label 'Asset Disposal Amount' ;
    rdfs:comment 'Forecasted cash proceeds from sale or disposal of fixed assets, equipment, or mining infrastructure.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Amount' ;
    rdfs:comment 'Forecasted capital expenditure cash outflows for sustaining and expansion capital projects, mine development, and equipment purchases.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingCashBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Closing Cash Balance Amount' ;
    rdfs:comment 'Forecasted cash and cash equivalents balance at the end of the forecast period, critical for liquidity planning and covenant monitoring.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commoditySalesAmount rdf:type rdf:Property ;
    rdfs:label 'Commodity Sales Amount' ;
    rdfs:comment 'Forecasted cash receipts from primary commodity sales, representing the main operating cash inflow for mining operations.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'Primary commodity or mineral type associated with this forecast, enabling commodity-specific cash flow analysis and price sensitivity modeling. [ENUM-REF-CANDIDATE: iron_ore|copper|coal|lithium|nickel|gold|mixed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debtCovenantComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Debt Covenant Compliance Flag' ;
    rdfs:comment 'Indicator whether the forecasted cash position and financial ratios meet all debt covenant requirements. True indicates compliance.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:debtServiceAmount rdf:type rdf:Property ;
    rdfs:label 'Debt Service Amount' ;
    rdfs:comment 'Forecasted cash outflows for debt principal and interest payments, critical for debt covenant compliance monitoring.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dividendPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Dividend Payment Amount' ;
    rdfs:comment 'Forecasted cash outflows for dividend distributions to shareholders, supporting dividend capacity assessment and board reporting.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Usd' ;
    rdfs:comment 'Exchange rate used to convert local currency amounts to USD for consolidated group reporting and AISC calculations.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expansionCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Expansion Capex Amount' ;
    rdfs:comment 'Forecasted expansion capital expenditure for growth projects, new mine development, and capacity expansion initiatives.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingCashInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Financing Cash Inflow Amount' ;
    rdfs:comment 'Forecasted cash inflows from financing activities including debt drawdowns, equity issuance, and capital contributions.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Financing Cash Outflow Amount' ;
    rdfs:comment 'Forecasted cash outflows for financing activities including debt service, dividend payments, and share buybacks.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAssumptions rdf:type rdf:Property ;
    rdfs:label 'Forecast Assumptions' ;
    rdfs:comment 'Key assumptions underlying this forecast including commodity price assumptions, production volumes, exchange rates, and cost escalation factors.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastHorizon rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon' ;
    rdfs:comment 'Time granularity and planning horizon of the forecast. LOM (Life of Mine) represents full mine life projection.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'End date of the period covered by this cash flow forecast.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this cash flow forecast.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this cash flow forecast version, used for tracking and audit purposes.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the cash flow forecast indicating its approval state and usability for decision-making.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by cash flow category aligned with cash flow statement structure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Version number of the forecast, incremented with each revision to track forecast evolution over time.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgingSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Hedging Settlement Amount' ;
    rdfs:comment 'Forecasted net cash flows from commodity price hedging instruments and derivative settlements, can be positive or negative.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investingCashInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Investing Cash Inflow Amount' ;
    rdfs:comment 'Forecasted cash inflows from investing activities including asset disposals, divestments, and investment redemptions.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investingCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Investing Cash Outflow Amount' ;
    rdfs:comment 'Forecasted cash outflows for investing activities including CAPEX (Capital Expenditure), exploration expenditure, and acquisitions.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomPlanReference rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Reference' ;
    rdfs:comment 'Reference to the Life of Mine plan document or version from which long-term cash flow forecasts are derived.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow Amount' ;
    rdfs:comment 'Forecasted net cash flow for the period, calculated as total inflows minus total outflows across all activity categories.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingCashBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Cash Balance Amount' ;
    rdfs:comment 'Forecasted cash and cash equivalents balance at the beginning of the forecast period.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCashInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Operating Cash Inflow Amount' ;
    rdfs:comment 'Forecasted cash inflows from operating activities including commodity sales revenue, by-product credits, and other operating receipts.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCashOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Operating Cash Outflow Amount' ;
    rdfs:comment 'Forecasted cash outflows for operating activities including OPEX (Operating Expenditure), royalties, and operating taxes.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Amount' ;
    rdfs:comment 'Forecasted operating expenditure cash outflows including mining, processing, general and administrative costs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Amount' ;
    rdfs:comment 'Forecasted cash outflows for mineral royalty payments to governments, landowners, and other royalty holders.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainingCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Sustaining Capex Amount' ;
    rdfs:comment 'Forecasted sustaining capital expenditure required to maintain current production levels, included in AISC (All-In Sustaining Cost) calculations.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Payment Amount' ;
    rdfs:comment 'Forecasted cash outflows for corporate income tax, mining tax, and other tax obligations.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast Amount' ;
    rdfs:comment 'Variance between current forecast net cash flow and the prior forecast version, enabling forecast accuracy tracking and variance analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorForecastPct rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast Pct' ;
    rdfs:comment 'Percentage variance between current forecast and prior forecast, calculated as (current - prior) / prior * 100.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each cost allocation transaction record in the SAP CO allocation cycle. Primary key for the cost_allocation data product in the finance domain Silver layer.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationCycleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Id' ;
    rdfs:comment 'Reference to the SAP CO allocation cycle definition (assessment or distribution cycle) under which this allocation was executed. Links to the cycle configuration that defines sender/receiver rules and allocation basis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:receiverProfitCentreId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_centre. Business justification: Cost allocations can be received by profit centres. The receiver_profit_centre code should be replaced with FK receiver_profit_centre_id → profit_centre.profit_centre_id to enable joining to profit ce' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCentre .

ind:receiverWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Receiver Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Cost allocations can be received by WBS elements (project cost objects). The receiver_wbs_element code should be replaced with FK receiver_wbs_element_id → wbs_element.wbs_element_id to enable joining' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:senderCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Cost allocations originate from a sender cost centre. The sender_cost_centre code and name should be replaced with FK sender_cost_centre_id → cost_centre.cost_centre_id to enable joining to sender cos' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:activityRate rdf:type rdf:Property ;
    rdfs:label 'Activity Rate' ;
    rdfs:comment 'The planned or actual cost rate per unit of activity (e.g., cost per equipment hour, cost per tonne processed) used to calculate the allocated amount. Supports equipment hourly rate charging and processing plant throughput-based apportionment in AISC and C1 cost build-up.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code when the allocation basis is an activity rate (e.g., \'EQUIP_HR\' for equipment hours, \'PROC_T\' for processing tonnes, \'DRILL_M\' for drilling metres). Drives the activity price calculation and links to the planned activity rate for variance analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aiscComponent rdf:type rdf:Property ;
    rdfs:label 'Aisc Component' ;
    rdfs:comment 'Classification of the allocated cost into the World Gold Council / ICMM All-In Sustaining Cost (AISC) reporting component. Enables automated AISC build-up from cost allocation transactions: mining costs, processing costs, G&A, royalties, sustaining capital, and by-product credits. [ENUM-REF-CANDIDATE: mining|processing|general_and_admin|royalties|sustaining_capital|by_product_credit — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary value of costs allocated from the sender to the receiver cost object in the controlling area currency. This is the primary financial outcome of the allocation transaction and feeds directly into AISC and C1 cash cost per-tonne calculations and OPEX/CAPEX reporting.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount Usd' ;
    rdfs:comment 'The allocated cost amount translated to US Dollars (USD) using the exchange rate applicable at the cycle run date. Required for AISC and C1 cash cost reporting in USD per ounce or USD per tonne as per ICMM and investor disclosure standards.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisType rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Type' ;
    rdfs:comment 'Method used to determine the allocation quantity or proportion. Activity rate charges based on confirmed activity quantities (e.g., equipment hours); statistical key figure uses operational metrics (e.g., tonnes processed, headcount); percentage applies a fixed split; fixed amount allocates a predetermined sum; equivalence number uses weighted ratios.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'Unit of measure for the allocation basis value (e.g., \'HR\' for hours, \'T\' for tonnes, \'PCT\' for percentage, \'KWH\' for kilowatt-hours). Aligns with SAP unit of measure codes and supports per-tonne cost build-up for AISC and C1 cash cost calculations.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Value' ;
    rdfs:comment 'The quantity or rate value of the allocation basis used to compute the allocated amount. For activity rate allocations this is the confirmed activity quantity (e.g., machine hours); for statistical key figure allocations this is the operational metric value (e.g., tonnes of ore processed); for percentage allocations this is the percentage applied.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Document Number' ;
    rdfs:comment 'SAP CO allocation document number uniquely identifying the posting document generated during the allocation cycle run. Corresponds to the CO document number in SAP S/4HANA CO module and serves as the business-facing reference for audit and reconciliation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the cost accountant describing the purpose, basis, or special circumstances of the allocation (e.g., \'Q3 processing plant overhead absorption based on ROM tonnes\', \'Equipment fleet hourly rate recharge to open pit operations\'). Supports audit review and period-end close documentation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationRunType rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Type' ;
    rdfs:comment 'Indicates whether the allocation was executed against actual costs (actual run), planned costs (plan run for budget allocation modelling), or as a simulation (test run without posting). Supports both actual AISC reporting and budget/forecast cost allocation modelling.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current processing status of the allocation document. Posted indicates confirmed CO posting; reversed indicates a reversal document has been generated; simulated indicates a test run without actual posting; error indicates a failed cycle run requiring correction; cancelled indicates a voided allocation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the SAP CO allocation method used. Assessment transfers primary and secondary costs using assessment cost elements; distribution reallocates primary costs; activity allocation charges based on activity rates; template allocation uses formula-based rules; periodic reposting corrects prior postings. [ENUM-REF-CANDIDATE: assessment|distribution|activity_allocation|template_allocation|periodic_reposting — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:c1CostComponent rdf:type rdf:Property ;
    rdfs:label 'C1 Cost Component' ;
    rdfs:comment 'Classification of the allocated cost into the Brook Hunt / CRU C1 Cash Cost reporting component. C1 cash cost is the industry-standard direct cash cost measure used for copper, nickel, and other base metals. Components include mining, processing, site G&A, transport, royalties, and treatment/refining charges. [ENUM-REF-CANDIDATE: mining|processing|site_general_admin|transport|royalties|treatment_refining — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Code identifying the mineral commodity to which the allocated cost is attributed (e.g., \'FE\' for iron ore, \'CU\' for copper, \'COAL\' for coal, \'LI\' for lithium, \'NI\' for nickel). Enables commodity-level cost reporting and per-tonne cost build-up for AISC and C1 calculations by commodity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP FI company code of the legal entity under which the allocation is posted. Supports legal entity-level financial reporting, intercompany cost allocation identification, and IFRS consolidated financial statement preparation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area code within which the allocation cycle was executed. The controlling area defines the organisational scope for management accounting and cost centre hierarchies. Required for multi-entity mining groups operating across multiple SAP controlling areas.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the allocated cost as Operating Expenditure (OPEX), Capital Expenditure (CAPEX), sustaining capital, or exploration cost. Drives AISC component classification (OPEX feeds C1 cash cost; sustaining capital feeds AISC; exploration feeds IFRS 6 capitalisation decisions).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'SAP CO cost element (secondary cost element for assessments, primary cost element for distributions) under which the allocation is posted. Determines the cost category in the chart of accounts and drives AISC cost component classification (mining, processing, G&A, sustaining capital).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementName rdf:type rdf:Property ;
    rdfs:label 'Cost Element Name' ;
    rdfs:comment 'Descriptive name of the SAP CO cost element (e.g., \'Equipment Hourly Rate Charge\', \'Processing Plant Overhead Absorption\', \'Shared Services Assessment\'). Provides human-readable cost category context for reporting.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleRunDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Run Date' ;
    rdfs:comment 'Calendar date on which the SAP CO allocation cycle was executed and postings were generated. Used to sequence allocation runs within a fiscal period and reconcile with period-end close activities.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this allocation crosses legal entity boundaries (True) or is within the same legal entity (False). Intercompany allocations require elimination in consolidated IFRS financial statements and may have transfer pricing implications under OECD guidelines.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this allocation document is a reversal of a prior allocation posting (True) or an original allocation (False). Reversal records carry negative amounts and are linked to the original document number for audit trail purposes.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Original Document Number' ;
    rdfs:comment 'For reversal allocation records, the SAP CO document number of the original allocation being reversed. Enables audit trail linkage between original and reversal postings for period-end reconciliation and financial control.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCostCentre rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Centre' ;
    rdfs:comment 'SAP CO cost centre code of the receiving cost object that absorbs the allocated costs. Represents the mine pit, processing circuit, exploration project, or operational department receiving the cost charge.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCostCentreName rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Centre Name' ;
    rdfs:comment 'Descriptive name of the receiving cost centre (e.g., \'Open Pit Mining Operations\', \'Copper Flotation Circuit\', \'Lithium Exploration\'). Provides human-readable context for the allocation destination.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost centre to receiving cost objects. \'direct\' — costs charged directly; \'assessment\' — allocated via SAP CO assessment cycle; \'distribution\' — allocated via SAP CO distribution cycle; \'activity_allocation\' — allocated based on activity quantities; \'none\' — no secondary allocation performed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Annual' ;
    rdfs:comment 'Total approved annual budget allocated to this cost centre for the current fiscal year, expressed in the cost centre\'s reporting currency. Used as the baseline for monthly budget vs. actual variance reporting and OPEX/CAPEX governance.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year (e.g., 2024) to which the annual budget amount applies. Enables year-on-year budget comparison and multi-year LOM cost planning.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area associated with this cost centre, used for cross-company-code reporting and segment-level balance sheet preparation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area to which this cost centre belongs, defining the organisational scope for internal cost accounting and management reporting. Typically aligned to a legal entity or mining group.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Category' ;
    rdfs:comment 'Classification of the cost centre by its primary function in the mining cost structure. \'production\' covers direct mining and processing activities contributing to AISC and C1 cash cost; \'service\' covers internal service providers (e.g., maintenance workshops); \'overhead\' covers indirect mine-site costs; \'administration\' covers corporate functions; \'investment\' covers CAPEX project cost centres.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreName rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Name' ;
    rdfs:comment 'Human-readable descriptive name of the cost centre (e.g., \'Pit 3 Drilling Operations\', \'SAG Mill Processing\', \'Corporate Finance\'). Corresponds to SAP CO KTEXT (short description) field.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Status' ;
    rdfs:comment 'Current lifecycle status of the cost centre. \'active\' — open for postings; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings pending review; \'pending_approval\' — awaiting authorisation; \'closed\' — permanently decommissioned following mine closure or restructure.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreType rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Type' ;
    rdfs:comment 'Indicates whether the cost centre primarily captures Operating Expenditure (OPEX) or Capital Expenditure (CAPEX), or functions as a shared service or IFRS 6 exploration cost centre. Drives treatment in AISC and C1 cash cost calculations and IFRS 6 exploration accounting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'SAP CO cost element group assigned to this cost centre, defining which primary cost elements (e.g., labour, materials, energy, depreciation) are permissible for posting. Supports structured cost build-up for AISC and C1 reporting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organisational department code to which this cost centre belongs (e.g., \'DRILL\', \'BLAST\', \'HAUL\', \'PROCESS\', \'MAINT\', \'HSE\', \'FINANCE\'). Supports departmental cost reporting and headcount allocation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Broad functional classification of the cost centre within the mining value chain. Used for cross-site functional cost benchmarking and AISC component attribution (e.g., mining, processing, G&A). [ENUM-REF-CANDIDATE: mining|processing|exploration|maintenance|logistics|hse|administration|finance|sales|rehabilitation — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP FI General Ledger (GL) account group associated with this cost centre, defining the chart of accounts range permissible for postings. Ensures correct financial statement classification under IFRS.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'The standard hierarchy node or cost centre group to which this cost centre belongs in SAP CO, defining its position in the organisational cost reporting tree (e.g., mine site > department > function). Feeds AISC and C1 per-tonne cost roll-up.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this is a statistical cost centre used for reporting and allocation base purposes only, with no actual cost postings permitted. Statistical cost centres track quantities (e.g., tonnes mined) used as allocation bases for activity-based costing.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether this cost centre is locked against actual postings in SAP CO. When True, no new financial transactions can be posted. Corresponds to SAP CO SPERRZ field.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Extended narrative description of the cost centre\'s business purpose, scope of activities, and cost allocation rationale. Supports AISC and C1 cash cost build-up documentation.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP MM/PM plant code associated with this cost centre, linking cost accounting to physical plant operations for maintenance work orders, material consumption, and asset depreciation postings.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Full name of the manager accountable for costs posted to this cost centre. Used for budget accountability, variance reporting, and management sign-off on monthly cost reviews. Corresponds to SAP CO VERAK field.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManagerPersonnelNo rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Personnel No' ;
    rdfs:comment 'SAP HR personnel number of the manager responsible for this cost centre, enabling system-driven workflow approvals, budget notifications, and organisational reporting linkage.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userResponsible rdf:type rdf:Property ;
    rdfs:label 'User Responsible' ;
    rdfs:comment 'SAP user ID of the person responsible for maintaining and updating this cost centre master record. Corresponds to SAP CO VERAK (user responsible) field for data stewardship.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date from which this cost centre is active and available for financial postings in SAP CO. Corresponds to SAP CO DATAB (valid from) field. Supports Life of Mine (LOM) planning and project phase cost tracking.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'The date after which this cost centre is no longer active for financial postings. Corresponds to SAP CO DATBI (valid to) field. Null indicates an open-ended cost centre with no planned closure date.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPerformanceReportId rdf:type rdf:Property ;
    rdfs:label 'Cost Performance Report Id' ;
    rdfs:comment 'Primary key for cost_performance_report' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aiscGuidanceHigh rdf:type rdf:Property ;
    rdfs:label 'Aisc Guidance High' ;
    rdfs:comment 'Upper bound of the published AISC cost guidance range for the reporting period or full year, as disclosed in investor guidance documents. Together with aisc_guidance_low defines the guidance band for performance assessment.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aiscGuidanceLow rdf:type rdf:Property ;
    rdfs:label 'Aisc Guidance Low' ;
    rdfs:comment 'Lower bound of the published AISC cost guidance range for the reporting period or full year, as disclosed in investor guidance documents. Used to assess whether actual AISC performance is within the guided range.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetUnitCost rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Cost' ;
    rdfs:comment 'Budgeted per-unit AISC or C1 cost for the reporting period as approved in the annual operating plan. Used as the benchmark for variance analysis against actual unit cost results. Sourced from SAP CO planning versions.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:byproductCredit rdf:type rdf:Property ;
    rdfs:label 'Byproduct Credit' ;
    rdfs:comment 'Revenue credit from by-product commodity sales (e.g., silver credits in a gold operation, molybdenum credits in a copper operation) deducted from gross costs to arrive at net AISC and C1 cost. A negative value reduces the reported unit cost.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVarianceDriver rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Driver' ;
    rdfs:comment 'Narrative description of the primary driver(s) explaining the variance between actual and budget unit cost. Examples include grade underperformance, unplanned maintenance downtime, reagent price escalation, or FX movement. Used in management commentary and investor disclosures.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Fx Rate To Usd' ;
    rdfs:comment 'Exchange rate applied to convert local currency cost components to USD for the reporting period. Sourced from SAP FI currency translation tables. Critical for cross-jurisdiction AISC benchmarking.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaCost rdf:type rdf:Property ;
    rdfs:label 'Ga Cost' ;
    rdfs:comment 'Site-level general and administrative overhead costs allocated to the reporting period, including site management, administration, and corporate services. Included in AISC but excluded from C1 cash cost per World Gold Council methodology.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headGrade rdf:type rdf:Property ;
    rdfs:label 'Head Grade' ;
    rdfs:comment 'Average grade of ore fed to the processing plant during the reporting period, expressed in the commodity-appropriate unit (e.g., g/t for gold, % for copper). Head grade is a key cost driver — lower grades increase unit AISC by reducing production volume from the same processing throughput.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGuidanceMet rdf:type rdf:Property ;
    rdfs:label 'Is Guidance Met' ;
    rdfs:comment 'Indicates whether the actual unit cost result falls within the published AISC or C1 guidance range for the period. True when unit_cost_result is between aisc_guidance_low and aisc_guidance_high. Used in investor reporting and board performance dashboards.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:miningOpex rdf:type rdf:Property ;
    rdfs:label 'Mining Opex' ;
    rdfs:comment 'Direct mining operating costs for the period including drilling, blasting, loading, hauling, and ROM pad management. A core component of both AISC and C1 cost calculations. Sourced from SAP CO cost centre actuals for mining cost centres.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodUnitCost rdf:type rdf:Property ;
    rdfs:label 'Prior Period Unit Cost' ;
    rdfs:comment 'Per-unit AISC or C1 cost from the immediately preceding reporting period of the same type (e.g., prior quarter for quarterly reports). Enables period-on-period trend analysis and investor disclosure of cost trajectory.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingOpex rdf:type rdf:Property ;
    rdfs:label 'Processing Opex' ;
    rdfs:comment 'Direct mineral processing and beneficiation costs for the period including comminution, flotation, leaching, SX-EW, and reagent consumption. Sourced from SAP CO processing plant cost centres.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Production Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the production volume field. Commodity-specific: troy ounces (oz) for gold and silver, dry metric tonnes (dmt) for iron ore and coal, pounds (lb) for copper and nickel. [ENUM-REF-CANDIDATE: oz|troy_oz|dmt|wmt|lb|t|kg — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolume rdf:type rdf:Property ;
    rdfs:label 'Production Volume' ;
    rdfs:comment 'Total quantity of payable commodity produced during the reporting period, expressed in the unit of measure applicable to the commodity (e.g., troy ounces for gold, dry metric tonnes for iron ore, pounds for copper). Used as the denominator in per-unit AISC and C1 cost calculations.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Pct' ;
    rdfs:comment 'Metallurgical recovery rate achieved during the reporting period, expressed as a percentage of valuable mineral extracted from the ore feed. Recovery rate directly impacts production volume and therefore unit AISC. Sourced from metallurgical balance reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refiningAndTransportCost rdf:type rdf:Property ;
    rdfs:label 'Refining And Transport Cost' ;
    rdfs:comment 'Costs incurred for off-site refining, smelting, and transportation of concentrate or doré to the point of sale. Included in C1 cash cost for base metals and in AISC for precious metals. Covers both CIF and FOB delivery terms.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known business identifier for the cost performance report, used in investor disclosures, management reporting packs, and peer benchmarking submissions. Follows the format CPR-YYYY-MM-SiteCode.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the cost performance report, controlling whether it is eligible for external disclosure or investor reporting. Draft reports are work-in-progress; published reports are locked for regulatory submission.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the cost reporting methodology applied. AISC follows World Gold Council standards including sustaining CAPEX and G&A. C1 captures direct cash costs only. C2 and C3 represent broader cost boundary definitions used in copper and base metals benchmarking.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'Last calendar date of the reporting period covered by this cost performance record. Together with reporting_period_start defines the cost accumulation window for AISC and C1 calculations.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'First calendar date of the reporting period covered by this cost performance record. Used to align cost metrics with production volumes and financial period boundaries in SAP FI/CO.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Granularity of the reporting period — monthly for operational management, quarterly for ASX/SEC investor disclosures, and annual for full-year AISC benchmarking against peers.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyCost rdf:type rdf:Property ;
    rdfs:label 'Royalty Cost' ;
    rdfs:comment 'Government and private royalties payable on mineral production during the reporting period. Included in both AISC and C1 cost calculations. Sourced from SAP FI accounts payable royalty accruals.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainingCapex rdf:type rdf:Property ;
    rdfs:label 'Sustaining Capex' ;
    rdfs:comment 'Capital expenditure required to sustain current production levels, including equipment replacement, tailings storage facility (TSF) raises, and mine infrastructure maintenance. Included in AISC but excluded from C1 cash cost. Sourced from SAP PS project actuals.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Usd' ;
    rdfs:comment 'Aggregate of all cost components (mining OPEX, processing OPEX, G&A, sustaining CAPEX, royalties, refining and transport) less by-product credits for the reporting period, expressed in USD. This is the numerator used to compute the per-unit AISC or C1 cost.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCostResult rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Result' ;
    rdfs:comment 'Calculated per-unit AISC or C1 cash cost expressed in USD per production unit of measure (e.g., USD/oz for gold, USD/lb for copper, USD/dmt for iron ore). This is the primary cost disclosure metric for investor reporting and peer benchmarking. Computed as total_cost_usd divided by production_volume.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Variance To Budget Pct' ;
    rdfs:comment 'Percentage variance of actual unit cost result against the budget unit cost for the period. Positive values indicate cost overrun; negative values indicate cost underperformance. Calculated as ((unit_cost_result - budget_unit_cost) / budget_unit_cost) * 100.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorPeriodPct rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Period Pct' ;
    rdfs:comment 'Percentage variance of actual unit cost result against the prior period unit cost. Used in quarterly investor reports and management commentary to explain cost movement drivers.' ;
    rdfs:domain ind:CostPerformanceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:explorationExpenditureId rdf:type rdf:Property ;
    rdfs:label 'Exploration Expenditure Id' ;
    rdfs:comment 'Primary key for exploration_expenditure' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'The SAP HR employee identifier of the authorised approver who approved this exploration expenditure for capitalisation or expensing. Supports delegated authority compliance and audit trail requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Accumulated Expenditure Amount' ;
    rdfs:comment 'The cumulative total of capitalised exploration and evaluation expenditure for this area of interest as at the posting date. Represents the carrying value of the E&E asset on the balance sheet prior to impairment assessment. Critical for IFRS 6 impairment trigger evaluation and JORC resource reporting.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountFunctionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Functional Currency' ;
    rdfs:comment 'The exploration expenditure amount translated into the entity\'s functional currency (typically AUD) using the exchange rate applicable at the transaction date. Used for consolidated IFRS financial reporting and IFRS 6 asset carrying value calculations.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaOfInterestCode rdf:type rdf:Property ;
    rdfs:label 'Area Of Interest Code' ;
    rdfs:comment 'Unique code identifying the geographic area of interest (AOI) to which this expenditure is attributed. The area of interest is the fundamental unit of account under IFRS 6 for capitalisation and impairment assessment. Aligns with tenement or exploration licence boundaries.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaOfInterestName rdf:type rdf:Property ;
    rdfs:label 'Area Of Interest Name' ;
    rdfs:comment 'Descriptive name of the exploration area of interest (e.g., \'Pilbara North Block\', \'Kalgoorlie East Tenement\'). Provides human-readable context for financial reporting and ASX continuous disclosure.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved budget amount allocated for this exploration expenditure line or project phase in the functional currency. Used for CAPEX/OPEX budget variance analysis and board-approved exploration programme tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalisationStatus rdf:type rdf:Property ;
    rdfs:label 'Capitalisation Status' ;
    rdfs:comment 'Indicates whether this expenditure has been capitalised as an exploration and evaluation (E&E) asset, expensed in the period, is pending accounting review, reclassified to mine development assets upon technical feasibility determination, or written off following impairment. Core IFRS 6 accounting policy field.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Expenditure Amount' ;
    rdfs:comment 'The gross monetary value of the exploration expenditure incurred in the transaction currency. This is the primary financial measure for IFRS 6 capitalisation tracking, budget variance analysis, and ASX continuous disclosure of exploration spend.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureType rdf:type rdf:Property ;
    rdfs:label 'Expenditure Type' ;
    rdfs:comment 'Classification of the nature of exploration expenditure incurred. Determines the appropriate accounting treatment under IFRS 6 and supports granular cost analysis by activity. [ENUM-REF-CANDIDATE: drilling|geophysical_survey|assaying|geological_mapping|feasibility_study|environmental_study|land_access|administration — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the entity\'s functional currency into which the transaction currency amount has been translated (e.g., AUD). Supports multi-entity group consolidation under IFRS.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'The monetary value of any impairment loss recognised against the capitalised exploration and evaluation asset for this area of interest in the functional currency. Recognised in profit or loss per IFRS 6 paragraph 21 when recoverable amount falls below carrying value.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicatorPresent rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Present' ;
    rdfs:comment 'Indicates whether one or more IFRS 6 impairment indicators are present for this area of interest at the reporting date (e.g., exploration licence expiry, no further exploration planned, resource not commercially viable). Triggers mandatory impairment test under IFRS 6 paragraph 20.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mineralCommodity rdf:type rdf:Property ;
    rdfs:label 'Mineral Commodity' ;
    rdfs:comment 'The primary mineral commodity being targeted by the exploration programme associated with this expenditure (e.g., iron_ore, copper, lithium). Used for commodity-level cost analysis, portfolio management, and segment reporting under IFRS 8. [ENUM-REF-CANDIDATE: iron_ore|copper|coal|lithium|nickel|gold|zinc|silver|manganese|other — promote to reference product]' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclassificationDate rdf:type rdf:Property ;
    rdfs:label 'Reclassification Date' ;
    rdfs:comment 'The date on which capitalised exploration and evaluation expenditure was reclassified from E&E assets to mine development assets (or written off) following technical feasibility determination or impairment. Null if reclassification has not occurred.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The SAP S/4HANA FI document number assigned to this exploration expenditure posting. Serves as the primary cross-reference to the source system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalFeasibilityDate rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Date' ;
    rdfs:comment 'The date on which technical feasibility and commercial viability was formally determined for the area of interest, triggering reclassification of E&E assets to mine development assets. Null if technical feasibility has not yet been determined.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalFeasibilityDetermined rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Determined' ;
    rdfs:comment 'Indicates whether technical feasibility and commercial viability of extracting the mineral resource has been determined for this area of interest. When True, triggers mandatory reclassification of capitalised E&E assets to mine development assets under IFRS 6 paragraph 17.' ;
    rdfs:domain ind:ExplorationExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'SAP MM vendor master code for the external supplier or contractor who provided the exploration services (e.g., drilling contractor, geophysical survey company, assay laboratory). Links to the SAP vendor master for accounts payable processing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique surrogate identifier for the fixed asset record in the data lakehouse. Primary key for the fixed_asset data product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from the acquisition date to the current reporting period. Corresponds to SAP ANLC-KNAFA. Used to calculate net book value for balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the fixed asset was acquired, capitalised, or placed in service. Used as the start date for depreciation calculations and CAPEX reporting. Corresponds to SAP ANLA-AKTIV.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level business category of the fixed asset used for CAPEX reporting and balance sheet disclosures. Aligns with IAS 16 and IFRS 6 asset groupings. [ENUM-REF-CANDIDATE: plant_and_equipment|mine_development|mineral_rights|infrastructure|mobile_equipment|land|construction_in_progress — promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP FI-AA asset class code (ANLA-ANLKL) that classifies the asset into categories such as plant and equipment, mine development costs, mineral rights, infrastructure, or vehicles. Drives depreciation rules and balance sheet grouping.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Short descriptive name of the fixed asset as recorded in SAP FI-AA (ANLA-TXT50). Examples: \'SAG Mill No. 3\', \'Haul Road – Pit 2 to ROM Pad\', \'Mineral Rights – Tenement ML1234\'.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The externally-known SAP FI-AA asset number uniquely identifying the capitalised asset within the asset accounting module. Corresponds to the SAP ANLA-ANLN1 field.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetResponsiblePerson rdf:type rdf:Property ;
    rdfs:label 'Asset Responsible Person' ;
    rdfs:comment 'Name or personnel number of the individual accountable for the asset\'s physical custody, condition, and compliance with asset management policies. Corresponds to SAP ANLA-VERTN.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. \'active\' indicates the asset is in service and depreciating; \'under_construction\' indicates a capital work in progress (CWIP); \'retired\' indicates end of useful life; \'disposed\' indicates sale or write-off; \'impaired\' indicates a recognised impairment loss; \'transferred\' indicates inter-company or inter-site transfer.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'SAP FI-AA sub-number (ANLN2) used to track components or partial retirements of a main asset number. Enables component-level tracking within a single asset master.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical asset tag or barcode number affixed to the asset for field identification and inventory verification. Used during physical asset counts and reconciliation with the SAP asset register.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Code' ;
    rdfs:comment 'Reference code linking the asset to the approved CAPEX budget line item or capital project authorisation. Supports CAPEX tracking and variance reporting against approved capital expenditure budgets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date on which the asset was retired, disposed of, or decommissioned. Marks the end of the asset\'s depreciable life in the accounting records.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP FI-AA depreciation key code (e.g., LINR, DG10, UOP1) that defines the specific depreciation calculation rules applied to the asset, including method, period control, and base value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs6ExplorationFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs6 Exploration Flag' ;
    rdfs:comment 'Indicates whether the asset is classified as an exploration and evaluation asset under IFRS 6 (Exploration for and Evaluation of Mineral Resources). When true, specific IFRS 6 recognition and impairment rules apply rather than standard IAS 16 treatment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment loss recognised against the asset where the recoverable amount has fallen below the carrying amount. Recorded in accordance with IAS 36 and disclosed in financial statements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Current insured replacement value of the asset as declared to the insurer. May differ from net book value; used for insurance adequacy reviews and risk management reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Specific physical location code within the plant or mine site where the asset is installed or stationed (e.g., processing circuit, pit bench, ROM pad). Corresponds to SAP ANLA-STORT.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current net book value (NBV) of the asset, calculated as acquisition cost less accumulated depreciation and any impairment losses. Key balance sheet figure for CAPEX and financial disclosures.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Remaining estimated useful life of the asset in years as at the current reporting date. Derived from useful life and elapsed depreciation periods; used for impairment assessments and LOM closure planning.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated residual or scrap value of the asset at the end of its useful life. Deducted from acquisition cost to determine the depreciable amount under IAS 16. Corresponds to SAP ANLC-SCHRW.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Cumulative revaluation surplus or deficit recognised for assets carried under the revaluation model per IAS 16. Applicable to mineral rights and land assets subject to periodic fair value assessment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the GL account (SAP WAERS). Mining enterprises operating across multiple jurisdictions (Australia, USA, Canada, South Africa) may maintain accounts in local currencies (AUD, USD, CAD, ZAR) with group currency translation.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group (KTOKS) that controls the number range and field selection for the GL account. Groups accounts by functional category (e.g., revenue, OPEX, CAPEX, exploration, balance sheet). [ENUM-REF-CANDIDATE: revenue|opex|capex|exploration|balance_sheet|intercompany|tax|depreciation|provisions — promote to reference product]' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongDescription rdf:type rdf:Property ;
    rdfs:label 'Account Long Description' ;
    rdfs:comment 'Extended description of the GL account providing full business context, including the nature of costs or revenues captured (e.g., \'OPEX — Drill and Blast Consumables — Open Pit\'). Supports financial reporting and audit.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as defined in the chart of accounts (SAP field TXT20/TXT50). Used in financial reports, trial balances, and cost postings across mining operations.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aiscCostCategory rdf:type rdf:Property ;
    rdfs:label 'Aisc Cost Category' ;
    rdfs:comment 'Mapping of the GL account to the World Gold Council AISC cost category framework, enabling AISC and C1 cash cost reporting. Categories include mining, processing, site G&A, sustaining CAPEX, royalties, and by-product credits. Used for commodity cost benchmarking across iron ore, copper, coal, lithium, and nickel operations. [ENUM-REF-CANDIDATE: c1_mining|c1_processing|c1_site_ga|royalties|by_product_credits|sustaining_capex|corporate_ga|reclamation — promote to reference product]' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'SAP alternative account number (ALTKT) from a country-specific or group chart of accounts. Used in mining companies operating across multiple jurisdictions to map local statutory accounts to the group chart of accounts for consolidated IFRS reporting.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetCategory rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Category' ;
    rdfs:comment 'For balance sheet GL accounts, the IFRS balance sheet category (e.g., property plant and equipment, mineral rights, exploration assets, inventory, provisions for rehabilitation). Supports IFRS financial statement presentation and mine closure liability accounting. [ENUM-REF-CANDIDATE: ppe|mineral_rights|exploration_assets|inventory|trade_receivables|trade_payables|rehabilitation_provision|deferred_tax — promote to reference product]' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedByUser rdf:type rdf:Property ;
    rdfs:label 'Changed By User' ;
    rdfs:comment 'SAP user ID (USNAM) of the person who last modified this GL account master record. Required for SOX internal controls, financial audit trails, and segregation of duties compliance in the mining finance function.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'SAP chart of accounts key (KTOPL) to which this GL account belongs. A mining enterprise may operate multiple charts of accounts across jurisdictions (e.g., Australian GAAP, IFRS, US GAAP for SEC reporting).' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Commitment Management Flag' ;
    rdfs:comment 'Indicates whether purchase order commitments and funds reservations are tracked against this GL account in SAP CO. When true, uncommitted CAPEX and OPEX budget balances are visible, supporting mine budget control and CAPEX approval workflows.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCentreRelevance rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Relevance' ;
    rdfs:comment 'Indicates whether postings to this GL account require a cost centre assignment in SAP CO. When true, all OPEX postings must be assigned to a cost centre (e.g., drill and blast, haulage, processing plant, maintenance) for mine cost centre accounting and AISC reporting.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'SAP Controlling (CO) cost element category (KATYP) indicating whether this is a primary cost element (linked to a P&L GL account, e.g., OPEX, CAPEX) or a secondary cost element (internal allocations, activity types). Critical for mine cost centre accounting and AISC/C1 cash cost reporting.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'SAP deletion flag (XLOEV) indicating the GL account has been marked for deletion from the chart of accounts. Accounts with this flag set will be removed during the next chart of accounts reorganisation run. Retained for audit trail purposes.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group (FSTAG) controlling which fields are required, optional, or suppressed when posting to this GL account. Determines mandatory entry of cost centre, WBS element, profit centre, or other account assignment objects for mining cost control.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'Classification of the GL account within the financial statement structure (e.g., Income Statement, Balance Sheet, Cash Flow Statement). Supports IFRS-compliant financial reporting and SEC S-K 1300 mining disclosure requirements. [ENUM-REF-CANDIDATE: income_statement|balance_sheet|cash_flow_operating|cash_flow_investing|cash_flow_financing|equity_statement — promote to reference product]' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestCalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Flag' ;
    rdfs:comment 'SAP interest calculation indicator (XZPMO) specifying whether interest is calculated on balances in this GL account. Relevant for intercompany loan accounts, rehabilitation provision accounts, and deferred tax accounts in mining group structures.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this GL account master record in SAP FI. Supports change management tracking, SOX compliance, and chart of accounts version control for the mining enterprise.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Flag' ;
    rdfs:comment 'SAP line item display flag (XKRES) indicating whether individual journal entry line items are stored and displayable for this account. When true, full drill-down to individual postings is available, supporting audit and cost analysis for mining operations.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementFlag rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Flag' ;
    rdfs:comment 'SAP open item management flag (XOPVW) indicating whether individual line items posted to this account must be cleared against each other (e.g., GR/IR clearing accounts, bank clearing accounts). Critical for accounts payable and procurement reconciliation in mining supply chain.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Planning Block Flag' ;
    rdfs:comment 'Indicates whether cost planning is blocked for this GL account in SAP CO (XSPEP). When true, budget planning entries cannot be made against this account, used to control CAPEX and OPEX budget planning integrity.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Block Flag' ;
    rdfs:comment 'Indicates whether direct postings to this GL account are blocked (SAP XSPEB). When true, no journal entries can be posted to this account, typically used for accounts under review, year-end closing accounts, or accounts pending reclassification.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCentreRelevance rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Relevance' ;
    rdfs:comment 'Indicates whether postings to this GL account are relevant for SAP Profit Centre Accounting (PCA). When true, all postings are distributed to profit centres representing individual mine sites or commodity business units, enabling site-level profitability reporting.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Flag' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account (SAP XINTB) that is automatically updated from a subledger (accounts payable, accounts receivable, asset accounting). Reconciliation accounts cannot be posted to directly and are critical for financial integrity in mining ERP environments.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehabilitationProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Provision Flag' ;
    rdfs:comment 'Indicates whether this GL account is used to record mine rehabilitation and closure provisions under IFRS IAS 37. Rehabilitation provision accounts are subject to annual actuarial review and are disclosed in the notes to financial statements and environmental impact statements.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyAccountFlag rdf:type rdf:Property ;
    rdfs:label 'Royalty Account Flag' ;
    rdfs:comment 'Indicates whether this GL account is designated for recording mineral royalty payments to government or private landowners. Royalty accounts are separately tracked for AISC reporting, tax deductibility assessment, and regulatory disclosure under mining tenement agreements.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP sort key (ZUAWA) defining the default assignment field populated when posting to this GL account (e.g., document date, posting date, purchase order number, cost centre). Controls how line items are sorted in account statements and financial reports.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'SAP tax category (MWSKZ) controlling whether the GL account is relevant for input tax (GST/VAT on purchases), output tax (GST/VAT on sales), or not tax-relevant. Critical for mining royalty and resource rent tax compliance across jurisdictions.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'SAP tolerance group (TOLGR) assigned to the GL account, defining acceptable variance limits for payment differences and clearing transactions. Used in accounts payable and receivable processing for mining procurement and commodity sales.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementRelevance rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Relevance' ;
    rdfs:comment 'Indicates whether postings to this GL account require a WBS element assignment in SAP PS (Project System). When true, costs must be assigned to a project WBS element, typically for CAPEX projects, mine development, or exploration programs tracked under IFRS 6.' ;
    rdfs:domain ind:GeneralLedgerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hedgeInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Hedge Instrument Id' ;
    rdfs:comment 'Unique identifier for the financial hedging instrument record.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aiscInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Aisc Inclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether gains/losses from this hedging instrument are included in the calculation of All-In Sustaining Cost (AISC) for the mine site. True if included, False if excluded.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:c1CostInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'C1 Cost Inclusion Flag' ;
    rdfs:comment 'Boolean flag indicating whether gains/losses from this hedging instrument are included in the calculation of C1 Cash Cost for the mine site. True if included, False if excluded.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyCreditRating rdf:type rdf:Property ;
    rdfs:label 'Counterparty Credit Rating' ;
    rdfs:comment 'The credit rating of the counterparty as assessed by a recognized rating agency (e.g., Moody\'s, S&P, Fitch), used for counterparty risk assessment.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeGainLoss rdf:type rdf:Property ;
    rdfs:label 'Cumulative Gain Loss' ;
    rdfs:comment 'The cumulative realized and unrealized gain or loss on the hedging instrument since inception, used for financial reporting and performance tracking.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeAccountingDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Accounting Designation' ;
    rdfs:comment 'The IFRS 9 hedge accounting classification: fair value hedge (hedging changes in fair value of recognized asset/liability), cash flow hedge (hedging variability in future cash flows), net investment hedge (hedging FX risk in foreign operations), or not designated (held at fair value through profit or loss).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeEffectivenessRatioPct rdf:type rdf:Property ;
    rdfs:label 'Hedge Effectiveness Ratio Pct' ;
    rdfs:comment 'The calculated hedge effectiveness ratio as a percentage, measuring the degree to which changes in the hedging instrument offset changes in the hedged item. IFRS 9 requires a ratio between 80% and 125% for hedge accounting qualification.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeEffectivenessTestMethod rdf:type rdf:Property ;
    rdfs:label 'Hedge Effectiveness Test Method' ;
    rdfs:comment 'The method used to assess hedge effectiveness under IFRS 9 (e.g., dollar offset method, regression analysis, scenario analysis).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeRatio rdf:type rdf:Property ;
    rdfs:label 'Hedge Ratio' ;
    rdfs:comment 'The ratio of the quantity of the hedging instrument to the quantity of the hedged item, used in hedge effectiveness calculations under IFRS 9.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Hedged Item Description' ;
    rdfs:comment 'Description of the underlying exposure or asset/liability being hedged (e.g., forecast copper sales Q1 2024, USD-denominated CAPEX for mine expansion, floating rate debt).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCategory rdf:type rdf:Property ;
    rdfs:label 'Instrument Category' ;
    rdfs:comment 'High-level categorization of the hedge by underlying risk exposure: commodity price hedge (gold, copper, iron ore), foreign currency hedge (FX protection for CAPEX or revenue), or interest rate hedge (debt cost management).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Instrument Reference Number' ;
    rdfs:comment 'External business identifier or contract number assigned to the hedging instrument by the treasury system or counterparty.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Status' ;
    rdfs:comment 'Current lifecycle status of the hedging instrument: active (open and in force), matured (reached maturity date), settled (closed out and settled), terminated (early termination by agreement), or cancelled (voided before execution).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the hedging instrument by derivative type: commodity forward, commodity option, foreign exchange (FX) forward, FX option, interest rate swap, or commodity swap.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEffectivenessTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Effectiveness Test Date' ;
    rdfs:comment 'The date on which the most recent hedge effectiveness test was performed.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markToMarketValue rdf:type rdf:Property ;
    rdfs:label 'Mark To Market Value' ;
    rdfs:comment 'The current fair value or mark-to-market valuation of the hedging instrument, representing unrealized gain or loss at the reporting date.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'The expiration or settlement date of the hedging instrument when the contract matures and is settled or exercised.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mtmValuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Currency' ;
    rdfs:comment 'The currency in which the mark-to-market value is reported (ISO 4217 three-letter code).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtmValuationDate rdf:type rdf:Property ;
    rdfs:label 'Mtm Valuation Date' ;
    rdfs:comment 'The date as of which the mark-to-market value was calculated or obtained.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notionalAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Amount' ;
    rdfs:comment 'The notional principal or contract size of the hedging instrument, representing the quantity or value being hedged (e.g., tonnes of copper, USD amount for FX forward).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Notional Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the notional amount (e.g., tonnes, ounces, USD, AUD, barrels).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionStyle rdf:type rdf:Property ;
    rdfs:label 'Option Style' ;
    rdfs:comment 'For option instruments, specifies the exercise style: European (exercisable only at maturity), American (exercisable any time before maturity), Asian (average price option), or not_applicable for non-option instruments.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'For option instruments, specifies whether it is a call option (right to buy) or put option (right to sell). Set to not_applicable for forwards, swaps, and other non-option instruments.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumCurrency rdf:type rdf:Property ;
    rdfs:label 'Premium Currency' ;
    rdfs:comment 'The currency in which the option premium was paid (ISO 4217 three-letter code).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaid rdf:type rdf:Property ;
    rdfs:label 'Premium Paid' ;
    rdfs:comment 'The upfront premium paid for option contracts. Null or zero for forward contracts and swaps that typically have no upfront premium.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The actual date on which the hedging instrument was settled or closed out. Null if the instrument is still open.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strikePrice rdf:type rdf:Property ;
    rdfs:label 'Strike Price' ;
    rdfs:comment 'The agreed strike or exercise price for option contracts, or the forward price for forward contracts. Represents the price at which the hedge is executed.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strikePriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Strike Price Currency' ;
    rdfs:comment 'The currency in which the strike or forward price is denominated (ISO 4217 three-letter code, e.g., USD, AUD, EUR).' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDate rdf:type rdf:Property ;
    rdfs:label 'Trade Date' ;
    rdfs:comment 'The date on which the hedging instrument was executed or contracted with the counterparty.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underlyingCommodity rdf:type rdf:Property ;
    rdfs:label 'Underlying Commodity' ;
    rdfs:comment 'The specific commodity being hedged (gold, copper, iron ore, nickel, lithium, coal) for commodity price hedges. Set to not_applicable for FX and interest rate hedges. [ENUM-REF-CANDIDATE: gold|copper|iron_ore|nickel|lithium|coal|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingCurrencyPair rdf:type rdf:Property ;
    rdfs:label 'Underlying Currency Pair' ;
    rdfs:comment 'The currency pair being hedged for foreign exchange instruments (e.g., USD/AUD, EUR/USD). Null for commodity and interest rate hedges.' ;
    rdfs:domain ind:HedgeInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'Date of the original business document that triggered the intercompany transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'Date on which the intercompany transaction was eliminated during the consolidation process.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Status indicating whether the intercompany transaction has been eliminated in group consolidation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the group reporting currency for consolidation purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for group-level consolidation and reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Detailed textual description of the intercompany transaction explaining the business purpose and context.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Transaction amount converted to the local currency of the sending company code.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving or being charged in the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as invoice number, purchase order, or contract reference supporting the intercompany transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this intercompany transaction is a reversal of a previously posted transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original transaction that this reversal posting is correcting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity initiating or charging the intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of the intercompany transaction settlement indicating payment progress.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code applicable to the intercompany transaction for withholding tax and compliance purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Gross monetary value of the intercompany transaction in the transaction currency before any adjustments.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Category' ;
    rdfs:comment 'High-level category grouping the intercompany transaction for reporting and analysis purposes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the intercompany transaction was originally denominated.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Document Number' ;
    rdfs:comment 'SAP FI document number uniquely identifying the intercompany posting in the general ledger.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Reference' ;
    rdfs:comment 'Reference identifier to the transfer pricing documentation supporting the transaction pricing.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'Transfer pricing methodology applied to determine the intercompany transaction price for tax compliance.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Effective date for cash flow and interest calculation purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax applied to the intercompany transaction as per local tax regulations.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry header record in the general ledger system. Primary key for all financial postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'The subnumber of the fixed asset for tracking components or sub-assets within a main asset. Used for detailed asset lifecycle management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business area for cross-company code reporting. Represents business segments that span multiple legal entities, such as global copper operations or integrated iron ore value chain.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this journal entry was cleared. Populated when open items are settled. Used for aging analysis and cash flow reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number of the clearing entry if this journal entry has been cleared (e.g., invoice cleared by payment). Used for open item management and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-form text description at the header level providing context for this journal entry. Used for explanatory notes, period-end adjustments, and manual posting descriptions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date when this journal entry was physically entered into the SAP system. Used for audit trail and user activity tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTime rdf:type rdf:Property ;
    rdfs:label 'Entry Time' ;
    rdfs:comment 'The time of day when this journal entry was entered into the system. Stored in HH:MM:SS format. Used for detailed audit trails.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an intercompany transaction between different company codes within the mining group. True for intercompany postings requiring elimination entries during consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'The internal order number for tracking specific cost collection objects such as maintenance campaigns, exploration programs, or overhead cost pools. Used for detailed OPEX analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Identifies the ledger to which this entry is posted: 0L (Leading Ledger - IFRS), 1L (Local GAAP), 2L (Management Reporting), 3L (Tax Ledger), 9L (Consolidation Ledger). Supports parallel accounting under IFRS and local standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code of the company code\'s local currency. All amounts are converted to this currency for statutory reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'The material master number when this journal entry relates to inventory movements, ROM stockpile valuations, or concentrate sales. Links to material master for commodity tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is parked (saved but not yet posted). True for parked documents awaiting approval, False for posted documents. Used for workflow and approval processes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls the type of posting at the line item level: 01-49 (Debit postings), 50-99 (Credit postings). Determines account type, debit/credit indicator, and field status.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversing the original entry: 01 (Reversal in Current Period), 02 (Reversal in Next Period), 03 (Incorrect Posting), 04 (Accrual Reversal), 05 (Other). Used for financial control and audit purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner when intercompany_indicator is True. Used for intercompany reconciliation and consolidation elimination entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Amount' ;
    rdfs:comment 'The total amount of this journal entry in the original transaction currency. Sum of all debit or credit line items in document currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of the line item converted to the local reporting currency of the operating entity. Used for consolidated financial reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The monetary amount of the line item in the original transaction currency. Represents the value before any currency conversion.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentText rdf:type rdf:Property ;
    rdfs:label 'Assignment Text' ;
    rdfs:comment 'Free-form text field for additional assignment or reference information. Often used to capture invoice numbers, purchase order references, or other cross-reference identifiers.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The baseline date from which payment terms are calculated. Determines the due date for payment or receipt of funds.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerCode rdf:type rdf:Property ;
    rdfs:label 'Customer Code' ;
    rdfs:comment 'The customer master code for accounts receivable postings. Identifies the buyer or customer associated with this line item.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line item is a debit (D) or credit (C) posting. Fundamental accounting classification for double-entry bookkeeping.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'The functional area code representing the business function (e.g., mining, processing, logistics, administration). Used for cost of sales and functional expense reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'The internal order number for cost collection and allocation. Used for tracking specific cost objects such as maintenance campaigns or exploration programs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text providing additional detail about the nature or purpose of this line item posting. Enhances auditability and understanding of the transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the journal entry document. Determines the ordering of line items within a single journal entry.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The payment terms code defining the due date calculation and discount conditions. Critical for cash flow forecasting and working capital management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when this line item was posted to the general ledger. Critical for audit trail and financial period cutoff verification.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceKey1 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 1' ;
    rdfs:comment 'First reference key field for linking to source documents or external systems. Commonly used for invoice numbers, contract references, or shipment identifiers.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey2 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 2' ;
    rdfs:comment 'Second reference key field for additional cross-referencing. Provides flexibility for multi-dimensional traceability to source transactions.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey3 rdf:type rdf:Property ;
    rdfs:label 'Reference Key 3' ;
    rdfs:comment 'Third reference key field for extended cross-referencing requirements. Supports complex traceability scenarios across multiple systems.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal document that reversed this line item. Null if the item has not been reversed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'The calculated tax amount for this line item in local currency. Derived from the tax code and base amount.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to this line item. Determines the tax treatment, rate, and GL accounts for tax posting (e.g., GST, VAT, sales tax).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'The trading partner code for intercompany transactions. Identifies the counterparty legal entity within the corporate group for consolidation and elimination purposes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'SAP HR employee identifier of the individual who formally approved this OPEX budget record. Supports segregation of duties and audit trail requirements under IFRS and SOX-equivalent controls.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'SAP HR employee identifier of the person accountable for managing and approving this OPEX budget line. Supports budget ownership governance and approval workflow tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetCycleCode rdf:type rdf:Property ;
    rdfs:label 'Budget Cycle Code' ;
    rdfs:comment 'Identifier for the budget planning cycle (e.g., AOP-2024, MYR-2024-Q2) during which this OPEX budget was prepared and submitted. Supports multi-cycle budget management including Annual Operating Plan (AOP) and mid-year reviews.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Description' ;
    rdfs:comment 'Free-text description of the OPEX budget line providing business context, justification, or notes entered by the budget owner. Supports budget review and audit processes.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget End Date' ;
    rdfs:comment 'The end date of the period covered by this OPEX budget record. Defines the temporal boundary for expenditure allocation and variance measurement.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetQuantity rdf:type rdf:Property ;
    rdfs:label 'Budget Quantity' ;
    rdfs:comment 'The budgeted quantity of the resource or activity associated with this OPEX line (e.g., tonnes of ore processed, litres of fuel, hours of labour). Used in unit cost calculations for C1 and AISC reporting.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the OPEX budget record in SAP S/4HANA CO, used for cross-system traceability and audit referencing. Corresponds to the SAP internal order or cost centre budget document number.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Start Date' ;
    rdfs:comment 'The start date of the period covered by this OPEX budget record. May align with the fiscal period start or represent a sub-period budget window for project-based expenditure.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'The latest forecast of total OPEX spend for the fiscal period, incorporating actuals to date plus projected remaining spend. Used in rolling forecast cycles and AISC guidance updates.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCapitalised rdf:type rdf:Property ;
    rdfs:label 'Is Capitalised' ;
    rdfs:comment 'Indicates whether any portion of this OPEX budget line has been reclassified as capital expenditure (CAPEX) under IFRS 6 or IAS 16. True if capitalised; False if fully expensed as OPEX. Critical for IFRS 6 exploration accounting compliance.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLomIncluded rdf:type rdf:Property ;
    rdfs:label 'Is Lom Included' ;
    rdfs:comment 'Indicates whether this OPEX budget line is included in the Life of Mine (LOM) plan financial model. True if included in LOM; False if excluded (e.g., one-off or non-recurring items). Supports NPV and DCF modelling.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'The date on which the most recent budget revision was applied to this record. Tracks the recency of budget amendments for governance and audit purposes.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opexClassification rdf:type rdf:Property ;
    rdfs:label 'Opex Classification' ;
    rdfs:comment 'Classifies the OPEX budget line according to industry cost reporting frameworks. C1 cash cost covers direct mining and processing costs; AISC (All-In Sustaining Cost) includes sustaining capital and corporate overhead. Critical for external cost disclosure to investors and regulators.' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The initially approved OPEX budget amount in the reporting currency for the specified cost centre, GL account, mine site, and fiscal period. Represents the baseline against which actual spend and revisions are measured.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the budget_quantity field (e.g., t = tonnes, kt = kilotonnes, L = litres, h = hours, kWh = kilowatt-hours). Ensures dimensional consistency in unit cost calculations. [ENUM-REF-CANDIDATE: t|kt|Mt|L|kL|h|kWh|MWh|m3|kg — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OpexBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The budget variance expressed as a percentage of the budget amount ((budget - actual) / budget * 100). Enables proportional variance analysis and exception reporting across cost centres and mine sites.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aiscReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Aisc Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre is included in All-In Sustaining Cost (AISC) reporting for external disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:c1CostReportingFlag rdf:type rdf:Property ;
    rdfs:label 'C1 Cost Reporting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre reports C1 cash cost metrics for commodity margin analysis.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCentreGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Group' ;
    rdfs:comment 'The cost centre group or hierarchy to which this profit centre\'s cost centres roll up for cost allocation and reporting.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explorationAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Exploration Accounting Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre applies IFRS 6 exploration and evaluation asset accounting.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node' ;
    rdfs:comment 'The hierarchical node or path representing this profit centre\'s position in the organizational profit centre hierarchy.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsSegmentFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs Segment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit centre is a reportable operating segment under IFRS 8.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jorcResourceCategory rdf:type rdf:Property ;
    rdfs:label 'Jorc Resource Category' ;
    rdfs:comment 'The highest JORC resource classification category applicable to this profit centre\'s mineral resources (measured, indicated, inferred), if the profit centre is a mine site.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The username or identifier of the user who last modified this profit centre record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Code' ;
    rdfs:comment 'The externally-known alphanumeric code identifying the profit centre in SAP CO. Used for reporting and integration with external systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Description' ;
    rdfs:comment 'Detailed description of the profit centre\'s business scope, operations, and responsibilities.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreName rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Name' ;
    rdfs:comment 'The full business name of the profit centre (e.g., \'Iron Ore Mine Site A\', \'Copper Processing Plant B\', \'Lithium Business Unit\').' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Status' ;
    rdfs:comment 'Current lifecycle status of the profit centre indicating whether it is operational, suspended, or closed.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreType rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Type' ;
    rdfs:comment 'Classification of the profit centre by operational function (e.g., mine site, processing plant, commodity business unit, corporate function, exploration division, logistics hub).' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCategory rdf:type rdf:Property ;
    rdfs:label 'Reserve Category' ;
    rdfs:comment 'The ore reserve classification (proved or probable) for this profit centre\'s economically mineable reserves, per JORC or equivalent standards.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name or acronym for the profit centre used in reports and dashboards.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this profit centre became active and operational for financial reporting.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this profit centre is valid. Null for open-ended profit centres.' ;
    rdfs:domain ind:ProfitCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aiscUsd rdf:type rdf:Property ;
    rdfs:label 'Aisc Usd' ;
    rdfs:comment 'All-In Sustaining Cost (AISC) per unit of payable metal/mineral produced, expressed in USD per applicable unit. Extends C1 to include royalties, sustaining CAPEX, corporate G&A, and reclamation costs. Used for investor reporting and project economics benchmarking.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakevenPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Breakeven Price Usd' ;
    rdfs:comment 'The commodity price at which the project NPV equals zero at the applied discount rate, expressed in USD per applicable unit. Represents the minimum long-term commodity price required for the project to be economically viable.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1CashCostUsd rdf:type rdf:Property ;
    rdfs:label 'C1 Cash Cost Usd' ;
    rdfs:comment 'C1 cash cost per unit of payable metal/mineral produced, expressed in USD per applicable unit. Represents direct cash costs of mining, processing, and site administration, excluding royalties, depreciation, and sustaining capital. Industry-standard cost metric for benchmarking.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexTotalMusd rdf:type rdf:Property ;
    rdfs:label 'Capex Total Musd' ;
    rdfs:comment 'Total capital expenditure (CAPEX) estimate for the project over its full life, expressed in million USD. Includes initial development CAPEX, sustaining CAPEX, and closure CAPEX as modelled in the DCF. Sourced from SAP PS capital budgeting.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Usd' ;
    rdfs:comment 'Long-term real commodity price assumption used as the base case in the DCF model, expressed in USD per applicable unit (e.g., USD/tonne for iron ore, USD/lb for copper). This is a proprietary price deck assumption and is commercially sensitive.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryRiskPremiumPct rdf:type rdf:Property ;
    rdfs:label 'Country Risk Premium Pct' ;
    rdfs:comment 'Additional risk premium added to the base discount rate to reflect sovereign, political, and regulatory risk in the jurisdiction where the project is located, expressed as a percentage. Used in cross-border acquisition and greenfield valuations.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headGradePct rdf:type rdf:Property ;
    rdfs:label 'Head Grade Pct' ;
    rdfs:comment 'Average feed grade of the ore reserve used in the DCF production profile, expressed as a percentage (e.g., % Fe for iron ore, % Cu for copper). Directly drives revenue calculations in the DCF model.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inflationRatePct rdf:type rdf:Property ;
    rdfs:label 'Inflation Rate Pct' ;
    rdfs:comment 'Annual general inflation rate assumption applied in nominal DCF models to escalate costs and revenues over the mine life, expressed as a percentage. Only applicable when price_basis is nominal.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mineLifeYears rdf:type rdf:Property ;
    rdfs:label 'Mine Life Years' ;
    rdfs:comment 'Estimated total operating life of the mine in years as modelled in the DCF, derived from the LOM (Life of Mine) plan. Directly determines the number of cash flow periods in the NPV calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npvBaseMusd rdf:type rdf:Property ;
    rdfs:label 'Npv Base Musd' ;
    rdfs:comment 'Net Present Value (NPV) of the project under the base case commodity price, production, and cost assumptions, expressed in million USD. The primary investment decision metric for capital allocation and stage-gate approval.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvHighMusd rdf:type rdf:Property ;
    rdfs:label 'Npv High Musd' ;
    rdfs:comment 'NPV under the upside/high commodity price and cost scenario, expressed in million USD. Used in sensitivity analysis to quantify project value upside under favourable market conditions.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvLowMusd rdf:type rdf:Property ;
    rdfs:label 'Npv Low Musd' ;
    rdfs:comment 'NPV under the downside/low commodity price and cost scenario, expressed in million USD. Used in sensitivity analysis to quantify project value at risk under adverse market conditions.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexUnitUsd rdf:type rdf:Property ;
    rdfs:label 'Opex Unit Usd' ;
    rdfs:comment 'Steady-state operating expenditure (OPEX) per tonne of ore processed, expressed in USD/t. Represents the all-in operating cost assumption in the DCF model, excluding royalties and sustaining capital.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreReserveCategory rdf:type rdf:Property ;
    rdfs:label 'Ore Reserve Category' ;
    rdfs:comment 'JORC/NI 43-101 resource and reserve classification underpinning the production profile used in the DCF model. Proved and Probable are Ore Reserves; Measured, Indicated, and Inferred are Mineral Resources. Determines the confidence level and regulatory disclosure requirements of the valuation.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paybackPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Payback Period Years' ;
    rdfs:comment 'Number of years from first production (or initial CAPEX commitment) required to recover the total initial capital investment from undiscounted project cash flows. Used as a liquidity and risk metric alongside NPV and IRR.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or employee identifier of the qualified person (QP) or financial analyst responsible for preparing this valuation study. For JORC/NI 43-101 disclosures, the QP must be a competent person as defined by the applicable standard.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Indicates whether the commodity price deck and cost estimates in the DCF model are expressed in real (constant purchasing power) or nominal (inflated) terms. Critical for correct interpretation of NPV and IRR outputs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRateMtpa rdf:type rdf:Property ;
    rdfs:label 'Production Rate Mtpa' ;
    rdfs:comment 'Steady-state annual ore production throughput assumption used in the DCF model, expressed in million tonnes per annum (Mtpa). Derived from the mine production schedule and processing plant design capacity.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'Government or private royalty rate applied to revenue or profit in the DCF model, expressed as a percentage. Jurisdiction-specific and commodity-specific; a material cost item in project economics.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyStage rdf:type rdf:Property ;
    rdfs:label 'Study Stage' ;
    rdfs:comment 'Stage-gate study phase at which this valuation was produced. Scoping = order-of-magnitude; PFS = Pre-Feasibility Study; DFS = Definitive Feasibility Study; BFS = Bankable Feasibility Study; Update = periodic refresh. Drives accuracy expectations and capital governance approval thresholds. [ENUM-REF-CANDIDATE: scoping|pfs|dfs|bfs|update — promote to reference product if additional stages are required]' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePct rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Pct' ;
    rdfs:comment 'Corporate income tax rate applied in the DCF model for the project jurisdiction, expressed as a percentage. Drives post-tax NPV and IRR calculations. May differ from statutory rate due to mining-specific tax concessions.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOreReserveMt rdf:type rdf:Property ;
    rdfs:label 'Total Ore Reserve Mt' ;
    rdfs:comment 'Total ore reserve tonnage (Proved + Probable) underpinning the LOM production schedule in the DCF model, expressed in million tonnes. Sourced from the JORC/NI 43-101 compliant resource estimate.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this valuation study, used in stage-gate governance documentation and board submissions (e.g., VAL-PILBARA-2024).' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationName rdf:type rdf:Property ;
    rdfs:label 'Valuation Name' ;
    rdfs:comment 'Human-readable descriptive name of the valuation study (e.g., \'Pilbara Iron Ore Expansion DFS 2024\'), used in reports and presentations.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle state of the valuation record within the stage-gate capital governance workflow. Draft = work in progress; Under Review = submitted for technical/financial review; Approved = board or investment committee approved; Superseded = replaced by a newer version; Archived = retained for audit trail.' ;
    rdfs:domain ind:ProjectValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Classification of the investment decision context: greenfield (new mine development), brownfield (expansion of existing operation), acquisition (target company or asset purchase), divestment (asset sale assessment), or exploration (early-stage resource discovery). Drives applicable discount rate and risk premium selection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential integer version of this valuation within the same study stage, enabling tracking of iterative model updates (e.g., commodity price deck revisions, CAPEX re-estimates) without creating a new study stage record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationProvisionId rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Provision Id' ;
    rdfs:comment 'Unique surrogate identifier for each mine rehabilitation and closure provision record in the lakehouse silver layer.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RehabilitationProvision .

ind:bondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Bond Expiry Date' ;
    rdfs:comment 'The expiry date of the regulatory rehabilitation bond instrument. Requires renewal before expiry to maintain regulatory compliance and avoid breach of mining licence conditions.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Bond Instrument Type' ;
    rdfs:comment 'The type of financial instrument used to secure the regulatory rehabilitation bond lodged with the government regulator.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Closing Balance Amount' ;
    rdfs:comment 'The rehabilitation provision balance at the end of the reporting period after all movements (unwinding of discount, revisions, drawdowns, new provisions) have been applied. Reported on the balance sheet as a non-current liability.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Basis' ;
    rdfs:comment 'The methodological basis used to derive the undiscounted rehabilitation cost estimate. Internal_estimate indicates costs prepared by the mine closure team; independent_review indicates a third-party specialist review; regulatory_assessment indicates costs assessed by the environmental regulator; lom_plan_derived indicates costs derived from the Life of Mine (LOM) plan.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disturbanceAreaHa rdf:type rdf:Property ;
    rdfs:label 'Disturbance Area Ha' ;
    rdfs:comment 'The total area of land disturbed by mining operations (in hectares) that is subject to rehabilitation obligations. Used as a key driver in estimating per-hectare rehabilitation costs and validating provision adequacy.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedClosureDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closure Date' ;
    rdfs:comment 'The estimated date on which mine operations will cease and full rehabilitation activities are expected to be completed, based on the current Life of Mine (LOM) plan. Drives the discounting period for the provision calculation.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEstimateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Estimate Review Date' ;
    rdfs:comment 'The date on which the rehabilitation cost estimate was most recently reviewed and updated. IAS 37 requires provisions to be reviewed at each balance sheet date.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'New Provision Amount' ;
    rdfs:comment 'Additional provision recognised during the reporting period for new disturbance areas or newly identified rehabilitation obligations at the mine site.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextEstimateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Estimate Review Date' ;
    rdfs:comment 'The scheduled date for the next formal review of the rehabilitation cost estimate, ensuring compliance with IAS 37 annual review requirements and regulatory bond reassessment cycles.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Amount' ;
    rdfs:comment 'The rehabilitation provision balance at the start of the reporting period, as carried forward from the prior period closing balance. Used to reconcile provision movements per IAS 37 disclosure requirements.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opexCapexClassification rdf:type rdf:Property ;
    rdfs:label 'Opex Capex Classification' ;
    rdfs:comment 'Indicates whether the rehabilitation expenditure is classified as Operating Expenditure (OPEX) or Capital Expenditure (CAPEX) for internal cost reporting and All-In Sustaining Cost (AISC) calculation purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionNotes rdf:type rdf:Property ;
    rdfs:label 'Provision Notes' ;
    rdfs:comment 'Free-text notes capturing material assumptions, significant judgements, regulatory conditions, or other contextual information relevant to the rehabilitation provision estimate and its movements during the period.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionReference rdf:type rdf:Property ;
    rdfs:label 'Provision Reference' ;
    rdfs:comment 'Externally-known business reference code for the provision record, used in SAP FI/CO and regulatory financial disclosures. Follows the format REHAB-<SITE_CODE>-<YEAR>.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionStatus rdf:type rdf:Property ;
    rdfs:label 'Provision Status' ;
    rdfs:comment 'Current lifecycle status of the rehabilitation provision record. Active indicates the provision is live on the balance sheet; revised indicates a formal estimate revision has been processed; settled indicates actual expenditure has fully drawn down the provision; closed indicates the mine site rehabilitation obligation has been discharged; under_review indicates the provision is being reassessed.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionType rdf:type rdf:Property ;
    rdfs:label 'Provision Type' ;
    rdfs:comment 'Classification of the nature of the rehabilitation obligation. Decommissioning covers plant and equipment removal; rehabilitation covers land and soil restoration; environmental_restoration covers broader ecosystem recovery; tailings_remediation covers Tailings Storage Facility (TSF) closure; water_treatment covers ongoing water management post-closure; infrastructure_removal covers roads, buildings, and utilities. [ENUM-REF-CANDIDATE: decommissioning|rehabilitation|environmental_restoration|tailings_remediation|water_treatment|infrastructure_removal — promote to reference product]' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which the rehabilitation provision was first recognised on the balance sheet, corresponding to the date the constructive or legal obligation arose (typically commencement of mining disturbance).' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBondAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Bond Amount' ;
    rdfs:comment 'The financial assurance bond amount lodged with the relevant government regulator as security for the rehabilitation obligation. May differ from the IAS 37 provision balance due to different regulatory vs. accounting methodologies.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationCompletedAreaHa rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Completed Area Ha' ;
    rdfs:comment 'The cumulative area of land (in hectares) that has been successfully rehabilitated and formally signed off by the relevant environmental regulator, reducing the outstanding rehabilitation obligation.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionAmount rdf:type rdf:Property ;
    rdfs:label 'Revision Amount' ;
    rdfs:comment 'Net increase or decrease to the provision balance arising from revisions to the estimated future rehabilitation cost during the period. Positive values indicate upward revisions; negative values indicate downward revisions. Corresponds to changes in the underlying asset under IFRIC 1.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapProvisionDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Provision Document Number' ;
    rdfs:comment 'The SAP FI accounting document number under which the rehabilitation provision journal entry is posted in the general ledger. Enables traceability between the data product and the source system of record.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsfRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Tsf Related Flag' ;
    rdfs:comment 'Indicates whether this rehabilitation provision relates specifically to a Tailings Storage Facility (TSF) closure obligation, which carries heightened regulatory scrutiny and disclosure requirements under ICMM and MAC standards.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undiscountedCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Undiscounted Cost Estimate' ;
    rdfs:comment 'The total estimated future cost of mine rehabilitation and closure in nominal (undiscounted) terms, as determined by the most recent mine closure cost estimate study. This is the gross cost before applying the time-value-of-money discount.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unwindingOfDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Unwinding Of Discount Amount' ;
    rdfs:comment 'The finance charge recognised in the income statement during the period representing the unwinding of the time-value-of-money discount applied to the provision. Calculated as the opening provision balance multiplied by the pre-tax risk-free discount rate.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsToClosure rdf:type rdf:Property ;
    rdfs:label 'Years To Closure' ;
    rdfs:comment 'The number of years from the reporting period end date to the expected mine closure date, used as the discounting period in the present value calculation of the rehabilitation provision.' ;
    rdfs:domain ind:RehabilitationProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyObligationId rdf:type rdf:Property ;
    rdfs:label 'Royalty Obligation Id' ;
    rdfs:comment 'Unique surrogate identifier for each royalty obligation record in the mining finance system. Primary key for the royalty_obligation data product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyObligation .

ind:accruedLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Liability Amount' ;
    rdfs:comment 'The cumulative royalty liability accrued in the current accounting period but not yet paid, as recorded in SAP FI accounts payable. Used for IFRS balance sheet reporting and period-end accrual journals.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this royalty obligation is currently subject to a formal dispute, audit, or legal challenge with the payee or regulatory authority. When true, accruals may require additional provisioning under IFRS.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'The legal or regulatory basis for any royalty exemption, such as a state agreement provision, development phase concession, or rehabilitation credit. Populated only when exemption_flag is true.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Indicates whether this royalty obligation has been granted a full or partial exemption by the relevant government authority (e.g., during mine development, rehabilitation, or under a state agreement). Affects accrual calculations.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLegislation rdf:type rdf:Property ;
    rdfs:label 'Governing Legislation' ;
    rdfs:comment 'The specific mining act, regulation, or agreement that establishes the legal basis for this royalty obligation (e.g., Mining Act 1978 WA, Mineral Resources Act 1989 QLD). Critical for regulatory compliance and legal review.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction (state, territory, or country) whose mining royalty legislation governs this obligation. Determines the applicable royalty rate schedule, calculation basis, and regulatory reporting requirements. Uses ISO 3166-1 alpha-3 country code or state code.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The monetary amount of the most recent royalty payment remitted to the payee, in the obligation currency. Used for payment trend analysis and SAP FI accounts payable reconciliation.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Royalty Amount' ;
    rdfs:comment 'The minimum royalty payable per payment period regardless of production volume or commodity price, as stipulated in the royalty agreement or legislation. Ensures a floor payment to the royalty authority. Expressed in the obligation currency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Externally-known business identifier for the royalty obligation, used in SAP FI accounts payable and regulatory correspondence. Follows the format ROY-YYYY-NNNNNN.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle state of the royalty obligation. Active indicates payments are currently due; suspended indicates a temporary halt; terminated indicates the obligation has ended; pending indicates awaiting regulatory approval; under_review indicates a dispute or audit is in progress.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeName rdf:type rdf:Property ;
    rdfs:label 'Payee Name' ;
    rdfs:comment 'Legal name of the entity to whom royalties are payable, including government authorities, state mining departments, landowners, or native title holders. Used for SAP FI vendor master alignment and regulatory disclosure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payeeType rdf:type rdf:Property ;
    rdfs:label 'Payee Type' ;
    rdfs:comment 'Classification of the royalty payee entity. Government includes federal and state mining authorities; landowner refers to private surface or mineral rights holders; native title refers to indigenous land rights holders; joint_venture refers to JV partner royalty arrangements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDay rdf:type rdf:Property ;
    rdfs:label 'Payment Due Day' ;
    rdfs:comment 'The day of the month (1–31) by which royalty payments must be received by the payee following the end of the reporting period. Used to calculate payment due dates in SAP FI and manage cash flow planning.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceReference rdf:type rdf:Property ;
    rdfs:label 'Price Reference' ;
    rdfs:comment 'The commodity price reference used in ad valorem royalty calculations. LME spot uses the London Metal Exchange spot price; Platts index uses the relevant Platts commodity index; contract price uses the actual sales contract price; realized price uses the actual achieved price; benchmark price uses a government-set reference price.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVolumeBasis rdf:type rdf:Property ;
    rdfs:label 'Production Volume Basis' ;
    rdfs:comment 'The production measurement basis used to calculate royalties. ROM (Run of Mine) tonnes is the raw ore extracted; dry metric tonnes (DMT) and wet metric tonnes (WMT) are standard shipping measures; contained metal is used for metal-in-concentrate royalties; concentrate tonnes applies to processed product royalties.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rate Review Date' ;
    rdfs:comment 'The scheduled date on which the royalty rate is subject to review or renegotiation by the relevant authority or as stipulated in the royalty agreement. Critical for financial planning and OPEX forecasting.' ;
    rdfs:domain ind:RoyaltyObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the royalty rate. Percent_revenue applies to ad valorem royalties; per_tonne or per_dmt (dry metric tonne) or per_wmt (wet metric tonne) applies to specific/production-based royalties; percent_profit applies to profit-based royalties.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'The applicable royalty rate expressed as a decimal fraction (e.g., 0.075 for 7.5%). For ad valorem royalties this is a percentage of revenue; for specific royalties this is a rate per unit of production. Confidential as it reflects negotiated commercial terms.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyType rdf:type rdf:Property ;
    rdfs:label 'Royalty Type' ;
    rdfs:comment 'Classification of the royalty obligation by calculation methodology. Ad valorem is based on the value of production, specific is a fixed rate per unit of production, profit-based is derived from net profit, production-based is a flat rate per tonne, and hybrid combines multiple methods.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxObligationId rdf:type rdf:Property ;
    rdfs:label 'Tax Obligation Id' ;
    rdfs:comment 'Unique identifier for the tax obligation record. Primary key.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date on which the tax obligation was formally assessed or confirmed by the tax authority or internal tax team.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentTaxLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Current Tax Liability Amount' ;
    rdfs:comment 'Current tax liability amount for the reporting period, representing tax payable within 12 months.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxAssetAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Asset Amount' ;
    rdfs:comment 'Deferred tax asset balance arising from temporary differences, tax loss carryforwards, or unused tax credits.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Liability Amount' ;
    rdfs:comment 'Deferred tax liability balance arising from temporary differences between accounting and tax bases of assets and liabilities.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTaxRatePct rdf:type rdf:Property ;
    rdfs:label 'Effective Tax Rate Pct' ;
    rdfs:comment 'Effective tax rate percentage calculated as total tax expense divided by pre-tax income for the reporting period.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Interest charged on overdue tax obligations or interest earned on overpaid tax amounts.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Penalty amount levied by the tax authority for late payment, underpayment, or non-compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'External reference number or document number for this tax obligation as recorded in SAP FI or tax authority systems.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryTaxRatePct rdf:type rdf:Property ;
    rdfs:label 'Statutory Tax Rate Pct' ;
    rdfs:comment 'Statutory tax rate percentage applicable in the jurisdiction for this tax type.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Adjustment Amount' ;
    rdfs:comment 'Adjustment amount applied to the tax obligation due to prior period corrections, audit findings, or regulatory changes.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the tax authority or regulatory body to which this obligation is owed (e.g., Australian Taxation Office, Canada Revenue Agency).' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxInstalmentAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Instalment Amount' ;
    rdfs:comment 'Amount of tax paid as an instalment or advance payment during the reporting period.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxLossCarryforwardAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Loss Carryforward Amount' ;
    rdfs:comment 'Accumulated tax loss carryforward amount available to offset future taxable income in this jurisdiction.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReturnReference rdf:type rdf:Property ;
    rdfs:label 'Tax Return Reference' ;
    rdfs:comment 'Reference number of the tax return filing to which this obligation relates.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Type of tax obligation: income tax, resource rent tax (PRRT/MRRT), withholding tax, GST/VAT, royalty, excise, or payroll tax. [ENUM-REF-CANDIDATE: income_tax|resource_rent_tax|withholding_tax|gst|vat|royalty|excise|payroll_tax — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Income Amount' ;
    rdfs:comment 'Taxable income or tax base amount used to calculate the tax obligation for the reporting period.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Obligation Amount' ;
    rdfs:comment 'Total tax obligation amount including base tax, adjustments, penalties, and interest.' ;
    rdfs:domain ind:TaxObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Any early payment discount or negotiated discount applied to the invoice.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'The date the dispute was formally raised against this invoice.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionAction rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Action' ;
    rdfs:comment 'Description of the action taken to resolve the dispute (e.g., credit note issued, price adjustment, goods returned).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'The date the dispute was resolved and closed.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'The category of dispute raised against this invoice, if applicable.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The portion of the invoice amount that is under dispute.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The net invoice amount converted to the company\'s functional currency (typically USD or local currency).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number used for three-way matching, confirming physical receipt of goods or services.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Invoice Amount' ;
    rdfs:comment 'The total invoice amount before tax and adjustments.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice, as printed on the invoice document.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'A textual description of the goods or services covered by this invoice.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The unique invoice number assigned by the vendor for this invoice document.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current payment status of the invoice in the procure-to-pay cycle. [ENUM-REF-CANDIDATE: pending|approved|disputed|paid|partially paid|cancelled|on hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Invoice Amount' ;
    rdfs:comment 'The final payable amount after tax, discounts, and adjustments.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The total tax amount (GST, VAT, sales tax) applied to the invoice.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation between purchase order, goods receipt, and invoice.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Foreign key reference to the parent WBS element in the hierarchical structure. Null for top-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual date when work on this WBS element was completed. Null if work is still in progress. Used for project closure and lessons learned analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date when work commenced on this WBS element. Used for schedule variance analysis and project performance reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetUnderConstructionFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Under Construction Flag' ;
    rdfs:comment 'Boolean flag indicating whether costs posted to this WBS element are capitalized as an Asset Under Construction per IFRS 16 and IAS 16. True for CAPEX projects that will be settled to fixed assets, false for OPEX or expensed projects.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'The total value of purchase orders, contracts, and other commitments issued against this WBS element but not yet invoiced. Used for funds reservation and cash flow forecasting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentProgram rdf:type rdf:Property ;
    rdfs:label 'Investment Program' ;
    rdfs:comment 'The strategic investment program or portfolio to which this WBS element belongs (e.g., Mine Expansion 2024, Sustaining Capital FY25, Exploration Campaign Q3). Used for portfolio-level CAPEX tracking and NPV/IRR analysis.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jorcReserveCategory rdf:type rdf:Property ;
    rdfs:label 'Jorc Reserve Category' ;
    rdfs:comment 'The JORC Code reserve classification associated with the ore body or resource being developed by this project: proved (highest confidence), probable (lower confidence), or not_applicable for non-mining projects. Used for reserve reporting and SEC S-K 1300 compliance.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The scheduled completion date for this WBS element. Used for milestone tracking and LOM financial planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The scheduled start date for work on this WBS element, as defined in the project plan. Used for Life of Mine (LOM) scheduling and resource planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPlant rdf:type rdf:Property ;
    rdfs:label 'Planning Plant' ;
    rdfs:comment 'The SAP plant code representing the physical mine site, processing facility, or operational location where the work will be performed.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleExists rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Exists' ;
    rdfs:comment 'Boolean flag indicating whether a settlement rule has been configured to allocate costs from this WBS element to assets, cost centres, or other receivers. True if settlement is configured, false otherwise.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemStatus rdf:type rdf:Property ;
    rdfs:label 'System Status' ;
    rdfs:comment 'The SAP system-controlled status of the WBS element lifecycle: created (initial), released (active for posting), technically_completed (work finished but financially open), closed (final settlement complete), or locked (posting blocked).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userStatus rdf:type rdf:Property ;
    rdfs:label 'User Status' ;
    rdfs:comment 'User-defined status field for business-specific workflow states (e.g., awaiting_approval, in_execution, on_hold, under_review). Configurable per company requirements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Description' ;
    rdfs:comment 'Full business description of the WBS element, detailing the scope of work, deliverable, or project phase it represents.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementType rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Type' ;
    rdfs:comment 'Classification of the WBS element by its functional purpose: planning (for scheduling), account_assignment (for cost posting), billing (for revenue recognition), or statistical (for reporting only).' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'The hierarchical level of this WBS element within the project structure. Level 1 is the top-level project, subsequent levels represent sub-phases or work packages.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockModelId rdf:type rdf:Property ;
    rdfs:label 'Block Model Id' ;
    rdfs:comment 'Primary key for block_model' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockModel .

ind:primarySupersededByModelBlockModelId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Model Block Model Id' ;
    rdfs:comment 'Reference to the block model version that superseded this version. Null for active models. Enables version chain navigation.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockModel .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Approval status of this block model version. Indicates whether the model has been formally approved by the competent person and management for use in resource reporting and mine planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Data Cutoff Date' ;
    rdfs:comment 'Date up to which drilling and sampling data were included in this block model. Defines the temporal scope of input data.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:datum rdf:type rdf:Property ;
    rdfs:label 'Datum' ;
    rdfs:comment 'Geodetic datum used for the block model (e.g., \'GDA94\', \'WGS84\', \'NAD83\'). Defines the reference ellipsoid and origin for coordinate measurements.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimationSoftware rdf:type rdf:Property ;
    rdfs:label 'Estimation Software' ;
    rdfs:comment 'Software package used to create and populate the block model (e.g., \'Geovia GEMS 6.8\', \'Datamine Studio RM 1.8\', \'Leapfrog Geo 2023.1\').' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extentX rdf:type rdf:Property ;
    rdfs:label 'Extent X' ;
    rdfs:comment 'Total extent of the block model in the X direction (easting) in meters. Defines the overall model width.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extentY rdf:type rdf:Property ;
    rdfs:label 'Extent Y' ;
    rdfs:comment 'Total extent of the block model in the Y direction (northing) in meters. Defines the overall model length.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extentZ rdf:type rdf:Property ;
    rdfs:label 'Extent Z' ;
    rdfs:comment 'Total extent of the block model in the Z direction (elevation) in meters. Defines the overall model height.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyChangesSummary rdf:type rdf:Property ;
    rdfs:label 'Key Changes Summary' ;
    rdfs:comment 'Summary of key changes made in this version compared to the previous version. Provides context for version history and audit trail.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Unique business identifier or code for the block model, used for external reference and reporting (e.g., \'NPT_IO_2024_V3\', \'SCD_CU_2023_V1\').' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Business name of the block model instance, typically referencing the orebody or deposit name (e.g., \'North Pit Iron Ore Model\', \'South Copper Deposit Model\').' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle status of the block model instance. Active models are used for current planning and resource estimation; superseded models have been replaced by newer versions; archived models are retained for historical reference; draft models are under development; under_review models are pending validation; approved models have passed competent person sign-off.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originX rdf:type rdf:Property ;
    rdfs:label 'Origin X' ;
    rdfs:comment 'X-coordinate (easting) of the block model origin point in the specified coordinate system. Defines the southwest corner of the model grid.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originY rdf:type rdf:Property ;
    rdfs:label 'Origin Y' ;
    rdfs:comment 'Y-coordinate (northing) of the block model origin point in the specified coordinate system. Defines the southwest corner of the model grid.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originZ rdf:type rdf:Property ;
    rdfs:label 'Origin Z' ;
    rdfs:comment 'Z-coordinate (elevation) of the block model origin point in meters above the datum. Defines the base elevation of the model grid.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBlockSizeX rdf:type rdf:Property ;
    rdfs:label 'Parent Block Size X' ;
    rdfs:comment 'X-axis dimension (easting) of the parent block in meters. Defines the fundamental block size in the east-west direction.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBlockSizeY rdf:type rdf:Property ;
    rdfs:label 'Parent Block Size Y' ;
    rdfs:comment 'Y-axis dimension (northing) of the parent block in meters. Defines the fundamental block size in the north-south direction.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBlockSizeZ rdf:type rdf:Property ;
    rdfs:label 'Parent Block Size Z' ;
    rdfs:comment 'Z-axis dimension (elevation) of the parent block in meters. Defines the fundamental block size in the vertical direction.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotationAngle rdf:type rdf:Property ;
    rdfs:label 'Rotation Angle' ;
    rdfs:comment 'Rotation angle of the block model grid in degrees, measured clockwise from north. Used to align the model with the orebody strike direction.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subBlockConfiguration rdf:type rdf:Property ;
    rdfs:label 'Sub Block Configuration' ;
    rdfs:comment 'Description of the sub-blocking configuration if enabled (e.g., \'2x2x2\', \'4x4x4\', \'adaptive\'). Specifies how parent blocks are subdivided.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subBlockingEnabled rdf:type rdf:Property ;
    rdfs:label 'Sub Blocking Enabled' ;
    rdfs:comment 'Indicates whether sub-blocking (subdivision of parent blocks into smaller blocks) is enabled in this model to improve resolution at orebody boundaries and geological contacts.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date when this block model version was superseded by a newer version. Null for active models.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalBlockCount rdf:type rdf:Property ;
    rdfs:label 'Total Block Count' ;
    rdfs:comment 'Total number of blocks (parent and sub-blocks) in the block model. Used for model size assessment and computational planning.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updateReason rdf:type rdf:Property ;
    rdfs:label 'Update Reason' ;
    rdfs:comment 'Primary reason for creating this new version of the block model (e.g., new drilling data, geological reinterpretation, methodology change, data correction, resource update, mine depletion). [ENUM-REF-CANDIDATE: new_drilling|geological_reinterpretation|methodology_change|data_correction|resource_update|mine_depletion|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDate rdf:type rdf:Property ;
    rdfs:label 'Version Date' ;
    rdfs:comment 'Effective date of this block model version. Represents the date from which this version is considered current for resource reporting and mine planning.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Version Identifier' ;
    rdfs:comment 'Version number or identifier for this block model instance (e.g., \'V1\', \'V2.1\', \'2024.03\'). Used to track model evolution and updates.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when this block model version was created. Used for version control and audit trail.' ;
    rdfs:domain ind:BlockModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockModelCellId rdf:type rdf:Property ;
    rdfs:label 'Block Model Cell Id' ;
    rdfs:comment 'Unique identifier for the block model cell. Primary key for the block model cell entity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockModelCell .

ind:geologicalDomainId rdf:type rdf:Property ;
    rdfs:label 'Geological Domain Id' ;
    rdfs:comment 'Foreign key linking to geology.geological_domain. Business justification: Block model cells are classified into geological domains for resource estimation. The cell currently stores geological_domain_code as a STRING; this should be normalized to a FK to geological_domain.g' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeologicalDomain .

ind:geologicalUnitId rdf:type rdf:Property ;
    rdfs:label 'Geological Unit Id' ;
    rdfs:comment 'Foreign key linking to geology.geological_unit. Business justification: block_model_cell currently has lithology_code and rock_type as STRING attributes. These are denormalized references to the geological_unit reference catalog. Adding geological_unit_id FK normalizes th' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeologicalUnit .

ind:pitDesignId rdf:type rdf:Property ;
    rdfs:label 'Pit Design Id' ;
    rdfs:comment 'Identifier of the optimized pit shell that contains this block. Used for open pit mine planning and scheduling. Links to pit optimization scenarios.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PitDesign .

ind:blockDimensionX rdf:type rdf:Property ;
    rdfs:label 'Block Dimension X' ;
    rdfs:comment 'Width of the block in the X direction (easting) measured in meters. Defines the block size in the east-west dimension.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockDimensionY rdf:type rdf:Property ;
    rdfs:label 'Block Dimension Y' ;
    rdfs:comment 'Length of the block in the Y direction (northing) measured in meters. Defines the block size in the north-south dimension.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockDimensionZ rdf:type rdf:Property ;
    rdfs:label 'Block Dimension Z' ;
    rdfs:comment 'Height of the block in the Z direction (elevation) measured in meters. Defines the vertical block size.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Block Volume M3' ;
    rdfs:comment 'Volume of the block in cubic meters. Calculated as the product of block dimensions (X * Y * Z) and used for tonnage calculations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidX rdf:type rdf:Property ;
    rdfs:label 'Centroid X' ;
    rdfs:comment 'X coordinate of the block centroid in the mine coordinate system (easting). Represents the center point of the block in the east-west direction.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidY rdf:type rdf:Property ;
    rdfs:label 'Centroid Y' ;
    rdfs:comment 'Y coordinate of the block centroid in the mine coordinate system (northing). Represents the center point of the block in the north-south direction.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidZ rdf:type rdf:Property ;
    rdfs:label 'Centroid Z' ;
    rdfs:comment 'Z coordinate of the block centroid representing elevation or depth below surface. Vertical position of the block center in the mine coordinate system.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutOffGradeApplied rdf:type rdf:Property ;
    rdfs:label 'Cut Off Grade Applied' ;
    rdfs:comment 'The minimum economic grade threshold applied to classify this block as ore or waste. Critical parameter for resource-to-reserve conversion and mine planning optimization.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:densityTPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density T Per M3' ;
    rdfs:comment 'Bulk density of the block material measured in tonnes per cubic meter. Used to convert block volume to tonnage for resource estimation.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimationPass rdf:type rdf:Property ;
    rdfs:label 'Estimation Pass' ;
    rdfs:comment 'The estimation pass number during which this block was populated. Multi-pass estimation uses progressively relaxed search parameters to fill all blocks.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gradeAuGPerT rdf:type rdf:Property ;
    rdfs:label 'Grade Au G Per T' ;
    rdfs:comment 'Estimated gold (Au) grade within the block expressed in grams per tonne. Critical for precious metal deposits and by-product recovery.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeCoalAshPct rdf:type rdf:Property ;
    rdfs:label 'Grade Coal Ash Pct' ;
    rdfs:comment 'Estimated ash content percentage for coal blocks. Key quality parameter for coal deposits affecting market value and processing requirements.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeCoalSulfurPct rdf:type rdf:Property ;
    rdfs:label 'Grade Coal Sulfur Pct' ;
    rdfs:comment 'Estimated sulfur content percentage for coal blocks. Environmental and quality parameter affecting coal marketability and emissions.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeCuPpm rdf:type rdf:Property ;
    rdfs:label 'Grade Cu Ppm' ;
    rdfs:comment 'Estimated copper (Cu) grade within the block expressed in parts per million (ppm). Used for copper and polymetallic deposits.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeFePct rdf:type rdf:Property ;
    rdfs:label 'Grade Fe Pct' ;
    rdfs:comment 'Estimated iron (Fe) grade within the block expressed as a percentage. Primary commodity grade for iron ore deposits.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeLiPpm rdf:type rdf:Property ;
    rdfs:label 'Grade Li Ppm' ;
    rdfs:comment 'Estimated lithium (Li) grade within the block expressed in parts per million (ppm). Used for lithium brine and hard rock deposits.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeNiPct rdf:type rdf:Property ;
    rdfs:label 'Grade Ni Pct' ;
    rdfs:comment 'Estimated nickel (Ni) grade within the block expressed as a percentage. Primary commodity grade for nickel deposits.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:krigingVariance rdf:type rdf:Property ;
    rdfs:label 'Kriging Variance' ;
    rdfs:comment 'Statistical variance from kriging estimation for this block. Measure of estimation uncertainty and confidence in the grade estimate.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:miningMethodFlag rdf:type rdf:Property ;
    rdfs:label 'Mining Method Flag' ;
    rdfs:comment 'Planned or applicable mining method for extracting this block. Values include open_pit, underground, SLC (Sub-Level Caving), block_cave, longwall (coal), room_pillar, not_applicable. [ENUM-REF-CANDIDATE: open_pit|underground|slc|block_cave|longwall|room_pillar|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:miningPhase rdf:type rdf:Property ;
    rdfs:label 'Mining Phase' ;
    rdfs:comment 'Planned mining phase or stage in which this block is scheduled for extraction. Used for Life of Mine (LOM) planning and sequencing.' ;
    rdfs:domain ind:BlockModelCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the block model. Tracks model updates and revisions over time as new geological data becomes available.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreWasteClassification rdf:type rdf:Property ;
    rdfs:label 'Ore Waste Classification' ;
    rdfs:comment 'Classification of the block as ore, waste, or intermediate material based on cut-off grade criteria. Drives mine planning and scheduling decisions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRecoveryFactor rdf:type rdf:Property ;
    rdfs:label 'Processing Recovery Factor' ;
    rdfs:comment 'Expected metallurgical recovery factor representing the proportion of valuable mineral that can be recovered during processing. Modifying factor applied during reserve conversion.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceCategory rdf:type rdf:Property ;
    rdfs:label 'Resource Category' ;
    rdfs:comment 'JORC/NI 43-101 resource classification category for this block. Reflects confidence level in the geological and grade continuity: measured (highest confidence), indicated (moderate confidence), inferred (lowest confidence), unclassified (insufficient data).' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkDensity rdf:type rdf:Property ;
    rdfs:label 'Bulk Density' ;
    rdfs:comment 'Average bulk density of the rock within this domain in tonnes per cubic meter. Used to convert volume to tonnage for resource estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:domainCode rdf:type rdf:Property ;
    rdfs:label 'Domain Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the domain in geological models and block models. Typically used in Geovia GEMS domain coding workflows.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainName rdf:type rdf:Property ;
    rdfs:label 'Domain Name' ;
    rdfs:comment 'Descriptive name of the geological domain that conveys its geological or spatial characteristics (e.g., High Grade Core, Oxide Zone, Supergene Enrichment).' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainType rdf:type rdf:Property ;
    rdfs:label 'Domain Type' ;
    rdfs:comment 'Classification of the domain based on the geological characteristic used to define its boundary: lithological (rock type), structural (fault/fold), alteration (hydrothermal), grade (metal concentration), oxidation (weathering), or mineralization (ore type).' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Domain Volume M3' ;
    rdfs:comment 'Total volume of the geological domain in cubic meters, calculated from the 3D wireframe boundary. Used for tonnage estimation.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimationConstraintType rdf:type rdf:Property ;
    rdfs:label 'Estimation Constraint Type' ;
    rdfs:comment 'Defines how the domain boundary constrains grade interpolation during resource estimation. Hard boundary prevents grade estimation across the boundary; soft boundary allows limited influence; transitional allows gradual transition.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologicalDomainStatus rdf:type rdf:Property ;
    rdfs:label 'Geological Domain Status' ;
    rdfs:comment 'Current lifecycle status of the domain definition. Active domains are used in current resource models; superseded domains have been replaced by updated interpretations; archived domains are retained for historical reference.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeVariance rdf:type rdf:Property ;
    rdfs:label 'Grade Variance' ;
    rdfs:comment 'Statistical variance of grade values within the domain. Indicates grade heterogeneity and informs estimation strategy.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumSampleCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Sample Count' ;
    rdfs:comment 'Maximum number of assay samples used in a single block grade estimation. Prevents over-smoothing and maintains local variability.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSampleCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Sample Count' ;
    rdfs:comment 'Minimum number of assay samples required within the search ellipsoid to estimate a block grade. Ensures statistical reliability of estimates.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchEllipsoidAzimuthDeg rdf:type rdf:Property ;
    rdfs:label 'Search Ellipsoid Azimuth Deg' ;
    rdfs:comment 'Azimuth angle in degrees (0-360) defining the orientation of the major axis of the search ellipsoid used in kriging. Typically aligned with geological strike.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchEllipsoidDipDeg rdf:type rdf:Property ;
    rdfs:label 'Search Ellipsoid Dip Deg' ;
    rdfs:comment 'Dip angle in degrees (-90 to +90) defining the plunge of the major axis of the search ellipsoid. Typically aligned with orebody dip.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchEllipsoidPlungeDeg rdf:type rdf:Property ;
    rdfs:label 'Search Ellipsoid Plunge Deg' ;
    rdfs:comment 'Plunge angle in degrees (0-360) defining the rotation of the search ellipsoid around the major axis. Used for complex 3D orientations.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramModelType rdf:type rdf:Property ;
    rdfs:label 'Variogram Model Type' ;
    rdfs:comment 'Type of geostatistical variogram model used to characterize spatial continuity of grades within this domain. Used in kriging interpolation.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variogramNuggetEffect rdf:type rdf:Property ;
    rdfs:label 'Variogram Nugget Effect' ;
    rdfs:comment 'Proportion of total variance attributed to micro-scale variability and measurement error. Expressed as a ratio (0 to 1). Higher values indicate greater short-range variability.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeMajorM rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Major M' ;
    rdfs:comment 'Maximum range of spatial continuity in the major axis direction (typically along strike or longest dimension) in meters. Defines search ellipsoid for kriging.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeMinorM rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Minor M' ;
    rdfs:comment 'Minimum range of spatial continuity in the minor axis direction (typically vertical or shortest dimension) in meters.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeSemiMajorM rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Semi Major M' ;
    rdfs:comment 'Range of spatial continuity in the semi-major axis direction (typically across strike or intermediate dimension) in meters.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramSill rdf:type rdf:Property ;
    rdfs:label 'Variogram Sill' ;
    rdfs:comment 'Total variance of the grade population within the domain. Represents the plateau value that the variogram approaches at large distances.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireframeReference rdf:type rdf:Property ;
    rdfs:label 'Wireframe Reference' ;
    rdfs:comment 'Reference to the 3D wireframe surface file or object in the geological modeling system (Geovia GEMS, Leapfrog, Vulcan) that defines the spatial boundary of this domain.' ;
    rdfs:domain ind:GeologicalDomain ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colourCodeHex rdf:type rdf:Property ;
    rdfs:label 'Colour Code Hex' ;
    rdfs:comment 'Hexadecimal colour code used for visualisation of the geological unit in cross-sections, block models, and GIS maps. Ensures consistent colour representation across all geological visualisations.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colourCodeRgb rdf:type rdf:Property ;
    rdfs:label 'Colour Code Rgb' ;
    rdfs:comment 'RGB colour code (comma-separated R,G,B values 0-255) for the geological unit. Alternative colour representation for systems that do not support hexadecimal codes.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityGCm3 rdf:type rdf:Property ;
    rdfs:label 'Density G Cm3' ;
    rdfs:comment 'Average bulk density of the geological unit in grams per cubic centimetre. Used for tonnage calculations in resource estimation and block modelling.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionalEnvironment rdf:type rdf:Property ;
    rdfs:label 'Depositional Environment' ;
    rdfs:comment 'Geological environment in which the unit was originally deposited or formed (e.g., marine, fluvial, volcanic, intrusive, metamorphic). Provides genetic context for the unit.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologicalAge rdf:type rdf:Property ;
    rdfs:label 'Geological Age' ;
    rdfs:comment 'Geological age or epoch of the unit (e.g., Proterozoic, Archean, Permian, Jurassic). Provides temporal context for the formation of the unit and aids in regional correlation.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geologicalUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Geological Unit Status' ;
    rdfs:comment 'Current lifecycle status of the geological unit in the enterprise geological model. Active units are in current use; deprecated units have been superseded by revised geological interpretations.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalDomain rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Domain' ;
    rdfs:comment 'Geotechnical domain code or name to which this geological unit is assigned. Links geological units to rock mass strength, stability, and slope design parameters.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardnessClassification rdf:type rdf:Property ;
    rdfs:label 'Hardness Classification' ;
    rdfs:comment 'Relative hardness classification of the geological unit. Influences drilling rates, blasting design, and comminution energy requirements in mineral processing.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreBearingFlag rdf:type rdf:Property ;
    rdfs:label 'Ore Bearing Flag' ;
    rdfs:comment 'Boolean indicator of whether the geological unit is known to host economic mineralisation. True if the unit is part of the ore body definition; false if it is waste rock or gangue.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentFormation rdf:type rdf:Property ;
    rdfs:label 'Parent Formation' ;
    rdfs:comment 'Name of the parent geological formation or group to which this unit belongs. Establishes hierarchical stratigraphic relationships (e.g., a member within a formation, a sub-unit within a larger intrusive complex).' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMineralogy rdf:type rdf:Property ;
    rdfs:label 'Primary Mineralogy' ;
    rdfs:comment 'Comma-separated list of the dominant minerals present in the geological unit (e.g., quartz, feldspar, biotite, magnetite, hematite, chalcopyrite). Critical for understanding ore-forming processes and metallurgical behaviour.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDomain rdf:type rdf:Property ;
    rdfs:label 'Processing Domain' ;
    rdfs:comment 'Mineral processing domain or metallurgical type to which this geological unit is assigned (e.g., oxide, transitional, sulphide, high-grade, low-grade). Determines processing route and recovery method.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Percent' ;
    rdfs:comment 'Typical metallurgical recovery rate (percentage of valuable mineral extracted) for ore from this geological unit. Used in resource-to-reserve conversion and economic modelling. Nullable for non-ore units.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralSetting rdf:type rdf:Property ;
    rdfs:label 'Structural Setting' ;
    rdfs:comment 'Description of the structural geological context of the unit (e.g., footwall, hanging wall, fault zone, fold limb, shear zone). Critical for understanding ore body geometry and mining method selection.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalGradeRange rdf:type rdf:Property ;
    rdfs:label 'Typical Grade Range' ;
    rdfs:comment 'Typical range of metal grades observed in this geological unit (e.g., 0.5-1.2% Cu, 55-62% Fe). Provides context for grade control and cut-off grade decisions. Nullable for non-ore units.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the geological unit across all mine sites. Used consistently in drillhole logging, block model coding, and grade control. Sourced from Geovia GEMS formation tables.' ;
    rdfs:domain ind:GeologicalUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full formal name of the geological unit (e.g., lithological formation, stratigraphic member, intrusive phase, alteration assemblage, weathering horizon). Human-readable identifier used in geological reports and cross-section interpretation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the geological unit by its primary geological nature: lithological (rock type), stratigraphic (formation/member), structural (fault/fold zone), alteration (hydrothermal/metamorphic assemblage), weathering (oxidation/supergene horizon), or intrusive (igneous phase).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatheringState rdf:type rdf:Property ;
    rdfs:label 'Weathering State' ;
    rdfs:comment 'Degree of weathering or oxidation of the geological unit. Influences geotechnical properties, ore recovery rates, and processing methods (oxide vs. sulphide ore).' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geostatisticalRunId rdf:type rdf:Property ;
    rdfs:label 'Geostatistical Run Id' ;
    rdfs:comment 'Unique identifier for the geostatistical estimation run. Primary key. Role: MASTER_RESOURCE (specialized analytical resource representing a parameterized estimation execution).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compositeLengthMetres rdf:type rdf:Property ;
    rdfs:label 'Composite Length Metres' ;
    rdfs:comment 'Length in metres of the composited intervals used in the estimation (e.g., 1.0m, 2.0m, 5.0m). Null if variable length compositing was used.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compositingMethod rdf:type rdf:Property ;
    rdfs:label 'Compositing Method' ;
    rdfs:comment 'Method used to composite drill hole assay intervals prior to estimation (e.g., fixed length, bench composite, geological composite).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalBias rdf:type rdf:Property ;
    rdfs:label 'Conditional Bias' ;
    rdfs:comment 'Measure of systematic over- or under-estimation in the kriging results, calculated from cross-validation (values near zero indicate unbiased estimation).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatedKrigingVarianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Indicated Kriging Variance Threshold' ;
    rdfs:comment 'Maximum kriging variance threshold for blocks to be classified as Indicated Resource. Null if kriging variance not used for classification.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:krigingEfficiency rdf:type rdf:Property ;
    rdfs:label 'Kriging Efficiency' ;
    rdfs:comment 'Ratio of kriging variance to total variance, measuring the effectiveness of the kriging estimator (values closer to 1.0 indicate better efficiency).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumSamples rdf:type rdf:Property ;
    rdfs:label 'Maximum Samples' ;
    rdfs:comment 'Maximum number of composite samples used in the kriging neighbourhood to estimate a block grade, limiting computational load and over-smoothing.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumSamplesPerDrillhole rdf:type rdf:Property ;
    rdfs:label 'Maximum Samples Per Drillhole' ;
    rdfs:comment 'Maximum number of samples allowed from a single drill hole in the kriging neighbourhood to avoid clustering bias.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measuredKrigingVarianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Measured Kriging Variance Threshold' ;
    rdfs:comment 'Maximum kriging variance threshold for blocks to be classified as Measured Resource. Null if kriging variance not used for classification.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSamples rdf:type rdf:Property ;
    rdfs:label 'Minimum Samples' ;
    rdfs:comment 'Minimum number of composite samples required within the search ellipsoid to estimate a block grade. Blocks with fewer samples remain unestimated.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resourceClassificationMethod rdf:type rdf:Property ;
    rdfs:label 'Resource Classification Method' ;
    rdfs:comment 'Method used to assign JORC resource classification categories (Measured, Indicated, Inferred) to estimated blocks (e.g., kriging variance thresholds, search pass, data spacing).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'Date on which the geostatistical estimation run was executed.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name or label assigned to this geostatistical run for identification and reference purposes (e.g., \'Q4_2023_FE_Main_Orebody_OK\').' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the geostatistical run indicating its stage in the estimation and approval workflow. [ENUM-REF-CANDIDATE: draft|in_progress|completed|validated|approved|rejected|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchEllipseMajorMetres rdf:type rdf:Property ;
    rdfs:label 'Search Ellipse Major Metres' ;
    rdfs:comment 'Radius of the search ellipsoid along the major axis in metres, defining the maximum search distance for sample selection during kriging.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchEllipseMinorMetres rdf:type rdf:Property ;
    rdfs:label 'Search Ellipse Minor Metres' ;
    rdfs:comment 'Radius of the search ellipsoid along the minor axis in metres.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchEllipseSemiMajorMetres rdf:type rdf:Property ;
    rdfs:label 'Search Ellipse Semi Major Metres' ;
    rdfs:comment 'Radius of the search ellipsoid along the semi-major axis in metres.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:searchPassCount rdf:type rdf:Property ;
    rdfs:label 'Search Pass Count' ;
    rdfs:comment 'Number of search passes executed with progressively relaxed search parameters to ensure all blocks are estimated (e.g., 1st pass strict, 2nd pass expanded).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slopeOfRegression rdf:type rdf:Property ;
    rdfs:label 'Slope Of Regression' ;
    rdfs:comment 'Slope of the regression line between estimated block grades and true sample grades from cross-validation, indicating estimation accuracy (ideal value near 1.0).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareName rdf:type rdf:Property ;
    rdfs:label 'Software Name' ;
    rdfs:comment 'Name of the geostatistical software package used to execute this run (e.g., Geovia GEMS, Datamine Studio, Leapfrog Geo, Surpac).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the geostatistical software used, ensuring reproducibility and audit compliance.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topCutGrade rdf:type rdf:Property ;
    rdfs:label 'Top Cut Grade' ;
    rdfs:comment 'Upper grade threshold applied to composite samples to cap extreme high values and reduce the influence of outliers on the estimate. Null if no top cut applied.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramAzimuthDegrees rdf:type rdf:Property ;
    rdfs:label 'Variogram Azimuth Degrees' ;
    rdfs:comment 'Azimuth rotation angle in degrees (0-360) defining the orientation of the major axis of the variogram ellipsoid in the horizontal plane.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramDipDegrees rdf:type rdf:Property ;
    rdfs:label 'Variogram Dip Degrees' ;
    rdfs:comment 'Dip angle in degrees (-90 to +90) defining the vertical inclination of the major axis of the variogram ellipsoid.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramNugget rdf:type rdf:Property ;
    rdfs:label 'Variogram Nugget' ;
    rdfs:comment 'Nugget effect value representing short-range variability or measurement error in the variogram model (dimensionless variance component).' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramPlungeDegrees rdf:type rdf:Property ;
    rdfs:label 'Variogram Plunge Degrees' ;
    rdfs:comment 'Plunge rotation angle in degrees defining the third rotation axis of the variogram ellipsoid for full 3D orientation.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeMajorMetres rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Major Metres' ;
    rdfs:comment 'Range of spatial continuity along the major axis of the variogram ellipsoid in metres, representing the maximum distance of grade correlation.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeMinorMetres rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Minor Metres' ;
    rdfs:comment 'Range of spatial continuity along the minor axis of the variogram ellipsoid in metres, typically representing the shortest correlation distance.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variogramRangeSemiMajorMetres rdf:type rdf:Property ;
    rdfs:label 'Variogram Range Semi Major Metres' ;
    rdfs:comment 'Range of spatial continuity along the semi-major (intermediate) axis of the variogram ellipsoid in metres.' ;
    rdfs:domain ind:GeostatisticalRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotechnicalLogId rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Log Id' ;
    rdfs:comment 'Unique identifier for the geotechnical log record. Primary key for downhole geotechnical and physical property measurements from diamond drillhole core.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laboratoryId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Id' ;
    rdfs:comment 'Identifier of the laboratory facility that performed the geotechnical testing and density measurements. Used for QAQC traceability and inter-laboratory comparison.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:coreRecoveryPercent rdf:type rdf:Property ;
    rdfs:label 'Core Recovery Percent' ;
    rdfs:comment 'Percentage of core recovered from the drilled interval, calculated as (recovered core length / drilled interval length) × 100. Critical indicator of rock quality and drilling conditions.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Source system from which this geotechnical log record was extracted. Typically Geovia GEMS for geological logging or LabWare LIMS for laboratory density and strength testing results.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:densityMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Density Measurement Method' ;
    rdfs:comment 'Laboratory method used to determine density and specific gravity. Water immersion is standard for competent core; wax-coated method used for porous or friable samples; pycnometer for fine material.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryBulkDensity rdf:type rdf:Property ;
    rdfs:label 'Dry Bulk Density' ;
    rdfs:comment 'Dry bulk density of the core sample in tonnes per cubic meter, measured after oven-drying to constant mass. Primary density value for resource tonnage calculations.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fractureFrequency rdf:type rdf:Property ;
    rdfs:label 'Fracture Frequency' ;
    rdfs:comment 'Number of natural fractures, joints, or discontinuities per meter of core. Key parameter for rock mass characterization and ground support design.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geomechanicalDomain rdf:type rdf:Property ;
    rdfs:label 'Geomechanical Domain' ;
    rdfs:comment 'Geomechanical domain classification code representing zones of similar rock mass behavior. Used to group rock masses with consistent geotechnical properties for slope stability and stope design modeling.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'Moisture content of the sample at time of measurement, calculated as ((wet mass - dry mass) / dry mass) × 100. Used to convert between wet and dry density values.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointLoadIndexMpa rdf:type rdf:Property ;
    rdfs:label 'Point Load Index Mpa' ;
    rdfs:comment 'Point Load Strength Index corrected to 50mm diameter equivalent (Is50) in megapascals. Field-based rock strength indicator used to estimate UCS when core testing is not available.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:porosityPercent rdf:type rdf:Property ;
    rdfs:label 'Porosity Percent' ;
    rdfs:comment 'Porosity of the rock sample expressed as percentage of void space to total volume. Influences density, strength, and fluid flow characteristics.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qIndex rdf:type rdf:Property ;
    rdfs:label 'Q Index' ;
    rdfs:comment 'Tunneling Quality Index (Q-system) per Barton et al. (1974). Logarithmic rock mass classification calculated from RQD, joint set number, joint roughness, joint alteration, water reduction factor, and stress reduction factor. Used for underground excavation support design.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaqcFlag rdf:type rdf:Property ;
    rdfs:label 'Qaqc Flag' ;
    rdfs:comment 'Free-text quality control flag or comment describing any data quality issues, anomalies, or validation failures identified during QAQC review. Empty if no issues detected.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmrRating rdf:type rdf:Property ;
    rdfs:label 'Rmr Rating' ;
    rdfs:comment 'Rock Mass Rating classification value (0-100 scale) per Bieniawski (1989). Composite geomechanical classification integrating rock strength, RQD, discontinuity spacing, condition, groundwater, and orientation. Used for ground support design.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificGravity rdf:type rdf:Property ;
    rdfs:label 'Specific Gravity' ;
    rdfs:comment 'Specific gravity of the rock sample, representing the ratio of sample density to water density. Measured using water immersion, wax-coated, or pycnometer methods.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the geotechnical laboratory testing was performed. Critical for temporal QAQC analysis and data vintage tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ucsMpa rdf:type rdf:Property ;
    rdfs:label 'Ucs Mpa' ;
    rdfs:comment 'Unconfined Compressive Strength of intact rock measured in megapascals (MPa). Laboratory-determined strength of rock under uniaxial compression, critical for pit slope and stope design.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetBulkDensity rdf:type rdf:Property ;
    rdfs:label 'Wet Bulk Density' ;
    rdfs:comment 'Wet bulk density of the core sample in tonnes per cubic meter, measured at natural moisture content. Used for in-situ tonnage estimation and comparison with dry density.' ;
    rdfs:domain ind:GeotechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeControlSampleId rdf:type rdf:Property ;
    rdfs:label 'Grade Control Sample Id' ;
    rdfs:comment 'Unique identifier for the grade control sample record. Primary key for the grade control sample entity.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blastPatternId rdf:type rdf:Property ;
    rdfs:label 'Blast Pattern Id' ;
    rdfs:comment 'Identifier of the blast pattern from which the sample was collected. Links grade control samples to specific drilling and blasting operations for reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlastPattern .

ind:drillRigAssetId rdf:type rdf:Property ;
    rdfs:label 'Drill Rig Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Grade control sampling operations must track which drill rig collected each sample for sample integrity verification, QAQC traceability, and correlation of sample quality with equipment performance. C' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:geologistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Geologist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Grade control decisions (ore/waste classification) require geologist sign-off for production accountability and reconciliation. Links enable competency verification, production variance analysis, and ' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:laboratorySampleId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Sample Id' ;
    rdfs:comment 'Foreign key linking to laboratory.laboratory_sample. Business justification: Grade control samples are collected from production drilling/blasting and sent to laboratory for assay. Links mining execution to laboratory analysis for ore/waste classification and production reconc' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaboratorySample .

ind:productionDrillholeId rdf:type rdf:Property ;
    rdfs:label 'Production Drillhole Id' ;
    rdfs:comment 'Identifier of the specific blast hole or drill hole from which the sample was collected. Used for blast hole samples to link back to drilling operations.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionDrillhole .

ind:al2o3Percent rdf:type rdf:Property ;
    rdfs:label 'Al2o3 Percent' ;
    rdfs:comment 'Assayed alumina content of the sample expressed as a percentage. Key deleterious element for iron ore quality and processing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assay Completion Date' ;
    rdfs:comment 'Date when the laboratory completed the assay analysis and reported results. Used to track turnaround time and operational delays.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assayMethod rdf:type rdf:Property ;
    rdfs:label 'Assay Method' ;
    rdfs:comment 'Analytical method used for sample assay. Examples include XRF (X-Ray Fluorescence), fire assay, ICP-MS (Inductively Coupled Plasma Mass Spectrometry), AAS (Atomic Absorption Spectroscopy). Critical for quality control and data validation.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auGPerT rdf:type rdf:Property ;
    rdfs:label 'Au G Per T' ;
    rdfs:comment 'Assayed gold content of the sample expressed in grams per tonne. Critical commodity grade for gold operations and by-product recovery.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bench rdf:type rdf:Property ;
    rdfs:label 'Bench' ;
    rdfs:comment 'Identifier of the mining bench or level where the sample was collected. Benches are horizontal working surfaces in open pit mines, typically designated by elevation (e.g., 450RL, 440RL).' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockModelGrade rdf:type rdf:Property ;
    rdfs:label 'Block Model Grade' ;
    rdfs:comment 'Predicted grade from the long-term geological block model for the spatial location of this sample. Used for model-versus-actual reconciliation to assess geological model accuracy.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Date and time when the grade control sample was physically collected in the field during mining operations. Critical for temporal reconciliation and operational sequencing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cuPpm rdf:type rdf:Property ;
    rdfs:label 'Cu Ppm' ;
    rdfs:comment 'Assayed copper content of the sample expressed in parts per million. Key commodity grade for copper operations.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:easting rdf:type rdf:Property ;
    rdfs:label 'Easting' ;
    rdfs:comment 'East-west spatial coordinate of the sample location in the mine grid coordinate system, typically in meters. Used for GIS mapping and spatial reconciliation against the geological block model.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationRl rdf:type rdf:Property ;
    rdfs:label 'Elevation Rl' ;
    rdfs:comment 'Vertical elevation of the sample location relative to a defined datum, typically in meters above sea level. RL (Reduced Level) is the mining industry standard term for elevation.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fePercent rdf:type rdf:Property ;
    rdfs:label 'Fe Percent' ;
    rdfs:comment 'Assayed iron content of the sample expressed as a percentage of total mass. Primary commodity grade for iron ore operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geologistSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Geologist Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the grade control geologist formally validated and signed off on the sample data and classification. Critical for operational approval workflow.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name or identifier of the laboratory that performed the assay analysis. May be on-site laboratory or external commercial laboratory.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDestination rdf:type rdf:Property ;
    rdfs:label 'Material Destination' ;
    rdfs:comment 'Designated destination for the material represented by this sample based on grade control classification. Crusher for direct processing, ROM (Run of Mine) pad for temporary storage before processing, stockpile for longer-term ore storage, waste dump for sub-economic material.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:miningBlock rdf:type rdf:Property ;
    rdfs:label 'Mining Block' ;
    rdfs:comment 'Short-term mining block identifier representing the operational dig unit. Mining blocks are subdivisions of the pit used for daily to weekly mine planning and grade control.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:northing rdf:type rdf:Property ;
    rdfs:label 'Northing' ;
    rdfs:comment 'North-south spatial coordinate of the sample location in the mine grid coordinate system, typically in meters. Used for GIS mapping and spatial reconciliation against the geological block model.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreType rdf:type rdf:Property ;
    rdfs:label 'Ore Type' ;
    rdfs:comment 'Geological classification of the ore type based on mineralogy, lithology, and processing characteristics. Examples include hematite, magnetite, banded iron formation, oxide copper, sulfide copper, free-milling gold. Used for material routing and processing decisions. [ENUM-REF-CANDIDATE: hematite|magnetite|goethite|bif|oxide_cu|sulfide_cu|transitional_cu|free_milling_au|refractory_au — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pPercent rdf:type rdf:Property ;
    rdfs:label 'P Percent' ;
    rdfs:comment 'Assayed phosphorus content of the sample expressed as a percentage. Critical deleterious element for steel-making iron ore quality.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this sample has been included in formal mine-to-model reconciliation reporting. True indicates the sample has been reconciled, false indicates pending reconciliation.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sPercent rdf:type rdf:Property ;
    rdfs:label 'S Percent' ;
    rdfs:comment 'Assayed sulfur content of the sample expressed as a percentage. Key deleterious element for iron ore and copper concentrate quality.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleIntervalFrom rdf:type rdf:Property ;
    rdfs:label 'Sample Interval From' ;
    rdfs:comment 'Starting depth of the sample interval in meters, measured from the collar of the hole. Used for blast hole and channel samples to define the vertical extent of the sample.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleIntervalTo rdf:type rdf:Property ;
    rdfs:label 'Sample Interval To' ;
    rdfs:comment 'Ending depth of the sample interval in meters, measured from the collar of the hole. Used for blast hole and channel samples to define the vertical extent of the sample.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Sample Weight Kg' ;
    rdfs:comment 'Weight of the collected sample in kilograms. Used for quality control and to ensure representative sample mass for laboratory analysis.' ;
    rdfs:domain ind:GradeControlSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sio2Percent rdf:type rdf:Property ;
    rdfs:label 'Sio2 Percent' ;
    rdfs:comment 'Assayed silica content of the sample expressed as a percentage. Key deleterious element for iron ore quality and processing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithologyLogId rdf:type rdf:Property ;
    rdfs:label 'Lithology Log Id' ;
    rdfs:comment 'Unique identifier for the lithological logging record. Primary key for the lithology log entity.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loggingGeologistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Logging Geologist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Geological logging is a regulated activity requiring competent person sign-off for JORC/NI 43-101 compliance. Linking to employee enables competency verification, training currency checks, and audit t' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:intervalFromDepthM rdf:type rdf:Property ;
    rdfs:label 'Interval From Depth M' ;
    rdfs:comment 'Starting depth of the logged interval measured in metres from the drill hole collar. Defines the top boundary of the lithological unit being described.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalLengthM rdf:type rdf:Property ;
    rdfs:label 'Interval Length M' ;
    rdfs:comment 'Length of the logged interval in metres, calculated as the difference between to_depth and from_depth. Represents the thickness of the lithological unit.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalToDepthM rdf:type rdf:Property ;
    rdfs:label 'Interval To Depth M' ;
    rdfs:comment 'Ending depth of the logged interval measured in metres from the drill hole collar. Defines the bottom boundary of the lithological unit being described.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mineralisationType rdf:type rdf:Property ;
    rdfs:label 'Mineralisation Type' ;
    rdfs:comment 'Style or morphology of mineralisation observed in the interval. Critical for understanding ore body geometry and grade distribution.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMineral rdf:type rdf:Property ;
    rdfs:label 'Primary Mineral' ;
    rdfs:comment 'Dominant mineral species observed in the interval. Represents the most abundant mineral constituent of the rock unit.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcComments rdf:type rdf:Property ;
    rdfs:label 'Qaqc Comments' ;
    rdfs:comment 'Comments or notes from the quality control review process. Documents any issues, corrections, or validation decisions made during QAQC review.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rockTypeCode rdf:type rdf:Property ;
    rdfs:label 'Rock Type Code' ;
    rdfs:comment 'Standardized code representing the primary rock type observed in this interval (e.g., GRAN for granite, BAS for basalt, SEDS for sedimentary). Used for geological classification and modeling.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rockTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Rock Type Description' ;
    rdfs:comment 'Detailed textual description of the rock type including lithological characteristics, composition, and geological interpretation. Provides full context beyond the standardized code.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryMineral rdf:type rdf:Property ;
    rdfs:label 'Secondary Mineral' ;
    rdfs:comment 'Second most abundant mineral species observed in the interval. Provides additional mineralogical context for geological interpretation.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structure rdf:type rdf:Property ;
    rdfs:label 'Structure' ;
    rdfs:comment 'Structural features observed in the interval including bedding, foliation, jointing, veining, or other geological structures. Important for geotechnical and structural geological interpretation.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulphidePercent rdf:type rdf:Property ;
    rdfs:label 'Sulphide Percent' ;
    rdfs:comment 'Visual estimate of sulphide mineral content as percentage of the interval. Important for ore grade estimation and metallurgical characterisation.' ;
    rdfs:domain ind:LithologyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidElevationM rdf:type rdf:Property ;
    rdfs:label 'Centroid Elevation M' ;
    rdfs:comment 'Elevation above sea level of the orebody centroid in meters. Used for mine planning, haulage design, and hydrological modeling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containedMetalKt rdf:type rdf:Property ;
    rdfs:label 'Contained Metal Kt' ;
    rdfs:comment 'Estimated quantity of contained metal or commodity in the orebody in thousand tonnes. Calculated as tonnage multiplied by average grade.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Cutoff Grade Unit' ;
    rdfs:comment 'Unit of measure for the cut-off grade (e.g., percent for iron ore, grams per tonne for gold). Ensures correct interpretation of grade thresholds.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depletionDate rdf:type rdf:Property ;
    rdfs:label 'Depletion Date' ;
    rdfs:comment 'Actual or forecast date when economically recoverable reserves in this orebody will be exhausted. Critical for mine closure planning.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositStyle rdf:type rdf:Property ;
    rdfs:label 'Deposit Style' ;
    rdfs:comment 'Geological classification of the deposit type. Defines the genetic model and controls exploration, mining method selection, and metallurgical processing approach. [ENUM-REF-CANDIDATE: porphyry|vms|bif|sedimentary|epithermal|skarn|iocg|laterite|pegmatite|orogenic|carlin — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitivity' ;
    rdfs:comment 'Assessment of environmental sensitivity and regulatory constraints affecting this orebody. Influences permitting, mine design, and closure planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstProductionDate rdf:type rdf:Property ;
    rdfs:label 'First Production Date' ;
    rdfs:comment 'Date when commercial ore extraction from this orebody commenced. Marks transition from development to production phase.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geologicalModelDate rdf:type rdf:Property ;
    rdfs:label 'Geological Model Date' ;
    rdfs:comment 'Date when the current geological model version was finalized and approved. Supports audit trail for resource and reserve reporting.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geologicalModelVersion rdf:type rdf:Property ;
    rdfs:label 'Geological Model Version' ;
    rdfs:comment 'Version identifier of the current geological block model from which this orebody definition is derived. Tracks model updates and resource estimate revisions.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostLithology rdf:type rdf:Property ;
    rdfs:label 'Host Lithology' ;
    rdfs:comment 'Primary rock type or lithological unit hosting the mineralisation. Influences geotechnical properties, mining method, and processing characteristics.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metallurgicalDomain rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Domain' ;
    rdfs:comment 'Metallurgical domain classification based on processing characteristics and recovery performance. Drives processing plant design and recovery assumptions.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orebodyCode rdf:type rdf:Property ;
    rdfs:label 'Orebody Code' ;
    rdfs:comment 'Business identifier code for the orebody used across geological modeling, mine planning, and resource reporting systems. Externally known reference code.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orebodyName rdf:type rdf:Property ;
    rdfs:label 'Orebody Name' ;
    rdfs:comment 'Human-readable name of the orebody or mineralised zone, typically reflecting geographic location, discovery history, or geological characteristics.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orebodyStatus rdf:type rdf:Property ;
    rdfs:label 'Orebody Status' ;
    rdfs:comment 'Current lifecycle status of the orebody from exploration through to depletion. Drives investment decisions and operational planning. [ENUM-REF-CANDIDATE: exploration|resource_defined|reserve_declared|in_production|depleted|suspended|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spatialExtentAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Spatial Extent Area Sqm' ;
    rdfs:comment 'Horizontal surface area extent of the orebody footprint in square meters. Derived from GIS spatial analysis of geological model boundaries.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralControl rdf:type rdf:Property ;
    rdfs:label 'Structural Control' ;
    rdfs:comment 'Description of the structural geological features (faults, folds, shear zones) that control the geometry and extent of mineralisation. Informs geological modeling and mine design.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnageEstimateMt rdf:type rdf:Property ;
    rdfs:label 'Tonnage Estimate Mt' ;
    rdfs:comment 'Estimated total tonnage of mineralised material in the orebody in million tonnes. Represents the scale of the resource and drives LOM planning.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalExtentM rdf:type rdf:Property ;
    rdfs:label 'Vertical Extent M' ;
    rdfs:comment 'Maximum vertical thickness or depth extent of the orebody from top to bottom in meters. Influences mining method selection and pit depth or underground level design.' ;
    rdfs:domain ind:Orebody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:azimuth rdf:type rdf:Property ;
    rdfs:label 'Azimuth' ;
    rdfs:comment 'Planned azimuth (bearing) of the drillhole at collar, measured in degrees from 0 to 360, where 0/360 is north, 90 is east, 180 is south, and 270 is west. Used to define hole trajectory.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coreDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Core Diameter Mm' ;
    rdfs:comment 'Diameter of the drill core or bit size in millimeters. Common sizes include HQ (63.5mm), NQ (47.6mm), PQ (85mm) for diamond drilling, or bit diameter for RC/RAB drilling.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dip rdf:type rdf:Property ;
    rdfs:label 'Dip' ;
    rdfs:comment 'Planned dip (inclination) of the drillhole at collar, measured in degrees from -90 (vertically down) to +90 (vertically up). Negative values indicate downward drilling. Used to define hole trajectory.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillerName rdf:type rdf:Property ;
    rdfs:label 'Driller Name' ;
    rdfs:comment 'Name of the lead driller or drilling supervisor responsible for executing the drillhole. Used for quality control and performance tracking.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillingContractor rdf:type rdf:Property ;
    rdfs:label 'Drilling Contractor' ;
    rdfs:comment 'Name of the drilling contractor company that executed the drillhole. Used for quality control, performance tracking, and contractor management.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holeType rdf:type rdf:Property ;
    rdfs:label 'Hole Type' ;
    rdfs:comment 'Type of drilling method used: RC (Reverse Circulation), Diamond (core drilling), RAB (Rotary Air Blast), AC (Air Core), Rotary, or Percussion.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAssayed rdf:type rdf:Property ;
    rdfs:label 'Is Assayed' ;
    rdfs:comment 'Boolean flag indicating whether samples from this drillhole have been submitted to the laboratory and assay results received. True if assayed, False if not yet assayed.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSurveyed rdf:type rdf:Property ;
    rdfs:label 'Is Surveyed' ;
    rdfs:comment 'Boolean flag indicating whether downhole survey measurements have been completed to determine actual hole trajectory. True if surveyed, False if not yet surveyed.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jorcCategory rdf:type rdf:Property ;
    rdfs:label 'Jorc Category' ;
    rdfs:comment 'JORC resource classification category that this drillhole contributes to: Measured (highest confidence), Indicated (moderate confidence), Inferred (lowest confidence), Exploration (pre-resource), or Non-JORC (not used in resource estimation).' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDepth rdf:type rdf:Property ;
    rdfs:label 'Total Depth' ;
    rdfs:comment 'Total depth drilled from collar, measured in meters along the hole trajectory. Represents the final depth achieved before completion or abandonment.' ;
    rdfs:domain ind:ProductionDrillhole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionDrillholeSurveyId rdf:type rdf:Property ;
    rdfs:label 'Production Drillhole Survey Id' ;
    rdfs:comment 'Unique identifier for the drillhole survey record. Primary key for the production drillhole survey entity.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyRunId rdf:type rdf:Property ;
    rdfs:label 'Survey Run Id' ;
    rdfs:comment 'Identifier for the survey run or batch in which this measurement was captured. Multiple survey points may be captured in a single survey run down the hole.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyRun .

ind:azimuthDegrees rdf:type rdf:Property ;
    rdfs:label 'Azimuth Degrees' ;
    rdfs:comment 'Horizontal direction of the drillhole at this survey point, measured in degrees clockwise from true north (0-360). Used to calculate the 3D trajectory of the hole.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Correction Applied Flag' ;
    rdfs:comment 'Boolean indicator of whether magnetic declination, temperature, or other correction factors have been applied to the raw survey measurements. True indicates corrected data, false indicates raw uncorrected data.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctionFactor rdf:type rdf:Property ;
    rdfs:label 'Correction Factor' ;
    rdfs:comment 'Numerical correction factor applied to the raw survey measurements to account for magnetic declination, instrument drift, or environmental interference. Null if no correction was applied.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depthMetres rdf:type rdf:Property ;
    rdfs:label 'Depth Metres' ;
    rdfs:comment 'Measured depth down the drillhole from the collar at which this survey reading was taken, expressed in metres. Critical for spatial positioning of all downhole data.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dipDegrees rdf:type rdf:Property ;
    rdfs:label 'Dip Degrees' ;
    rdfs:comment 'Vertical inclination of the drillhole at this survey point, measured in degrees from horizontal. Negative values indicate downward inclination, positive values indicate upward inclination. Typically ranges from -90 (vertical down) to +90 (vertical up).' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eastingCoordinate rdf:type rdf:Property ;
    rdfs:label 'Easting Coordinate' ;
    rdfs:comment 'Calculated easting (X) coordinate of this survey point in the mine coordinate system, derived from collar position and survey trajectory. Used for 3D spatial positioning in GIS and block models.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gravityFieldStrength rdf:type rdf:Property ;
    rdfs:label 'Gravity Field Strength' ;
    rdfs:comment 'Measured gravitational field strength at this survey point, expressed in g-units. Used by gyroscopic instruments for orientation reference.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:magneticDipAngle rdf:type rdf:Property ;
    rdfs:label 'Magnetic Dip Angle' ;
    rdfs:comment 'Angle of the local magnetic field relative to horizontal, measured in degrees. Used for magnetic survey correction and quality validation.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:northingCoordinate rdf:type rdf:Property ;
    rdfs:label 'Northing Coordinate' ;
    rdfs:comment 'Calculated northing (Y) coordinate of this survey point in the mine coordinate system, derived from collar position and survey trajectory. Used for 3D spatial positioning in GIS and block models.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyInstrument rdf:type rdf:Property ;
    rdfs:label 'Survey Instrument' ;
    rdfs:comment 'Specific make and model of the survey instrument used to capture this reading (e.g., Reflex EZ-TRAC, Gyrodata MGTS). Important for quality assurance and data validation.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Sequence Number' ;
    rdfs:comment 'Sequential order number of this survey measurement within the drillhole. Used to order survey points from collar to end-of-hole.' ;
    rdfs:domain ind:ProductionDrillholeSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Downhole temperature at this survey point, measured in degrees Celsius. High temperatures can affect instrument accuracy and require correction factors.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousStatementResourceStatementId rdf:type rdf:Property ;
    rdfs:label 'Previous Statement Resource Statement Id' ;
    rdfs:comment 'Reference to the previous version of the resource statement that this statement supersedes, enabling version tracking and reconciliation.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResourceStatement .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Explanation of the reason for changes from the previous resource statement (e.g., new drilling data, updated geological model, revised economic assumptions, depletion from mining).' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentPersonMembership rdf:type rdf:Property ;
    rdfs:label 'Competent Person Membership' ;
    rdfs:comment 'Professional body membership of the Competent Person (e.g., AusIMM, CIM, SACNASP) that qualifies them to sign off on this statement.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicAssumptionsSummary rdf:type rdf:Property ;
    rdfs:label 'Economic Assumptions Summary' ;
    rdfs:comment 'Summary of key economic assumptions used in reserve conversion, including commodity price, exchange rate, operating cost, and capital cost assumptions.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeValue rdf:type rdf:Property ;
    rdfs:label 'Grade Value' ;
    rdfs:comment 'Average grade of the primary commodity in the resource or reserve, expressed in the unit specified in grade_unit.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the resource statement was publicly disclosed or filed with regulatory authorities.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statementCode rdf:type rdf:Property ;
    rdfs:label 'Statement Code' ;
    rdfs:comment 'Unique business identifier code for the resource statement, typically used in external reporting and regulatory filings.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementName rdf:type rdf:Property ;
    rdfs:label 'Statement Name' ;
    rdfs:comment 'Descriptive name of the resource statement, typically including orebody name and reporting period.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementStatus rdf:type rdf:Property ;
    rdfs:label 'Statement Status' ;
    rdfs:comment 'Current lifecycle status of the resource statement in the approval and publication workflow.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementType rdf:type rdf:Property ;
    rdfs:label 'Statement Type' ;
    rdfs:comment 'Type of statement: Mineral Resource only, Ore Reserve only, or Combined Resource and Reserve statement.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnageMt rdf:type rdf:Property ;
    rdfs:label 'Tonnage Mt' ;
    rdfs:comment 'Total tonnage of mineral resource or ore reserve in million tonnes (Mt) for this classification category.' ;
    rdfs:domain ind:ResourceStatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Structural Measurement Id' ;
    rdfs:comment 'Unique identifier for the structural measurement record. Primary key.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alphaAngle rdf:type rdf:Property ;
    rdfs:label 'Alpha Angle' ;
    rdfs:comment 'The alpha angle representing the orientation of the structural feature relative to the drill hole axis, used in oriented core analysis.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:betaAngle rdf:type rdf:Property ;
    rdfs:label 'Beta Angle' ;
    rdfs:comment 'The beta angle representing the orientation of the structural feature relative to the drill hole axis, used in oriented core analysis.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'The classification level of this structural measurement data for information security and access control purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dipDirection rdf:type rdf:Property ;
    rdfs:label 'Dip Direction' ;
    rdfs:comment 'The azimuth direction in which the structural feature dips, measured in degrees from north (0-360).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevation rdf:type rdf:Property ;
    rdfs:label 'Elevation' ;
    rdfs:comment 'The elevation of the measurement location in meters above mean sea level.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featureDescription rdf:type rdf:Property ;
    rdfs:label 'Feature Description' ;
    rdfs:comment 'Detailed textual description of the structural feature including characteristics such as thickness, infill material, surface texture, and any other relevant observations.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureThickness rdf:type rdf:Property ;
    rdfs:label 'Feature Thickness' ;
    rdfs:comment 'The measured thickness of the structural feature in millimeters (e.g., vein width, fault gouge thickness).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geomechanicalSignificance rdf:type rdf:Property ;
    rdfs:label 'Geomechanical Significance' ;
    rdfs:comment 'Assessment of the geomechanical significance of the structural feature for pit slope design and ground stability analysis.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infillMaterial rdf:type rdf:Property ;
    rdfs:label 'Infill Material' ;
    rdfs:comment 'Description of the material filling the structural feature (e.g., quartz, calcite, clay, gouge).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDepthFrom rdf:type rdf:Property ;
    rdfs:label 'Measurement Depth From' ;
    rdfs:comment 'The starting depth in meters down the drill hole where the structural feature was measured. Null for surface measurements.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDepthTo rdf:type rdf:Property ;
    rdfs:label 'Measurement Depth To' ;
    rdfs:comment 'The ending depth in meters down the drill hole where the structural feature was measured. Null for surface measurements.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The source from which the structural measurement was obtained (drillhole core, surface mapping, underground mapping, outcrop, or trench).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mineralisationAssociation rdf:type rdf:Property ;
    rdfs:label 'Mineralisation Association' ;
    rdfs:comment 'Indicates whether the structural feature is associated with mineralisation, critical for understanding structural controls on ore bodies.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCode rdf:type rdf:Property ;
    rdfs:label 'Quality Code' ;
    rdfs:comment 'Quality assessment of the structural measurement based on exposure quality, measurement accuracy, and confidence.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roughness rdf:type rdf:Property ;
    rdfs:label 'Roughness' ;
    rdfs:comment 'Qualitative assessment of the surface roughness of the structural feature, important for geomechanical modeling.' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strike rdf:type rdf:Property ;
    rdfs:label 'Strike' ;
    rdfs:comment 'The compass direction of a horizontal line on the plane of the structural feature, measured in degrees from north (0-360).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structuralFeatureType rdf:type rdf:Property ;
    rdfs:label 'Structural Feature Type' ;
    rdfs:comment 'The type of structural geological feature being measured (fault, fold, joint, shear zone, vein, or foliation).' ;
    rdfs:domain ind:StructuralMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireframeId rdf:type rdf:Property ;
    rdfs:label 'Wireframe Id' ;
    rdfs:comment 'Unique identifier for the geological wireframe record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wireframe .

ind:parentWireframeId rdf:type rdf:Property ;
    rdfs:label 'Parent Wireframe Id' ;
    rdfs:comment 'Reference to a parent or containing wireframe in hierarchical geological models. For example, a sub-domain wireframe may reference its parent orebody envelope wireframe.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wireframe .

ind:validatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Wireframe validation requires competent person sign-off for resource estimation and mine planning. Links enable competency verification for JORC/NI 43-101 compliance and audit trails for geological mo' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:centroidEasting rdf:type rdf:Property ;
    rdfs:label 'Centroid Easting' ;
    rdfs:comment 'Easting coordinate of the geometric centroid (centre of mass) of the wireframe. Used for spatial indexing and proximity analysis.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidElevationRl rdf:type rdf:Property ;
    rdfs:label 'Centroid Elevation Rl' ;
    rdfs:comment 'Elevation (reduced level) of the geometric centroid (centre of mass) of the wireframe in metres. Used for spatial indexing and 3D analysis.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidNorthing rdf:type rdf:Property ;
    rdfs:label 'Centroid Northing' ;
    rdfs:comment 'Northing coordinate of the geometric centroid (centre of mass) of the wireframe. Used for spatial indexing and proximity analysis.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creationMethod rdf:type rdf:Property ;
    rdfs:label 'Creation Method' ;
    rdfs:comment 'The methodology or technique used to construct the wireframe. Manual interpretation involves geologist-driven section-by-section digitization. Implicit modelling uses algorithmic interpolation from drill data. Explicit modelling involves direct construction from known boundaries. Kriging, triangulation, and digitization represent specific technical approaches.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpretationConfidence rdf:type rdf:Property ;
    rdfs:label 'Interpretation Confidence' ;
    rdfs:comment 'Geologist\'s assessment of confidence in the wireframe interpretation based on data density, geological complexity, and structural understanding. High confidence indicates dense drill spacing and clear geological boundaries. Low confidence indicates sparse data or complex geology requiring further investigation.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClosedSolid rdf:type rdf:Property ;
    rdfs:label 'Is Closed Solid' ;
    rdfs:comment 'Boolean flag indicating whether the wireframe is a closed solid (true) or an open surface (false). Closed solids are required for volume calculations and block model domain coding.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumElevationRl rdf:type rdf:Property ;
    rdfs:label 'Maximum Elevation Rl' ;
    rdfs:comment 'Highest elevation (reduced level) of the wireframe in metres. Defines the top extent of the geological feature or orebody envelope.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumElevationRl rdf:type rdf:Property ;
    rdfs:label 'Minimum Elevation Rl' ;
    rdfs:comment 'Lowest elevation (reduced level) of the wireframe in metres. Defines the bottom extent of the geological feature or orebody envelope.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modellingSoftware rdf:type rdf:Property ;
    rdfs:label 'Modelling Software' ;
    rdfs:comment 'Name and version of the geological modelling software used to create the wireframe (e.g., Geovia GEMS, Hexagon MinePlan, Leapfrog, Surpac, Vulcan). Critical for reproducibility and audit trail.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionZone rdf:type rdf:Property ;
    rdfs:label 'Projection Zone' ;
    rdfs:comment 'The map projection zone or grid zone identifier (e.g., UTM Zone 50S, MGA Zone 51). Provides additional spatial context for coordinate transformation.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Result of automated quality assurance checks on the wireframe geometry (e.g., checks for self-intersecting triangles, inverted normals, gaps, overlaps). Passed indicates the wireframe meets technical quality standards.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Surface Area Sqm' ;
    rdfs:comment 'Total surface area of the wireframe in square metres. For solid wireframes, represents the external surface area. For surface wireframes, represents the area of the surface itself. Used for volume calculations and spatial analysis.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triangleCount rdf:type rdf:Property ;
    rdfs:label 'Triangle Count' ;
    rdfs:comment 'Number of triangular facets or polygons that compose the wireframe mesh. Indicates the level of detail and complexity of the wireframe geometry.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation and approval status of the wireframe. Draft indicates initial construction, under review indicates peer review in progress, validated indicates technical QA complete, approved indicates competent person sign-off, superseded indicates replaced by newer version, archived indicates historical record only.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vertexCount rdf:type rdf:Property ;
    rdfs:label 'Vertex Count' ;
    rdfs:comment 'Number of vertices (points) that define the wireframe mesh. Higher vertex counts indicate finer resolution and more detailed geometry.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume M3' ;
    rdfs:comment 'Total volume enclosed by the wireframe in cubic metres. Applicable only to solid (closed) wireframes. Critical for tonnage estimation and mine planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireframeCode rdf:type rdf:Property ;
    rdfs:label 'Wireframe Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier used to reference the wireframe in geological databases and mine planning software.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireframeName rdf:type rdf:Property ;
    rdfs:label 'Wireframe Name' ;
    rdfs:comment 'Business name or label assigned to the wireframe for identification and reference in geological models and mine planning systems.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wireframeType rdf:type rdf:Property ;
    rdfs:label 'Wireframe Type' ;
    rdfs:comment 'Classification of the wireframe geometry type. Solid represents 3D closed volumes (orebody envelopes), surface represents 2D boundaries, DTM (Digital Terrain Model) represents topographic surfaces, fault represents structural discontinuities, contact represents lithological boundaries, and alteration represents geochemical or mineralogical zones.' ;
    rdfs:domain ind:Wireframe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Primary key for audit' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:auditedStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Audited Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Community engagement audits and social performance audits assess relationships with specific stakeholder groups (indigenous communities, local villages). Audit scope often focuses on particular stakeh' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:legalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Legal Register Id' ;
    rdfs:comment 'Foreign key linking to hse.legal_register. Business justification: HSE audits often verify compliance with specific legal and regulatory requirements. Audit records should link to the legal obligations being assessed, creating traceability between audit findings and ' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalRegister .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the audit or inspection was completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the audit or inspection commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:areaInspected rdf:type rdf:Property ;
    rdfs:label 'Area Inspected' ;
    rdfs:comment 'Specific operational area, department, or location within the site that was inspected (e.g., underground mine, processing plant, tailings storage facility).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier or reference number assigned to the audit or inspection for tracking and reporting purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Description of the scope of the audit or inspection, including the processes, areas, or management system elements covered.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit or inspection activity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Discriminator indicating the nature of the assessment: internal audit, external audit, certification audit (ISO 45001, ISO 14001), regulatory compliance audit, ICMM performance audit, or workplace inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization conducting the audit (internal department, third-party certification body, regulatory agency).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date on which the issued certification expires and requires renewal or recertification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the certification was issued, if the audit resulted in certification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the accredited certification body conducting the certification audit, if applicable (e.g., for ISO 45001, ISO 14001).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Certification Outcome' ;
    rdfs:comment 'Outcome of the certification audit, if applicable (certified, not certified, conditional certification, surveillance passed, recertification passed).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistUsed rdf:type rdf:Property ;
    rdfs:label 'Checklist Used' ;
    rdfs:comment 'Identifier or name of the audit checklist or inspection form used during the assessment.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformanceCount rdf:type rdf:Property ;
    rdfs:label 'Conformance Count' ;
    rdfs:comment 'Number of conformances (areas meeting requirements) identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which corrective actions must be completed to address audit findings.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalPermitVerified rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Verified' ;
    rdfs:comment 'Indicates whether environmental permit conditions were verified during the audit or inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentInspected rdf:type rdf:Property ;
    rdfs:label 'Equipment Inspected' ;
    rdfs:comment 'Description or identifier of specific equipment or assets inspected during the assessment (e.g., haul truck, conveyor, ventilation system).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Planned frequency of the inspection or audit (e.g., daily, weekly, monthly, quarterly, annual, ad-hoc).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor or inspector responsible for conducting the assessment.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformance Count' ;
    rdfs:comment 'Number of major non-conformances (critical failures to meet requirements) identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformanceCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformance Count' ;
    rdfs:comment 'Number of minor non-conformances (less critical failures to meet requirements) identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of observations (opportunities for improvement that are not non-conformances) identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppeComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Verified' ;
    rdfs:comment 'Indicates whether personal protective equipment compliance was verified during the inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal audit or inspection report document.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date on which the formal audit or inspection report was issued to stakeholders.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the audit or inspection to commence.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'Reference to the standard or regulatory framework against which the audit or inspection was conducted (e.g., ISO 45001:2018, ISO 14001:2015, MSHA 30 CFR Part 56).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of names or identifiers of additional auditors or inspectors participating in the assessment.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings (conformances, non-conformances, observations) identified during the audit or inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service to every chemical substance described in the open scientific literature.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'Common or trade name of the hazardous chemical or substance as used in operations (e.g., Sodium Cyanide, Sulphuric Acid, Xanthate, ANFO).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Chemical Register Status' ;
    rdfs:comment 'Current lifecycle status of the chemical in the register (active = currently in use, inactive = no longer used but may have residual inventory, restricted = use limited by permit or policy, phased_out = scheduled for elimination, pending_approval = awaiting regulatory or management approval).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalType rdf:type rdf:Property ;
    rdfs:label 'Chemical Type' ;
    rdfs:comment 'Classification of the chemical based on its primary use or function in mining operations. [ENUM-REF-CANDIDATE: reagent|explosive_precursor|fuel|solvent|acid|base|oxidizer|process_chemical — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentInventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Inventory Quantity' ;
    rdfs:comment 'Current quantity of the chemical on hand at the site, as of the last inventory count or system update.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyContactNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Number' ;
    rdfs:comment '24-hour emergency contact phone number for the chemical supplier or emergency response service (e.g., CHEMTREC, supplier hotline).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Notes' ;
    rdfs:comment 'Free-text notes describing known or potential environmental impacts of the chemical, including aquatic toxicity, persistence, bioaccumulation, or soil contamination risks.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstRegisteredDate rdf:type rdf:Property ;
    rdfs:label 'First Registered Date' ;
    rdfs:comment 'Date when the chemical was first registered in the site chemical register.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ghsClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification' ;
    rdfs:comment 'Hazard classification code(s) according to the GHS standard (e.g., Acute Toxicity Category 2, Corrosive to Metals Category 1, Environmental Hazard Acute Category 1).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsPictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Ghs Pictogram Codes' ;
    rdfs:comment 'Comma-separated list of GHS pictogram codes representing hazard symbols (e.g., GHS05 for Corrosion, GHS06 for Skull and Crossbones, GHS09 for Environment).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Handling Procedure Reference' ;
    rdfs:comment 'Reference number or title of the Standard Operating Procedure (SOP) governing safe handling, use, and storage of this chemical.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Hazard Statement Codes' ;
    rdfs:comment 'Comma-separated list of H-codes describing the nature of hazards (e.g., H290 May be corrosive to metals, H314 Causes severe skin burns and eye damage, H400 Very toxic to aquatic life).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthHazardSummary rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Summary' ;
    rdfs:comment 'Summary of primary health hazards associated with exposure to this chemical (e.g., Corrosive to skin and eyes, Respiratory irritant, Carcinogen Category 1A, Acute toxicity if ingested).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleMaterials rdf:type rdf:Property ;
    rdfs:label 'Incompatible Materials' ;
    rdfs:comment 'List of materials or chemical classes that must not be stored or mixed with this chemical due to risk of dangerous reactions (e.g., Strong oxidizers, Acids, Alkalis, Water-reactive substances).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the maximum inventory quantity (e.g., kilograms, litres, tonnes, cubic metres, units).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when the chemical register entry was last reviewed for accuracy and compliance.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumInventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Inventory Quantity' ;
    rdfs:comment 'Maximum quantity of the chemical permitted to be stored on site at any time, as defined by permit conditions or internal risk assessments.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory review of this chemical register entry.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Reference Number' ;
    rdfs:comment 'Reference number of the environmental or operational permit authorizing the use or storage of this chemical at the site.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Mandatory personal protective equipment required when handling this chemical (e.g., Chemical-resistant gloves, Face shield, Respirator with organic vapor cartridge, Acid-resistant apron).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatementCodes rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement Codes' ;
    rdfs:comment 'Comma-separated list of P-codes describing recommended measures to minimize or prevent adverse effects (e.g., P280 Wear protective gloves, P305+P351+P338 IF IN EYES rinse cautiously with water).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Flag' ;
    rdfs:comment 'Indicates whether the chemical quantity exceeds regulatory reporting thresholds (e.g., EPCRA Section 312 Tier II, state environmental reporting).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryThresholdType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Type' ;
    rdfs:comment 'Description of the specific regulatory threshold or reporting requirement triggered (e.g., EPCRA Tier II Reporting, State Hazardous Substance Inventory).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Document control number or identifier for the current Safety Data Sheet (formerly MSDS) on file for this chemical.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most recent revision of the Safety Data Sheet for this chemical.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageAreaType rdf:type rdf:Property ;
    rdfs:label 'Storage Area Type' ;
    rdfs:comment 'Classification of the storage facility based on its design and environmental controls.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit number that identifies hazardous substances in the framework of international transport (e.g., UN1789 for Hydrochloric Acid).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usagePurpose rdf:type rdf:Property ;
    rdfs:label 'Usage Purpose' ;
    rdfs:comment 'Description of the primary operational purpose or process for which the chemical is used (e.g., Gold leaching, Flotation reagent, Blasting agent, Equipment lubrication, Dust suppression).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Waste Classification Code' ;
    rdfs:comment 'Regulatory waste classification code for disposal purposes (e.g., EPA Hazardous Waste Code, Basel Convention Code).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key reference to the HSE incident that triggered this corrective action, if applicable. Null if action was triggered by audit, inspection, or risk assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Foreign key reference to the incident investigation that identified this corrective action requirement. Null if not investigation-derived.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:managementOfChangeId rdf:type rdf:Property ;
    rdfs:label 'Management Of Change Id' ;
    rdfs:comment 'Foreign key linking to hse.management_of_change. Business justification: Corrective actions may be triggered by Management of Change processes, particularly from PSSR (Pre-Startup Safety Review) findings, MOC risk assessments, or post-implementation reviews. CAPAs should l' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagementOfChange .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Corrective actions assign accountability to specific employees for completion tracking, escalation, and performance metrics. Current responsible_owner is denormalized text; FK enables workforce integr' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplyMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Supply Material Master Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_master. Business justification: Corrective actions for material quality issues, handling procedure updates, or storage requirement changes require material master linkage for material-specific improvement tracking, quality managemen' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name of the individual with authority who formally closed the corrective action after confirming effectiveness.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationRequired rdf:type rdf:Property ;
    rdfs:label 'Communication Required' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action requires formal communication to workforce, contractors, or external stakeholders (True) or is internal only (False).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed narrative description of the corrective or preventive action to be taken, including specific steps, controls to be implemented, and expected outcomes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the corrective action successfully addressed the root cause and prevented recurrence: effective (fully resolved), partially_effective (some improvement), ineffective (issue persists), not_yet_assessed (awaiting review period).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled date for follow-up review to assess the long-term effectiveness of the corrective action, typically 30-90 days after implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hierarchyOfControls rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Of Controls' ;
    rdfs:comment 'Classification of the corrective action according to the hierarchy of controls framework: elimination (remove hazard), substitution (replace with less hazardous), engineering (isolate people from hazard), administrative (change work procedures), PPE (Personal Protective Equipment - last resort).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimActionTaken rdf:type rdf:Property ;
    rdfs:label 'Interim Action Taken' ;
    rdfs:comment 'Description of any immediate interim or temporary controls implemented while the permanent corrective action is being developed and executed.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the corrective action based on risk severity and business impact: critical (immediate action required), high (urgent), medium (standard timeline), low (routine).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action addresses a recurring issue (True) or a first-time occurrence (False). Used to identify systemic problems requiring deeper intervention.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteLocation rdf:type rdf:Property ;
    rdfs:label 'Site Location' ;
    rdfs:comment 'Mine site, processing plant, or facility location where the corrective action is to be implemented.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdated rdf:type rdf:Property ;
    rdfs:label 'Sop Updated' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action resulted in updates to Standard Operating Procedures (True) or not (False).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceTriggerType rdf:type rdf:Property ;
    rdfs:label 'Source Trigger Type' ;
    rdfs:comment 'Type of event or activity that triggered the creation of this corrective action: incident (actual HSE event), investigation (formal inquiry), audit (compliance review), inspection (routine check), risk_assessment (hazard identification), observation (safety observation), complaint (stakeholder concern), near_miss (potential incident). [ENUM-REF-CANDIDATE: incident|investigation|audit|inspection|risk_assessment|observation|complaint|near_miss — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Boolean flag indicating whether implementation of this corrective action requires workforce training or competency development (True) or not (False).' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assemblyPointPrimary rdf:type rdf:Property ;
    rdfs:label 'Assembly Point Primary' ;
    rdfs:comment 'Primary designated assembly point location where personnel should gather during an emergency evacuation.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyPointSecondary rdf:type rdf:Property ;
    rdfs:label 'Assembly Point Secondary' ;
    rdfs:comment 'Secondary or alternate assembly point location to be used if the primary assembly point is compromised or inaccessible.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Compliance Status' ;
    rdfs:comment 'Current compliance status of emergency drill frequency against regulatory and corporate requirements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillFrequencyRequiredMonths rdf:type rdf:Property ;
    rdfs:label 'Drill Frequency Required Months' ;
    rdfs:comment 'Required frequency for emergency drills or exercises in months, as mandated by regulation or corporate policy.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyContactPrimary rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Primary' ;
    rdfs:comment 'Primary emergency contact person and phone number for this plan, typically the site emergency coordinator or incident controller.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactSecondary rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Secondary' ;
    rdfs:comment 'Secondary or backup emergency contact person and phone number for this plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentResources rdf:type rdf:Property ;
    rdfs:label 'Equipment Resources' ;
    rdfs:comment 'List of emergency equipment and resources required for this plan, including location, quantity, and maintenance status (e.g., self-rescuers, fire extinguishers, spill kits, medical supplies).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyContacts rdf:type rdf:Property ;
    rdfs:label 'External Agency Contacts' ;
    rdfs:comment 'Contact details for external emergency response agencies including fire brigade, ambulance, police, environmental protection, and mine rescue services.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDrillDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory emergency drill or exercise for this plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the emergency response plan, identifying the scenario or scope covered.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the specific regulatory requirement or standard that mandates this emergency response plan (e.g., MSHA 30 CFR Part 49, ISO 45001 Clause 8.2).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseProcedures rdf:type rdf:Property ;
    rdfs:label 'Response Procedures' ;
    rdfs:comment 'Detailed step-by-step response procedures to be followed when the emergency scenario occurs, including immediate actions, escalation protocols, and containment measures.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Summary of changes made in the current version of the emergency response plan, documenting updates, corrections, or enhancements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCategory rdf:type rdf:Property ;
    rdfs:label 'Scenario Category' ;
    rdfs:comment 'Primary emergency scenario category that this plan addresses, aligned with mining-specific hazards.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed description of the emergency scenario, including triggering conditions, potential impacts, and scope of the emergency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Notification Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Monitoring points near communities require stakeholder notification when permit limits are exceeded (air quality, water quality, noise). Regulatory requirement in most mining jurisdictions and critica' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Reference to the physical sample record in the Laboratory Information Management System (LIMS). Null for direct field measurements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mining .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to procurement.warehouse_location. Business justification: Environmental monitoring points at or near storage facilities (dust, emissions, groundwater contamination from stored fuels/chemicals/reagents) require warehouse location linkage for compliance monito' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Indicates whether the measured value exceeded the permit limit. True if exceeded, False otherwise.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedancePercentage rdf:type rdf:Property ;
    rdfs:label 'Exceedance Percentage' ;
    rdfs:comment 'Percentage by which the measurement exceeded the permit limit. Null if no exceedance occurred.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisLatitude rdf:type rdf:Property ;
    rdfs:label 'Gis Latitude' ;
    rdfs:comment 'Latitude coordinate of the monitoring point in decimal degrees for spatial analysis and mapping.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gisLongitude rdf:type rdf:Property ;
    rdfs:label 'Gis Longitude' ;
    rdfs:comment 'Longitude coordinate of the monitoring point in decimal degrees for spatial analysis and mapping.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Reference Number' ;
    rdfs:comment 'External reference or job number assigned by the laboratory for traceability. Null for field measurements.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'Numeric value of the environmental measurement recorded.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Equipment Code' ;
    rdfs:comment 'Reference to the monitoring instrument or equipment used (e.g., air quality analyzer, water quality meter, noise meter).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringPointCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Code' ;
    rdfs:comment 'Unique code identifying the specific monitoring location or station (e.g., surface water sampling point, air quality station, groundwater bore).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPointName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Name' ;
    rdfs:comment 'Descriptive name of the monitoring location for business user reference.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current status of the monitoring record in the workflow from sampling through validation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Category of environmental monitoring activity being performed. [ENUM-REF-CANDIDATE: air_quality|water_quality_surface|water_quality_groundwater|noise|vibration|biodiversity|soil — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterMeasured rdf:type rdf:Property ;
    rdfs:label 'Parameter Measured' ;
    rdfs:comment 'Specific environmental parameter or pollutant being measured (e.g., PM10, PM2.5, pH, dissolved oxygen, total suspended solids, heavy metals, noise level dB).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimit rdf:type rdf:Property ;
    rdfs:label 'Permit Limit' ;
    rdfs:comment 'Regulatory or permit-defined threshold limit for the measured parameter. Null if no limit applies.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Created Datetime' ;
    rdfs:comment 'Timestamp when this environmental monitoring record was first created in the system.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedDatetime rdf:type rdf:Property ;
    rdfs:label 'Record Updated Datetime' ;
    rdfs:comment 'Timestamp when this environmental monitoring record was last modified.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Flag' ;
    rdfs:comment 'Indicates whether this monitoring result must be included in regulatory compliance reporting to authorities.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampledBy rdf:type rdf:Property ;
    rdfs:label 'Sampled By' ;
    rdfs:comment 'Name or identifier of the person or team who collected the sample or performed the measurement.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDatetime rdf:type rdf:Property ;
    rdfs:label 'Sampling Datetime' ;
    rdfs:comment 'Date and time when the environmental sample was collected or measurement was taken.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Methodology or protocol used for sample collection or measurement (e.g., grab sample, composite sample, continuous monitoring, manual measurement).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDatetime rdf:type rdf:Property ;
    rdfs:label 'Validation Datetime' ;
    rdfs:comment 'Date and time when the monitoring result was validated.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Cardinal direction from which the wind was blowing at the time of measurement. [ENUM-REF-CANDIDATE: N|NE|E|SE|S|SW|W|NW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMps rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Mps' ;
    rdfs:comment 'Wind speed in meters per second at the time of measurement. Relevant for air quality and dust monitoring.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programmeOfWorkId rdf:type rdf:Property ;
    rdfs:label 'Programme Of Work Id' ;
    rdfs:comment 'Foreign key linking to tenement.programme_of_work. Business justification: Environmental permits authorize programme of work activities. Compliance verification, operational authorization, and regulatory tracking require this link. Mining operations obtain permits to execute' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgrammeOfWork .

ind:enforcementActionDescription rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Description' ;
    rdfs:comment 'Description of any regulatory enforcement action, penalty notice, improvement order, or formal warning issued by the regulatory authority in relation to this permit.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether any regulatory enforcement action, penalty, or formal notice has been issued in relation to this permit. True if enforcement action is active or pending.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAssuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Amount' ;
    rdfs:comment 'Monetary value of the financial assurance, bond, or guarantee required under the permit conditions. Expressed in the operating currency of the mining operation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssuranceCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial assurance amount.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires the mining operation to provide financial assurance, bond, or guarantee to cover potential environmental liabilities or rehabilitation costs.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the government agency, regulatory body, or environmental authority that issued the permit. Examples include state environmental protection agencies, water boards, or mining departments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Assessment Date' ;
    rdfs:comment 'Date of the most recent internal or external compliance assessment or audit conducted for this permit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Count' ;
    rdfs:comment 'Number of permit conditions currently assessed as non-compliant. Provides a quantitative indicator of compliance risk.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitConditionsSummary rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions Summary' ;
    rdfs:comment 'High-level summary of the key conditions, restrictions, and obligations imposed by the permit. Detailed condition-level tracking is maintained in a related permit conditions entity.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Permit Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL to the official permit document, licence certificate, or approval letter issued by the regulatory authority.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit number or licence identifier issued by the regulatory authority. This is the externally-known unique identifier used in all regulatory correspondence and submissions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the environmental permit. Indicates whether the permit is in force, requires renewal action, or has been terminated.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the environmental permit based on the regulated activity or environmental medium. Determines the applicable regulatory framework and monitoring requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatedActivity rdf:type rdf:Property ;
    rdfs:label 'Regulated Activity' ;
    rdfs:comment 'Description of the specific activity, discharge, emission, or environmental aspect that is authorized under this permit. Examples include water extraction, tailings discharge, air emissions from processing plant, or waste rock disposal.' ;
    rdfs:domain ind:EnvironmentalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Target date by which the permit renewal application must be submitted to the regulatory authority to avoid lapse. Typically set in advance of the expiry date per regulatory requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the permit renewal process. Tracks whether renewal action is required and the stage of the renewal application.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOwner rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner' ;
    rdfs:comment 'Name or identifier of the individual, role, or department responsible for managing compliance with this permit. Accountable for monitoring, reporting, and renewal activities.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSurveillanceId rdf:type rdf:Property ;
    rdfs:label 'Health Surveillance Id' ;
    rdfs:comment 'Unique identifier for the health surveillance record. Primary key for the health surveillance data product.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionLevelValue rdf:type rdf:Property ;
    rdfs:label 'Action Level Value' ;
    rdfs:comment 'Action level threshold value that triggers additional monitoring, medical surveillance, or control measures. Typically set at 50% of the OEL/PEL or as defined by regulatory standards.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineTestFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Test Flag' ;
    rdfs:comment 'Boolean flag indicating whether this is a baseline health surveillance test conducted at the start of employment or upon first exposure to a specific hazard. Baseline tests establish reference values for future comparison.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:examiningPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Examining Physician Name' ;
    rdfs:comment 'Name of the occupational physician or medical professional who conducted the health surveillance examination or reviewed the exposure monitoring results.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureDurationHours rdf:type rdf:Property ;
    rdfs:label 'Exposure Duration Hours' ;
    rdfs:comment 'Duration of exposure to the occupational hazard during the monitoring period, measured in hours. Used for calculating time-weighted average exposures and cumulative dose assessments.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessClassification rdf:type rdf:Property ;
    rdfs:label 'Fitness Classification' ;
    rdfs:comment 'Classification of the worker\'s fitness for work based on the medical examination or health assessment. Determines whether the worker can perform their assigned duties without restrictions, with restrictions, or is unfit for work.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Follow-up action required based on the health surveillance results. May include repeat testing, referral to specialist, workplace exposure assessment, engineering controls implementation, or administrative controls.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Type of occupational hazard being monitored or assessed. Includes noise exposure, airborne dust (respirable silica, coal dust, diesel particulate matter), chemical exposure, biological agents, ergonomic risks, and heat stress.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingProtectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hearing Protection Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether hearing protection (Personal Protective Equipment - PPE) is required for this worker based on noise exposure monitoring or audiometric test results. True indicates mandatory hearing protection.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Related Flag' ;
    rdfs:comment 'Boolean flag indicating whether this health surveillance record is related to a specific workplace incident, injury, or exposure event requiring immediate medical assessment.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the surveillance measurement value. Common units: dB (decibels for audiometry), dB TWA (time-weighted average noise exposure), mg/m³ (airborne dust concentration), µg/dL (blood lead level), L (liters for spirometry volume), L/min (spirometry flow rate), percent (lung function percentage), mmHg (blood pressure). [ENUM-REF-CANDIDATE: dB|dB_TWA|mg_m3|ug_dL|L|L_min|percent|mmHg — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the medical facility, clinic, or occupational health service provider where the health surveillance test or examination was conducted.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Date when the next health surveillance test or assessment is due for this worker. Calculated based on test frequency requirements and used for scheduling periodic medical examinations.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oelValue rdf:type rdf:Property ;
    rdfs:label 'Oel Value' ;
    rdfs:comment 'Occupational Exposure Limit (OEL) or Permissible Exposure Limit (PEL) threshold value applicable to this hazard type and measurement. Regulatory limit against which the measurement is compared to determine compliance.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodicExaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Periodic Examination Flag' ;
    rdfs:comment 'Boolean flag indicating whether this is a periodic (routine) medical examination conducted at regular intervals as part of the ongoing health surveillance program.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicianRecommendation rdf:type rdf:Property ;
    rdfs:label 'Physician Recommendation' ;
    rdfs:comment 'Recommendation provided by the occupational physician or medical professional based on the health surveillance results. May include follow-up testing, work restrictions, referral to specialist, or clearance for duty.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Type Required' ;
    rdfs:comment 'Type of Personal Protective Equipment (PPE) required based on the health surveillance findings. May include hearing protection (earplugs, earmuffs), respiratory protection (dust masks, respirators), or other protective equipment.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preEmploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Employment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this health surveillance record is part of a pre-employment medical examination conducted before the worker commences employment at the mine site.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this health surveillance record must be submitted to regulatory authorities such as MSHA or state mining regulators as part of mandatory health reporting requirements.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveillanceType rdf:type rdf:Property ;
    rdfs:label 'Surveillance Type' ;
    rdfs:comment 'Type of health surveillance or medical assessment conducted. Discriminates between audiometric testing, spirometry, blood lead testing, medical examinations, fitness-for-work assessments, and exposure monitoring.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Test Frequency Months' ;
    rdfs:comment 'Required frequency for this type of health surveillance test or assessment, measured in months. Determines the interval between periodic medical examinations or exposure monitoring based on regulatory requirements and risk assessment.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Location where the health surveillance test or assessment was conducted. May be mine site medical facility, external clinic, or field location for exposure monitoring.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workRestrictions rdf:type rdf:Property ;
    rdfs:label 'Work Restrictions' ;
    rdfs:comment 'Specific work restrictions or limitations imposed based on the health surveillance findings. May include restrictions on noise exposure, dust exposure, heavy lifting, confined space entry, or specific tasks.' ;
    rdfs:domain ind:HealthSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Employee Id' ;
    rdfs:comment 'Identifier of the person leading the incident investigation team.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incidentInjuredPersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Injured Person Employee Id' ;
    rdfs:comment 'Identifier of the person injured in the incident. Applicable only for injury incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityBeingPerformed rdf:type rdf:Property ;
    rdfs:label 'Activity Being Performed' ;
    rdfs:comment 'Description of the work activity or task being performed at the time of the incident (e.g., drilling, blasting, hauling, maintenance, processing).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMedia rdf:type rdf:Property ;
    rdfs:label 'Affected Media' ;
    rdfs:comment 'For environmental incidents, the environmental media or receptor affected: air, water, soil, groundwater, vegetation, wildlife, heritage site, or none (for non-environmental incidents). [ENUM-REF-CANDIDATE: air|water|soil|groundwater|vegetation|wildlife|heritage_site|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentActions rdf:type rdf:Property ;
    rdfs:label 'Containment Actions' ;
    rdfs:comment 'Description of immediate containment or emergency response actions taken to control the incident and prevent escalation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Description of contributing factors that enabled or exacerbated the incident (e.g., equipment condition, training gaps, procedural deficiencies, environmental conditions).' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysLost rdf:type rdf:Property ;
    rdfs:label 'Days Lost' ;
    rdfs:comment 'Number of scheduled work days lost due to the injury. Applicable for LTI incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalVolumeReleased rdf:type rdf:Property ;
    rdfs:label 'Environmental Volume Released' ;
    rdfs:comment 'Volume of material released in an environmental spill or discharge incident, measured in cubic meters or liters. Applicable only for environmental incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'Description of the immediate or direct cause of the incident as identified during initial assessment.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known unique incident reference number assigned by IsoMetrix or site HSE system for tracking and reporting purposes.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryBodyPart rdf:type rdf:Property ;
    rdfs:label 'Injury Body Part' ;
    rdfs:comment 'Body part affected by the injury (e.g., hand, leg, head, back). Applicable only for injury incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Nature or type of injury sustained (e.g., fracture, laceration, contusion, burn, strain). Applicable only for injury incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationMethodology rdf:type rdf:Property ;
    rdfs:label 'Investigation Methodology' ;
    rdfs:comment 'Root cause analysis methodology used for the investigation: ICAM (Incident Cause Analysis Method), Bow-Tie, 5-Why, Root Cause Tree, TapRoot, or not applicable if no formal investigation conducted.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationReportStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Report Status' ;
    rdfs:comment 'Status of the formal investigation report: not started, in progress, draft, final, or approved.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a formal investigation is required for this incident based on severity and company policy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltifrContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Ltifr Contribution Flag' ;
    rdfs:comment 'Boolean flag indicating whether this incident contributes to the Lost Time Injury Frequency Rate (LTIFR) calculation. True for LTI and fatal incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this incident requires notification to regulatory authorities (MSHA, state environmental agencies, etc.).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of regulatory notification: not required, pending, submitted, or acknowledged by the authority.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Deadline' ;
    rdfs:comment 'Deadline date by which the incident must be reported to regulatory authorities (e.g., MSHA 24-hour or 10-day reporting requirements).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDescription rdf:type rdf:Property ;
    rdfs:label 'Remediation Description' ;
    rdfs:comment 'Description of remediation or corrective actions required to address the incident impact and prevent recurrence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether environmental remediation or corrective actions are required as a result of this incident.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Summary of the root cause(s) identified through the investigation, including immediate, underlying, and systemic causes.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the incident occurred: day, night, or swing shift.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trifrContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Trifr Contribution Flag' ;
    rdfs:comment 'Boolean flag indicating whether this incident contributes to the Total Recordable Injury Frequency Rate (TRIFR) calculation. True for LTI, MTI, RWI, and fatal incidents.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or update to the legislation that affects this compliance obligation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentSummary rdf:type rdf:Property ;
    rdfs:label 'Amendment Summary' ;
    rdfs:comment 'Brief summary of the most recent amendment or change to the legislation and its impact on compliance obligations.' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Applicability Notes' ;
    rdfs:comment 'Additional notes or context regarding the applicability of this legal requirement to the specific site, operation, or activity.' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Compliance Evidence Location' ;
    rdfs:comment 'Reference to the location or system where evidence of compliance with this legal requirement is stored (e.g., document management system path, IsoMetrix record ID, file server location).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationSummary rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Summary' ;
    rdfs:comment 'Concise summary of the specific compliance obligation or requirement imposed by the legislation on the mine site (e.g., submit annual environmental report, maintain dust monitoring records, conduct quarterly safety audits).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legislationName rdf:type rdf:Property ;
    rdfs:label 'Legislation Name' ;
    rdfs:comment 'Full name or title of the applicable legislation, act, regulation, code of practice, or standard (e.g., Mine Safety and Health Act 1996, Environmental Protection Act 1994).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legislationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Legislation Reference Number' ;
    rdfs:comment 'Official reference number, citation, or identifier for the legislation (e.g., Act No. 82 of 1996, Regulation 2019/123).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legislationType rdf:type rdf:Property ;
    rdfs:label 'Legislation Type' ;
    rdfs:comment 'Classification of the legal instrument (act, regulation, code of practice, standard, licence condition, permit condition).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legislationUrl rdf:type rdf:Property ;
    rdfs:label 'Legislation Url' ;
    rdfs:comment 'Web link or URL to the official source or full text of the legislation for reference.' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'Mining licence, environmental permit, or authorization number to which this legal requirement is attached (if applicable).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of penalties, fines, or sanctions that may be imposed for non-compliance with this legal requirement.' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the government agency or regulatory authority responsible for administering and enforcing the legislation (e.g., Mine Safety and Health Administration (MSHA), Department of Environment and Science, Resources Safety and Health Queensland).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByLegislation rdf:type rdf:Property ;
    rdfs:label 'Superseded By Legislation' ;
    rdfs:comment 'Name or reference of the legislation that has superseded or replaced this legal requirement (if applicable).' ;
    rdfs:domain ind:LegalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryManagementInitiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Management Initiator Employee Id' ;
    rdfs:comment 'Identifier of the employee who originated the MOC request.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to product.product_specification. Business justification: Product specification changes are a primary MOC trigger in mining. Direct link to the specific spec revision enables traceability of HSE risk assessments, training updates, and regulatory notification' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:affectedArea rdf:type rdf:Property ;
    rdfs:label 'Affected Area' ;
    rdfs:comment 'Specific operational area, work zone, or department impacted by the change (e.g., underground stope, processing plant, tailings storage facility, maintenance workshop).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'Name or code of the operational process being modified (e.g., blasting sequence, ventilation system, ore crushing, chemical leaching, ground support installation).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Stage' ;
    rdfs:comment 'Current stage in the multi-level approval process (e.g., supervisor review, HSE review, engineering review, site manager approval, general manager approval).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Primary classification of what is being changed: equipment (machinery, tools), process (operational workflow), chemical (hazardous substances), organizational (structure, roles), facility (infrastructure, buildings), or procedure (Standard Operating Procedure / SOP).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative description of the proposed modification to mine operations, equipment, processes, chemicals, or organizational structures, including scope, rationale, and expected outcomes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the proposed change for quick identification and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change duration and intent: temporary (time-limited), permanent (indefinite), emergency (immediate safety response), or trial (pilot/testing phase).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Date' ;
    rdfs:comment 'Date when the MOC was formally verified as complete, all actions closed, and the change fully integrated into normal operations.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Verified By' ;
    rdfs:comment 'Name of the HSE or operations manager who verified and authorized closure of the MOC.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Summary of risk controls and mitigation actions to be implemented as part of the change, following hierarchy of controls (elimination, substitution, engineering, administrative, Personal Protective Equipment / PPE).' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategories rdf:type rdf:Property ;
    rdfs:label 'Hazard Categories' ;
    rdfs:comment 'Comma-separated list of hazard types introduced or affected by the change (e.g., ground instability, chemical exposure, confined space, electrical, mobile equipment interaction).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Detailed plan outlining steps, resources, timeline, and responsibilities for executing the approved change.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Level' ;
    rdfs:comment 'Risk severity rating before implementation of control measures, derived from the linked risk assessment.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Department or functional area of the initiating employee (e.g., Mine Operations, Processing, Maintenance, Engineering).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the employee who originated the MOC request.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocNumber rdf:type rdf:Property ;
    rdfs:label 'Moc Number' ;
    rdfs:comment 'Business-facing unique reference number for the MOC request, used for tracking and communication across departments and regulatory submissions.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mocStatus rdf:type rdf:Property ;
    rdfs:label 'Moc Status' ;
    rdfs:comment 'Current lifecycle status of the MOC request in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|implementation|completed|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssrCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pssr Completion Date' ;
    rdfs:comment 'Date when the Pre-Startup Safety Review was completed and the change was verified safe to commission.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pssrOutcome rdf:type rdf:Property ;
    rdfs:label 'Pssr Outcome' ;
    rdfs:comment 'Result of the Pre-Startup Safety Review: passed (safe to commission), failed (deficiencies must be corrected), or conditional (minor items to be closed post-startup).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pssrRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pssr Required Flag' ;
    rdfs:comment 'Indicates whether a formal Pre-Startup Safety Review is mandated before the change can be commissioned, typically required for high-risk modifications to critical systems (ventilation, ground support, blasting, chemical processes).' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the regulatory authority was formally notified of the change.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Required Implementation Date' ;
    rdfs:comment 'Target date by which the change must be implemented to meet operational or regulatory requirements.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Risk severity rating after implementation of proposed control measures, derived from the linked risk assessment.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Updated Flag' ;
    rdfs:comment 'Indicates whether relevant Standard Operating Procedures have been revised to reflect the change.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when all required training for affected personnel was completed.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether workforce training or competency verification is required before the change can be implemented.' ;
    rdfs:domain ind:ManagementOfChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Identifier of the specific PPE item from the master catalogue (hard hat, respirator, safety boots, etc.).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:primaryPpeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ppe Employee Id' ;
    rdfs:comment 'Identifier of the worker or contractor to whom the PPE was issued.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgementSignature rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Signature' ;
    rdfs:comment 'Digital or scanned signature of the worker acknowledging receipt of the PPE and understanding of its proper use and care requirements.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'The actual date on which the PPE was returned by the worker, used to track compliance and lifecycle completion.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The manufacturing batch or lot number of the PPE item, used for quality control and recall management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtIssue rdf:type rdf:Property ;
    rdfs:label 'Condition At Issue' ;
    rdfs:comment 'The physical condition of the PPE at the time of issuance to the worker.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'The date by which the PPE is expected to be returned for inspection, replacement, or end of assignment, applicable to reusable or high-value items.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestDate rdf:type rdf:Property ;
    rdfs:label 'Fit Test Date' ;
    rdfs:comment 'The date on which the worker completed a fit test for the issued PPE, applicable to respirators and breathing apparatus.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fit Test Required Flag' ;
    rdfs:comment 'Indicates whether a fit test is required for the issued PPE (e.g., respirators), per regulatory and manufacturer requirements.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuance Number' ;
    rdfs:comment 'Business-readable unique transaction number for the PPE issuance event, typically generated by IsoMetrix or stores system.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLocation rdf:type rdf:Property ;
    rdfs:label 'Issuing Location' ;
    rdfs:comment 'The mine site, warehouse, or stores location from which the PPE was issued.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'The number of units of the PPE item issued in this transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementReason rdf:type rdf:Property ;
    rdfs:label 'Replacement Reason' ;
    rdfs:comment 'The reason for issuing replacement PPE, used for cost tracking, compliance reporting, and trend analysis.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'The physical condition of the PPE at the time of return, used to determine whether it can be reissued, requires repair, or must be disposed of.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this issuance record in the source operational system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the PPE issuance transaction, calculated as quantity issued multiplied by unit cost.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completed Flag' ;
    rdfs:comment 'Indicates whether the worker has completed mandatory training on the proper use, maintenance, and limitations of the issued PPE.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'The date on which the worker completed PPE-specific training, used for compliance verification and audit trails.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The cost per unit of the PPE item at the time of issuance, used for financial tracking and OPEX reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Unique identifier for the regulatory submission record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement_application. Business justification: Regulatory submissions may reference tenement applications (supporting documentation, compliance evidence). Application tracking and regulatory approval processes require this link. Mining operations ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:cargoShipmentId rdf:type rdf:Property ;
    rdfs:label 'Cargo Shipment Id' ;
    rdfs:comment 'Foreign key linking to sales.cargo_shipment. Business justification: Export compliance submissions (environmental clearances, hazardous cargo declarations, customs filings) reference specific bill of lading numbers and shipment details. Regulatory bodies require shipme' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoShipment .

ind:consultedStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Consulted Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Mining regulatory submissions (EIS, permit applications, compliance reports) require documented stakeholder consultation. Mandatory in most jurisdictions for environmental and social impact assessment' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:lomPlanId rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Id' ;
    rdfs:comment 'Identifier of the specific mine operation covered by this regulatory submission.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LomPlan .

ind:acknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received' ;
    rdfs:comment 'Indicates whether an acknowledgement or receipt confirmation has been received from the regulatory body.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Reference' ;
    rdfs:comment 'Reference number or identifier provided by the regulatory body in their acknowledgement of receipt.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text notes capturing key events, decisions, and communications related to the submission for audit and compliance tracking purposes.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Recurring frequency or schedule at which this type of submission is required by the regulatory body. [ENUM-REF-CANDIDATE: Annual|Quarterly|Monthly|Ad-Hoc|Event-Driven|Biennial|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework, standard, or legislation under which the submission is required (e.g., MSHA Part 50, SEC Regulation S-K 1300, ISO 14001).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseComments rdf:type rdf:Property ;
    rdfs:label 'Response Comments' ;
    rdfs:comment 'Comments, feedback, or conditions provided by the regulatory body in their response to the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date on which a formal response or decision was received from the regulatory body.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseOutcome rdf:type rdf:Property ;
    rdfs:label 'Response Outcome' ;
    rdfs:comment 'Outcome or decision communicated by the regulatory body in response to the submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceived rdf:type rdf:Property ;
    rdfs:label 'Response Received' ;
    rdfs:comment 'Indicates whether a formal response, decision, or feedback has been received from the regulatory body following submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDescription rdf:type rdf:Property ;
    rdfs:label 'Submission Description' ;
    rdfs:comment 'Detailed description of the content, scope, and purpose of the regulatory submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method or channel used to deliver the submission to the regulatory body.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'External reference number or tracking code assigned to the regulatory submission by the submitting organization or regulatory body. Used for correspondence and audit trail.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory submission indicating its progress through the submission and approval workflow. [ENUM-REF-CANDIDATE: Draft|Pending Review|Submitted|Accepted|Rejected|Under Revision|Overdue|Withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Category of regulatory submission indicating the nature and purpose of the report or filing. [ENUM-REF-CANDIDATE: MSHA Annual Report|Environmental Impact Statement|JORC Resource Report|SEC Mining Disclosure|GRI Sustainability Report|ISO 14001 Audit|ISO 45001 Audit|Permit Application|Incident Notification|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardId rdf:type rdf:Property ;
    rdfs:label 'Hazard Id' ;
    rdfs:comment 'Reference to the hazard record in the enterprise-wide hazard register that this risk assessment evaluates.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:primaryRiskEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted the risk assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByAssessmentRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assessment Risk Assessment Id' ;
    rdfs:comment 'Reference to the newer risk assessment that replaces this one, if applicable.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:affectedPersonnelCount rdf:type rdf:Property ;
    rdfs:label 'Affected Personnel Count' ;
    rdfs:comment 'Estimated number of workers potentially exposed to the assessed hazard.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the risk assessment, typically following organizational numbering convention (e.g., RA-2024-001).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAdequacyRating rdf:type rdf:Property ;
    rdfs:label 'Control Adequacy Rating' ;
    rdfs:comment 'Assessment of whether the implemented control measures are sufficient to manage the risk to an acceptable level.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy Level' ;
    rdfs:comment 'Highest level of control hierarchy applied per ISO 45001. PPE (Personal Protective Equipment) is the lowest level of control.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Classification of the hazard type being assessed: Physical (noise, vibration, radiation), Chemical (dust, fumes, gases), Biological (bacteria, viruses), Ergonomic (manual handling, repetitive strain), Psychosocial (stress, fatigue), Environmental (spills, emissions).' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardSource rdf:type rdf:Property ;
    rdfs:label 'Hazard Source' ;
    rdfs:comment 'The origin or cause of the hazard (e.g., mobile equipment, explosives, confined space, high voltage, falling objects).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Consequence Rating' ;
    rdfs:comment 'Severity of potential harm or loss before any control measures are applied, using a 5-level scale.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Rating' ;
    rdfs:comment 'Probability of the hazard occurring before any control measures are applied, using a 5-level scale.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated risk matrix score before controls (likelihood × consequence), typically ranging from 1 to 25.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence Rating' ;
    rdfs:comment 'Severity of potential harm or loss after control measures are applied, using a 5-level scale.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Probability of the hazard occurring after control measures are applied, using a 5-level scale.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Calculated risk matrix score after controls (likelihood × consequence), typically ranging from 1 to 25.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Status' ;
    rdfs:comment 'Whether the residual risk level is accepted by management or requires further treatment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workArea rdf:type rdf:Property ;
    rdfs:label 'Work Area' ;
    rdfs:comment 'Specific work area, pit, underground level, processing plant section, or operational zone where the assessed hazard is present.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservationId rdf:type rdf:Property ;
    rdfs:label 'Safety Observation Id' ;
    rdfs:comment 'Unique identifier for the safety observation record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyObservation .

ind:primarySafetyObserverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Observer Employee Id' ;
    rdfs:comment 'Identifier of the employee who made the safety observation (supervisor, safety officer, or worker).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySafetyAssignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Safety Assigned To Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to complete follow-up actions.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fatigueIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Fatigue Indicator Flag' ;
    rdfs:comment 'Indicates whether fatigue was identified as a contributing factor or declared by the worker (True = fatigue present, False = no fatigue).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionDescription rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Description' ;
    rdfs:comment 'Description of planned or required follow-up actions, investigations, or corrective measures.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of any immediate corrective action taken at the time of observation (e.g., work stopped, hazard isolated, coaching provided, positive feedback given).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadingIndicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Leading Indicator Category' ;
    rdfs:comment 'Classification of the observation for leading indicator reporting and trend analysis (e.g., behavioral safety, housekeeping, equipment condition, procedural compliance).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Assessment of the likelihood or probability of the observed hazard resulting in an incident.' ;
    rdfs:domain ind:Hse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationDescription rdf:type rdf:Property ;
    rdfs:label 'Observation Description' ;
    rdfs:comment 'Detailed narrative description of what was observed, including context, behavior, condition, and circumstances.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Number' ;
    rdfs:comment 'Business identifier for the safety observation in the format OBS-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current lifecycle status of the safety observation.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'Date and time when the safety observation was made in the field.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observationType rdf:type rdf:Property ;
    rdfs:label 'Observation Type' ;
    rdfs:comment 'Classification of the observation: safe act, unsafe act, safe condition, unsafe condition, fatigue declaration, or positive recognition.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedPersonName rdf:type rdf:Property ;
    rdfs:label 'Observed Person Name' ;
    rdfs:comment 'Name of the person observed (nullable for anonymous observations or condition-based observations).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerName rdf:type rdf:Property ;
    rdfs:label 'Observer Name' ;
    rdfs:comment 'Full name of the person who made the safety observation.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerRole rdf:type rdf:Property ;
    rdfs:label 'Observer Role' ;
    rdfs:comment 'Role or position of the person who made the observation.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Url' ;
    rdfs:comment 'URL or file path to photographic evidence captured at the time of observation.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Flag' ;
    rdfs:comment 'Indicates whether proper PPE was being worn at the time of observation (True = compliant, False = non-compliant).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Calculated risk score based on severity and likelihood ratings, used for prioritization.' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Assessment of the potential severity or consequence of the observed hazard or unsafe condition.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopWorkAuthorityExercisedFlag rdf:type rdf:Property ;
    rdfs:label 'Stop Work Authority Exercised Flag' ;
    rdfs:comment 'Indicates whether stop work authority was exercised as a result of this observation (True = work stopped, False = work continued).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workActivity rdf:type rdf:Property ;
    rdfs:label 'Work Activity' ;
    rdfs:comment 'Specific work activity or task being performed at the time of observation (e.g., drilling blast holes, loading ore, equipment maintenance, sample collection).' ;
    rdfs:domain ind:SafetyObservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Reference to the mine worker or contractor who received the training.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Reference to the HSE training program or course catalog entry.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether the training requires a formal assessment or examination for completion.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the training assessment: pass (met competency standard), fail (did not meet standard), not_assessed (no assessment required), or pending (assessment scheduled but not completed).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved in the training assessment, typically expressed as a percentage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Participant attendance outcome: attended (full participation), absent (did not attend), partial (attended part of session), or excused (authorized absence).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a training certificate or competency card was issued to the participant upon successful completion.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique identifier of the training certificate or competency card issued.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'Level of competency achieved or required for this training: basic (foundational), intermediate (operational), advanced (supervisory), or expert (specialist/trainer).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred for delivering this training session, including trainer fees, materials, and facility costs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the training cost amount.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Mode of training delivery: classroom (in-person instruction), online (e-learning), on_the_job (practical field training), simulation (virtual or physical simulator), or blended (combination of methods).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the training session in hours.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment, expressed as a percentage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refresherDueDate rdf:type rdf:Property ;
    rdfs:label 'Refresher Due Date' ;
    rdfs:comment 'Date by which refresher training must be completed to maintain competency and compliance.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference to the specific regulatory or statutory requirement that mandates this training (e.g., MSHA Part 46, ISO 45001 clause, state mining act section).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerName rdf:type rdf:Property ;
    rdfs:label 'Trainer Name' ;
    rdfs:comment 'Full name of the instructor or facilitator who delivered the training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course in the HSE training catalog.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., training room, online platform, field site).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current lifecycle status of the training record: scheduled (planned but not started), in_progress (underway), completed (successfully finished), cancelled (did not proceed), or expired (certificate validity lapsed).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTitle rdf:type rdf:Property ;
    rdfs:label 'Training Title' ;
    rdfs:comment 'Full name of the HSE training course or module delivered.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Category of HSE training delivered: induction (site orientation), statutory (legally mandated such as first aid, warden, explosives handling), refresher (periodic recertification), competency (skill validation), emergency_response (evacuation, rescue), or ppe (Personal Protective Equipment usage).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Number of months for which the training certification remains valid before refresher training is required.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticalMethodId rdf:type rdf:Property ;
    rdfs:label 'Analytical Method Id' ;
    rdfs:comment 'Unique identifier for the analytical method record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalMethod .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Unique accreditation certificate or registration number issued by the accrediting body for this specific method. Used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStandard rdf:type rdf:Property ;
    rdfs:label 'Accreditation Standard' ;
    rdfs:comment 'The formal accreditation standard under which this method is certified (e.g., NATA for National Association of Testing Authorities in Australia, ISO 17025 for international laboratory accreditation, A2LA for American Association for Laboratory Accreditation). Critical for resource estimation and regulatory compliance.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyBiasPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Bias Percent' ;
    rdfs:comment 'Method accuracy expressed as percentage bias from certified reference material (CRM) true values. Positive values indicate over-reporting; negative values indicate under-reporting. Acceptable bias is typically within ±5% for resource estimation methods.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Analysis Duration Minutes' ;
    rdfs:comment 'Typical time required to complete the analytical procedure for a single sample, measured in minutes. Used for laboratory capacity planning and turnaround time estimation.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyteList rdf:type rdf:Property ;
    rdfs:label 'Analyte List' ;
    rdfs:comment 'Comma-separated list of chemical elements or compounds that this method can detect and quantify (e.g., Au, Ag, Cu, Fe, S, C for multi-element methods; Au only for single-element fire assay). Defines the scope of the method\'s analytical capability.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForProcessControl rdf:type rdf:Property ;
    rdfs:label 'Approved For Process Control' ;
    rdfs:comment 'Boolean flag indicating whether this method is approved for real-time or near-real-time process control and optimization in mineral processing plants. True if suitable for operational decision-making; false if restricted to formal assay reporting.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedForResourceEstimation rdf:type rdf:Property ;
    rdfs:label 'Approved For Resource Estimation' ;
    rdfs:comment 'Boolean flag indicating whether this method meets the quality and accreditation standards required for JORC, NI 43-101, or SAMREC compliant mineral resource and ore reserve estimation. True if approved; false if restricted to process control or non-compliant applications.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerSample rdf:type rdf:Property ;
    rdfs:label 'Cost Per Sample' ;
    rdfs:comment 'Standard cost to analyze one sample using this method, including labor, consumables, reagents, and instrument time. Used for laboratory budgeting and exploration/production cost estimation. Expressed in the organization\'s reporting currency.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitLower rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Lower' ;
    rdfs:comment 'Minimum concentration or grade that the method can reliably detect and quantify, expressed in the method\'s reporting unit. Values below this threshold are reported as below detection limit (BDL).' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interferenceNotes rdf:type rdf:Property ;
    rdfs:label 'Interference Notes' ;
    rdfs:comment 'Documentation of known chemical or spectral interferences that may affect method accuracy (e.g., high iron content interfering with copper XRF analysis, arsenic interference in gold fire assay). Used to guide method selection and result interpretation.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date of the most recent method validation or re-validation exercise, including precision and accuracy testing against certified reference materials. ISO 17025 requires periodic re-validation.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matrixApplicability rdf:type rdf:Property ;
    rdfs:label 'Matrix Applicability' ;
    rdfs:comment 'Description of the sample matrix types for which this method is validated and approved (e.g., oxide ore, sulphide ore, concentrate, tailings, soil, water, rock). Critical for ensuring method suitability for different geological and process materials.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodCategory rdf:type rdf:Property ;
    rdfs:label 'Method Category' ;
    rdfs:comment 'Business classification of the method\'s primary application domain (geochemical for ore assays, metallurgical for concentrate and recovery testing, environmental for tailings and water analysis, quality_control for QA/QC samples, process_control for real-time plant monitoring).' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodCode rdf:type rdf:Property ;
    rdfs:label 'Method Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the analytical method (e.g., FA-AAS-01, XRF-PP-02, ICP-MS-03). Used as the business identifier for the method across laboratory systems and resource estimation workflows.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Method Documentation Reference' ;
    rdfs:comment 'Reference to the detailed method documentation, standard operating procedure (SOP), or published standard (e.g., SOP-LAB-FA-001, ASTM E1915, ISO 11426). Used to access full procedural details and compliance evidence.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodName rdf:type rdf:Property ;
    rdfs:label 'Method Name' ;
    rdfs:comment 'Full descriptive name of the analytical method (e.g., Fire Assay with Atomic Absorption Spectroscopy for Gold, X-Ray Fluorescence Pressed Pellet for Multi-Element Analysis).' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodOwner rdf:type rdf:Property ;
    rdfs:label 'Method Owner' ;
    rdfs:comment 'Name or identifier of the laboratory manager or technical specialist responsible for maintaining and validating this method. Used for accountability and technical queries.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodStatus rdf:type rdf:Property ;
    rdfs:label 'Method Status' ;
    rdfs:comment 'Current lifecycle status of the analytical method. Active methods are approved for use; superseded methods have been replaced by newer versions; pending_accreditation methods are awaiting formal approval.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Classification of the analytical technique family (e.g., fire_assay for FA-AAS/FA-OES, xrf for X-Ray Fluorescence, icp_ms for Inductively Coupled Plasma Mass Spectrometry, leco for LECO carbon/sulphur analyzers). [ENUM-REF-CANDIDATE: fire_assay|xrf|icp_ms|icp_oes|leco|titration|gravimetric|wet_chemistry|spectroscopy|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodVersion rdf:type rdf:Property ;
    rdfs:label 'Method Version' ;
    rdfs:comment 'Version number of the analytical method (e.g., 1.0, 2.1, 3.0.1). Incremented when method parameters, detection limits, or procedures are updated.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Validation Due Date' ;
    rdfs:comment 'Scheduled date for the next method validation or re-validation exercise. Used for laboratory quality management and accreditation maintenance planning.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:precisionRsdPercent rdf:type rdf:Property ;
    rdfs:label 'Precision Rsd Percent' ;
    rdfs:comment 'Method precision expressed as relative standard deviation (RSD) percentage, derived from replicate analysis of certified reference materials (CRMs). Lower values indicate higher precision. Typical acceptable range is 1-10% depending on analyte and concentration.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentList rdf:type rdf:Property ;
    rdfs:label 'Reagent List' ;
    rdfs:comment 'Comma-separated list of chemical reagents required for the analytical procedure (e.g., lithium borate flux, hydrochloric acid, nitric acid, lead oxide, silver nitrate). Used for laboratory inventory management and safety planning.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceMaterialRequired rdf:type rdf:Property ;
    rdfs:label 'Reference Material Required' ;
    rdfs:comment 'Specification of certified reference materials (CRMs) or standard reference materials (SRMs) that must be analyzed alongside samples for quality control (e.g., OREAS 101a, AMIS 0318, NIST 2709a). Critical for QA/QC protocol compliance.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingUnit rdf:type rdf:Property ;
    rdfs:label 'Reporting Unit' ;
    rdfs:comment 'Standard unit of measure in which analytical results are reported (e.g., ppm for parts per million, g_per_t for grams per tonne, percent for percentage concentration). Aligns with JORC and NI 43-101 reporting standards. [ENUM-REF-CANDIDATE: ppm|ppb|percent|g_per_t|mg_per_l|ug_per_l|oz_per_ton — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePreparationProcedure rdf:type rdf:Property ;
    rdfs:label 'Sample Preparation Procedure' ;
    rdfs:comment 'Description of the required sample preparation steps before analysis (e.g., crushing to -2mm, pulverizing to 90% passing 75 microns, drying at 105°C, pressed pellet formation, fusion bead preparation). Critical for method reproducibility and quality control.' ;
    rdfs:domain ind:AnalyticalMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Standard turnaround time from sample receipt to result reporting, measured in hours. Includes sample preparation, analysis, quality control, and data validation. Used for mine planning and grade control scheduling.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'Maximum concentration or grade that the method can accurately measure without dilution or re-analysis. Samples exceeding this limit require dilution or alternative method.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayResultId rdf:type rdf:Property ;
    rdfs:label 'Assay Result Id' ;
    rdfs:comment 'Unique identifier for each assay result record. Primary key for the assay result entity.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmStandardId rdf:type rdf:Property ;
    rdfs:label 'Crm Standard Id' ;
    rdfs:comment 'Identifier of the certified reference material (CRM) or standard reference material (SRM) used for this QA/QC check, if applicable. Empty for non-standard samples.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrmStandard .

ind:failureReportId rdf:type rdf:Property ;
    rdfs:label 'Failure Report Id' ;
    rdfs:comment 'Foreign key linking to maintenance.failure_report. Business justification: Analytical results from failure investigation samples are critical evidence in root cause analysis and must be traceable to the failure report for engineering decisions, warranty claims, and continuou' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureReport .

ind:gradeControlBlockId rdf:type rdf:Property ;
    rdfs:label 'Grade Control Block Id' ;
    rdfs:comment 'Foreign key linking to mine.grade_control_block. Business justification: Individual assay results classify grade control blocks for ore/waste designation and dispatch routing. Real-world process: grade control block model population and ore classification workflow. New FK ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GradeControlBlock .

ind:instrumentId rdf:type rdf:Property ;
    rdfs:label 'Instrument Id' ;
    rdfs:comment 'Unique identifier of the laboratory instrument used to perform the analysis. Enables traceability and quality control by linking results to specific equipment calibration and maintenance records.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instrument .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Assay results from maintenance-related samples (lubricant chemistry, coolant analysis, material composition verification) must link to work orders for root cause analysis, predictive maintenance decis' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:sampleBatchId rdf:type rdf:Property ;
    rdfs:label 'Sample Batch Id' ;
    rdfs:comment 'Foreign key linking to laboratory.sample_batch. Business justification: Assay results are produced as part of a batch submission. Currently assay_result has batch_number (STRING) but no FK to sample_batch. Adding sample_batch_id FK allows joining to batch-level metadata (' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleBatch .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:comment 'Calculated accuracy of the assay result compared to the expected grade for standard reference materials, expressed as a percentage. Measures systematic bias in the analytical method.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date on which the assay analysis was performed. Critical for tracking sample turnaround time and ensuring results are used within appropriate timeframes for resource estimation and grade control.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'The precise date and time when the assay analysis was completed. Provides granular traceability for quality control and audit purposes.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analyteCode rdf:type rdf:Property ;
    rdfs:label 'Analyte Code' ;
    rdfs:comment 'Standard code representing the element or compound analyzed (e.g., AU for gold, CU for copper, FE for iron, S for sulfur). Follows periodic table symbols or industry-standard compound codes.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteName rdf:type rdf:Property ;
    rdfs:label 'Analyte Name' ;
    rdfs:comment 'Full name of the element or compound analyzed (e.g., Gold, Copper, Iron, Sulfur, Arsenic). Human-readable description of the analyte.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:belowDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Below Detection Flag' ;
    rdfs:comment 'Indicates whether the assay result was below the detection limit of the analytical method. True if below detection, False otherwise. Results flagged as below detection are typically assigned half the detection limit value for statistical purposes.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifiedResultFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Result Flag' ;
    rdfs:comment 'Indicates whether this assay result has been certified and approved for use in JORC/NI 43-101 resource estimation and public reporting. True if certified, False if preliminary or for internal use only.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedGrade rdf:type rdf:Property ;
    rdfs:label 'Expected Grade' ;
    rdfs:comment 'The certified or expected grade value for a standard reference material. Used to calculate accuracy and bias in QA/QC analysis. Null for non-standard samples.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Over Limit Flag' ;
    rdfs:comment 'Indicates whether the initial assay result exceeded the upper detection limit of the analytical method, requiring dilution and re-analysis. True if over limit, False otherwise.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precisionPercent rdf:type rdf:Property ;
    rdfs:label 'Precision Percent' ;
    rdfs:comment 'Calculated precision of the assay result based on duplicate sample analysis, expressed as a percentage. Measures random error and reproducibility of the analytical method.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaqcSampleType rdf:type rdf:Property ;
    rdfs:label 'Qaqc Sample Type' ;
    rdfs:comment 'Identifies the type of QA/QC sample if this result is part of the quality control program. Original indicates a regular production sample; other values indicate QA/QC control samples inserted into the analytical stream.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the assay result was officially reported and released from the laboratory to the requesting party. May differ from analysis date due to quality control review and approval workflows.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedGrade rdf:type rdf:Property ;
    rdfs:label 'Reported Grade' ;
    rdfs:comment 'The final assay grade value reported for the analyte in the sample. This is the primary geochemical measurement used for resource estimation, grade control, and metallurgical balance calculations. May be expressed in various units depending on analyte (ppm, percent, g/t).' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current lifecycle status of the assay result. Preliminary results are for internal use only; final results are certified for resource estimation; cancelled results have been invalidated; superseded results have been replaced by re-analysis.' ;
    rdfs:domain ind:AssayResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterizationLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Characterization Laboratory Id' ;
    rdfs:comment 'Foreign key linking to laboratory.laboratory. Business justification: CRM standards are characterized (certified values determined) at a specific laboratory. Currently crm_standard has characterization_laboratory (STRING) but no FK. Adding characterization_laboratory_id' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:supplierCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Supplier Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Certified reference materials are purchased from specialized suppliers who are counterparties. This link enables purchase order tracking, supplier performance evaluation, certificate verification, inv' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the reference material was officially certified by the supplier or certifying body, as documented on the certificate of analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifiedValueJson rdf:type rdf:Property ;
    rdfs:label 'Certified Value Json' ;
    rdfs:comment 'JSON-formatted string containing certified values for all analytes in the reference material, including element symbol, certified concentration, unit of measure, and uncertainty. Structured as array of objects to support multi-element standards.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmCode rdf:type rdf:Property ;
    rdfs:label 'Crm Code' ;
    rdfs:comment 'Unique business identifier for the certified reference material, typically assigned by the supplier or internal laboratory. Used for sample tracking and quality control workflows.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmName rdf:type rdf:Property ;
    rdfs:label 'Crm Name' ;
    rdfs:comment 'Descriptive name or title of the certified reference material, often including the supplier designation and material type.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmStatus rdf:type rdf:Property ;
    rdfs:label 'Crm Status' ;
    rdfs:comment 'Current lifecycle status of the certified reference material in the laboratory inventory and quality assurance program.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homogeneityStatement rdf:type rdf:Property ;
    rdfs:label 'Homogeneity Statement' ;
    rdfs:comment 'Statement or assessment from the supplier regarding the homogeneity of the reference material, indicating whether it is suitable for the intended sample size and analytical method.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInHouseStandard rdf:type rdf:Property ;
    rdfs:label 'Is In House Standard' ;
    rdfs:comment 'Boolean flag indicating whether this is an in-house prepared reference material (true) or a commercially sourced certified reference material (false). In-house standards are typically prepared from site-specific ore and characterized through round-robin testing.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Physical and chemical composition category of the reference material matrix, indicating the material type it is designed to represent in quality control programs. [ENUM-REF-CANDIDATE: ore|concentrate|tailings|soil|rock|pulp|solution — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum inventory threshold for the certified reference material below which reordering should be triggered to ensure continuity of quality control programs.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Particle Size Description' ;
    rdfs:comment 'Description of the particle size distribution or preparation state of the reference material (e.g., minus 75 micron pulp, coarse reject, -200 mesh), relevant for ensuring homogeneity and representativeness in quality control.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcProgramName rdf:type rdf:Property ;
    rdfs:label 'Qaqc Program Name' ;
    rdfs:comment 'Name or identifier of the quality assurance and quality control program in which this certified reference material is used (e.g., Exploration QA/QC, Grade Control QA/QC, Metallurgical QA/QC).' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockQuantity rdf:type rdf:Property ;
    rdfs:label 'Stock Quantity' ;
    rdfs:comment 'Current quantity of the certified reference material available in laboratory inventory, measured in the unit specified in stock_unit_of_measure.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Stock Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the stock quantity of the certified reference material (e.g., grams, kilograms, vials).' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental conditions for storing the certified reference material to maintain stability and certified values (e.g., temperature range, humidity control, light protection).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityStatement rdf:type rdf:Property ;
    rdfs:label 'Traceability Statement' ;
    rdfs:comment 'Statement describing the metrological traceability of the certified values to international measurement standards or reference materials, as required for compliance with ISO/IEC 17025 and resource reporting codes.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyJson rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Json' ;
    rdfs:comment 'JSON-formatted string containing measurement uncertainty ranges for each certified analyte, including standard deviation, confidence interval, and uncertainty type (e.g., expanded uncertainty at 95% confidence level).' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency' ;
    rdfs:comment 'Recommended or actual frequency at which this certified reference material is inserted into the analytical workflow as part of the quality assurance and quality control (QA/QC) program.' ;
    rdfs:domain ind:CrmStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationScope rdf:type rdf:Property ;
    rdfs:label 'Accreditation Scope' ;
    rdfs:comment 'Description of the accredited scope of testing for this instrument under ISO/IEC 17025 or equivalent laboratory accreditation. Identifies which tests are covered by accreditation.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracySpecification rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification' ;
    rdfs:comment 'Manufacturer\'s accuracy specification or laboratory-validated accuracy for the instrument. Expressed as percentage, absolute value, or relative standard deviation.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMethods rdf:type rdf:Property ;
    rdfs:label 'Applicable Methods' ;
    rdfs:comment 'List of analytical methods or standard operating procedures (SOPs) that this instrument is qualified to perform. May reference industry standards such as ASTM, ISO, or internal method codes.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal asset tag or property number assigned by the organization for fixed asset tracking and inventory management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Standard calibration interval in days as defined by the instrument manufacturer, regulatory requirements, or laboratory quality procedures.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current calibration status of the instrument. In Calibration (calibration in progress), Calibration Passed (within calibration validity period), Calibration Failed (failed last calibration check), Calibration Overdue (past due date), Not Applicable (instrument does not require calibration).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Business identifier code for the instrument used in laboratory operations and reporting. Typically assigned by LIMS or laboratory management.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Human-readable name or designation of the analytical instrument used for identification in laboratory workflows.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent successful calibration performed on the instrument.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCalibrationResult rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Result' ;
    rdfs:comment 'Outcome of the most recent calibration check. Pass (within tolerance), Fail (outside tolerance), Conditional Pass (marginal performance, monitoring required).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationStandard rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Standard' ;
    rdfs:comment 'Identifier or description of the certified reference material or calibration standard used in the most recent calibration.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationTechnician rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Technician' ;
    rdfs:comment 'Name or identifier of the technician who performed the most recent calibration. Required for ISO 17025 traceability.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance performed on the instrument.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location of the instrument within the laboratory facility. Includes building, room number, or laboratory section identifier.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Description of the preventive maintenance schedule for the instrument (e.g., daily, weekly, monthly, quarterly). May reference maintenance procedure documents.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the analytical instrument.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementRangeLower rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Lower' ;
    rdfs:comment 'Lower limit of the instrument\'s measurement range or detection limit. Units depend on instrument type and analyte.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Upper' ;
    rdfs:comment 'Upper limit of the instrument\'s measurement range. Units depend on instrument type and analyte.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next calibration of the instrument. Critical for ISO 17025 compliance and result validity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity on the instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:precisionSpecification rdf:type rdf:Property ;
    rdfs:label 'Precision Specification' ;
    rdfs:comment 'Manufacturer\'s precision specification or laboratory-validated precision (repeatability) for the instrument. Typically expressed as relative standard deviation (RSD) or coefficient of variation (CV).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTechnician rdf:type rdf:Property ;
    rdfs:label 'Responsible Technician' ;
    rdfs:comment 'Name or identifier of the laboratory technician or analyst responsible for the operation and routine maintenance of this instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleThroughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Sample Throughput Capacity' ;
    rdfs:comment 'Maximum number of samples the instrument can process per day under normal operating conditions. Used for capacity planning and scheduling.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceContractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Service Contract Expiry Date' ;
    rdfs:comment 'Expiration date of the current service or maintenance contract. Null if no active contract.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Reference number for the active service or maintenance contract with the manufacturer or third-party service provider.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageHours rdf:type rdf:Property ;
    rdfs:label 'Usage Hours' ;
    rdfs:comment 'Total cumulative operating hours logged for the instrument since commissioning. Used for lifecycle management and maintenance planning.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'The recognized accreditation authority that has certified the laboratory: NATA (National Association of Testing Authorities - Australia), SANAS (South African National Accreditation System), CALA (Canadian Association for Laboratory Accreditation), A2LA (American Association for Laboratory Accreditation), UKAS (United Kingdom Accreditation Service), or ISO/IEC 17025 generic certification.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'The date on which the current accreditation certificate expires and requires renewal or re-assessment.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedAnalyteList rdf:type rdf:Property ;
    rdfs:label 'Approved Analyte List' ;
    rdfs:comment 'Comma-separated list of analytes (elements or compounds) that this laboratory is approved and accredited to analyze (e.g., Au, Cu, Fe, Ni, S, moisture, particle size).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMethodList rdf:type rdf:Property ;
    rdfs:label 'Approved Method List' ;
    rdfs:comment 'Comma-separated list of analytical methods that this laboratory is approved to perform (e.g., fire assay, XRF, ICP-MS, AAS, flotation testwork, leach testwork).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the current service contract or agreement with this laboratory expires or is due for renewal.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the current service contract or agreement with this laboratory commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPerSampleStandard rdf:type rdf:Property ;
    rdfs:label 'Cost Per Sample Standard' ;
    rdfs:comment 'Average contracted cost per sample for standard analytical packages, used for budgeting and laboratory performance benchmarking.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the laboratory in operational systems and sample tracking workflows.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryStatus rdf:type rdf:Property ;
    rdfs:label 'Laboratory Status' ;
    rdfs:comment 'Current operational status of the laboratory: active (approved for use), inactive (not currently used), suspended (temporarily not approved due to quality issues), or under_review (pending audit or accreditation renewal).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryType rdf:type rdf:Property ;
    rdfs:label 'Laboratory Type' ;
    rdfs:comment 'Classification of the laboratory based on its primary function: preparation (sample crushing, splitting), analytical (assay and chemical analysis), metallurgical (process testwork), geochemical (exploration samples), environmental (water, air, soil compliance), or third_party (external commercial laboratory).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent internal or external audit conducted at this laboratory to verify compliance with quality and accreditation standards.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next audit or quality review of the laboratory.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredLaboratoryFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Laboratory Flag' ;
    rdfs:comment 'Indicates whether this laboratory is designated as a preferred provider for specific sample types or programs, based on quality, cost, and turnaround performance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality performance rating based on QA/QC (Quality Assurance/Quality Control) results, proficiency testing, and audit outcomes.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTypeScope rdf:type rdf:Property ;
    rdfs:label 'Sample Type Scope' ;
    rdfs:comment 'Description of the sample types and matrices the laboratory is equipped to handle (e.g., drill core, ROM ore, concentrate, tailings, water, soil, vegetation).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region where the laboratory is located.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeRushDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Rush Days' ;
    rdfs:comment 'Expedited turnaround time in calendar days for priority or rush samples, typically at a premium cost.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeStandardDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Standard Days' ;
    rdfs:comment 'Contracted standard turnaround time in calendar days from sample receipt to result delivery for routine samples, as per the Service Level Agreement (SLA).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blastExecutionId rdf:type rdf:Property ;
    rdfs:label 'Blast Execution Id' ;
    rdfs:comment 'Foreign key linking to mine.blast_execution. Business justification: Post-blast samples verify fragmentation quality and ore/waste classification for blast reconciliation. Real-world process: blast performance analysis and ore loss/dilution assessment. New FK needed as' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlastExecution .

ind:collectionAssetId rdf:type rdf:Property ;
    rdfs:label 'Collection Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Mining operations track which drill rig, excavator, or sampling equipment collected each sample for traceability, equipment performance analysis, and contamination investigation. Critical for grade co' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:duplicateOfSampleLaboratorySampleId rdf:type rdf:Property ;
    rdfs:label 'Duplicate Of Sample Laboratory Sample Id' ;
    rdfs:comment 'Reference to the original sample ID if this sample is a field or lab duplicate. Used to pair duplicates for precision analysis.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaboratorySample .

ind:externalLaboratoryCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'External Laboratory Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Mining operations routinely send samples to external commercial laboratories for independent verification, umpire analysis, and capacity overflow. Tracking the counterparty enables invoice reconciliat' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:sampleProgramId rdf:type rdf:Property ;
    rdfs:label 'Sample Program Id' ;
    rdfs:comment 'Foreign key linking to laboratory.sample_program. Business justification: Every sample is collected under a sampling program or campaign. The sample_program defines the protocol, QA/QC requirements, and analytical suite. Currently laboratory_sample has project_code (STRING)' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleProgram .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Machine-readable barcode assigned by LIMS for automated sample tracking through preparation and analysis workflows. Ensures chain-of-custody integrity.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchName rdf:type rdf:Property ;
    rdfs:label 'Bench Name' ;
    rdfs:comment 'Designation of the mining bench or level from which the sample was collected. Used for grade control and reconciliation workflows.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationEasting rdf:type rdf:Property ;
    rdfs:label 'Location Easting' ;
    rdfs:comment 'Easting coordinate (X) of the sample collection point in the mine coordinate system. Used for spatial analysis and integration with geological models.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationElevation rdf:type rdf:Property ;
    rdfs:label 'Location Elevation' ;
    rdfs:comment 'Elevation (Z) of the sample collection point in meters above sea level. Completes the 3D spatial coordinates for geological modeling.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationNorthing rdf:type rdf:Property ;
    rdfs:label 'Location Northing' ;
    rdfs:comment 'Northing coordinate (Y) of the sample collection point in the mine coordinate system. Used for spatial analysis and integration with geological models.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparationMethod rdf:type rdf:Property ;
    rdfs:label 'Preparation Method' ;
    rdfs:comment 'Sample preparation technique applied before analysis. Crush and split for coarse reduction; pulverize for fine grinding; dry for moisture removal; wet screen for size separation; no prep for direct analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStreamName rdf:type rdf:Property ;
    rdfs:label 'Process Stream Name' ;
    rdfs:comment 'Name of the processing plant stream from which the sample was collected (e.g., ROM feed, crusher discharge, flotation concentrate, tailings). Applicable for process stream samples.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pulpWeightG rdf:type rdf:Property ;
    rdfs:label 'Pulp Weight G' ;
    rdfs:comment 'Weight in grams of the pulverized sample (pulp) prepared for assay analysis. Typically 200-500g depending on analytical method and commodity.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the sample was received and registered in the laboratory LIMS. Used to track turnaround time and chain-of-custody.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days the sample or its pulp must be retained before disposal, as per regulatory or company policy. Typically 90-365 days depending on sample type and jurisdiction.' ;
    rdfs:domain ind:LaboratorySample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metallurgicalTestId rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Test Id' ;
    rdfs:comment 'Unique identifier for the metallurgical test record. Primary key.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Metallurgical test work uses specific pilot plant equipment (lab-scale crushers, mills, flotation cells, leach reactors) that must be tracked for test result validation, equipment calibration history,' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:testOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Test Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Metallurgical test execution requires operator tracking for competency verification, QA/QC accountability, and regulatory compliance (JORC/NI 43-101). Test validity depends on qualified personnel perf' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abrasionIndex rdf:type rdf:Property ;
    rdfs:label 'Abrasion Index' ;
    rdfs:comment 'Measure of ore abrasiveness, indicating wear on grinding media and mill liners. Derived from Bond Abrasion Index test.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondWorkIndexKwhPerTonne rdf:type rdf:Property ;
    rdfs:label 'Bond Work Index Kwh Per Tonne' ;
    rdfs:comment 'Bond Ball Mill Work Index (BWi) or Bond Rod Mill Work Index (RWi) result, measured in kilowatt-hours per tonne. Indicates ore hardness and energy required for comminution.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateMassKg rdf:type rdf:Property ;
    rdfs:label 'Concentrate Mass Kg' ;
    rdfs:comment 'Mass of concentrate product produced from the test, measured in kilograms. Applicable to flotation and DMS tests.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Extraction Rate Percent' ;
    rdfs:comment 'Percentage of target commodity extracted into solution during leach test. Equivalent to recovery rate for leach processes.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGradePercent rdf:type rdf:Property ;
    rdfs:label 'Feed Grade Percent' ;
    rdfs:comment 'Assayed grade of the target commodity in the feed sample, expressed as percentage. For example, 1.25% Cu or 2.5 g/t Au converted to percent.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedMassKg rdf:type rdf:Property ;
    rdfs:label 'Feed Mass Kg' ;
    rdfs:comment 'Total mass of ore sample fed into the metallurgical test, measured in kilograms.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedP80Microns rdf:type rdf:Property ;
    rdfs:label 'Feed P80 Microns' ;
    rdfs:comment 'Particle size distribution metric for feed material: 80% passing size in microns. Critical parameter for comminution and flotation tests.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flotationPh rdf:type rdf:Property ;
    rdfs:label 'Flotation Ph' ;
    rdfs:comment 'pH level maintained during flotation test. Critical process parameter affecting mineral surface chemistry and reagent performance.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flotationReagentType rdf:type rdf:Property ;
    rdfs:label 'Flotation Reagent Type' ;
    rdfs:comment 'Primary reagent or reagent suite used in flotation tests. Examples: xanthate, dithiophosphate, frother (MIBC, DF250), depressant (lime, sodium silicate), activator (copper sulfate).' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flotationTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Flotation Time Minutes' ;
    rdfs:comment 'Total flotation residence time in minutes. Includes rougher, scavenger, and cleaner stages for locked cycle tests.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grindSizeP80Microns rdf:type rdf:Property ;
    rdfs:label 'Grind Size P80 Microns' ;
    rdfs:comment 'Target or achieved grind size (80% passing) for the test, measured in microns. Critical for flotation and leach tests.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachDurationHours rdf:type rdf:Property ;
    rdfs:label 'Leach Duration Hours' ;
    rdfs:comment 'Total duration of the leach test, measured in hours. Includes all stages for multi-stage leach tests.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachEhMillivolts rdf:type rdf:Property ;
    rdfs:label 'Leach Eh Millivolts' ;
    rdfs:comment 'Oxidation-reduction potential (Eh) maintained during leach test, measured in millivolts. Critical for controlling oxidation state of dissolved metals.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachPh rdf:type rdf:Property ;
    rdfs:label 'Leach Ph' ;
    rdfs:comment 'pH level maintained during leach test. Critical for controlling reaction chemistry and metal solubility.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachSolutionConcentration rdf:type rdf:Property ;
    rdfs:label 'Leach Solution Concentration' ;
    rdfs:comment 'Concentration of the leaching reagent in solution, typically expressed in grams per liter (g/L) or molarity (M).' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachSolutionType rdf:type rdf:Property ;
    rdfs:label 'Leach Solution Type' ;
    rdfs:comment 'Lixiviant or leaching solution used in the test. Examples: sulfuric acid (H2SO4), cyanide (NaCN), ammonia, ferric chloride, thiosulfate.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Leach Temperature Celsius' ;
    rdfs:comment 'Temperature maintained during leach test, measured in degrees Celsius. Critical for reaction kinetics.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGradePercent rdf:type rdf:Property ;
    rdfs:label 'Product Grade Percent' ;
    rdfs:comment 'Assayed grade of the target commodity in the final product (concentrate, leach residue, or extracted solution), expressed as percentage.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionGPerTonne rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption G Per Tonne' ;
    rdfs:comment 'Total reagent consumption for the test, measured in grams per tonne of ore processed. Critical for operating cost estimation.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smcTestParameterA rdf:type rdf:Property ;
    rdfs:label 'Smc Test Parameter A' ;
    rdfs:comment 'SAG Mill Comminution test parameter A, representing ore competence. Used in SAG mill design and modeling.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smcTestParameterB rdf:type rdf:Property ;
    rdfs:label 'Smc Test Parameter B' ;
    rdfs:comment 'SAG Mill Comminution test parameter B, representing ore abrasion. Used in SAG mill design and modeling.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsGradePercent rdf:type rdf:Property ;
    rdfs:label 'Tailings Grade Percent' ;
    rdfs:comment 'Assayed grade of the target commodity remaining in the tailings or waste stream, expressed as percentage. Indicates losses.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when the metallurgical test program was completed and results finalized.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testConditionsNotes rdf:type rdf:Property ;
    rdfs:label 'Test Conditions Notes' ;
    rdfs:comment 'Free-text field capturing additional test conditions, parameters, or observations not covered by structured fields. Examples: agitation speed, solid-liquid ratio, oxygen partial pressure, multi-stage configurations.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Externally-known unique identifier or work order number for the metallurgical test program, used for tracking and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testObjective rdf:type rdf:Property ;
    rdfs:label 'Test Objective' ;
    rdfs:comment 'Business purpose and goals of the metallurgical test program. Examples: process design, feasibility study, plant optimization, ore variability characterization, flowsheet development.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Document reference number or file path to the detailed metallurgical test report containing full methodology, results, and interpretation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when the metallurgical test program commenced.' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the metallurgical test program.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSubtype rdf:type rdf:Property ;
    rdfs:label 'Test Subtype' ;
    rdfs:comment 'Specific test method or procedure within the test type category. Examples: Bond Ball Mill Work Index (BWi), Bond Rod Mill Work Index (RWi), SAG Mill Comminution (SMC) test, JK Drop Weight test, batch flotation, locked cycle flotation, bottle roll leach, column leach, heap leach, agitation leach, Carbon-In-Leach (CIL), Carbon-In-Pulp (CIP), High Pressure Grinding Rolls (HPGR), Dense Media Separation (DMS), Solvent Extraction Electrowinning (SX-EW).' ;
    rdfs:domain ind:MetallurgicalTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'High-level category of metallurgical test conducted. Comminution includes Bond Work Index, SAG Mill Comminution, JK Drop Weight, HPGR, Abrasion Index. Flotation includes batch and locked cycle tests. Leach includes bottle roll, column, heap, agitation, CIL/CIP, SX-EW.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcResultId rdf:type rdf:Property ;
    rdfs:label 'Qaqc Result Id' ;
    rdfs:comment 'Unique identifier for the QA/QC result record. Primary key for the qaqc_result data product.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qaqcSampleId rdf:type rdf:Property ;
    rdfs:label 'Qaqc Sample Id' ;
    rdfs:comment 'Reference to the control sample that was analyzed. Links to the sample record in the Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QaqcSample .

ind:absoluteDifference rdf:type rdf:Property ;
    rdfs:label 'Absolute Difference' ;
    rdfs:comment 'The absolute difference between the reported value and expected value. Calculated as |reported_value - expected_value|. Used for low-grade samples where relative measures may be misleading.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyte rdf:type rdf:Property ;
    rdfs:label 'Analyte' ;
    rdfs:comment 'The element or compound being measured in the QA/QC sample (e.g., Au, Cu, Fe, SiO2). Represents the target mineral or geochemical parameter.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biasFlag rdf:type rdf:Property ;
    rdfs:label 'Bias Flag' ;
    rdfs:comment 'Boolean flag indicating whether systematic bias has been detected in the analytical results. True indicates bias is present (consistently high or low results), false indicates no bias detected.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Boolean flag indicating whether contamination has been detected based on blank sample results. True indicates contamination is present, false indicates no contamination detected.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlSampleNumber rdf:type rdf:Property ;
    rdfs:label 'Control Sample Number' ;
    rdfs:comment 'The unique identifier or barcode assigned to the physical QA/QC control sample submitted for analysis.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlSampleType rdf:type rdf:Property ;
    rdfs:label 'Control Sample Type' ;
    rdfs:comment 'Type of QA/QC control sample analyzed. Blank samples detect contamination, standards verify calibration, duplicates assess precision, and certified reference materials (CRM) verify accuracy.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedValue rdf:type rdf:Property ;
    rdfs:label 'Expected Value' ;
    rdfs:comment 'The expected or certified value for the control sample. For standards and certified reference materials (CRM), this is the known concentration. For blanks, this is typically zero. For duplicates, this is the original sample value.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the QA/QC result failed acceptance criteria. Includes specific metrics that were out of range and potential root causes identified during investigation.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jorcTable1Reference rdf:type rdf:Property ;
    rdfs:label 'Jorc Table 1 Reference' ;
    rdfs:comment 'Reference to the specific section of the JORC Code Table 1 documentation where this QA/QC result is disclosed. Required for public reporting of mineral resources and ore reserves.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerControlLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Control Limit' ;
    rdfs:comment 'The lower acceptable threshold for the QA/QC result. Values below this limit indicate a potential quality issue requiring investigation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'The overall assessment of whether the QA/QC result meets acceptance criteria. Pass indicates the result is within control limits, fail indicates a quality issue, warning indicates borderline performance, and under investigation indicates pending review.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentRelativeDifference rdf:type rdf:Property ;
    rdfs:label 'Percent Relative Difference' ;
    rdfs:comment 'The relative difference between reported and expected values expressed as a percentage. Calculated as ((reported_value - expected_value) / expected_value) * 100. Key metric for duplicate precision assessment.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precisionFlag rdf:type rdf:Property ;
    rdfs:label 'Precision Flag' ;
    rdfs:comment 'Boolean flag indicating whether precision issues have been detected based on duplicate sample results. True indicates poor precision (high variability), false indicates acceptable precision.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedValue rdf:type rdf:Property ;
    rdfs:label 'Reported Value' ;
    rdfs:comment 'The analytical result value reported by the laboratory for this QA/QC control sample. Measured in the unit of measure specified for the analyte.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceEstimationApproved rdf:type rdf:Property ;
    rdfs:label 'Resource Estimation Approved' ;
    rdfs:comment 'Boolean flag indicating whether the associated analytical batch has been approved for use in resource estimation based on QA/QC performance. True indicates data is suitable for JORC resource calculations, false indicates data quality issues prevent use.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Additional comments or observations recorded by the reviewer during the QA/QC assessment. May include context for borderline results or justification for acceptance decisions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'The name or identifier of the qualified person (QP) or laboratory supervisor who reviewed and approved the QA/QC result assessment. Required for JORC Table 1 compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperControlLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Control Limit' ;
    rdfs:comment 'The upper acceptable threshold for the QA/QC result. Values above this limit indicate a potential quality issue requiring investigation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The number of standard deviations the reported value is from the expected value. Calculated as (reported_value - expected_value) / standard_deviation. Used to assess the statistical significance of deviations.' ;
    rdfs:domain ind:QaqcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayResult rdf:type rdf:Property ;
    rdfs:label 'Assay Result' ;
    rdfs:comment 'Actual analytical result returned by the laboratory for this QA/QC sample, expressed in the same unit as expected_grade. Compared against expected_grade and tolerance limits to determine pass/fail status and calculate bias/precision metrics.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayResultUnit rdf:type rdf:Property ;
    rdfs:label 'Assay Result Unit' ;
    rdfs:comment 'Unit of measure for the assay result. Must match expected_grade_unit for valid comparison. Percent (%) for major elements, parts per million (ppm) for trace elements, grams per tonne (g/t) for precious metals.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReanalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Reanalysis Required' ;
    rdfs:comment 'Boolean flag indicating whether the entire sample batch must be reanalyzed due to systematic QA/QC failure (e.g., multiple CRM failures, blank contamination, duplicate precision failure). True triggers batch rejection and resubmission workflow.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biasPercent rdf:type rdf:Property ;
    rdfs:label 'Bias Percent' ;
    rdfs:comment 'Calculated percentage difference between assay_result and expected_grade, expressed as ((assay_result - expected_grade) / expected_grade) * 100. Positive values indicate over-reporting, negative values indicate under-reporting. Used to assess laboratory accuracy and systematic error.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedStandardDeviation rdf:type rdf:Property ;
    rdfs:label 'Certified Standard Deviation' ;
    rdfs:comment 'Certified standard deviation for CRM samples as documented in the supplier certificate. Null for non-CRM QA/QC sample types. Used to calculate statistical control limits and assess laboratory precision against certified variability.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Expected Grade Unit' ;
    rdfs:comment 'Unit of measure for the expected grade value. Percent (%) for major elements, parts per million (ppm) for trace elements, grams per tonne (g/t) for precious metals, ounces per ton (oz/t) for imperial systems, milligrams per kilogram (mg/kg) for environmental samples.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insertionRatio rdf:type rdf:Property ;
    rdfs:label 'Insertion Ratio' ;
    rdfs:comment 'Target insertion frequency of this QA/QC sample type expressed as a percentage of total samples (e.g., 5.00 means 1 in 20 samples). Used to validate compliance with QA/QC protocols and JORC/NI 43-101 requirements.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertionSequence rdf:type rdf:Property ;
    rdfs:label 'Insertion Sequence' ;
    rdfs:comment 'Sequential position of the QA/QC sample within the batch submission stream. Used to verify insertion frequency and systematic placement per QA/QC protocols (e.g., 1 CRM per 20 samples, 1 blank per 40 samples).' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Free-text field documenting investigation findings, root cause analysis, and corrective actions taken for failed QA/QC samples. Null if no investigation required. Critical for audit trails and continuous improvement.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequired rdf:type rdf:Property ;
    rdfs:label 'Investigation Required' ;
    rdfs:comment 'Boolean flag indicating whether this QA/QC result requires formal investigation due to failure, systematic bias, or contamination. True triggers investigation workflow per JORC/NI 43-101 requirements.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryJobNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Job Number' ;
    rdfs:comment 'External job or work order number assigned by the laboratory for this batch submission. Used for cross-referencing with laboratory certificates and invoices.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcSampleNumber rdf:type rdf:Property ;
    rdfs:label 'Qaqc Sample Number' ;
    rdfs:comment 'Externally-known unique identifier for the QA/QC sample, typically following laboratory naming conventions (e.g., CRM-2023-001, BLK-001, DUP-045). Used for sample tracking and audit trails.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLower rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower' ;
    rdfs:comment 'Lower acceptable limit for assay results, typically defined as expected_grade minus acceptable variance (e.g., 2 standard deviations for CRMs, detection limit for blanks). Results below this threshold trigger QA/QC failure flags and investigation.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceType rdf:type rdf:Property ;
    rdfs:label 'Tolerance Type' ;
    rdfs:comment 'Method used to define tolerance limits. Absolute uses fixed grade units, relative_percent uses percentage of expected grade, standard_deviation uses statistical variance from certified mean. Determines how tolerance_lower and tolerance_upper are calculated.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceUpper rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper' ;
    rdfs:comment 'Upper acceptable limit for assay results, typically defined as expected_grade plus acceptable variance (e.g., 2 standard deviations for CRMs, maximum contamination threshold for blanks). Results above this threshold trigger QA/QC failure flags and investigation.' ;
    rdfs:domain ind:QaqcSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValidationId rdf:type rdf:Property ;
    rdfs:label 'Result Validation Id' ;
    rdfs:comment 'Unique identifier for the result validation record. Primary key.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validator Employee Id' ;
    rdfs:comment 'Internal employee identifier of the validator, linking to the HR system for competency verification and audit purposes.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blankContaminationCheck rdf:type rdf:Property ;
    rdfs:label 'Blank Contamination Check' ;
    rdfs:comment 'Indicates whether blank samples showed acceptable low contamination levels. True if passed (no contamination detected), False if failed (contamination detected).' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicatePrecisionCheck rdf:type rdf:Property ;
    rdfs:label 'Duplicate Precision Check' ;
    rdfs:comment 'Indicates whether duplicate samples met precision acceptance criteria (e.g., relative percent difference within acceptable limits). True if passed, False if failed.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peerReviewDate rdf:type rdf:Property ;
    rdfs:label 'Peer Review Date' ;
    rdfs:comment 'Date on which the peer review was completed. Populated only when peer review was performed.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peerReviewerName rdf:type rdf:Property ;
    rdfs:label 'Peer Reviewer Name' ;
    rdfs:comment 'Name of the peer reviewer who independently reviewed the validation, if peer review was performed. Used for additional quality assurance on critical validations.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcPassRatePercent rdf:type rdf:Property ;
    rdfs:label 'Qaqc Pass Rate Percent' ;
    rdfs:comment 'Percentage of QA/QC samples (standards, duplicates, blanks) that passed acceptance criteria during this validation. Used to quantify the quality of the assay batch.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes documenting any qualifications, conditions, or limitations applied to the validated results. Used when validation outcome is \'qualified\' to explain the nature of the qualification and any restrictions on data use.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDeviationCheck rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation Check' ;
    rdfs:comment 'Indicates whether the assay results passed statistical standard deviation checks against certified reference materials (CRMs). True if passed, False if failed.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'The method or technique used to validate the assay results. Indicates the type of quality control check performed (e.g., statistical analysis of QA/QC samples, comparison with certified reference materials, visual inspection of data patterns, peer review). [ENUM-REF-CANDIDATE: statistical_review|qaqc_check|visual_inspection|duplicate_comparison|standard_comparison|blank_check|peer_review|automated_rule — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Number' ;
    rdfs:comment 'Externally-known unique business identifier for this validation event, used for audit trail and traceability.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Final outcome of the validation process: accepted (results approved for use), rejected (results failed validation), or qualified (results accepted with conditions or limitations).' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Validation Software Version' ;
    rdfs:comment 'Version of the LIMS or validation software used to perform the validation. Important for audit trail and reproducibility of validation decisions.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Precise timestamp when the validation was completed, including time-of-day. Used for detailed audit trail and chronological sequencing of validation events.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validatorName rdf:type rdf:Property ;
    rdfs:label 'Validator Name' ;
    rdfs:comment 'Full name of the competent person (geologist, metallurgist, or laboratory manager) who performed and signed off on the validation. Required for JORC, NI 43-101, and SAMREC competent person requirements.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatorProfessionalRegistration rdf:type rdf:Property ;
    rdfs:label 'Validator Professional Registration' ;
    rdfs:comment 'Professional registration or membership number of the validator with a recognized professional body (e.g., AusIMM, CIM, SACNASP). Required to demonstrate competent person status under JORC, NI 43-101, and SAMREC.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatorRole rdf:type rdf:Property ;
    rdfs:label 'Validator Role' ;
    rdfs:comment 'Professional role or title of the validator. Indicates the authority and competency level of the person performing the validation.' ;
    rdfs:domain ind:ResultValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBatchSampleBatchId rdf:type rdf:Property ;
    rdfs:label 'Original Batch Sample Batch Id' ;
    rdfs:comment 'Reference to the original sample batch identifier if this batch is a reanalysis. Enables traceability and comparison of original versus repeat results.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleBatch .

ind:primarySampleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sample Employee Id' ;
    rdfs:comment 'User identifier of the person who submitted the batch to the laboratory. Provides accountability and contact point for batch-related queries.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftProductionRunId rdf:type rdf:Property ;
    rdfs:label 'Shift Production Run Id' ;
    rdfs:comment 'Foreign key linking to processing.shift_production_run. Business justification: Associates laboratory sample batches with production shifts for reconciliation, performance reporting, and tracking sample turnaround against shift schedules. Standard practice for metallurgical accou' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftProductionRun .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Precise date and time when the batch processing was completed. Enables detailed turnaround time analysis and workflow optimization.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchComments rdf:type rdf:Property ;
    rdfs:label 'Batch Comments' ;
    rdfs:comment 'Free-text field for laboratory technicians and supervisors to record observations, issues, deviations, or special handling instructions related to the batch.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the sample batch. Tracks progression through laboratory workflow from creation to final release of results.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch based on the analytical or preparation process. Determines the workflow and equipment requirements.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchWeightKg rdf:type rdf:Property ;
    rdfs:label 'Batch Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of all sample material in the batch. Used for material tracking and laboratory capacity planning.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedTurnaroundDate rdf:type rdf:Property ;
    rdfs:label 'Expected Turnaround Date' ;
    rdfs:comment 'Target completion date based on the laboratory Service Level Agreement (SLA) and batch priority. Used for planning and performance monitoring.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalLaboratoryFlag rdf:type rdf:Property ;
    rdfs:label 'External Laboratory Flag' ;
    rdfs:comment 'Indicates whether the batch was processed by an external third-party laboratory. True if external, False if processed in-house.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaqcComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Qaqc Compliance Flag' ;
    rdfs:comment 'Indicates whether the batch meets the required Quality Assurance/Quality Control (QA/QC) insertion rate and protocol compliance. True if compliant, False if non-compliant.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaqcInsertionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Qaqc Insertion Rate Percent' ;
    rdfs:comment 'Percentage of Quality Assurance/Quality Control (QA/QC) samples relative to total samples in the batch. Used to verify compliance with laboratory quality standards.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaqcSampleCount rdf:type rdf:Property ;
    rdfs:label 'Qaqc Sample Count' ;
    rdfs:comment 'Number of Quality Assurance/Quality Control (QA/QC) samples (blanks, standards, duplicates, certified reference materials) inserted into the batch for quality validation.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reanalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Flag' ;
    rdfs:comment 'Indicates whether this batch is a reanalysis or repeat of a previous batch due to Quality Assurance/Quality Control (QA/QC) failure or data quality concerns. True if reanalysis, False if original analysis.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the batch results were formally released and made available to downstream systems and users after Quality Assurance/Quality Control (QA/QC) approval.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Precise date and time when batch results were released. Critical for audit trail and data lineage tracking.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Business unit or department that requested the batch analysis (e.g., Exploration, Mine Operations, Mineral Processing). Used for cost allocation and reporting.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleOriginType rdf:type rdf:Property ;
    rdfs:label 'Sample Origin Type' ;
    rdfs:comment 'Classification of the source or origin of samples in the batch. Determines the analytical requirements and data usage downstream.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the batch was completed within the agreed Service Level Agreement (SLA) turnaround time. True if compliant, False if breached.' ;
    rdfs:domain ind:SampleBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleDispatchId rdf:type rdf:Property ;
    rdfs:label 'Sample Dispatch Id' ;
    rdfs:comment 'Unique identifier for the sample dispatch record. Primary key for the sample dispatch entity.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Destination Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Sample dispatch to external laboratories requires counterparty linkage for chain of custody documentation, commercial terms enforcement, insurance claims, and dispute resolution. Essential for trackin' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:destinationLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Destination Laboratory Id' ;
    rdfs:comment 'FK to laboratory.laboratory' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:dispatchPreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Chain of custody tracking is a regulatory requirement in mining sample management. Dispatch preparation must be traceable to a specific employee for audit trails, quality assurance, and accountability' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transportAssetId rdf:type rdf:Property ;
    rdfs:label 'Transport Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Sample dispatch to external laboratories uses mine-owned transport vehicles (light vehicles, sample trucks) that must be tracked for chain-of-custody compliance, transport cost allocation, and logisti' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Actual date when the laboratory confirmed receipt of the sample batch. Null until receipt is confirmed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the laboratory logged receipt of the sample batch in their LIMS system.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisSuiteRequested rdf:type rdf:Property ;
    rdfs:label 'Analysis Suite Requested' ;
    rdfs:comment 'Description or code of the analytical test suite requested for this sample batch (e.g., fire assay, XRF multi-element, leach test).' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Document Reference' ;
    rdfs:comment 'Reference number or identifier of the chain-of-custody documentation accompanying the sample dispatch. Critical for audit trail and sample integrity verification.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courierName rdf:type rdf:Property ;
    rdfs:label 'Courier Name' ;
    rdfs:comment 'Name of the courier or transport service provider responsible for transporting the sample batch.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Courier Reference Number' ;
    rdfs:comment 'Tracking or consignment number provided by the courier service for shipment tracking and proof of delivery.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Dispatch Authorized By' ;
    rdfs:comment 'Name or identifier of the supervisor or geologist who authorized the sample dispatch. Required for chain-of-custody compliance.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Cost Estimate' ;
    rdfs:comment 'Estimated total cost for this sample dispatch including courier fees, laboratory analysis charges, and handling costs. Used for budget tracking.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special circumstances related to the sample dispatch.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Number' ;
    rdfs:comment 'Externally-known unique business identifier for the sample dispatch batch. Used for tracking and reference in chain-of-custody documentation.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchPurpose rdf:type rdf:Property ;
    rdfs:label 'Dispatch Purpose' ;
    rdfs:comment 'Business purpose or program for which the samples are being dispatched. Determines priority and analysis requirements.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchStatus rdf:type rdf:Property ;
    rdfs:label 'Dispatch Status' ;
    rdfs:comment 'Current lifecycle status of the sample dispatch. Tracks the dispatch from preparation through to laboratory receipt confirmation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Precise date and time when the sample batch was handed over to the courier or transport service. Used for turnaround time calculations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'Anticipated date when the laboratory is expected to receive the sample batch. Used for planning and turnaround time monitoring.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Specific location or facility within the origin site where samples were prepared and dispatched from (e.g., core shed, sample preparation plant).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSiteCode rdf:type rdf:Property ;
    rdfs:label 'Origin Site Code' ;
    rdfs:comment 'Code identifying the mine site or facility from which the samples were dispatched. Links to site master data.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Description of the packaging method used for the sample dispatch (e.g., sealed bags, core boxes, drums, crates).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptConfirmationBy rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmation By' ;
    rdfs:comment 'Name or identifier of the laboratory personnel who confirmed receipt and logged the sample batch into the LIMS system.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Requested Turnaround Days' ;
    rdfs:comment 'Number of business days requested for laboratory analysis completion from receipt date. Used for scheduling and performance monitoring.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleConditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Sample Condition On Receipt' ;
    rdfs:comment 'Assessment of the physical condition and integrity of samples upon receipt at the laboratory. Documents any damage or contamination during transport.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any special requirements or instructions for sample handling, storage, or analysis (e.g., keep refrigerated, handle as hazardous, rush processing).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the dispatched sample batch in kilograms, including packaging. Used for freight costing and logistics.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMethod rdf:type rdf:Property ;
    rdfs:label 'Transport Method' ;
    rdfs:comment 'Mode of transportation used to move the sample batch from origin to destination laboratory.' ;
    rdfs:domain ind:SampleDispatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePreparationId rdf:type rdf:Property ;
    rdfs:label 'Sample Preparation Id' ;
    rdfs:comment 'Unique identifier for the sample preparation record. Primary key.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Time Hours' ;
    rdfs:comment 'Actual time taken to complete the preparation, measured in hours. Used for performance monitoring and SLA compliance.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Boolean flag indicating whether chain-of-custody was verified and maintained during preparation. True if verified, false otherwise.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Contamination Risk Level' ;
    rdfs:comment 'Assessment of contamination risk during preparation based on equipment history, sample type, and preparation method. Used for contamination investigation.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Drying Duration Minutes' ;
    rdfs:comment 'Duration for which the sample was dried, measured in minutes. Ensures consistent moisture removal across samples.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dryingTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Drying Temperature Celsius' ;
    rdfs:comment 'Temperature at which the sample was dried during preparation, measured in degrees Celsius. Critical for moisture removal and sample stability.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSampleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Original Sample Weight Kg' ;
    rdfs:comment 'Weight of the original sample received for preparation, measured in kilograms. Baseline for mass balance calculations.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeActualMicrons rdf:type rdf:Property ;
    rdfs:label 'Particle Size Actual Microns' ;
    rdfs:comment 'Actual particle size achieved after preparation, measured in microns. Used to verify preparation quality and compliance with analytical requirements.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:particleSizeTargetMicrons rdf:type rdf:Property ;
    rdfs:label 'Particle Size Target Microns' ;
    rdfs:comment 'Target particle size for the prepared sample, measured in microns. Defines the fineness required for subsequent analytical methods.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Date on which the sample preparation was performed. Critical for chain-of-custody tracking and sample integrity assessment.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Preparation Method Code' ;
    rdfs:comment 'Standardized code identifying the preparation method applied (e.g., CRUSH, PULV, SPLIT, DRY, SIEVE). Defines the specific preparation protocol used.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Preparation Method Description' ;
    rdfs:comment 'Detailed description of the preparation method applied, including specific steps, equipment settings, and protocols followed.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationNotes rdf:type rdf:Property ;
    rdfs:label 'Preparation Notes' ;
    rdfs:comment 'Free-text notes capturing any deviations, observations, or issues encountered during sample preparation. Supports investigation and audit trails.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationPriority rdf:type rdf:Property ;
    rdfs:label 'Preparation Priority' ;
    rdfs:comment 'Priority level assigned to the sample preparation, determining processing sequence and turnaround time.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationStatus rdf:type rdf:Property ;
    rdfs:label 'Preparation Status' ;
    rdfs:comment 'Current status of the sample preparation workflow. Tracks progress from initiation to completion.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Preparation Timestamp' ;
    rdfs:comment 'Precise date and time when the sample preparation was completed. Supports detailed chain-of-custody and workflow tracking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pulpWeightKg rdf:type rdf:Property ;
    rdfs:label 'Pulp Weight Kg' ;
    rdfs:comment 'Weight of the fine pulp or prepared sample after preparation, measured in kilograms. This is the material sent for analysis.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectWeightKg rdf:type rdf:Property ;
    rdfs:label 'Reject Weight Kg' ;
    rdfs:comment 'Weight of the coarse reject material removed during preparation (e.g., after crushing or sieving), measured in kilograms. Used for mass balance verification.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sieveSizeMesh rdf:type rdf:Property ;
    rdfs:label 'Sieve Size Mesh' ;
    rdfs:comment 'Mesh size of the sieve used during preparation (e.g., 100, 200, 400 mesh). Defines the particle size separation applied.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splittingMethod rdf:type rdf:Property ;
    rdfs:label 'Splitting Method' ;
    rdfs:comment 'Method used to split or sub-sample the prepared material (e.g., riffle splitter, rotary splitter, cone and quarter). Ensures representative sub-sampling.' ;
    rdfs:domain ind:SamplePreparation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Consultation Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Sample programs on traditional lands require stakeholder consultation and FPIC. Indigenous groups and landowners are consulted before drilling/sampling campaigns commence. This link tracks which stake' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:hseLegalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hse Legal Register Id' ;
    rdfs:comment 'Foreign key linking to hse.legal_register. Business justification: Sampling programs must comply with specific legislation (MSHA respirable dust sampling, state EPA tailings monitoring). Links program design to legal obligation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalRegister .

ind:stageGateId rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Id' ;
    rdfs:comment 'Foreign key linking to project.stage_gate. Business justification: Sample programs are tied to stage-gate milestones with defined deliverables (e.g., PFS requires infill drilling, FS requires metallurgical testwork). Stage-gate criteria include completion of specifie' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StageGate .

ind:actualSampleCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Count' ;
    rdfs:comment 'Actual number of samples collected to date under this program, excluding QA/QC samples. Updated as sampling progresses.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticalSuiteSpecification rdf:type rdf:Property ;
    rdfs:label 'Analytical Suite Specification' ;
    rdfs:comment 'Specification of which analytes and analytical methods apply to samples collected under this program, such as \'Fire Assay Au + ICP-MS multi-element\' or \'XRF Fe, SiO2, Al2O3, P, S + LOI\'.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blankInsertionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Blank Insertion Rate Percent' ;
    rdfs:comment 'Specific insertion rate for blank samples to detect contamination, typically 2-5% of total samples.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateInsertionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duplicate Insertion Rate Percent' ;
    rdfs:comment 'Specific insertion rate for field or laboratory duplicate samples to assess sampling and analytical precision, typically 5-10% of total samples.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSampleCount rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Count' ;
    rdfs:comment 'Target number of samples to be collected under this program, excluding QA/QC samples.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the sample program objectives, scope, and methodology, including geological targets, sampling density, and expected outcomes.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this sample program is subject to regulatory reporting requirements under JORC, NI 43-101, SEC S-K 1300, or SAMREC codes (True) or is for internal operational purposes only (False).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSecurityLevel rdf:type rdf:Property ;
    rdfs:label 'Sample Security Level' ;
    rdfs:comment 'Security classification for samples in this program: standard (normal handling), high_value (precious metals requiring secure transport), or confidential (exploration samples requiring restricted access).' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Sampling Protocol Reference' ;
    rdfs:comment 'Reference to the documented sampling protocol or Standard Operating Procedure (SOP) that governs sample collection, handling, and chain of custody for this program.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardInsertionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Standard Insertion Rate Percent' ;
    rdfs:comment 'Specific insertion rate for certified reference material (CRM) standards to monitor analytical accuracy, typically 5-10% of total samples.' ;
    rdfs:domain ind:SampleProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundPriority rdf:type rdf:Property ;
    rdfs:label 'Turnaround Priority' ;
    rdfs:comment 'Priority level for laboratory turnaround time: routine (standard turnaround), expedited (faster than standard), urgent (high priority), or critical (immediate processing required for operational decisions).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleResubmissionId rdf:type rdf:Property ;
    rdfs:label 'Sample Resubmission Id' ;
    rdfs:comment 'Unique identifier for the sample resubmission event. Primary key for the sample resubmission product.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Assigned Laboratory Id' ;
    rdfs:comment 'Reference to the laboratory facility assigned to perform the re-analysis. May be the same laboratory as the original analysis or a different laboratory for umpire assay purposes.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:primarySampleAssayResultId rdf:type rdf:Property ;
    rdfs:label 'Primary Sample Assay Result Id' ;
    rdfs:comment 'Reference to the original assay result that triggered the resubmission. Links to the initial analytical result record that failed QA/QC or required verification.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayResult .

ind:tertiarySampleCompetentPersonSignoffUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sample Competent Person Signoff User Employee Id' ;
    rdfs:comment 'User identifier of the JORC or NI 43-101 competent person who reviewed and signed off on the final result validation decision.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySampleFinalAcceptedResultAssayResultId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sample Final Accepted Result Assay Result Id' ;
    rdfs:comment 'Reference to the final accepted assay result after competent person review and sign-off. May be the new result, the original result, or an average of multiple results depending on the validation decision.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayResult .

ind:deviationMagnitude rdf:type rdf:Property ;
    rdfs:label 'Deviation Magnitude' ;
    rdfs:comment 'Calculated magnitude of deviation from expected value or tolerance limit, expressed as percentage or absolute difference depending on the QA/QC protocol.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newResultReceivedDate rdf:type rdf:Property ;
    rdfs:label 'New Result Received Date' ;
    rdfs:comment 'Date when the new assay result from the resubmission was received and recorded in the LIMS system. Null until the re-analysis is completed.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'Actual observed value from the original analysis that triggered the resubmission. Used to calculate deviation from expected value or tolerance limits.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalAssayMethod rdf:type rdf:Property ;
    rdfs:label 'Original Assay Method' ;
    rdfs:comment 'Analytical method code used for the original analysis that is being resubmitted. Examples: FA-AAS (Fire Assay - Atomic Absorption Spectroscopy), XRF (X-Ray Fluorescence), ICP-MS (Inductively Coupled Plasma Mass Spectrometry).' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalElementSuite rdf:type rdf:Property ;
    rdfs:label 'Original Element Suite' ;
    rdfs:comment 'Comma-separated list of elements or compounds analyzed in the original assay. Examples: Au,Ag,Cu or Fe,SiO2,Al2O3.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcFailureType rdf:type rdf:Property ;
    rdfs:label 'Qaqc Failure Type' ;
    rdfs:comment 'Specific type of QA/QC failure that triggered the resubmission. CRM_BIAS: Certified Reference Material result outside accuracy tolerance; CRM_PRECISION: CRM result outside precision tolerance; BLANK_CONTAMINATION: Blank sample shows contamination; DUPLICATE_PRECISION: Field or pulp duplicate exceeds precision threshold; NONE: Resubmission not due to QA/QC failure.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionAssayMethod rdf:type rdf:Property ;
    rdfs:label 'Resubmission Assay Method' ;
    rdfs:comment 'Analytical method code to be used for the re-analysis. May be the same as the original method or a different method for verification purposes.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Date' ;
    rdfs:comment 'Date when the sample was formally resubmitted for re-analysis. Represents the business event timestamp for the resubmission workflow initiation.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionElementSuite rdf:type rdf:Property ;
    rdfs:label 'Resubmission Element Suite' ;
    rdfs:comment 'Comma-separated list of elements or compounds to be analyzed in the re-analysis. May be a subset or superset of the original element suite.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Resubmission Number' ;
    rdfs:comment 'Business identifier for the resubmission event. Format: RESUB-YYYYMMDD-NNNN where YYYYMMDD is the resubmission date and NNNN is a sequential counter.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Resubmission Reason Code' ;
    rdfs:comment 'Standardized code indicating why the sample was resubmitted. QC_CRM_FAIL: Certified Reference Material out of tolerance; QC_BLANK_CONTAM: Blank contamination detected; QC_DUP_EXCEED: Duplicate precision exceedance; OVERLIMIT_DILUTION: Result over instrument limit requiring dilution; CHECK_ASSAY: Verification assay for resource estimation; UMPIRE_ASSAY: Inter-laboratory bias assessment.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Resubmission Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances that triggered the resubmission, including reference values, tolerance limits, and deviation magnitude.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Resubmission Status' ;
    rdfs:comment 'Current lifecycle status of the resubmission workflow. REQUESTED: Initial request logged; APPROVED: Management approval obtained; SUBMITTED: Sample dispatched to laboratory; IN_PROGRESS: Analysis underway; COMPLETED: New result received; SIGNED_OFF: Competent person validation complete; CANCELLED: Resubmission cancelled. [ENUM-REF-CANDIDATE: REQUESTED|APPROVED|SUBMITTED|IN_PROGRESS|COMPLETED|SIGNED_OFF|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resubmission Timestamp' ;
    rdfs:comment 'Precise timestamp when the resubmission event was recorded in the LIMS system, including time zone information.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resubmissionType rdf:type rdf:Property ;
    rdfs:label 'Resubmission Type' ;
    rdfs:comment 'Classification of the resubmission workflow. INTERNAL_REPEAT: Same laboratory re-analysis; EXTERNAL_CHECK: Different laboratory verification; UMPIRE_ASSAY: Third-party inter-laboratory comparison; DILUTION_RERUN: Re-analysis with sample dilution.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValidationDecision rdf:type rdf:Property ;
    rdfs:label 'Result Validation Decision' ;
    rdfs:comment 'Competent person decision on which result to accept for resource estimation and reporting. ACCEPT_NEW: Use new resubmission result; ACCEPT_ORIGINAL: Original result deemed acceptable; ACCEPT_AVERAGE: Use average of original and new; REJECT_BOTH: Both results rejected, further investigation required; PENDING: Decision not yet made.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Limit' ;
    rdfs:comment 'Acceptable tolerance limit (as percentage or absolute value) for the QA/QC control sample. Exceedance of this limit triggers resubmission.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Expected or actual turnaround time in days from resubmission date to new result received date. Used for laboratory performance monitoring and resource estimation scheduling.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Validation Decision Rationale' ;
    rdfs:comment 'Detailed explanation of the competent person rationale for the result validation decision, including statistical analysis, geological context, and compliance considerations.' ;
    rdfs:domain ind:SampleResubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetBomId rdf:type rdf:Property ;
    rdfs:label 'Asset Bom Id' ;
    rdfs:comment 'Unique identifier for the asset bill of materials record. Primary key for the asset BOM entity.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryComponentAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Component Asset Id' ;
    rdfs:comment 'Reference to the child component or sub-assembly asset that is part of the parent asset structure. Links to the equipment asset master or component register.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Foreign key linking to maintenance.spare_part. Business justification: asset_bom has part_number (STRING) but no FK to spare_part master. One spare_part can appear in many asset BOMs. Adding spare_part_id FK enables linking BOM components to the authoritative spare_part ' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Hierarchical level of this component within the BOM structure. Level 1 represents top-level assemblies, with increasing numbers for deeper sub-assemblies.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of this BOM record. Active=currently in use, Superseded=replaced by newer version, Obsolete=no longer applicable, Pending=awaiting approval.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Number' ;
    rdfs:comment 'Reference number for the engineering change order that introduced or modified this BOM line. Used for change traceability and configuration management.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Critical Flag' ;
    rdfs:comment 'Indicates whether failure of this component could result in environmental incidents such as spills, emissions, or contamination. Requires enhanced monitoring per ISO 14001 Environmental Management Systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeableFlag rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Flag' ;
    rdfs:comment 'Indicates whether this component can be substituted with alternative parts from different manufacturers or specifications without affecting asset performance.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialSpecification rdf:type rdf:Property ;
    rdfs:label 'Material Specification' ;
    rdfs:comment 'Technical specification of materials used in the component, including grades, alloys, and compliance standards. Critical for mining equipment operating in harsh environments.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average operating time in hours between component failures. Key reliability metric used for preventive maintenance scheduling and spare parts planning.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average time in hours required to repair or replace this component. Used for shutdown planning and downtime estimation.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer or internal part number for the component. Used for procurement, inventory management, and spare parts identification.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTagNumber rdf:type rdf:Property ;
    rdfs:label 'Position Tag Number' ;
    rdfs:comment 'Physical location identifier or tag number for the component within the parent asset assembly. Used for maintenance work instructions and field identification.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'Number of units of this component required per parent asset assembly. Supports fractional quantities for consumables and bulk materials.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rotableFlag rdf:type rdf:Property ;
    rdfs:label 'Rotable Flag' ;
    rdfs:comment 'Indicates whether the component is a rotable spare that can be repaired, refurbished, and reused across multiple parent assets. True for high-value repairable components, False for consumables.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether failure of this component poses a direct safety risk to personnel or operations. Safety critical components require enhanced inspection and maintenance protocols per Mine Safety and Health Administration (MSHA) regulations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential ordering of components within the same BOM level and parent asset. Used for assembly instructions and kitting sequences.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serializedFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Flag' ;
    rdfs:comment 'Indicates whether individual instances of this component are tracked by unique serial numbers for warranty, maintenance history, and lifecycle management.' ;
    rdfs:domain ind:AssetBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Standard warranty period in months provided by the manufacturer for this component. Used for warranty claim management and lifecycle costing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Condition Monitoring Id' ;
    rdfs:comment 'Unique identifier for the condition monitoring record.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissioningActivityId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Activity Id' ;
    rdfs:comment 'Foreign key linking to project.commissioning_activity. Business justification: Commissioning activities include baseline condition monitoring (vibration signatures, oil analysis, thermography). Mining operations link monitoring records to commissioning activities to establish pe' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissioningActivity .

ind:geotechnicalInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Instrument Id' ;
    rdfs:comment 'Foreign key linking to tailings.geotechnical_instrument. Business justification: Condition monitoring of geotechnical instruments themselves (not readings from them). Tracks instrument health, drift, calibration status. Essential for ensuring reliability of dam safety monitoring d' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeotechnicalInstrument .

ind:inspectionRoundId rdf:type rdf:Property ;
    rdfs:label 'Inspection Round Id' ;
    rdfs:comment 'Foreign key linking to maintenance.inspection_round. Business justification: condition_monitoring has inspection_route_id (STRING) which is a route template, but no FK to the actual inspection_round instance. One inspection_round can have many condition_monitoring readings. Ad' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRound .

ind:inspectionRouteId rdf:type rdf:Property ;
    rdfs:label 'Inspection Route Id' ;
    rdfs:comment 'Identifier of the inspection route or round template used for operator inspection rounds.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRoute .

ind:alarmThreshold rdf:type rdf:Property ;
    rdfs:label 'Alarm Threshold' ;
    rdfs:comment 'Critical threshold value that triggers an alarm or immediate action when exceeded.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertLevel rdf:type rdf:Property ;
    rdfs:label 'Alert Level' ;
    rdfs:comment 'Current alert status based on measured value compared to thresholds (normal, warning, critical).' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect, anomaly, or condition issue identified during monitoring.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Identified Flag' ;
    rdfs:comment 'Boolean flag indicating whether a defect or anomaly was identified during this monitoring activity.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Severity classification of the identified defect (low, medium, high, critical) based on impact to asset reliability and safety.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Work Order Flag' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up work order should be or has been created based on this monitoring result.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Numeric value of the measurement taken during condition monitoring (e.g., vibration amplitude, temperature, wear depth, oil contamination level).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the condition monitoring measurement or inspection was performed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringLocation rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location' ;
    rdfs:comment 'Specific location or measurement point on the asset where the reading was taken (e.g., motor drive end bearing, gearbox input shaft).' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Pass or fail result for inspection-based monitoring where numeric measurement is not applicable (pass, fail, conditional, not applicable).' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Pf Interval Days' ;
    rdfs:comment 'Estimated number of days between potential failure detection (P) and functional failure (F) based on current condition trend, used for predictive maintenance scheduling.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended corrective or preventive action based on the monitoring results (e.g., schedule maintenance, replace component, increase monitoring frequency).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Statutory Inspection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this monitoring activity fulfills a statutory or regulatory inspection requirement (e.g., pressure vessel inspection, lifting equipment certification).' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'Warning threshold value that indicates elevated risk and requires increased monitoring frequency.' ;
    rdfs:domain ind:ConditionMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorServiceId rdf:type rdf:Property ;
    rdfs:label 'Contractor Service Id' ;
    rdfs:comment 'Unique identifier for the contractor service record. Primary key.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Contractor Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Contractor service records are the primary transaction record for external maintenance work delivery. Mining operations require structured link to counterparty for invoice matching, performance rating' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:contractorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Id' ;
    rdfs:comment 'Foreign key linking to workforce.contractor. Business justification: Contractor service records must link to contractor master for rate verification, insurance/safety clearance validation, performance tracking, and invoice reconciliation. Mining operations require cont' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:maintenanceShutdownScopeId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Shutdown Scope Id' ;
    rdfs:comment 'Foreign key linking to maintenance.shutdown_scope. Business justification: contractor_service has shutdown_event_reference (STRING) but no FK to shutdown_scope. One shutdown_scope can have many contractor_service records. Adding shutdown_scope_id FK enables linking contracto' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceShutdownScope .

ind:workOrderTaskId rdf:type rdf:Property ;
    rdfs:label 'Work Order Task Id' ;
    rdfs:comment 'Reference to the specific work order task or scope item that this contractor service supports. Nullable if service applies to the entire work order.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrderTask .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total actual hours worked by the contractor on this service, as recorded in timesheets or service completion records.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes documenting the completion of the contractor service, including any issues, deviations, or observations.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedHours rdf:type rdf:Property ;
    rdfs:label 'Contracted Hours' ;
    rdfs:comment 'Total hours contracted or estimated for the contractor service as per the purchase order or scope agreement.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'Hourly or daily rate agreed in the purchase order or contract for this contractor service.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCentre rdf:type rdf:Property ;
    rdfs:label 'Cost Centre' ;
    rdfs:comment 'Cost centre code to which the contractor service cost is allocated for financial reporting and cost control.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demobilisationDate rdf:type rdf:Property ;
    rdfs:label 'Demobilisation Date' ;
    rdfs:comment 'Date when the contractor demobilised from site and completed work. Nullable if service is still in progress.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General ledger account code for posting the contractor service cost in the financial system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Invoice number or reference submitted by the contractor for payment of this service.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilisationDate rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Date' ;
    rdfs:comment 'Date when the contractor mobilised to site and commenced work.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Performance rating assigned to the contractor for this service delivery, based on quality, safety, timeliness, and adherence to scope.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitReference rdf:type rdf:Property ;
    rdfs:label 'Permit Reference' ;
    rdfs:comment 'Reference number of the work permit or safety permit issued for this contractor service (e.g., hot work permit, confined space permit, isolation permit).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInductionDate rdf:type rdf:Property ;
    rdfs:label 'Safety Induction Date' ;
    rdfs:comment 'Date when the contractor completed the mandatory site safety induction.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyInductionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Safety Induction Expiry Date' ;
    rdfs:comment 'Expiry date of the contractor\'s safety induction certification, after which re-induction is required.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyInductionStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Induction Status' ;
    rdfs:comment 'Status of the contractor\'s site safety induction and compliance with Health Safety and Environment (HSE) requirements.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the contractor service scope and work performed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the contractor service engagement.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of maintenance service provided by the contractor (e.g., preventive maintenance, corrective maintenance, shutdown support, project work, inspection, commissioning). [ENUM-REF-CANDIDATE: preventive_maintenance|corrective_maintenance|shutdown_support|project_work|inspection|commissioning|emergency_response — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownEventReference rdf:type rdf:Property ;
    rdfs:label 'Shutdown Event Reference' ;
    rdfs:comment 'Reference to the planned shutdown or turnaround event if this contractor service is part of a major shutdown scope.' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeCategory rdf:type rdf:Property ;
    rdfs:label 'Trade Category' ;
    rdfs:comment 'Classification of the contractor trade or craft discipline (e.g., mechanical, electrical, instrumentation, civil, structural, piping, rigging, scaffolding). [ENUM-REF-CANDIDATE: mechanical|electrical|instrumentation|civil|structural|piping|rigging|scaffolding|insulation|painting|welding|fabrication|hvac|plumbing — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractorService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDowntimeId rdf:type rdf:Property ;
    rdfs:label 'Equipment Downtime Id' ;
    rdfs:comment 'Unique identifier for the equipment downtime event record. Primary key for the equipment downtime transactional entity.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentDowntime .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'Standardized code identifying the corrective action taken to restore the equipment to operational status (e.g., repair, replace, adjust, clean, reset). Used for maintenance strategy analysis and cost tracking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualRepairCost rdf:type rdf:Property ;
    rdfs:label 'Actual Repair Cost' ;
    rdfs:comment 'Actual total cost in local currency incurred to repair or resolve the downtime event, including labour, parts, contractor services, and equipment hire. Captured upon work order completion and cost reconciliation.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:causeCode rdf:type rdf:Property ;
    rdfs:label 'Cause Code' ;
    rdfs:comment 'Standardized code identifying the root cause of the failure or downtime event (e.g., wear and tear, operator error, design defect, inadequate maintenance, environmental factors). Used for reliability improvement and preventive maintenance optimization.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total duration of the downtime event measured in hours, calculated as the difference between downtime end and start timestamps. Used for OEE availability percentage, MTTR (Mean Time To Repair), and production loss calculations.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'The precise date and time when the equipment was restored to operational status and became available for production. Represents the end of the downtime period. Null for ongoing downtime events.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeEventNumber rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Number' ;
    rdfs:comment 'Business identifier for the downtime event, typically auto-generated by CMMS or FMS. Used for tracking and reporting purposes.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'The precise date and time when the equipment became unavailable or non-operational. Represents the beginning of the downtime period. Critical for MTBF (Mean Time Between Failures) and availability calculations.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeType rdf:type rdf:Property ;
    rdfs:label 'Downtime Type' ;
    rdfs:comment 'Detailed classification of the downtime event providing granular categorization within the downtime category (e.g., mechanical failure, electrical failure, hydraulic failure, scheduled inspection, component replacement).' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated total cost in local currency to repair or resolve the downtime event, including labour, parts, and contractor costs. Captured at the time of work order creation or initial assessment.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Free-text narrative describing the nature of the failure, symptoms observed, and conditions leading to the downtime event. Captured by operators or maintenance technicians for detailed incident documentation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFailureCode rdf:type rdf:Property ;
    rdfs:label 'Primary Failure Code' ;
    rdfs:comment 'Standardized code identifying the primary system, component, or subsystem that failed or required maintenance. Typically follows equipment taxonomy hierarchy (e.g., engine, hydraulics, electrical, structural). Used for failure mode analysis and spare parts planning.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Urgency classification of the downtime event determining the response sequence and resource allocation. Critical priority indicates production-stopping events requiring immediate attention.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactTonnes rdf:type rdf:Property ;
    rdfs:label 'Production Impact Tonnes' ;
    rdfs:comment 'Estimated production loss in tonnes of ore or material that could not be processed or moved due to this downtime event. Calculated based on equipment rated capacity and downtime duration. Critical for production planning and financial impact assessment.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Repair Time Minutes' ;
    rdfs:comment 'Active repair or maintenance time in minutes, excluding waiting time, parts procurement delays, or administrative delays. Represents hands-on work duration. Used for MTTR (Mean Time To Repair) calculation and technician productivity analysis.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Time elapsed in minutes between the downtime event being reported and the first maintenance response or technician arrival on site. Key performance indicator for maintenance service level.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the downtime event involved or resulted in a safety incident, near-miss, or hazardous condition requiring HSE (Health Safety and Environment) investigation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryFailureCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Failure Code' ;
    rdfs:comment 'Standardized code identifying the specific component or part within the primary failure system that failed. Provides granular detail for root cause analysis and component reliability tracking.' ;
    rdfs:domain ind:EquipmentDowntime ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCentre rdf:type rdf:Property ;
    rdfs:label 'Work Centre' ;
    rdfs:comment 'The maintenance work centre or crew responsible for responding to and resolving the downtime event. Used for workload balancing, resource planning, and accountability tracking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Functional Location Id' ;
    rdfs:comment 'Foreign key linking to maintenance.functional_location. Business justification: failure_report has functional_location (STRING) but no FK to functional_location master. One functional_location can have many failure reports. Adding functional_location_id FK enables linking failure' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:originatingDowntimeEventId rdf:type rdf:Property ;
    rdfs:label 'Originating Downtime Event Id' ;
    rdfs:comment 'Foreign key linking to equipment.downtime_event. Business justification: Failure reports document root cause analysis for equipment downtime events. Mining reliability engineering requires traceability from RCA findings back to the originating downtime event for MTBF impro' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DowntimeEvent .

ind:previousFailureReportId rdf:type rdf:Property ;
    rdfs:label 'Previous Failure Report Id' ;
    rdfs:comment 'Reference to the prior failure report if this is a repeat failure. Enables tracking of failure recurrence patterns.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureReport .

ind:primaryFailureEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Failure Employee Id' ;
    rdfs:comment 'Reference to the reliability engineer assigned to investigate this failure and develop preventive recommendations.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryFailureLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Failure Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the failure report record.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFailureCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Failure Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created the failure report record in the system.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Action Completed Date' ;
    rdfs:comment 'Actual date when the recommended preventive actions were completed and verified.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Due Date' ;
    rdfs:comment 'Target completion date for implementing the recommended preventive actions. Used to track closure of reliability improvement initiatives.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the immediate corrective action performed to restore the asset to service (e.g., replaced bearing, repaired weld, cleaned filter, reset system).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the failure was detected or reported. May differ from failure timestamp if failure was latent or gradual.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether this failure resulted in an environmental release or impact requiring environmental incident reporting.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedMtbfGainHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Mtbf Gain Hours' ;
    rdfs:comment 'Estimated improvement in Mean Time Between Failures (MTBF) expected from implementing the recommended actions, measured in hours. Used to quantify reliability improvement potential.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventClassification rdf:type rdf:Property ;
    rdfs:label 'Event Classification' ;
    rdfs:comment 'Classification of the failure event for reliability program tracking (e.g., breakdown for unplanned stoppage, bad actor for high-cost repeat offender, FMEA finding for risk-based analysis result). [ENUM-REF-CANDIDATE: breakdown|bad_actor|repeat_failure|chronic_failure|fmea_finding|reliability_improvement|critical_failure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCause rdf:type rdf:Property ;
    rdfs:label 'Failure Cause' ;
    rdfs:comment 'Root cause or contributing factor that led to the failure (e.g., inadequate lubrication, material fatigue, operator error, design deficiency, environmental conditions).' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCauseCode rdf:type rdf:Property ;
    rdfs:label 'Failure Cause Code' ;
    rdfs:comment 'Standardized code classifying the failure cause according to the organization\'s cause taxonomy or ISO 14224 standard.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCost rdf:type rdf:Property ;
    rdfs:label 'Failure Cost' ;
    rdfs:comment 'Total cost of the failure including repair costs, lost production value, and consequential costs. Used for bad actor analysis and reliability investment justification.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureEffect rdf:type rdf:Property ;
    rdfs:label 'Failure Effect' ;
    rdfs:comment 'Description of the consequence or impact of the failure on operations (e.g., complete shutdown, reduced capacity, safety hazard, environmental release, quality degradation).' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeCode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Code' ;
    rdfs:comment 'Standardized code classifying the failure mode according to the organization\'s failure taxonomy or ISO 14224 standard.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReportNumber rdf:type rdf:Property ;
    rdfs:label 'Failure Report Number' ;
    rdfs:comment 'Human-readable business identifier for the failure report. Used for external reference and communication.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureSeverity rdf:type rdf:Property ;
    rdfs:label 'Failure Severity' ;
    rdfs:comment 'Severity classification of the failure based on operational impact, safety risk, and cost. Used for prioritizing reliability improvement efforts.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failure Timestamp' ;
    rdfs:comment 'Date and time when the failure event occurred. Critical for downtime calculation and reliability analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalLocation rdf:type rdf:Property ;
    rdfs:label 'Functional Location' ;
    rdfs:comment 'Hierarchical location code identifying where the asset is installed within the mine site structure (e.g., pit, processing plant, conveyor system). Used for spatial failure analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossTonnes rdf:type rdf:Property ;
    rdfs:label 'Production Loss Tonnes' ;
    rdfs:comment 'Estimated production loss in tonnes caused by this failure event. Used to quantify the operational impact of the failure.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rcaFindings rdf:type rdf:Property ;
    rdfs:label 'Rca Findings' ;
    rdfs:comment 'Summary of the root cause analysis investigation findings, including identified root causes, contributing factors, and failure mechanism analysis.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcaMethod rdf:type rdf:Property ;
    rdfs:label 'Rca Method' ;
    rdfs:comment 'Methodology used to conduct the root cause analysis (e.g., 5 Whys, Fishbone Diagram, Fault Tree Analysis, FMEA). [ENUM-REF-CANDIDATE: 5_whys|fishbone_diagram|fault_tree_analysis|failure_mode_effects_analysis|pareto_analysis|barrier_analysis|change_analysis — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcaPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Rca Performed Flag' ;
    rdfs:comment 'Indicates whether a formal root cause analysis investigation was conducted for this failure event. Typically performed for critical or repeat failures.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatFailureFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Failure Flag' ;
    rdfs:comment 'Indicates whether this failure is a recurrence of a previous failure on the same asset with the same or similar failure mode. Used to identify chronic reliability issues.' ;
    rdfs:domain ind:FailureReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nearestCulturalHeritageSiteId rdf:type rdf:Property ;
    rdfs:label 'Nearest Cultural Heritage Site Id' ;
    rdfs:comment 'Foreign key linking to community.cultural_heritage_site. Business justification: Functional locations (plants, dumps, roads) must maintain regulatory buffer zones from cultural heritage sites. Spatial planning, access control, and work authorization depend on proximity assessment.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CulturalHeritageSite .

ind:parentFlFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Fl Functional Location Id' ;
    rdfs:comment 'Reference to the parent functional location in the hierarchy. Enables roll-up of maintenance costs and performance metrics. Null for top-level site locations.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:wasteRockDumpId rdf:type rdf:Property ;
    rdfs:label 'Waste Rock Dump Id' ;
    rdfs:comment 'Foreign key linking to tailings.waste_rock_dump. Business justification: Functional location hierarchy includes waste rock dumps as major facility nodes. Essential for asset hierarchy, work planning, cost allocation, and organizing maintenance activities by dump facility.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteRockDump .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification indicator for criticality and maintenance priority. A = critical to production, B = important, C = non-critical. Drives preventive maintenance frequency and spare parts stocking strategy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingStructureReference rdf:type rdf:Property ;
    rdfs:label 'Building Structure Reference' ;
    rdfs:comment 'Reference to the physical building or structure housing this functional location (e.g., crusher building, mill house, workshop). Used for facility management and capital asset tracking.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionType rdf:type rdf:Property ;
    rdfs:label 'Construction Type' ;
    rdfs:comment 'Construction type or design specification of the functional location (e.g., steel frame, concrete structure, underground excavation type). Relevant for structural integrity and maintenance planning.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalSensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitive Flag' ;
    rdfs:comment 'Boolean flag indicating whether this functional location is environmentally sensitive (e.g., Tailings Storage Facility - TSF, water treatment plant, chemical storage) requiring enhanced monitoring and compliance reporting per ISO 14001 and Environmental Impact Statement (EIS) requirements.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system reference identifier for cross-system integration and data synchronization. Enables traceability back to the source operational system.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flCode rdf:type rdf:Property ;
    rdfs:label 'Fl Code' ;
    rdfs:comment 'Hierarchical alphanumeric code representing the functional location within the mine or plant structure. Typically follows a structured format (e.g., SITE-AREA-SYSTEM-SUBSYSTEM). Sourced from Infor EAM and SAP PM functional location hierarchy.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flDescription rdf:type rdf:Property ;
    rdfs:label 'Fl Description' ;
    rdfs:comment 'Full business description of the functional location, providing context on the physical or logical position within the mine or plant where assets are installed and maintained.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flType rdf:type rdf:Property ;
    rdfs:label 'Fl Type' ;
    rdfs:comment 'Classification of the functional location within the hierarchy. Defines the level of granularity (e.g., site, area, system, sub-system, component position, zone).' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Isolation Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether equipment at this functional location requires Lock Out Tag Out (LOTO) isolation procedures before maintenance work can commence.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearUnit rdf:type rdf:Property ;
    rdfs:label 'Linear Unit' ;
    rdfs:comment 'Unit of measure for linear dimensions at this functional location (e.g., m for meters, ft for feet, km for kilometers). Used for spatial calculations and engineering drawings.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlannerGroup rdf:type rdf:Property ;
    rdfs:label 'Maintenance Planner Group' ;
    rdfs:comment 'Code identifying the maintenance planner group responsible for work orders and preventive maintenance activities at this functional location. Links to workforce planning and scheduling.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlantCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plant Code' ;
    rdfs:comment 'Maintenance plant code for work execution and spare parts inventory management. Links to Computerized Maintenance Management System (CMMS) organizational hierarchy.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether work at this functional location requires special permits (e.g., hot work permit, confined space entry, isolation permit) per Standard Operating Procedure (SOP) and safety protocols.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningPlantCode rdf:type rdf:Property ;
    rdfs:label 'Planning Plant Code' ;
    rdfs:comment 'SAP PM planning plant code associated with this functional location. Used for maintenance planning scope and organizational assignment in Enterprise Resource Planning (ERP) systems.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantArea rdf:type rdf:Property ;
    rdfs:label 'Plant Area' ;
    rdfs:comment 'Specific plant area or operational zone within the mine site (e.g., crushing plant, concentrator, ROM pad, tailings storage facility, underground level).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomFloorReference rdf:type rdf:Property ;
    rdfs:label 'Room Floor Reference' ;
    rdfs:comment 'Specific room, floor, or level reference within a building or underground mine level. Provides granular spatial context for asset location and maintenance access planning.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaTagPrefix rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Prefix' ;
    rdfs:comment 'SCADA tag prefix used to identify real-time process data and telemetry streams from equipment installed at this functional location. Enables integration with OSIsoft PI System and Manufacturing Execution System (MES).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortField rdf:type rdf:Property ;
    rdfs:label 'Sort Field' ;
    rdfs:comment 'Additional sorting or grouping field used for custom reporting and functional location list displays in CMMS and ERP systems.' ;
    rdfs:domain ind:FunctionalLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for weight-related attributes at this functional location (e.g., kg for kilograms, t for metric tonnes, lb for pounds). Used for load calculations and structural capacity planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Work Order Id' ;
    rdfs:comment 'Reference to the primary corrective work order created to address defects identified during this inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:inspectionTemplateId rdf:type rdf:Property ;
    rdfs:label 'Inspection Template Id' ;
    rdfs:comment 'Reference to the inspection template or checklist that defines the inspection points and criteria for this round.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionTemplate .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this inspection round requires supervisory or engineering approval before closure, typically for statutory or critical inspections.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkpointsFailed rdf:type rdf:Property ;
    rdfs:label 'Checkpoints Failed' ;
    rdfs:comment 'Number of inspection checkpoints that did not meet acceptance criteria and failed inspection.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointsObservation rdf:type rdf:Property ;
    rdfs:label 'Checkpoints Observation' ;
    rdfs:comment 'Number of inspection checkpoints that resulted in an observation or advisory note without constituting a failure.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointsPassed rdf:type rdf:Property ;
    rdfs:label 'Checkpoints Passed' ;
    rdfs:comment 'Number of inspection checkpoints that met the acceptance criteria and passed inspection.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Count' ;
    rdfs:comment 'Number of defects classified as critical severity, requiring immediate corrective action or asset shutdown.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, anomalies, or non-conformances identified during the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Description of environmental factors such as temperature, humidity, dust levels, or other conditions that may affect inspection results or asset condition.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestDefectSeverity rdf:type rdf:Property ;
    rdfs:label 'Highest Defect Severity' ;
    rdfs:comment 'The most severe defect classification identified during the inspection, used for prioritization and escalation.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Timestamp' ;
    rdfs:comment 'The precise date and time when the inspector completed the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The calendar date on which the inspection round was performed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text field for the inspector to record observations, context, recommendations, or any additional information relevant to the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Timestamp' ;
    rdfs:comment 'The precise date and time when the inspector began the inspection round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the inspector, required for statutory inspections of pressure vessels, lifting equipment, and electrical systems.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the person who conducted the inspection round, captured for audit and accountability purposes.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Major Defects Count' ;
    rdfs:comment 'Number of defects classified as major severity, requiring corrective action within a defined timeframe.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defects Count' ;
    rdfs:comment 'Number of defects classified as minor severity, to be addressed during planned maintenance activities.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallConditionRating rdf:type rdf:Property ;
    rdfs:label 'Overall Condition Rating' ;
    rdfs:comment 'Summary assessment of the asset or location condition based on the inspection findings, used to trigger condition-based maintenance decisions.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Business identifier or sequence number for the inspection round, often used for tracking and reporting purposes.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Identifier for the operational shift during which the inspection was performed.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Statutory Compliance Flag' ;
    rdfs:comment 'Indicates whether this inspection is required by law or regulation, such as pressure vessel, lifting equipment, or electrical system inspections.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCheckpoints rdf:type rdf:Property ;
    rdfs:label 'Total Checkpoints' ;
    rdfs:comment 'Total number of inspection checkpoints or items defined in the inspection template for this round.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workOrderRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Work Order Raised Flag' ;
    rdfs:comment 'Indicates whether one or more corrective or follow-up work orders were generated as a result of this inspection.' ;
    rdfs:domain ind:InspectionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labourRecordId rdf:type rdf:Property ;
    rdfs:label 'Labour Record Id' ;
    rdfs:comment 'Unique identifier for the labour record. Primary key.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The hourly labour rate applied to this record. May be standard employee rate or contractor rate.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labourCost rdf:type rdf:Property ;
    rdfs:label 'Labour Cost' ;
    rdfs:comment 'Total labour cost for this record, calculated as (regular_hours * hourly_rate) + (overtime_hours * overtime_rate).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours booked against this labour record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeRate rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate' ;
    rdfs:comment 'The hourly overtime rate applied to overtime hours. Typically a multiplier of the regular hourly rate.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderReference rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Reference' ;
    rdfs:comment 'Reference to the purchase order under which contractor labour services were procured. Applicable for contractor labour only.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of regular working hours booked against this labour record, excluding overtime.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Indicates whether the labour was performed by an internal employee or an external contractor.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Entry Number' ;
    rdfs:comment 'Unique timesheet entry number from the source system (Infor EAM or SAP HR) for traceability and reconciliation.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total labour hours booked (regular hours plus overtime hours).' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeCraft rdf:type rdf:Property ;
    rdfs:label 'Trade Craft' ;
    rdfs:comment 'The trade or craft skill of the worker performing the labour (e.g., Electrician, Fitter, Boilermaker, Diesel Mechanic, Welder).' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the labour was performed.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed description of the work performed by the worker during this labour booking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerName rdf:type rdf:Property ;
    rdfs:label 'Worker Name' ;
    rdfs:comment 'Full name of the worker who performed the labour.' ;
    rdfs:domain ind:LabourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Unique identifier for the maintenance permit record. Primary key.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heritageClearanceId rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Id' ;
    rdfs:comment 'Foreign key linking to tenement.heritage_clearance. Business justification: Permits for work in heritage-sensitive areas must reference specific heritage clearance records to demonstrate compliance with traditional owner agreements, verify clearance validity, and ensure work ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeritageClearance .

ind:permitCancelledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Cancelled By Employee Id' ;
    rdfs:comment 'Employee identifier of the person who cancelled the permit. Links to workforce records for accountability and audit trails.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitIssuingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Issuing Authority Employee Id' ;
    rdfs:comment 'Employee identifier of the person who issued the permit. Links to workforce records for competency verification and audit trails.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitSiteSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Site Supervisor Employee Id' ;
    rdfs:comment 'Employee identifier of the site supervisor. Links to workforce records for accountability and competency verification.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:atmosphericTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Atmospheric Testing Required Flag' ;
    rdfs:comment 'Indicates whether atmospheric testing for oxygen levels, flammable gases, or toxic substances is required before and during work. Mandatory for confined space entry permits.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedPersonnel rdf:type rdf:Property ;
    rdfs:label 'Authorized Personnel' ;
    rdfs:comment 'List of employee names or identifiers who are authorized to perform work under this permit. Only listed personnel may execute the permitted activity.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the permit was cancelled before work completion. May include changes in work scope, unsafe conditions identified, or work postponement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the permit was cancelled. Used for compliance reporting and incident investigation if cancellation was due to safety concerns.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the permit was formally closed after work completion and area clearance. Marks the end of the permits lifecycle.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureSignature rdf:type rdf:Property ;
    rdfs:label 'Closure Signature' ;
    rdfs:comment 'Digital or scanned signature confirming that work has been completed, all isolation points have been restored, and the work area has been inspected and cleared.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'Number of times this permit has been extended beyond its original end timestamp. Tracks permit lifecycle complexity and potential safety control degradation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireWatchRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Watch Required Flag' ;
    rdfs:comment 'Indicates whether a dedicated fire watch person must be present during and after hot work activities. Mandatory for welding, cutting, grinding, and other spark-producing operations.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardIdentification rdf:type rdf:Property ;
    rdfs:label 'Hazard Identification' ;
    rdfs:comment 'Comprehensive list of identified hazards associated with the permitted work activity. Includes physical, chemical, biological, ergonomic, and psychosocial hazards.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationPoints rdf:type rdf:Property ;
    rdfs:label 'Isolation Points' ;
    rdfs:comment 'Detailed description of all energy isolation points (electrical, mechanical, hydraulic, pneumatic) that must be locked out or tagged out before work commences. Critical for LOTO compliance.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the permit was formally issued by the authorized issuing authority. Marks the official approval of the permit.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuerSignature rdf:type rdf:Property ;
    rdfs:label 'Issuer Signature' ;
    rdfs:comment 'Digital or scanned signature of the permit issuer confirming that all safety requirements have been reviewed and the permit is authorized.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverSignature rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature' ;
    rdfs:comment 'Digital or scanned signature of the person receiving the permit, acknowledging understanding of hazards, controls, and responsibilities.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredPpe rdf:type rdf:Property ;
    rdfs:label 'Required Ppe' ;
    rdfs:comment 'Mandatory personal protective equipment that all workers must wear during the permitted activity. May include hard hat, safety glasses, gloves, respirator, fall protection, etc.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescuePlanReference rdf:type rdf:Property ;
    rdfs:label 'Rescue Plan Reference' ;
    rdfs:comment 'Reference to the emergency rescue plan document that must be in place before work commences. Required for confined space entry and working at heights permits.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Reference number or identifier of the formal risk assessment document that supports this permit. Links to detailed risk analysis and control measures.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteSupervisorName rdf:type rdf:Property ;
    rdfs:label 'Site Supervisor Name' ;
    rdfs:comment 'Name of the on-site supervisor responsible for overseeing the permitted work and ensuring compliance with safety controls.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPrecautions rdf:type rdf:Property ;
    rdfs:label 'Special Precautions' ;
    rdfs:comment 'Additional safety precautions or site-specific requirements that must be observed during the permitted work. May include environmental controls, traffic management, or simultaneous operations restrictions.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestId rdf:type rdf:Property ;
    rdfs:label 'Request Id' ;
    rdfs:comment 'Unique identifier for the maintenance request. Primary key.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Work Order Id' ;
    rdfs:comment 'Reference to the work order that was created from this maintenance request after approval. Null if request has not yet been converted or was rejected.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'Employee identifier of the person who raised the maintenance request, used for accountability and follow-up communication.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.requisition. Business justification: Maintenance requests that identify material requirements not in stock trigger procurement requisitions. Mining operations track this link to monitor procurement lead time impact on maintenance backlog' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents, photos, or files attached to the maintenance request (e.g., photos of damage, inspection reports, technical drawings).' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Converted Timestamp' ;
    rdfs:comment 'Date and time when the maintenance request was converted into a formal work order in the CMMS.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dateRaised rdf:type rdf:Property ;
    rdfs:label 'Date Raised' ;
    rdfs:comment 'Calendar date when the maintenance request was created and submitted into the system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateRequired rdf:type rdf:Property ;
    rdfs:label 'Date Required' ;
    rdfs:comment 'Target date by which the requestor needs the maintenance work to be completed, used for planning and scheduling prioritization.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Requestor or planner estimate of equipment downtime hours required to complete the maintenance work, used for production planning and scheduling.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed narrative description of the observed fault, defect, or required maintenance work as reported by the requestor. Captures symptoms, abnormal conditions, or specific work requirements.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Additional comments or planning notes added by the maintenance planner during review, including scope clarification, resource requirements, or scheduling considerations.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Production Impact Flag' ;
    rdfs:comment 'Indicator whether the fault or required maintenance is currently impacting or will impact production output. True indicates production loss or risk.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business identifier for the maintenance request, typically system-generated with a prefix and sequential number.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance request. Open indicates newly created; under_review indicates supervisor assessment; approved indicates ready for work order conversion; rejected indicates declined request; converted indicates work order has been created; cancelled indicates request withdrawn.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the maintenance request indicating the nature of work required: corrective (breakdown), preventive (scheduled), predictive (condition-based), inspection, modification, or emergency.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorContactNumber rdf:type rdf:Property ;
    rdfs:label 'Requestor Contact Number' ;
    rdfs:comment 'Phone number or radio call sign of the requestor for clarification or follow-up on the maintenance request.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the person who initiated the maintenance request, typically an equipment operator, supervisor, or maintenance planner.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the maintenance request was reviewed and a decision (approve/reject) was made.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority classification indicating how quickly the maintenance work must be addressed. Critical indicates immediate safety or production impact; high indicates significant operational impact; medium and low indicate routine work.' ;
    rdfs:domain ind:Request ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Unique identifier for the maintenance strategy record. Primary key.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:strategyApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Strategy Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or authority who approved this maintenance strategy for deployment.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:strategyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Strategy Employee Id' ;
    rdfs:comment 'Reference to the reliability engineer or asset management specialist responsible for maintaining and optimizing this strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Regulatory or industry compliance framework that this maintenance strategy is designed to satisfy, such as MSHA, ISO 45001, or environmental regulations. [ENUM-REF-CANDIDATE: iso_45001|iso_14001|msha|jorc|icmm|local_mining_act — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Condition Monitoring Flag' ;
    rdfs:comment 'Indicates whether this strategy includes condition monitoring techniques such as vibration analysis, thermography, or oil analysis.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Cost' ;
    rdfs:comment 'Estimated total annual cost in base currency for executing this maintenance strategy, including labour, parts, and contractor costs.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmeaReference rdf:type rdf:Property ;
    rdfs:label 'Fmea Reference' ;
    rdfs:comment 'Reference identifier to the FMEA study that informed the failure modes and maintenance tasks for this strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePhilosophy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Philosophy' ;
    rdfs:comment 'The overarching maintenance approach applied: run-to-failure (reactive), time-based (preventive), condition-based (CBM), predictive (PdM), reliability-centred maintenance (RCM), or risk-based maintenance (RBM).' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceKpiDefinition rdf:type rdf:Property ;
    rdfs:label 'Performance Kpi Definition' ;
    rdfs:comment 'Definition of the key performance indicators used to measure the success and effectiveness of this maintenance strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmScheduleCount rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Count' ;
    rdfs:comment 'Number of preventive maintenance schedules or task lists associated with this maintenance strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictiveAnalyticsFlag rdf:type rdf:Property ;
    rdfs:label 'Predictive Analytics Flag' ;
    rdfs:comment 'Indicates whether this strategy leverages predictive analytics or machine learning models to forecast failures and optimize maintenance timing.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rcmAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Rcm Analysis Reference' ;
    rdfs:comment 'Reference identifier to the RCM analysis document or study that underpins this maintenance strategy, if applicable.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Frequency in months at which this maintenance strategy is reviewed and updated to ensure continued effectiveness and alignment with asset performance.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskMitigationApproach rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Approach' ;
    rdfs:comment 'Description of how this maintenance strategy mitigates operational, safety, and environmental risks associated with asset failure.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownStrategyFlag rdf:type rdf:Property ;
    rdfs:label 'Shutdown Strategy Flag' ;
    rdfs:comment 'Indicates whether this strategy is specifically designed for major shutdowns or turnarounds requiring extended downtime.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsStrategy rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Strategy' ;
    rdfs:comment 'Approach to spare parts inventory management for assets covered by this strategy: stock on hand, just-in-time, vendor-managed inventory, or consignment.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Business identifier code for the maintenance strategy, used for external reference and integration with CMMS systems.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyDescription rdf:type rdf:Property ;
    rdfs:label 'Strategy Description' ;
    rdfs:comment 'Detailed narrative describing the maintenance strategy objectives, scope, key activities, and expected outcomes.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Descriptive name of the maintenance strategy that clearly identifies the approach and scope.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance strategy indicating whether it is in use, under development, or retired.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'Classification of the maintenance strategy by execution type: preventive (scheduled), predictive (condition-triggered), corrective (planned repair), breakdown (emergency), shutdown (major overhaul), or project (capital upgrade).' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOeePercent rdf:type rdf:Property ;
    rdfs:label 'Target Oee Percent' ;
    rdfs:comment 'Target Overall Equipment Effectiveness percentage that this maintenance strategy is designed to support or improve.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Parts Consumption Id' ;
    rdfs:comment 'Unique identifier for the parts consumption transaction record.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPartsIssuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Parts Issued By Employee Id' ;
    rdfs:comment 'Reference to the stores employee who issued the part.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aiscAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Aisc Allocation Flag' ;
    rdfs:comment 'Indicates whether this parts consumption cost is included in the All-In Sustaining Cost calculation for the mine site.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin or shelf location within the store from which the part was picked.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Core Charge Flag' ;
    rdfs:comment 'Indicates whether a core charge applies to this part, requiring return of the old component.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'System-generated material document number from the ERP system recording the goods movement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexCategory rdf:type rdf:Property ;
    rdfs:label 'Opex Category' ;
    rdfs:comment 'Classification of the parts consumption cost within the OPEX structure (maintenance, operations, sustaining, growth, exploration).' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Quantity of the part originally requested for the work order.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Material requisition number or document reference that authorized the part issue.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this consumption transaction has been reversed or cancelled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotableReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Rotable Return Flag' ;
    rdfs:comment 'Indicates whether the part is a rotable component that was returned for repair or refurbishment after removal.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Store Location Code' ;
    rdfs:comment 'Code identifying the warehouse or store location from which the part was issued.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeLocationName rdf:type rdf:Property ;
    rdfs:label 'Store Location Name' ;
    rdfs:comment 'Name or description of the warehouse or store location from which the part was issued.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this part consumption is covered under warranty and may be claimed from the supplier or manufacturer.' ;
    rdfs:domain ind:PartsConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Unique identifier for the preventive maintenance schedule record. Primary key.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:standardJobId rdf:type rdf:Property ;
    rdfs:label 'Standard Job Id' ;
    rdfs:comment 'Reference to the standard job plan that defines the detailed task list, labor requirements, spare parts, tools, and safety procedures for this PM schedule. Ensures consistency and standardization of maintenance execution.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardJob .

ind:workCentreId rdf:type rdf:Property ;
    rdfs:label 'Work Centre Id' ;
    rdfs:comment 'Reference to the work centre or maintenance crew responsible for executing this PM schedule. Used for resource planning and work order assignment.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCentre .

ind:autoGenerateFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Flag' ;
    rdfs:comment 'Indicates whether work orders should be automatically generated from this PM schedule when the next_due_date is reached. If false, work orders must be manually created.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Target Percentage' ;
    rdfs:comment 'The target compliance percentage for on-time completion of PM work orders generated from this schedule. Typically set at 95% or higher for critical assets. Used for KPI tracking and performance management.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this PM schedule expires and stops generating work orders. Nullable for open-ended schedules. Used for temporary or project-specific PM plans.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this PM schedule becomes active and begins generating work orders. Supports future-dated schedule activation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether this PM schedule is required for environmental compliance purposes. Environmental compliance PM schedules are subject to regulatory audit and reporting requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'The estimated time in hours required to complete the preventive maintenance activities defined in this schedule. Used for resource planning and downtime scheduling.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'The type of frequency trigger that determines when the PM work order is generated. Calendar-based uses fixed time intervals, runtime-hours uses equipment operating hours, cycles uses production cycles, condition-triggered uses sensor thresholds, meter-based uses equipment meter readings, and event-based uses specific operational events.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'The unit of measure for the interval_value. Must align with the frequency_type selected. [ENUM-REF-CANDIDATE: days|weeks|months|years|hours|cycles|units|threshold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'The numeric value of the maintenance interval. Interpretation depends on frequency_type: days for calendar, hours for runtime-hours, count for cycles, threshold value for condition-triggered.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Completion Date' ;
    rdfs:comment 'The date when this PM schedule was last completed. Used to calculate the next due date for calendar-based schedules.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days in advance of the next_due_date that the PM work order should be generated. Allows time for planning, parts procurement, and resource scheduling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The calculated date when the next preventive maintenance work order is due to be generated and executed. Automatically calculated based on last_completion_date and interval_value.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the preventive maintenance plan, including scope of work, objectives, and key activities to be performed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmPlanCode rdf:type rdf:Property ;
    rdfs:label 'Pm Plan Code' ;
    rdfs:comment 'Business identifier for the PM schedule plan. Unique code used in operational systems and work order generation.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the PM schedule. Active schedules generate work orders automatically. Suspended schedules are temporarily paused. Inactive schedules are permanently disabled. Under-review schedules are being evaluated for changes. Obsolete schedules are retained for historical reference only.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Shutdown Required Flag' ;
    rdfs:comment 'Indicates whether the asset must be shut down to perform the PM activities. Used for production planning and downtime scheduling.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reliabilityEventId rdf:type rdf:Property ;
    rdfs:label 'Reliability Event Id' ;
    rdfs:comment 'Unique identifier for the reliability engineering event record. Primary key for the reliability event entity.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Action Completion Date' ;
    rdfs:comment 'Actual date when the recommended reliability improvement action was completed and verified.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority classification for implementing the recommended action based on risk assessment, operational impact, and resource availability.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualMtbfImprovementHours rdf:type rdf:Property ;
    rdfs:label 'Actual Mtbf Improvement Hours' ;
    rdfs:comment 'Measured improvement in Mean Time Between Failures in hours, achieved after implementing the reliability improvement action. Captured through post-implementation monitoring and used to validate the effectiveness of reliability initiatives.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMtbfImprovementHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Mtbf Improvement Hours' ;
    rdfs:comment 'Projected improvement in Mean Time Between Failures measured in hours, expected to result from implementing the recommended action. Used to quantify the reliability benefit and justify investment in the improvement program.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatFailureCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Failure Count' ;
    rdfs:comment 'Number of times this specific failure mode has occurred on this asset or asset class. Used to identify chronic reliability issues and bad actors requiring focused improvement efforts.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Flag' ;
    rdfs:comment 'Indicates whether the reliability event had actual or potential safety implications requiring additional safety review and controls.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Assessment of the reliability event severity based on impact to operations, safety, production, and asset lifecycle. Critical events require immediate action; high severity events significantly impact operations; medium and low severity events have progressively less operational impact.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocationCode rdf:type rdf:Property ;
    rdfs:label 'Site Location Code' ;
    rdfs:comment 'Code identifying the mine site or facility where the reliability event occurred. Used for site-level reliability performance tracking and benchmarking.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownPlanId rdf:type rdf:Property ;
    rdfs:label 'Shutdown Plan Id' ;
    rdfs:comment 'Unique identifier for the planned maintenance shutdown or major overhaul event. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShutdownPlan .

ind:primaryAffectedStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Primary Affected Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Shutdowns significantly affect local communities through workforce fluctuations, contractor accommodation demand, and local business impacts. Tracking primary affected stakeholder enables targeted com' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:primaryShutdownEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shutdown Employee Id' ;
    rdfs:comment 'Identifier of the maintenance superintendent or shutdown manager accountable for planning, coordinating, and executing the shutdown event.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryShutdownLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Shutdown Last Modified By Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the shutdown plan record, establishing accountability for the most recent changes.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryShutdownCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Shutdown Created By Employee Id' ;
    rdfs:comment 'Identifier of the user who created the shutdown plan record, establishing accountability for plan origination.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Total actual duration of the shutdown in hours, calculated from actual start to actual end timestamps, enabling schedule variance analysis.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorInvolvementFlag rdf:type rdf:Property ;
    rdfs:label 'Contractor Involvement Flag' ;
    rdfs:comment 'Indicates whether external contractors are engaged for any work packages within the shutdown, triggering contractor management and coordination requirements.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalPathDurationHours rdf:type rdf:Property ;
    rdfs:label 'Critical Path Duration Hours' ;
    rdfs:comment 'Duration of the longest sequence of dependent activities (critical path) that determines the minimum shutdown duration, used for schedule optimization and risk management.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Required Flag' ;
    rdfs:comment 'Indicates whether the shutdown requires environmental permits or notifications for activities such as emissions, waste disposal, or water discharge.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearnedSummary rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Summary' ;
    rdfs:comment 'Post-shutdown summary of key lessons learned, best practices identified, and improvement opportunities for future shutdown planning and execution.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Hours' ;
    rdfs:comment 'Total planned duration of the shutdown in hours, from start to completion, used for resource planning and production impact forecasting.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyPermitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Required Flag' ;
    rdfs:comment 'Indicates whether the shutdown requires special safety permits such as hot work permits, confined space entry permits, or isolation certificates.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Comprehensive narrative describing the overall scope of work, objectives, and deliverables for the shutdown event, including major work packages and critical activities.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownName rdf:type rdf:Property ;
    rdfs:label 'Shutdown Name' ;
    rdfs:comment 'Descriptive name of the shutdown event, such as \'Annual Plant Shutdown 2024\' or \'SAG Mill Major Overhaul Q2\'.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownNumber rdf:type rdf:Property ;
    rdfs:label 'Shutdown Number' ;
    rdfs:comment 'Business identifier for the shutdown event, typically a human-readable code used across planning, execution, and reporting systems.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownStatus rdf:type rdf:Property ;
    rdfs:label 'Shutdown Status' ;
    rdfs:comment 'Current lifecycle status of the shutdown plan: draft (initial planning), planned (scope defined), approved (authorized for execution), in_progress (shutdown underway), completed (all work finished), cancelled (shutdown not proceeding), or on_hold (temporarily suspended). [ENUM-REF-CANDIDATE: draft|planned|approved|in_progress|completed|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownType rdf:type rdf:Property ;
    rdfs:label 'Shutdown Type' ;
    rdfs:comment 'Classification of the shutdown event by purpose and scope: annual shutdown (routine yearly maintenance), major overhaul (extensive equipment rebuild), statutory inspection (regulatory compliance), emergency shutdown (unplanned critical event), planned outage (scheduled downtime), or turnaround (comprehensive facility maintenance).' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActualCost rdf:type rdf:Property ;
    rdfs:label 'Total Actual Cost' ;
    rdfs:comment 'Total actual cost incurred during shutdown execution, aggregated from all work orders, purchase orders, and contractor invoices, enabling cost variance analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalActualLabourHours rdf:type rdf:Property ;
    rdfs:label 'Total Actual Labour Hours' ;
    rdfs:comment 'Aggregate of all actual labour hours consumed across all work packages during shutdown execution, enabling productivity and efficiency analysis.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedCost rdf:type rdf:Property ;
    rdfs:label 'Total Planned Cost' ;
    rdfs:comment 'Total estimated cost for the shutdown including labour, materials, contractor services, and equipment hire, used for budget approval and financial planning.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlannedLabourHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Labour Hours' ;
    rdfs:comment 'Aggregate of all estimated labour hours across all work packages and scope items within the shutdown plan, used for workforce planning and resource levelling.' ;
    rdfs:domain ind:ShutdownPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedContractorId rdf:type rdf:Property ;
    rdfs:label 'Assigned Contractor Id' ;
    rdfs:comment 'Reference to the contractor or service provider assigned to execute this scope item. Links to the contractor master data for commercial tracking.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:actualLabourHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labour Hours' ;
    rdfs:comment 'Actual total labour hours consumed to complete this scope item. Captured for cost tracking and future estimation accuracy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfMaterialsReference rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Reference' ;
    rdfs:comment 'Reference to the bill of materials listing all spare parts and consumables required for this scope item. Used for procurement and inventory planning.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this scope item is on the critical path of the shutdown schedule. True if any delay will extend the overall shutdown duration.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLabourHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labour Hours' ;
    rdfs:comment 'Planned total labour hours required to complete this scope item. Used for resource levelling and cost estimation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predecessorScopeItems rdf:type rdf:Property ;
    rdfs:label 'Predecessor Scope Items' ;
    rdfs:comment 'Comma-separated list of scope item numbers that must be completed before this scope item can commence. Defines task dependencies for scheduling.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'Planned date when work on this scope item is scheduled to be completed. Used for critical path analysis and shutdown duration planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date when work on this scope item is scheduled to commence. Used for resource scheduling and shutdown timeline management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeItemNumber rdf:type rdf:Property ;
    rdfs:label 'Scope Item Number' ;
    rdfs:comment 'Business identifier for the scope item within the shutdown plan. Typically a hierarchical or sequential numbering scheme used for tracking and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the scope item. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Classification of the scope item by maintenance type. Determines the nature of work to be executed during the shutdown.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardJobCode rdf:type rdf:Property ;
    rdfs:label 'Standard Job Code' ;
    rdfs:comment 'Reference to a standard job plan or procedure that defines the detailed steps for this scope item. Ensures consistency and quality.' ;
    rdfs:domain ind:MaintenanceShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeCode rdf:type rdf:Property ;
    rdfs:label 'Trade Code' ;
    rdfs:comment 'Code identifying the primary trade or craft skill required to execute this scope item (e.g., mechanical, electrical, instrumentation, civil).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDescription rdf:type rdf:Property ;
    rdfs:label 'Trade Description' ;
    rdfs:comment 'Full description of the trade or craft skill required for this scope item. Provides clarity for resource planning and allocation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfMaterialsFlag rdf:type rdf:Property ;
    rdfs:label 'Bill Of Materials Flag' ;
    rdfs:comment 'Indicates whether this spare part is itself composed of sub-components tracked as a BOM structure.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Classification of spare part criticality based on impact to operations: insurance (strategic stock for catastrophic failure), critical (required for production continuity), non-critical (routine consumables).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical dimensions of the spare part (length x width x height) in standard units. Supports storage planning and handling logistics.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Economic Order Quantity' ;
    rdfs:comment 'Optimal order quantity that minimizes total inventory costs including ordering costs and holding costs.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of hazardous material type (e.g., flammable, corrosive, toxic, explosive) per regulatory standards. Populated only if hazardous_material_flag is true.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeablePartNumber rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Number' ;
    rdfs:comment 'Reference to alternative or substitute part numbers that can be used interchangeably. Supports obsolescence management and supply chain flexibility.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date when this spare part was last issued from inventory for maintenance work. Used for consumption pattern analysis.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent procurement transaction for this spare part. Used for usage analysis and obsolescence detection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) or supplier who produces the spare part.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum inventory quantity allowed to avoid overstocking, obsolescence risk, and excessive capital tie-up.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsolescenceStatus rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Status' ;
    rdfs:comment 'Current lifecycle status indicating availability and support: active (fully supported), obsolete (no longer available), phase-out (limited availability), discontinued (manufacturer ceased production).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level categorization of the spare part (e.g., mechanical, electrical, hydraulic, structural, consumable, lubricant, wear part).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed textual description of the spare part including its function, specifications, and application context.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'Current operational status of the spare part master record: active (available for use), inactive (not in use), pending (awaiting approval), blocked (restricted from use).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Type classification indicating lifecycle management approach: rotable (reusable after repair), repairable (can be refurbished), consumable (single-use), expendable (disposable).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level threshold that triggers a replenishment order. Calculated based on lead time demand and safety stock requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Tracking Flag' ;
    rdfs:comment 'Indicates whether individual units of this spare part are tracked by unique serial numbers for traceability and warranty management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Maximum storage duration in months before the part degrades or becomes unusable. Critical for consumables, lubricants, and rubber components.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardUnitCost rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Cost' ;
    rdfs:comment 'Standard cost per unit of measure for inventory valuation and maintenance cost estimation. Excludes freight and taxes.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Warehouse or storage bin location code where the spare part is physically stored. Supports warehouse management and picking operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this job plan is currently active and available for selection in new work orders and PM schedules.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Competency Requirements' ;
    rdfs:comment 'List of required certifications, licenses, or competency levels that technicians must hold to execute this job plan (e.g., high voltage license, confined space entry certification).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCode rdf:type rdf:Property ;
    rdfs:label 'Frequency Code' ;
    rdfs:comment 'Recommended or typical execution frequency for this job plan when used in preventive maintenance schedules. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|biennial|condition_based — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPlanCode rdf:type rdf:Property ;
    rdfs:label 'Job Plan Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the standard job plan in the CMMS. Used for lookup and reference across PM schedules and work orders.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Job Plan Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance activity covered by this standard job plan, including scope, objectives, and expected outcomes.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPlanType rdf:type rdf:Property ;
    rdfs:label 'Job Plan Type' ;
    rdfs:comment 'Classification of the maintenance activity type that this job plan supports.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsListAttachedFlag rdf:type rdf:Property ;
    rdfs:label 'Parts List Attached Flag' ;
    rdfs:comment 'Indicates whether a Bill of Materials (BOM) or parts list is attached to this job plan, specifying required spare parts and consumables.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryTradeCode rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Code' ;
    rdfs:comment 'Code identifying the primary trade or craft required to execute this job plan (e.g., ELEC for electrician, MECH for mechanic, INST for instrument technician).' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTradeDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Description' ;
    rdfs:comment 'Full name or description of the primary trade required for this job plan.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current revision of the job plan was created or last modified.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential version number of the job plan. Incremented each time the plan is updated and re-approved to maintain change history.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInstructions rdf:type rdf:Property ;
    rdfs:label 'Safety Instructions' ;
    rdfs:comment 'Detailed safety procedures, hazard warnings, and Personal Protective Equipment (PPE) requirements that must be followed when executing this job plan.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated title or summary of the job plan for display in lists, dropdowns, and mobile interfaces.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardOperatingProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Standard Operating Procedure Reference' ;
    rdfs:comment 'Reference number or hyperlink to the detailed Standard Operating Procedure (SOP) document that provides step-by-step instructions for this job plan.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequenceCount rdf:type rdf:Property ;
    rdfs:label 'Task Sequence Count' ;
    rdfs:comment 'Total number of sequential tasks defined in this job plan. Each task represents a discrete step in the maintenance procedure.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Cost' ;
    rdfs:comment 'Total estimated cost for executing this job plan, including labor, materials, and contractor costs. Used for budgeting and cost control.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedHours rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Hours' ;
    rdfs:comment 'Sum of estimated labor hours across all tasks and trades defined in this job plan. Used for scheduling and resource planning.' ;
    rdfs:domain ind:StandardJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this job plan has been used to generate work orders or PM schedules. Indicates plan popularity and effectiveness.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work execution was completed on site.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionCode rdf:type rdf:Property ;
    rdfs:label 'Completion Code' ;
    rdfs:comment 'Standardized code indicating the outcome or reason for work order closure (e.g., completed as planned, partially completed, deferred, cancelled, unable to complete).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorCost rdf:type rdf:Property ;
    rdfs:label 'Contractor Cost' ;
    rdfs:comment 'Total cost of external contractor services engaged for the work order execution.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'Variance between estimated and actual total cost (actual minus estimated). Positive values indicate cost overrun, negative values indicate cost savings.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentHireCost rdf:type rdf:Property ;
    rdfs:label 'Equipment Hire Cost' ;
    rdfs:comment 'Total cost of hired equipment, tools, or machinery used during work order execution (e.g., crane hire, specialist tooling).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingSource rdf:type rdf:Property ;
    rdfs:label 'Originating Source' ;
    rdfs:comment 'System or process that initiated the work order: CMMS scheduled PM, SCADA alert, operator request, inspection finding, condition monitoring system, or breakdown event. [ENUM-REF-CANDIDATE: cmms|scada_alert|operator_request|inspection|condition_monitoring|pm_schedule|breakdown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsMaterialsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Materials Cost' ;
    rdfs:comment 'Total cost of spare parts, consumables, and materials consumed during work order execution. Sourced from inventory transactions and purchase orders.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Scheduled date when the maintenance work is planned to be completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyPermitReference rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Reference' ;
    rdfs:comment 'Reference number of the safety work permit or isolation certificate required before work can commence (e.g., hot work permit, confined space entry, electrical isolation).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCoOrderReference rdf:type rdf:Property ;
    rdfs:label 'Sap Co Order Reference' ;
    rdfs:comment 'Reference to the SAP CO internal order used for detailed cost tracking and allocation of the work order.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shutdownFlag rdf:type rdf:Property ;
    rdfs:label 'Shutdown Flag' ;
    rdfs:comment 'Indicates whether this work order is part of a planned shutdown or turnaround event requiring asset downtime.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeCraftRequired rdf:type rdf:Property ;
    rdfs:label 'Trade Craft Required' ;
    rdfs:comment 'Primary trade or craft skill required for the work order execution (e.g., fitter, electrician, boilermaker, diesel mechanic, instrumentation technician).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle status of the work order in the CMMS workflow. [ENUM-REF-CANDIDATE: draft|planned|approved|released|in_progress|on_hold|completed|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance work order: preventive (PM), corrective (CM), predictive (PdM), condition-based (CBM), breakdown, or project work.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderCostId rdf:type rdf:Property ;
    rdfs:label 'Work Order Cost Id' ;
    rdfs:comment 'Unique identifier for the work order cost record. Primary key for this entity.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetReference rdf:type rdf:Property ;
    rdfs:label 'Budget Reference' ;
    rdfs:comment 'Reference to the maintenance budget line item or project budget against which this work order cost is tracked. Links cost actuals to budget planning.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:c1AllocationFlag rdf:type rdf:Property ;
    rdfs:label 'C1 Allocation Flag' ;
    rdfs:comment 'Indicates whether this work order cost is included in the C1 cash cost calculation. True if the cost is part of direct operating costs; false if excluded (e.g., royalties, depreciation).' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCaptureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cost Capture Timestamp' ;
    rdfs:comment 'Date and time when the cost record was initially captured in the system. Represents the business event time for cost recording.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costNotes rdf:type rdf:Property ;
    rdfs:label 'Cost Notes' ;
    rdfs:comment 'Free-text notes and comments related to the work order cost record. Provides additional context, explanations, or justifications for cost variances.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPostingDate rdf:type rdf:Property ;
    rdfs:label 'Cost Posting Date' ;
    rdfs:comment 'Date on which the work order costs were posted to the general ledger. Determines the financial period for cost recognition and reporting.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Cost Record Number' ;
    rdfs:comment 'Business identifier for the work order cost record. Externally visible reference number used in financial reporting and cost reconciliation processes.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Current lifecycle status of the cost record in the approval and posting workflow. Tracks progression from draft through approval to final posting in the general ledger.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Classification of the work order cost as operating expenditure (OPEX), capital expenditure (CAPEX), sustaining capital, or project capital. Critical for financial reporting and AISC/C1 cost allocation.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Percentage' ;
    rdfs:comment 'Cost variance expressed as a percentage of the total estimated cost. Calculated as (cost_variance / total_estimated_cost) * 100. Used for performance reporting and trend analysis.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherCost rdf:type rdf:Property ;
    rdfs:label 'Other Cost' ;
    rdfs:comment 'Miscellaneous actual costs not classified under labour, parts, contractor, or equipment hire categories. Includes permits, travel, accommodation, and incidental expenses.' ;
    rdfs:domain ind:WorkOrderCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedCrewId rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Id' ;
    rdfs:comment 'Foreign key reference to the maintenance crew or team assigned to execute this task. Used when tasks require multi-person coordination.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:scheduleActivityId rdf:type rdf:Property ;
    rdfs:label 'Schedule Activity Id' ;
    rdfs:comment 'Foreign key linking to project.schedule_activity. Business justification: During commissioning and pre-production phases, maintenance tasks (lubrication, alignment checks, run-in procedures) are scheduled as project activities. Mining operations link tasks to project schedu' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleActivity .

ind:taskPlanStandardJobId rdf:type rdf:Property ;
    rdfs:label 'Task Plan Standard Job Id' ;
    rdfs:comment 'Foreign key reference to the master task plan template from which this task instance was generated. Links to preventive maintenance schedules.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StandardJob .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized code identifying the type of failure or defect addressed by this task. Used for failure mode analysis and reliability engineering.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the maintenance task or operation step to be performed, including specific instructions and procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Business identifier for the task, typically a combination of work order number and task sequence. Used for external reference and reporting.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance task. Tracks progression through planning, execution, and completion stages. [ENUM-REF-CANDIDATE: planned|ready|in_progress|on_hold|completed|cancelled|deferred — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchId rdf:type rdf:Property ;
    rdfs:label 'Bench Id' ;
    rdfs:comment 'Foreign key linking to mine.bench. Business justification: blast_execution has bench_elevation_m (DECIMAL) but no FK to bench table. Adding bench_id FK normalizes bench reference and removes redundant elevation column. The bench table contains elevation_rl_m,' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bench .

ind:blastRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Blast Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to hse.risk_assessment. Business justification: Blasting is high-risk activity requiring documented risk assessment before execution. Regulatory requirement in all mining jurisdictions. Complements existing incident link by capturing preventive con' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:pitOrLevelId rdf:type rdf:Property ;
    rdfs:label 'Pit Or Level Id' ;
    rdfs:comment 'Reference to the specific open-cut pit or underground level where the blast was executed. Supports spatial analysis and strip ratio tracking by pit.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PitOrLevel .

ind:primaryBlastCrewSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Blast Crew Supervisor Employee Id' ;
    rdfs:comment 'Reference to the shift supervisor or blast crew leader who oversaw the physical loading and firing of the blast. Supports accountability tracking and post-incident investigation.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftReportId rdf:type rdf:Property ;
    rdfs:label 'Shift Report Id' ;
    rdfs:comment 'Foreign key linking to mine.shift_report. Business justification: Blast events occur during a shift and are reported in shift report. N:1 relationship (many blasts per shift). No bidirectional conflict. Valid operational link.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftReport .

ind:actualExplosiveMassKg rdf:type rdf:Property ;
    rdfs:label 'Actual Explosive Mass Kg' ;
    rdfs:comment 'Total mass of explosive in kilograms actually consumed during loading and detonation. Compared against planned to compute consumption variance and update explosive inventory in SAP MM.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airblastOverpressureDb rdf:type rdf:Property ;
    rdfs:label 'Airblast Overpressure Db' ;
    rdfs:comment 'Peak airblast overpressure in decibels (dB) measured at the nearest sensitive receiver. Used to assess compliance with community noise and airblast limits specified in the mine\'s Environmental Impact Statement (EIS) and operating licence.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blastApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Blast Approval Timestamp' ;
    rdfs:comment 'Date and time at which the blast design and loading plan received formal approval from the authorised blast engineer or mine manager. Required for regulatory compliance and audit trail under MSHA and state mining regulations.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blastNumber rdf:type rdf:Property ;
    rdfs:label 'Blast Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the blast event by the blast management system (e.g., SHOTPlus or BME). Used for cross-system traceability and regulatory reporting. Corresponds to the blast ID in Hexagon MinePlan and IsoMetrix incident linkage.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blastStatus rdf:type rdf:Property ;
    rdfs:label 'Blast Status' ;
    rdfs:comment 'Current lifecycle state of the blast event, tracking progression from design through execution and post-blast clearance. Drives exclusion zone management and shift handover communications.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blastedRockMassT rdf:type rdf:Property ;
    rdfs:label 'Blasted Rock Mass T' ;
    rdfs:comment 'Estimated total mass of rock in tonnes broken by the blast, derived from the blast volume and in-situ rock density. Used for powder factor calculation, production reconciliation, and haulage planning.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detonationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detonation Timestamp' ;
    rdfs:comment 'Actual date and time at which the blast was detonated. The principal real-world event timestamp for the blast execution lifecycle. Recorded to millisecond precision for vibration and airblast monitoring correlation.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dilutionPct rdf:type rdf:Property ;
    rdfs:label 'Dilution Pct' ;
    rdfs:comment 'Estimated percentage of waste material mixed with ore during the blast, expressed as a percentage of total blasted material. High dilution reduces head grade and processing efficiency. A key blast quality KPI tracked against the LOM plan.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionZoneCompliant rdf:type rdf:Property ;
    rdfs:label 'Exclusion Zone Compliant' ;
    rdfs:comment 'Indicates whether the exclusion zone was fully established and verified clear of personnel and equipment prior to detonation. Non-compliance triggers mandatory IsoMetrix HSE incident reporting.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionZoneRadiusM rdf:type rdf:Property ;
    rdfs:label 'Exclusion Zone Radius M' ;
    rdfs:comment 'Radius in metres of the mandatory exclusion zone established around the blast area prior to detonation. Determined by blast design and regulatory requirements to protect personnel and equipment from flyrock.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentationP80Mm rdf:type rdf:Property ;
    rdfs:label 'Fragmentation P80 Mm' ;
    rdfs:comment 'Post-blast fragmentation size at the 80th percentile in millimetres, assessed via photogrammetry or image analysis (e.g., Split-Desktop, WipFrag). Indicates whether the blast achieved the target fragmentation for downstream crusher and mill feed requirements.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentationTargetP80Mm rdf:type rdf:Property ;
    rdfs:label 'Fragmentation Target P80 Mm' ;
    rdfs:comment 'Planned target fragmentation size at the 80th percentile in millimetres as specified in the blast design. Compared against actual fragmentation_p80_mm to assess blast quality and optimise future designs.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiationSystemType rdf:type rdf:Property ;
    rdfs:label 'Initiation System Type' ;
    rdfs:comment 'Type of detonation initiation system used (e.g., electronic, non-electric NONEL, shock tube). Electronic systems (e.g., Orica i-kon, Dyno Nobel DigiShot) provide precise timing control for vibration management.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misfireCount rdf:type rdf:Property ;
    rdfs:label 'Misfire Count' ;
    rdfs:comment 'Number of holes that failed to detonate as planned during the blast event. Misfires are a critical safety hazard requiring mandatory reporting under MSHA and state mining regulations and must be managed per IsoMetrix HSE incident workflow.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:misfireResolved rdf:type rdf:Property ;
    rdfs:label 'Misfire Resolved' ;
    rdfs:comment 'Indicates whether all misfires identified during this blast event have been safely resolved and cleared. A value of False triggers a mandatory hold on re-entry and follow-up IsoMetrix HSE action.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oreTonnesBlasted rdf:type rdf:Property ;
    rdfs:label 'Ore Tonnes Blasted' ;
    rdfs:comment 'Estimated mass of ore-grade material in tonnes broken by the blast, based on the geological block model classification. Used for production reconciliation, dilution tracking, and ROM pad inventory updates.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakParticleVelocityMms rdf:type rdf:Property ;
    rdfs:label 'Peak Particle Velocity Mms' ;
    rdfs:comment 'Maximum ground vibration measured in millimetres per second (mm/s) at the nearest sensitive receiver during the blast. Compared against regulatory and community limits to assess vibration compliance. Sourced from OSIsoft PI System seismograph integration.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBurdenM rdf:type rdf:Property ;
    rdfs:label 'Planned Burden M' ;
    rdfs:comment 'Designed distance in metres between the blast hole and the free face (burden). A critical blast design parameter controlling fragmentation, flyrock risk, and ground vibration.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedExplosiveMassKg rdf:type rdf:Property ;
    rdfs:label 'Planned Explosive Mass Kg' ;
    rdfs:comment 'Total mass of explosive in kilograms specified in the approved blast design across all holes. Used for powder factor calculation and explosive inventory planning.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHoleDepthM rdf:type rdf:Property ;
    rdfs:label 'Planned Hole Depth M' ;
    rdfs:comment 'Designed depth of each blast hole in metres as specified in the blast design. Includes sub-drill allowance below the bench floor to ensure complete fragmentation at the toe.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSpacingM rdf:type rdf:Property ;
    rdfs:label 'Planned Spacing M' ;
    rdfs:comment 'Designed distance in metres between adjacent blast holes within a row. Together with burden, determines the powder factor and fragmentation distribution.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powderFactorKgPerT rdf:type rdf:Property ;
    rdfs:label 'Powder Factor Kg Per T' ;
    rdfs:comment 'Ratio of actual explosive mass consumed (kg) to the total mass of rock blasted (tonnes). A key blast efficiency metric used to optimise fragmentation, digging rates, and explosive costs. Calculated as actual_explosive_mass_kg / blasted_rock_mass_t.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Re Entry Timestamp' ;
    rdfs:comment 'Date and time at which the exclusion zone was lifted and personnel were authorised to re-enter the blast area following post-blast inspection and fume clearance. Critical for shift productivity and safety compliance.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wasteTonnesBlasted rdf:type rdf:Property ;
    rdfs:label 'Waste Tonnes Blasted' ;
    rdfs:comment 'Estimated mass of waste rock in tonnes broken by the blast. Used for strip ratio calculation, waste dump scheduling, and overburden haulage planning.' ;
    rdfs:domain ind:BlastExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsSampleBatchId rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Batch Id' ;
    rdfs:comment 'Identifier of the assay sample batch in LabWare LIMS from which the grade data for this block was sourced. Provides traceability from the grade control block back to the laboratory analysis records.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleBatch .

ind:resourceModelId rdf:type rdf:Property ;
    rdfs:label 'Resource Model Id' ;
    rdfs:comment 'Identifier of the geological resource block model version from which this grade control block\'s initial grade estimates were derived. Enables traceability back to the JORC-compliant resource model in Geovia GEMS.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockModel .

ind:blockCode rdf:type rdf:Property ;
    rdfs:label 'Block Code' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the grade control block as assigned in Geovia GEMS or the mine\'s block model system. Used for cross-system traceability and field reference.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockName rdf:type rdf:Property ;
    rdfs:label 'Block Name' ;
    rdfs:comment 'Human-readable name or label assigned to the grade control block, typically combining bench, row, and column identifiers for operational reference at the mine face.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockSizeXM rdf:type rdf:Property ;
    rdfs:label 'Block Size X M' ;
    rdfs:comment 'Horizontal dimension of the grade control block in the X (easting) direction, in metres. Defines the block geometry used for volume and tonnage calculations.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockSizeYM rdf:type rdf:Property ;
    rdfs:label 'Block Size Y M' ;
    rdfs:comment 'Horizontal dimension of the grade control block in the Y (northing) direction, in metres. Defines the block geometry used for volume and tonnage calculations.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockSizeZM rdf:type rdf:Property ;
    rdfs:label 'Block Size Z M' ;
    rdfs:comment 'Vertical dimension (height) of the grade control block in metres, typically equal to the bench height. Used for volume and tonnage calculations.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the grade control block indicating its operational state. \'active\' = classified and awaiting dispatch; \'dispatched\' = ore/waste destination assigned; \'mined_out\' = block fully extracted; \'on_hold\' = pending re-assay or review; \'cancelled\' = block voided.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkDensityTm3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density Tm3' ;
    rdfs:comment 'Bulk density of the material in the grade control block expressed in tonnes per cubic metre (t/m³). Used to convert block volume to in-situ tonnes. Sourced from laboratory measurements or geological domain defaults.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidEastingM rdf:type rdf:Property ;
    rdfs:label 'Centroid Easting M' ;
    rdfs:comment 'Easting coordinate of the block centroid in the mine\'s local or projected coordinate system (metres). Used for spatial location, blast pattern design, and GIS integration.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centroidNorthingM rdf:type rdf:Property ;
    rdfs:label 'Centroid Northing M' ;
    rdfs:comment 'Northing coordinate of the block centroid in the mine\'s local or projected coordinate system (metres). Used for spatial location, blast pattern design, and GIS integration.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date on which the ore/waste classification decision was made for this grade control block, based on assay results and cut-off grade analysis. Represents the principal business event date for this entity.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Confidence level assigned to the grade estimate for this block, reflecting the density and quality of sampling data. \'high\' = well-drilled with close-spaced samples; \'medium\' = adequate sampling; \'low\' = sparse data, interpolated grade. Influences dispatch decision risk.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dilutionFactorPct rdf:type rdf:Property ;
    rdfs:label 'Dilution Factor Pct' ;
    rdfs:comment 'Estimated percentage of waste or gangue material mixed with ore during mining of this block, expressed as a percentage. Dilution reduces the effective grade of mined material relative to in-situ grade. Used for reconciliation and production planning.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchDestination rdf:type rdf:Property ;
    rdfs:label 'Dispatch Destination' ;
    rdfs:comment 'Assigned destination for the material in this grade control block based on its classification. Drives truck dispatch instructions in the Fleet Management System (FMS). \'mill_feed\' = direct to processing plant; \'rom_pad\' = Run of Mine stockpile; \'low_grade_stockpile\' = future processing; \'waste_dump\' = permanent waste; \'tsf\' = Tailings Storage Facility.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchInstructionCode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Instruction Code' ;
    rdfs:comment 'Specific dispatch instruction code issued to the Fleet Management System (FMS) for truck routing of material from this block. Corresponds to a destination code in Caterpillar MineStar for automated truck assignment.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insituTonnes rdf:type rdf:Property ;
    rdfs:label 'Insitu Tonnes' ;
    rdfs:comment 'Estimated in-situ dry metric tonnes of material within the grade control block, calculated from block volume and bulk density. Represents the raw tonnage before mining dilution or recovery adjustments.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isResampled rdf:type rdf:Property ;
    rdfs:label 'Is Resampled' ;
    rdfs:comment 'Indicates whether this grade control block has been subject to a re-assay or resampling event due to initial classification uncertainty or grade variability. True = block was resampled; False = original assay used. Supports audit trail for classification decisions.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minedOutDate rdf:type rdf:Property ;
    rdfs:label 'Mined Out Date' ;
    rdfs:comment 'Date on which the grade control block was fully extracted and the block status transitioned to \'mined_out\'. Used for production reconciliation, LOM tracking, and mine closure planning.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mineralDomainCode rdf:type rdf:Property ;
    rdfs:label 'Mineral Domain Code' ;
    rdfs:comment 'Geological domain or mineralisation zone code to which this block belongs, as defined in the resource model. Used for grade estimation and variogram modelling within homogeneous geological units.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGrade rdf:type rdf:Property ;
    rdfs:label 'Primary Grade' ;
    rdfs:comment 'Assay-derived grade of the primary commodity (e.g., Fe%, Cu%, Li ppm) for the grade control block. The principal quantitative fact driving ore/waste classification and dispatch decisions. Units depend on commodity (% for Fe/Cu, ppm for Li/Au).' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Primary Grade Unit' ;
    rdfs:comment 'Unit of measure for the primary commodity grade value (e.g., \'pct\' for percentage, \'ppm\' for parts per million, \'g_per_t\' for grams per tonne). Ensures correct interpretation of the primary_grade field across different commodities.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryGrade rdf:type rdf:Property ;
    rdfs:label 'Secondary Grade' ;
    rdfs:comment 'Assay-derived grade of a secondary or by-product commodity (e.g., SiO2%, Al2O3%, S%) for the grade control block. Used for penalty/bonus calculations, blending decisions, and metallurgical planning.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryGradeElement rdf:type rdf:Property ;
    rdfs:label 'Secondary Grade Element' ;
    rdfs:comment 'Chemical element or compound symbol for the secondary grade value (e.g., \'SiO2\', \'Al2O3\', \'S\', \'P\'). Identifies which element the secondary_grade field represents for this block.' ;
    rdfs:domain ind:GradeControlBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulageCycleId rdf:type rdf:Property ;
    rdfs:label 'Haulage Cycle Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual haul truck cycle record in the Silver layer. Primary key generated by the Databricks lakehouse ingestion pipeline from Caterpillar MineStar Fleet Management System (FMS) telemetry data.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHaulageAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Haulage Asset Id' ;
    rdfs:comment 'Reference to the haul truck asset that performed this cycle. Links to the equipment/fleet master record in the Fleet Management System (FMS) and Infor EAM asset registry.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryHaulageLoadLocationFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Haulage Load Location Functional Location Id' ;
    rdfs:comment 'Reference to the spatial location (bench, pit, stope, or ROM pad) from which the truck was loaded. Links to the mine location/spatial master for origin-based production and grade tracking.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:romStockpileId rdf:type rdf:Property ;
    rdfs:label 'Rom Stockpile Id' ;
    rdfs:comment 'Foreign key linking to mine.rom_stockpile. Business justification: Haulage cycles can dump to ROM stockpiles. N:1 relationship (many cycles to one stockpile). No bidirectional conflict. Valid operational link.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RomStockpile .

ind:tertiaryHaulageFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Haulage Functional Location Id' ;
    rdfs:comment 'Reference to the primary haul road segment traversed during this cycle. Used for road condition monitoring, fuel consumption benchmarking by route, and haulage route optimisation.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:wasteDumpId rdf:type rdf:Property ;
    rdfs:label 'Waste Dump Id' ;
    rdfs:comment 'Foreign key linking to mine.waste_dump. Business justification: Haulage cycles can dump waste to waste dumps. N:1 relationship (many cycles to one dump). No bidirectional conflict. Valid operational link.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteDump .

ind:dumpTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Dump Time Seconds' ;
    rdfs:comment 'Duration in seconds from when the truck arrived at the dump point to when it departed after discharging its load. Includes tipping and body lowering time. Used in cycle time analysis and dump point throughput modelling.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dumpType rdf:type rdf:Property ;
    rdfs:label 'Dump Type' ;
    rdfs:comment 'Categorical classification of the dump destination for this cycle. Values: crusher (primary crusher feed), rom_pad (Run of Mine stockpile pad), stockpile (grade-segregated stockpile), waste_dump (permanent waste rock dump), tsf (Tailings Storage Facility). Drives material flow reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Litres' ;
    rdfs:comment 'Total diesel fuel consumed in litres during this haulage cycle as recorded by the truck\'s on-board fuel monitoring system integrated with Caterpillar MineStar. Used for C1 (C1 Cash Cost) per tonne calculation, OPEX tracking, and GHG emissions reporting.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulEmptyTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Haul Empty Time Seconds' ;
    rdfs:comment 'Duration in seconds for the empty (return) haul from the dump destination back to the loading point. Compared against haul full time to assess road grade asymmetry and return route efficiency.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulFullTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Haul Full Time Seconds' ;
    rdfs:comment 'Duration in seconds for the loaded (full) haul from the loading point to the dump destination. Reflects haul road conditions, grade, distance, and truck speed. Key input for haulage route optimisation and fuel modelling.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOverloaded rdf:type rdf:Property ;
    rdfs:label 'Is Overloaded' ;
    rdfs:comment 'Indicates whether the truck payload exceeded the nominal rated payload capacity for this cycle (True = overloaded). Overloading causes accelerated tyre and suspension wear, increases maintenance costs, and may breach equipment warranty conditions. Sourced from Caterpillar MineStar TPMS.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRehandle rdf:type rdf:Property ;
    rdfs:label 'Is Rehandle' ;
    rdfs:comment 'Indicates whether this cycle involved rehandling of previously stockpiled material (True = rehandle). Rehandle cycles are tracked separately from primary extraction cycles for accurate OPEX (Operating Expenditure) per tonne reporting and production efficiency analysis.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadPassCount rdf:type rdf:Property ;
    rdfs:label 'Load Pass Count' ;
    rdfs:comment 'Number of bucket/dipper passes made by the loading unit (excavator or shovel) to fill the haul truck to its payload target. Used in truck-shovel match factor analysis and loader bucket fill factor assessment.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Load Time Seconds' ;
    rdfs:comment 'Duration in seconds from when loading commenced to when the truck departed the loading point with a full load. Reflects loader productivity and number of passes required. Used in truck-shovel match factor analysis.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nominalPayloadTonnes rdf:type rdf:Property ;
    rdfs:label 'Nominal Payload Tonnes' ;
    rdfs:comment 'The rated/design payload capacity of the haul truck model in metric tonnes as specified by the manufacturer. Used as the denominator for payload utilisation percentage calculation and overload detection.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreGradeEstimate rdf:type rdf:Property ;
    rdfs:label 'Ore Grade Estimate' ;
    rdfs:comment 'Estimated head grade of the material in the truck load as assigned by the grade control model at the time of loading (e.g., % Fe for iron ore, % Cu for copper). Nullable for waste loads. Used for production grade reconciliation against JORC resource model.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Queue Time Seconds' ;
    rdfs:comment 'Duration in seconds the truck spent waiting in queue at the dump point before being able to discharge its load. Indicates crusher or dump point congestion. Used for bottleneck analysis and production scheduling optimisation.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spotTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Spot Time Seconds' ;
    rdfs:comment 'Duration in seconds from when the truck arrived at the loading point to when loading commenced. Measures truck positioning efficiency. A key component of the cycle time breakdown used in truck-shovel match factor analysis.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Cycle Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds for the complete haulage cycle from spot to end of empty return haul. Sum of spot, load, haul full, queue, dump, and haul empty times. Primary KPI input for truck productivity and OEE (Overall Equipment Effectiveness) reporting.' ;
    rdfs:domain ind:HaulageCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aiscUsdPerT rdf:type rdf:Property ;
    rdfs:label 'Aisc Usd Per T' ;
    rdfs:comment 'All-In Sustaining Cost (AISC) per tonne, expressed in USD. Includes C1 cash costs plus sustaining CAPEX, royalties, and corporate G&A. Provides a comprehensive cost measure for economic viability assessment and investor disclosure.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAnnualOreMt rdf:type rdf:Property ;
    rdfs:label 'Average Annual Ore Mt' ;
    rdfs:comment 'The average annual ore extraction rate in million tonnes per year (Mtpa) over the full LOM plan. Used for steady-state OPEX modelling, workforce planning, and long-term supply agreements.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageOreGrade rdf:type rdf:Property ;
    rdfs:label 'Average Ore Grade' ;
    rdfs:comment 'The average head grade of the ore reserve included in the LOM plan, expressed in the same unit as cutoff_grade_unit. A key input to revenue and concentrate production forecasts.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1CashCostUsdPerT rdf:type rdf:Property ;
    rdfs:label 'C1 Cash Cost Usd Per T' ;
    rdfs:comment 'The C1 Cash Cost per tonne of ore or concentrate produced, expressed in USD. Represents direct cash costs of mining and processing excluding royalties, depreciation, and sustaining capital. Industry-standard cost metric for benchmarking and investor reporting.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityPriceAssumptionUsd rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Assumption Usd' ;
    rdfs:comment 'The long-term commodity price assumption used in the LOM financial model, expressed in USD per tonne (or per lb/oz as applicable). A critical sensitivity input; changes to this assumption materially affect NPV and IRR outcomes.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competentPersonName rdf:type rdf:Property ;
    rdfs:label 'Competent Person Name' ;
    rdfs:comment 'Name of the Competent Person (JORC/SAMREC) or Qualified Person (NI 43-101/SEC S-K 1300) who has reviewed and signed off on the mineral resource and reserve estimates underpinning this LOM plan. Required for regulatory disclosure.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Assumption' ;
    rdfs:comment 'The foreign exchange rate assumption used in the LOM financial model (e.g., AUD/USD, CLP/USD). Applied to convert local currency OPEX and CAPEX to USD for NPV/IRR calculations. A key sensitivity variable in the financial model.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomStripRatio rdf:type rdf:Property ;
    rdfs:label 'Lom Strip Ratio' ;
    rdfs:comment 'The overall Life of Mine strip ratio, expressed as tonnes of waste per tonne of ore (t:t). A key economic indicator representing the ratio of overburden to ore that must be moved to extract the ore reserve. Calculated as total_waste_mt / total_ore_reserve_mt.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvMusd rdf:type rdf:Property ;
    rdfs:label 'Npv Musd' ;
    rdfs:comment 'Net Present Value (NPV) of the LOM plan in millions of USD, calculated using the Discounted Cash Flow (DCF) methodology at the specified discount rate. Primary financial metric for investment decision-making and project approval.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakAnnualOreMt rdf:type rdf:Property ;
    rdfs:label 'Peak Annual Ore Mt' ;
    rdfs:comment 'The maximum planned annual ore extraction rate in million tonnes per year (Mtpa) over the LOM plan. Used for infrastructure sizing, processing plant capacity planning, and peak CAPEX determination.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'The calendar date on which the LOM plan production schedule concludes, representing the projected end of mine life including rehabilitation and closure activities.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'The calendar date from which the LOM plan production schedule commences. Represents the effective start of the planned mine life, aligned with the first scheduled ore extraction period.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the LOM plan (e.g., \'v1.0\', \'v2.3\'). Enables tracking of iterative revisions and scenario comparisons over the mine life planning cycle.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedRecoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Planned Recovery Rate Pct' ;
    rdfs:comment 'The planned metallurgical recovery rate expressed as a percentage, representing the proportion of the valuable mineral extracted from the ore during processing. A critical input to concentrate production and revenue forecasting in the LOM plan.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probableReserveMt rdf:type rdf:Property ;
    rdfs:label 'Probable Reserve Mt' ;
    rdfs:comment 'Probable Ore Reserve category in million tonnes, as defined by JORC/NI 43-101/SAMREC. Lower geological confidence than Proved Reserve but still economically viable and included in the LOM production schedule.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provedReserveMt rdf:type rdf:Property ;
    rdfs:label 'Proved Reserve Mt' ;
    rdfs:comment 'Highest-confidence ore reserve category (Proved Reserve) in million tonnes, as defined by JORC/NI 43-101/SAMREC. Represents the portion of the ore body with the greatest geological certainty, used in bankable feasibility studies and investor disclosures.' ;
    rdfs:domain ind:LomPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapexMusd rdf:type rdf:Property ;
    rdfs:label 'Total Capex Musd' ;
    rdfs:comment 'Total planned Capital Expenditure (CAPEX) over the full mine life in millions of USD, including pre-production development, sustaining capital, and closure/rehabilitation costs. A primary input to NPV and IRR calculations in the LOM financial model.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOpexMusd rdf:type rdf:Property ;
    rdfs:label 'Total Opex Musd' ;
    rdfs:comment 'Total planned Operating Expenditure (OPEX) over the full mine life in millions of USD, encompassing mining, processing, G&A, and site services costs. Used in conjunction with revenue forecasts to derive LOM cash flow projections.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteMt rdf:type rdf:Property ;
    rdfs:label 'Total Waste Mt' ;
    rdfs:comment 'Total planned waste rock and overburden movement over the full mine life in million tonnes. Used to calculate the Life of Mine (LOM) strip ratio and plan waste dump infrastructure and haulage requirements.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialMovementId rdf:type rdf:Property ;
    rdfs:label 'Material Movement Id' ;
    rdfs:comment 'Primary key for material_movement' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Functional Location Id' ;
    rdfs:comment 'Reference to the destination location to which material was delivered, such as a crusher, processing plant, stockpile, or waste dump. Sourced from the mine location registry.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:movementCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Movement Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Material movements are costed to cost centres for haulage cost allocation, unit cost calculation, and mining cost tracking. Core operational finance link. Reusing cost_centre_code as denormalized fiel' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:primaryMaterialFunctionalLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Functional Location Id' ;
    rdfs:comment 'Reference to the source location from which material was extracted or loaded, such as a bench, stope, ROM pad, or stockpile. Sourced from the mine location registry.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:sourceTenementId rdf:type rdf:Property ;
    rdfs:label 'Source Tenement Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement. Business justification: Ore movements must track source tenement for accurate royalty calculations (rates vary by tenement/state), production reporting by license area, and expenditure commitment substantiation for regulator' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenement .

ind:dryTonnes rdf:type rdf:Property ;
    rdfs:label 'Dry Tonnes' ;
    rdfs:comment 'Weight of material in metric dry tonnes, calculated by adjusting tonnes_delivered for moisture content. Dry tonnes is the standard unit for commodity sales contracts, JORC resource reporting, and revenue recognition under CIF/FOB terms.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGradePct rdf:type rdf:Property ;
    rdfs:label 'Estimated Grade Pct' ;
    rdfs:comment 'Estimated head grade of the primary commodity in the moved material, expressed as a percentage (e.g., % Fe for iron ore, % Cu for copper). Derived from the geological block model at the source location. Used for ore quality tracking and production reconciliation.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Free-text description of the material being moved, providing additional context beyond the material type classification, such as lithology, ore zone name, or specific waste rock type.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moisturePct rdf:type rdf:Property ;
    rdfs:label 'Moisture Pct' ;
    rdfs:comment 'Estimated moisture content of the moved material expressed as a percentage of total weight. Moisture affects the dry tonne calculation, commodity grade reporting, and processing plant feed quality. Sourced from geological sampling or SCADA sensors.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement End Timestamp' ;
    rdfs:comment 'The real-world timestamp when the material movement was completed, i.e., when the haul truck or conveyor finished dumping or delivering material at the destination location.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this material movement transaction, formatted as MM-{YEAR}-{SEQUENCE}. Used for cross-system reconciliation between FMS, SCADA, and ERP.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Start Timestamp' ;
    rdfs:comment 'The real-world timestamp when the material movement commenced, i.e., when the haul truck or conveyor began loading or transporting material at the source location. Principal business event time for this transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of the material movement transaction as tracked by the Fleet Management System (FMS). Drives production reporting and dispatch reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the movement activity type. Primary haul is direct extraction to destination; rehandle is movement of previously stockpiled material; stockpile reclaim is feeding from a stockpile to the plant; ROM feed is delivery to the Run of Mine (ROM) pad; waste dump is disposal of waste rock.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stripRatioContribution rdf:type rdf:Property ;
    rdfs:label 'Strip Ratio Contribution' ;
    rdfs:comment 'The incremental contribution of this movement to the strip ratio calculation, expressed as the ratio of waste tonnes to ore tonnes moved in this transaction. Aggregated to compute the overall strip ratio (overburden to ore ratio) for the pit or mining area.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnesDelivered rdf:type rdf:Property ;
    rdfs:label 'Tonnes Delivered' ;
    rdfs:comment 'Net weight in metric tonnes of material delivered and confirmed at the destination location, as recorded by the FMS or weighbridge at the crusher or stockpile. May differ from tonnes_loaded due to spillage or measurement variance.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnesLoaded rdf:type rdf:Property ;
    rdfs:label 'Tonnes Loaded' ;
    rdfs:comment 'Gross weight in metric tonnes of material loaded onto the haul truck or conveyor at the source location, as measured by the on-board payload management system or weighbridge.' ;
    rdfs:domain ind:MaterialMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'The mode of transport used to move material from source to destination. Distinguishes between haul truck, conveyor belt, rail, front-end loader (FEL), and underground truck, enabling mode-specific cost and productivity analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planScenarioId rdf:type rdf:Property ;
    rdfs:label 'Plan Scenario Id' ;
    rdfs:comment 'Unique identifier for the mine plan scenario record. Primary key.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanScenario .

ind:parentScenarioPlanScenarioId rdf:type rdf:Property ;
    rdfs:label 'Parent Scenario Plan Scenario Id' ;
    rdfs:comment 'Reference to the parent scenario from which this scenario was derived or forked, enabling scenario lineage tracking.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanScenario .

ind:primaryPlanCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Plan Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this scenario record.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commodityPriceUnit rdf:type rdf:Property ;
    rdfs:label 'Commodity Price Unit' ;
    rdfs:comment 'Unit of measure for the commodity price assumption (e.g., per tonne, per pound, per ounce).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateCurrencyPair rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Currency Pair' ;
    rdfs:comment 'Currency pair for the exchange rate assumption (e.g., USD/AUD, USD/CAD).' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalScenarioReference rdf:type rdf:Property ;
    rdfs:label 'External Scenario Reference' ;
    rdfs:comment 'External reference identifier or file path in the source planning system (Deswik or Hexagon MinePlan) for traceability.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetSizeConstraint rdf:type rdf:Property ;
    rdfs:label 'Fleet Size Constraint' ;
    rdfs:comment 'Maximum number of equipment units (trucks, loaders, drills) assumed available in this scenario as a constraint parameter.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketDemandConstraintTpa rdf:type rdf:Property ;
    rdfs:label 'Market Demand Constraint Tpa' ;
    rdfs:comment 'Maximum annual market demand in tonnes per annum assumed as a constraint in this scenario.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon End Date' ;
    rdfs:comment 'End date of the planning horizon covered by this scenario.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Start Date' ;
    rdfs:comment 'Start date of the planning horizon covered by this scenario.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'Duration of the planning horizon in years for this scenario.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCommodity rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity' ;
    rdfs:comment 'Primary commodity targeted in this mine plan scenario (e.g., iron ore, copper, coal, lithium, nickel).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCapacityConstraintTpa rdf:type rdf:Property ;
    rdfs:label 'Processing Capacity Constraint Tpa' ;
    rdfs:comment 'Maximum annual processing plant capacity in tonnes per annum assumed as a constraint in this scenario.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Code' ;
    rdfs:comment 'Business identifier code for the mine plan scenario, used for external reference and reporting.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Descriptive name of the mine plan scenario for business user identification and reporting purposes.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioStatus rdf:type rdf:Property ;
    rdfs:label 'Scenario Status' ;
    rdfs:comment 'Current lifecycle status of the mine plan scenario in the approval workflow.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Classification of the scenario type indicating the planning approach or purpose (base case, optimistic, pessimistic, sensitivity analysis, feasibility study, expansion plan).' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioVersion rdf:type rdf:Property ;
    rdfs:label 'Scenario Version' ;
    rdfs:comment 'Version number of this scenario, incremented with each revision to support version control and audit trail.' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensitivityParameter rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Parameter' ;
    rdfs:comment 'Key parameter being varied in sensitivity analysis scenarios (e.g., commodity price, exchange rate, discount rate, recovery rate).' ;
    rdfs:domain ind:PlanScenario ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualExtractionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Extraction Date' ;
    rdfs:comment 'Actual calendar date on which extraction of this block commenced. Populated post-extraction from FMS (Fleet Management System) or SCADA records. Used for schedule variance analysis and production reconciliation.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockHeightM rdf:type rdf:Property ;
    rdfs:label 'Block Height M' ;
    rdfs:comment 'Height dimension of the mining block in metres (Z-direction / bench height). Corresponds to the bench height in open-cut or the stope height in underground operations.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockLengthM rdf:type rdf:Property ;
    rdfs:label 'Block Length M' ;
    rdfs:comment 'Length dimension of the mining block in metres (Y-direction in the block model). Used with width and height to compute block volume and in-situ tonnage.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockWidthM rdf:type rdf:Property ;
    rdfs:label 'Block Width M' ;
    rdfs:comment 'Width dimension of the mining block in metres (X-direction in the block model). Together with height and length defines the block volume used for tonnage estimation.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionSequence rdf:type rdf:Property ;
    rdfs:label 'Extraction Sequence' ;
    rdfs:comment 'Numeric sequence or priority order in which this block is scheduled for extraction within the mine plan. Lower values indicate earlier extraction. Drives the production schedule and LOM (Life of Mine) plan sequencing in Deswik and Hexagon MinePlan.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardnessIndex rdf:type rdf:Property ;
    rdfs:label 'Hardness Index' ;
    rdfs:comment 'Measure of rock hardness or grindability, typically expressed as Bond Work Index (BWi) in kWh/t. Used to estimate comminution energy requirements for SAG mill and HPGR circuit design and throughput forecasting.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insituDensity rdf:type rdf:Property ;
    rdfs:label 'Insitu Density' ;
    rdfs:comment 'Estimated in-situ bulk density of the block material in tonnes per cubic metre (t/m³). Derived from geological sampling and used to convert block volume to tonnage. Critical input to resource estimation.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:levelOrDrive rdf:type rdf:Property ;
    rdfs:label 'Level Or Drive' ;
    rdfs:comment 'Underground level designation or drive name to which this block is assigned (e.g., \'4200L\', \'North Drive\'). Applicable for underground mining methods only; null for open-cut blocks.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomPeriod rdf:type rdf:Property ;
    rdfs:label 'Lom Period' ;
    rdfs:comment 'Life of Mine (LOM) planning period to which this block is assigned, expressed as a year (e.g., \'2027\') or year-quarter (e.g., \'2027-Q3\'). Enables aggregation of block-level data to LOM schedule periods for strategic planning and NPV/IRR analysis.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Model Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this block\'s attributes in the source geological block model. Supports data lineage tracking, reconciliation workflows, and audit trail requirements under JORC and regulatory reporting frameworks.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pitOrLevelCode rdf:type rdf:Property ;
    rdfs:label 'Pit Or Level Code' ;
    rdfs:comment 'Reference to the open-cut pit or underground level/drive to which this block is assigned for extraction planning and scheduling.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryFactor rdf:type rdf:Property ;
    rdfs:label 'Recovery Factor' ;
    rdfs:comment 'Estimated proportion of the target mineral that will be successfully extracted and recovered through the processing circuit, expressed as a decimal fraction (e.g., 0.88 = 88% recovery). Incorporates both mining recovery and metallurgical recovery. Used to calculate payable metal from the block.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledExtractionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Extraction Date' ;
    rdfs:comment 'Planned calendar date on which extraction of this block is scheduled to commence, as defined in the current mine production schedule. Used for LOM planning, fleet scheduling, and processing plant feed forecasting.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:secondaryGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Secondary Grade Unit' ;
    rdfs:comment 'Unit of measure for the secondary element grade value. Mirrors the unit options available for primary_grade_unit.' ;
    rdfs:domain ind:MiningBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the pit design was formally approved by the responsible engineering authority for use in mine planning and scheduling. Null if not yet approved.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchHeightM rdf:type rdf:Property ;
    rdfs:label 'Bench Height M' ;
    rdfs:comment 'The vertical height of each mining bench in metres. Determines the drilling and blasting pattern, equipment selection, and ore/waste delineation resolution. Typically 5–15 m for large open-cut operations.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bermWidthM rdf:type rdf:Property ;
    rdfs:label 'Berm Width M' ;
    rdfs:comment 'The width of catch berms (safety benches) in metres between inter-ramp slope segments. Berms are designed to catch falling material and provide geotechnical stability. Minimum berm width is governed by geotechnical design criteria.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCode rdf:type rdf:Property ;
    rdfs:label 'Design Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this pit design within the mine planning system (e.g., PIT-NW-001-R3). Used as the business-facing reference across engineering, scheduling, and LOM planning documents.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEngineer rdf:type rdf:Property ;
    rdfs:label 'Design Engineer' ;
    rdfs:comment 'Name or employee identifier of the mine planning or geotechnical engineer responsible for authoring this pit design revision. Used for accountability and design review traceability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designFileReference rdf:type rdf:Property ;
    rdfs:label 'Design File Reference' ;
    rdfs:comment 'File path or document management system reference to the source design file (e.g., DXF, DWG, or MinePlan project file) containing the pit shell geometry. Enables engineers to retrieve the authoritative spatial data.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable descriptive name of the pit design (e.g., \'North-West Pit Stage 3 Pushback\'). Used in reports, LOM schedules, and stakeholder communications.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designNotes rdf:type rdf:Property ;
    rdfs:label 'Design Notes' ;
    rdfs:comment 'Free-text field for engineering notes, assumptions, constraints, or change rationale associated with this pit design revision. Captures context not represented in structured fields.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designStatus rdf:type rdf:Property ;
    rdfs:label 'Design Status' ;
    rdfs:comment 'Current lifecycle status of the pit design record. \'draft\' indicates work-in-progress; \'under_review\' means submitted for engineering or geotechnical review; \'approved\' is the authorised design for mine planning; \'superseded\' means replaced by a newer revision; \'archived\' is retained for historical reference only.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'Classification of the pit design indicating its engineering purpose. \'ultimate_pit\' is the final planned pit extent; \'pushback\' or \'cutback\' represents an incremental mining stage; \'stage\' is a scheduled mining increment; \'interim\' is a temporary design used for short-term planning. [ENUM-REF-CANDIDATE: ultimate_pit|pushback|stage|cutback|interim|exploration — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Face Angle Deg' ;
    rdfs:comment 'The bench face angle in degrees, representing the angle of the individual bench face from horizontal. Determined by rock mass strength and blasting parameters. Typically 65°–80° for competent rock.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydrogeologyConsidered rdf:type rdf:Property ;
    rdfs:label 'Hydrogeology Considered' ;
    rdfs:comment 'Indicates whether hydrogeological conditions (groundwater, dewatering requirements) were explicitly incorporated into the pit slope design parameters. True = hydrogeology modelled; False = not considered or not applicable.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interRampAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Inter Ramp Angle Deg' ;
    rdfs:comment 'The inter-ramp slope angle in degrees, measured between catch berms. Represents the slope angle of the pit wall between successive ramp access levels. Used in geotechnical stability analysis and bench design.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimisationSoftware rdf:type rdf:Property ;
    rdfs:label 'Optimisation Software' ;
    rdfs:comment 'Name of the mine planning software used to generate the pit shell optimisation (e.g., Hexagon MinePlan, Deswik, Whittle). Provides provenance for the design methodology and enables reproducibility of results.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreTonnes rdf:type rdf:Property ;
    rdfs:label 'Ore Tonnes' ;
    rdfs:comment 'Total estimated ore tonnes within the pit design shell above the applied cut-off grade. Derived from the resource block model intersected with the pit shell geometry. Used in LOM scheduling and reserve reporting.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallSlopeAngleDeg rdf:type rdf:Property ;
    rdfs:label 'Overall Slope Angle Deg' ;
    rdfs:comment 'The overall inter-ramp or overall pit slope angle in degrees, representing the angle from horizontal of the pit wall from crest to toe. A critical geotechnical parameter governing pit stability and strip ratio. Typically ranges from 35° to 55° depending on rock mass conditions.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitBottomRlM rdf:type rdf:Property ;
    rdfs:label 'Pit Bottom Rl M' ;
    rdfs:comment 'The elevation of the pit floor at its lowest point, expressed as a Reduced Level (RL) in metres above mean sea level (AHD or equivalent datum). Defines the maximum depth of the pit design.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitCrestRlM rdf:type rdf:Property ;
    rdfs:label 'Pit Crest Rl M' ;
    rdfs:comment 'The elevation of the pit crest (top of the uppermost bench) in metres above mean sea level (AHD or equivalent datum). Together with pit_bottom_rl_m defines the total vertical depth of the pit.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pitVolumeBcm rdf:type rdf:Property ;
    rdfs:label 'Pit Volume Bcm' ;
    rdfs:comment 'Total volume of material (ore and waste) within the pit design shell, expressed in Bank Cubic Metres (BCM). Used for LOM scheduling, equipment fleet sizing, and capital cost estimation.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rampGradientPct rdf:type rdf:Property ;
    rdfs:label 'Ramp Gradient Pct' ;
    rdfs:comment 'The maximum gradient of haul road ramps within the pit expressed as a percentage (rise over run × 100). Governs truck cycle times and fuel consumption. Typically 8–12% for large haul trucks.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rampWidthM rdf:type rdf:Property ;
    rdfs:label 'Ramp Width M' ;
    rdfs:comment 'The design width of haul road ramps within the pit in metres. Determines the minimum turning radius and equipment access for the selected truck fleet. Typically 3–4 times the width of the largest haul truck.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Resource Model Version' ;
    rdfs:comment 'Version identifier of the geological resource block model used as the basis for this pit design optimisation. Ensures traceability between the pit shell geometry and the underlying resource estimate. Sourced from Geovia GEMS or Hexagon MinePlan.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDepthM rdf:type rdf:Property ;
    rdfs:label 'Total Depth M' ;
    rdfs:comment 'The total vertical depth of the pit design in metres, calculated as the difference between pit crest RL and pit bottom RL. A key design parameter for geotechnical stability assessment and LOM planning.' ;
    rdfs:domain ind:PitDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTonnes rdf:type rdf:Property ;
    rdfs:label 'Waste Tonnes' ;
    rdfs:comment 'Total estimated waste rock tonnes within the pit design shell, including overburden and internal waste. Used to calculate strip ratio and plan waste dump capacity.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Production Reconciliation Id' ;
    rdfs:comment 'Unique surrogate identifier for each production reconciliation record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Identifier of the qualified geologist responsible for preparing and validating the reconciliation record. The responsible geologist is a Competent Person under JORC or Qualified Person under NI 43-101 who certifies the geological model inputs.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:stopeDesignId rdf:type rdf:Property ;
    rdfs:label 'Stope Design Id' ;
    rdfs:comment 'Foreign key linking to mine.stope_design. Business justification: For underground mining reconciliation, linking to stope_design provides access to design parameters for comparison with actuals. This is essential for underground production reconciliation. No redunda' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StopeDesign .

ind:actualGrade rdf:type rdf:Property ;
    rdfs:label 'Actual Grade' ;
    rdfs:comment 'Actual head grade (percentage or grams per tonne) of the primary commodity as determined by assay results from LabWare LIMS for the reconciliation period. Used as the numerator in F2 (grade reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMetalContent rdf:type rdf:Property ;
    rdfs:label 'Actual Metal Content' ;
    rdfs:comment 'Actual contained metal or mineral content (tonnes of metal) for the reconciliation period, derived from actual_tonnes and actual_grade assay data from LabWare LIMS. Used as the numerator in F3 (metal content reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualTonnes rdf:type rdf:Property ;
    rdfs:label 'Actual Tonnes' ;
    rdfs:comment 'Actual ore tonnes mined and delivered to the ROM pad or processing plant during the reconciliation period, as measured by Caterpillar MineStar FMS payload data and survey. Used as the numerator in F1 (tonnes reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assaySampleCount rdf:type rdf:Property ;
    rdfs:label 'Assay Sample Count' ;
    rdfs:comment 'Number of assay samples collected and analysed in LabWare LIMS to determine the actual_grade for this reconciliation period. Higher sample counts increase grade confidence. Used to assess statistical reliability of the F2 grade reconciliation factor.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchElevationM rdf:type rdf:Property ;
    rdfs:label 'Bench Elevation M' ;
    rdfs:comment 'Elevation in metres above sea level (mRL) of the mining bench or stope level from which the reconciled ore was extracted. Used to spatially locate the reconciliation within the mine design and correlate with the geological block model in Geovia GEMS.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:f1Factor rdf:type rdf:Property ;
    rdfs:label 'F1 Factor' ;
    rdfs:comment 'F1 reconciliation factor representing the ratio of actual mined tonnes to geological model tonnes (actual_tonnes / model_tonnes). A value of 1.0 indicates perfect tonnes reconciliation. Values significantly above or below 1.0 indicate geological model uncertainty or mining dilution issues. Critical JORC resource model confidence metric.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:f2Factor rdf:type rdf:Property ;
    rdfs:label 'F2 Factor' ;
    rdfs:comment 'F2 reconciliation factor representing the ratio of actual mined grade to geological model grade (actual_grade / model_grade). A value of 1.0 indicates perfect grade reconciliation. Deviations indicate geological estimation error, sampling bias, or dilution effects. Critical for resource model confidence and JORC compliance.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:f3Factor rdf:type rdf:Property ;
    rdfs:label 'F3 Factor' ;
    rdfs:comment 'F3 reconciliation factor representing the ratio of actual metal content to geological model metal content (actual_metal_content / model_metal_content). Combines the effect of both F1 and F2 (F3 = F1 × F2). The primary indicator of overall geological model performance and resource model confidence for JORC and NI 43-101 reporting.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeVariancePct rdf:type rdf:Property ;
    rdfs:label 'Grade Variance Pct' ;
    rdfs:comment 'Percentage variance between actual mined grade and geological model grade, expressed as ((actual_grade - model_grade) / model_grade) × 100. Positive values indicate higher-than-predicted grade; negative values indicate grade underperformance. Drives cut-off grade and ore/waste classification reviews.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelGrade rdf:type rdf:Property ;
    rdfs:label 'Model Grade' ;
    rdfs:comment 'Predicted head grade (percentage or grams per tonne) of the primary commodity for the reconciliation period as estimated in the geological block model. Used as the denominator in F2 (grade reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelMetalContent rdf:type rdf:Property ;
    rdfs:label 'Model Metal Content' ;
    rdfs:comment 'Predicted contained metal or mineral content (tonnes of metal) for the reconciliation period, calculated as model_tonnes multiplied by model_grade. Represents the geological model\'s expected metal inventory. Used in F3 (metal content reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelTonnes rdf:type rdf:Property ;
    rdfs:label 'Model Tonnes' ;
    rdfs:comment 'Predicted ore tonnes for the reconciliation period as derived from the geological block model in Geovia GEMS or Hexagon MinePlan. Represents the mine plan scheduled tonnes before actual mining. Used as the denominator in F1 (tonnes reconciliation factor) calculation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Model Update Required' ;
    rdfs:comment 'Indicates whether the reconciliation results have triggered a requirement to update the geological block model in Geovia GEMS. Set to True when F1, F2, or F3 factors fall outside acceptable tolerance thresholds, indicating the resource model requires re-estimation.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oreRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Ore Recovery Pct' ;
    rdfs:comment 'Percentage of the geological model ore tonnes that were successfully extracted and delivered to the ROM pad or processing plant, accounting for ore losses to waste dumps or misclassification. Distinct from metallurgical recovery rate in the processing plant.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreSourceCode rdf:type rdf:Property ;
    rdfs:label 'Ore Source Code' ;
    rdfs:comment 'Identifier for the specific ore source (e.g., pit bench, stope, ore block, or mining block) from which the reconciled tonnes were extracted. Sourced from Geovia GEMS block model and Hexagon MinePlan scheduling.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreSourceType rdf:type rdf:Property ;
    rdfs:label 'Ore Source Type' ;
    rdfs:comment 'Classification of the ore source by mining method or material origin. Distinguishes between open-cut bench, underground stope, ROM pad stockpile, or blended feed to the processing plant. Critical for strip ratio and dilution analysis.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Granularity of the reconciliation period. Determines the reporting cadence and is used to aggregate or disaggregate reconciliation factors (F1/F2/F3) for LOM planning and JORC resource model confidence assessments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End' ;
    rdfs:comment 'End date of the production period covered by this reconciliation. Together with reconciliation_period_start defines the temporal scope of the comparison between geological model and actual production.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start' ;
    rdfs:comment 'Start date of the production period covered by this reconciliation. Typically aligned to shift, daily, weekly, monthly, or quarterly reporting cycles.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationReference rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Reference' ;
    rdfs:comment 'Externally-known business identifier for the reconciliation run, typically formatted as REC-<SITE>-<YEAR>-<PERIOD>. Used for cross-system traceability across Geovia GEMS, LabWare LIMS, and Caterpillar MineStar.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnesVariancePct rdf:type rdf:Property ;
    rdfs:label 'Tonnes Variance Pct' ;
    rdfs:comment 'Percentage variance between actual mined tonnes and geological model tonnes, expressed as ((actual_tonnes - model_tonnes) / model_tonnes) × 100. Positive values indicate over-mining relative to model; negative values indicate under-mining. Used for production scheduling variance reporting.' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Primary categorical classification of the reconciliation variance cause. Used for trend analysis and systematic identification of recurring model or operational issues. Supports resource model update prioritisation and mine planning improvement. [ENUM-REF-CANDIDATE: geological_model|dilution|ore_loss|sampling_bias|survey_error|blast_movement|equipment_error|classification_error — promote to reference product]' ;
    rdfs:domain ind:ProductionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitOrStopeStopeDesignId rdf:type rdf:Property ;
    rdfs:label 'Pit Or Stope Stope Design Id' ;
    rdfs:comment 'Reference to the specific open-cut pit or underground stope to which this schedule applies. Enables scheduling at the individual mining unit level for bench sequencing and stope optimization.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StopeDesign .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'Reference to the mine planning engineer or scheduler responsible for authoring this production schedule. Links to the workforce/employee master record in SAP HR.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:isLomSchedule rdf:type rdf:Property ;
    rdfs:label 'Is Lom Schedule' ;
    rdfs:comment 'Indicates whether this schedule record is part of the long-range Life of Mine (LOM) plan (True) or a short-to-medium term operational schedule (False). Used to filter LOM planning records from operational scheduling records in analytics.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar date on which the scheduled production period ends. Defines the end boundary of the planning horizon for this schedule record.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar date on which the scheduled production period begins. Defines the start boundary of the planning horizon for this schedule record (e.g., first day of the week, month, or quarter).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedBlastCount rdf:type rdf:Property ;
    rdfs:label 'Planned Blast Count' ;
    rdfs:comment 'The number of planned blast events scheduled within the production period. Used for explosives procurement planning, blast crew scheduling, and regulatory notification compliance.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCapexUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Capex Usd' ;
    rdfs:comment 'The planned Capital Expenditure (CAPEX) in USD allocated to this production schedule period, covering equipment, infrastructure, and development costs. Used for LOM capital planning and NPV/IRR analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDilutionPct rdf:type rdf:Property ;
    rdfs:label 'Planned Dilution Pct' ;
    rdfs:comment 'The planned percentage of waste material mixed with ore during the extraction process (Dilution = waste mixed with ore during mining). Expressed as a percentage. Used to adjust head grade targets and assess ore quality at the ROM pad.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDrillMetres rdf:type rdf:Property ;
    rdfs:label 'Planned Drill Metres' ;
    rdfs:comment 'The total planned drilling metres for blast hole drilling associated with this schedule period. A key drill-and-blast planning metric used to size drilling equipment requirements and schedule blast events.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHaulageCycles rdf:type rdf:Property ;
    rdfs:label 'Planned Haulage Cycles' ;
    rdfs:comment 'The planned number of truck haulage cycles required to move the scheduled ore and waste tonnes during the period. Used for fleet utilisation planning and fuel consumption estimation in the Fleet Management System (FMS).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOpexUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Opex Usd' ;
    rdfs:comment 'The planned Operating Expenditure (OPEX) in USD associated with executing this production schedule for the period. Includes mining, haulage, and processing costs. Used for budget tracking and AISC (All-In Sustaining Cost) reporting.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOreTonnes rdf:type rdf:Property ;
    rdfs:label 'Planned Ore Tonnes' ;
    rdfs:comment 'The scheduled quantity of ore (in dry metric tonnes) to be extracted from the mining block or stope during the schedule period. Represents the primary production target and is the principal quantitative fact of this schedule record. Excludes waste and overburden.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStripRatio rdf:type rdf:Property ;
    rdfs:label 'Planned Strip Ratio' ;
    rdfs:comment 'The planned ratio of waste tonnes to ore tonnes (waste:ore) for the schedule period. A key economic indicator in open-cut mining used to assess mining cost efficiency. Calculated as planned_waste_tonnes / planned_ore_tonnes but stored as a scheduled target value from the mine plan.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalMaterialTonnes rdf:type rdf:Property ;
    rdfs:label 'Planned Total Material Tonnes' ;
    rdfs:comment 'Total planned material movement (ore plus waste, in dry metric tonnes) for the schedule period. Used for equipment allocation, fleet sizing, and haulage planning via the Fleet Management System (FMS).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedWasteTonnes rdf:type rdf:Property ;
    rdfs:label 'Planned Waste Tonnes' ;
    rdfs:comment 'The scheduled quantity of waste rock and overburden (in dry metric tonnes) to be moved during the schedule period. Used to calculate the planned strip ratio and assess haulage and equipment requirements.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleBasis rdf:type rdf:Property ;
    rdfs:label 'Schedule Basis' ;
    rdfs:comment 'Indicates the planning basis of this schedule record. \'budget\' is the approved annual plan; \'forecast\' is a revised in-period estimate; \'actual_reconciled\' is a schedule updated with actual production data; \'scenario\' is a what-if planning scenario.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this production schedule record as sourced from Deswik or Hexagon MinePlan (e.g., PS-2024-Q3-001). Used for cross-system reference and operational reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable descriptive name for the production schedule (e.g., \'North Pit Q3 2024 Monthly Schedule\'). Used for identification in planning dashboards and operational reports.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Temporal horizon classification of the schedule. \'weekly\' covers 7-day operational targets; \'monthly\' covers 4-week periods; \'quarterly\' covers 13-week periods; \'annual\' covers full-year plans; \'lom\' refers to Life of Mine (LOM) long-range planning schedules.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Incremental version number of the production schedule, incremented each time the schedule is revised and re-approved. Enables tracking of schedule revisions and comparison between versions for variance analysis.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetHeadGrade rdf:type rdf:Property ;
    rdfs:label 'Target Head Grade' ;
    rdfs:comment 'The planned average grade of the primary commodity (e.g., % Fe for iron ore, % Cu for copper, g/t Au for gold) in the ore scheduled for extraction. Expressed as a decimal fraction or percentage per commodity convention. Drives mill feed quality targets and recovery rate planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTenementId rdf:type rdf:Property ;
    rdfs:label 'Primary Tenement Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement. Business justification: ROM stockpiles often blend ore from multiple tenements; tracking primary source tenement enables royalty allocation, grade reconciliation by license area, and accurate production reporting for regulat' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenement .

ind:bulkDensityTM3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density T M3' ;
    rdfs:comment 'Estimated bulk density of the ROM stockpile material in tonnes per cubic metre. Used to convert survey-derived volume measurements to tonne estimates for inventory reconciliation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the ROM stockpile pad was formally commissioned and made available for ore dumping operations. Marks the start of the operational lifecycle for this pad.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentInventoryT rdf:type rdf:Property ;
    rdfs:label 'Current Inventory T' ;
    rdfs:comment 'Current estimated tonnes of ore on the ROM stockpile pad at the time of the last survey or inventory snapshot. Sourced from Caterpillar MineStar truck dispatch data and periodic survey reconciliation.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutOffGradePct rdf:type rdf:Property ;
    rdfs:label 'Cut Off Grade Pct' ;
    rdfs:comment 'Minimum economic grade threshold applied to classify material as ore (vs waste) for this stockpile. Material below cut-off grade is directed to waste dumps. Determined by LOM economic parameters.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which the ROM stockpile pad was formally decommissioned and removed from active operations. Null for currently active pads. Supports LOM planning and mine rehabilitation scheduling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designCapacityT rdf:type rdf:Property ;
    rdfs:label 'Design Capacity T' ;
    rdfs:comment 'Maximum engineered storage capacity of the ROM stockpile pad in dry metric tonnes (DMT) as per mine design specifications. Used for capacity planning, haulage scheduling, and LOM planning.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitRef rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Ref' ;
    rdfs:comment 'Reference number of the environmental permit or approval governing the operation of this ROM stockpile pad, including conditions related to dust suppression, drainage, and contamination prevention.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmsZoneCode rdf:type rdf:Property ;
    rdfs:label 'Fms Zone Code' ;
    rdfs:comment 'Zone code assigned to this ROM stockpile in the Caterpillar MineStar Fleet Management System (FMS). Used to track haul truck dump assignments, cycle times, and tonne delivery records to this pad.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalZone rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Zone' ;
    rdfs:comment 'Geotechnical classification zone of the stockpile pad foundation and surrounding area. Informs structural stability assessments, load-bearing capacity, and safe stacking height limits for the ROM pad.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headGradeCuPct rdf:type rdf:Property ;
    rdfs:label 'Head Grade Cu Pct' ;
    rdfs:comment 'Estimated head grade of copper (Cu) content in the ROM stockpile expressed as a percentage. Applicable for copper operations; null for non-copper commodities. Sourced from LabWare LIMS assay results.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headGradeFePct rdf:type rdf:Property ;
    rdfs:label 'Head Grade Fe Pct' ;
    rdfs:comment 'Estimated head grade of iron (Fe) content in the ROM stockpile expressed as a percentage. Derived from assay data and geological block model estimates. Used for processing plant feed quality management.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headGradePrimaryPct rdf:type rdf:Property ;
    rdfs:label 'Head Grade Primary Pct' ;
    rdfs:comment 'Estimated head grade of the primary valuable element in the ROM stockpile expressed as a percentage, applicable to the commodity type (e.g., Li2O for lithium, Ni for nickel, ash content for coal). Sourced from LabWare LIMS assay results and geological model.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventorySnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Snapshot Timestamp' ;
    rdfs:comment 'Date and time at which the current inventory estimate was last updated or surveyed. Critical for understanding the currency of the inventory figure and scheduling reclaim operations.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxStackHeightM rdf:type rdf:Property ;
    rdfs:label 'Max Stack Height M' ;
    rdfs:comment 'Maximum permitted stacking height of ore on the ROM stockpile pad in metres, as determined by geotechnical assessment and mine design. Exceeding this limit creates slope stability and safety risks.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Pct' ;
    rdfs:comment 'Estimated moisture content of the ROM stockpile material expressed as a percentage. Critical for accurate tonne reconciliation (wet vs dry), processing plant feed management, and transport logistics (weight limits).' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:padAreaM2 rdf:type rdf:Property ;
    rdfs:label 'Pad Area M2' ;
    rdfs:comment 'Total surface area of the ROM stockpile pad in square metres as per mine design. Used for capacity calculations, survey volume estimation, and infrastructure planning.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationVarianceT rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Variance T' ;
    rdfs:comment 'Difference between scheduled tonnes and actual surveyed inventory tonnes for the current period. Positive value indicates over-delivery; negative indicates under-delivery. Key metric for production schedule adherence and ore loss/dilution tracking.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scadaTagCode rdf:type rdf:Property ;
    rdfs:label 'Scada Tag Code' ;
    rdfs:comment 'OSIsoft PI System tag identifier associated with this ROM stockpile for real-time process data monitoring (e.g., belt scale feed rate, moisture sensor readings). Enables integration between the master record and time-series operational data.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTonnesT rdf:type rdf:Property ;
    rdfs:label 'Scheduled Tonnes T' ;
    rdfs:comment 'Planned tonnes to be delivered to this ROM stockpile in the current production scheduling period as per the mine production schedule. Used for reconciliation variance calculation against actual inventory.' ;
    rdfs:domain ind:RomStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockpileCode rdf:type rdf:Property ;
    rdfs:label 'Stockpile Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the ROM stockpile pad, used across operational systems including Caterpillar MineStar, OSIsoft PI, and mine planning tools. Unique within the mine site.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileName rdf:type rdf:Property ;
    rdfs:label 'Stockpile Name' ;
    rdfs:comment 'Human-readable descriptive name of the ROM stockpile pad (e.g., \'North ROM Pad 1\', \'Crusher Feed Stockpile A\'). Used in operational reporting and mine planning communications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileStatus rdf:type rdf:Property ;
    rdfs:label 'Stockpile Status' ;
    rdfs:comment 'Current operational lifecycle status of the ROM stockpile pad. Active = receiving material; Reclaiming = material being drawn down to processing plant; Full = at design capacity; Depleted = empty; On Hold = temporarily suspended.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileType rdf:type rdf:Property ;
    rdfs:label 'Stockpile Type' ;
    rdfs:comment 'Categorical classification of the stockpile\'s operational role within the ore flow: ROM Pad (direct dump from haul trucks), Crusher Feed, Blend Stockpile, Low-Grade, High-Grade, or Waste. Drives processing plant feed sequencing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Surveyed Volume M3' ;
    rdfs:comment 'Volume of material on the ROM stockpile pad as measured by the most recent survey (drone, LiDAR, or conventional survey). Combined with bulk density to derive tonne inventory estimate.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blastsFiredCount rdf:type rdf:Property ;
    rdfs:label 'Blasts Fired Count' ;
    rdfs:comment 'Number of blast events executed during the shift. Used for drill-and-blast productivity tracking, explosive consumption reconciliation, and regulatory blast notification compliance.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakdownDelayHours rdf:type rdf:Property ;
    rdfs:label 'Breakdown Delay Hours' ;
    rdfs:comment 'Total hours of production lost during the shift due to unplanned equipment breakdowns and mechanical failures. Used for Mean Time Between Failures (MTBF) and Mean Time To Repair (MTTR) analysis and maintenance planning.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewHeadcount rdf:type rdf:Property ;
    rdfs:label 'Crew Headcount' ;
    rdfs:comment 'Total number of personnel (operators, technicians, supervisors) who worked during the shift. Used for workforce productivity analysis, labour cost allocation, and safety compliance (persons on site).' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Operating Hours' ;
    rdfs:comment 'Total aggregate operating hours across all production equipment (trucks, excavators, drills) during the shift. Sourced from Caterpillar MineStar FMS engine hours. Used for OEE calculation and maintenance scheduling.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentScheduledHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Scheduled Hours' ;
    rdfs:comment 'Total aggregate scheduled operating hours for all production equipment during the shift as per the mine production schedule. Used as the denominator for equipment utilisation rate calculation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Equipment Utilisation Pct' ;
    rdfs:comment 'Actual equipment utilisation rate for the shift expressed as a decimal percentage (e.g., 0.8500 = 85%). Calculated as equipment operating hours divided by equipment scheduled hours. Key input to Overall Equipment Effectiveness (OEE) reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text handover communication from the outgoing shift supervisor to the incoming shift supervisor. Captures outstanding tasks, equipment status, safety hazards, and operational priorities for continuity of operations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDailyRollupComplete rdf:type rdf:Property ;
    rdfs:label 'Is Daily Rollup Complete' ;
    rdfs:comment 'Indicates whether this shift report has been included in the daily production rollup for management reporting. True when the shift data has been aggregated into the daily summary; False when pending rollup.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lostTimeInjuryCount rdf:type rdf:Property ;
    rdfs:label 'Lost Time Injury Count' ;
    rdfs:comment 'Number of Lost Time Injuries (LTIs) recorded during the shift — injuries resulting in at least one full shift of lost work time. Key input to Lost Time Injury Frequency Rate (LTIFR) regulatory reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metresDeveloped rdf:type rdf:Property ;
    rdfs:label 'Metres Developed' ;
    rdfs:comment 'Total metres of underground development advance (drives, declines, crosscuts) completed during the shift. Applicable to underground mining operations. Used for development schedule tracking.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metresDrilledTarget rdf:type rdf:Property ;
    rdfs:label 'Metres Drilled Target' ;
    rdfs:comment 'Scheduled target metres of drilling for the shift as per the mine production schedule. Used for drill performance variance analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreGradeFePct rdf:type rdf:Property ;
    rdfs:label 'Ore Grade Fe Pct' ;
    rdfs:comment 'Average head grade of iron (Fe) content in ore mined during the shift, expressed as a decimal percentage. Sourced from assay results and grade control data. Used for production reconciliation and mineral resource reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreMinedTargetTonnes rdf:type rdf:Property ;
    rdfs:label 'Ore Mined Target Tonnes' ;
    rdfs:comment 'Scheduled target ore tonnes to be mined during the shift as per the mine production schedule. Used for variance analysis and production reconciliation against actuals.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreMinedTonnes rdf:type rdf:Property ;
    rdfs:label 'Ore Mined Tonnes' ;
    rdfs:comment 'Actual tonnes of ore material mined and dispatched to the Run of Mine (ROM) pad or stockpile during the shift. Core production KPI. Sourced from Caterpillar MineStar FMS truck payload data and OSIsoft PI belt weigher integration.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedMaintenanceDelayHours rdf:type rdf:Property ;
    rdfs:label 'Planned Maintenance Delay Hours' ;
    rdfs:comment 'Total hours of production lost during the shift due to scheduled preventive maintenance activities. Distinguishes planned downtime from unplanned breakdowns for OEE and availability reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Total number of safety incidents (including near misses, first aid, medical treatment, and lost time injuries) recorded during the shift. Used for LTIFR and TRIFR calculation and regulatory HSE reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'The actual date and time the shift concluded at the mine site. Used in conjunction with shift_start_timestamp to calculate shift duration and for production period boundary alignment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftReportNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Report Number' ;
    rdfs:comment 'Externally-known business identifier for the shift report, typically formatted as SR-YYYY-MM-DD-SHF-NNN (e.g., SR-2024-07-15-DAY-001). Used for cross-system reference, regulatory production returns, and management reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'The actual date and time the shift commenced at the mine site. Principal business event timestamp for the shift. Used for production reconciliation, KPI dashboards, and regulatory production returns. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle state of the shift report record. Draft indicates data entry in progress; submitted indicates supervisor sign-off; approved indicates management review complete; closed indicates period locked; voided indicates record cancelled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantEventsNotes rdf:type rdf:Property ;
    rdfs:label 'Significant Events Notes' ;
    rdfs:comment 'Free-text narrative capturing significant events during the shift including major breakdowns, safety incidents, geotechnical events, blast misfires, environmental exceedances, or other notable occurrences. Critical for shift handover and management reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stripRatioActual rdf:type rdf:Property ;
    rdfs:label 'Strip Ratio Actual' ;
    rdfs:comment 'Actual strip ratio for the shift, calculated as waste tonnes moved divided by ore tonnes mined (overburden to ore ratio). A key economic indicator for open-cut mining operations used in OPEX and LOM planning.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteMovedTargetTonnes rdf:type rdf:Property ;
    rdfs:label 'Waste Moved Target Tonnes' ;
    rdfs:comment 'Scheduled target waste tonnes to be moved during the shift as per the mine production schedule. Used for strip ratio variance analysis and LOM planning reconciliation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteMovedTonnes rdf:type rdf:Property ;
    rdfs:label 'Waste Moved Tonnes' ;
    rdfs:comment 'Actual tonnes of waste rock (overburden and interburden) moved to waste dumps during the shift. Used to calculate the strip ratio and track overburden removal progress against the Life of Mine (LOM) plan.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherDelayHours rdf:type rdf:Property ;
    rdfs:label 'Weather Delay Hours' ;
    rdfs:comment 'Total hours of production lost during the shift due to adverse weather conditions (e.g., lightning stand-down, heavy rain, dust storm). Used for delay analysis and production variance reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backfillStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Backfill Strength Mpa' ;
    rdfs:comment 'Specified minimum unconfined compressive strength (UCS) of the cemented backfill in megapascals (MPa) at the design cure time. Applicable only to cemented paste fill and cemented rock fill designs. Drives cement binder content and backfill plant mix design.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backfillType rdf:type rdf:Property ;
    rdfs:label 'Backfill Type' ;
    rdfs:comment 'Type of backfill material specified for this stope design after ore extraction. Determines geotechnical stability of adjacent stopes, backfill plant requirements, and extraction sequence constraints. None indicates open stoping without backfill.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designDate rdf:type rdf:Property ;
    rdfs:label 'Design Date' ;
    rdfs:comment 'Date on which the current revision of the stope design was formally completed and issued by the mine design engineer.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designGradePrimary rdf:type rdf:Property ;
    rdfs:label 'Design Grade Primary' ;
    rdfs:comment 'Estimated in-situ grade of the primary commodity within the designed stope boundary, expressed in the commodity-appropriate unit (g/t for gold/silver, % for base metals). Derived from the block model and used for mill feed planning and revenue forecasting.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designRevision rdf:type rdf:Property ;
    rdfs:label 'Design Revision' ;
    rdfs:comment 'Sequential revision number of the stope design, incremented each time the design is formally updated. Revision 0 represents the initial issue; subsequent revisions capture engineering changes, geotechnical updates, or grade re-interpretations.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designedBy rdf:type rdf:Property ;
    rdfs:label 'Designed By' ;
    rdfs:comment 'Name or employee identifier of the mine design engineer responsible for authoring this stope design revision.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designedDilutionPct rdf:type rdf:Property ;
    rdfs:label 'Designed Dilution Pct' ;
    rdfs:comment 'Planned dilution percentage representing the proportion of waste rock expected to be extracted with the ore due to stope geometry and mining method. Expressed as a percentage of total ROM tonnes. Key input to mill feed grade forecasting.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designedOreTonnes rdf:type rdf:Property ;
    rdfs:label 'Designed Ore Tonnes' ;
    rdfs:comment 'Estimated in-situ ore tonnage within the designed stope boundary, calculated from the block model grade-tonnage curve. Represents the planned ore extraction quantity before dilution and recovery adjustments.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designedRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Designed Recovery Pct' ;
    rdfs:comment 'Planned ore recovery percentage representing the proportion of in-situ ore tonnes expected to be extracted from the stope. Accounts for ore loss to pillars, hangingwall slough, and extraction method limitations.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Designed Volume M3' ;
    rdfs:comment 'Total designed void volume of the stope in cubic metres as calculated from the 3D stope solid in Deswik or Geovia GEMS. Used for backfill volume estimation, blast design, and ventilation requirements.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deswikStopeReference rdf:type rdf:Property ;
    rdfs:label 'Deswik Stope Reference' ;
    rdfs:comment 'Native stope identifier from the Deswik mine planning and stope optimisation system. Enables reconciliation between the silver layer data product and the Deswik source system for scheduling and optimisation workflows.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionMethod rdf:type rdf:Property ;
    rdfs:label 'Extraction Method' ;
    rdfs:comment 'Underground mining extraction method applied to this stope design. Determines drill pattern, blast design, support requirements, and backfill strategy. Key driver of dilution, recovery rate, and OPEX. [ENUM-REF-CANDIDATE: longhole_open|longhole_retreat|cut_and_fill|sublevel_caving|sublevel_stoping|bench_and_fill|room_and_pillar|shrinkage — promote to reference product]' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoviaGemsStopeReference rdf:type rdf:Property ;
    rdfs:label 'Geovia Gems Stope Reference' ;
    rdfs:comment 'Native stope object identifier from the Geovia GEMS geological modelling and mine design system. Used for traceability and data lineage between the silver layer data product and the source system of record.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSupportClass rdf:type rdf:Property ;
    rdfs:label 'Ground Support Class' ;
    rdfs:comment 'Geotechnical ground support classification assigned to the stope design, typically based on rock mass rating (RMR) or Q-system. Drives the specification of rock bolts, cable bolts, mesh, and shotcrete requirements. Class A = competent rock; Class E = very poor ground.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelElevationM rdf:type rdf:Property ;
    rdfs:label 'Level Elevation M' ;
    rdfs:comment 'Elevation in metres above mean sea level (mAMSL) of the primary extraction level or ore drive floor for this stope design. Used for ventilation circuit design, dewatering planning, and LOM scheduling.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomSchedulePeriod rdf:type rdf:Property ;
    rdfs:label 'Lom Schedule Period' ;
    rdfs:comment 'Life of Mine (LOM) planning period or fiscal year-quarter in which this stope is scheduled for extraction (e.g., \'FY2026-Q2\'). Links the stope design to the LOM production schedule in Deswik for NPV and IRR modelling.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreDriveCount rdf:type rdf:Property ;
    rdfs:label 'Ore Drive Count' ;
    rdfs:comment 'Number of ore drives (extraction drives) designed within the stope footprint. Determines development metres required, drill rig access, and mucking logistics for the stope.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oreDriveHeightM rdf:type rdf:Property ;
    rdfs:label 'Ore Drive Height M' ;
    rdfs:comment 'Designed height of each ore drive (extraction drive) within the stope in metres. Determines equipment clearance and development cost per metre.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreDriveWidthM rdf:type rdf:Property ;
    rdfs:label 'Ore Drive Width M' ;
    rdfs:comment 'Designed width of each ore drive (extraction drive) within the stope in metres. Determines equipment clearance, drill pattern geometry, and development cost per metre.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pillarType rdf:type rdf:Property ;
    rdfs:label 'Pillar Type' ;
    rdfs:comment 'Type of geotechnical pillar incorporated into the stope design to maintain ground stability. Crown pillars separate stopes vertically; rib pillars separate stopes horizontally; sill pillars provide floor support; barrier pillars protect major infrastructure. None indicates pillarless design.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pillarWidthM rdf:type rdf:Property ;
    rdfs:label 'Pillar Width M' ;
    rdfs:comment 'Designed width of the geotechnical pillar in metres. Null if no pillar is specified (pillar_type = none). Critical geotechnical parameter determining pillar stability factor and ore loss to pillars.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopeCode rdf:type rdf:Property ;
    rdfs:label 'Stope Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the stope design within the mine planning system. Used as the primary business reference across Deswik, Geovia GEMS, and SAP PS work breakdown structures.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopeHeightM rdf:type rdf:Property ;
    rdfs:label 'Stope Height M' ;
    rdfs:comment 'Designed vertical height of the stope from floor to back (crown) in metres. Critical input for geotechnical stability assessment, cable bolt design, and blast energy calculations.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopeLengthM rdf:type rdf:Property ;
    rdfs:label 'Stope Length M' ;
    rdfs:comment 'Designed horizontal length of the stope along the strike direction in metres. Primary dimension used for volume calculation, drill pattern design, and production scheduling.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopeName rdf:type rdf:Property ;
    rdfs:label 'Stope Name' ;
    rdfs:comment 'Human-readable name or label assigned to the stope design, typically incorporating level, drive, and sequence identifiers (e.g., \'L15-OD-001\'). Used in engineering drawings, P&IDs, and operational communications.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopeWidthM rdf:type rdf:Property ;
    rdfs:label 'Stope Width M' ;
    rdfs:comment 'Designed horizontal width of the stope across the orebody in metres. Determines minimum mining width, dilution exposure, and equipment access requirements.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublevelIntervalM rdf:type rdf:Property ;
    rdfs:label 'Sublevel Interval M' ;
    rdfs:comment 'Vertical distance in metres between sublevels within the stope design, applicable to sublevel caving (SLC) and sublevel stoping extraction methods. Drives drill ring burden, blast design, and ore recovery modelling.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ventilationRequirementM3s rdf:type rdf:Property ;
    rdfs:label 'Ventilation Requirement M3s' ;
    rdfs:comment 'Minimum required fresh air supply to the stope in cubic metres per second (m³/s) during active extraction, as specified in the stope design. Determined by diesel equipment fleet, blast fume clearance time, and regulatory minimum airflow standards.' ;
    rdfs:domain ind:StopeDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Survey Measurement Id' ;
    rdfs:comment 'Unique system-generated identifier for each mine survey measurement record. Primary key for the survey_measurement data product.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the specific geographic location or spatial feature (stockpile, dump, TSF cell, stope) being surveyed, as defined in the mine\'s GIS (Geographic Information System) location master.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FunctionalLocation .

ind:previousSurveySurveyMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Previous Survey Survey Measurement Id' ;
    rdfs:comment 'Reference to the immediately preceding survey measurement record for the same location, enabling period-over-period volumetric change calculation and production reconciliation.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyMeasurement .

ind:primarySurveyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Survey Employee Id' ;
    rdfs:comment 'Reference to the licensed mine surveyor or survey crew responsible for conducting the field survey. Links to the workforce/personnel master data product.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accuracyClass rdf:type rdf:Property ;
    rdfs:label 'Accuracy Class' ;
    rdfs:comment 'Classification of the positional accuracy standard achieved by the survey method. Survey-grade (±0.05m) is required for production reconciliation; engineering-grade (±0.1–0.5m) for planning; reconnaissance for preliminary assessments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Design Volume M3' ;
    rdfs:comment 'The planned or design volume in cubic metres (m³) for the surveyed feature as per the mine design model in Hexagon MinePlan or Deswik. Used to calculate variance to design for production scheduling compliance.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtmFileRef rdf:type rdf:Property ;
    rdfs:label 'Dtm File Ref' ;
    rdfs:comment 'File path or object storage URI referencing the Digital Terrain Model (DTM) or Digital Surface Model (DSM) derived from the survey, used as the basis for volume calculations in Hexagon MinePlan.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationMaxM rdf:type rdf:Property ;
    rdfs:label 'Elevation Max M' ;
    rdfs:comment 'Maximum elevation in metres above Reduced Level (mRL) datum recorded within the survey extent. Used for crest height validation, dump height compliance, and TSF (Tailings Storage Facility) freeboard monitoring.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationMinM rdf:type rdf:Property ;
    rdfs:label 'Elevation Min M' ;
    rdfs:comment 'Minimum elevation in metres above Reduced Level (mRL) datum recorded within the survey extent. Used for bench floor validation, geotechnical monitoring, and pit design compliance.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotechnicalFlag rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Flag' ;
    rdfs:comment 'Indicates whether this survey measurement was triggered or flagged for geotechnical monitoring purposes (e.g., slope stability monitoring, TSF embankment deformation, underground convergence). When true, the record is shared with the geotechnical team for risk assessment.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:horizontalAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Horizontal Accuracy M' ;
    rdfs:comment 'Estimated horizontal positional accuracy of the survey in metres (m), representing the root mean square error (RMSE) of check point comparisons. Governs fitness-for-purpose for production reconciliation and geotechnical monitoring.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointCloudFileRef rdf:type rdf:Property ;
    rdfs:label 'Point Cloud File Ref' ;
    rdfs:comment 'File path or object storage URI referencing the raw point cloud dataset (LAS/LAZ format) or photogrammetric model generated by the survey. Enables traceability back to source survey data in the data lake.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPeriod rdf:type rdf:Property ;
    rdfs:label 'Production Period' ;
    rdfs:comment 'The production reporting period (e.g., 2024-Q3, 2024-W42) to which this survey measurement is attributed for production reconciliation and LOM (Life of Mine) schedule tracking.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAreaM2 rdf:type rdf:Property ;
    rdfs:label 'Survey Area M2' ;
    rdfs:comment 'Total horizontal surface area in square metres (m²) covered by the survey extent polygon. Used to assess survey coverage completeness and calculate average depth or height of material.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Survey Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the survey event, used for cross-referencing with Hexagon MinePlan survey records, field reports, and production reconciliation documents.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Timestamp' ;
    rdfs:comment 'Precise date and time at which the survey capture commenced, including timezone offset. Used for SCADA integration and time-series alignment with OSIsoft PI System historian data.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyedTonnes rdf:type rdf:Property ;
    rdfs:label 'Surveyed Tonnes' ;
    rdfs:comment 'Estimated mass in dry metric tonnes (dmt) of material represented by the surveyed volume, derived by applying the appropriate bulk density factor. Used for production reconciliation against FMS (Fleet Management System) truck counts.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnesChange rdf:type rdf:Property ;
    rdfs:label 'Tonnes Change' ;
    rdfs:comment 'Net change in estimated dry metric tonnes between the current and previous survey for the same location. Used as the primary production reconciliation metric against FMS-reported movement tonnes.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToDesignM3 rdf:type rdf:Property ;
    rdfs:label 'Variance To Design M3' ;
    rdfs:comment 'Difference in cubic metres (m³) between the surveyed volume and the design volume (surveyed minus design). Negative values indicate under-excavation; positive values indicate over-excavation or excess material. Critical for LOM (Life of Mine) plan compliance.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToDesignPct rdf:type rdf:Property ;
    rdfs:label 'Variance To Design Pct' ;
    rdfs:comment 'Percentage variance between the surveyed volume and the design volume, expressed as (surveyed - design) / design × 100. Enables normalised comparison across survey areas of different sizes for production scheduling KPI reporting.' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Vertical Accuracy M' ;
    rdfs:comment 'Estimated vertical positional accuracy of the survey in metres (m), representing the RMSE of elevation check point comparisons. Critical for volumetric calculation reliability and bench floor compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeChangeM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Change M3' ;
    rdfs:comment 'Net volumetric change in cubic metres (m³) between the current survey and the previous survey for the same location. Positive values indicate material addition (e.g., stockpile build); negative values indicate material removal (e.g., pit excavation, reclaim).' ;
    rdfs:domain ind:SurveyMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acidRockDrainageRisk rdf:type rdf:Property ;
    rdfs:label 'Acid Rock Drainage Risk' ;
    rdfs:comment 'Classification of the waste dump\'s potential to generate Acid Rock Drainage (ARD) based on net acid generation (NAG) testing and acid-base accounting (ABA) of the waste material. Drives encapsulation design, water management, and long-term monitoring requirements.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFillTonnes rdf:type rdf:Property ;
    rdfs:label 'Current Fill Tonnes' ;
    rdfs:comment 'Cumulative mass of waste material currently emplaced in the dump expressed in dry metric tonnes. Derived from FMS truck payload data and survey reconciliation. Used for mass-balance and OPEX reporting.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentFillVolumeBcm rdf:type rdf:Property ;
    rdfs:label 'Current Fill Volume Bcm' ;
    rdfs:comment 'Cumulative volume of waste material currently emplaced in the dump expressed in Bank Cubic Metres (BCM). Updated from survey data and FMS haulage records. Used to calculate remaining capacity and track fill progression against LOM schedule.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityBcm rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Bcm' ;
    rdfs:comment 'Total approved design capacity of the waste dump expressed in Bank Cubic Metres (BCM). Represents the maximum volume of in-situ material the facility is permitted and engineered to receive. Sourced from mine planning systems (Hexagon MinePlan, Deswik).' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tonnes' ;
    rdfs:comment 'Total approved design capacity of the waste dump expressed in dry metric tonnes. Complements BCM capacity for mass-balance reconciliation and LOM planning. Sourced from mine planning systems.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dumpCode rdf:type rdf:Property ;
    rdfs:label 'Dump Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the waste dump facility, used in mine planning systems (Hexagon MinePlan, Deswik) and regulatory submissions. Unique across the mine site.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dumpName rdf:type rdf:Property ;
    rdfs:label 'Dump Name' ;
    rdfs:comment 'Human-readable name assigned to the waste dump facility (e.g., \'North Waste Dump 1\', \'Southern Overburden Emplacement\'). Used in operational communications, mine plans, and regulatory reports.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dumpStatus rdf:type rdf:Property ;
    rdfs:label 'Dump Status' ;
    rdfs:comment 'Current lifecycle status of the waste dump facility. Active indicates ongoing waste emplacement; closed indicates emplacement has ceased; rehabilitating indicates progressive or final rehabilitation is underway per the mine closure plan.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalClassification rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Classification' ;
    rdfs:comment 'Geotechnical risk classification of the waste dump based on foundation conditions, material properties, and consequence of failure. Class 1 (lowest risk) to Class 4 (highest risk). Drives inspection frequency, monitoring requirements, and regulatory reporting obligations. [ENUM-REF-CANDIDATE: class_1|class_2|class_3|class_4 — promote to reference product]' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Required' ;
    rdfs:comment 'Indicates whether ongoing groundwater quality monitoring is required for this waste dump as a condition of the environmental permit or based on ARD risk classification. True triggers monitoring schedule in IsoMetrix.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isometrixFacilityReference rdf:type rdf:Property ;
    rdfs:label 'Isometrix Facility Reference' ;
    rdfs:comment 'Source system identifier for this waste dump facility as recorded in IsoMetrix HSE and Environmental Monitoring module. Used for data lineage and cross-system reconciliation.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Survey Date' ;
    rdfs:comment 'Date of the most recent topographic survey conducted on the waste dump to update volume and surface area measurements. Survey data is used to reconcile FMS haulage records with actual fill volumes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leachateManagementStatus rdf:type rdf:Property ;
    rdfs:label 'Leachate Management Status' ;
    rdfs:comment 'Current operational status of the leachate collection and management system for the waste dump. Indicates whether leachate is being actively collected, passively monitored, or not required based on liner type and regulatory conditions.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerType rdf:type rdf:Property ;
    rdfs:label 'Liner Type' ;
    rdfs:comment 'Type of engineered liner system installed at the base of the waste dump to control leachate migration and protect groundwater. None indicates an unlined facility; HDPE geomembrane is a high-density polyethylene synthetic liner. Sourced from mine design records and IsoMetrix.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxHeightM rdf:type rdf:Property ;
    rdfs:label 'Max Height M' ;
    rdfs:comment 'Maximum permitted or current height of the waste dump from base to crest in metres. A key geotechnical design parameter governing slope stability and regulatory permit conditions.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minePlanDumpReference rdf:type rdf:Property ;
    rdfs:label 'Mine Plan Dump Reference' ;
    rdfs:comment 'Source system identifier for this waste dump as recorded in the mine planning system (Hexagon MinePlan or Deswik). Used for data lineage, cross-system reconciliation, and LOM schedule integration.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Date of the next scheduled geotechnical or environmental inspection of the waste dump as required by the geotechnical classification, permit conditions, or IsoMetrix inspection schedule.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Date' ;
    rdfs:comment 'Date on which the environmental permit or licence for this waste dump expires and must be renewed. Triggers compliance workflow in IsoMetrix for permit renewal actions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:progressiveRehabAreaHa rdf:type rdf:Property ;
    rdfs:label 'Progressive Rehab Area Ha' ;
    rdfs:comment 'Cumulative area of the waste dump that has been progressively rehabilitated to date, expressed in hectares. Used to track rehabilitation progress against permit commitments and LOM closure plan milestones.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressiveRehabRequired rdf:type rdf:Property ;
    rdfs:label 'Progressive Rehab Required' ;
    rdfs:comment 'Indicates whether progressive rehabilitation (rehabilitation of completed dump benches during the operational phase) is required as a permit condition or company commitment. True drives progressive rehab scheduling in the LOM plan.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehabilitationBondAmount rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Bond Amount' ;
    rdfs:comment 'Financial assurance (bond) amount in the site\'s functional currency held by the relevant regulatory authority to cover the estimated cost of rehabilitating this waste dump to an approved post-mining land use standard. Commercially sensitive.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationBondCurrency rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Bond Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the rehabilitation bond amount (e.g., AUD, USD, ZAR). Required for multi-jurisdiction financial reporting under IFRS.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Plan Reference' ;
    rdfs:comment 'Document reference number or identifier for the approved mine rehabilitation and closure plan applicable to this waste dump. Links to the formal closure plan document registered in the document management system. Required for regulatory compliance and bond calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name or employee identifier of the qualified geotechnical engineer responsible for the design, monitoring, and sign-off of this waste dump facility. Required for regulatory accountability and competent person declarations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceAreaHa rdf:type rdf:Property ;
    rdfs:label 'Surface Area Ha' ;
    rdfs:comment 'Total surface footprint of the waste dump facility in hectares, including all active and inactive benches. Used for rehabilitation cost estimation, environmental bond calculation, and land tenure management.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteRockClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Rock Classification' ;
    rdfs:comment 'Geochemical classification of the predominant waste rock material deposited in the dump based on laboratory acid-base accounting. Non-Acid Forming (NAF), Potentially Acid Forming (PAF), or Acid Forming (AF). Determines encapsulation and placement strategy.' ;
    rdfs:domain ind:WasteDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiationTestId rdf:type rdf:Property ;
    rdfs:label 'Beneficiation Test Id' ;
    rdfs:comment 'Unique surrogate identifier for each beneficiation testwork record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitId rdf:type rdf:Property ;
    rdfs:label 'Circuit Id' ;
    rdfs:comment 'Foreign key linking to processing.circuit. Business justification: Beneficiation tests are conducted to optimize specific circuits. One test targets one circuit; one circuit has many tests. This links the test to the specific circuit being optimized. The plant_id is ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Circuit .

ind:feasibilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Feasibility Study Id' ;
    rdfs:comment 'Foreign key linking to project.feasibility_study. Business justification: Metallurgical test work establishes processing route, recovery rates, and operating costs for feasibility studies. Required for JORC/NI 43-101 competent person sign-off, study basis documentation, and' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeasibilityStudy .

ind:limsSampleId rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Id' ;
    rdfs:comment 'Reference identifier for the ore sample as registered in LabWare LIMS. Links this testwork record to the physical sample submission and chain-of-custody documentation.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaboratorySample .

ind:energyConsumptionKwhT rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh T' ;
    rdfs:comment 'Electrical energy consumed per tonne of feed processed during the beneficiation test, expressed in kWh/t. Used for OPEX estimation, All-In Sustaining Cost (AISC) modelling, and carbon footprint assessments.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGradePct rdf:type rdf:Property ;
    rdfs:label 'Feed Grade Pct' ;
    rdfs:comment 'Head grade of the ore sample fed into the beneficiation test, expressed as a percentage of the target commodity (e.g., % Cu, % Fe). Establishes the baseline for recovery and upgrade ratio calculations.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Feed Grade Unit' ;
    rdfs:comment 'Unit of measure for the feed grade value (e.g., percentage for base metals, grams per tonne for precious metals, ppm for trace elements). Ensures correct interpretation of the feed_grade_pct field.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedParticleSizeP80Um rdf:type rdf:Property ;
    rdfs:label 'Feed Particle Size P80 Um' ;
    rdfs:comment '80th percentile particle size (P80) of the feed material in micrometres, representing the grind size at which 80% of particles pass. Critical comminution parameter that directly influences liberation and recovery in downstream separation processes.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grindTargetP80Um rdf:type rdf:Property ;
    rdfs:label 'Grind Target P80 Um' ;
    rdfs:comment 'Target 80th percentile grind size (P80) in micrometres specified for the test. Compared against the achieved feed_particle_size_p80_um to assess whether the test was conducted at the intended grind size.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLomPlanUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Is Lom Plan Update Required' ;
    rdfs:comment 'Indicates whether the results of this beneficiation test necessitate an update to the LOM plan recovery assumptions or processing circuit design. Triggers the LOM plan review workflow when set to True.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lomPlanRecoveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Recovery Target Pct' ;
    rdfs:comment 'The recovery rate target from the current LOM plan against which this test result is benchmarked. Enables direct comparison of achieved test recovery versus planned recovery assumptions for resource estimation and financial modelling.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:massPullPct rdf:type rdf:Property ;
    rdfs:label 'Mass Pull Pct' ;
    rdfs:comment 'Percentage of the total feed mass that reports to the concentrate or product stream. Indicates the selectivity of the separation process; a lower mass pull with high recovery indicates better separation efficiency.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productGradePct rdf:type rdf:Property ;
    rdfs:label 'Product Grade Pct' ;
    rdfs:comment 'Grade of the concentrate or product stream achieved in the beneficiation test, expressed as a percentage of the target commodity. Key output metric for assessing test performance against design targets.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pulpDensityPctSolids rdf:type rdf:Property ;
    rdfs:label 'Pulp Density Pct Solids' ;
    rdfs:comment 'Percentage solids by weight of the slurry (pulp) during the beneficiation test. A key operating parameter for flotation, leaching, and gravity separation that affects reagent dosage, residence time, and recovery.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pulpPh rdf:type rdf:Property ;
    rdfs:label 'Pulp Ph' ;
    rdfs:comment 'pH of the slurry during the beneficiation test. Critical operating parameter for flotation and leaching circuits; affects reagent selectivity, mineral surface chemistry, and recovery performance.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentSuite rdf:type rdf:Property ;
    rdfs:label 'Reagent Suite' ;
    rdfs:comment 'Description of the reagent combination tested, including collector, frother, depressant, activator, and pH modifier types and dosages (e.g., \'PAX 80g/t, MIBC 20g/t, CuSO4 200g/t\'). Captures the full reagent regime for circuit design and operating condition recommendations.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedOperatingConditions rdf:type rdf:Property ;
    rdfs:label 'Recommended Operating Conditions' ;
    rdfs:comment 'Narrative summary of the optimal operating conditions identified from this beneficiation test, including recommended grind size, reagent dosages, pH, density, and temperature. Directly informs circuit design parameters and standard operating procedures (SOPs).' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryPct rdf:type rdf:Property ;
    rdfs:label 'Recovery Pct' ;
    rdfs:comment 'Percentage of the target commodity recovered from the feed into the product stream during the beneficiation test. Primary performance indicator for metallurgical testwork; informs LOM plan recovery assumptions.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleMassKg rdf:type rdf:Property ;
    rdfs:label 'Sample Mass Kg' ;
    rdfs:comment 'Total mass of the ore sample (in kilograms) used as feed for the beneficiation test. Determines the representativeness of the test and the reliability of mass balance calculations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSourceDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Source Description' ;
    rdfs:comment 'Descriptive reference to the origin of the ore sample used in the test, including mine site, pit, bench, drill hole, or stockpile location. Provides traceability for the sample provenance as required by JORC and NI 43-101.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tailingsGradePct rdf:type rdf:Property ;
    rdfs:label 'Tailings Grade Pct' ;
    rdfs:comment 'Grade of the target commodity remaining in the tailings stream after beneficiation, expressed as a percentage. Used to assess metal losses and validate mass balance closure.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Operating temperature in degrees Celsius during the beneficiation test. Particularly relevant for leaching (heap leach, pressure oxidation), SX-EW, and bio-leach tests where temperature significantly affects reaction kinetics and recovery.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testDurationMin rdf:type rdf:Property ;
    rdfs:label 'Test Duration Min' ;
    rdfs:comment 'Total duration of the beneficiation test in minutes, from feed introduction to final product collection. Used to calculate throughput rates and assess residence time requirements for circuit design.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testResultSummary rdf:type rdf:Property ;
    rdfs:label 'Test Result Summary' ;
    rdfs:comment 'Narrative summary of the key findings and outcomes of the beneficiation test, including notable observations, anomalies, and conclusions. Supports metallurgical reporting and competent person review.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScale rdf:type rdf:Property ;
    rdfs:label 'Test Scale' ;
    rdfs:comment 'Scale at which the beneficiation test was conducted, distinguishing between bench-scale laboratory tests, locked-cycle tests, batch tests, and pilot plant trials. Determines the confidence level and applicability of results to full-scale circuit design.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReagentConsumptionKgT rdf:type rdf:Property ;
    rdfs:label 'Total Reagent Consumption Kg T' ;
    rdfs:comment 'Total mass of all reagents consumed per tonne of feed processed during the beneficiation test, expressed in kg/t. Used for operating cost estimation and OPEX modelling in LOM plan updates.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeRatio rdf:type rdf:Property ;
    rdfs:label 'Upgrade Ratio' ;
    rdfs:comment 'Ratio of product grade to feed grade, indicating the degree of concentration achieved in the beneficiation test. A higher upgrade ratio indicates more effective separation of the valuable mineral from gangue.' ;
    rdfs:domain ind:BeneficiationTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionM3T rdf:type rdf:Property ;
    rdfs:label 'Water Consumption M3 T' ;
    rdfs:comment 'Volume of water consumed per tonne of feed processed during the beneficiation test, expressed in m³/t. Informs water balance modelling and environmental impact assessments for circuit design.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateBatchId rdf:type rdf:Property ;
    rdfs:label 'Concentrate Batch Id' ;
    rdfs:comment 'Unique surrogate identifier for each concentrate production batch record in the processing plant. Primary key for the concentrate_batch data product.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concentrateStockpileId rdf:type rdf:Property ;
    rdfs:label 'Concentrate Stockpile Id' ;
    rdfs:comment 'Foreign key linking to processing.concentrate_stockpile. Business justification: Concentrate batches are added to stockpiles. One batch is stored in one stockpile; one stockpile receives many batches. This is a standard parent FK. The storage_location_code string attribute becomes' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConcentrateStockpile .

ind:feedStreamId rdf:type rdf:Property ;
    rdfs:label 'Feed Stream Id' ;
    rdfs:comment 'Foreign key linking to processing.feed_stream. Business justification: Concentrate batches are produced from specific feed streams. One batch from one feed stream; one feed stream produces many batches. This links the batch to the feed stream that was processed. The ore_' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeedStream .

ind:qualityApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales contract compliance and customer quality assurance require traceability to qualified metallurgist who approved batch for dispatch. quality_approved_timestamp exists but no approver FK; regulator' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityMaintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Quality Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Concentrate quality issues (off-spec grade, high impurities) may trace to equipment maintenance needs (screen wear, cyclone apex wear, flotation cell condition). Links product quality problems to main' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assayNumber rdf:type rdf:Property ;
    rdfs:label 'Assay Number' ;
    rdfs:comment 'The unique laboratory assay reference number assigned by LabWare LIMS for the chemical analysis (assay) performed on this concentrate batch. Links the batch to its quality certificate and detailed elemental analysis results.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrateGradePct rdf:type rdf:Property ;
    rdfs:label 'Concentrate Grade Pct' ;
    rdfs:comment 'The grade of the primary commodity in the final concentrate product for this batch, expressed as a percentage (% Cu, % Fe, % Li, % Ni). The key product quality metric used in sales contracts and customer specifications. Sourced from LabWare LIMS assay results.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchMode rdf:type rdf:Property ;
    rdfs:label 'Dispatch Mode' ;
    rdfs:comment 'The primary transport mode used to dispatch this concentrate batch from the processing plant to the port or customer (e.g., rail, road, ship, pipeline, conveyor). Determines logistics cost allocation and supply chain planning.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryWeightDmt rdf:type rdf:Property ;
    rdfs:label 'Dry Weight Dmt' ;
    rdfs:comment 'Dry weight of the concentrate batch in dry metric tonnes (DMT), calculated after moisture correction. The primary commercial weight measure used for sales contracts, invoicing, and production reporting. Key SSOT field for concentrate production output.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTonnes rdf:type rdf:Property ;
    rdfs:label 'Feed Tonnes' ;
    rdfs:comment 'Total dry metric tonnes of Run of Mine (ROM) ore fed into the processing circuit to produce this concentrate batch. Used as the denominator in recovery rate and yield calculations.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impuritySilicaPct rdf:type rdf:Property ;
    rdfs:label 'Impurity Silica Pct' ;
    rdfs:comment 'Silica (SiO2) content in the concentrate batch expressed as a percentage (%). A key gangue impurity that affects product quality, smelter penalties, and customer acceptance. Sourced from LabWare LIMS assay results.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impuritySulfurPct rdf:type rdf:Property ;
    rdfs:label 'Impurity Sulfur Pct' ;
    rdfs:comment 'Sulfur (S) content in the concentrate batch expressed as a percentage (%). A critical impurity for smelter operations and environmental compliance. High sulfur levels may attract penalties or rejection. Sourced from LabWare LIMS.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isQualityApproved rdf:type rdf:Property ;
    rdfs:label 'Is Quality Approved' ;
    rdfs:comment 'Indicates whether this concentrate batch has passed quality control review and been formally approved for sale or dispatch. True = approved; False = pending or rejected. Set by the metallurgist or quality manager in LabWare LIMS.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:particleSizeP80Um rdf:type rdf:Property ;
    rdfs:label 'Particle Size P80 Um' ;
    rdfs:comment 'The P80 particle size of the concentrate batch in micrometres (µm), representing the sieve size through which 80% of the material passes. Critical comminution (size reduction) quality parameter affecting downstream processing efficiency and product specification compliance.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processRoute rdf:type rdf:Property ;
    rdfs:label 'Process Route' ;
    rdfs:comment 'The mineral processing route used to produce this concentrate batch (e.g., flotation, leaching, Dense Media Separation (DMS), Solvent Extraction Electrowinning (SX-EW), High Pressure Grinding Rolls (HPGR), Semi-Autogenous Grinding (SAG)). Determines applicable quality standards and reagent profiles. [ENUM-REF-CANDIDATE: flotation|leaching|DMS|SX-EW|HPGR|SAG|gravity|magnetic_separation — promote to reference product]' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Timestamp' ;
    rdfs:comment 'Precise date and time when the concentrate batch production was completed and the batch was sealed/finalised at the processing plant. Sourced from OSIsoft PI System historian.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:provisionalPriceUsdDmt rdf:type rdf:Property ;
    rdfs:label 'Provisional Price Usd Dmt' ;
    rdfs:comment 'The provisional sale price per dry metric tonne (DMT) in US dollars (USD) agreed at the time of dispatch, subject to final price adjustment based on quotation period commodity prices. Used for initial revenue recognition under IFRS 15.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Approved Timestamp' ;
    rdfs:comment 'Date and time when the concentrate batch was formally approved for sale following quality control review. Represents a key lifecycle milestone in the batch workflow. Sourced from LabWare LIMS.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'The quality classification assigned to this concentrate batch based on assay results and product specification compliance. Grade A = premium specification met; Grade B = standard specification met; Grade C = marginal specification; off_spec = outside specification but saleable; rejected = failed quality control and cannot be sold.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentConsumptionKgT rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Kg T' ;
    rdfs:comment 'Total reagent consumption per tonne of ore processed for this concentrate batch, expressed in kilograms per tonne (kg/t). Aggregates all flotation, leaching, or other process reagents. Used for operating expenditure (OPEX) tracking and process efficiency analysis.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Contract Number' ;
    rdfs:comment 'The sales contract reference number under which this concentrate batch is sold to a customer. Links the production batch to the commercial sales agreement. Classified as confidential due to commercial sensitivity of contract terms.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDate rdf:type rdf:Property ;
    rdfs:label 'Sample Date' ;
    rdfs:comment 'The date on which the representative sample was taken from this concentrate batch for laboratory assay analysis. Used for sample chain-of-custody tracking and quality control compliance.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slurryDensityGcm3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density Gcm3' ;
    rdfs:comment 'The density of the concentrate slurry (water and ore mixture) in grams per cubic centimetre (g/cm³) at the point of batch finalisation. Monitored via OSIsoft PI System SCADA. Used for process control and dewatering circuit optimisation.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputTph rdf:type rdf:Property ;
    rdfs:label 'Throughput Tph' ;
    rdfs:comment 'The average ore processing throughput rate in tonnes per hour (tph) achieved during the production of this concentrate batch. Sourced from OSIsoft PI System SCADA historian. Used for Overall Equipment Effectiveness (OEE) and capacity utilisation analysis.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wetWeightT rdf:type rdf:Property ;
    rdfs:label 'Wet Weight T' ;
    rdfs:comment 'Total wet weight of the concentrate batch in metric tonnes (t) as measured at the processing plant prior to moisture correction. Used as the basis for moisture content calculation.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:comment 'The mass yield of concentrate produced as a percentage of the total ore feed for this batch (DMT concentrate / feed tonnes × 100). Indicates the ratio of product output to ore input and is used for process efficiency benchmarking.' ;
    rdfs:domain ind:ConcentrateBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesShipmentNominationId rdf:type rdf:Property ;
    rdfs:label 'Sales Shipment Nomination Id' ;
    rdfs:comment 'Foreign key linking to sales.shipment_nomination. Business justification: Shipment nominations allocate specific stockpile inventory to customer orders and vessel schedules. Logistics planning, inventory management, and customer delivery commitments depend on linking nomina' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentNomination .

ind:additionsDmt rdf:type rdf:Property ;
    rdfs:label 'Additions Dmt' ;
    rdfs:comment 'Cumulative dry metric tonnes of concentrate added to this stockpile from production since the last inventory reconciliation period. Represents inflows from the processing circuit (e.g., flotation, leaching, SX-EW). Used in mass balance and inventory reconciliation.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blendTargetGrade rdf:type rdf:Property ;
    rdfs:label 'Blend Target Grade' ;
    rdfs:comment 'Target product grade (%) for this stockpile as specified in the blend optimisation plan or sales contract specification. Used to guide production blending decisions to meet customer or smelter feed requirements.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateType rdf:type rdf:Property ;
    rdfs:label 'Concentrate Type' ;
    rdfs:comment 'Mineralogical classification of the concentrate product in this stockpile. Determines applicable processing routes, smelter penalty elements, and sales contract terms. E.g., sulphide concentrate from flotation vs oxide concentrate from leaching/SX-EW.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dustSuppressionApplied rdf:type rdf:Property ;
    rdfs:label 'Dust Suppression Applied' ;
    rdfs:comment 'Indicates whether dust suppression measures (e.g., water sprays, chemical binders, covers) are currently applied to this stockpile. Relevant for environmental compliance, HSE reporting, and community impact management.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeElement rdf:type rdf:Property ;
    rdfs:label 'Grade Element' ;
    rdfs:comment 'Chemical element or compound symbol for which the product_grade is reported (e.g., \'Cu\' for copper, \'Fe\' for iron, \'Li2O\' for lithium oxide, \'Ni\' for nickel). Ensures unambiguous interpretation of the grade value across commodities.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryDmt rdf:type rdf:Property ;
    rdfs:label 'Inventory Dmt' ;
    rdfs:comment 'Current physical inventory of concentrate in the stockpile expressed as dry metric tonnes (DMT), adjusted for moisture content. This is the primary inventory quantity used for sales nominations, shipping calculations, and inventory reconciliation. Updated after each survey event.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryWmt rdf:type rdf:Property ;
    rdfs:label 'Inventory Wmt' ;
    rdfs:comment 'Current physical inventory of concentrate in the stockpile expressed as wet metric tonnes (WMT), inclusive of moisture. Used for physical handling, transport weight calculations, and logistics planning. Distinct from DMT which is the commercial quantity.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isShipmentNominated rdf:type rdf:Property ;
    rdfs:label 'Is Shipment Nominated' ;
    rdfs:comment 'Indicates whether this stockpile inventory has been nominated against an active shipment or vessel loading schedule. True = nominated for an upcoming shipment; False = available for future nomination. Supports logistics scheduling and sales operations.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnderEnvironmentalHold rdf:type rdf:Property ;
    rdfs:label 'Is Under Environmental Hold' ;
    rdfs:comment 'Indicates whether this stockpile is subject to an environmental hold that restricts movement or shipment of material (e.g., pending EIS review, acid rock drainage concern, or regulatory compliance investigation). True = hold in place; False = no environmental restriction.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssayDate rdf:type rdf:Property ;
    rdfs:label 'Last Assay Date' ;
    rdfs:comment 'Date of the most recent laboratory assay used to determine the current product grade and moisture content of the stockpile. Used to assess grade data currency for sales nominations and blend optimisation.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lomInventoryTargetDmt rdf:type rdf:Property ;
    rdfs:label 'Lom Inventory Target Dmt' ;
    rdfs:comment 'Target concentrate inventory level in dry metric tonnes as specified in the Life of Mine (LOM) plan for the current period. Used to assess inventory performance against plan and trigger production rate adjustments.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCapacityDmt rdf:type rdf:Property ;
    rdfs:label 'Max Capacity Dmt' ;
    rdfs:comment 'Engineered maximum storage capacity of the stockpile expressed in dry metric tonnes (DMT). Used for capacity planning, logistics scheduling, and triggering production rate adjustments when inventory approaches capacity limits.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxMoistureSpec rdf:type rdf:Property ;
    rdfs:label 'Max Moisture Spec' ;
    rdfs:comment 'Maximum allowable moisture content (%) for this stockpile as defined by the applicable sales contract, shipping specification, or transportable moisture limit (TML) under the IMSBC Code. Exceedance triggers quarantine or drying operations.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minGradeSpec rdf:type rdf:Property ;
    rdfs:label 'Min Grade Spec' ;
    rdfs:comment 'Minimum acceptable product grade (%) for this stockpile as defined by the applicable sales contract or offtake agreement. Material below this threshold may be subject to penalty pricing or rejection.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominatedShipmentDmt rdf:type rdf:Property ;
    rdfs:label 'Nominated Shipment Dmt' ;
    rdfs:comment 'Quantity of concentrate in dry metric tonnes nominated against an active shipment or vessel loading schedule from this stockpile. Enables available-to-nominate calculation (inventory_dmt minus nominated_shipment_dmt) for logistics planning.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingInventoryDmt rdf:type rdf:Property ;
    rdfs:label 'Opening Inventory Dmt' ;
    rdfs:comment 'Dry metric tonne inventory at the start of the current reconciliation period. Together with additions_dmt and removals_dmt, enables closing inventory calculation and mass balance closure verification.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyElementFlags rdf:type rdf:Property ;
    rdfs:label 'Penalty Element Flags' ;
    rdfs:comment 'Comma-separated list of penalty elements detected in the concentrate above contractual threshold levels (e.g., \'As,Pb,Bi\'). Penalty elements attract price deductions in smelter contracts and may trigger quarantine or blending requirements. Sourced from LabWare LIMS assay results.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGrade rdf:type rdf:Property ;
    rdfs:label 'Product Grade' ;
    rdfs:comment 'Current assay-derived grade of the valuable mineral in the concentrate stockpile, expressed as a percentage (%). Represents the weighted average grade of all material currently in the stockpile based on the most recent survey or assay. Critical for sales nomination and blend optimisation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalsDmt rdf:type rdf:Property ;
    rdfs:label 'Removals Dmt' ;
    rdfs:comment 'Cumulative dry metric tonnes of concentrate removed from this stockpile for shipment, blending, or transfer since the last inventory reconciliation period. Represents outflows to logistics, port, or downstream processing. Used in mass balance and inventory reconciliation.' ;
    rdfs:domain ind:ConcentrateStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockpileNotes rdf:type rdf:Property ;
    rdfs:label 'Stockpile Notes' ;
    rdfs:comment 'Free-text operational notes recorded by the metallurgist or inventory controller regarding this stockpile, such as quality observations, blending instructions, survey anomalies, or logistics constraints. Supports operational decision-making and audit trail.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsEventId rdf:type rdf:Property ;
    rdfs:label 'Dms Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each DMS circuit operational event record in the silver layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDmsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dms Employee Id' ;
    rdfs:comment 'Reference to the plant operator responsible for operating the DMS circuit during this event. Used for accountability, training compliance, and incident investigation.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:circuitAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Circuit Availability Pct' ;
    rdfs:comment 'Percentage of the scheduled operating time during which the DMS circuit was available and operational during this event period. Calculated as (operating hours / scheduled hours) × 100. Key input to Overall Equipment Effectiveness (OEE) reporting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circuitRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Circuit Recovery Pct' ;
    rdfs:comment 'Metallurgical recovery rate of the DMS circuit for this event, expressed as the percentage of valuable mineral in the feed that is recovered in the product stream. Core KPI for DMS circuit performance against LOM plan targets.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyclonePressureKpa rdf:type rdf:Property ;
    rdfs:label 'Cyclone Pressure Kpa' ;
    rdfs:comment 'Operating pressure of the DMS cyclone(s) measured in kilopascals (kPa) during this event. Cyclone pressure directly affects separation efficiency and is a key SCADA-monitored process control parameter.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeDurationMin rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Min' ;
    rdfs:comment 'Total duration of unplanned and planned downtime experienced by the DMS circuit during this event, measured in minutes. Used for availability calculations, maintenance planning, and OPEX impact assessment.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Description of the primary cause of DMS circuit downtime during this event (e.g., cyclone blockage, pump failure, medium drain, planned maintenance, feed interruption). Used for root cause analysis and maintenance planning. [ENUM-REF-CANDIDATE: cyclone_blockage|pump_failure|medium_drain|planned_maintenance|feed_interruption|screen_blinding|magnetic_drum_fault|electrical_fault — promote to reference product]' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Feed Moisture Pct' ;
    rdfs:comment 'Moisture content of the ore feed expressed as a percentage of wet weight. Critical for converting wet tonnes to dry metric tonnes (DMT) for metallurgical accounting and product quality reporting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedParticleSizeP80Mm rdf:type rdf:Property ;
    rdfs:label 'Feed Particle Size P80 Mm' ;
    rdfs:comment '80th percentile particle size of the DMS feed in millimetres, representing the size at which 80% of feed particles pass. Influences separation efficiency and medium stability in the DMS circuit.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedRateTargetTph rdf:type rdf:Property ;
    rdfs:label 'Feed Rate Target Tph' ;
    rdfs:comment 'Planned feed rate target for the DMS circuit in tonnes per hour (tph) for this event period, sourced from the production schedule or LOM plan. Enables throughput variance analysis against actual feed_rate_tph.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedRateTph rdf:type rdf:Property ;
    rdfs:label 'Feed Rate Tph' ;
    rdfs:comment 'Mass flow rate of Run of Mine (ROM) ore fed into the DMS circuit during this event, measured in tonnes per hour (tph). Key throughput metric benchmarked against design capacity and LOM plan targets.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTonnesWet rdf:type rdf:Property ;
    rdfs:label 'Feed Tonnes Wet' ;
    rdfs:comment 'Total wet mass of ore fed into the DMS circuit during the event period, measured in wet metric tonnes. Used for mass balance calculations and shift production reconciliation.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Float Tonnes Dry' ;
    rdfs:comment 'Total dry metric tonnes (DMT) of material reporting to the float stream during this DMS event. Used for mass balance closure, metallurgical accounting, and clean product inventory tracking.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatYieldPct rdf:type rdf:Property ;
    rdfs:label 'Float Yield Pct' ;
    rdfs:comment 'Percentage of the DMS feed that reports to the float (light) product stream, expressed as a mass percentage. For coal DMS, the float is the clean coal product; for iron ore, the float is typically the gangue reject.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:magneticRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Magnetic Recovery Pct' ;
    rdfs:comment 'Percentage of dense medium (ferrosilicon or magnetite) recovered from the product and reject streams via magnetic drum separators during this event. High magnetic recovery reduces medium losses and OPEX. Benchmarked against circuit design targets.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumDensitySg rdf:type rdf:Property ;
    rdfs:label 'Medium Density Sg' ;
    rdfs:comment 'Specific gravity (SG) of the dense medium (typically ferrosilicon or magnetite suspension) used in the DMS circuit during this event. The primary separation control parameter — particles denser than the medium sink, lighter particles float.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumLossKgPerT rdf:type rdf:Property ;
    rdfs:label 'Medium Loss Kg Per T' ;
    rdfs:comment 'Mass of dense medium (ferrosilicon or magnetite) lost per tonne of feed processed during this DMS event, measured in kg/t. Medium losses are a significant operating cost driver and are tracked for reagent consumption reporting and OPEX management.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumToOreRatio rdf:type rdf:Property ;
    rdfs:label 'Medium To Ore Ratio' ;
    rdfs:comment 'Ratio of dense medium volume to ore feed volume in the DMS circuit during this event. A key process control parameter affecting separation efficiency and medium stability. Typically expressed as m³ medium per tonne of ore.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumType rdf:type rdf:Property ;
    rdfs:label 'Medium Type' ;
    rdfs:comment 'Type of dense medium used in the DMS circuit. Ferrosilicon is used for higher-density separations (diamonds, iron ore), while magnetite is common for coal DMS circuits. Affects reagent cost and medium recovery efficiency.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Recovery Target Pct' ;
    rdfs:comment 'Planned metallurgical recovery rate target for the DMS circuit during this event period, sourced from the LOM plan or shift production plan. Enables real-time variance tracking against actual circuit_recovery_pct.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectGradePct rdf:type rdf:Property ;
    rdfs:label 'Reject Grade Pct' ;
    rdfs:comment 'Grade of the valuable mineral in the DMS reject (discard) stream, expressed as a percentage. Used to assess mineral losses to tailings and validate separation efficiency. High reject grade indicates potential recovery improvement opportunity.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sinkTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Sink Tonnes Dry' ;
    rdfs:comment 'Total dry metric tonnes (DMT) of material reporting to the sink stream during this DMS event. Used for mass balance closure, metallurgical accounting, and product inventory reconciliation.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sinkYieldPct rdf:type rdf:Property ;
    rdfs:label 'Sink Yield Pct' ;
    rdfs:comment 'Percentage of the DMS feed that reports to the sink (dense) product stream, expressed as a mass percentage. For coal DMS, the sink is typically the reject (high-ash discard); for iron ore and diamonds, the sink is the valuable product.' ;
    rdfs:domain ind:DmsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondWorkIndexKwhT rdf:type rdf:Property ;
    rdfs:label 'Bond Work Index Kwh T' ;
    rdfs:comment 'Bond Ball Mill Work Index (BWi) of the ore expressed in kilowatt-hours per tonne (kWh/t). Measures ore hardness and grindability; used to predict mill power requirements, throughput, and energy consumption in comminution circuit design and optimisation.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityTph rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tph' ;
    rdfs:comment 'Maximum rated throughput capacity of the feed stream infrastructure (conveyor, feeder, chute) in dry metric tonnes per hour. Used for bottleneck analysis and OEE (Overall Equipment Effectiveness) calculations.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this feed stream definition and its associated parameters (nominal rate, target grade, processing route) became operationally effective. Supports temporal versioning of feed stream configurations aligned to LOM plan revisions.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this feed stream definition ceases to be operationally effective. Null indicates the stream is currently active with no planned end date. Supports LOM plan stage transitions and plant reconfiguration tracking.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Feed Temperature C' ;
    rdfs:comment 'Temperature of the ore or slurry in the feed stream measured in degrees Celsius. Relevant for leaching circuits (SX-EW), autoclave operations, and cold-climate operations where freezing affects conveyor and crusher performance.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gangueContentPct rdf:type rdf:Property ;
    rdfs:label 'Gangue Content Pct' ;
    rdfs:comment 'Percentage of waste rock (gangue) minerals in the feed stream material. High gangue content increases dilution, reduces effective head grade, and impacts reagent consumption in flotation and leaching circuits.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalFeedRateTph rdf:type rdf:Property ;
    rdfs:label 'Nominal Feed Rate Tph' ;
    rdfs:comment 'The design or nameplate feed rate for this stream expressed in dry metric tonnes per hour (tph). Represents the target throughput capacity used in LOM (Life of Mine) plan scheduling and plant design. Distinct from actual measured feed rate.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p50ParticleSizeMm rdf:type rdf:Property ;
    rdfs:label 'P50 Particle Size Mm' ;
    rdfs:comment 'The 50th percentile (median) passing particle size of the feed stream material in millimetres. Complements P80 to characterise the full particle size distribution (PSD) shape, supporting comminution circuit modelling and screen efficiency analysis.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p80ParticleSizeMm rdf:type rdf:Property ;
    rdfs:label 'P80 Particle Size Mm' ;
    rdfs:comment 'The 80th percentile passing particle size of the feed stream material expressed in millimetres (mm). P80 is the industry-standard metric for characterising particle size distribution (PSD) in comminution circuits. Critical input for SAG mill and HPGR (High Pressure Grinding Rolls) performance modelling.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagFeedRate rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Feed Rate' ;
    rdfs:comment 'The OSIsoft PI System historian tag name for the real-time feed rate measurement instrument (belt scale or flow meter) associated with this feed stream. Enables direct linkage between the data product and the SCADA/PI process historian for real-time and historical data retrieval.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagParticleSize rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Particle Size' ;
    rdfs:comment 'The OSIsoft PI System historian tag name for the online particle size analyser (PSA) instrument monitoring P80 for this feed stream. Supports real-time comminution circuit control and automated variance alerting.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRoute rdf:type rdf:Property ;
    rdfs:label 'Processing Route' ;
    rdfs:comment 'The designated mineral processing route for material in this feed stream (e.g., SAG/Ball Mill comminution, DMS (Dense Media Separation), flotation, leaching, SX-EW (Solvent Extraction Electrowinning)). Determines downstream circuit routing and reagent requirements. [ENUM-REF-CANDIDATE: sag_ball_mill|hpgr|dms|flotation|leaching|sx_ew|gravity|magnetic_separation|cil|cip — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slurryDensityTM3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density T M3' ;
    rdfs:comment 'Density of the ore-water slurry mixture in the feed stream expressed in tonnes per cubic metre. Applicable to wet processing circuits (SAG mill discharge, flotation feed). Monitored via OSIsoft PI System for real-time process control.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurrySolidsPct rdf:type rdf:Property ;
    rdfs:label 'Slurry Solids Pct' ;
    rdfs:comment 'Percentage of solids by mass in the slurry feed stream (percent solids). A key process control parameter for wet grinding and flotation circuits; directly affects mill power draw, pump performance, and flotation cell residence time.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:streamCode rdf:type rdf:Property ;
    rdfs:label 'Stream Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the feed stream within the processing plant configuration (e.g., FS-ROM-001, FS-CRU-002). Used in mass balance reconciliation and plant P&ID references.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamName rdf:type rdf:Property ;
    rdfs:label 'Stream Name' ;
    rdfs:comment 'Descriptive human-readable name of the feed stream (e.g., \'Primary ROM Feed\', \'SAG Mill Discharge\', \'Crusher Product Recirculating Load\'). Used in operational dashboards and reporting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamStatus rdf:type rdf:Property ;
    rdfs:label 'Stream Status' ;
    rdfs:comment 'Current lifecycle status of the feed stream definition within the processing plant. Active streams are currently receiving material; suspended streams are temporarily offline; decommissioned streams are permanently retired from the circuit.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamType rdf:type rdf:Property ;
    rdfs:label 'Stream Type' ;
    rdfs:comment 'Classification of the feed stream by its position and role in the comminution circuit. ROM (Run of Mine) feed is direct from the ROM pad; crushed feed is post-primary crusher; recirculating load is material returned for regrinding. [ENUM-REF-CANDIDATE: rom_feed|crushed_feed|recirculating_load|classifier_overflow|classifier_underflow|screen_oversize|sag_discharge|ball_mill_discharge — promote to reference product]' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFeedRateTph rdf:type rdf:Property ;
    rdfs:label 'Target Feed Rate Tph' ;
    rdfs:comment 'The planned or scheduled feed rate for this stream in dry metric tonnes per hour as defined in the current production schedule or LOM plan. Distinct from nominal (design) feed rate; used for shift-level production planning and variance reporting.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetHeadGradePct rdf:type rdf:Property ;
    rdfs:label 'Target Head Grade Pct' ;
    rdfs:comment 'The planned head grade of the primary valuable mineral for this feed stream as per the current production schedule or LOM plan. Used for production reconciliation and variance analysis against actual assayed head grade.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetP80Mm rdf:type rdf:Property ;
    rdfs:label 'Target P80 Mm' ;
    rdfs:comment 'The planned P80 particle size target for this feed stream in millimetres as specified in the processing plant design or LOM plan. Used to assess crusher and mill performance against design specifications.' ;
    rdfs:domain ind:FeedStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topSizeMm rdf:type rdf:Property ;
    rdfs:label 'Top Size Mm' ;
    rdfs:comment 'Maximum lump size of material in the feed stream expressed in millimetres. Defines the upper bound of the particle size distribution and is critical for crusher gap settings, conveyor design, and mill liner protection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flotationEventId rdf:type rdf:Property ;
    rdfs:label 'Flotation Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each flotation circuit performance record per shift. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airFlowRateM3PerMin rdf:type rdf:Property ;
    rdfs:label 'Air Flow Rate M3 Per Min' ;
    rdfs:comment 'Volumetric flow rate of air injected into the flotation cells, measured in cubic metres per minute (m³/min). Air flow is a primary control variable affecting bubble generation, froth stability, and mineral recovery. Monitored via OSIsoft PI SCADA integration.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellCountOperating rdf:type rdf:Property ;
    rdfs:label 'Cell Count Operating' ;
    rdfs:comment 'Number of flotation cells actively operating in the circuit during this event period. Cells may be taken offline for maintenance or cleaning. Operating cell count affects residence time and overall circuit capacity. Sourced from Infor EAM work order data.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cell Volume M3' ;
    rdfs:comment 'Total active volume of the flotation cells in operation during this event, measured in cubic metres (m³). Combined with feed rate, determines slurry residence time which is a key flotation kinetics parameter.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circuitStage rdf:type rdf:Property ;
    rdfs:label 'Circuit Stage' ;
    rdfs:comment 'The specific stage of the flotation circuit captured in this event record. Rougher is the primary separation stage; scavenger recovers minerals from rougher tailings; cleaner upgrades rougher concentrate grade; recleaner further upgrades cleaner concentrate. Critical for stage-by-stage metallurgical accounting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorDosageGPerT rdf:type rdf:Property ;
    rdfs:label 'Collector Dosage G Per T' ;
    rdfs:comment 'Dosage rate of the collector reagent (e.g., xanthate, dithiophosphate) added to the flotation circuit, expressed in grams per dry metric tonne of feed (g/t). Collector promotes hydrophobicity of target mineral surfaces to enable bubble attachment. Key reagent optimisation variable.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateGradeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Concentrate Grade Target Pct' ;
    rdfs:comment 'The planned or contractually required concentrate grade for the valuable mineral, expressed as a percentage (%). Used to assess whether the flotation circuit is meeting product quality specifications for offtake agreements and smelter contracts.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateMassT rdf:type rdf:Property ;
    rdfs:label 'Concentrate Mass T' ;
    rdfs:comment 'Total dry mass of concentrate produced by the flotation circuit during the event period, measured in dry metric tonnes (t). Used in metallurgical accounting mass balance and payable metal calculations.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depressantDosageGPerT rdf:type rdf:Property ;
    rdfs:label 'Depressant Dosage G Per T' ;
    rdfs:comment 'Dosage rate of the depressant reagent (e.g., sodium cyanide, zinc sulphate, CMC) added to the flotation circuit, expressed in grams per dry metric tonne of feed (g/t). Depressants selectively prevent flotation of gangue minerals or penalty elements, improving concentrate grade and selectivity.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frothDepthMm rdf:type rdf:Property ;
    rdfs:label 'Froth Depth Mm' ;
    rdfs:comment 'Depth of the froth layer maintained in the flotation cell during the event period, measured in millimetres (mm). Froth depth is a critical control parameter influencing concentrate grade and recovery trade-off. Deeper froth generally improves grade at the expense of recovery.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frotherDosageGPerT rdf:type rdf:Property ;
    rdfs:label 'Frother Dosage G Per T' ;
    rdfs:comment 'Dosage rate of the frother reagent (e.g., MIBC, pine oil, polyglycol) added to the flotation circuit, expressed in grams per dry metric tonne of feed (g/t). Frother stabilises the froth layer and controls bubble size distribution. Critical for froth stability and concentrate transport.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impellerSpeedRpm rdf:type rdf:Property ;
    rdfs:label 'Impeller Speed Rpm' ;
    rdfs:comment 'Average rotational speed of the flotation cell impellers during the event period, measured in revolutions per minute (RPM). Impeller speed controls slurry agitation, air dispersion, and bubble-particle contact. Monitored via OSIsoft PI SCADA.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limeDosageKgPerT rdf:type rdf:Property ;
    rdfs:label 'Lime Dosage Kg Per T' ;
    rdfs:comment 'Dosage rate of lime (calcium hydroxide or calcium oxide) added to the flotation circuit for pH control, expressed in kilograms per dry metric tonne of feed (kg/t). Lime is typically the highest-volume reagent in sulphide flotation circuits and a significant OPEX driver.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mineralType rdf:type rdf:Property ;
    rdfs:label 'Mineral Type' ;
    rdfs:comment 'The primary valuable mineral being recovered in this flotation circuit event (e.g., copper, nickel, lithium). Determines the applicable reagent suite, recovery benchmarks, and product specifications. Essential for multi-commodity processing plants. [ENUM-REF-CANDIDATE: copper|nickel|lithium|zinc|lead|molybdenum|gold|silver — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slurryTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Slurry Temperature C' ;
    rdfs:comment 'Temperature of the flotation feed slurry during the event period, measured in degrees Celsius (°C). Slurry temperature affects reagent solubility, reaction kinetics, and froth stability. Particularly relevant in cold-climate operations and heated leach-flotation circuits.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsMassT rdf:type rdf:Property ;
    rdfs:label 'Tailings Mass T' ;
    rdfs:comment 'Total dry mass of tailings discharged from the flotation circuit during the event period, measured in dry metric tonnes (t). Used in mass balance reconciliation and TSF volumetric planning.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterAdditionM3PerH rdf:type rdf:Property ;
    rdfs:label 'Water Addition M3 Per H' ;
    rdfs:comment 'Rate of process water added to the flotation circuit to maintain target pulp density, measured in cubic metres per hour (m³/h). Water consumption is a key environmental and OPEX metric, particularly in water-stressed mining regions subject to ISO 14001 reporting.' ;
    rdfs:domain ind:FlotationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachEventId rdf:type rdf:Property ;
    rdfs:label 'Leach Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each leaching operation event record in the silver layer lakehouse. Primary key for the leach_event data product.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolvedMetalConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Dissolved Metal Concentration Ppm' ;
    rdfs:comment 'Concentration of the target dissolved metal in the pregnant leach solution (PLS) or leachate, measured in parts per million (ppm). Primary indicator of leaching effectiveness and solution grade. Sourced from LabWare LIMS assay results or inline OSIsoft PI analyser tags.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dissolvedOxygenMgL rdf:type rdf:Property ;
    rdfs:label 'Dissolved Oxygen Mg L' ;
    rdfs:comment 'Concentration of dissolved oxygen in the leach solution, measured in milligrams per litre (mg/L). Dissolved oxygen is a critical parameter for cyanide leaching of gold and silver, directly influencing metal dissolution rates. Monitored via OSIsoft PI DO analysers.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Extraction Efficiency Pct' ;
    rdfs:comment 'Percentage of the target metal extracted from the ore feed into solution during this leach event, calculated as (metal dissolved / metal in feed) × 100. Key performance indicator for process optimisation, LOM plan reconciliation, and recovery rate reporting. Sourced from LabWare LIMS mass balance.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachDurationHrs rdf:type rdf:Property ;
    rdfs:label 'Leach Duration Hrs' ;
    rdfs:comment 'Total elapsed time of the leaching operation for this event, measured in hours. Represents the actual leach time from solution application/charge to drain/discharge. Used for cycle time optimisation, throughput modelling, and LOM plan variance analysis.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachType rdf:type rdf:Property ;
    rdfs:label 'Leach Type' ;
    rdfs:comment 'Classification of the leaching method applied in this event. Distinguishes between heap leach (copper, gold), tank leach (CIL/CIP for gold), vat leach, and agitation leach configurations. Drives process parameter benchmarking and recovery rate analysis. [ENUM-REF-CANDIDATE: heap_leach|tank_leach|vat_leach|cil|cip|agitation_leach — promote to reference product]' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreFeedMassT rdf:type rdf:Property ;
    rdfs:label 'Ore Feed Mass T' ;
    rdfs:comment 'Total dry mass of ore charged to the leach circuit for this event, measured in metric tonnes. Represents the principal quantitative input for recovery rate calculation and throughput reporting against Life of Mine (LOM) plan targets.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxidationReductionPotentialMv rdf:type rdf:Property ;
    rdfs:label 'Oxidation Reduction Potential Mv' ;
    rdfs:comment 'Oxidation-reduction potential (ORP) of the leach solution measured in millivolts (mV). Critical electrochemical parameter for monitoring leaching conditions, particularly in cyanide leach (gold) and SX-EW (copper) circuits. Sourced from OSIsoft PI inline analysers.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagReference rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Reference' ;
    rdfs:comment 'The OSIsoft PI System tag name or event frame reference associated with this leach event. Enables direct traceability back to the process historian for raw time-series data retrieval, audit, and re-processing. Applicable when data_source is pi_system or scada.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processUpsetFlag rdf:type rdf:Property ;
    rdfs:label 'Process Upset Flag' ;
    rdfs:comment 'Indicates whether a process upset or abnormal operating condition occurred during this leach event (True = upset occurred, False = normal operation). Process upsets may include pH excursions, reagent dosing failures, pump trips, or temperature deviations. Triggers investigation and corrective action workflows in IsoMetrix.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reagentConcentrationGL rdf:type rdf:Property ;
    rdfs:label 'Reagent Concentration G L' ;
    rdfs:comment 'Concentration of the primary leaching reagent (e.g., cyanide for gold CIL/CIP, sulphuric acid for copper heap leach, caustic soda for lithium leach) in the leach solution, measured in grams per litre (g/L). Key process control parameter for optimising extraction efficiency and reagent cost (OPEX).' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionKg rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Kg' ;
    rdfs:comment 'Total mass of primary leaching reagent consumed during this leach event, measured in kilograms. Used for OPEX tracking, reagent cost allocation, and environmental reporting of chemical usage. Sourced from Pronto Xi inventory consumption records and SCADA flow meters.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentType rdf:type rdf:Property ;
    rdfs:label 'Reagent Type' ;
    rdfs:comment 'Type of primary leaching reagent used in this event. Determines applicable safety, environmental, and regulatory requirements. Examples include sodium cyanide (gold CIL/CIP), sulphuric acid (copper heap leach), and caustic soda (lithium leach circuits). [ENUM-REF-CANDIDATE: cyanide|sulphuric_acid|caustic_soda|ammonia|chlorine|hydrochloric_acid — promote to reference product]' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueGradePct rdf:type rdf:Property ;
    rdfs:label 'Residue Grade Pct' ;
    rdfs:comment 'Grade of the target metal remaining in the leach residue (tailings) after the leaching event, expressed as a percentage. Used to calculate actual metal recovery and identify process losses. Sourced from LabWare LIMS assay results on residue samples.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryDensityGCm3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density G Cm3' ;
    rdfs:comment 'Density of the ore-solution slurry (water and ore mixture) in the leach circuit, measured in grams per cubic centimetre (g/cm³). Applicable to tank leach and CIL/CIP circuits. Monitored via OSIsoft PI density instruments. Affects mass transfer and reagent efficiency.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solutionFlowRateM3Hr rdf:type rdf:Property ;
    rdfs:label 'Solution Flow Rate M3 Hr' ;
    rdfs:comment 'Volumetric flow rate of leach solution through the circuit during this event, measured in cubic metres per hour (m³/hr). Monitored via OSIsoft PI flow instrumentation. Influences reagent distribution, contact time, and overall leaching kinetics.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solutionPh rdf:type rdf:Property ;
    rdfs:label 'Solution Ph' ;
    rdfs:comment 'Measured pH of the leach solution at the time of this event or at the representative sampling point within the event window. Critical process control parameter for reagent efficiency, metal dissolution kinetics, and environmental compliance (acid mine drainage prevention).' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solutionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Solution Temperature C' ;
    rdfs:comment 'Temperature of the leach solution in degrees Celsius (°C) measured during this event. Temperature directly influences leaching kinetics, reagent consumption rates, and metal dissolution efficiency. Monitored via OSIsoft PI System instrumentation.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solutionVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Solution Volume M3' ;
    rdfs:comment 'Total volume of leach solution applied or circulated during this event, measured in cubic metres (m³). Used for water balance reporting, reagent dosing calculations, and environmental water management compliance.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankPadReference rdf:type rdf:Property ;
    rdfs:label 'Tank Pad Reference' ;
    rdfs:comment 'Operational identifier of the specific leach tank, leach pad cell, or vat vessel used in this event (e.g., TANK-03, PAD-CELL-7B). Sourced from the OSIsoft PI asset hierarchy or SCADA tag configuration. Enables equipment-level performance tracking.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetExtractionEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Target Extraction Efficiency Pct' ;
    rdfs:comment 'Planned or budgeted extraction efficiency percentage for this leach event type and ore type, as defined in the Life of Mine (LOM) plan or metallurgical test work. Enables variance analysis between actual and planned recovery performance.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upsetDescription rdf:type rdf:Property ;
    rdfs:label 'Upset Description' ;
    rdfs:comment 'Free-text description of the process upset or abnormal condition that occurred during this leach event, if applicable. Populated when process_upset_flag is True. Captures the nature of the deviation for root cause analysis and corrective action tracking.' ;
    rdfs:domain ind:LeachEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metallurgicalBalanceId rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each metallurgical balance record in the processing domain. Primary key for the metallurgical_balance data product.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetallurgicalBalance .

ind:accountingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Accounting Period End' ;
    rdfs:comment 'End date of the metallurgical accounting period covered by this balance record. Together with accounting_period_start defines the reconciliation window.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Start' ;
    rdfs:comment 'Start date of the metallurgical accounting period covered by this balance record (daily, weekly, or monthly). Aligns with the financial reporting calendar.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentAuthoriser rdf:type rdf:Property ;
    rdfs:label 'Adjustment Authoriser' ;
    rdfs:comment 'Name or employee identifier of the competent person or authorised metallurgist who approved the adjustment or restatement of this balance record. Required for JORC-compliant audit trail and regulatory sign-off.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text description of the reason for any adjustment or restatement applied to this version of the metallurgical balance (e.g., assay rerun, sampling error correction, instrument calibration update, stockpile reweigh). Required for audit trail and competent person sign-off.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceReference rdf:type rdf:Property ;
    rdfs:label 'Balance Reference' ;
    rdfs:comment 'Externally-known business identifier for the metallurgical balance record, used in reports, sign-off documentation, and regulatory submissions. Format: METBAL-YYYY-MM-NNNNNN.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current workflow status of the metallurgical balance record: draft (in preparation), submitted (awaiting review), under_review (being assessed by competent person), approved (signed off), or rejected (returned for correction).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrateGrade rdf:type rdf:Property ;
    rdfs:label 'Concentrate Grade' ;
    rdfs:comment 'Assayed grade of the concentrate product expressed in the same unit as feed_grade_unit. Determines the commercial value and smelter payability of the concentrate.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Concentrate Tonnes Dry' ;
    rdfs:comment 'Total dry metric tonnes of concentrate product produced during the accounting period. Represents the valuable mineral product output from the processing circuit.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh' ;
    rdfs:comment 'Total electrical energy consumed by the processing circuit during the accounting period in kilowatt hours. Key OPEX component and sustainability metric reported under GRI and ICMM frameworks.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGrade rdf:type rdf:Property ;
    rdfs:label 'Feed Grade' ;
    rdfs:comment 'Assayed head grade of the feed material expressed as percentage (%) for base metals or grams per tonne (g/t) for precious metals. Determined by LabWare LIMS assay results on feed samples.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Feed Tonnes Dry' ;
    rdfs:comment 'Total dry metric tonnes of Run of Mine (ROM) ore fed to the processing circuit during the accounting period. Dry weight basis is the standard for metallurgical accounting.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Indicates whether this record is the current (latest approved) version of the metallurgical balance for the given period and circuit. True = current version; False = superseded version retained for audit trail.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massBalanceClosurePct rdf:type rdf:Property ;
    rdfs:label 'Mass Balance Closure Pct' ;
    rdfs:comment 'Mass balance closure expressed as a percentage: (concentrate_tonnes_dry + tailings_tonnes_dry) / feed_tonnes_dry × 100. Values outside 98–102% typically trigger investigation and adjustment.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Measured Recovery Pct' ;
    rdfs:comment 'Actual metallurgical recovery percentage calculated from assayed feed, concentrate, and tailings grades and tonnes using the standard two-product formula. Represents the proportion of valuable mineral recovered into concentrate.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalUnitsFeed rdf:type rdf:Property ;
    rdfs:label 'Metal Units Feed' ;
    rdfs:comment 'Total contained metal units in the feed stream for the period, calculated as feed_tonnes_dry × feed_grade. Expressed in tonnes of metal or troy ounces depending on commodity. Key input to JORC resource-to-reserve reconciliation.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalUnitsRecovered rdf:type rdf:Property ;
    rdfs:label 'Metal Units Recovered' ;
    rdfs:comment 'Total contained metal units recovered into concentrate for the period, calculated as concentrate_tonnes_dry × concentrate_grade. Used in LOM plan tracking and sales reconciliation.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Plant Availability Pct' ;
    rdfs:comment 'Percentage of the accounting period during which the processing plant was available for production (scheduled hours minus planned and unplanned downtime). Component of Overall Equipment Effectiveness (OEE).' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionKgPerT rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Kg Per T' ;
    rdfs:comment 'Total reagent consumption per dry metric tonne of feed processed during the period, aggregated across all reagents (collectors, frothers, pH modifiers, leach reagents). Key OPEX driver for processing cost reporting.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryVariancePct rdf:type rdf:Property ;
    rdfs:label 'Recovery Variance Pct' ;
    rdfs:comment 'Difference between measured_recovery_pct and theoretical_recovery_pct (measured minus theoretical). Positive value indicates outperformance; negative indicates underperformance against LOM plan.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsGrade rdf:type rdf:Property ;
    rdfs:label 'Tailings Grade' ;
    rdfs:comment 'Assayed grade of the tailings stream expressed in the same unit as feed_grade_unit. Indicates the residual valuable mineral content lost to tailings; key input to recovery calculation and environmental reporting.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Tailings Tonnes Dry' ;
    rdfs:comment 'Total dry metric tonnes of tailings (gangue and process waste) discharged to the Tailings Storage Facility (TSF) during the accounting period. Used in mass balance closure and TSF capacity planning.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Theoretical Recovery Pct' ;
    rdfs:comment 'Theoretical or planned recovery percentage for the period based on LOM plan targets, ore type characterisation, and process design parameters. Used as the benchmark for variance analysis.' ;
    rdfs:domain ind:MetallurgicalBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputRateTph rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Tph' ;
    rdfs:comment 'Average processing throughput rate in dry metric tonnes per hour during the accounting period. Key operational KPI for plant performance against design capacity and LOM plan.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Water Consumption M3' ;
    rdfs:comment 'Total fresh water consumed by the processing circuit during the accounting period in cubic metres. Reported for environmental compliance under ISO 14001 and GRI Mining and Metals Sector Supplement.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalExceptionId rdf:type rdf:Property ;
    rdfs:label 'Operational Exception Id' ;
    rdfs:comment 'Primary key for operational_exception' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeOrderId rdf:type rdf:Property ;
    rdfs:label 'Change Order Id' ;
    rdfs:comment 'Foreign key linking to project.change_order. Business justification: Operational exceptions during commissioning/defects liability trigger change orders against project contracts. Supports defects liability claims, contractor performance disputes, warranty claims, and ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeOrder .

ind:primaryOperationalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Operational Employee Id' ;
    rdfs:comment 'Identifier of the plant operator or control room operator responsible for logging and managing this operational exception. Links to the workforce/employee master. Used for accountability tracking and operator performance analysis.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alarmLimitHigh rdf:type rdf:Property ;
    rdfs:label 'Alarm Limit High' ;
    rdfs:comment 'The configured high alarm threshold for the process parameter at the time of the event. Used to contextualise whether the actual_value breached the high alarm boundary and to support alarm rationalisation analysis.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmLimitLow rdf:type rdf:Property ;
    rdfs:label 'Alarm Limit Low' ;
    rdfs:comment 'The configured low alarm threshold for the process parameter at the time of the event. Used to contextualise whether the actual_value breached the low alarm boundary.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action taken by the operator or maintenance team to resolve the operational exception and restore normal plant operations. Feeds maintenance knowledge base and SOP review processes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'Operational category of the exception cause: mechanical (equipment failure), electrical (power or instrumentation fault), process (reagent, slurry, or chemistry issue), planned_maintenance (scheduled shutdown), feed_shortage (insufficient ROM feed), or parameter_exceedance (process variable breach). Drives OEE loss categorisation and maintenance domain routing.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReference rdf:type rdf:Property ;
    rdfs:label 'Event Reference' ;
    rdfs:comment 'Human-readable business identifier for the operational exception event, used for cross-referencing with maintenance work orders, shift reports, and process control logs. Format: OE-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseIncidentRaised rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Raised' ;
    rdfs:comment 'Indicates whether this operational exception also triggered a formal HSE incident report in the IsoMetrix system (True) or not (False). Enables cross-domain linkage between process exceptions and HSE incident management.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateAction rdf:type rdf:Property ;
    rdfs:label 'Immediate Action' ;
    rdfs:comment 'Description of the immediate containment action taken at the time of the exception to prevent further production loss, equipment damage, or safety risk, prior to full corrective action. Distinct from corrective_action which addresses root cause.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlanned rdf:type rdf:Property ;
    rdfs:label 'Is Planned' ;
    rdfs:comment 'Indicates whether the downtime or exception event was planned (True) or unplanned (False). Planned events include scheduled maintenance shutdowns and planned feed stoppages. Used to segregate planned vs unplanned downtime in OEE calculations.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oeeLossCategory rdf:type rdf:Property ;
    rdfs:label 'Oee Loss Category' ;
    rdfs:comment 'OEE loss category to which this exception is attributed for OEE calculation purposes: availability (equipment or circuit not running), performance (running below rated throughput), or quality (product not meeting grade specification). Aligns with ISO 22400 OEE decomposition.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterDescription rdf:type rdf:Property ;
    rdfs:label 'Parameter Description' ;
    rdfs:comment 'Human-readable description of the process parameter that deviated, providing context beyond the SCADA tag code. Examples: SAG Mill Feed Rate (tph), Flotation Cell Level (%), Leach Tank pH.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterTag rdf:type rdf:Property ;
    rdfs:label 'Parameter Tag' ;
    rdfs:comment 'The OSIsoft PI System or SCADA tag identifier for the process parameter that deviated from its set-point. Applicable only for event_type = parameter_deviation or alarm. Examples: SAG_MILL_FEED_TPH, FLOTATION_CELL_LEVEL_PCT, LEACH_TANK_PH.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterUnit rdf:type rdf:Property ;
    rdfs:label 'Parameter Unit' ;
    rdfs:comment 'Engineering unit of measure for the process parameter set-point and actual values. Examples: tph (tonnes per hour), %, pH, m3/h, kPa, degC, g/L. Ensures correct interpretation of setpoint_value and actual_value.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardised code classifying the root cause of the exception per the plant\'s failure taxonomy (e.g., ISO 14224 cause codes). Enables structured root cause analysis and trend reporting across events.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative description of the identified root cause of the operational exception, as determined through investigation. Supports root cause analysis (RCA), recurring failure identification, and process improvement initiatives.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setpointValue rdf:type rdf:Property ;
    rdfs:label 'Setpoint Value' ;
    rdfs:comment 'The target or set-point value for the process parameter at the time of the deviation event. Used in conjunction with actual_value to quantify the magnitude of the deviation. Applicable for event_type = parameter_deviation.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity rating of the operational exception indicating its impact on plant throughput, safety, and production targets. Critical: full circuit or plant stoppage; High: significant throughput reduction; Medium: partial degradation; Low: minor deviation with negligible production impact.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputLossTph rdf:type rdf:Property ;
    rdfs:label 'Throughput Loss Tph' ;
    rdfs:comment 'Estimated reduction in processing throughput rate in tonnes per hour (tph) attributable to this exception event. Supports OEE rate loss analysis and process bottleneck identification.' ;
    rdfs:domain ind:OperationalException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantUtilityConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Plant Utility Consumption Id' ;
    rdfs:comment 'Primary key for plant_utility_consumption' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonBudgetTargetCo2eT rdf:type rdf:Property ;
    rdfs:label 'Carbon Budget Target Co2e T' ;
    rdfs:comment 'Approved carbon budget allocation for this circuit and period in tonnes of CO₂ equivalent (tCO₂e), derived from the LOM plan carbon budget. Used to calculate emissions variance and compliance status.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compressedAirConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Compressed Air Consumption M3' ;
    rdfs:comment 'Volume of compressed air consumed by the circuit during the period in standard cubic metres (Sm³). Used for flotation cell aeration, instrumentation, and pneumatic equipment. Contributes to energy OPEX.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionReference rdf:type rdf:Property ;
    rdfs:label 'Consumption Reference' ;
    rdfs:comment 'Externally-known business reference number for this utility consumption record, used for cross-referencing with SAP S/4HANA CO cost postings and OPEX reporting. Format: UC-YYYY-MM-NNNNNN.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electricityConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Electricity Consumption Kwh' ;
    rdfs:comment 'Total electrical energy consumed by the circuit during the period in kilowatt-hours (kWh), sourced from OSIsoft PI System metering data. Primary input for energy OPEX calculation and carbon footprint reporting.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricityCostTotal rdf:type rdf:Property ;
    rdfs:label 'Electricity Cost Total' ;
    rdfs:comment 'Total monetary cost of electricity consumed during the period in the reporting currency, calculated as electricity_consumption_kwh multiplied by electricity_unit_cost plus applicable demand charges. Posted to SAP S/4HANA CO cost centre.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricityUnitCost rdf:type rdf:Property ;
    rdfs:label 'Electricity Unit Cost' ;
    rdfs:comment 'Contracted or metered unit cost of electricity per kilowatt-hour ($/kWh) applicable to this period. Confidential commercial rate used for OPEX cost allocation and energy cost benchmarking.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyTargetKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Target Kwh' ;
    rdfs:comment 'Planned electrical energy consumption target for this circuit and period in kilowatt-hours (kWh), derived from the LOM plan energy budget. Used to calculate energy consumption variance for OPEX performance reporting.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaporationLossM3 rdf:type rdf:Property ;
    rdfs:label 'Evaporation Loss M3' ;
    rdfs:comment 'Estimated volume of water lost to evaporation from open process vessels, ponds, and the TSF during the period in cubic metres (m³). Required for water balance closure and environmental reporting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freshWaterIntakeM3 rdf:type rdf:Property ;
    rdfs:label 'Fresh Water Intake M3' ;
    rdfs:comment 'Volume of fresh water drawn from licensed water sources (rivers, bores, municipal supply) into the processing plant during the period in cubic metres (m³). Reported against water licence limits for regulatory compliance.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterReadingReference rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Reference' ;
    rdfs:comment 'Reference identifier for the physical or virtual meter reading(s) underpinning this consumption record, as recorded in OSIsoft PI System or the utility provider invoice. Supports audit trail and data lineage for regulatory submissions.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naturalGasConsumptionGj rdf:type rdf:Property ;
    rdfs:label 'Natural Gas Consumption Gj' ;
    rdfs:comment 'Volume of natural gas consumed by the circuit during the period in gigajoules (GJ), used for drying, heating, or on-site power generation. Input for Scope 1 greenhouse gas emissions calculation.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakDemandKw rdf:type rdf:Property ;
    rdfs:label 'Peak Demand Kw' ;
    rdfs:comment 'Maximum instantaneous electrical power demand recorded during the period in kilowatts (kW). Used for utility tariff management, demand charge optimisation, and grid capacity planning.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerFactor rdf:type rdf:Property ;
    rdfs:label 'Power Factor' ;
    rdfs:comment 'Average power factor (ratio of real power to apparent power, dimensionless 0–1) for the circuit during the period. Low power factor incurs utility penalty charges and indicates reactive power inefficiency.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWaterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Process Water Consumption M3' ;
    rdfs:comment 'Total process water consumed within the circuit during the period (fresh intake plus recycled, minus discharge) in cubic metres (m³). Net water balance input for environmental reporting and water licence compliance.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledWaterM3 rdf:type rdf:Property ;
    rdfs:label 'Recycled Water M3' ;
    rdfs:comment 'Volume of process water recycled from the Tailings Storage Facility (TSF) and other internal sources back into the processing circuit during the period in cubic metres (m³). Supports water stewardship reporting and licence compliance.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope1EmissionsCo2eT rdf:type rdf:Property ;
    rdfs:label 'Scope1 Emissions Co2e T' ;
    rdfs:comment 'Direct greenhouse gas emissions from on-site combustion of natural gas or other fuels during the period in tonnes of CO₂ equivalent (tCO₂e). Supports carbon budget compliance and NGER/GRI reporting.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsCo2eT rdf:type rdf:Property ;
    rdfs:label 'Scope2 Emissions Co2e T' ;
    rdfs:comment 'Indirect greenhouse gas emissions from purchased electricity consumption during the period in tonnes of CO₂ equivalent (tCO₂e), calculated using applicable grid emission factors. Supports carbon budget compliance and GRI/NGER reporting.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificEnergyKwhPerT rdf:type rdf:Property ;
    rdfs:label 'Specific Energy Kwh Per T' ;
    rdfs:comment 'Electrical energy consumed per dry metric tonne of ore processed (kWh/t), calculated as electricity_consumption_kwh divided by tonnes_processed. Key comminution efficiency KPI benchmarked against LOM plan and AISC targets.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificWaterM3PerT rdf:type rdf:Property ;
    rdfs:label 'Specific Water M3 Per T' ;
    rdfs:comment 'Process water consumed per dry metric tonne of ore processed (m³/t). Key water efficiency metric benchmarked against LOM plan targets and water licence conditions.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnesProcessed rdf:type rdf:Property ;
    rdfs:label 'Tonnes Processed' ;
    rdfs:comment 'Dry metric tonnes of ore processed through the circuit during the period. Used as the denominator for calculating specific consumption rates (e.g., kWh/t, m³/t) for benchmarking and LOM plan variance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterCostTotal rdf:type rdf:Property ;
    rdfs:label 'Water Cost Total' ;
    rdfs:comment 'Total monetary cost of fresh water intake during the period in the reporting currency, including licence fees and supply charges. Posted to SAP S/4HANA CO cost centre for OPEX tracking.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterLicenceComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Water Licence Compliance Flag' ;
    rdfs:comment 'Indicates whether fresh water intake during the period remained within the regulatory water licence limit (True = compliant, False = licence limit exceeded). Triggers environmental incident reporting workflow in IsoMetrix when False.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterLicenceLimitM3 rdf:type rdf:Property ;
    rdfs:label 'Water Licence Limit M3' ;
    rdfs:comment 'Regulatory water licence limit for fresh water intake applicable to this circuit and period in cubic metres (m³). Used to calculate compliance headroom and trigger licence breach alerts.' ;
    rdfs:domain ind:PlantUtilityConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processDeviationId rdf:type rdf:Property ;
    rdfs:label 'Process Deviation Id' ;
    rdfs:comment 'Unique surrogate identifier for each process parameter deviation record within the processing plant. Primary key for the process_deviation data product.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProcessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Employee Id' ;
    rdfs:comment 'Reference to the plant operator responsible for the circuit at the time of the deviation, used for accountability tracking and training needs analysis.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alarmTag rdf:type rdf:Property ;
    rdfs:label 'Alarm Tag' ;
    rdfs:comment 'The OSIsoft PI System or SCADA tag identifier associated with the alarmed process parameter, enabling direct traceability back to the source historian record and real-time monitoring point.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionType rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Type' ;
    rdfs:comment 'Categorical classification of the corrective action taken, enabling aggregated analysis of response patterns and effectiveness across deviation types. [ENUM-REF-CANDIDATE: reagent_adjustment|flow_adjustment|equipment_intervention|setpoint_change|process_shutdown|no_action_required|other — promote to reference product]' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The precise date and time at which the process parameter deviation was first detected, either by SCADA/PI System automated alarm or by operator observation. This is the principal real-world event time for the deviation.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationDirection rdf:type rdf:Property ;
    rdfs:label 'Deviation Direction' ;
    rdfs:comment 'Indicates whether the actual parameter value exceeded the set-point (above_setpoint) or fell below it (below_setpoint), supporting directional root cause analysis and process optimisation.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Externally-known business reference number for the deviation event, used in corrective action reports, process control logs, and root cause analysis documentation. Format: DEV-YYYY-NNNNNN.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationPct rdf:type rdf:Property ;
    rdfs:label 'Deviation Pct' ;
    rdfs:comment 'The deviation magnitude expressed as a percentage of the set-point value, enabling normalised comparison of deviation severity across parameters with different engineering units and scales.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation record, tracking progression from initial detection through corrective action to closure. [ENUM-REF-CANDIDATE: open|acknowledged|in_progress|resolved|closed|escalated — promote to reference product]' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMins rdf:type rdf:Property ;
    rdfs:label 'Duration Mins' ;
    rdfs:comment 'Total duration in minutes for which the process parameter remained outside the acceptable control limits, from detected_timestamp to resolved_timestamp. Used for severity classification and SLA compliance assessment.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the deviation was escalated beyond the shift operator level to the metallurgist, plant superintendent, or management due to severity, duration, or quality impact.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedWorkOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Work Order Number' ;
    rdfs:comment 'SAP S/4HANA PM or Infor EAM work order number raised as a result of this deviation, where equipment failure or instrumentation fault was identified as the root cause. Enables traceability between process deviations and maintenance activities.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Name of the process parameter that deviated from its set-point target, such as pH, slurry density, pulp temperature, reagent flow rate, air flow rate, or feed rate. Aligns with OSIsoft PI System tag naming conventions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Categorical classification of the process parameter type that deviated, enabling aggregated analysis by parameter category across circuits and plants. [ENUM-REF-CANDIDATE: pH|density|temperature|flow_rate|pressure|level|speed|grade|reagent_dosage|other — promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piEventFrameReference rdf:type rdf:Property ;
    rdfs:label 'Pi Event Frame Reference' ;
    rdfs:comment 'The unique event frame identifier from the OSIsoft PI System historian that corresponds to this deviation record, enabling direct cross-reference to the source process data historian for detailed time-series analysis.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLossT rdf:type rdf:Property ;
    rdfs:label 'Production Loss T' ;
    rdfs:comment 'Estimated tonnes of concentrate or processed ore lost due to the deviation, as assessed by the metallurgist. Used for OPEX impact quantification and LOM plan variance reporting.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Flag' ;
    rdfs:comment 'Indicates whether the process parameter deviation had a measurable impact on product quality (concentrate grade, recovery rate, or product specification compliance). True if quality impact was confirmed.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoveryImpactPct rdf:type rdf:Property ;
    rdfs:label 'Recovery Impact Pct' ;
    rdfs:comment 'Estimated percentage point impact on metallurgical recovery rate attributable to this deviation, as assessed by the metallurgist. Negative values indicate recovery loss. Null if no recovery impact was identified.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Deviation Flag' ;
    rdfs:comment 'Indicates whether this deviation is a recurrence of a previously recorded deviation for the same parameter and circuit within a defined lookback period, flagging chronic process control issues for targeted investigation.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time at which the process parameter was returned to within acceptable set-point tolerance and the deviation was formally resolved. Null if deviation is still open.' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorisation of the identified root cause of the deviation, used for trend analysis, recurring deviation identification, and process improvement initiatives. [ENUM-REF-CANDIDATE: equipment_failure|feed_variability|reagent_issue|operator_error|instrumentation_fault|utility_disruption|process_upset|unknown — promote to reference product]' ;
    rdfs:domain ind:ProcessDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processSampleId rdf:type rdf:Property ;
    rdfs:label 'Process Sample Id' ;
    rdfs:comment 'Unique surrogate identifier for each process sample record in the processing plant metallurgical accounting system.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesQualityCertificateId rdf:type rdf:Property ;
    rdfs:label 'Sales Quality Certificate Id' ;
    rdfs:comment 'Foreign key linking to sales.quality_certificate. Business justification: Quality certificates aggregate process sample assays to certify concentrate grade for contractual purposes. Dispute resolution, umpire assay reconciliation, and quality assurance audits require tracea' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCertificate .

ind:samplerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sampler Employee Id' ;
    rdfs:comment 'Reference to the employee who physically collected the sample at the sampling point, supporting chain of custody and quality assurance traceability.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assayElement rdf:type rdf:Property ;
    rdfs:label 'Assay Element' ;
    rdfs:comment 'Primary commodity element or analyte for which the sample is being assayed (e.g., Cu, Fe, Au, Li, Ni, Co). Drives the metallurgical accounting grade reporting.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Composite End Timestamp' ;
    rdfs:comment 'End time of the compositing period for composite samples, defining the close of the time window over which increments were collected. Null for grab or incremental samples.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compositeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Composite Start Timestamp' ;
    rdfs:comment 'Start time of the compositing period for composite samples, defining the beginning of the time window over which increments were collected. Null for grab or incremental samples.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:headGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Head Grade Unit' ;
    rdfs:comment 'Unit of measure for the head_grade value: pct = percentage (%), g_per_t = grams per tonne, ppm = parts per million, ppb = parts per billion, kg_per_t = kilograms per tonne.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementCount rdf:type rdf:Property ;
    rdfs:label 'Increment Count' ;
    rdfs:comment 'Number of individual increments combined to form a composite sample. Used to assess sampling representativeness per Theory of Sampling (TOS). Null for grab samples.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRepresentative rdf:type rdf:Property ;
    rdfs:label 'Is Representative' ;
    rdfs:comment 'Indicates whether the sample has been assessed as representative of the process stream for metallurgical accounting purposes. False samples are excluded from mass balance calculations.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massDryG rdf:type rdf:Property ;
    rdfs:label 'Mass Dry G' ;
    rdfs:comment 'Dry mass of the sample in grams after moisture removal during preparation. Used for dry-basis grade calculations and metallurgical accounting.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:massWetG rdf:type rdf:Property ;
    rdfs:label 'Mass Wet G' ;
    rdfs:comment 'Total wet mass of the collected sample in grams as weighed at the sampling point prior to preparation. Used for mass balance calculations and sample representativeness assessment.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleNotes rdf:type rdf:Property ;
    rdfs:label 'Sample Notes' ;
    rdfs:comment 'Free-text field for additional observations recorded by the sampler or metallurgist at the time of collection or preparation, such as unusual process conditions, equipment anomalies, or visual observations.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerType rdf:type rdf:Property ;
    rdfs:label 'Sampler Type' ;
    rdfs:comment 'Type of sampling device or method used to collect the sample: manual (operator-collected), automatic (automated cross-stream sampler), cross_belt, vezin (rotary cutter), or pipe_cross_cut. Affects representativeness assessment per TOS.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointCode rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Code' ;
    rdfs:comment 'Standardised code identifying the defined sampling point within the processing plant where the sample was collected (e.g., SAG_FEED, FLOAT_CONC, FLOAT_TAIL, CIL_FEED, LEACH_PLS). Corresponds to OSIsoft PI tag location.' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPointDescription rdf:type rdf:Property ;
    rdfs:label 'Sampling Point Description' ;
    rdfs:comment 'Human-readable description of the sampling point location within the processing circuit (e.g., \'SAG Mill Discharge Screen Oversize\', \'Rougher Flotation Concentrate Launder\').' ;
    rdfs:domain ind:ProcessSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processWaterBalanceId rdf:type rdf:Property ;
    rdfs:label 'Process Water Balance Id' ;
    rdfs:comment 'Unique surrogate identifier for each process water balance record in the processing plant. Primary key for the silver layer lakehouse table.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waterLicenceId rdf:type rdf:Property ;
    rdfs:label 'Water Licence Id' ;
    rdfs:comment 'Reference to the applicable water licence or water use permit under which the processing plant operates. Used for compliance tracking against licence limits.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licence .

ind:balanceClosurePct rdf:type rdf:Property ;
    rdfs:label 'Balance Closure Pct' ;
    rdfs:comment 'Percentage closure of the water mass balance, calculated as total measured outputs divided by total measured inputs multiplied by 100. Values outside 95–105% indicate measurement errors or unaccounted losses requiring investigation.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balancePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Balance Period End' ;
    rdfs:comment 'The end date and time of the water balance accounting period. Together with balance_period_start defines the measurement window.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balancePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Balance Period Start' ;
    rdfs:comment 'The start date and time of the water balance accounting period. May represent the beginning of a shift, day, or other reporting interval.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concentrateMoistureLossM3 rdf:type rdf:Property ;
    rdfs:label 'Concentrate Moisture Loss M3' ;
    rdfs:comment 'Volume of water lost from the processing circuit as moisture contained within the concentrate product dispatched during the balance period, measured in cubic metres.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freshWaterLicenceLimitM3 rdf:type rdf:Property ;
    rdfs:label 'Fresh Water Licence Limit M3' ;
    rdfs:comment 'Maximum volume of fresh water permitted to be drawn during the balance period as specified in the water use licence. Used for compliance tracking and early warning of licence exceedance.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLicenceLimitExceeded rdf:type rdf:Property ;
    rdfs:label 'Is Licence Limit Exceeded' ;
    rdfs:comment 'Indicates whether the fresh water intake during the balance period exceeded the permitted water licence limit. True = licence limit breached; False = within licence. Triggers regulatory notification obligations.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Licence Utilisation Pct' ;
    rdfs:comment 'Percentage of the water licence limit consumed during the balance period, calculated as fresh water intake divided by the licence limit. Used for proactive licence management and environmental compliance dashboards.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWaterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Net Water Consumption M3' ;
    rdfs:comment 'Net volume of water consumed by the processing plant during the balance period, calculated as total water input minus total water output, measured in cubic metres. Key metric for water stewardship reporting.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreProcessedT rdf:type rdf:Property ;
    rdfs:label 'Ore Processed T' ;
    rdfs:comment 'Dry tonnes of ore processed through the plant during the balance period. Used as the denominator for specific water consumption calculations and throughput-normalised water metrics.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWaterIntakeM3 rdf:type rdf:Property ;
    rdfs:label 'Process Water Intake M3' ;
    rdfs:comment 'Volume of water entering the processing circuit from ore moisture, reagent solutions, and other process-bound sources during the balance period, measured in cubic metres.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledWaterIntakeM3 rdf:type rdf:Property ;
    rdfs:label 'Recycled Water Intake M3' ;
    rdfs:comment 'Volume of recycled or reclaimed water returned from tailings storage facility (TSF), thickeners, or other internal circuits and reused in the processing plant during the balance period, measured in cubic metres.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recycledWaterRatioPct rdf:type rdf:Property ;
    rdfs:label 'Recycled Water Ratio Pct' ;
    rdfs:comment 'Percentage of total water input that was sourced from recycled or reclaimed water during the balance period. Measures water recycling efficiency and supports sustainability reporting targets.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seepageLossM3 rdf:type rdf:Property ;
    rdfs:label 'Seepage Loss M3' ;
    rdfs:comment 'Estimated volume of water lost through ground seepage from process ponds, pipelines, and the TSF during the balance period, measured in cubic metres. Monitored for environmental compliance.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryDensityPctSolids rdf:type rdf:Property ;
    rdfs:label 'Slurry Density Pct Solids' ;
    rdfs:comment 'Average percentage of solids by weight in the process slurry during the balance period. Directly influences water consumption in comminution and flotation circuits and is a key process control parameter.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificWaterConsumptionM3PerT rdf:type rdf:Property ;
    rdfs:label 'Specific Water Consumption M3 Per T' ;
    rdfs:comment 'Volume of fresh water consumed per tonne of ore processed during the balance period, measured in cubic metres per tonne (m³/t). Key operational efficiency and environmental performance indicator benchmarked against Life of Mine (LOM) plan targets.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificWaterConsumptionTargetM3PerT rdf:type rdf:Property ;
    rdfs:label 'Specific Water Consumption Target M3 Per T' ;
    rdfs:comment 'Life of Mine (LOM) plan target for specific water consumption in cubic metres per tonne of ore processed. Used to calculate variance against actual performance for operational and sustainability reporting.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsSlurryDensityPctSolids rdf:type rdf:Property ;
    rdfs:label 'Tailings Slurry Density Pct Solids' ;
    rdfs:comment 'Average percentage of solids by weight in the tailings slurry discharged to the TSF during the balance period. Determines the volume of water reporting to the TSF and influences TSF water recovery rates.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsWaterLossM3 rdf:type rdf:Property ;
    rdfs:label 'Tailings Water Loss M3' ;
    rdfs:comment 'Volume of water discharged to the tailings storage facility (TSF) as part of the tailings slurry during the balance period, measured in cubic metres. Critical for TSF water management and environmental compliance.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWaterInputM3 rdf:type rdf:Property ;
    rdfs:label 'Total Water Input M3' ;
    rdfs:comment 'Sum of all water inputs (fresh, recycled, and process water) entering the processing plant during the balance period, measured in cubic metres. Used as the denominator for specific water consumption calculations.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWaterOutputM3 rdf:type rdf:Property ;
    rdfs:label 'Total Water Output M3' ;
    rdfs:comment 'Sum of all water outputs (concentrate moisture, tailings, evaporation, seepage) leaving the processing circuit during the balance period, measured in cubic metres.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsfReturnWaterM3 rdf:type rdf:Property ;
    rdfs:label 'Tsf Return Water M3' ;
    rdfs:comment 'Volume of water recovered from the tailings storage facility (TSF) decant pond and returned to the processing plant as recycled water during the balance period, measured in cubic metres.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Classification of the primary fresh water source supplying the processing plant during the balance period. [ENUM-REF-CANDIDATE: bore|river|dam|municipal|stormwater|tsf_return — promote to reference product if additional sources are required]' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStressZone rdf:type rdf:Property ;
    rdfs:label 'Water Stress Zone' ;
    rdfs:comment 'Classification of the water stress level of the catchment area in which the processing plant operates, aligned with the World Resources Institute (WRI) Aqueduct framework. Informs water stewardship risk reporting.' ;
    rdfs:domain ind:ProcessWaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitCode rdf:type rdf:Property ;
    rdfs:label 'Circuit Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the processing circuit within the plant flowsheet (e.g., PC-SAG-01, FL-RGH-02). Used in P&ID documentation, SCADA tags, and operational reporting.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitDescription rdf:type rdf:Property ;
    rdfs:label 'Circuit Description' ;
    rdfs:comment 'Free-text description of the processing circuit including its role in the plant flowsheet, key equipment, and any notable design features or operational constraints. Supports engineering documentation and onboarding.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitName rdf:type rdf:Property ;
    rdfs:label 'Circuit Name' ;
    rdfs:comment 'Human-readable descriptive name of the processing circuit (e.g., Primary SAG Mill Circuit, Rougher Flotation Circuit, Leach Circuit 1). Used in operational dashboards and reporting.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitStatus rdf:type rdf:Property ;
    rdfs:label 'Circuit Status' ;
    rdfs:comment 'Current operational lifecycle status of the processing circuit. Drives scheduling, maintenance planning, and production reporting inclusion/exclusion.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitType rdf:type rdf:Property ;
    rdfs:label 'Circuit Type' ;
    rdfs:comment 'Category of mineral processing technology employed in this circuit. Drives applicable KPIs, reagent profiles, and recovery benchmarks. [ENUM-REF-CANDIDATE: comminution|flotation|leaching|gravity_separation|dense_media_separation|sx_ew|thickening|filtration|classification — promote to reference product]' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Design Availability Pct' ;
    rdfs:comment 'Design basis mechanical availability of the circuit expressed as a percentage of scheduled operating hours. Used as the denominator in OEE calculations and production planning. Derived from MTBF and MTTR estimates at design stage.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFeedSizeP80Mm rdf:type rdf:Property ;
    rdfs:label 'Design Feed Size P80 Mm' ;
    rdfs:comment 'Design basis P80 particle size of the feed material entering this circuit in millimetres. P80 represents the 80th percentile passing size. Critical for comminution circuit design and mill sizing.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designPhTarget rdf:type rdf:Property ;
    rdfs:label 'Design Ph Target' ;
    rdfs:comment 'Design basis target pH value for the circuit process stream. Applicable to flotation (pH control for selectivity), leaching (acid/alkaline conditions), and SX-EW circuits. Drives lime/acid reagent consumption.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designProductSizeP80Mm rdf:type rdf:Property ;
    rdfs:label 'Design Product Size P80 Mm' ;
    rdfs:comment 'Design basis P80 particle size of the product leaving this circuit in millimetres. Defines the target grind size for comminution circuits and classification efficiency for downstream separation circuits.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designResidenceTimeMin rdf:type rdf:Property ;
    rdfs:label 'Design Residence Time Min' ;
    rdfs:comment 'Design basis residence time of material within the circuit expressed in minutes. Determines tank/vessel sizing and is a key parameter for leach kinetics, flotation recovery, and thickener design.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designSlurryDensityPct rdf:type rdf:Property ;
    rdfs:label 'Design Slurry Density Pct' ;
    rdfs:comment 'Design basis slurry density expressed as percentage solids by weight for circuits handling slurry streams. Critical for pump sizing, pipe design, and process control setpoints.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputMtpa rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Mtpa' ;
    rdfs:comment 'Annualised nameplate design throughput capacity expressed in million dry metric tonnes per annum (Mtpa). Used for LOM plan alignment, capital project justification, and annual production reporting.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Tph' ;
    rdfs:comment 'Nameplate design throughput capacity of the circuit expressed in dry metric tonnes per hour (tph). Represents the engineering design basis used for LOM plan benchmarking and OEE calculations.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Design Utilisation Pct' ;
    rdfs:comment 'Design basis utilisation rate of the circuit expressed as a percentage of available hours actually used for production. Combined with availability to derive OEE. Accounts for planned feed interruptions and scheduled downtime.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designWaterConsumptionM3pt rdf:type rdf:Property ;
    rdfs:label 'Design Water Consumption M3pt' ;
    rdfs:comment 'Design basis fresh water consumption rate for this circuit expressed in cubic metres per dry metric tonne of feed processed. Used for water balance modelling, environmental licence compliance, and OPEX planning.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'Reference number of the environmental operating permit or licence governing this circuit\'s operations (e.g., water use licence, air emission permit). Required for regulatory compliance reporting under ISO 14001 and EIS obligations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedMaterialType rdf:type rdf:Property ;
    rdfs:label 'Feed Material Type' ;
    rdfs:comment 'Classification of the primary feed material entering this circuit (e.g., ROM Ore for primary comminution, slurry for flotation). Determines applicable feed quality parameters and circuit design basis. [ENUM-REF-CANDIDATE: rom_ore|crushed_ore|ground_ore|concentrate|slurry|leach_solution|tailings|recycled_stream — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowsheetSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Flowsheet Sequence Order' ;
    rdfs:comment 'Integer position of this circuit within the overall plant processing flowsheet. Defines the order of material flow from feed preparation through to final product, enabling flowsheet visualisation and mass balance calculations.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installedPowerKw rdf:type rdf:Property ;
    rdfs:label 'Installed Power Kw' ;
    rdfs:comment 'Total installed electrical power capacity of the circuit in kilowatts (kW). Used for energy consumption benchmarking, OPEX modelling, and specific energy intensity calculations (kWh/t).' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryCircuit rdf:type rdf:Property ;
    rdfs:label 'Is Primary Circuit' ;
    rdfs:comment 'Indicates whether this circuit is the primary (first-pass) processing circuit in the plant flowsheet as opposed to a secondary, scavenger, or retreatment circuit. Used for production reporting hierarchy and mass balance prioritisation.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfUnits rdf:type rdf:Property ;
    rdfs:label 'Number Of Units' ;
    rdfs:comment 'Count of parallel processing units (e.g., mills, flotation cells, leach tanks) operating within this circuit. Used for availability calculations, maintenance scheduling, and throughput modelling.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:piAfElementPath rdf:type rdf:Property ;
    rdfs:label 'Pi Af Element Path' ;
    rdfs:comment 'Full Asset Framework (AF) element path in the OSIsoft PI System for this processing circuit (e.g., \\\\Server\\Plant\\MillCircuit\\SAG01). Enables direct linkage between the data product and real-time process historian data.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentSchemeCode rdf:type rdf:Property ;
    rdfs:label 'Reagent Scheme Code' ;
    rdfs:comment 'Code identifying the standard reagent addition scheme applied in this circuit (e.g., collector, frother, pH modifier for flotation; acid type for leaching). Links to reagent consumption planning and OPEX budgeting.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Specific processing sub-type within the circuit type category (e.g., SAG Mill under comminution, Rougher under flotation, CIL under leaching). Enables granular performance benchmarking. [ENUM-REF-CANDIDATE: sag_mill|ball_mill|hpgr|rod_mill|rougher|scavenger|cleaner|recleaner|heap_leach|vat_leach|cil|cip|dms|jig|spiral|electrowinning|solvent_extraction — promote to reference product]' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFeedGradePct rdf:type rdf:Property ;
    rdfs:label 'Target Feed Grade Pct' ;
    rdfs:comment 'LOM plan target head grade of the feed material entering this circuit expressed as a percentage of the primary commodity. Used for cut-off grade optimisation and circuit performance benchmarking.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProductGradePct rdf:type rdf:Property ;
    rdfs:label 'Target Product Grade Pct' ;
    rdfs:comment 'LOM plan target grade of the circuit output product expressed as a percentage of the primary commodity (e.g., concentrate grade for flotation, cathode purity for SX-EW). Used for sales contract compliance and resource reporting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRecoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Recovery Rate Pct' ;
    rdfs:comment 'LOM plan target metallurgical recovery rate for the primary commodity expressed as a percentage (e.g., 87.500 for 87.5%). Represents the expected proportion of valuable mineral extracted relative to feed grade. Basis for reserve reporting under JORC/CIM.' ;
    rdfs:domain ind:Circuit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Primary Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Processing plants engage with primary affected communities and indigenous groups. Required for stakeholder engagement registers, social licence reporting, community consultation tracking, and regulato' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:aiscBenchmarkUsdPerT rdf:type rdf:Property ;
    rdfs:label 'Aisc Benchmark Usd Per T' ;
    rdfs:comment 'The budgeted or benchmark All-In Sustaining Cost (AISC) for processing at this plant expressed in USD per dry metric tonne of ore processed. Used as the financial performance baseline for C1 cash cost reporting and LOM plan economics.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualCapacityMt rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Mt' ;
    rdfs:comment 'Nameplate annual throughput capacity expressed in million dry metric tonnes per annum (Mtpa). Derived from design_capacity_tph and planned operating hours but stored as a master data attribute for LOM plan alignment and regulatory resource reporting.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:careMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Care Maintenance Date' ;
    rdfs:comment 'The date on which the plant was placed into care-and-maintenance status. Null if the plant has never been placed on care-and-maintenance. Used for OPEX tracking, insurance, and regulatory compliance reporting.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comminutionTechnology rdf:type rdf:Property ;
    rdfs:label 'Comminution Technology' ;
    rdfs:comment 'Primary size-reduction (comminution) technology installed in the plant. SAG (Semi-Autogenous Grinding), HPGR (High Pressure Grinding Rolls), ball mill, rod mill, crusher, AG (Autogenous Grinding), or combined circuit. Drives energy consumption benchmarking and maintenance planning. [ENUM-REF-CANDIDATE: SAG|HPGR|ball_mill|rod_mill|crusher|AG|combined — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationMasl rdf:type rdf:Property ;
    rdfs:label 'Elevation Masl' ;
    rdfs:comment 'Elevation of the processing plant site in metres above sea level (mASL). Relevant for water balance modelling, slurry pipeline hydraulics design, and environmental impact assessments.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGradeDesignPct rdf:type rdf:Property ;
    rdfs:label 'Feed Grade Design Pct' ;
    rdfs:comment 'Design ROM feed head grade (percentage of valuable mineral in the feed ore) for which the plant was engineered. Used as the baseline for metallurgical balance calculations, cut-off grade assessments, and LOM plan modelling.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsPlantCode rdf:type rdf:Property ;
    rdfs:label 'Lims Plant Code' ;
    rdfs:comment 'The plant identifier used in the LabWare LIMS (Laboratory Information Management System) for sample registration, assay result linkage, and metallurgical accounting. Enables traceability from plant feed to product assay.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameplateRecoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Nameplate Recovery Rate Pct' ;
    rdfs:comment 'Design-rated metallurgical recovery rate expressed as a percentage (0–100). Represents the percentage of the target valuable mineral in the feed that is expected to report to the concentrate or product stream under nameplate conditions. Key input to LOM plan financial modelling and JORC/NI 43-101 resource estimation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfProcessingLines rdf:type rdf:Property ;
    rdfs:label 'Number Of Processing Lines' ;
    rdfs:comment 'Total count of parallel processing lines (circuits) within the plant. Each line represents an independent processing train capable of treating ore from feed to product. Drives capacity planning, maintenance scheduling, and redundancy analysis.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oreTypeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Ore Type Compatibility' ;
    rdfs:comment 'Comma-separated list of ore/commodity types this plant is designed and certified to process (e.g., \'iron ore, copper, gold, lithium, nickel, coal, diamonds\'). Drives feed stream routing and LOM plan alignment. [ENUM-REF-CANDIDATE: iron ore|copper|gold|lithium|nickel|coal|diamonds|zinc|lead|manganese — promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantDescription rdf:type rdf:Property ;
    rdfs:label 'Plant Description' ;
    rdfs:comment 'Free-text narrative description of the processing plant including key design features, processing circuit configuration, historical context, and any notable operational characteristics. Supports regulatory submissions, investor reports, and technical documentation.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantName rdf:type rdf:Property ;
    rdfs:label 'Plant Name' ;
    rdfs:comment 'Full human-readable name of the mineral processing plant facility (e.g., \'Pilbara Iron Ore Processing Plant 1\', \'Olympic Dam Copper Concentrator\'). Used in reports, dashboards, and regulatory submissions.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantType rdf:type rdf:Property ;
    rdfs:label 'Plant Type' ;
    rdfs:comment 'High-level classification of the processing plant by metallurgical process family. \'concentrator\' = physical separation to produce mineral concentrate; \'hydrometallurgical\' = chemical leaching/SX-EW; \'pyrometallurgical\' = smelting/roasting; \'beneficiation\' = upgrading without full extraction; \'refinery\' = final product refining; \'pelletising\' = iron ore pellet production.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionDesignKw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Design Kw' ;
    rdfs:comment 'Nameplate design electrical power consumption in kilowatts (kW) at full throughput. Used for energy cost modelling (OPEX), carbon footprint reporting (GRI Mining and Metals Sector Supplement), and grid capacity planning.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryProcessingMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Processing Method' ;
    rdfs:comment 'The principal mineral processing and beneficiation method employed by this plant. Comminution includes SAG/HPGR milling; flotation covers froth flotation separation; leaching includes heap and tank leaching; SX-EW (Solvent Extraction Electrowinning) for copper cathode production; DMS (Dense Media Separation) for coal/diamonds; gravity and magnetic separation for iron ore. [ENUM-REF-CANDIDATE: comminution|flotation|leaching|SX-EW|DMS|gravity|magnetic — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'The primary saleable product form produced by this plant (e.g., \'concentrate\' for copper/gold flotation plants, \'cathode\' for SX-EW copper plants, \'pellet\' for iron ore pelletising, \'fines\'/\'lump\' for iron ore beneficiation, \'doré\' for gold/silver). Drives sales contract and logistics configuration. [ENUM-REF-CANDIDATE: concentrate|cathode|pellet|fines|lump|slurry|doré — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFunctionalLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Functional Location' ;
    rdfs:comment 'The SAP S/4HANA Plant Maintenance (PM) functional location code assigned to this processing plant. Enables linkage to maintenance work orders, preventive maintenance plans, and CAPEX/OPEX cost centre reporting in SAP.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemCode rdf:type rdf:Property ;
    rdfs:label 'Scada System Code' ;
    rdfs:comment 'The identifier of the SCADA (Supervisory Control and Data Acquisition) system instance or node that monitors and controls this processing plant. Used to link real-time process historian data (OSIsoft PI System) to the plant master record.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tailingsGenerationDesignTph rdf:type rdf:Property ;
    rdfs:label 'Tailings Generation Design Tph' ;
    rdfs:comment 'Nameplate design rate of tailings (gangue and process residue) generated by the plant in dry metric tonnes per hour. Drives TSF (Tailings Storage Facility) capacity planning, environmental licence conditions, and ICMM tailings governance compliance.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionDesignM3ph rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Design M3ph' ;
    rdfs:comment 'Nameplate design water consumption rate in cubic metres per hour (m³/h) for the plant under full throughput conditions. Critical for water balance management, environmental licence compliance, and EIS (Environmental Impact Statement) reporting.' ;
    rdfs:domain ind:Plant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each reagent consumption record in the mineral processing circuit. Primary key for this transactional entity.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Supplier batch or lot number of the reagent consumed. Enables traceability for quality incidents, reagent performance investigations, and environmental compliance audits.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Consumption Record Number' ;
    rdfs:comment 'Externally-visible business identifier for this consumption record, formatted as RC-YYYY-MM-NNNNNN. Used for cross-referencing with SAP material documents, LIMS records, and environmental compliance reports.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Consumption Status' ;
    rdfs:comment 'Current lifecycle status of the reagent consumption record. Draft records are pending operator confirmation; confirmed records are locked for OPEX reporting; adjusted records have been corrected post-shift; cancelled records are voided.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The principal real-world date and time at which the reagent consumption event occurred or was recorded by the process control system (OSIsoft PI / SCADA). Distinct from record audit timestamps.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosageRate rdf:type rdf:Property ;
    rdfs:label 'Dosage Rate' ;
    rdfs:comment 'Rate at which the reagent was dosed into the circuit, expressed in grams per tonne (g/t) of ore processed or kilograms per hour (kg/hr) depending on the reagent type and circuit. Core metric for reagent optimisation and benchmarking against LOM plan targets.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosageRateUnit rdf:type rdf:Property ;
    rdfs:label 'Dosage Rate Unit' ;
    rdfs:comment 'Unit of measure for the reagent dosage rate field. Common units include grams per tonne (g/t) for solid reagents dosed relative to ore throughput, and kilograms per hour (kg/hr) for liquid reagents dosed by flow rate.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReportRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Report Required' ;
    rdfs:comment 'Indicates whether this reagent consumption event requires mandatory environmental compliance reporting (e.g., cyanide usage under ICMC, acid consumption under EIS conditions). Drives automated compliance workflow in IsoMetrix.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether the reagent is classified as hazardous under applicable environmental and safety regulations (e.g., cyanide, sulphuric acid). Triggers mandatory environmental compliance reporting and PPE requirements per ISO 14001 and ISO 45001.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oreThroughputT rdf:type rdf:Property ;
    rdfs:label 'Ore Throughput T' ;
    rdfs:comment 'Total dry metric tonnes of ore processed through the circuit during the shift. Used as the denominator for calculating specific reagent consumption (g/t) and benchmarking against LOM plan targets.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDosageRate rdf:type rdf:Property ;
    rdfs:label 'Plan Dosage Rate' ;
    rdfs:comment 'Life of Mine (LOM) plan target dosage rate for this reagent in this circuit, in the same unit as dosage_rate. Enables variance analysis between actual and planned reagent consumption for process optimisation.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Plan Quantity Kg' ;
    rdfs:comment 'Life of Mine (LOM) plan target quantity of reagent for this shift and circuit in kilograms. Used for budget variance reporting and OPEX performance management against the approved mine plan.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityConsumedKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed Kg' ;
    rdfs:comment 'Total mass of reagent consumed during the shift in kilograms. Primary quantity field for OPEX cost calculation, reagent inventory reconciliation, and environmental compliance reporting of chemical usage volumes.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryDensityGPerCm3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density G Per Cm3' ;
    rdfs:comment 'Density of the slurry in grams per cubic centimetre at the time of reagent consumption. Influences reagent dispersion and effectiveness; monitored via OSIsoft PI System for process control and optimisation.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryPh rdf:type rdf:Property ;
    rdfs:label 'Slurry Ph' ;
    rdfs:comment 'pH level of the slurry (water and ore mixture) in the circuit at the time of reagent consumption. Critical process parameter for reagent effectiveness — lime and acid dosage directly controls pH for flotation and leaching circuits.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificConsumptionGPerT rdf:type rdf:Property ;
    rdfs:label 'Specific Consumption G Per T' ;
    rdfs:comment 'Reagent consumption normalised per dry metric tonne of ore processed (grams per tonne). Calculated as quantity_consumed_kg × 1000 / ore_throughput_t. Key OPEX optimisation metric and LOM plan variance indicator.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the supplier who provided the reagent batch consumed. Used for supplier performance management, procurement analysis, and reagent quality investigations.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRecoveryTargetId rdf:type rdf:Property ;
    rdfs:label 'Processing Recovery Target Id' ;
    rdfs:comment 'Unique surrogate identifier for each recovery target record in the LOM plan-derived processing circuit performance baseline.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessingRecoveryTarget .

ind:revenueForecastId rdf:type rdf:Property ;
    rdfs:label 'Revenue Forecast Id' ;
    rdfs:comment 'Foreign key linking to sales.revenue_forecast. Business justification: Revenue forecasts assume metallurgical recovery rates from processing targets to project saleable product volumes. Financial planning, investor reporting, and budget variance analysis require linking ' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueForecast .

ind:basisType rdf:type rdf:Property ;
    rdfs:label 'Basis Type' ;
    rdfs:comment 'Classification of the technical study or planning document type that forms the basis for this recovery target (e.g., LOM plan, definitive feasibility study, pre-feasibility study, scoping study, annual budget). Indicates the confidence level and authority of the target.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrateGradeUnit rdf:type rdf:Property ;
    rdfs:label 'Concentrate Grade Unit' ;
    rdfs:comment 'Unit of measure for the target concentrate grade value (e.g., pct for percentage, g_per_t for grams per tonne). Ensures correct interpretation of the concentrate quality specification.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityStudyRef rdf:type rdf:Property ;
    rdfs:label 'Feasibility Study Ref' ;
    rdfs:comment 'Document reference number or title of the feasibility study, pre-feasibility study (PFS), or definitive feasibility study (DFS) from which this recovery target is derived. Provides audit traceability to the authorised technical study.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Version' ;
    rdfs:comment 'Version identifier of the LOM plan from which this target is derived (e.g., LOM-2024-v3.1). Enables tracking of target changes across successive LOM plan revisions and supports variance analysis against the correct plan baseline.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalUnitsUnit rdf:type rdf:Property ;
    rdfs:label 'Metal Units Unit' ;
    rdfs:comment 'Unit of measure for the target contained metal units (e.g., t for metric tonnes, oz for troy ounces, lb for pounds). Ensures correct interpretation across different commodity reporting conventions.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConcentrateGrade rdf:type rdf:Property ;
    rdfs:label 'Target Concentrate Grade' ;
    rdfs:comment 'Planned grade of the final concentrate or product output from the processing circuit during the target period, expressed in the unit defined by concentrate_grade_unit. Represents the quality specification for the saleable product.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetConcentrateKt rdf:type rdf:Property ;
    rdfs:label 'Target Concentrate Kt' ;
    rdfs:comment 'Planned total dry metric tonnes of concentrate (in kilotonnes) to be produced during the target period. Supports sales planning, logistics scheduling, and LOM revenue forecasting.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEnergyConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Target Energy Consumption Kwh' ;
    rdfs:comment 'Planned total electrical energy consumption in kilowatt-hours for the processing circuit during the target period. Used for energy cost budgeting, carbon footprint reporting, and OPEX modelling.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFeedMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Target Feed Moisture Pct' ;
    rdfs:comment 'Planned moisture content of the Run of Mine (ROM) feed entering the processing circuit, expressed as a percentage. Affects dry tonne calculations, throughput, and reagent dosing. Derived from ore characterisation in the feasibility study.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMassPullPct rdf:type rdf:Property ;
    rdfs:label 'Target Mass Pull Pct' ;
    rdfs:comment 'Planned mass pull percentage — the proportion of feed mass reporting to the concentrate stream. A key flotation circuit design parameter that balances recovery against concentrate grade. Derived from metallurgical test work in the feasibility study.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMetalUnits rdf:type rdf:Property ;
    rdfs:label 'Target Metal Units' ;
    rdfs:comment 'Planned quantity of contained metal units to be recovered during the target period, expressed in the unit defined by metal_units_unit (e.g., tonnes of copper, ounces of gold). Core metric for LOM production target and revenue planning.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Target Period End' ;
    rdfs:comment 'End date of the planning period to which this recovery target applies. Defines the upper boundary of the target window for performance measurement and LOM plan variance reporting.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Target Period Start' ;
    rdfs:comment 'Start date of the planning period to which this recovery target applies. Combined with target_period_end to define the exact window for variance analysis against actual metallurgical balance results.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetPeriodType rdf:type rdf:Property ;
    rdfs:label 'Target Period Type' ;
    rdfs:comment 'Granularity of the planning period for which this recovery target is defined: monthly, quarterly, annual, or full Life of Mine (LOM). Determines the temporal resolution of variance analysis.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPlantAvailabilityPct rdf:type rdf:Property ;
    rdfs:label 'Target Plant Availability Pct' ;
    rdfs:comment 'Planned plant availability percentage for the processing circuit during the target period, representing the proportion of scheduled time the plant is available for production. Used in conjunction with throughput targets to derive planned production volumes.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReagentConsumption rdf:type rdf:Property ;
    rdfs:label 'Target Reagent Consumption' ;
    rdfs:comment 'Planned total reagent consumption rate in kilograms per dry metric tonne of ore processed. Aggregated across all reagents for the circuit. Used for OPEX budgeting and reagent procurement planning.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Target Recovery Pct' ;
    rdfs:comment 'Planned metallurgical recovery rate expressed as a percentage of valuable mineral recovered from feed to final product (concentrate or cathode). Derived from LOM plan or feasibility study metallurgical test work. Core KPI for processing performance variance analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReference rdf:type rdf:Property ;
    rdfs:label 'Target Reference' ;
    rdfs:comment 'Externally-known business identifier for this recovery target record, used in planning documents, feasibility studies, and variance reporting (e.g., RT-CU-FL-202401).' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of this recovery target record: draft (under preparation), approved (authorised for use in variance reporting), superseded (replaced by a newer version), or archived (no longer active).' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThroughputKt rdf:type rdf:Property ;
    rdfs:label 'Target Throughput Kt' ;
    rdfs:comment 'Total planned dry metric tonnes (in kilotonnes) to be processed through the circuit during the target period. Complements the rate-based tph target for period-level production planning and LOM schedule adherence.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetThroughputTph rdf:type rdf:Property ;
    rdfs:label 'Target Throughput Tph' ;
    rdfs:comment 'Planned processing throughput rate in dry metric tonnes per hour (tph) for the circuit during the target period. Used to assess whether actual mill throughput meets LOM plan expectations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWaterConsumptionM3 rdf:type rdf:Property ;
    rdfs:label 'Target Water Consumption M3' ;
    rdfs:comment 'Planned total water consumption in cubic metres for the processing circuit during the target period. Supports water balance management, environmental licence compliance, and sustainability reporting.' ;
    rdfs:domain ind:ProcessingRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Employee identifier of the shift supervisor responsible for sign-off on this production run record. Required for accountability, regulatory compliance, and shift handover documentation. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualThroughputRateTph rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Rate Tph' ;
    rdfs:comment 'Actual average processing rate achieved during the shift, expressed in dry tonnes per hour (tph). Calculated as tonnes processed divided by operating hours. Compared against design throughput rate for performance gap analysis.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calendarHours rdf:type rdf:Property ;
    rdfs:label 'Calendar Hours' ;
    rdfs:comment 'Total number of hours in the shift period as defined by the site calendar (typically 12 hours for a standard shift). Used as the denominator for plant utilisation and OEE calculations. Expressed in decimal hours.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrateProducedTonnes rdf:type rdf:Property ;
    rdfs:label 'Concentrate Produced Tonnes' ;
    rdfs:comment 'Total dry tonnes of mineral concentrate or final processed product produced during the shift. Used for production accounting, inventory management, and sales dispatch planning. Sourced from product weighbridge or belt scale measurements.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputRateTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Rate Tph' ;
    rdfs:comment 'Nameplate or design throughput rate of the processing plant circuit, expressed in dry tonnes per hour (tph), as specified in the LOM plan and plant design documentation. Used as the benchmark for actual throughput performance assessment.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedBlendOxidePct rdf:type rdf:Property ;
    rdfs:label 'Feed Blend Oxide Pct' ;
    rdfs:comment 'Percentage of oxide ore type in the ROM feed blend during the shift. Part of the feed blend composition tracking used to predict and explain metallurgical recovery variations and circuit performance. Sourced from grade control block data and ROM stockpile management.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedBlendSulphidePct rdf:type rdf:Property ;
    rdfs:label 'Feed Blend Sulphide Pct' ;
    rdfs:comment 'Percentage of sulphide ore type in the ROM feed blend during the shift. Used alongside oxide percentage to characterise the feed blend composition for metallurgical performance analysis and reagent dosage optimisation.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedGradeElement rdf:type rdf:Property ;
    rdfs:label 'Feed Grade Element' ;
    rdfs:comment 'Chemical element symbol for which the feed head grade is reported (e.g., Fe for iron ore, Cu for copper, Li for lithium). Enables multi-commodity processing plants to correctly attribute grade measurements to the target mineral. [ENUM-REF-CANDIDATE: Fe|Cu|Au|Ag|Li|Ni|Co|Zn|Pb|Mo — promote to reference product]' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedHeadGradePct rdf:type rdf:Property ;
    rdfs:label 'Feed Head Grade Pct' ;
    rdfs:comment 'Assayed head grade of the primary valuable element (e.g., Fe%, Cu%, Li%) in the ROM feed during the shift, expressed as a percentage. Sourced from LabWare LIMS composite sample assay results. Critical input for metallurgical recovery calculations and LOM plan reconciliation.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metallurgicalRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Recovery Pct' ;
    rdfs:comment 'Percentage of the valuable element in the ROM feed that is successfully recovered into the final concentrate or product during the shift. Calculated from feed grade, product grade, and mass balance. Core KPI for processing efficiency and LOM plan reconciliation.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oeePct rdf:type rdf:Property ;
    rdfs:label 'Oee Pct' ;
    rdfs:comment 'Overall Equipment Effectiveness expressed as a percentage, combining availability, performance, and quality rate for the processing plant during the shift. Industry-standard KPI for processing plant productivity benchmarking against LOM plan targets. Sourced from OSIsoft PI System.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Downtime Hours' ;
    rdfs:comment 'Hours of scheduled downtime during the shift for planned maintenance, inspections, or scheduled shutdowns. Used in circuit availability and OEE calculations. Sourced from Infor EAM work order schedules.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Plant Utilisation Pct' ;
    rdfs:comment 'Percentage of available hours during which the plant was actively processing ore, calculated as operating hours divided by available hours. Reflects how effectively available plant time is being used for production. Reported in daily production meetings.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryOreType rdf:type rdf:Property ;
    rdfs:label 'Primary Ore Type' ;
    rdfs:comment 'Dominant ore type or lithological classification of the ROM feed processed during the shift (e.g., oxide, sulphide, mixed, transitional, fresh). Determines the applicable processing circuit configuration and expected metallurgical recovery. Sourced from Geovia GEMS geological model and grade control data.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCircuitType rdf:type rdf:Property ;
    rdfs:label 'Processing Circuit Type' ;
    rdfs:comment 'Primary processing circuit configuration active during the shift. Identifies the comminution and separation technology applied (e.g., SAG/ball mill, HPGR, DMS, flotation, leach, SX-EW). Used for circuit-level performance benchmarking and maintenance planning. [ENUM-REF-CANDIDATE: SAG_ball_mill|HPGR|DMS|flotation|leach|SX_EW|gravity|magnetic_separation — promote to reference product]' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:romFeedTonnesDry rdf:type rdf:Property ;
    rdfs:label 'Rom Feed Tonnes Dry' ;
    rdfs:comment 'Total dry tonnes of Run of Mine (ROM) ore fed to the processing plant during the shift, calculated by applying the measured moisture factor to wet tonnes. Dry tonnes are the standard basis for metallurgical accounting, resource reporting, and LOM plan reconciliation.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:romFeedTonnesWet rdf:type rdf:Property ;
    rdfs:label 'Rom Feed Tonnes Wet' ;
    rdfs:comment 'Total wet tonnes of Run of Mine (ROM) ore fed to the processing plant during the shift, as measured at the feed conveyor belt scale. Wet weight includes moisture content. Used for mass balance and throughput reporting.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftNotes rdf:type rdf:Property ;
    rdfs:label 'Shift Notes' ;
    rdfs:comment 'Free-text operational notes recorded by the shift supervisor covering significant events, process upsets, equipment issues, safety observations, or other contextual information relevant to the shift production run. Supports shift handover communication and exception reporting.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Designates the shift rotation within the calendar day: \'day\' (typically 06:00–18:00), \'night\' (18:00–06:00), or \'afternoon\' (14:00–22:00) depending on site roster configuration. Used for shift-based production reporting and crew scheduling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftRunNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Run Number' ;
    rdfs:comment 'Externally-known business identifier for the shift production run, used in daily production reports, shift handover documentation, and reconciliation against LOM plan targets. Format: SPR-YYYY-MM-DD-PLANTCODE-SEQ. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Signoff Timestamp' ;
    rdfs:comment 'Date and time when the shift supervisor formally approved and signed off the shift production run record. Marks the transition from \'under_review\' to \'approved\' status. Required for daily production reporting and audit compliance.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unplannedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Unplanned Downtime Hours' ;
    rdfs:comment 'Hours of unscheduled downtime during the shift due to equipment breakdowns, process upsets, or emergency stoppages. Key input for MTBF and MTTR analysis and OEE degradation reporting.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether adverse weather conditions materially impacted processing plant operations or throughput during the shift. Used to qualify production shortfalls in reporting and distinguish weather-related downtime from equipment or process failures.' ;
    rdfs:domain ind:ShiftProductionRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slurryMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Slurry Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each slurry measurement record in the Silver Layer lakehouse. Primary key for this time-series observation table. Entity role: EVENT_LOG — append-only stream of immutable slurry parameter observations captured from OSIsoft PI System via OPC-UA at key mineral processing points.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementPointId rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Id' ;
    rdfs:comment 'Reference to the process measurement point (instrument tag location) where the slurry parameters were captured. Corresponds to the PI tag source location in the OSIsoft PI System, identifying the physical sensor or instrument node in the mineral processing circuit (e.g., SAG mill discharge, flotation feed, leach feed).' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeasurementPoint .

ind:processCircuitId rdf:type rdf:Property ;
    rdfs:label 'Process Circuit Id' ;
    rdfs:comment 'Reference to the specific processing circuit (e.g., comminution, flotation, leaching, SX-EW) within the plant where the measurement was taken. Supports circuit-level mass balance and metallurgical accounting.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Circuit .

ind:alarmHighLimit rdf:type rdf:Property ;
    rdfs:label 'Alarm High Limit' ;
    rdfs:comment 'The configured upper alarm threshold for this measurement point in the SCADA/DCS system. When the measured value exceeds this limit, an automated high alarm is generated for operator response. Expressed in the same engineering unit as the measurement. Used for automated alarm generation and process safety management.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmLowLimit rdf:type rdf:Property ;
    rdfs:label 'Alarm Low Limit' ;
    rdfs:comment 'The configured lower alarm threshold for this measurement point in the SCADA/DCS system. When the measured value falls below this limit, an automated low alarm is generated for operator response. Expressed in the same engineering unit as the measurement. Used for automated alarm generation and process safety management.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conductivityMsCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Ms Cm' ;
    rdfs:comment 'Electrical conductivity of the slurry at the measurement point, expressed in millisiemens per centimetre (mS/cm). Indicator of dissolved ion concentration, relevant for process water quality management, reagent dosing control in flotation, and environmental monitoring of process water circuits.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationFromSetpoint rdf:type rdf:Property ;
    rdfs:label 'Deviation From Setpoint' ;
    rdfs:comment 'The arithmetic difference between the actual measured value and the configured process setpoint value (measured_value minus setpoint_value), expressed in the same engineering unit. A non-derived operational field captured directly from the PI System control deviation tag. Positive values indicate measurement above setpoint; negative values indicate below setpoint. Used for process control performance monitoring and alarm root cause analysis.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineeringUnit rdf:type rdf:Property ;
    rdfs:label 'Engineering Unit' ;
    rdfs:comment 'The unit of measurement associated with the primary measurement value for this PI tag (e.g., t/m³, %w/w, m³/hr, pH, °C, cP, mS/cm, µm). Sourced from the PI tag engineering unit configuration. Supports dynamic unit-aware analytics and cross-tag comparisons in the metallurgical historian.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateM3Hr rdf:type rdf:Property ;
    rdfs:label 'Flow Rate M3 Hr' ;
    rdfs:comment 'Volumetric flow rate of the slurry stream at the measurement point, expressed in cubic metres per hour (m³/hr). Measured by electromagnetic or Coriolis flow meter. Used in metallurgical mass balance, throughput calculations, and pump performance monitoring. Fundamental input for recovery rate and concentrate production calculations.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which this measurement record was ingested into the Databricks Lakehouse Silver Layer from the OSIsoft PI System source. Distinct from the measurement_timestamp (when the physical measurement occurred). Used for data pipeline latency monitoring, SLA tracking, and identifying late-arriving data in streaming ingestion pipelines.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAlarmActive rdf:type rdf:Property ;
    rdfs:label 'Is Alarm Active' ;
    rdfs:comment 'Boolean flag indicating whether an active process alarm condition existed at this measurement point at the time of measurement (True = alarm active; False = no alarm). Sourced from the SCADA/DCS alarm management system via OSIsoft PI System event frames. Enables alarm frequency analysis, process stability assessment, and operator response time reporting.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInControl rdf:type rdf:Property ;
    rdfs:label 'Is In Control' ;
    rdfs:comment 'Boolean flag indicating whether the measurement value was within the defined process control limits (alarm_low_limit to alarm_high_limit) at the time of measurement (True = in control; False = out of control). Supports Statistical Process Control (SPC) analysis, process stability KPIs, and automated metallurgical mass balance quality gates.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:massFlowRateTHr rdf:type rdf:Property ;
    rdfs:label 'Mass Flow Rate T Hr' ;
    rdfs:comment 'Mass flow rate of dry solids in the slurry stream, expressed in dry metric tonnes per hour (t/hr). Calculated from volumetric flow rate and slurry density adjusted for percent solids. Primary throughput metric for metallurgical accounting, LOM (Life of Mine) plan tracking, and production reporting against targets.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPointDescription rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Description' ;
    rdfs:comment 'Human-readable description of the physical location and purpose of the measurement point within the processing circuit (e.g., \'SAG Mill 01 Discharge Slurry\', \'Flotation Feed Box\', \'CIL Tank 3 Overflow\'). Supports operator interpretation and alarm investigation.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classification of the physical parameter being measured at this process point. Identifies which slurry property this record represents, enabling filtering and aggregation by parameter type across the processing circuit. Aligns with PI tag attribute classification in the OSIsoft PI System. [ENUM-REF-CANDIDATE: density|percent_solids|flow_rate|ph|temperature|viscosity|conductivity|particle_size|mass_flow — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Date' ;
    rdfs:comment 'The scheduled date for the next calibration of the instrument or sensor, in yyyy-MM-dd format. Used to proactively manage instrument maintenance schedules via Infor EAM and to flag measurements from instruments approaching or past their calibration due date. Supports data quality governance and regulatory compliance for measurement traceability.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opcUaNodeReference rdf:type rdf:Property ;
    rdfs:label 'Opc Ua Node Reference' ;
    rdfs:comment 'The OPC-UA (OPC Unified Architecture) node identifier for the data source that feeds this measurement into the OSIsoft PI System. Provides the source system address for data lineage, integration troubleshooting, and SCADA connectivity management. Format follows OPC-UA NodeId specification (e.g., ns=2;s=SITE.AREA.UNIT.TAG).' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentSolids rdf:type rdf:Property ;
    rdfs:label 'Percent Solids' ;
    rdfs:comment 'Weight percentage of solid material in the slurry, expressed as percent weight-by-weight (%w/w). Derived from slurry density and known ore specific gravity. A key process control parameter for comminution (SAG, HPGR), flotation, and leaching circuits. Typical operating range: 20–75 %w/w depending on circuit type.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'Measured pH of the slurry at the measurement point on the standard pH scale (0–14). Critical process control parameter for flotation (reagent effectiveness), leaching (acid/alkaline conditions), and cyanide destruction circuits. Monitored continuously to ensure optimal mineral recovery and environmental compliance. Typical operating range varies by circuit: flotation 8–11, acid leach 1.5–2.5.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:piTagName rdf:type rdf:Property ;
    rdfs:label 'Pi Tag Name' ;
    rdfs:comment 'The OSIsoft PI System tag identifier (instrument tag name) associated with this measurement point. Serves as the source system natural key enabling traceability back to the PI historian tag configuration and SCADA/OPC-UA data source. Format follows site-specific PI tag naming conventions (e.g., SITE.AREA.UNIT.PARAMETER).' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processAreaCode rdf:type rdf:Property ;
    rdfs:label 'Process Area Code' ;
    rdfs:comment 'Alphanumeric code identifying the functional process area within the mineral processing plant where the measurement was taken (e.g., COMM for comminution, FLOT for flotation, LEACH for leaching, SXEW for SX-EW, THCK for thickening). Supports area-level operational reporting and alarm management.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The unprocessed, unvalidated measurement value as received directly from the OSIsoft PI System historian before any quality filtering, engineering unit conversion, or substitution is applied. Preserved for audit, instrument calibration verification, and data quality investigation. Enables comparison between raw and processed values to detect instrument drift.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleIntervalSeconds rdf:type rdf:Property ;
    rdfs:label 'Sample Interval Seconds' ;
    rdfs:comment 'The configured sampling or scan interval for this PI tag in seconds, indicating how frequently the OSIsoft PI System captures a new measurement value (e.g., 1, 5, 10, 30, 60 seconds). Used to assess data density, identify gaps in time-series data, and configure alarm thresholds appropriately.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensorStatusCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Status Code' ;
    rdfs:comment 'Instrument or sensor status code as reported by the SCADA/OPC-UA system at the time of measurement. Provides granular diagnostic information beyond the data quality flag, including specific fault codes (e.g., COMM_FAIL, RANGE_HI, RANGE_LO, CAL_DUE, OFFLINE, NORMAL). Used for instrument maintenance scheduling via Infor EAM and sensor fault detection analytics. [ENUM-REF-CANDIDATE: NORMAL|COMM_FAIL|RANGE_HI|RANGE_LO|CAL_DUE|OFFLINE|FROZEN|DRIFT — promote to reference product]' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The natural key or record identifier from the OSIsoft PI System historian for this specific measurement event (e.g., PI event frame ID or compressed archive record reference). Enables exact traceability back to the source historian record for data lineage, audit, and reconciliation purposes in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionReason rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason' ;
    rdfs:comment 'Reason code explaining why a measurement value was substituted when data_quality_flag = \'substituted\'. Values: \'manual_entry\' = operator manually entered value; \'interpolated\' = value interpolated from adjacent timestamps; \'last_known_good\' = previous valid value carried forward; \'calculated\' = derived from related measurements; \'not_applicable\' = no substitution occurred. Required for metallurgical mass balance audit trail and data governance compliance.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viscosityCp rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cp' ;
    rdfs:comment 'Dynamic viscosity of the slurry at the measurement point, expressed in centipoise (cP). Affects pump performance, pipeline transport efficiency, and flotation cell hydrodynamics. Elevated viscosity can indicate high clay content or incorrect percent solids, impacting comminution and separation efficiency.' ;
    rdfs:domain ind:SlurryMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sxewEventId rdf:type rdf:Property ;
    rdfs:label 'Sxew Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each SX-EW operational event record in the silver layer lakehouse. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acidConcentrationGl rdf:type rdf:Property ;
    rdfs:label 'Acid Concentration Gl' ;
    rdfs:comment 'Sulphuric acid concentration in the electrowinning electrolyte, measured in grams per litre (g/L). Acid balance is critical for cathode quality, current efficiency, and prevention of anode corrosion in the EW tankhouse.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aqueousFeedGradeGl rdf:type rdf:Property ;
    rdfs:label 'Aqueous Feed Grade Gl' ;
    rdfs:comment 'Copper concentration in the aqueous feed (pregnant leach solution, PLS) entering the solvent extraction circuit, measured in grams per litre (g/L). Determines the extraction circuit loading and directly influences cathode production output.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cathodeGradePct rdf:type rdf:Property ;
    rdfs:label 'Cathode Grade Pct' ;
    rdfs:comment 'Purity of the copper cathode produced, expressed as a percentage of copper content. LME Grade A copper cathode requires ≥99.99% Cu. Used for product quality certification, sales contract compliance, and LME registration eligibility.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cathodeProductionKg rdf:type rdf:Property ;
    rdfs:label 'Cathode Production Kg' ;
    rdfs:comment 'Total mass of copper cathode produced during the shift, measured in kilograms. The primary production output metric for the SX-EW circuit, used for daily production reporting, LOM plan reconciliation, and sales volume tracking.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cathodeQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Cathode Quality Grade' ;
    rdfs:comment 'Quality classification of copper cathode produced during the shift. \'LME_Grade_A\' indicates product meets London Metal Exchange Grade A specification (≥99.99% Cu); \'off_spec\' indicates product below LME standard but saleable; \'rejected\' indicates product not suitable for sale.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cathodesHarvested rdf:type rdf:Property ;
    rdfs:label 'Cathodes Harvested' ;
    rdfs:comment 'Number of individual copper cathode sheets harvested (stripped) from the electrowinning cells during the shift. Used for tankhouse productivity tracking, cathode cycle time management, and inventory reconciliation.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellVoltageV rdf:type rdf:Property ;
    rdfs:label 'Cell Voltage V' ;
    rdfs:comment 'Average operating voltage across the electrowinning cells during the shift, measured in volts (V). Used to monitor energy efficiency, detect anode/cathode fouling, and calculate specific energy consumption per tonne of copper produced.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellsOperating rdf:type rdf:Property ;
    rdfs:label 'Cells Operating' ;
    rdfs:comment 'Number of electrowinning cells in active operation during the shift. Used to calculate effective circuit capacity, monitor cell availability, and assess impact of cell outages on production.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellsTotal rdf:type rdf:Property ;
    rdfs:label 'Cells Total' ;
    rdfs:comment 'Total number of electrowinning cells installed in the circuit (nameplate capacity). Used as the denominator for cell availability calculations and Overall Equipment Effectiveness (OEE) reporting.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitDowntimeMin rdf:type rdf:Property ;
    rdfs:label 'Circuit Downtime Min' ;
    rdfs:comment 'Total unplanned and planned downtime for the SX-EW circuit during the shift, measured in minutes. Used for Overall Equipment Effectiveness (OEE) calculation, maintenance planning via Infor EAM, and production loss reporting.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentDensityAm2 rdf:type rdf:Property ;
    rdfs:label 'Current Density Am2' ;
    rdfs:comment 'Electrical current density applied across the electrowinning cathode surface, measured in amperes per square metre (A/m²). A primary electrowinning process control parameter governing copper deposition rate, cathode quality, and energy consumption.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentEfficiencyPct rdf:type rdf:Property ;
    rdfs:label 'Current Efficiency Pct' ;
    rdfs:comment 'Ratio of actual copper deposited to the theoretical copper that should have been deposited based on Faraday\'s Law, expressed as a percentage. A key electrowinning performance indicator; values below target indicate short-circuiting, impurity effects, or electrolyte imbalance.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electrolyteTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Electrolyte Temperature C' ;
    rdfs:comment 'Operating temperature of the electrowinning electrolyte during the shift, measured in degrees Celsius (°C). Temperature affects copper ion mobility, current efficiency, and cathode surface quality. Monitored via OSIsoft PI System.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impurityFeMgl rdf:type rdf:Property ;
    rdfs:label 'Impurity Fe Mgl' ;
    rdfs:comment 'Concentration of iron (Fe) impurity in the electrowinning electrolyte, measured in milligrams per litre (mg/L). Elevated iron levels reduce current efficiency and degrade cathode surface quality. Monitored via LabWare LIMS shift samples.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impurityMnMgl rdf:type rdf:Property ;
    rdfs:label 'Impurity Mn Mgl' ;
    rdfs:comment 'Concentration of manganese (Mn) impurity in the electrowinning electrolyte, measured in milligrams per litre (mg/L). Manganese causes anode passivation and cathode surface defects. Tracked via LabWare LIMS for electrolyte bleed management.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomPlanCathodeKg rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Cathode Kg' ;
    rdfs:comment 'Planned cathode copper production target for the shift as defined in the Life of Mine (LOM) plan or short-term production schedule. Used for variance analysis between actual and planned production, and for LOM plan tracking.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicCuConcentrationGl rdf:type rdf:Property ;
    rdfs:label 'Organic Cu Concentration Gl' ;
    rdfs:comment 'Concentration of copper in the organic (solvent) phase of the solvent extraction circuit, measured in grams per litre (g/L). A key process control parameter indicating the loading efficiency of the organic extractant (e.g., LIX reagent). Sourced from OSIsoft PI System online analysers or LabWare LIMS shift samples.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicFlowRateM3h rdf:type rdf:Property ;
    rdfs:label 'Organic Flow Rate M3h' ;
    rdfs:comment 'Volumetric flow rate of the organic solvent phase circulating through the solvent extraction mixer-settlers, measured in cubic metres per hour (m³/h). Used to control the aqueous-to-organic (A:O) ratio and optimise copper extraction efficiency.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plsFlowRateM3h rdf:type rdf:Property ;
    rdfs:label 'Pls Flow Rate M3h' ;
    rdfs:comment 'Volumetric flow rate of the pregnant leach solution (PLS) entering the solvent extraction circuit, measured in cubic metres per hour (m³/h). Controls the aqueous-to-organic (A:O) ratio and extraction circuit residence time.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raffinateGradeGl rdf:type rdf:Property ;
    rdfs:label 'Raffinate Grade Gl' ;
    rdfs:comment 'Copper concentration in the raffinate (barren aqueous solution) exiting the solvent extraction circuit after copper has been extracted, measured in grams per litre (g/L). Used to calculate extraction efficiency and monitor copper losses to raffinate.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionLm3 rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Lm3' ;
    rdfs:comment 'Volume of organic extractant reagent (e.g., LIX 984N or equivalent) consumed per cubic metre of pregnant leach solution processed, measured in litres per cubic metre (L/m³). Used for reagent cost tracking, OPEX reporting, and supply chain planning via Pronto Xi.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificEnergyKwhT rdf:type rdf:Property ;
    rdfs:label 'Specific Energy Kwh T' ;
    rdfs:comment 'Electrical energy consumed per tonne of copper cathode produced, measured in kilowatt-hours per tonne (kWh/t Cu). A key OPEX and sustainability metric for the electrowinning circuit, used for energy cost allocation and carbon footprint reporting.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spentElectrolyteGradeGl rdf:type rdf:Property ;
    rdfs:label 'Spent Electrolyte Grade Gl' ;
    rdfs:comment 'Copper concentration in the spent electrolyte returning from the electrowinning cells to the stripping circuit, measured in grams per litre (g/L). The difference between strip solution grade and spent electrolyte grade represents the copper deposited per pass.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stripSolutionGradeGl rdf:type rdf:Property ;
    rdfs:label 'Strip Solution Grade Gl' ;
    rdfs:comment 'Copper concentration in the electrolyte strip solution (advance electrolyte) fed to the electrowinning tankhouse, measured in grams per litre (g/L). Directly controls cathode deposition rate and current efficiency in the EW circuit.' ;
    rdfs:domain ind:SxewEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOperationEventId rdf:type rdf:Property ;
    rdfs:label 'Unit Operation Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each unit operation event record in the mineral processing domain. Primary key for the silver-layer lakehouse table.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentDensityAPerM2 rdf:type rdf:Property ;
    rdfs:label 'Current Density A Per M2' ;
    rdfs:comment 'Electrical current density applied in electrowinning (EW) cells during SX-EW unit operations, expressed in A/m². Type-specific parameter for electrowinning operations. Controls cathode deposition rate, product purity, and specific energy consumption.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Human-readable externally-known business identifier for this unit operation event, used in metallurgical reports, process control logs, and MES reconciliation. Format: UOE-YYYY-NNNNNN.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedTonnageDryT rdf:type rdf:Property ;
    rdfs:label 'Feed Tonnage Dry T' ;
    rdfs:comment 'Dry metric tonnes of ore or material fed to the unit operation during the event period. Core throughput metric for metallurgical accounting and LOM plan variance analysis. Sourced from belt scale or flow meter readings in OSIsoft PI System.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLomPlanPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Lom Plan Period' ;
    rdfs:comment 'Indicates whether this unit operation event falls within an active LOM (Life of Mine) plan period with defined targets, enabling filtering of events for plan vs actual variance reporting.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leachSolutionGradeGPerL rdf:type rdf:Property ;
    rdfs:label 'Leach Solution Grade G Per L' ;
    rdfs:comment 'Concentration of the target metal in the pregnant leach solution (PLS), expressed in grams per litre. Type-specific parameter for heap, tank, vat, CIL, and CIP leaching operations. Used in leach circuit mass balance and SX-EW feed quality assessment.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomPlanFeedTonnageT rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Feed Tonnage T' ;
    rdfs:comment 'LOM (Life of Mine) plan target for feed tonnage to this unit operation for the corresponding shift/period. Used for variance analysis between actual and planned throughput. Sourced from Deswik or Hexagon MinePlan scheduling outputs.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomPlanRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Lom Plan Recovery Pct' ;
    rdfs:comment 'LOM (Life of Mine) plan target metallurgical recovery percentage for this unit operation and period. Used for variance analysis between actual and planned recovery. Sourced from process design basis and LOM plan assumptions.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mediumDensityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Medium Density Kg Per M3' ;
    rdfs:comment 'Density of the dense medium (ferrosilicon or magnetite suspension) used in Dense Media Separation (DMS) unit operations, expressed in kg/m³. Type-specific parameter for DMS operations. Controls separation cut-point and product quality.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metallurgicalAccountPeriod rdf:type rdf:Property ;
    rdfs:label 'Metallurgical Account Period' ;
    rdfs:comment 'The calendar month period (YYYY-MM) to which this unit operation event is assigned for metallurgical accounting and financial reporting purposes. Used to aggregate shift-level events into monthly mass balance reconciliation reports.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationSubtype rdf:type rdf:Property ;
    rdfs:label 'Operation Subtype' ;
    rdfs:comment 'Detailed sub-classification of the unit operation within its type (e.g., SAG mill, ball mill, HPGR, crusher for comminution; rougher, scavenger, cleaner for flotation; heap, tank, vat, CIL, CIP for leaching; solvent extraction, electrowinning for SX-EW; spirals, shaking tables, jigs for gravity). [ENUM-REF-CANDIDATE: sag_mill|ball_mill|hpgr|crusher|rougher|scavenger|cleaner|heap_leach|tank_leach|vat_leach|cil|cip|solvent_extraction|electrowinning|spirals|shaking_tables|jigs|dense_media_separation|magnetic_separation|thickener|filter — promote to reference product]' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type discriminator identifying the class of mineral processing unit operation for this event. Drives which type-specific attribute groups are populated. [ENUM-REF-CANDIDATE: comminution|flotation|leaching|sx_ew|dms|gravity_separation|magnetic_separation|thickening_dewatering — promote to reference product]' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:p80FeedMicrons rdf:type rdf:Property ;
    rdfs:label 'P80 Feed Microns' ;
    rdfs:comment '80th percentile passing size of the feed material in microns (µm). Primary comminution circuit feed size parameter used to characterise ore hardness, set mill operating conditions, and benchmark against design P80. Applicable to comminution operation types (SAG, ball mill, HPGR, crusher).' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p80ProductMicrons rdf:type rdf:Property ;
    rdfs:label 'P80 Product Microns' ;
    rdfs:comment '80th percentile passing size of the product material in microns (µm) exiting the comminution unit operation. Compared against target grind size to assess liberation efficiency and downstream flotation or leach performance.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantAreaCode rdf:type rdf:Property ;
    rdfs:label 'Plant Area Code' ;
    rdfs:comment 'Alphanumeric code identifying the physical plant area or section within the processing facility where this unit operation is located (e.g., COMM-01 for comminution area 1, FLOT-02 for flotation area 2). Aligns with P&ID area designations.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionKwh rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Kwh' ;
    rdfs:comment 'Total electrical energy consumed by the unit operation during the event period, expressed in kWh. Used in energy cost allocation, OPEX reporting, and carbon footprint calculations. Sourced from power meters via OSIsoft PI System.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productTonnageDryT rdf:type rdf:Property ;
    rdfs:label 'Product Tonnage Dry T' ;
    rdfs:comment 'Dry metric tonnes of product (concentrate, leach solution, or processed material) produced by the unit operation during the event period. Used in metallurgical accounting mass balance calculations.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentDosageGPerT rdf:type rdf:Property ;
    rdfs:label 'Reagent Dosage G Per T' ;
    rdfs:comment 'Total reagent addition rate for the primary reagent in the unit operation, expressed in grams per dry metric tonne of feed. Covers collectors, frothers, depressants (flotation), or lixiviants (leaching). Used in reagent cost tracking and process optimisation.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryDensityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density Kg Per M3' ;
    rdfs:comment 'Density of the slurry (water and ore mixture) in the unit operation, expressed in kg/m³. Critical process control parameter for flotation, leaching, and thickening circuits. Sourced from nuclear density gauges or Coriolis meters via OSIsoft PI System.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsTonnageDryT rdf:type rdf:Property ;
    rdfs:label 'Tailings Tonnage Dry T' ;
    rdfs:comment 'Dry metric tonnes of tailings (gangue and waste material) generated by the unit operation during the event period. Used in mass balance reconciliation, TSF (Tailings Storage Facility) capacity planning, and environmental reporting.' ;
    rdfs:domain ind:UnitOperationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementApprovedVendorMaterialId rdf:type rdf:Property ;
    rdfs:label 'Procurement Approved Vendor Material Id' ;
    rdfs:comment 'Unique identifier for the approved vendor-material commercial relationship record. Primary key for the Approved Vendor List (AVL) at the material level.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'The date when the vendor approval for this material expires. After this date, the vendor may no longer be eligible for procurement unless re-approved.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:comment 'Indicates whether this vendor-material relationship is currently blocked for procurement. When true, purchase orders cannot be created for this combination.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'The reason why this vendor-material relationship is blocked (e.g., quality issues, contract dispute, vendor suspension, price negotiation pending).' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The user ID or name of the person who created this approved vendor-material record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'The standard number of days required for the vendor to deliver this material from order placement to goods receipt. Used for MRP (Material Requirements Planning) and delivery date calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'The International Commercial Terms (Incoterms) code defining the delivery terms and transfer of risk between vendor and buyer for this material (e.g., FOB, CIF, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port specified in the Incoterms agreement (e.g., Port Hedland, Singapore, Perth). Defines the point of delivery or risk transfer.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'The most recent actual purchase price paid for this material from this vendor. Used for price variance analysis and benchmarking.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity that must be ordered from this vendor for this material. Enforced during purchase requisition and order creation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Unit Price' ;
    rdfs:comment 'The negotiated price per unit for this vendor-material combination. Auto-populates purchase order pricing during requisition conversion.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'The planned delivery time in calendar days from order placement to expected goods receipt at the plant. Used for MRP (Material Requirements Planning) run calculations.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred supplier for this material. Used for automatic source determination during requisition conversion to purchase orders.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity unit to which the negotiated unit price applies (e.g., price per 1, per 10, per 100 units). Used in price calculation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'The date until which the negotiated unit price remains valid. After this date, price renegotiation may be required.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'The date from which the negotiated unit price becomes effective. Part of the price validity period.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'The purchasing group responsible for managing this vendor-material relationship. Identifies the buyer or procurement team.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingInfoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Purchasing Info Record Number' ;
    rdfs:comment 'Business identifier for the purchasing information record from SAP S/4HANA MM (ME11/ME12/ME13). Serves as the external reference for this vendor-material relationship.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganisationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organisation Code' ;
    rdfs:comment 'The purchasing organization responsible for this vendor-material relationship. Determines procurement authority and organizational assignment.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListNumber rdf:type rdf:Property ;
    rdfs:label 'Source List Number' ;
    rdfs:comment 'Business identifier for the source list record from SAP S/4HANA MM. Used for traceability to the originating purchasing info record.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceListValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Source List Validity End Date' ;
    rdfs:comment 'The date until which this source list entry remains valid. After this date, the vendor will not be automatically proposed for this material.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceListValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Source List Validity Start Date' ;
    rdfs:comment 'The date from which this source list entry becomes valid for automatic source determination in MRP (Material Requirements Planning) and purchase requisition processing.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardOrderUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Order Unit' ;
    rdfs:comment 'The standard unit of measure in which this material is ordered from this vendor (e.g., TON, KG, EA, M3). Must be compatible with the material base unit.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The vendors own part number or material code for this item. Used for cross-referencing and order communication with the vendor.' ;
    rdfs:domain ind:ProcurementApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_event. Business justification: Contract is awarded as result of sourcing event (RFP, RFT, tender). One sourcing event can result in multiple contracts if multi-award strategy. N:1 relationship (many contracts from one sourcing even' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Initial unit price established at contract inception, before any escalation or de-escalation adjustments.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'High-level classification of goods or services covered by the contract (e.g., explosives, diesel fuel, mining equipment, maintenance services, PPE, laboratory consumables).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique contract identifier used across procurement systems and vendor communications.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract: draft (being prepared), pending_approval (awaiting authorization), approved (authorized but not yet effective), active (in force), suspended (temporarily halted), expired (end date reached), terminated (ended early), closed (completed and archived). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|expired|terminated|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract structure: blanket order (quantity-based), outline agreement (value-based), schedule agreement (delivery schedule), service contract (time and materials), framework agreement (multi-year umbrella), or call-off contract (release-based).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedQuantity rdf:type rdf:Property ;
    rdfs:label 'Contracted Quantity' ;
    rdfs:comment 'Total quantity of goods or service units committed under the contract. Nullable for value-based contracts without quantity commitments.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:latestAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Amendment Date' ;
    rdfs:comment 'Date when the most recent contract amendment was executed. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latestAmendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Latest Amendment Description' ;
    rdfs:comment 'Summary of changes made in the most recent amendment (e.g., price adjustment, scope extension, volume change, term extension).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latestAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Latest Amendment Number' ;
    rdfs:comment 'Identifier of the most recent contract amendment. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Largest quantity that can be ordered under the contract in a single purchase order release. Nullable if no upper limit applies.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the contract owner for escalations and contract-related communications.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the procurement professional or contract manager responsible for this contract.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceKpiDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Kpi Description' ;
    rdfs:comment 'Narrative description of the performance metrics and service level agreements the vendor must meet under the contract (e.g., on-time delivery rate, quality acceptance rate, response time).' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Price Effective Date' ;
    rdfs:comment 'Date from which the current pricing schedule becomes applicable.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Contractual terms governing automatic price increases based on index movements, cost changes, or time-based triggers.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Price Expiry Date' ;
    rdfs:comment 'Date when the current pricing schedule ceases to be valid. Nullable for indefinite pricing.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Price Review Frequency' ;
    rdfs:comment 'Scheduled interval for formal price review and renegotiation as stipulated in the contract.' ;
    rdfs:domain ind:ProcurementContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Mechanism governing contract pricing: fixed (locked price), CPI-indexed (Consumer Price Index escalation), commodity-indexed (linked to commodity benchmark), cost-plus (cost recovery plus margin), market-rate (prevailing market price at time of order).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer or procurement team code responsible for day-to-day contract administration and purchase order releases.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Organizational unit responsible for negotiating and managing the contract (e.g., corporate procurement, regional procurement, site-level procurement).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Renewal Indicator' ;
    rdfs:comment 'Flag indicating whether the contract includes automatic renewal provisions (True) or requires explicit renegotiation (False).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Period Days' ;
    rdfs:comment 'Number of days before contract expiry that renewal or termination notice must be provided to the vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the contract was terminated early. Nullable if contract was not terminated.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required to terminate the contract before its natural expiry date.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business justification or cause for early contract termination (e.g., vendor non-performance, scope change, mine closure, cost reduction initiative).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Maximum monetary value committed under the contract over its full term. Used for budget tracking and contract compliance monitoring.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key for the contract amendment entity.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative describing the specific changes being made to the parent contract. Includes business rationale, scope of change, and impact summary for audit trail and governance.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentInitiatorEmail rdf:type rdf:Property ;
    rdfs:label 'Amendment Initiator Email' ;
    rdfs:comment 'Corporate email address of the amendment initiator for communication and workflow notifications. Business contact information classified as confidential.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentInitiatorName rdf:type rdf:Property ;
    rdfs:label 'Amendment Initiator Name' ;
    rdfs:comment 'Full name of the employee or procurement professional who created and submitted this amendment request. Provides accountability for change initiation.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential amendment identifier within the parent contract lifecycle. Typically formatted as contract_number-A01, A02, etc. to maintain traceability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the contract amendment. Tracks progression through approval workflow from initial draft to final execution or cancellation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the contractual change being made. Determines approval workflow and commercial impact assessment requirements. [ENUM-REF-CANDIDATE: price_adjustment|scope_extension|volume_change|term_extension|payment_terms_revision|specification_change|delivery_schedule_revision|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentValueDelta rdf:type rdf:Property ;
    rdfs:label 'Amendment Value Delta' ;
    rdfs:comment 'Net change in contract value resulting from this amendment. Positive values indicate contract value increase, negative values indicate reduction. Critical for budget impact assessment and Capital Expenditure (CAPEX) or Operating Expenditure (OPEX) tracking.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentReference rdf:type rdf:Property ;
    rdfs:label 'Attachment Reference' ;
    rdfs:comment 'Document management system reference or file path to supporting documentation for this amendment. May include revised specifications, vendor quotes, or approval memos.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary business driver or trigger for the contract amendment. Used for trend analysis and procurement governance reporting. [ENUM-REF-CANDIDATE: market_conditions|scope_creep|regulatory_requirement|vendor_request|cost_optimization|quality_issue|force_majeure|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal department completed their review of the amendment. Null if legal review is not required or has not yet been completed.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewerName rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Name' ;
    rdfs:comment 'Full name of the legal counsel who reviewed and cleared this amendment. Provides accountability for legal risk assessment.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalContractValue rdf:type rdf:Property ;
    rdfs:label 'Original Contract Value' ;
    rdfs:comment 'Total monetary value of the parent contract before this amendment. Baseline for calculating commercial impact and value delta.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDelta rdf:type rdf:Property ;
    rdfs:label 'Quantity Delta' ;
    rdfs:comment 'Net change in contracted quantity or volume resulting from this amendment. Positive for increases, negative for reductions. Used for supply chain planning and inventory management.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedContractValue rdf:type rdf:Property ;
    rdfs:label 'Revised Contract Value' ;
    rdfs:comment 'Total contract value after applying this amendment. Calculated as original contract value plus amendment value delta. Represents the new committed procurement spend.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised End Date' ;
    rdfs:comment 'New contract expiration date after applying term extension. Null if amendment does not modify contract duration. Critical for Life of Mine (LOM) planning and procurement forecasting.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Term Extension Days' ;
    rdfs:comment 'Number of calendar days by which the contract validity period is extended. Null if amendment does not affect contract duration. Used to calculate revised end date.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Acceptance Date' ;
    rdfs:comment 'Date when the vendor formally accepted or signed the amendment. Null if vendor acceptance is not required or has not yet been received.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAcceptanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Acceptance Required Flag' ;
    rdfs:comment 'Indicates whether this amendment requires formal acceptance or counter-signature from the vendor. True for bilateral amendments, false for unilateral variations permitted under contract terms.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery schedule record. Primary key for the delivery schedule entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliverySchedule .

ind:purchaseOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order_line. Business justification: Delivery schedules are call-offs against specific purchase order line items. The delivery_schedule table already has purchase_order_id (header FK) but no FK to purchase_order_line. Adding purchase_ord' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrderLine .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date on which the material was delivered and goods receipt was posted. Used for supplier performance evaluation and schedule adherence tracking.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callOffDate rdf:type rdf:Property ;
    rdfs:label 'Call Off Date' ;
    rdfs:comment 'Date on which the call-off or release was issued to the vendor. Marks the formal request for delivery under the blanket agreement.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calledOffQuantity rdf:type rdf:Property ;
    rdfs:label 'Called Off Quantity' ;
    rdfs:comment 'Quantity of material released or called off from the blanket purchase order for this specific delivery schedule line. Represents the amount requested from the supplier for this delivery.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed by the vendor for delivery on the planned delivery date. May differ from called-off quantity if supplier cannot fulfill the full request.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual quantity of material delivered and received against this schedule line. Updated upon goods receipt posting.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the specific delivery destination for this schedule line (mine site, warehouse, port facility, or storage location). Used for logistics planning and routing.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationName rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Name' ;
    rdfs:comment 'Descriptive name of the delivery destination. Provides human-readable context for the delivery location.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-provided delivery note or packing slip number accompanying the shipment. Used for cross-referencing and reconciliation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Percent' ;
    rdfs:comment 'Acceptable percentage variance (over or under) from the called-off quantity that the supplier may deliver without requiring approval. Used for managing supply flexibility.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the scheduled material is classified as hazardous or dangerous goods. Triggers special handling and compliance requirements.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'Remaining quantity yet to be delivered against this schedule line. Calculated as called-off quantity minus delivered quantity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Scheduled date on which the material is expected to be delivered to the designated location. Used for planning and coordination of mining operations and inventory management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Indicator' ;
    rdfs:comment 'Business priority level assigned to this delivery schedule. Used for expediting critical materials and managing supplier attention.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number within the parent purchase order or schedule agreement identifying this specific delivery schedule line. Used for ordering and referencing individual schedule lines within a blanket agreement.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or comments related to this delivery schedule. Used for capturing additional context, exceptions, or coordination details.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transport Reference Number' ;
    rdfs:comment 'Shipment tracking number or transport order reference for this delivery. Used for logistics tracking and coordination.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Framework Agreement Id' ;
    rdfs:comment 'Primary key for framework_agreement' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrameworkAgreement .

ind:primaryFrameworkContractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Framework Contract Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which vendor performance under this framework agreement is formally reviewed and documented.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'Mechanism by which pricing is determined under this framework agreement. Fixed price remains constant, variable price adjusts per order, cost-plus adds margin to vendor cost, index-linked ties to commodity index, market-based uses spot rates, tiered pricing varies by volume.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Contract Quantity' ;
    rdfs:comment 'Maximum quantity of goods or services committed under this framework agreement for quantity contracts. Nullable for value contracts or service agreements without fixed quantities.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightOrderId rdf:type rdf:Property ;
    rdfs:label 'Freight Order Id' ;
    rdfs:comment 'Unique identifier for the freight order. Primary key for the freight order entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightOrder .

ind:originWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to procurement.warehouse_location. Business justification: Freight orders have origin locations that should reference warehouse_location master. Currently freight_order has origin_location_code and origin_location_name as denormalized strings. Creating this F' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the logistics carrier or freight forwarder responsible for transporting the cargo.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the freight arrived at the destination location.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the freight departed from the origin location.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of lading number issued by the carrier for sea freight, serving as receipt and contract of carriage. Null for non-sea transport.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoDescription rdf:type rdf:Property ;
    rdfs:label 'Cargo Description' ;
    rdfs:comment 'Detailed textual description of the cargo being transported, including packaging and handling requirements.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'Date when customs clearance was completed for international freight. Null if not applicable or not yet cleared.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Status of customs clearance for international freight movements: not-required, pending, cleared, held, or rejected.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'UN dangerous goods classification code (e.g., 1.1, 3, 8) if cargo contains hazardous materials. Null if not dangerous goods.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the cargo contains dangerous goods requiring special handling and regulatory compliance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Un Number' ;
    rdfs:comment 'Four-digit UN number identifying the dangerous goods substance (e.g., UN1203 for gasoline). Null if not dangerous goods.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteReference rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Reference' ;
    rdfs:comment 'Reference number of the delivery note or goods receipt document associated with this freight order.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationName rdf:type rdf:Property ;
    rdfs:label 'Destination Location Name' ;
    rdfs:comment 'Full name of the destination location for the freight movement.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of freight movement: inbound (vendor to site), outbound (site to customer), or inter-site (between mining sites).' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned or scheduled date when the freight is expected to arrive at the destination location.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Expected Departure Date' ;
    rdfs:comment 'Planned or scheduled date when the freight is expected to depart from the origin location.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight cost for this shipment in the specified currency.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the freight cost amount (e.g., USD, AUD, EUR).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Order Number' ;
    rdfs:comment 'Business-facing unique freight order number used for tracking and reference across logistics operations.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRatePerTonne rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Per Tonne' ;
    rdfs:comment 'Freight rate charged per metric tonne of cargo. Applicable primarily to bulk commodity shipments.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightStatus rdf:type rdf:Property ;
    rdfs:label 'Freight Status' ;
    rdfs:comment 'Current lifecycle status of the freight order: planned, booked, in-transit, arrived, delivered, or cancelled.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Tonnes' ;
    rdfs:comment 'Total gross weight of the cargo including packaging and containers, measured in metric tonnes.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laycanEndDate rdf:type rdf:Property ;
    rdfs:label 'Laycan End Date' ;
    rdfs:comment 'End date of the laycan period (latest date vessel can arrive for loading) for sea freight. Null for non-sea transport.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laycanStartDate rdf:type rdf:Property ;
    rdfs:label 'Laycan Start Date' ;
    rdfs:comment 'Start date of the laycan period (earliest date vessel can arrive for loading) for sea freight. Null for non-sea transport.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadedQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Loaded Quantity Tonnes' ;
    rdfs:comment 'Actual quantity of commodity loaded onto the vessel, measured in metric tonnes. Applicable to sea freight.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Net Weight Tonnes' ;
    rdfs:comment 'Net weight of the cargo excluding packaging and containers, measured in metric tonnes.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominatedQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Nominated Quantity Tonnes' ;
    rdfs:comment 'Quantity of commodity nominated or planned for loading onto the vessel, measured in metric tonnes. Applicable to sea freight.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingReference rdf:type rdf:Property ;
    rdfs:label 'Tracking Reference' ;
    rdfs:comment 'Carrier-provided tracking reference number for real-time shipment visibility and status updates.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselName rdf:type rdf:Property ;
    rdfs:label 'Vessel Name' ;
    rdfs:comment 'Name of the vessel for sea freight movements. Null for non-sea transport modes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicMetres rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Metres' ;
    rdfs:comment 'Total volume of the cargo measured in cubic metres.' ;
    rdfs:domain ind:FreightOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voyageNumber rdf:type rdf:Property ;
    rdfs:label 'Voyage Number' ;
    rdfs:comment 'Voyage or sailing number for sea freight movements. Null for non-sea transport modes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Unique identifier for the goods issue transaction. Primary key for the goods issue record.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Outbound delivery document number for stock transport orders. Links the goods issue to the logistics execution document.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsRecipient rdf:type rdf:Property ;
    rdfs:label 'Goods Recipient' ;
    rdfs:comment 'Name of the person or organizational unit receiving the material. Used for accountability and tracking.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text notes or comments entered at the material document header level. Provides additional context for the transaction.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Item' ;
    rdfs:comment 'Line item number within the material document. Represents the sequence of individual material movements within a single document.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year in which the material document was posted. Part of the compound key in SAP along with material document number.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'Single-character indicator that further classifies the movement (e.g., B for goods movement for purchase order, F for production order, L for delivery).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Code indicating the business reason for the goods issue (e.g., planned maintenance, breakdown repair, operational consumption, scrapping due to damage).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPlantCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Code' ;
    rdfs:comment 'Four-character code identifying the destination mine site or plant for inter-plant transfers (movement type 301). Null for consumption issues.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Code' ;
    rdfs:comment 'Four-character code identifying the destination storage location for inter-storage-location transfers (movement type 311). Null for consumption issues.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationItem rdf:type rdf:Property ;
    rdfs:label 'Reservation Item' ;
    rdfs:comment 'Line item number within the reservation document.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Material reservation number that pre-allocated the stock for this issue. Links the goods issue to the planning document.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalMovementType rdf:type rdf:Property ;
    rdfs:label 'Reversal Movement Type' ;
    rdfs:comment 'Movement type used for the reversal transaction (e.g., 202 reverses 201, 262 reverses 261). Populated only if the transaction has been reversed.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'Single-character code indicating special stock categories (e.g., E for sales order stock, Q for project stock, K for consignment stock).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Physical location or area within the receiving site where the material is delivered (e.g., workshop bay, crusher station, ROM pad).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Procurement Goods Receipt Id' ;
    rdfs:comment 'Primary key for goods_receipt' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementGoodsReceipt .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to procurement.inbound_delivery. Business justification: Goods receipt records warehouse acceptance of materials from an inbound delivery. One inbound delivery can result in multiple goods receipts if received in batches. N:1 relationship (many GRs per deli' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Reference number of the certificate of analysis provided by the vendor or generated by the laboratory. Documents quality specifications and test results for the received material.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'The current lifecycle status of the goods receipt transaction. Posted indicates successful inventory update; reversed indicates cancellation; pending inspection indicates awaiting quality clearance; completed indicates full processing including invoice verification.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this goods receipt transaction in the ERP (Enterprise Resource Planning) system. Used for audit trail and three-way match in invoice verification.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Gr Document Year' ;
    rdfs:comment 'The fiscal year in which the goods receipt document was posted. Used in combination with document number for unique identification in SAP systems.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Line Item Number' ;
    rdfs:comment 'The line item sequence number within the goods receipt document. Identifies individual material lines when multiple items are received in a single transaction.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'The total weight of the received shipment including packaging and containers. Used for freight reconciliation and logistics tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'The unique identifier for the quality inspection lot created for this goods receipt. Links to laboratory sample management and assay results in LIMS.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the material document. Identifies individual material movements within a single goods receipt document.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'The weight of the received materials excluding packaging and containers. Used for inventory valuation and yield calculations in mineral processing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received materials must undergo quality inspection before being released for unrestricted use. When true, materials are placed in quality inspection stock pending LIMS (Laboratory Information Management System) assay results.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity originally ordered on the purchase order line. Used to calculate delivery variance and over/under delivery tolerance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The physical quantity of material received and accepted at the storage location. This quantity updates inventory levels and is used in the three-way match against purchase order quantity and invoice quantity.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptCondition rdf:type rdf:Property ;
    rdfs:label 'Receipt Condition' ;
    rdfs:comment 'Condition assessment of the goods upon physical receipt. Indicates whether materials were received in acceptable condition or if there were issues such as damage or quantity discrepancies.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The actual date when the physical goods were received at the mine site, warehouse, or processing plant. Used for delivery performance tracking.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingPersonName rdf:type rdf:Property ;
    rdfs:label 'Receiving Person Name' ;
    rdfs:comment 'The name of the warehouse or stores personnel who physically accepted and verified the delivered goods. Used for accountability and audit trail.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'The inventory status category of the received goods. Unrestricted stock is available for use; quality inspection stock awaits testing; blocked stock cannot be used; restricted stock has limited usage.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeight rdf:type rdf:Property ;
    rdfs:label 'Tare Weight' ;
    rdfs:comment 'The weight of packaging, containers, or transport equipment. Calculated as gross weight minus net weight.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total value of the goods receipt in the local currency. Used for inventory valuation and financial accounting. Calculated as quantity received multiplied by material price.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Batch Number' ;
    rdfs:comment 'The batch or lot number assigned by the vendor to the delivered materials. Used for traceability back to the suppliers production records and quality certificates.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'The unit in which weights are measured (e.g., TON for tonnes, KG for kilograms, LB for pounds). Must be consistent across gross, net, and tare weights.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Register Id' ;
    rdfs:comment 'Unique identifier for the hazardous material register record.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHazmatSupplyMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazmat Supply Material Master Id' ;
    rdfs:comment 'Foreign key reference to the material master record for this hazardous material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:tertiaryHazmatMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hazmat Material Master Id' ;
    rdfs:comment 'FK to procurement.material_master' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:dangerousGoodsLicenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Licence Expiry Date' ;
    rdfs:comment 'The expiry date of the dangerous goods licence.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dangerousGoodsLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Licence Number' ;
    rdfs:comment 'The regulatory licence number authorizing the storage and handling of dangerous goods at this site.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure Reference' ;
    rdfs:comment 'Reference to the documented emergency response procedure or Standard Operating Procedure (SOP) for incidents involving this hazardous material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosivesLicenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Explosives Licence Expiry Date' ;
    rdfs:comment 'The expiry date of the explosives licence, after which storage and handling is not permitted.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:explosivesLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Explosives Licence Number' ;
    rdfs:comment 'The regulatory licence number authorizing the storage and handling of explosives at this site.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDivision rdf:type rdf:Property ;
    rdfs:label 'Hazard Division' ;
    rdfs:comment 'The subdivision within the hazard class that further categorizes the type of hazard (e.g., 1.1, 1.2, 1.3 for explosives).' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazchemCode rdf:type rdf:Property ;
    rdfs:label 'Hazchem Code' ;
    rdfs:comment 'The emergency action code used by emergency services to identify appropriate response procedures for the hazardous material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'The operational status of this hazardous material in the supply chain inventory.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPermittedStorageQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Permitted Storage Quantity' ;
    rdfs:comment 'The maximum quantity of this hazardous material that is permitted to be stored at the site under regulatory licence conditions.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'The packing group indicating the degree of danger: I (high danger), II (medium danger), III (low danger).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'The current regulatory compliance status of this hazardous material registration.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Contact' ;
    rdfs:comment 'The contact phone number or email of the responsible person for emergency situations.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'The name of the person responsible for managing and overseeing this hazardous material at the site.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Use Flag' ;
    rdfs:comment 'Indicates whether the use of this hazardous material is restricted to specific operations or requires special authorization.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedUseReason rdf:type rdf:Property ;
    rdfs:label 'Restricted Use Reason' ;
    rdfs:comment 'Explanation of why the material is restricted, including regulatory or operational reasons.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCompatibilityGroup rdf:type rdf:Property ;
    rdfs:label 'Storage Compatibility Group' ;
    rdfs:comment 'The compatibility group code that determines which hazardous materials can be stored together safely (e.g., explosives compatibility groups A-S).' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Storage Quantity Unit' ;
    rdfs:comment 'The unit of measure for the maximum permitted storage quantity (e.g., KG for kilograms, L for litres, T for tonnes).' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'The actual date when the delivery arrived at the destination plant. Null if delivery has not yet arrived. Used for performance tracking and variance analysis.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerNumber rdf:type rdf:Property ;
    rdfs:label 'Container Number' ;
    rdfs:comment 'The ISO standard container identification number for containerized sea freight. Format: 4 letters (owner code) + 7 digits.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'The official customs declaration reference number for international shipments. Used for compliance tracking and audit.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsDeclarationReference rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Declaration Reference' ;
    rdfs:comment 'Reference number to the dangerous goods declaration document if the delivery contains hazardous materials. Required for compliance with transport safety regulations.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'General notes and comments related to this delivery. May include vendor remarks, carrier observations, or internal receiving notes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'The business priority assigned to this delivery. Critical deliveries may contain materials needed for urgent production or maintenance activities.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the inbound delivery. Tracks progression from planning through final goods receipt. [ENUM-REF-CANDIDATE: planned|dispatched|in_transit|arrived|goods_received|cancelled|delayed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPlantCode rdf:type rdf:Property ;
    rdfs:label 'Destination Plant Code' ;
    rdfs:comment 'The mine site or processing plant code where the materials are to be received. Aligns with SAP plant master data.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Completed Flag' ;
    rdfs:comment 'Indicates whether the goods receipt process has been completed in the system. True when all items have been received and posted to inventory.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'The International Commercial Terms code defining the responsibilities and risk transfer point between vendor and buyer. Common mining terms include FOB (Free on Board) and CIF (Cost Insurance and Freight).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'The security seal number applied to the container or truck. Used to verify that the shipment has not been tampered with during transit.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on delivery urgency and consolidation strategy.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'The total gross weight of the delivery including packaging and pallets, measured in kilograms. Used for freight cost calculation and logistics planning.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'The net weight of the materials excluding packaging, measured in kilograms. Represents the actual usable material weight.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'The total volumetric space occupied by the delivery, measured in cubic meters. Used for transport capacity planning and freight cost calculation.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryBalanceId rdf:type rdf:Property ;
    rdfs:label 'Inventory Balance Id' ;
    rdfs:comment 'Unique identifier for the inventory balance record.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Quantity' ;
    rdfs:comment 'Quantity of material blocked from use due to quality issues, damage, or other restrictions.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countCycleCode rdf:type rdf:Property ;
    rdfs:label 'Count Cycle Code' ;
    rdfs:comment 'Cycle count assignment code indicating the frequency category for this material and location.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countFrequencyCategory rdf:type rdf:Property ;
    rdfs:label 'Count Frequency Category' ;
    rdfs:comment 'Classification of count frequency based on material criticality and ABC analysis, determining how often physical counts are performed. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|abc_a|abc_b|abc_c — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual quantity counted during the physical inventory count.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitStockQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Stock Quantity' ;
    rdfs:comment 'Quantity of material currently in transit between storage locations or plants.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Count Date' ;
    rdfs:comment 'Date when the most recent physical inventory count was performed for this material and location.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Issue Date' ;
    rdfs:comment 'Date of the most recent goods issue transaction that decreased stock at this location.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastGoodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Receipt Date' ;
    rdfs:comment 'Date of the most recent goods receipt transaction that increased stock at this location.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Business identifier for the material, typically the SAP material number or internal SKU.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevelQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level Quantity' ;
    rdfs:comment 'Maximum allowable stock level for the material at this location to prevent overstocking.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalInventoryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Document Number' ;
    rdfs:comment 'Document number of the most recent physical inventory count for this material and location.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Status of the physical inventory count posting to the general ledger and material ledger.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Stock Quantity' ;
    rdfs:comment 'Quantity of material currently under quality inspection and not yet released for use.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Flag' ;
    rdfs:comment 'Indicates whether a recount was required due to significant variance or count discrepancy.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock maintained to protect against demand variability and supply disruptions.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Timestamp when this inventory balance snapshot was captured, enabling historical trend analysis.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Stock Accuracy Percentage' ;
    rdfs:comment 'Calculated stock accuracy percentage for this material and location, used for inventory KPI reporting.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current operational status of the stock based on availability and business rules.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantityAtCount rdf:type rdf:Property ;
    rdfs:label 'System Quantity At Count' ;
    rdfs:comment 'System-recorded quantity at the time of the physical inventory count, used for variance calculation.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total monetary value of all stock at this location, calculated using standard cost or moving average price.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrestrictedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Stock Quantity' ;
    rdfs:comment 'Quantity of material available for unrestricted use and consumption in operations.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between system quantity and counted quantity, calculated as counted minus system quantity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'Monetary value of the variance between system and counted quantities.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The primary unit in which the material quantity is managed (e.g., KG=kilogram, L=liter, EA=each, M=meter, TON=tonne).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Management Indicator' ;
    rdfs:comment 'Flag indicating whether the material is managed in batches for traceability and quality control purposes.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating that the material master record is marked for deletion and should not be used in new transactions.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last updated or changed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original equipment manufacturer\'s part number or catalog identifier for the material.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Grouping code used to classify materials by commodity category for procurement and reporting purposes (e.g., explosives, reagents, fuel, tyres, lubricants, spare parts).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Upper limit for inventory holding to prevent overstocking and optimize working capital.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Weighted average price calculated from goods receipts, used for material valuation in moving average price control scenarios.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Lead Time Days' ;
    rdfs:comment 'Expected number of days from purchase order creation to goods receipt, used for procurement planning and MRP calculations.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plantSpecificStatus rdf:type rdf:Property ;
    rdfs:label 'Plant Specific Status' ;
    rdfs:comment 'Material status at the plant or site level, allowing different availability across mining operations.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Control Indicator' ;
    rdfs:comment 'Defines the valuation method for the material. S=Standard Price, V=Moving Average Price.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Method by which the material is procured, defining the procurement process and inventory ownership model.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration code defining serial number management requirements for the material (applicable to high-value equipment and components).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the material can be stored before it expires or degrades and becomes unusable. Applicable to reagents, chemicals, and perishable items.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'Fixed price used for material valuation in standard costing scenarios. Expressed in the company currency.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'Accounting classification code that determines the general ledger accounts to which material movements are posted.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume occupied by the material, used for storage and transportation planning.' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume (e.g., L=liter, M3=cubic meter, GAL=gallon).' ;
    rdfs:domain ind:MaterialMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialPlanId rdf:type rdf:Property ;
    rdfs:label 'Material Plan Id' ;
    rdfs:comment 'Primary key for material_plan' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalityIndicator rdf:type rdf:Property ;
    rdfs:label 'Criticality Indicator' ;
    rdfs:comment 'Business classification of how critical this material is to operations. Critical materials require higher safety stock and expedited procurement to avoid production stoppages.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lom Alignment Flag' ;
    rdfs:comment 'Indicates whether this material plan is aligned with the long-term Life of Mine plan. True if the plan supports strategic LOM objectives, false for tactical short-term planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'The person or team responsible for managing the material planning process for this material at this plant. Three-character code identifying the planner.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Date' ;
    rdfs:comment 'The date when this material plan was formally approved by the MRP controller or procurement manager. Null if still in draft status.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planCreationDate rdf:type rdf:Property ;
    rdfs:label 'Plan Creation Date' ;
    rdfs:comment 'The date when this material plan record was initially created in the system. Represents the planning run date.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business identifier for the material requirements plan, typically generated by the MRP (Material Requirements Planning) system. Format: MP-YYYYMMDD.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Order Quantity' ;
    rdfs:comment 'The quantity of material to be procured or produced to satisfy the planned requirement, adjusted for existing stock, safety stock, and lot-sizing rules. Represents net procurement need.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProcurementCost rdf:type rdf:Property ;
    rdfs:label 'Planned Procurement Cost' ;
    rdfs:comment 'Estimated total cost for procuring the planned order quantity, based on current pricing, contracts, or moving average price. Used for budget planning and cost control.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRequirementQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Requirement Quantity' ;
    rdfs:comment 'The forecasted or calculated quantity of material required for the planning period, derived from production schedules, maintenance plans, or consumption forecasts. Represents gross demand.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningNotes rdf:type rdf:Property ;
    rdfs:label 'Planning Notes' ;
    rdfs:comment 'Free-text field for MRP controller or planner to document special considerations, assumptions, or constraints affecting this material plan. Supports collaborative planning.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'The time bucket granularity for this material plan. Indicates whether the plan is structured on a daily, weekly, monthly, quarterly, or annual basis.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Reference' ;
    rdfs:comment 'Reference identifier to the mine production schedule or processing plant schedule that drives this material requirement. Links demand to operational plans.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Indicates how the material requirement will be fulfilled: external vendor procurement, existing contract, internal plant transfer, or in-house production.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockoutRiskScore rdf:type rdf:Property ;
    rdfs:label 'Stockout Risk Score' ;
    rdfs:comment 'Calculated risk score (0-100) indicating the probability of a stockout occurring during the planning period. Based on demand variability, lead time, and supplier reliability.' ;
    rdfs:domain ind:MaterialPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Id' ;
    rdfs:comment 'Unique identifier for the outbound shipment record. Primary key for the outbound shipment entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipment .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual date the vessel departed from the origin port or loading facility.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageGradePercent rdf:type rdf:Property ;
    rdfs:label 'Average Grade Percent' ;
    rdfs:comment 'Average grade or concentration of the valuable mineral in the shipped product, expressed as a percentage (e.g., iron content in iron ore concentrate).' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demurrageCost rdf:type rdf:Property ;
    rdfs:label 'Demurrage Cost' ;
    rdfs:comment 'Total demurrage cost incurred due to delays beyond agreed laytime, calculated based on daily demurrage rate and number of demurrage days.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demurrageDays rdf:type rdf:Property ;
    rdfs:label 'Demurrage Days' ;
    rdfs:comment 'Number of days the vessel was delayed beyond the agreed laytime at the loading or discharge port, potentially incurring demurrage charges.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the destination country of the shipment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortCode rdf:type rdf:Property ;
    rdfs:label 'Destination Port Code' ;
    rdfs:comment 'Five-letter UN/LOCODE identifying the destination port where the shipment will be delivered.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPortName rdf:type rdf:Property ;
    rdfs:label 'Destination Port Name' ;
    rdfs:comment 'Full name of the destination port where the customer will receive the shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Estimated date the vessel will arrive at the destination port, updated based on voyage progress and weather conditions.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code in which the freight rate is denominated.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imoNumber rdf:type rdf:Property ;
    rdfs:label 'Imo Number' ;
    rdfs:comment 'Seven-digit IMO ship identification number assigned to the vessel for permanent identification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Completion Timestamp' ;
    rdfs:comment 'Date and time when loading operations were completed and the vessel was ready to depart.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Start Timestamp' ;
    rdfs:comment 'Date and time when loading operations commenced at the origin port or stockpile.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originLocationName rdf:type rdf:Property ;
    rdfs:label 'Origin Location Name' ;
    rdfs:comment 'Full name of the origin port, mine site, or stockpile facility from which the shipment departs.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Number' ;
    rdfs:comment 'Reference number of the quality certificate or certificate of analysis issued for the shipped commodity product, documenting grade and specifications.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityVarianceTonnes rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance Tonnes' ;
    rdfs:comment 'Difference between nominated and loaded quantity in metric tonnes, calculated as loaded minus nominated.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known unique business identifier for the shipment, used for tracking and reference across systems and with customers.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the outbound shipment, tracking progress from planning through to delivery completion. [ENUM-REF-CANDIDATE: planned|loading|in_transit|arrived|discharged|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAgentName rdf:type rdf:Property ;
    rdfs:label 'Shipping Agent Name' ;
    rdfs:comment 'Name of the shipping agent or freight forwarder managing the logistics and documentation for this shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFreightCost rdf:type rdf:Property ;
    rdfs:label 'Total Freight Cost' ;
    rdfs:comment 'Total freight cost for the shipment, calculated as loaded quantity multiplied by freight rate per tonne.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Id' ;
    rdfs:comment 'Unique identifier for the physical inventory count document. Primary key for the physical inventory record.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Counter Employee Id' ;
    rdfs:comment 'The employee identifier of the person who performed the physical count.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Approval Required Indicator' ;
    rdfs:comment 'Flag indicating whether the variance requires management or supervisor approval before posting.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'The user ID of the person who approved the physical inventory variance for posting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookQuantity rdf:type rdf:Property ;
    rdfs:label 'Book Quantity' ;
    rdfs:comment 'The system-recorded inventory quantity (book inventory) at the time of the physical count.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The date on which the physical inventory count was conducted at the storage location.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'The current status of the physical inventory count document in its lifecycle.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'The type of physical inventory count performed: scheduled periodic count, ad-hoc count, cycle count, annual stocktake, or spot check.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterName rdf:type rdf:Property ;
    rdfs:label 'Counter Name' ;
    rdfs:comment 'The name of the person or team who performed the physical count.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeBookInventoryIndicator rdf:type rdf:Property ;
    rdfs:label 'Freeze Book Inventory Indicator' ;
    rdfs:comment 'Flag indicating whether the book inventory was frozen at the time of count to prevent movements during counting.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed description or notes explaining the reason for the inventory variance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recountDate rdf:type rdf:Property ;
    rdfs:label 'Recount Date' ;
    rdfs:comment 'The date on which the recount was performed, if applicable.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recountIndicator rdf:type rdf:Property ;
    rdfs:label 'Recount Indicator' ;
    rdfs:comment 'Flag indicating whether a recount was required or performed due to significant variance or discrepancy.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceExceededIndicator rdf:type rdf:Property ;
    rdfs:label 'Tolerance Exceeded Indicator' ;
    rdfs:comment 'Flag indicating whether the variance exceeded the configured tolerance threshold requiring management approval.' ;
    rdfs:domain ind:PhysicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portStockpileId rdf:type rdf:Property ;
    rdfs:label 'Port Stockpile Id' ;
    rdfs:comment 'Unique identifier for the port stockpile. Primary key for this entity.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portFacilityId rdf:type rdf:Property ;
    rdfs:label 'Port Facility Id' ;
    rdfs:comment 'Reference to the port facility where this stockpile is located. Links to the port facility master data.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortFacility .

ind:primaryPortAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Port Asset Id' ;
    rdfs:comment 'Reference to the primary stacker equipment assigned to this stockpile for stack-in operations. Links to equipment master data.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:stockpileWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Stockpile Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to procurement.warehouse_location. Business justification: Port stockpiles are physical storage locations that should reference the warehouse_location master. The port_stockpile table has stockpile_code and location-related attributes but no FK to warehouse_l' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:blendingInstructions rdf:type rdf:Property ;
    rdfs:label 'Blending Instructions' ;
    rdfs:comment 'Operational instructions for blending this stockpile with other stockpiles to achieve target quality specifications for vessel loading. May include blend ratios and target quality parameters.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTonnage rdf:type rdf:Property ;
    rdfs:label 'Current Tonnage' ;
    rdfs:comment 'Current inventory balance of material in the stockpile measured in metric tonnes. Represents the net result of all stack-in and reclaim movements.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dustSuppressionActive rdf:type rdf:Property ;
    rdfs:label 'Dust Suppression Active' ;
    rdfs:comment 'Indicates whether dust suppression systems are currently active for this stockpile. Critical for environmental compliance and Health Safety and Environment (HSE) management.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent material movement (stack-in or reclaim) affecting this stockpile. Used for activity monitoring and operational reporting.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSurveyTonnage rdf:type rdf:Property ;
    rdfs:label 'Last Survey Tonnage' ;
    rdfs:comment 'Measured tonnage from the most recent physical survey in metric tonnes. Used to reconcile system inventory against physical stockpile volume.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTonnageThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Tonnage Threshold' ;
    rdfs:comment 'Maximum storage capacity of the stockpile in metric tonnes. Represents the physical or operational limit for stacking operations.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTonnageThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Tonnage Threshold' ;
    rdfs:comment 'Minimum allowable tonnage level for the stockpile in metric tonnes. Triggers alerts when inventory falls below this level to ensure continuous vessel loading capability.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moisturePercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Percent' ;
    rdfs:comment 'Moisture content percentage of the stockpile material. Important for shipping weight calculations and product quality specifications.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Explanation for why the stockpile is quarantined or restricted from use. Populated when stockpile_status is quarantined due to quality issues, contamination, or regulatory hold.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeFractionMm rdf:type rdf:Property ;
    rdfs:label 'Size Fraction Mm' ;
    rdfs:comment 'Particle size distribution range of the stockpile material in millimeters (e.g., 6.3-31.5 for lump, 0-6.3 for fines). Critical for product classification and customer specifications.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Stockpile Area Sqm' ;
    rdfs:comment 'Physical footprint area of the stockpile in square meters. Used for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockpileHeightM rdf:type rdf:Property ;
    rdfs:label 'Stockpile Height M' ;
    rdfs:comment 'Current height of the stockpile in meters. Used for volume calculations and operational safety monitoring.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyVarianceTonnage rdf:type rdf:Property ;
    rdfs:label 'Survey Variance Tonnage' ;
    rdfs:comment 'Difference between system inventory and last physical survey tonnage in metric tonnes. Positive values indicate system over-reporting, negative values indicate under-reporting.' ;
    rdfs:domain ind:PortStockpile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Price Schedule Id' ;
    rdfs:comment 'Unique identifier for the price schedule record. Primary key.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPriceSupplyMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Supply Material Master Id' ;
    rdfs:comment 'Reference to the material master record for which this price schedule applies. Null if the schedule applies to a service.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:tertiaryPriceMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Price Material Master Id' ;
    rdfs:comment 'FK to procurement.material_master' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialMaster .

ind:autoPoCreationFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Po Creation Flag' ;
    rdfs:comment 'Indicates whether this price schedule supports automated purchase order creation from materials requirements planning (MRP) or requisitions without manual intervention.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFormula rdf:type rdf:Property ;
    rdfs:label 'Escalation Formula' ;
    rdfs:comment 'The mathematical formula or calculation method used to adjust the base price based on index movements or other variables, supporting automated price variance analysis.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'The specific index or benchmark used for price adjustments when the price basis is indexed, such as Consumer Price Index (CPI), Producer Price Index (PPI), or commodity spot price reference.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVarianceTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Price Variance Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage deviation from the scheduled price before triggering a price variance alert or approval workflow, supporting contract compliance monitoring.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the price schedule, typically a human-readable code or reference number used in procurement documents and purchase orders.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTier rdf:type rdf:Property ;
    rdfs:label 'Volume Tier' ;
    rdfs:comment 'The volume bracket or tier to which this price schedule applies, enabling tiered pricing structures where unit price decreases with higher volumes.' ;
    rdfs:domain ind:PriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line 1' ;
    rdfs:comment 'First line of the delivery address for the purchase order. May reference mine site, ROM (Run of Mine) pad, processing plant, warehouse, or other operational location.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line 2' ;
    rdfs:comment 'Second line of the delivery address providing additional location details such as building, gate, or specific area within the facility.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City or locality of the delivery address.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery address.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Requested or committed delivery date for goods or services. Represents the expected fulfillment date agreed with the vendor.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery address.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State, province, or region of the delivery address.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the responsibilities, costs, and risks between buyer and seller for transportation and delivery. Common mining terms include FOB (Free on Board) and CIF (Cost Insurance and Freight). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft delete flag indicating whether the purchase order has been logically deleted from active use. Supports data retention and audit requirements without physical deletion.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Net monetary value of the purchase order after applying discounts and before tax. Represents the actual amount payable to the vendor excluding tax.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Business event date when the purchase order was issued or approved for transmission to the vendor. Principal transaction timestamp for procurement analytics.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally visible unique purchase order number assigned by the procurement system. The primary business identifier used in vendor communications and goods receipt documentation.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Draft indicates not yet released, open indicates released and awaiting delivery, partially delivered indicates some goods received, fully delivered indicates all goods received, invoiced indicates invoice received, closed indicates completed and archived, cancelled indicates order terminated before completion. [ENUM-REF-CANDIDATE: draft|open|partially_delivered|fully_delivered|invoiced|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order based on procurement scenario. Standard for regular goods procurement, subcontracting for components sent to vendor for processing, consignment for vendor-owned stock, stock transport for inter-plant transfers, framework for blanket agreements, service for service procurement.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganisation rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organisation' ;
    rdfs:comment 'Organizational unit responsible for procurement activities. Represents the legal entity or business unit negotiating and executing the purchase order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the buyer requests delivery of goods or completion of services. Used for planning and scheduling purposes.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingInstructions rdf:type rdf:Property ;
    rdfs:label 'Shipping Instructions' ;
    rdfs:comment 'Special instructions for delivery, handling, or transportation of goods. Includes requirements for packaging, labeling, hazardous materials handling, or site-specific delivery protocols.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items before tax. Represents the gross committed spend for this procurement transaction.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date until which the purchase order remains valid. After this date, no further deliveries or services should be accepted against this order.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Effective start date for blanket or framework purchase orders. Defines the beginning of the period during which the purchase order terms are valid.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedCommodityCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Categories' ;
    rdfs:comment 'Comma-separated list of commodity categories or material groups that the vendor is approved to supply. Defines the scope of goods and services the vendor is authorized to provide based on their capabilities and prequalification assessment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'The name on the vendor\'s bank account used for payment processing. Must match the legal name or authorized signatory for payment validation and fraud prevention.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The vendor\'s bank account number for electronic funds transfer payments. Highly sensitive financial information requiring restricted access and encryption.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'The bank routing code, BSB (Bank-State-Branch), SWIFT code, or equivalent identifier for the vendor\'s bank. Required for domestic and international payment processing.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistDate rdf:type rdf:Property ;
    rdfs:label 'Blacklist Date' ;
    rdfs:comment 'Date when the vendor was added to the blacklist.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Boolean indicator showing whether the vendor is blacklisted and prohibited from receiving new purchase orders due to performance issues, compliance violations, or contractual breaches.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Detailed explanation of why the vendor was blacklisted, including reference to incidents, policy violations, or performance failures.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s current certification expires. Used to trigger recertification workflows and ensure compliance with procurement policies.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Indicates whether the vendor holds required certifications for supplying to the mining operation (e.g., ISO 9001 quality management, ISO 14001 environmental, ISO 45001 safety, explosives handling license).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country where the vendor is legally registered and operates from.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'The maximum outstanding accounts payable balance allowed for this vendor before payment or credit review is required. Used for financial risk management and cash flow control.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'The reference number of the vendor\'s current public liability and professional indemnity insurance certificate. Required for contractor and service provider prequalification and risk management.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The total coverage amount of the vendor\'s public liability insurance policy. Must meet minimum thresholds defined in procurement policies for high-risk categories such as explosives suppliers and heavy equipment contractors.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date the vendor was first registered and approved in the procurement system. Used for vendor relationship tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'The date on which the vendor\'s prequalification status expires and requires renewal. Used to trigger re-evaluation workflows and ensure ongoing compliance with vendor standards.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Indicates whether the vendor has completed the prequalification process and meets the mining operation\'s standards for safety, quality, financial stability, and compliance. Prequalified vendors are eligible for tender participation and contract awards.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary business contact person at the vendor organization. Used for procurement communications, order management, and issue resolution.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'The street address of the vendor\'s primary business location or registered office. Used for correspondence, legal notices, and logistics planning.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Government-issued tax identification number for the vendor. May be ABN (Australian Business Number), TIN (Tax Identification Number), VAT number, or equivalent depending on jurisdiction.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Classification of the vendor based on the primary type of goods or services they supply to the mining operation. Used for vendor segmentation and spend analysis. [ENUM-REF-CANDIDATE: explosives_supplier|reagent_manufacturer|fuel_distributor|tyre_supplier|spare_parts_dealer|equipment_oem|contractor_services|logistics_provider|consumables_supplier|professional_services — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the procurement system. Active vendors can receive purchase orders; suspended or blacklisted vendors are blocked from new transactions.' ;
    rdfs:domain ind:ProcurementVendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementVendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Procurement Vendor Performance Id' ;
    rdfs:comment 'Primary key for vendor_performance' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageIssueResolutionTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Issue Resolution Time Days' ;
    rdfs:comment 'The average number of days taken by the vendor to resolve reported issues, complaints, or non-conformances during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Delivery Performance Score' ;
    rdfs:comment 'The score measuring the vendor\'s delivery performance, including on-time delivery rate and order fulfillment metrics.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'The date when the vendor performance evaluation was formally conducted and recorded.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluator providing additional context, observations, or recommendations regarding the vendor\'s performance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period. Defines the conclusion of the assessment window for vendor KPIs.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period. Defines the beginning of the assessment window for vendor KPIs.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current workflow status of the vendor performance evaluation record. Tracks the evaluation through draft, approval, and closure stages.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the procurement or category manager who conducted the vendor performance evaluation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorRole rdf:type rdf:Property ;
    rdfs:label 'Evaluator Role' ;
    rdfs:comment 'Job role or title of the person who conducted the evaluation (e.g., Procurement Manager, Category Manager, Supply Chain Lead).' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate Percent' ;
    rdfs:comment 'Percentage of vendor invoices that matched purchase orders and goods receipts without discrepancies (three-way match success rate). Sourced from SAP S/4HANA FI invoice verification.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncrCount rdf:type rdf:Property ;
    rdfs:label 'Ncr Count' ;
    rdfs:comment 'The total number of Non-Conformance Reports (NCRs) raised against the vendor during the evaluation period for quality issues.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the scheduled delivery date during the evaluation period. Key delivery performance KPI.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Order Fill Rate Percent' ;
    rdfs:comment 'The percentage of purchase order line items completely fulfilled by the vendor without shortages or backorders during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Composite performance rating summarizing the vendor\'s overall performance across all evaluation dimensions. Used for contract renewal and preferred supplier decisions.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'The composite overall performance score for the vendor across all evaluation dimensions, typically expressed as a percentage or weighted average.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Price Performance Score' ;
    rdfs:comment 'The score measuring the vendor\'s price competitiveness and adherence to contracted pricing.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Price Variance Percent' ;
    rdfs:comment 'The percentage variance between actual invoiced prices and contracted prices during the evaluation period. Positive values indicate overcharges, negative values indicate discounts.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAcceptanceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate Percent' ;
    rdfs:comment 'Percentage of goods receipts that passed quality inspection without rejection or non-conformance during the evaluation period. Calculated from LabWare LIMS and SAP quality inspection data.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Quality Performance Score' ;
    rdfs:comment 'The score measuring the vendor\'s quality performance, including rejection rates and non-conformance records.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionCount rdf:type rdf:Property ;
    rdfs:label 'Rejection Count' ;
    rdfs:comment 'Total number of goods receipts rejected due to quality non-conformance during the evaluation period. Used to calculate quality acceptance rate.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Rejection Rate Percent' ;
    rdfs:comment 'The percentage of goods receipts rejected due to quality defects or non-conformance during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessRating rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Rating' ;
    rdfs:comment 'Qualitative rating of the vendor\'s responsiveness to inquiries, requests, and communications during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Qualitative score (0-100) assessing the vendor\'s responsiveness to inquiries, issue resolution, and communication timeliness. Evaluated by procurement and operational teams.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Service Performance Score' ;
    rdfs:comment 'The score measuring the vendor\'s service quality, including responsiveness and issue resolution capabilities.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGoodsReceiptCount rdf:type rdf:Property ;
    rdfs:label 'Total Goods Receipt Count' ;
    rdfs:comment 'Total number of goods receipts processed for the vendor during the evaluation period. Used to calculate delivery and quality metrics.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Count' ;
    rdfs:comment 'The total number of purchase orders issued to the vendor during the evaluation period that were included in this performance assessment.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Line Count' ;
    rdfs:comment 'The total number of purchase order line items issued to the vendor during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalProcurementValue rdf:type rdf:Property ;
    rdfs:label 'Total Procurement Value' ;
    rdfs:comment 'Total monetary value of all procurement transactions with the vendor during the evaluation period. Represents the vendor\'s business volume.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPurchaseOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Order Count' ;
    rdfs:comment 'Total number of purchase orders issued to the vendor during the evaluation period. Provides context for performance metrics.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRejectionCount rdf:type rdf:Property ;
    rdfs:label 'Total Rejection Count' ;
    rdfs:comment 'The total number of goods receipts rejected due to quality defects or non-conformance during the evaluation period.' ;
    rdfs:domain ind:ProcurementVendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Defines how the purchase order line cost will be allocated in the financial system. Determines whether the expense is charged to a cost centre, capital project (CAPEX), fixed asset, or internal order.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the final invoice has been received for this purchase order line. When true, no further invoices are expected and the line can be closed.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a goods receipt transaction is required for this purchase order line. When true, physical receipt must be posted before invoice can be processed.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'The cumulative quantity of material that has been physically received and posted against this purchase order line. Updated each time a goods receipt transaction is recorded.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the vendor against this purchase order line. Used for three-way matching between PO, goods receipt, and invoice.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether invoice verification is required for this purchase order line. When true, vendor invoice must be matched and posted.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order line item. Tracks progression from open order through goods receipt to final closure or cancellation.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netOrderValue rdf:type rdf:Property ;
    rdfs:label 'Net Order Value' ;
    rdfs:comment 'Total net value of this purchase order line, calculated as quantity ordered multiplied by net price. Excludes taxes and freight charges.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The net price per unit of measure for this line item, excluding taxes and additional charges. Used to calculate line item total value.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may over-deliver beyond the ordered quantity without requiring approval. Used for goods receipt tolerance checking.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured. Provides human-readable context for the line item on purchase order documents and reports.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may under-deliver below the ordered quantity without requiring approval. Used for goods receipt tolerance checking and automatic PO closure.' ;
    rdfs:domain ind:PurchaseOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Requisitions are raised by employees. Tracking who requested materials is essential for approval workflows, cost centre validation, budget accountability, and audit trails. Currently stored as text na' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current stage in the multi-level approval workflow. Requisitions above certain value thresholds require manager, department head, and executive approvals.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Status indicating whether the requisition has been converted to a purchase order. Tracks the progression from demand signal to formal procurement commitment.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total value of the requisition line in the requisition currency. Used for budgeting and approval threshold determination.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested material or service must be delivered to the requesting location. Drives procurement planning and supplier selection.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created in the system. Represents the formal initiation of the procurement demand signal.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the requisition in the approval and conversion workflow. Tracks progression from creation through approval to purchase order conversion. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|partially_converted|fully_converted|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition based on procurement scenario: standard purchase, stock transfer between plants, subcontracting with vendor, consignment arrangement, or service procurement.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionerEmail rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Email' ;
    rdfs:comment 'Email address of the requisitioner for communication regarding the requisition status, approvals, and delivery notifications.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeterminationIndicator rdf:type rdf:Property ;
    rdfs:label 'Source Determination Indicator' ;
    rdfs:comment 'Boolean flag indicating whether automatic source determination should be performed to identify preferred vendors or contracts. True triggers sourcing logic in procurement workflow.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEntrySheetId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Id' ;
    rdfs:comment 'Unique identifier for the service entry sheet record. Primary key.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the service was formally accepted and confirmed as complete by the approving supervisor or contract administrator. Triggers invoice verification workflow.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Reference to the vendor invoice document that was verified against this service entry sheet. Links SES to accounts payable for payment processing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of the two-way match process between purchase order, service entry sheet, and vendor invoice. Critical for accounts payable processing and contractor payment.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total monetary value for this service line item, calculated as quantity performed multiplied by unit rate. Forms the basis for invoice verification.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityPerformed rdf:type rdf:Property ;
    rdfs:label 'Quantity Performed' ;
    rdfs:comment 'Quantity of service units completed and accepted. Measured in hours, days, tonnes moved, metres drilled, square metres cleared, or other unit appropriate to the service type.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date on which the service entry sheet was reversed or cancelled. Null if not reversed.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Classification of the service type performed at mine sites, processing plants, or project locations. Aligns with mining operational service categories for spend analysis. [ENUM-REF-CANDIDATE: drilling|blasting|haulage|maintenance|engineering|consulting|laboratory|environmental|security|catering — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Service Line Number' ;
    rdfs:comment 'Line item sequence number within the service entry sheet. Identifies individual service activities or deliverables within the SES document.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service performance period. Defines the conclusion of the timeframe during which the contracted service was delivered.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service performance period. Defines the beginning of the timeframe during which the contracted service was delivered.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sesNumber rdf:type rdf:Property ;
    rdfs:label 'Ses Number' ;
    rdfs:comment 'Business document number for the service entry sheet, externally visible identifier used in procurement and invoice verification workflows.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sesStatus rdf:type rdf:Property ;
    rdfs:label 'Ses Status' ;
    rdfs:comment 'Current lifecycle status of the service entry sheet. Tracks progression from creation through approval or rejection. Critical for invoice verification workflow control.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Reference Number' ;
    rdfs:comment 'Reference to field-based timesheet system record that supports this service entry. Links to source data from contractor time tracking systems.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Contracted price per unit of service performed. Used to calculate line value based on quantity performed.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingBidId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Bid Id' ;
    rdfs:comment 'Unique identifier for the sourcing bid submission record.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardJustification rdf:type rdf:Property ;
    rdfs:label 'Award Justification' ;
    rdfs:comment 'Business justification and rationale for the award recommendation decision, documenting why this bid was selected or rejected.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Award Recommendation Flag' ;
    rdfs:comment 'Indicates whether this bid is recommended for contract award (True = recommended, False = not recommended).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidBondAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Amount' ;
    rdfs:comment 'Monetary value of the bid bond or bid security submitted by the vendor, if applicable.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Reference Number' ;
    rdfs:comment 'Reference number or identifier of the bid bond or bank guarantee submitted by the vendor.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required Flag' ;
    rdfs:comment 'Indicates whether a bid bond or bid security was required for this sourcing event (True = required, False = not required).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this bid submission by the vendor or procurement system.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current status of the bid in the evaluation and award workflow. [ENUM-REF-CANDIDATE: submitted|under_evaluation|shortlisted|preferred|unsuccessful|withdrawn|disqualified — promote to reference product]' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Bid Validity End Date' ;
    rdfs:comment 'Date until which the vendor\'s bid pricing and terms remain valid and binding.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commercialEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Evaluation Score' ;
    rdfs:comment 'Numerical score assigned to the bid based on commercial evaluation criteria (e.g., price competitiveness, payment terms, delivery terms).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialExceptionsSummary rdf:type rdf:Property ;
    rdfs:label 'Commercial Exceptions Summary' ;
    rdfs:comment 'Summary of any commercial exceptions, deviations, or alternative terms proposed by the vendor that differ from the sourcing event requirements.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceWithSpecificationsFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance With Specifications Flag' ;
    rdfs:comment 'Indicates whether the bid fully complies with the technical specifications and requirements outlined in the sourcing event (True = compliant, False = non-compliant or partial compliance).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Reason for disqualifying the bid if it was deemed non-compliant or ineligible (e.g., late submission, non-responsive, failed prequalification).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completion Date' ;
    rdfs:comment 'Date when the evaluation of this bid was completed.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationRanking rdf:type rdf:Property ;
    rdfs:label 'Evaluation Ranking' ;
    rdfs:comment 'Numerical ranking of this bid relative to other bids received for the same sourcing event (1 = highest ranked).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Hse Evaluation Score' ;
    rdfs:comment 'Numerical score assigned to the bid based on the vendor\'s health, safety, and environmental management systems, certifications, and performance history.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indigenousParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Indigenous Participation Flag' ;
    rdfs:comment 'Indicates whether the vendor is an indigenous-owned business or includes indigenous participation in the bid, relevant for diversity and inclusion evaluation.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Local Content Percentage' ;
    rdfs:comment 'Percentage of goods, services, or labor sourced locally as declared by the vendor, relevant for local content compliance and evaluation.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Overall Evaluation Score' ;
    rdfs:comment 'Weighted overall evaluation score combining technical, commercial, and HSE scores to rank bids.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management certifications held by the vendor (e.g., ISO 9001, Six Sigma).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Occupational health and safety certifications held by the vendor (e.g., ISO 45001, OHSAS 18001).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Sustainability or environmental certifications held by the vendor (e.g., ISO 14001, EcoVadis rating, Carbon Neutral certification).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Technical Evaluation Score' ;
    rdfs:comment 'Numerical score assigned to the bid based on technical evaluation criteria (e.g., solution quality, methodology, experience, capability).' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalProposalSummary rdf:type rdf:Property ;
    rdfs:label 'Technical Proposal Summary' ;
    rdfs:comment 'Summary of the vendor\'s technical approach, methodology, and solution proposed in response to the sourcing event requirements.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBidValue rdf:type rdf:Property ;
    rdfs:label 'Total Bid Value' ;
    rdfs:comment 'Total monetary value of the bid across all line items, representing the vendor\'s proposed total contract value.' ;
    rdfs:domain ind:SourcingBid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the sourcing event was formally awarded to the successful vendor.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Value' ;
    rdfs:comment 'Total contract value awarded to the successful vendor, representing the committed spend over the contract term.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commoditySubcategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Subcategory' ;
    rdfs:comment 'Detailed subcategory within the commodity category for more granular classification of the procurement scope.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Intended duration of the resulting contract in months, defining the commitment period for the awarded vendor.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Spend' ;
    rdfs:comment 'Estimated total annual spend value for the commodity or service being sourced, used for vendor qualification and internal budgeting.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationMethodology rdf:type rdf:Property ;
    rdfs:label 'Evaluation Methodology' ;
    rdfs:comment 'Method used to evaluate vendor responses: price only (lowest price wins), weighted score (price and quality factors), best value (qualitative assessment), or technical compliance (pass/fail then price).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when formal evaluation of vendor responses commenced.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Event Owner Email' ;
    rdfs:comment 'Email address of the event owner for vendor communication and internal coordination.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOwnerName rdf:type rdf:Property ;
    rdfs:label 'Event Owner Name' ;
    rdfs:comment 'Name of the procurement professional or category manager who owns and is accountable for this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceWeightingPercent rdf:type rdf:Property ;
    rdfs:label 'Price Weighting Percent' ;
    rdfs:comment 'Percentage weight assigned to price in the evaluation scoring model (0-100). Remaining percentage is allocated to quality, technical, and other non-price factors.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityWeightingPercent rdf:type rdf:Property ;
    rdfs:label 'Quality Weighting Percent' ;
    rdfs:comment 'Percentage weight assigned to quality and technical factors in the evaluation scoring model (0-100).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsAchieved rdf:type rdf:Property ;
    rdfs:label 'Savings Achieved' ;
    rdfs:comment 'Total savings achieved compared to the baseline value, calculated as baseline value minus awarded value. Positive values indicate cost reduction.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Savings Percentage' ;
    rdfs:comment 'Percentage savings achieved relative to the baseline value, calculated as (savings achieved / baseline value) * 100.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Strategic importance classification of this sourcing event based on business impact, spend value, and supply risk: critical, high, medium, or low.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Submission Close Date' ;
    rdfs:comment 'Final date and time by which vendor submissions must be received. No late submissions are accepted after this date.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Submission Open Date' ;
    rdfs:comment 'Date when vendor submissions are first accepted for this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorsInvitedCount rdf:type rdf:Property ;
    rdfs:label 'Vendors Invited Count' ;
    rdfs:comment 'Total number of vendors invited to participate in this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorsRespondedCount rdf:type rdf:Property ;
    rdfs:label 'Vendors Responded Count' ;
    rdfs:comment 'Total number of vendors who submitted a valid response to the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Unique identifier for the stock transfer record. Primary key.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStockWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Location Id' ;
    rdfs:comment 'Foreign key reference to the specific storage location within the sending plant from which the material is being issued (e.g., central warehouse, maintenance stores, ROM pad).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:receivingPlantId rdf:type rdf:Property ;
    rdfs:label 'Receiving Plant Id' ;
    rdfs:comment 'Foreign key reference to the plant or site to which the material is being delivered. Links to the plant/site master data.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:receivingStorageLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Receiving Storage Location Warehouse Location Id' ;
    rdfs:comment 'Foreign key reference to the specific storage location within the receiving plant where the material will be received and stored (e.g., remote site stores, maintenance workshop, processing plant warehouse).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:sendingPlantId rdf:type rdf:Property ;
    rdfs:label 'Sending Plant Id' ;
    rdfs:comment 'Foreign key reference to the plant or site from which the material is being dispatched. Links to the plant/site master data.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The name of the logistics carrier, freight company, or internal fleet responsible for transporting the material between locations (e.g., \'Internal Fleet\', \'ABC Logistics\', \'Mine Haul Trucks\').' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssuePostedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Posted Flag' ;
    rdfs:comment 'Boolean flag indicating whether the goods issue (dispatch) has been posted in SAP MM, reducing inventory at the sending location. True if posted, False if not yet posted.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Posted Flag' ;
    rdfs:comment 'Boolean flag indicating whether the goods receipt has been posted in SAP MM, increasing inventory at the receiving location. True if posted, False if not yet received.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendingStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sending Storage Location Code' ;
    rdfs:comment 'The SAP storage location code (4-character alphanumeric) within the sending plant identifying the specific warehouse, bin, or stockpile area from which material is dispatched.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The planned or actual date when the stock transfer order was executed and goods were dispatched from the sending location. Business event date for the transfer transaction.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'The externally-known unique business identifier for the stock transfer order as recorded in SAP S/4HANA MM. Format: STO followed by 10 digits.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'The quantity of material being transferred in the base unit of measure. Supports up to 3 decimal places for precision in measuring spare parts, consumables, or bulk materials.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the stock transfer order: draft (not yet released), released (approved for execution), in transit (goods dispatched but not received), partially received (some items received), completed (all items received), or cancelled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the stock transfer based on the nature of the movement: plant-to-plant, storage location to storage location within same plant, site-to-site across mine operations, warehouse to mine site, or central warehouse to remote location.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'The registration or fleet number of the vehicle (truck, haul truck, light vehicle) used to transport the material. Enables tracking of transport asset utilization and route compliance.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileMovementId rdf:type rdf:Property ;
    rdfs:label 'Stockpile Movement Id' ;
    rdfs:comment 'Unique identifier for the stockpile movement transaction. Primary key for the stockpile movement record.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendId rdf:type rdf:Property ;
    rdfs:label 'Blend Id' ;
    rdfs:comment 'Identifier of the blending recipe or specification used if this movement is part of a blending operation. Nullable for non-blend movements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Blend .

ind:destinationStockpilePortStockpileId rdf:type rdf:Property ;
    rdfs:label 'Destination Stockpile Port Stockpile Id' ;
    rdfs:comment 'Identifier of the destination stockpile for blend or transfer movements. Nullable for reclaim or vessel loading movements.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortStockpile .

ind:primaryPortStockpileId rdf:type rdf:Property ;
    rdfs:label 'Primary Port Stockpile Id' ;
    rdfs:comment 'Identifier of the port stockpile involved in this movement transaction.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortStockpile .

ind:sourceStockpilePortStockpileId rdf:type rdf:Property ;
    rdfs:label 'Source Stockpile Port Stockpile Id' ;
    rdfs:comment 'Identifier of the source stockpile for blend or transfer movements. Nullable for stack-in movements from external sources.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortStockpile .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Description of any delays or interruptions encountered during the movement operation, used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finesPercent rdf:type rdf:Property ;
    rdfs:label 'Fines Percent' ;
    rdfs:comment 'Percentage of fine-sized material (typically -6mm) in the stockpile movement, important for product specification compliance.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeAl2o3Percent rdf:type rdf:Property ;
    rdfs:label 'Grade Al2o3 Percent' ;
    rdfs:comment 'Alumina content percentage of the material at the time of movement, important quality parameter for mineral processing.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeFePercent rdf:type rdf:Property ;
    rdfs:label 'Grade Fe Percent' ;
    rdfs:comment 'Iron content percentage of the material at the time of movement, critical quality parameter for iron ore products.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradePPercent rdf:type rdf:Property ;
    rdfs:label 'Grade P Percent' ;
    rdfs:comment 'Phosphorus content percentage of the material at the time of movement, critical impurity parameter for steel-making ore.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeSio2Percent rdf:type rdf:Property ;
    rdfs:label 'Grade Sio2 Percent' ;
    rdfs:comment 'Silica content percentage of the material at the time of movement, key gangue indicator for ore quality.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lumpPercent rdf:type rdf:Property ;
    rdfs:label 'Lump Percent' ;
    rdfs:comment 'Percentage of lump-sized material (typically +6mm) in the stockpile movement, important for product specification compliance.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the stockpile movement transaction, used for tracking and reconciliation across systems.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementPriority rdf:type rdf:Property ;
    rdfs:label 'Movement Priority' ;
    rdfs:comment 'Operational priority level assigned to this movement, used for scheduling and resource allocation decisions.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the stockpile movement operation was executed or completed in the physical operation.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedTonnage rdf:type rdf:Property ;
    rdfs:label 'Planned Tonnage' ;
    rdfs:comment 'Target mass of material planned to be moved in this transaction, measured in metric tonnes. Used for variance analysis against actual tonnage.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainNumber rdf:type rdf:Property ;
    rdfs:label 'Train Number' ;
    rdfs:comment 'Reference number of the rail train if this movement involves rail discharge to stockpile. Nullable for non-rail movements.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckNumber rdf:type rdf:Property ;
    rdfs:label 'Truck Number' ;
    rdfs:comment 'Reference number of the haulage truck if this movement involves truck discharge to stockpile. Nullable for non-truck movements.' ;
    rdfs:domain ind:StockpileMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPrequalificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Prequalification Id' ;
    rdfs:comment 'Unique identifier for the vendor prequalification assessment record. Primary key for this entity.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedServiceCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Service Categories' ;
    rdfs:comment 'Comma-separated list of service categories for which the vendor is prequalified to provide. May include drilling, haulage, maintenance, engineering, consulting, etc.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedSiteLocations rdf:type rdf:Property ;
    rdfs:label 'Approved Site Locations' ;
    rdfs:comment 'Comma-separated list of mine sites or plant codes where the vendor is approved to operate. Site-specific HSE inductions and access requirements may apply.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text field capturing additional observations, comments, or context from the prequalification assessment that do not fit structured fields.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Final decision on the vendor prequalification application. Approved vendors are added to AVL, conditional approvals require remediation, rejected vendors cannot supply.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Job title or functional role of the person who conducted the assessment, such as Procurement Manager, Supply Chain Analyst, or Category Manager.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalApprovalReason rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Reason' ;
    rdfs:comment 'Explanation of conditions or deficiencies that resulted in conditional approval status, including specific remediation actions required before full approval.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialHealthScore rdf:type rdf:Property ;
    rdfs:label 'Financial Health Score' ;
    rdfs:comment 'Numerical score representing the vendor\'s financial stability, creditworthiness, and fiscal capacity to fulfill contracts. Based on financial statements, credit ratings, and liquidity analysis.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Hse Performance Score' ;
    rdfs:comment 'Score evaluating the vendor\'s health, safety, and environmental compliance record including LTIFR, TRIFR, incident history, and environmental management systems. Critical for mine site access approval.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Insurance Compliance Score' ;
    rdfs:comment 'Score assessing adequacy of vendor\'s insurance coverage including public liability, professional indemnity, workers compensation, and contract-specific insurance requirements.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification. Required for vendors with potential environmental impact.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification. Mandatory for high-risk mining service providers.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified Flag' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification. Demonstrates commitment to quality processes and continuous improvement.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceCertificationScore rdf:type rdf:Property ;
    rdfs:label 'Licence Certification Score' ;
    rdfs:comment 'Assessment of vendor\'s possession of required business licences, industry certifications, trade qualifications, and regulatory permits necessary for mining operations.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ltifrRate rdf:type rdf:Property ;
    rdfs:label 'Ltifr Rate' ;
    rdfs:comment 'Vendor\'s Lost Time Injury Frequency Rate per million hours worked. Critical HSE metric for mining industry vendor assessment and site access approval.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Threshold Score' ;
    rdfs:comment 'Minimum overall score required for vendor approval. Vendors scoring below this threshold are rejected or granted conditional approval with remediation requirements.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Weighted composite score aggregating all assessment category scores to provide a single measure of vendor suitability for approved vendor list inclusion.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prequalificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prequalification Reference Number' ;
    rdfs:comment 'Externally visible unique reference number assigned to this prequalification assessment for tracking and audit purposes.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementScore rdf:type rdf:Property ;
    rdfs:label 'Quality Management Score' ;
    rdfs:comment 'Score evaluating the vendor\'s quality management systems, certifications, inspection processes, and track record of delivering conforming products and services.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reassessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic reassessment of vendor prequalification. Typically occurs before expiry date to ensure continuity of approval.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalCapabilityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Capability Score' ;
    rdfs:comment 'Assessment score for the vendor\'s technical competency, equipment capability, workforce skills, quality management systems, and ability to meet mining industry technical specifications.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trifrRate rdf:type rdf:Property ;
    rdfs:label 'Trifr Rate' ;
    rdfs:comment 'Vendor\'s Total Recordable Injury Frequency Rate per million hours worked. Broader HSE metric capturing all recordable injuries including medical treatment cases.' ;
    rdfs:domain ind:VendorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Security classification level governing personnel access to the warehouse location. Determines required clearances and access control procedures.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPalletPositions rdf:type rdf:Property ;
    rdfs:label 'Capacity Pallet Positions' ;
    rdfs:comment 'Number of standard pallet positions available in the warehouse location. Used for space utilization planning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum storage capacity of the location measured in cubic meters. Applicable for enclosed storage facilities.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Tonnes' ;
    rdfs:comment 'Maximum weight capacity of the storage location in metric tonnes. Critical for structural load limits and safety compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Flag' ;
    rdfs:comment 'Indicates whether the location has automated environmental monitoring systems for temperature, humidity, gas detection, or other parameters.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:explosivesLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Explosives License Expiry Date' ;
    rdfs:comment 'Expiration date of the explosives storage license. Requires renewal before this date to maintain compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:explosivesLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Explosives License Number' ;
    rdfs:comment 'Government-issued license number authorizing storage of explosives at this magazine location. Applicable only for explosives storage facilities.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystemType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Type' ;
    rdfs:comment 'Type of fire suppression system installed at the warehouse location. Critical for emergency response planning and insurance compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousGoodsClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Classification' ;
    rdfs:comment 'UN hazardous materials classification code(s) for materials authorized to be stored at this location. Multiple classes separated by semicolon. Empty if non-hazardous storage only.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage facility type based on its primary function and storage characteristics. Determines handling procedures and access controls. [ENUM-REF-CANDIDATE: bulk_storage|hazmat_bunker|cold_store|open_laydown|explosives_magazine|general_warehouse|parts_store|consumables_store|quarantine_area|scrap_yard — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether the warehouse location has climate control systems for temperature-sensitive materials storage.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum operating temperature maintained in the storage location in degrees Celsius. Applicable for temperature-controlled facilities.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum operating temperature maintained in the storage location in degrees Celsius. Applicable for temperature-controlled facilities.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseManagerName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Manager Name' ;
    rdfs:comment 'Name of the person responsible for managing operations at this warehouse location. Business reference, not direct PII.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkPricingIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Pricing Index' ;
    rdfs:comment 'The market pricing index or benchmark used for commercial pricing of this commodity (e.g., Platts Iron Ore Index, LME Copper, Newcastle Coal Index, Fastmarkets Lithium Hydroxide).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cimDefinitionStandard rdf:type rdf:Property ;
    rdfs:label 'Cim Definition Standard' ;
    rdfs:comment 'CIM definition standard reference for the commodity used in Canadian mineral resource and reserve reporting.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityClass rdf:type rdf:Property ;
    rdfs:label 'Commodity Class' ;
    rdfs:comment 'High-level classification of the commodity type. Used for strategic segmentation and market analysis.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGroup rdf:type rdf:Property ;
    rdfs:label 'Commodity Group' ;
    rdfs:comment 'Higher-level grouping or family to which this commodity belongs for reporting and analysis purposes (e.g., Iron Ore Products, Copper Products, Coal Products).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Full business name of the commodity (e.g., Iron Ore, Copper Concentrate, Thermal Coal, Lithium Hydroxide, Nickel Matte).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity in the product catalog. Active commodities are currently produced and sold.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClassification rdf:type rdf:Property ;
    rdfs:label 'Environmental Classification' ;
    rdfs:comment 'Environmental impact classification or category for the commodity based on extraction, processing, and disposal considerations.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Export License Required' ;
    rdfs:comment 'Indicates whether an export license or permit is required for international shipment of this commodity due to regulatory or strategic controls.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International Harmonized System tariff classification code used for customs, trade documentation, and export/import compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether the commodity is classified as a hazardous material requiring special handling, storage, and transportation protocols.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jorcCommodityType rdf:type rdf:Property ;
    rdfs:label 'Jorc Commodity Type' ;
    rdfs:comment 'JORC-compliant commodity type classification used for resource and reserve reporting to ensure alignment with Australian mineral reporting standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndUseMarket rdf:type rdf:Property ;
    rdfs:label 'Primary End Use Market' ;
    rdfs:comment 'The principal industry or market segment that consumes this commodity (e.g., steel manufacturing, energy generation, battery production, construction materials).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory or compliance classification code for the commodity as defined by governing bodies (e.g., JORC resource category, SEC S-K 1300 classification, CIM definition standards).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Royalty Applicable' ;
    rdfs:comment 'Indicates whether government or third-party royalties apply to the production and sale of this commodity.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samrecCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Samrec Commodity Code' ;
    rdfs:comment 'SAMREC-compliant commodity code for operations reporting under South African mineral resource standards.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardPackagingType rdf:type rdf:Property ;
    rdfs:label 'Standard Packaging Type' ;
    rdfs:comment 'The standard packaging or shipment format for this commodity (e.g., bulk vessel, containerized, bagged, drummed).' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Of Measure' ;
    rdfs:comment 'The standard unit of measure used for quantifying and trading this commodity across all transactions and reporting.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportanceLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Level' ;
    rdfs:comment 'Internal strategic importance rating of the commodity to the business based on revenue contribution, market position, and long-term value.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingCurrency rdf:type rdf:Property ;
    rdfs:label 'Trading Currency' ;
    rdfs:comment 'The standard currency in which this commodity is priced and traded internationally. Three-letter ISO 4217 currency code.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalRecoveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Typical Recovery Rate Percent' ;
    rdfs:comment 'The typical percentage of valuable mineral extracted during processing for this commodity. Used for production planning and resource estimation.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeParameterId rdf:type rdf:Property ;
    rdfs:label 'Grade Parameter Id' ;
    rdfs:comment 'Unique identifier for the grade parameter. Primary key for the grade parameter reference catalog.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GradeParameter .

ind:alternativeNames rdf:type rdf:Property ;
    rdfs:label 'Alternative Names' ;
    rdfs:comment 'Comma-separated list of alternative names, synonyms, or abbreviations used for this parameter across different systems, regions, or customer specifications (e.g., \'Fe\' may also be known as \'Iron\', \'Fe Total\', \'Fe%\'; \'CV\' as \'Calorific Value\', \'Heating Value\', \'Energy Content\'). Supports data integration and customer communication.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCommodityScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Commodity Scope' ;
    rdfs:comment 'Comma-separated list of mineral commodities to which this parameter applies (e.g., iron_ore, copper_concentrate, thermal_coal, metallurgical_coal, lithium_hydroxide, lithium_carbonate, nickel_matte, nickel_concentrate, gold_dore). Defines the product catalog scope where this parameter is relevant for quality specification.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decimalPrecision rdf:type rdf:Property ;
    rdfs:label 'Decimal Precision' ;
    rdfs:comment 'Number of decimal places to which parameter values should be reported and rounded (e.g., 2 for percentages like 62.35%, 0 for whole numbers, 4 for trace elements in ppm). Ensures consistency in assay reporting and contract specifications.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gradeParameterStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Parameter Status' ;
    rdfs:comment 'Current lifecycle status of the parameter definition: active (in use), inactive (temporarily not used), deprecated (being phased out), under_review (pending validation or approval). Controls which parameters are available for new product specifications.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonusElement rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Element' ;
    rdfs:comment 'Indicates whether exceeding specified thresholds for this parameter results in commercial bonuses or price premiums (True). Typically applies to valuable elements or quality characteristics that enhance product value (e.g., high Fe content in iron ore, high CV in coal).' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractualParameter rdf:type rdf:Property ;
    rdfs:label 'Is Contractual Parameter' ;
    rdfs:comment 'Indicates whether this parameter is typically included in sales contracts and commercial specifications (True) or is used only for internal quality control and process optimization (False). Contractual parameters drive pricing adjustments, penalties, and bonuses.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPenaltyElement rdf:type rdf:Property ;
    rdfs:label 'Is Penalty Element' ;
    rdfs:comment 'Indicates whether exceeding specified limits for this parameter results in commercial penalties or price deductions (True). Typically applies to deleterious elements like sulfur, phosphorus, arsenic, and excess moisture that negatively impact downstream processing.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsParameterCode rdf:type rdf:Property ;
    rdfs:label 'Lims Parameter Code' ;
    rdfs:comment 'The parameter code used in the Laboratory Information Management System (LIMS) for sample tracking and assay result recording. Enables integration between the product catalog and laboratory systems. May differ from the standard parameter_code due to legacy system conventions.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'Business classification grouping parameters by commercial significance: major_element (primary value drivers like Fe, Cu), minor_element (secondary constituents), trace_element (low-concentration elements), deleterious_element (penalty elements like S, P, As), moisture_content (H2O measures), size_distribution (particle sizing), energy_property (CV, calorific measures), physical_property (density, hardness). [ENUM-REF-CANDIDATE: major_element|minor_element|trace_element|deleterious_element|moisture_content|size_distribution|energy_property|physical_property — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the quality parameter (e.g., FE, CU, AL2O3, SIO2, S, P, MN, TIO2, LOI, LCE, H2O, P80, CV, ASH, VM, FC). Used as the standard reference key across product specifications, assay results, and quality control systems.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingBasis rdf:type rdf:Property ;
    rdfs:label 'Reporting Basis' ;
    rdfs:comment 'Moisture basis on which the parameter value is reported: as_received (natural state including moisture), dry_basis (moisture removed), air_dried (equilibrated with ambient air), moisture_free (completely dried), daf (dry ash-free basis for coal). Critical for accurate comparison of assay results and contract specifications.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Typical Range Maximum' ;
    rdfs:comment 'Upper bound of the typical value range observed for this parameter across the company\'s mineral products. Used for data validation and quality control checks. Expressed in the parameter\'s unit of measure.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Typical Range Minimum' ;
    rdfs:comment 'Lower bound of the typical value range observed for this parameter across the company\'s mineral products. Used for data validation and quality control checks. Expressed in the parameter\'s unit of measure.' ;
    rdfs:domain ind:GradeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Moisture Specification Id' ;
    rdfs:comment 'Unique identifier for the moisture specification record. Primary key for this entity.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowMoisturePointPct rdf:type rdf:Property ;
    rdfs:label 'Flow Moisture Point Pct' ;
    rdfs:comment 'Flow Moisture Point (FMP) as defined by IMSBC Code. Moisture content at which the cargo begins to exhibit fluid-like behavior under vibration or compaction. Used to calculate TML (TML = 0.9 × FMP).' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeMoistureLimitPct rdf:type rdf:Property ;
    rdfs:label 'Free Moisture Limit Pct' ;
    rdfs:comment 'Maximum allowable free moisture (surface moisture) as a percentage of total weight. Free moisture is distinct from inherent moisture and is critical for assessing liquefaction risk in nickel and copper concentrates under IMSBC Code.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imsbcGroupClassification rdf:type rdf:Property ;
    rdfs:label 'Imsbc Group Classification' ;
    rdfs:comment 'IMSBC Code cargo classification: Group A (may liquefy - requires TML testing), Group B (chemical hazards), Group C (neither liquefaction nor chemical hazard), or not applicable. Critical for nickel and copper concentrates (Group A).' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Inherent Moisture Pct' ;
    rdfs:comment 'Inherent moisture content (moisture bound within the mineral structure) as a percentage of total weight. Inherent moisture is not removable by standard drying and is excluded from free moisture calculations.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumContractualMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Maximum Contractual Moisture Pct' ;
    rdfs:comment 'Maximum allowable moisture content as a percentage of total weight, as specified in customer contracts. Exceeding this limit may trigger penalties, price adjustments, or cargo rejection. Critical for iron ore, coal, and concentrate products.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Minimum Moisture Pct' ;
    rdfs:comment 'Minimum moisture content percentage, if applicable. Some products require minimum moisture to prevent dust generation during handling and transport (e.g., coal, iron ore fines).' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureControlMethod rdf:type rdf:Property ;
    rdfs:label 'Moisture Control Method' ;
    rdfs:comment 'Primary method used to control and reduce moisture content in the product: natural drainage (stockpile drainage), mechanical dewatering (filter press, belt filter), thermal drying (rotary dryer, fluidized bed), filtration, centrifuge, or vacuum dewatering.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Moisture Measurement Method' ;
    rdfs:comment 'Primary method used to measure moisture content: oven drying (ISO 11465 standard), microwave (rapid field test), online analyser (continuous real-time monitoring), infrared, capacitance, or nuclear moisture gauge.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moisturePenaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Moisture Penalty Rate Pct' ;
    rdfs:comment 'Penalty rate applied per percentage point of moisture above the penalty threshold. Expressed as a percentage reduction in payable weight or price.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moisturePenaltyThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Penalty Threshold Pct' ;
    rdfs:comment 'Moisture content percentage above which financial penalties are applied to the shipment value. Penalties typically reduce the payable weight or apply a price discount per percentage point over the threshold.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureRejectionThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Rejection Threshold Pct' ;
    rdfs:comment 'Moisture content percentage above which the shipment may be rejected by the customer or deemed unsafe for transport. Critical for IMSBC Code compliance and contract enforcement.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureSpecificationStatus rdf:type rdf:Property ;
    rdfs:label 'Moisture Specification Status' ;
    rdfs:comment 'Current lifecycle status of the moisture specification. Active specifications are enforced in production and sales; superseded specifications are retained for historical reference.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureVariabilityStdDevPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Variability Std Dev Pct' ;
    rdfs:comment 'Standard deviation of moisture content variability observed in production, expressed as a percentage. Used for process control and to set appropriate target moisture levels below contractual limits.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ovenDryingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Oven Drying Duration Hours' ;
    rdfs:comment 'Standard oven drying duration in hours required to achieve constant weight for moisture determination (typically 24 hours for most minerals).' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ovenDryingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Oven Drying Temperature C' ;
    rdfs:comment 'Standard oven drying temperature in degrees Celsius used for moisture determination (typically 105°C for most minerals). Critical for ensuring consistent and reproducible moisture measurements.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeKg rdf:type rdf:Property ;
    rdfs:label 'Sample Size Kg' ;
    rdfs:comment 'Standard sample size in kilograms collected for moisture testing. Larger samples provide more representative results but require longer drying times.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Frequency at which moisture samples are collected and tested: continuous (online analyser), per shift, per batch, per shipment, hourly, daily, or weekly. Determines the granularity of moisture control and compliance verification. [ENUM-REF-CANDIDATE: continuous|per_shift|per_batch|per_shipment|hourly|daily|weekly — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCode rdf:type rdf:Property ;
    rdfs:label 'Specification Code' ;
    rdfs:comment 'Unique business identifier for the moisture specification, typically aligned with product grade codes and contract references.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name of the moisture specification, describing the product and moisture control regime (e.g., \'Iron Ore Fines Standard Moisture\', \'Copper Concentrate IMSBC Compliant\').' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNotes rdf:type rdf:Property ;
    rdfs:label 'Specification Notes' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to the moisture specification, including customer-specific requirements, seasonal adjustments, or operational constraints.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of the moisture specification: contractual (customer contract requirement), operational (internal production target), regulatory (IMSBC Code compliance), or internal (quality control standard).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Target Moisture Pct' ;
    rdfs:comment 'Internal operational target moisture content percentage for production and quality control. Typically set below the contractual maximum to provide a safety margin and account for measurement variability.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportableMoistureLimitPct rdf:type rdf:Property ;
    rdfs:label 'Transportable Moisture Limit Pct' ;
    rdfs:comment 'Transportable Moisture Limit (TML) as defined by IMSBC Code for Group A cargoes (concentrates and fine ores). Maximum moisture content at which the cargo can be safely shipped without liquefaction risk. Mandatory for nickel, copper, and iron ore concentrates.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalShippedMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Typical Shipped Moisture Pct' ;
    rdfs:comment 'Average moisture content percentage typically achieved in shipped product under normal operating conditions. Used for production planning and quality forecasting.' ;
    rdfs:domain ind:MoistureSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingStandardId rdf:type rdf:Property ;
    rdfs:label 'Packaging Standard Id' ;
    rdfs:comment 'Unique identifier for the packaging standard record. Primary key for the packaging standard entity.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulkDensityMaxTPerM3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density Max T Per M3' ;
    rdfs:comment 'Maximum bulk density of the product in the specified packaging configuration, measured in tonnes per cubic metre. Used for cargo planning and stowage calculations.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkDensityMinTPerM3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density Min T Per M3' ;
    rdfs:comment 'Minimum bulk density of the product in the specified packaging configuration, measured in tonnes per cubic metre. Critical for cargo planning and vessel stability calculations.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerSpecification rdf:type rdf:Property ;
    rdfs:label 'Container Specification' ;
    rdfs:comment 'Detailed specification of the container or packaging unit, including dimensions, material, liner type, and construction standards (e.g., \'20ft ISO container with polyethylene liner\', \'1000kg FIBC Type C conductive\').' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corrosiveFlag rdf:type rdf:Property ;
    rdfs:label 'Corrosive Flag' ;
    rdfs:comment 'Indicates whether the product has corrosive properties that can cause severe damage to living tissue or materials. True for products like lithium hydroxide (Class 8).' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencySchedule rdf:type rdf:Property ;
    rdfs:label 'Emergency Schedule' ;
    rdfs:comment 'IMDG Code Emergency Schedule reference (e.g., \'F-A, S-B\') indicating emergency response procedures for fire and spillage. Empty if not dangerous goods.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imdgCodeClass rdf:type rdf:Property ;
    rdfs:label 'Imdg Code Class' ;
    rdfs:comment 'IMDG Code hazard classification for dangerous goods (e.g., Class 8 for corrosives, Class 4.2 for self-heating substances). Empty if product is not classified as dangerous goods.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imsbcCodeClassification rdf:type rdf:Property ;
    rdfs:label 'Imsbc Code Classification' ;
    rdfs:comment 'IMSBC Code cargo group classification. Group A: cargoes that may liquefy (require TML testing). Group B: cargoes with chemical hazards. Group C: cargoes that are neither liable to liquefy nor possess chemical hazards.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirements' ;
    rdfs:comment 'Mandatory labeling and marking requirements for the packaging unit including hazard labels, handling symbols, product identification, batch numbers, and regulatory compliance marks per IMDG/IMSBC codes.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerMaterial rdf:type rdf:Property ;
    rdfs:label 'Liner Material' ;
    rdfs:comment 'Material specification for container or bag liner used to protect product from moisture, contamination, or chemical reaction (e.g., \'polyethylene 200 micron\', \'polypropylene woven\', \'aluminum foil laminate\'). Empty if no liner is used.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Gross Weight Kg' ;
    rdfs:comment 'Maximum permissible gross weight of a single packaging unit including product and packaging materials, measured in kilograms. Constrained by container ratings and handling equipment capacity.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStackHeightUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Stack Height Units' ;
    rdfs:comment 'Maximum number of packaging units (containers, bags, drums) that can be safely stacked vertically during storage or transport. Critical for warehouse planning and container loading.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moistureSensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Moisture Sensitive Flag' ;
    rdfs:comment 'Indicates whether the product is sensitive to moisture exposure and requires moisture-controlled packaging or storage. True for products like lithium hydroxide that react with water.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netWeightTypicalKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Typical Kg' ;
    rdfs:comment 'Typical net weight of product per packaging unit, measured in kilograms. Used for logistics planning and invoicing calculations.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxidisingFlag rdf:type rdf:Property ;
    rdfs:label 'Oxidising Flag' ;
    rdfs:comment 'Indicates whether the product has oxidising properties that may intensify fire or cause combustion of other materials. Relevant for certain mineral concentrates.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Standard Status' ;
    rdfs:comment 'Current lifecycle status of the packaging standard. Active standards are approved for use. Superseded standards have been replaced by newer versions.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'Official UN proper shipping name for dangerous goods transport documentation (e.g., \'CORROSIVE SOLID, BASIC, INORGANIC, N.O.S. (lithium hydroxide)\'). Empty if not dangerous goods.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealingMethod rdf:type rdf:Property ;
    rdfs:label 'Sealing Method' ;
    rdfs:comment 'Method used to seal the packaging unit to prevent moisture ingress, contamination, or spillage (e.g., \'heat seal\', \'cable tie\', \'bolted lid\', \'welded closure\'). Critical for moisture-sensitive products.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationGroup rdf:type rdf:Property ;
    rdfs:label 'Segregation Group' ;
    rdfs:comment 'Cargo segregation group code indicating which other cargo types this product must be separated from during transport and storage per IMDG Code segregation tables.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfHeatingFlag rdf:type rdf:Property ;
    rdfs:label 'Self Heating Flag' ;
    rdfs:comment 'Indicates whether the product is liable to spontaneous heating and combustion. Critical for coal and certain sulfide concentrates classified as Materials Hazardous in Bulk (MHB).' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Detailed description of special handling, storage, and transport requirements including ventilation needs, segregation rules, temperature controls, and emergency response procedures.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Unique business identifier code for the packaging standard, used for external reference and documentation.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Descriptive name of the packaging standard, identifying the product and packaging configuration (e.g., \'Iron Ore Fines Bulk Vessel\', \'Lithium Hydroxide Lined Container\').' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stowageFactorM3PerT rdf:type rdf:Property ;
    rdfs:label 'Stowage Factor M3 Per T' ;
    rdfs:comment 'Volume occupied by one tonne of cargo including voids and dunnage, measured in cubic metres per tonne. Inverse of bulk density, used for vessel hold capacity planning.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Weight of the empty packaging unit (container, bag, drum) without product, measured in kilograms. Used to calculate net product weight from gross weight measurements.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmlMaxPercentage rdf:type rdf:Property ;
    rdfs:label 'Tml Max Percentage' ;
    rdfs:comment 'Maximum moisture content percentage at which the cargo can be safely transported without risk of liquefaction. Applicable only to Group A cargoes. Expressed as percentage of total mass.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tmlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tml Required Flag' ;
    rdfs:comment 'Indicates whether the product is classified as Group A cargo under IMSBC Code and requires Transportable Moisture Limit testing and certification prior to shipment. True for nickel concentrate and certain iron ore fines.' ;
    rdfs:domain ind:PackagingStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Pricing Configuration Id' ;
    rdfs:comment 'Primary key for pricing_configuration' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByConfigurationPricingConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Configuration Pricing Configuration Id' ;
    rdfs:comment 'Reference to the newer pricing configuration that replaces this one, if superseded. Null if current.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingConfiguration .

ind:adjustmentCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Adjustment Calculation Method' ;
    rdfs:comment 'Mathematical method used to calculate penalty/bonus adjustments (linear interpolation, stepped brackets, exponential scaling, or custom formula).' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseReferenceGrade rdf:type rdf:Property ;
    rdfs:label 'Base Reference Grade' ;
    rdfs:comment 'The baseline quality specification value for the parameter (e.g., 62.0% Fe, 5.0% SiO2). Deviations from this trigger penalties or bonuses.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseReferenceUnit rdf:type rdf:Property ;
    rdfs:label 'Base Reference Unit' ;
    rdfs:comment 'Unit of measure for the base reference grade (e.g., %, ppm, mm, g/t).' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkIndexReference rdf:type rdf:Property ;
    rdfs:label 'Benchmark Index Reference' ;
    rdfs:comment 'The market price index or benchmark used as the base pricing reference (e.g., Platts IODEX 62% Fe CFR China, LME Copper Grade A, Newcastle Coal Index, Fastmarkets Lithium Hydroxide CIF Asia, LME Nickel).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusCapAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Cap Amount' ;
    rdfs:comment 'Maximum total bonus amount that can be applied for this parameter, capping upside price adjustments.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Bonus Rate Per Unit' ;
    rdfs:comment 'Price adjustment rate applied per unit above the base reference grade (e.g., +0.40 USD/dmt per 0.1% Fe above 62.0%).' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Business identifier code for this pricing configuration template, used in offtake agreements and commercial contracts.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Descriptive name of the pricing configuration template (e.g., \'IODEX 62% Fe CFR China Standard\', \'LME Copper Grade A Premium\').' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of the pricing configuration template.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum total penalty amount that can be applied for this parameter, preventing excessive price reductions.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRatePerUnit rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Per Unit' ;
    rdfs:comment 'Price adjustment rate applied per unit below the base reference grade (e.g., -0.50 USD/dmt per 0.1% Fe below 62.0%).' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the pricing is denominated (e.g., USD, AUD, CNY).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalPricingPercentage rdf:type rdf:Property ;
    rdfs:label 'Provisional Pricing Percentage' ;
    rdfs:comment 'Percentage of the estimated final price paid provisionally at shipment (typically 80-90%). Remainder settled after final assay and quotational period completion.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityParameterName rdf:type rdf:Property ;
    rdfs:label 'Quality Parameter Name' ;
    rdfs:comment 'Name of the quality parameter subject to penalty/bonus adjustment (e.g., Fe%, SiO2%, Al2O3%, Moisture%, Ash%, Sulfur%, Phosphorus%, Size Distribution).' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationalPeriodDefinition rdf:type rdf:Property ;
    rdfs:label 'Quotational Period Definition' ;
    rdfs:comment 'Definition of the quotational period used for pricing (e.g., \'Month of Bill of Lading\', \'Month Prior to Shipment\', \'Average of M+1 and M+2\'). Determines which market prices apply to a shipment.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionLimitLower rdf:type rdf:Property ;
    rdfs:label 'Rejection Limit Lower' ;
    rdfs:comment 'Minimum acceptable value for the quality parameter. Material below this threshold may be rejected or subject to renegotiation.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Rejection Limit Upper' ;
    rdfs:comment 'Maximum acceptable value for the quality parameter (for deleterious elements). Material above this threshold may be rejected.' ;
    rdfs:domain ind:PricingConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Customer Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Custom blends are created to meet individual customer specifications (e.g., blending ore sources to achieve contractual Fe/SiO2 ratios). Supports blend approval workflows, customer acceptance testing,' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:sourceOrebodyId rdf:type rdf:Property ;
    rdfs:label 'Source Orebody Id' ;
    rdfs:comment 'Foreign key linking to geology.orebody. Business justification: Product blends target material from specific orebodies to achieve grade specifications. Blend recipes reference source orebodies for quality prediction, optimization algorithms, and production plannin' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Orebody .

ind:blendCode rdf:type rdf:Property ;
    rdfs:label 'Blend Code' ;
    rdfs:comment 'Externally-known unique code identifying this blend recipe, used across mine planning, processing, and logistics systems.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blendName rdf:type rdf:Property ;
    rdfs:label 'Blend Name' ;
    rdfs:comment 'Human-readable name of the blend recipe, typically reflecting target grade or customer specification (e.g., \'62% Fe Lump Blend\', \'Premium Thermal Coal Blend\').' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blendStatus rdf:type rdf:Property ;
    rdfs:label 'Blend Status' ;
    rdfs:comment 'Current lifecycle status of the blend recipe: draft (under development), approved (ready for use), active (currently in production), suspended (temporarily inactive), retired (no longer used).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blendType rdf:type rdf:Property ;
    rdfs:label 'Blend Type' ;
    rdfs:comment 'Classification of the blend by commodity type: ore_blend (iron ore, copper ore), coal_blend (thermal, metallurgical), concentrate_blend (processed mineral concentrate), custom_blend (customer-specific recipe).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blendingLocationType rdf:type rdf:Property ;
    rdfs:label 'Blending Location Type' ;
    rdfs:comment 'Type of facility where blending occurs: rom_pad (Run of Mine stockpile pad), stockpile (intermediate stockpile), train_loadout (rail loading facility), port_stockpile (port storage yard), ship_loader (vessel loading point).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityRating rdf:type rdf:Property ;
    rdfs:label 'Complexity Rating' ;
    rdfs:comment 'Operational complexity classification: simple (2-3 components, wide tolerance), moderate (3-4 components, standard tolerance), complex (5+ components, tight tolerance), advanced (requires real-time optimization and quality prediction).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Customer Specification Reference' ;
    rdfs:comment 'Reference code to the customer contract or specification document that defines the quality requirements for this blend. Links blend to commercial agreements.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Component Count' ;
    rdfs:comment 'Maximum number of source products allowed in this blend (typically 3-8). Limits operational complexity and maintains traceability.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumComponentCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Component Count' ;
    rdfs:comment 'Minimum number of source products required to create this blend (typically 2-5). Ensures blend complexity and quality consistency.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Optimization Objective' ;
    rdfs:comment 'Primary business objective for this blend: maximize_grade (highest quality), minimize_cost (lowest production cost), meet_specification (exact customer requirement), maximize_recovery (best yield), balance_inventory (stockpile management).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceProtocol rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Protocol' ;
    rdfs:comment 'Level of quality testing and validation required: standard (routine sampling), enhanced (increased sampling frequency), premium (continuous monitoring), customer_specific (per contract requirements).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPredictionModelReference rdf:type rdf:Property ;
    rdfs:label 'Quality Prediction Model Reference' ;
    rdfs:comment 'Reference code to the predictive analytics model used to forecast blend quality outcomes based on source material properties. Supports real-time blend optimization.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAluminaPercent rdf:type rdf:Property ;
    rdfs:label 'Target Alumina Percent' ;
    rdfs:comment 'Target alumina content percentage for iron ore and mineral blends. Impacts smelting efficiency (typical range 1-4%).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAshPercent rdf:type rdf:Property ;
    rdfs:label 'Target Ash Percent' ;
    rdfs:comment 'Target ash content percentage for coal blends. Lower ash content increases energy value and reduces waste (typical range 8-25%).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEnergyContentKcalKg rdf:type rdf:Property ;
    rdfs:label 'Target Energy Content Kcal Kg' ;
    rdfs:comment 'Target calorific value for coal blends measured in kilocalories per kilogram. Critical for thermal coal pricing and power generation efficiency (typical range 4500-7000 kcal/kg).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFeGradePercent rdf:type rdf:Property ;
    rdfs:label 'Target Fe Grade Percent' ;
    rdfs:comment 'Target iron content percentage for iron ore blends, typically 58-67% Fe. Critical for meeting customer specifications and pricing.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMoisturePercent rdf:type rdf:Property ;
    rdfs:label 'Target Moisture Percent' ;
    rdfs:comment 'Target moisture content percentage for the blended product. Critical for shipping weight calculations and product quality (typical range 2-10%).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPhosphorusPercent rdf:type rdf:Property ;
    rdfs:label 'Target Phosphorus Percent' ;
    rdfs:comment 'Target phosphorus content percentage for iron ore blends. Low phosphorus is critical for high-grade steel production (typical range 0.02-0.10%).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSilicaPercent rdf:type rdf:Property ;
    rdfs:label 'Target Silica Percent' ;
    rdfs:comment 'Target silica content percentage for iron ore and mineral blends. Lower silica is preferred for steel-making (typical range 2-8%).' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Target Specification Code' ;
    rdfs:comment 'Reference code to the product specification that this blend is designed to meet, including grade parameters, moisture limits, and quality tolerances.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceRangePercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Range Percent' ;
    rdfs:comment 'Allowable deviation from target specification expressed as percentage (e.g., ±2% for Fe grade). Defines acceptable quality variance for the blend.' ;
    rdfs:domain ind:Blend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blendComponentId rdf:type rdf:Property ;
    rdfs:label 'Blend Component Id' ;
    rdfs:comment 'Unique identifier for the product blend component record. Primary key.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBlendSaleableProductId rdf:type rdf:Property ;
    rdfs:label 'Primary Blend Saleable Product Id' ;
    rdfs:comment 'Reference to the source product that serves as a component in this blend. Links to the product master entity representing the individual mineral product (e.g., iron ore fines from specific pit, lump ore from specific source).' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SaleableProduct .

ind:blendingPriority rdf:type rdf:Property ;
    rdfs:label 'Blending Priority' ;
    rdfs:comment 'Priority ranking for this component when multiple blend recipes are being executed simultaneously. Lower numbers indicate higher priority. Used by blend optimization systems.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Component Availability Status' ;
    rdfs:comment 'Current availability status of this component product for blending operations. Indicates whether the component is readily available, constrained, or unavailable for production planning.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCostPerTonne rdf:type rdf:Property ;
    rdfs:label 'Component Cost Per Tonne' ;
    rdfs:comment 'The unit cost per tonne of this component product. Used for blend cost optimization and product margin analysis. Represents internal transfer price or production cost.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentGradeAl2o3Pct rdf:type rdf:Property ;
    rdfs:label 'Component Grade Al2o3 Pct' ;
    rdfs:comment 'The alumina (Al2O3) grade percentage of this component product. Represents the alumina content contribution to the blend. Monitored for product specification compliance.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentGradeFePct rdf:type rdf:Property ;
    rdfs:label 'Component Grade Fe Pct' ;
    rdfs:comment 'The iron (Fe) grade percentage of this specific component product. Represents the Fe content contribution that this component brings to the final blend. Critical for calculating blended Fe grade for iron ore products.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentGradePPct rdf:type rdf:Property ;
    rdfs:label 'Component Grade P Pct' ;
    rdfs:comment 'The phosphorus (P) grade percentage of this component product. Critical impurity parameter for steel-making iron ore products. Managed to meet customer specifications.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentGradeSPct rdf:type rdf:Property ;
    rdfs:label 'Component Grade S Pct' ;
    rdfs:comment 'The sulfur (S) grade percentage of this component product. Critical impurity parameter for steel-making iron ore products. Managed to meet customer specifications.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentGradeSio2Pct rdf:type rdf:Property ;
    rdfs:label 'Component Grade Sio2 Pct' ;
    rdfs:comment 'The silica (SiO2) grade percentage of this component product. Represents the gangue content that this component contributes to the blend. Important for managing impurity levels in final product.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentLoiPct rdf:type rdf:Property ;
    rdfs:label 'Component Loi Pct' ;
    rdfs:comment 'The loss on ignition (LOI) percentage of this component product. Represents volatile content and combined water. Important for calculating true mineral content and meeting product specifications.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Component Moisture Pct' ;
    rdfs:comment 'The typical moisture content percentage of this component product. Used to calculate dry weight contributions and manage moisture limits in the final blend for shipping and handling.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Ordering sequence of this component within the blend recipe. Used for display and processing order in blend execution systems.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSizeFraction rdf:type rdf:Property ;
    rdfs:label 'Component Size Fraction' ;
    rdfs:comment 'The size fraction classification of this component product (e.g., fines, lump, pellet). Defines the physical form and particle size distribution of the component material. [ENUM-REF-CANDIDATE: fines|lump|pellet|concentrate|ROM|crushed|screened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSourceLocation rdf:type rdf:Property ;
    rdfs:label 'Component Source Location' ;
    rdfs:comment 'The mine site, pit, or processing plant location from which this component product originates. Enables traceability and source tracking for blend components.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStockpileCode rdf:type rdf:Property ;
    rdfs:label 'Component Stockpile Code' ;
    rdfs:comment 'The ROM pad or port stockpile code where this component material is stored. Links blend recipe to physical inventory locations for operational execution.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBlendRatioPct rdf:type rdf:Property ;
    rdfs:label 'Maximum Blend Ratio Pct' ;
    rdfs:comment 'The maximum allowable percentage contribution of this component to the blend. Defines the upper bound of acceptable blend variance for operational flexibility and quality control.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBlendRatioPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Blend Ratio Pct' ;
    rdfs:comment 'The minimum allowable percentage contribution of this component to the blend. Defines the lower bound of acceptable blend variance for operational flexibility and quality control.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityVarianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Quality Variance Tolerance Pct' ;
    rdfs:comment 'The allowable percentage variance in component quality parameters (grade, moisture, etc.) from the specified values. Defines acceptable quality fluctuation for operational flexibility.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Flag indicating whether this component can be substituted with an alternative product if unavailable. True if substitution is permitted within defined quality parameters; False if this specific component must be used.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetBlendRatioPct rdf:type rdf:Property ;
    rdfs:label 'Target Blend Ratio Pct' ;
    rdfs:comment 'The target percentage contribution of this component to the final blend by weight. Represents the ideal ratio for achieving desired product specifications. Must sum to 100% across all components in a blend.' ;
    rdfs:domain ind:BlendComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the product certification record. Primary key.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdiction' ;
    rdfs:comment 'The specific legal or regulatory jurisdiction under which this certification is governed. May include sub-national regions, trade zones, or regulatory frameworks (e.g., EU REACH, China AQSIQ, Korea MOE).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableMarket rdf:type rdf:Property ;
    rdfs:label 'Applicable Market' ;
    rdfs:comment 'The geographic market, country, or jurisdiction where this certification is required and valid. Examples: European Union, China, South Korea, Japan, United States. Use 3-letter ISO country codes where applicable (e.g., CHN, KOR, JPN, USA) or regional identifiers (e.g., EU).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the certification audit or inspection was conducted by the issuing authority or third-party auditor. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'The name of the individual auditor or audit firm that conducted the certification assessment.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'A description of the scope of the certification, including what aspects of the product, process, or operation are covered. Examples: product composition, manufacturing process, environmental impact, quality management system, occupational health and safety.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category or type of certification. Examples include REACH registration (EU chemical regulation), China GB (Guobiao) standard approval, Korean KS certification, Japanese JIS (Japanese Industrial Standards) approval, hazardous goods classification certificate (IMDG, ADR, IATA), ISO 9001 quality management, ISO 14001 environmental management. [ENUM-REF-CANDIDATE: reach_registration|china_gb_standard|korean_ks_certification|japanese_jis_approval|hazardous_goods_classification|iso_9001|iso_14001 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'The total cost incurred to obtain or renew this certification, including application fees, audit fees, testing fees, and administrative costs. Expressed in the reporting currency.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'The hazardous goods classification code assigned to the product for transport and handling. Examples: UN number (UN 3264 for corrosive liquids), IMDG class (Class 8 Corrosive), ADR class, IATA dangerous goods code. Critical for lithium products and concentrates.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The date by which the certification must be renewed to maintain validity. Format: yyyy-MM-dd. Null if renewal is not required.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productGradeCovered rdf:type rdf:Property ;
    rdfs:label 'Product Grade Covered' ;
    rdfs:comment 'The specific product grade, specification, or variant that this certification covers. For example, battery-grade lithium hydroxide monohydrate (>56.5% LiOH), copper concentrate (>25% Cu), iron ore fines (Fe 62% min). Critical for products with multiple grades.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The frequency in months at which the certification must be renewed. Examples: 12 (annual), 24 (biennial), 36 (triennial). Null if renewal is not required.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal. True if renewal is required, False if the certification is indefinite or one-time.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The name of the internal business unit, department, or individual responsible for managing and maintaining this certification. Examples: Product Compliance Team, HSE Department, Quality Assurance Manager.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'A reference or file path to the supporting documentation, certificate files, audit reports, or compliance records associated with this certification. May be a document management system identifier or URL.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeLimitId rdf:type rdf:Property ;
    rdfs:label 'Grade Limit Id' ;
    rdfs:comment 'Unique identifier for the product grade limit record. Primary key for this entity.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusRate rdf:type rdf:Property ;
    rdfs:label 'Bonus Rate' ;
    rdfs:comment 'The financial bonus rate applied per unit improvement beyond the bonus threshold. Typically expressed as currency per percentage point or currency per ppm. Used to calculate provisional pricing adjustments and commercial premiums when grade parameters exceed target specifications. Confidential commercial term from sales contracts.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusThreshold rdf:type rdf:Property ;
    rdfs:label 'Bonus Threshold' ;
    rdfs:comment 'The value at which financial bonuses or price premiums begin to apply. For beneficial elements, bonuses typically apply when the value exceeds this threshold. For deleterious elements, bonuses may apply when the value falls below this threshold. Triggers provisional pricing adjustments and commercial premiums.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTolerance rdf:type rdf:Property ;
    rdfs:label 'Compliance Tolerance' ;
    rdfs:comment 'The acceptable measurement uncertainty or tolerance band around the limit value within which minor excursions are considered acceptable due to analytical variability. Accounts for sampling error, analytical precision, and measurement repeatability. Used to avoid false rejections due to normal measurement variation. Expressed in the same unit as the grade parameter.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedValue rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Value' ;
    rdfs:comment 'The contractually guaranteed value for this grade parameter committed to the customer. Failure to meet this guarantee may trigger price adjustments, penalties, or cargo rejection. More conservative than typical value to account for operational variability. Used in sales contracts and letters of credit.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitStatus rdf:type rdf:Property ;
    rdfs:label 'Limit Status' ;
    rdfs:comment 'Current lifecycle status of the grade limit record. Active: currently in force and used for quality compliance checking. Superseded: replaced by a newer version. Draft: proposed limit pending approval. Under_review: existing limit being evaluated for revision. Suspended: temporarily not enforced due to operational or commercial reasons.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Classification of the grade limit based on its source and enforcement authority. Contractual: limits specified in customer sales contracts. Operational: limits defined by internal process capabilities and equipment constraints. Regulatory: limits mandated by environmental or safety regulations. Shipping: limits required for safe maritime transport (e.g., TML). Internal: limits set for quality control and process optimization purposes.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Limit' ;
    rdfs:comment 'The absolute maximum acceptable value for this grade parameter. Values above this threshold may trigger cargo rejection or require remediation. For deleterious elements (e.g., silica, alumina, phosphorus, sulfur in iron ore), represents the ceiling specification. For beneficial elements, this field may be null as only minimum limits apply.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLimit rdf:type rdf:Property ;
    rdfs:label 'Minimum Limit' ;
    rdfs:comment 'The absolute minimum acceptable value for this grade parameter. Values below this threshold may trigger cargo rejection or require remediation. For beneficial elements (e.g., iron in iron ore), represents the floor specification. For deleterious elements (e.g., phosphorus, sulfur), this field may be null as only maximum limits apply.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyRate rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate' ;
    rdfs:comment 'The financial penalty rate applied per unit deviation beyond the penalty threshold. Typically expressed as currency per percentage point or currency per ppm. Used to calculate provisional pricing adjustments and commercial deductions when grade parameters fall outside acceptable ranges. Confidential commercial term from sales contracts.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyThreshold rdf:type rdf:Property ;
    rdfs:label 'Penalty Threshold' ;
    rdfs:comment 'The value at which financial penalties or price deductions begin to apply. For deleterious elements, penalties typically apply when the value exceeds this threshold. For beneficial elements, penalties may apply when the value falls below this threshold. Triggers provisional pricing adjustments and commercial deductions.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionLimit rdf:type rdf:Property ;
    rdfs:label 'Rejection Limit' ;
    rdfs:comment 'The absolute value at which the cargo or shipment will be rejected by the customer or deemed non-compliant with contractual specifications. Represents the hard boundary beyond which the product is considered off-specification and unsaleable. More extreme than penalty thresholds. Triggers cargo hold, rework, or disposal decisions.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version identifier for the product specification document from which this grade limit is derived. Enables tracking of specification changes over time and ensures traceability to the authoritative source document. Format typically follows semantic versioning or document control numbering (e.g., V1.0, V2.3, 2024-Q1).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodCode rdf:type rdf:Property ;
    rdfs:label 'Test Method Code' ;
    rdfs:comment 'Standardized code identifying the analytical test method or assay procedure used to measure this grade parameter. References international standards (ISO, ASTM, AS) or internal laboratory methods. Ensures consistency between specification limits and measurement procedures. Links to Laboratory Information Management System (LIMS) test method registry.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportableMoistureLimit rdf:type rdf:Property ;
    rdfs:label 'Transportable Moisture Limit' ;
    rdfs:comment 'The maximum moisture content at which the mineral concentrate or ore can be safely transported by sea without risk of liquefaction and cargo shift. Critical safety parameter for bulk carrier shipping of iron ore fines, nickel ore, and other fine concentrates. Compliance with TML is mandatory under International Maritime Solid Bulk Cargoes (IMSBC) Code. Only applicable to moisture-related grade parameters.' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalValue rdf:type rdf:Property ;
    rdfs:label 'Typical Value' ;
    rdfs:comment 'The typical or average value historically achieved for this grade parameter under normal operating conditions. Represents the expected value communicated to customers in product marketing materials and used for sales forecasting. Distinct from target (aspiration) and guaranteed (contractual commitment).' ;
    rdfs:domain ind:GradeLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingBasisId rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis Id' ;
    rdfs:comment 'Unique identifier for the product pricing basis record. Primary key.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByPricingBasisId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Pricing Basis Id' ;
    rdfs:comment 'Reference to the pricing basis record that supersedes this one, if applicable. Used to maintain version lineage and historical pricing basis evolution.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingBasis .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'The geographic location or port associated with the Incoterm and pricing basis (e.g., Port Hedland, Qingdao, Rotterdam, Singapore). Used in conjunction with Incoterm to define the pricing point.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPricingTrigger rdf:type rdf:Property ;
    rdfs:label 'Final Pricing Trigger' ;
    rdfs:comment 'The business event or condition that triggers final pricing and settlement (e.g., Assay results received, 30 days after discharge, End of quotational period, LME prompt month settlement). Defines when provisional pricing is finalized.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightComponentIncluded rdf:type rdf:Property ;
    rdfs:label 'Freight Component Included' ;
    rdfs:comment 'Indicates whether freight cost is included in the pricing basis (true for CIF/CFR Incoterms, false for FOB). Determines if separate freight adjustment is required in contract pricing.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indexProvider rdf:type rdf:Property ;
    rdfs:label 'Index Provider' ;
    rdfs:comment 'The organization or agency that publishes the price index (e.g., Platts, London Metal Exchange, Fastmarkets, IHS Markit, Argus Media).' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceComponentIncluded rdf:type rdf:Property ;
    rdfs:label 'Insurance Component Included' ;
    rdfs:comment 'Indicates whether insurance cost is included in the pricing basis (true for CIF, false for CFR/FOB). Determines if separate insurance adjustment is required in contract pricing.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentFormula rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Formula' ;
    rdfs:comment 'The formula or methodology used to adjust the base index price for product-specific quality parameters, grade differentials, or impurities (e.g., Fe% premium/discount schedule, penalty for silica above threshold, copper treatment and refining charges). May reference separate specification tables.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCeiling rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling' ;
    rdfs:comment 'The maximum price per unit above which the pricing basis will not rise, if a contractual ceiling is defined. Used in hedging and risk management. Null if no ceiling applies.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceFloor rdf:type rdf:Property ;
    rdfs:label 'Price Floor' ;
    rdfs:comment 'The minimum price per unit below which the pricing basis will not fall, if a contractual floor is defined. Used in hedging and risk management. Null if no floor applies.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'The benchmark price index or reference used for pricing (e.g., Platts IODEX 62% Fe CFR China, LME Copper Grade A, Newcastle Coal Index, Fastmarkets Lithium Hydroxide CIF Asia, LME Nickel). This is the industry-standard pricing benchmark against which the product is priced.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Price Unit Of Measure' ;
    rdfs:comment 'The unit of measure for pricing (e.g., USD/dmt for dry metric tonne, USD/t for tonne, USD/lb for pound, USD/kg for kilogram). Defines the denominator for the price.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasisCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis Code' ;
    rdfs:comment 'Unique business code identifying the pricing basis configuration (e.g., IODEX_62FE_CFR, LME_CU_A, NCI_6000, FMB_LIOH_CIF).' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasisName rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis Name' ;
    rdfs:comment 'Human-readable name of the pricing basis (e.g., Platts IODEX 62% Fe CFR China, LME Copper Grade A Cash, Newcastle Coal Index 6000 kcal/kg).' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingBasisStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis Status' ;
    rdfs:comment 'Current lifecycle status of the pricing basis configuration. Active indicates currently in use for new contracts; superseded indicates replaced by a newer version.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingLagDays rdf:type rdf:Property ;
    rdfs:label 'Pricing Lag Days' ;
    rdfs:comment 'The number of days between the reference event (e.g., Bill of Lading date, discharge date) and the start of the quotational period. Used to calculate the applicable pricing window.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refiningChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Refining Charge Applicable' ;
    rdfs:comment 'Indicates whether refining charges apply to this pricing basis. Refining charges are fees for refining metal to final purity, typically applied in conjunction with treatment charges for concentrates.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Treatment Charge Applicable' ;
    rdfs:comment 'Indicates whether treatment charges apply to this pricing basis. Treatment charges are fees deducted by smelters/refiners for processing concentrate into refined metal, common in copper and other base metal concentrates.' ;
    rdfs:domain ind:PricingBasis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredAnalyticalMethodId rdf:type rdf:Property ;
    rdfs:label 'Required Analytical Method Id' ;
    rdfs:comment 'Foreign key linking to laboratory.analytical_method. Business justification: Product specifications define required analytical methods for contractual quality assurance. Export products require specific accredited methods (e.g., ISO methods for iron ore). Links specification r' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalMethod .

ind:supersedesSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Specification Id' ;
    rdfs:comment 'Reference to the previous product specification that this version replaces, enabling specification lineage tracking.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:ashPercent rdf:type rdf:Property ;
    rdfs:label 'Ash Percent' ;
    rdfs:comment 'Ash content percentage for coal products, representing the non-combustible mineral matter remaining after complete combustion.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkDensityTPerM3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density T Per M3' ;
    rdfs:comment 'Bulk density of the product in tonnes per cubic meter, critical for storage, transport planning, and vessel loading calculations.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorificValueKcalPerKg rdf:type rdf:Property ;
    rdfs:label 'Calorific Value Kcal Per Kg' ;
    rdfs:comment 'Gross calorific value for coal products in kilocalories per kilogram, representing the energy content and primary pricing parameter for thermal coal.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractualReference rdf:type rdf:Property ;
    rdfs:label 'Contractual Reference' ;
    rdfs:comment 'Reference to the master offtake agreement, sales contract, or commercial framework under which this specification is defined and enforced.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeBasis rdf:type rdf:Property ;
    rdfs:label 'Grade Basis' ;
    rdfs:comment 'Basis on which chemical grade parameters are measured and reported (dry basis, as received, moisture free, air dried) for consistent quality assessment.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedAl2o3PercentMax rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Al2o3 Percent Max' ;
    rdfs:comment 'Contractually guaranteed maximum alumina content percentage, above which penalties or rejection may apply due to processing constraints.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedCuPercentMin rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Cu Percent Min' ;
    rdfs:comment 'Contractually guaranteed minimum copper content percentage for copper concentrate products, below which penalties or rejection may apply.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedFePercentMin rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Fe Percent Min' ;
    rdfs:comment 'Contractually guaranteed minimum iron content percentage for iron ore products, below which penalties or rejection may apply.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedMoisturePercentMax rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Moisture Percent Max' ;
    rdfs:comment 'Contractually guaranteed maximum moisture content percentage, above which penalties, weight adjustments, or rejection may apply.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedSio2PercentMax rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Sio2 Percent Max' ;
    rdfs:comment 'Contractually guaranteed maximum silica content percentage, above which penalties or rejection may apply due to quality constraints.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedSulfurPercentMax rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Sulfur Percent Max' ;
    rdfs:comment 'Contractually guaranteed maximum sulfur content percentage, above which penalties or rejection may apply due to environmental and processing constraints.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCustomerSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Customer Specific' ;
    rdfs:comment 'Flag indicating whether this specification is tailored for a specific customer (true) or represents a standard product offering (false).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExportSpecification rdf:type rdf:Property ;
    rdfs:label 'Is Export Specification' ;
    rdfs:comment 'Flag indicating whether this specification is used for export sales (true) or domestic sales (false), affecting regulatory compliance and documentation requirements.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:p80Microns rdf:type rdf:Property ;
    rdfs:label 'P80 Microns' ;
    rdfs:comment 'Particle size in microns at which 80% of the material by weight passes through, a key comminution and processing parameter.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingRequirement rdf:type rdf:Property ;
    rdfs:label 'Packaging Requirement' ;
    rdfs:comment 'Required packaging method for the product (bulk, bagged, containerized, intermediate bulk container, drums, supersacks) as specified in the sales contract.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productForm rdf:type rdf:Property ;
    rdfs:label 'Product Form' ;
    rdfs:comment 'Physical form of the mineral product (fines, lump, concentrate, pellets, briquettes, slurry, powder, granules, matte, hydroxide) as delivered to customers. [ENUM-REF-CANDIDATE: fines|lump|concentrate|pellets|briquettes|slurry|powder|granules|matte|hydroxide — promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandardReference rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Reference' ;
    rdfs:comment 'Reference to the international or industry quality standard (ISO, ASTM, JORC, CIM) that this specification complies with or is based upon.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Size Measurement Method' ;
    rdfs:comment 'Standard method used for particle size distribution determination (wet screening, dry screening, laser diffraction, sieve analysis).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDescription rdf:type rdf:Property ;
    rdfs:label 'Specification Description' ;
    rdfs:comment 'Detailed textual description of the product specification including any special conditions, handling requirements, or customer-specific modifications.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the product specification indicating whether it is in draft, actively used in contracts, superseded by a newer version, obsolete, suspended, or under review.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmlPercent rdf:type rdf:Property ;
    rdfs:label 'Tml Percent' ;
    rdfs:comment 'Transportable Moisture Limit for Group A cargoes under IMSBC Code, representing the maximum moisture content at which the cargo can be safely shipped without liquefaction risk.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalAl2o3Percent rdf:type rdf:Property ;
    rdfs:label 'Typical Al2o3 Percent' ;
    rdfs:comment 'Typical alumina content percentage, a key impurity parameter for iron ore and other mineral products affecting downstream processing efficiency.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalCuPercent rdf:type rdf:Property ;
    rdfs:label 'Typical Cu Percent' ;
    rdfs:comment 'Typical copper content percentage for copper concentrate products, representing the average Cu grade expected under normal production conditions.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalFePercent rdf:type rdf:Property ;
    rdfs:label 'Typical Fe Percent' ;
    rdfs:comment 'Typical iron content percentage for iron ore products, representing the average Fe grade expected under normal production conditions.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalMoisturePercent rdf:type rdf:Property ;
    rdfs:label 'Typical Moisture Percent' ;
    rdfs:comment 'Typical moisture content percentage representing the average moisture level expected under normal production and storage conditions.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalSio2Percent rdf:type rdf:Property ;
    rdfs:label 'Typical Sio2 Percent' ;
    rdfs:comment 'Typical silica content percentage, a key gangue mineral parameter affecting product quality and downstream processing requirements.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalSulfurPercent rdf:type rdf:Property ;
    rdfs:label 'Typical Sulfur Percent' ;
    rdfs:comment 'Typical sulfur content percentage, a critical impurity parameter for iron ore, coal, and copper products affecting environmental compliance and processing.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volatileMatterPercent rdf:type rdf:Property ;
    rdfs:label 'Volatile Matter Percent' ;
    rdfs:comment 'Volatile matter content percentage for coal products, indicating the proportion of gaseous products released during heating, affecting combustion characteristics.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationRevisionId rdf:type rdf:Property ;
    rdfs:label 'Specification Revision Id' ;
    rdfs:comment 'Unique identifier for each product specification revision record. Primary key for the product specification revision entity.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededRevisionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Revision Id' ;
    rdfs:comment 'Reference to the previous product specification revision that this revision replaces. Enables full version history tracking and audit trail of specification evolution over time. Nullable for the initial specification revision.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecificationRevision .

ind:changeReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Change Reason Category' ;
    rdfs:comment 'Primary business driver for this specification revision. Process improvement indicates internal operational enhancement, market requirement indicates competitive positioning, regulatory update indicates compliance mandate, customer request indicates specific buyer need, cost optimization indicates economic efficiency, quality enhancement indicates product performance improvement.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why this specification revision was initiated, including business context, stakeholder input, and expected benefits. Supports audit trail and commercial renegotiation justification.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost impact estimate (e.g., USD, AUD, CAD). Ensures consistent financial reporting and currency conversion.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate' ;
    rdfs:comment 'Estimated change in operating expenditure (OPEX) or capital expenditure (CAPEX) resulting from this specification revision, expressed in the reporting currency. Positive values indicate cost increases, negative values indicate savings. Used for financial planning and pricing adjustments.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which customers were formally notified of this specification revision. Used to track compliance with contractual notice periods and manage customer expectations.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether formal notification to customers is required under contract terms (typically 30-90 days advance notice for material specification changes). True if notification is mandatory, false if change is immaterial.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeParameterChanges rdf:type rdf:Property ;
    rdfs:label 'Grade Parameter Changes' ;
    rdfs:comment 'Detailed listing of changes to mineral grade specifications (e.g., Fe min/max, Cu grade, ash content, sulfur limits, phosphorus limits, alumina, silica). Structured as parameter name, old value, new value, and tolerance. Critical for assay compliance and pricing adjustments.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedContractCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Contract Count' ;
    rdfs:comment 'Number of active offtake agreements, sales contracts, or customer commitments that are affected by this specification revision. Used for prioritizing commercial engagement and risk assessment.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan Reference' ;
    rdfs:comment 'Reference identifier or document link to the detailed implementation plan for this specification revision (e.g., project code, work breakdown structure (WBS) reference, change request number). Links to project management systems for tracking execution.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impurityLimitChanges rdf:type rdf:Property ;
    rdfs:label 'Impurity Limit Changes' ;
    rdfs:comment 'Changes to maximum allowable levels of deleterious elements (e.g., phosphorus, sulfur, arsenic, lead, mercury, cadmium). Critical for steel-making quality, environmental compliance, and penalty clauses in offtake agreements.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureLimitChange rdf:type rdf:Property ;
    rdfs:label 'Moisture Limit Change' ;
    rdfs:comment 'Change to maximum allowable moisture content specification (e.g., from 8.0% to 7.5%). Impacts shipping weight calculations, cargo stability, and customer acceptance criteria per Incoterms.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newSpecificationSummary rdf:type rdf:Property ;
    rdfs:label 'New Specification Summary' ;
    rdfs:comment 'Snapshot of the key specification parameters in this revision (e.g., Fe content 62.5-64.0%, moisture max 7.5%, size 0-10mm). Defines the new quality standards for production, assay validation, and customer acceptance.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offtakeAgreementImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Offtake Agreement Impact Flag' ;
    rdfs:comment 'Indicates whether this specification revision affects existing offtake agreements and may require commercial renegotiation, customer notification, or pricing adjustments. True if contracts are impacted, false if change is within existing tolerance bands.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingStandardChange rdf:type rdf:Property ;
    rdfs:label 'Packaging Standard Change' ;
    rdfs:comment 'Change to packaging, containerization, or bulk handling specifications (e.g., bulk vessel shipment, ISO container, super sacks, drums). Impacts logistics costs, handling procedures, and customer receiving facilities.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSpecificationSummary rdf:type rdf:Property ;
    rdfs:label 'Previous Specification Summary' ;
    rdfs:comment 'Snapshot of the key specification parameters from the prior revision (e.g., Fe content 62.0-63.5%, moisture max 8.0%, size 0-10mm). Enables before-and-after comparison and impact analysis for existing contracts.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingAdjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether this specification revision necessitates a change in product pricing, premium/discount structures, or penalty clauses in sales contracts. True if pricing renegotiation is required, false if existing pricing remains valid.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionProcessImpact rdf:type rdf:Property ;
    rdfs:label 'Production Process Impact' ;
    rdfs:comment 'Description of changes required in mining, processing, or beneficiation operations to meet the new specification (e.g., adjusted crusher settings, modified flotation reagents, tighter blending controls). Informs operational planning and capital expenditure (CAPEX) requirements.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlProcedureUpdate rdf:type rdf:Property ;
    rdfs:label 'Quality Control Procedure Update' ;
    rdfs:comment 'Reference to updated quality control procedures, sampling protocols, or assay methods required to verify compliance with the new specification (e.g., increased sampling frequency, new analytical method for trace elements). Links to Laboratory Information Management System (LIMS) procedures.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Impact' ;
    rdfs:comment 'Description of how this specification revision relates to regulatory requirements (e.g., new environmental limits on heavy metals, updated export standards, revised safety data sheet requirements). Links to specific regulations or standards.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionStatus rdf:type rdf:Property ;
    rdfs:label 'Revision Status' ;
    rdfs:comment 'Current lifecycle status of this specification revision. Draft indicates work in progress, under review indicates pending approval, approved indicates ready for implementation, active indicates currently in force, superseded indicates replaced by newer revision, withdrawn indicates cancelled before activation.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeDistributionChange rdf:type rdf:Property ;
    rdfs:label 'Size Distribution Change' ;
    rdfs:comment 'Change to particle size specifications (e.g., lump 6-31mm, fines 0-6mm, concentrate -150 micron 80%). Affects downstream processing efficiency, handling characteristics, and customer blending requirements.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewCommittee rdf:type rdf:Property ;
    rdfs:label 'Technical Review Committee' ;
    rdfs:comment 'Name of the cross-functional committee or working group that reviewed and validated the technical feasibility of this specification revision (e.g., Product Quality Committee, Technical Services Team). Ensures multi-disciplinary input from geology, processing, quality, and commercial functions.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Technical Review Date' ;
    rdfs:comment 'Date on which the technical review committee completed their assessment of this specification revision. Precedes formal approval and marks completion of technical due diligence.' ;
    rdfs:domain ind:SpecificationRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifyingLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Certifying Laboratory Id' ;
    rdfs:comment 'Foreign key linking to laboratory.laboratory. Business justification: Export products require quality certificates from specific accredited laboratories for market access and customer acceptance. Tracks the approved certifying laboratory relationship for regulatory comp' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:availableForSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Available For Sale Flag' ;
    rdfs:comment 'Indicates whether the product is currently available for inclusion in new sales contracts and shipment nominations. False when product is temporarily unavailable due to plant maintenance, feedstock constraints, or quality holds.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benchmarkIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Index' ;
    rdfs:comment 'Name of the published commodity price index or assessment used as the reference for contract pricing. Examples: \'Platts IODEX 62% Fe CFR China\', \'LME Nickel 3-month\', \'IHS McCloskey Newcastle Coal\', \'Fastmarkets MB Lithium Hydroxide CIF Asia\'. Empty for products with purely negotiated pricing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintKgCo2ePerTonne rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kg Co2e Per Tonne' ;
    rdfs:comment 'Estimated greenhouse gas emissions intensity for producing one tonne of this saleable product, expressed as kilograms of CO2 equivalent. Includes Scope 1 and Scope 2 emissions from mining, processing, and on-site logistics. Used for customer carbon accounting and regulatory reporting.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental or sustainability certification(s) held for this product, if any. Examples: \'ResponsibleSteel\', \'Copper Mark\', \'Initiative for Responsible Mining Assurance (IRMA)\', \'ISO 14001 Certified Site\'. Increasingly required by customers for ESG compliance and supply chain transparency.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportLicenseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Export License Required Flag' ;
    rdfs:comment 'Indicates whether an export license or permit is required from the country of origin government to ship this product internationally. True for strategic minerals, rare earths, or products subject to export controls or quotas.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeSpecification rdf:type rdf:Property ;
    rdfs:label 'Grade Specification' ;
    rdfs:comment 'Target grade or concentration of the valuable mineral component expressed as percentage or parts per million. Examples: \'62.0% Fe\', \'25% Cu\', \'70% Ni\', \'99.5% LiOH·H2O\'. This is the headline specification that drives product pricing and customer acceptance.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'International hazardous materials classification code if the product is regulated for transport. Examples: UN 3077 (Environmentally Hazardous Substance, Solid), UN 3264 (Corrosive Liquid, Acidic, Inorganic). Empty if product is non-hazardous. Governs shipping documentation, vessel requirements, and emergency response procedures.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impurityLimits rdf:type rdf:Property ;
    rdfs:label 'Impurity Limits' ;
    rdfs:comment 'Specification of maximum allowable concentrations for deleterious impurity elements that negatively impact customer processing or final product quality. Expressed as comma-separated element:limit pairs. Examples: \'P:0.08%, S:0.05%, As:0.01%\' for iron ore; \'Hg:1ppm, Cd:5ppm\' for copper concentrate. Penalties may apply if limits are exceeded.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermDefault rdf:type rdf:Property ;
    rdfs:label 'Incoterm Default' ;
    rdfs:comment 'Default Incoterm used for pricing and risk transfer in sales contracts for this product. FOB (Free on Board) and CIF (Cost, Insurance and Freight) are most common for bulk mineral commodities. Defines seller and buyer responsibilities for logistics, insurance, and customs. [ENUM-REF-CANDIDATE: EXW|FCA|FAS|FOB|CFR|CIF|CPT|CIP|DAP|DPU|DDP — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current stage in the product\'s commercial lifecycle. Development: under testing, not yet offered. Qualified: approved for sale, customer trials ongoing. Active: fully commercialized and available. Sunset: being phased out, existing contracts honored. Discontinued: no longer offered or produced. Governs whether product can be included in new sales contracts.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Tonnes' ;
    rdfs:comment 'Minimum commercial order quantity in metric tonnes. Driven by production batch sizes, shipping economics (vessel parcel sizes), and inventory management. Typical values: 50,000-170,000 tonnes for bulk iron ore/coal shipments, 500-2,000 tonnes for concentrates, 20-100 tonnes for specialty chemicals.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentMaxPct rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Max Pct' ;
    rdfs:comment 'Maximum allowable moisture content as percentage of total mass. Critical specification for shipping weight calculations, pricing adjustments, and customer process efficiency. Typical ranges: iron ore 8-10%, coal 10-15%, concentrates 8-12%.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingStandard rdf:type rdf:Property ;
    rdfs:label 'Packaging Standard' ;
    rdfs:comment 'Standard packaging or shipping format for the product. Bulk options for high-volume commodities (iron ore, coal), containerized or bagged options for specialty products (lithium chemicals, precious metal concentrates). Determines logistics costs and handling requirements. [ENUM-REF-CANDIDATE: bulk_vessel|bulk_rail|bulk_truck|ibc_tote|drum|bag_1mt|bag_25kg|container_20ft|container_40ft — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Externally-known unique business identifier for the saleable product used in commercial documentation, contracts, and customer communications. Typically follows company-specific coding standards combining commodity type, grade, and form.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productManagerName rdf:type rdf:Property ;
    rdfs:label 'Product Manager Name' ;
    rdfs:comment 'Name of the commercial product manager or marketing manager responsible for this product\'s market positioning, pricing strategy, and customer relationships. Business reference, not classified as PII.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable commercial name of the saleable product as it appears on invoices, contracts, and marketing materials. Examples: \'Iron Ore Fines 62% Fe\', \'Copper Concentrate 25% Cu\', \'Thermal Coal 6000 kcal NAR\', \'Lithium Hydroxide Monohydrate Battery Grade\'.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Product Specification Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the authoritative product specification document that defines all technical parameters, test methods, sampling protocols, and acceptance criteria. Typically a controlled document in the company document management system.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a third-party or company-issued quality certificate (assay certificate, certificate of analysis) must accompany each shipment. True for most mineral concentrates and specialty products where grade and impurity verification is contractually required.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizingSpecification rdf:type rdf:Property ;
    rdfs:label 'Sizing Specification' ;
    rdfs:comment 'Particle size distribution specification defining the acceptable range of particle sizes, typically expressed as percentage passing through standard mesh screens. Example: \'90% passing 6.3mm, 10% max passing 150 micron\'. Critical for customer handling systems and process performance.' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Primary customer industry segment or end-use application for which this product variant is designed and marketed. Influences specification tolerances, packaging, and logistics requirements. [ENUM-REF-CANDIDATE: steel_mills|smelters|refineries|battery_manufacturers|chemical_plants|power_generation|construction|automotive|electronics — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SaleableProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Size Specification Id' ;
    rdfs:comment 'Unique identifier for the size specification record. Primary key for the size specification entity.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededBySpecificationSizeSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Specification Size Specification Id' ;
    rdfs:comment 'Reference to the newer size specification that replaces this one when status is superseded. Maintains specification lineage and change history.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SizeSpecification .

ind:blendingTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Blending Tolerance Pct' ;
    rdfs:comment 'Allowable deviation percentage for size parameters when blending multiple ore sources to meet specification. Used in ROM (Run of Mine) pad management and stockpile blending strategies.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crushSizeTargetMm rdf:type rdf:Property ;
    rdfs:label 'Crush Size Target Mm' ;
    rdfs:comment 'Target crush size in millimeters for products that undergo crushing or grinding. Specifies the desired output size from comminution circuits.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSpecificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Specification Flag' ;
    rdfs:comment 'Indicates whether this size specification is a custom requirement for a specific customer contract (True) or a standard product specification (False).' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:d90TargetMicron rdf:type rdf:Property ;
    rdfs:label 'D90 Target Micron' ;
    rdfs:comment 'Target particle size in microns at which 90% of the material is finer. Alternative specification metric used in some concentrate contracts.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finesSizeRangeMm rdf:type rdf:Property ;
    rdfs:label 'Fines Size Range Mm' ;
    rdfs:comment 'Textual representation of the fines size range (e.g., -6mm, -10mm) for iron ore fines products. Used in product marketing and customer specifications.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lumpSizeRangeMm rdf:type rdf:Property ;
    rdfs:label 'Lump Size Range Mm' ;
    rdfs:comment 'Textual representation of the lump size range (e.g., 6-31mm, 8-40mm) for iron ore lump products. Used in product marketing and customer specifications.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalBottomSizeMm rdf:type rdf:Property ;
    rdfs:label 'Nominal Bottom Size Mm' ;
    rdfs:comment 'The minimum particle size in millimeters that defines the lower limit of the size distribution. Distinguishes between lump and fines products.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalTopSizeMm rdf:type rdf:Property ;
    rdfs:label 'Nominal Top Size Mm' ;
    rdfs:comment 'The maximum particle size in millimeters that defines the upper limit of the size distribution. Critical for downstream processing equipment compatibility and customer specifications.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversizeLimitPct rdf:type rdf:Property ;
    rdfs:label 'Oversize Limit Pct' ;
    rdfs:comment 'Maximum allowable percentage of particles exceeding the nominal top size. Exceeding this limit may result in product rejection or price penalties.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p50TargetMicron rdf:type rdf:Property ;
    rdfs:label 'P50 Target Micron' ;
    rdfs:comment 'Target median particle size in microns at which 50% of the material passes through. Used for fine-grind concentrate specifications and process control.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:p80TargetMicron rdf:type rdf:Property ;
    rdfs:label 'P80 Target Micron' ;
    rdfs:comment 'Target particle size in microns at which 80% of the material passes through. Critical specification for concentrates and ground products used in downstream processing (flotation, leaching, smelting).' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumProductFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Product Flag' ;
    rdfs:comment 'Indicates whether this size specification defines a premium-grade product that commands higher pricing due to tighter size control and superior downstream processing characteristics.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Classification of the product form based on particle size characteristics. Lump refers to coarse ore pieces, fines to fine particles, concentrate to processed high-grade material. [ENUM-REF-CANDIDATE: lump|fines|concentrate|pellet|sinter_feed|chip|briquette — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenApertureSeries rdf:type rdf:Property ;
    rdfs:label 'Screen Aperture Series' ;
    rdfs:comment 'The standard sieve series used for size analysis (e.g., Tyler, ISO R20, ASTM E11). Defines the specific screen sizes used in particle size distribution testing.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeDistributionCurve rdf:type rdf:Property ;
    rdfs:label 'Size Distribution Curve' ;
    rdfs:comment 'Textual or encoded representation of the full particle size distribution curve, showing cumulative percentage passing at multiple size fractions. Used for detailed quality analysis and process optimization.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandardReference rdf:type rdf:Property ;
    rdfs:label 'Test Standard Reference' ;
    rdfs:comment 'The specific industry or international standard method reference used for size analysis (e.g., ISO 4701, ASTM D4749, AS 4264.1). Ensures consistent and comparable test results.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:undersizeLimitPct rdf:type rdf:Property ;
    rdfs:label 'Undersize Limit Pct' ;
    rdfs:comment 'Maximum allowable percentage of particles below the nominal bottom size. Critical for lump products where excessive fines reduce value and handling characteristics.' ;
    rdfs:domain ind:SizeSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Budget Amendment Id' ;
    rdfs:comment 'Unique identifier for the budget amendment record. Primary key for the budget amendment entity.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costEstimateId rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Id' ;
    rdfs:comment 'Foreign key linking to project.cost_estimate. Business justification: Budget amendments are supported by revised cost estimates. When requesting additional funds (AFE variation), a new estimate is prepared to justify the amendment. This links the amendment to its suppor' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostEstimate .

ind:projectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Id' ;
    rdfs:comment 'Foreign key linking to project.project_budget. Business justification: Budget amendments modify approved project budgets. Currently budget_amendment has project_id but no FK to project_budget. This is a parent-child relationship - amendments are changes to a specific bud' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:amendmentAmount rdf:type rdf:Property ;
    rdfs:label 'Amendment Amount' ;
    rdfs:comment 'The incremental budget change requested in this amendment. Positive values indicate budget increases; negative values indicate budget reductions. This is the delta amount, not the new total. Expressed in the project\'s functional currency.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Detailed narrative explanation of why the budget amendment is required. Captures the business justification, root cause analysis, and rationale for the budget change. This field provides the audit trail context for the amendment decision.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderReference rdf:type rdf:Property ;
    rdfs:label 'Change Order Reference' ;
    rdfs:comment 'Reference to the formal change order document if this budget amendment is associated with a scope or design change. Links the amendment to the change control process and provides traceability to engineering or procurement variations.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyAmountUsed rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount Used' ;
    rdfs:comment 'The amount of project contingency reserve utilized by this amendment if contingency_drawdown_flag is True. Tracks depletion of contingency funds and remaining risk buffer. Expressed in the project\'s functional currency.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyDrawdownFlag rdf:type rdf:Property ;
    rdfs:label 'Contingency Drawdown Flag' ;
    rdfs:comment 'Indicates whether this budget amendment is funded from the project\'s contingency reserve (True) or requires new budget allocation (False). Used for contingency management and budget governance.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactOnIrr rdf:type rdf:Property ;
    rdfs:label 'Impact On Irr' ;
    rdfs:comment 'The estimated change in project Internal Rate of Return (percentage points) resulting from this budget amendment. Positive values indicate IRR improvement; negative values indicate IRR reduction. Used for investment decision analysis and hurdle rate assessment.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactOnNpv rdf:type rdf:Property ;
    rdfs:label 'Impact On Npv' ;
    rdfs:comment 'The estimated change in project Net Present Value resulting from this budget amendment. Positive values indicate NPV improvement; negative values indicate NPV reduction. Used for investment decision analysis and project viability assessment. Expressed in the project\'s functional currency.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Original Approved Amount' ;
    rdfs:comment 'The total approved project budget amount prior to this amendment. Represents the baseline budget that this amendment is modifying. Expressed in the project\'s functional currency.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedTotalBudget rdf:type rdf:Property ;
    rdfs:label 'Revised Total Budget' ;
    rdfs:comment 'The new total approved project budget after applying this amendment. Calculated as original_approved_amount plus amendment_amount. Represents the updated budget ceiling for the project. Expressed in the project\'s functional currency.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRegisterReference rdf:type rdf:Property ;
    rdfs:label 'Risk Register Reference' ;
    rdfs:comment 'Reference to the risk register entry if this budget amendment is triggered by a materialized project risk. Links the amendment to the formal risk management process and provides traceability to risk mitigation actions.' ;
    rdfs:domain ind:BudgetAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'The estimated impact on project schedule in calendar days resulting from this budget amendment. Positive values indicate schedule extension; negative values indicate schedule acceleration; zero indicates no schedule impact. Used for critical path analysis and project timeline management.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageGatePhase rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Phase' ;
    rdfs:comment 'The project stage gate phase during which this budget amendment was submitted. Aligns with the project lifecycle governance framework and stage-gate approval process used in mining capital projects. [ENUM-REF-CANDIDATE: feasibility|pre_feasibility|detailed_design|procurement|construction|commissioning|handover — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation for the budget amendment (e.g., cost estimates, engineering drawings, vendor quotes, risk assessments). Provides traceability to the evidence base for the amendment request.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the sponsoring business unit or division responsible for funding and owning the capital project outcomes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:capitalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capital Manager Employee Id' ;
    rdfs:comment 'Reference to the employee assigned as the accountable project manager responsible for delivery of scope, schedule, and budget.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capitalSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capital Sponsor Employee Id' ;
    rdfs:comment 'Reference to the senior executive or business leader who sponsors the project and provides strategic direction and funding authority.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closureProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Closure Provision Amount' ;
    rdfs:comment 'Estimated financial provision for mine rehabilitation and closure obligations associated with the project, required for regulatory compliance and financial reporting.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractStrategy rdf:type rdf:Property ;
    rdfs:label 'Contract Strategy' ;
    rdfs:comment 'Primary contracting and delivery model for the project: EPC (engineering, procurement, construction), EPCM (engineering, procurement, construction management), alliance, construct_only, design_build, or owner_operated.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacity rdf:type rdf:Property ;
    rdfs:label 'Design Capacity' ;
    rdfs:comment 'Nameplate design capacity of the asset being constructed or expanded, expressed in the appropriate unit of measure for the commodity (e.g., tonnes per annum for processing plants, metres for shafts).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityUnit rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Unit' ;
    rdfs:comment 'Unit of measure for the design capacity: tpa (tonnes per annum), mtpa (million tonnes per annum), mw (megawatts), km (kilometres), m (metres), or units (discrete items).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eisReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Eis Reference Number' ;
    rdfs:comment 'Official reference number of the environmental impact statement submitted to regulatory authorities for the project.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Approval Status' ;
    rdfs:comment 'Status of environmental impact statement (EIS) and regulatory approvals required for the project to proceed, critical for permitting and compliance.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCompletionCost rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Cost' ;
    rdfs:comment 'Current forecast of the total cost to complete the project, including all committed and anticipated expenditures, used for variance analysis and cost control.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Date' ;
    rdfs:comment 'Current forecast date for project completion based on progress to date and remaining work, used for schedule variance analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'Date on which the completed project was formally handed over from the project team to the operational business unit, transferring accountability for ongoing performance.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irrPercentage rdf:type rdf:Property ;
    rdfs:label 'Irr Percentage' ;
    rdfs:comment 'Internal rate of return percentage calculated during feasibility studies, representing the discount rate at which NPV equals zero, used to assess project viability.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifeOfMineYears rdf:type rdf:Property ;
    rdfs:label 'Life Of Mine Years' ;
    rdfs:comment 'Expected operational life of the mine or asset in years, used for project economic modeling and closure planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Scheduled date for project commissioning and handover to operations, as per the approved baseline schedule.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the project scope, objectives, deliverables, and strategic rationale, used in business cases and governance documentation.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by development approach: greenfield (new mine site), brownfield (existing site development), sustaining capital (maintain current production), expansion (increase capacity), closure (rehabilitation and decommissioning), or infrastructure (roads, power, water).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionDate rdf:type rdf:Property ;
    rdfs:label 'Sanction Date' ;
    rdfs:comment 'Date on which the project received final investment decision (FID) approval from the board or investment committee, authorizing full execution.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicAlignment rdf:type rdf:Property ;
    rdfs:label 'Strategic Alignment' ;
    rdfs:comment 'Description of how the project aligns with corporate strategy, business unit objectives, and long-term portfolio plans.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or title of the individual or governance body authorized to approve or reject the change order (e.g., Project Manager, Project Director, Change Control Board, Steering Committee). Reflects delegation of authority based on change order value and impact.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Update Flag' ;
    rdfs:comment 'Boolean indicator of whether the approved change order has been incorporated into the project baseline (scope, schedule, cost). True indicates baseline has been updated; False indicates pending baseline update.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Impact Amount' ;
    rdfs:comment 'Portion of the cost impact that affects capital expenditure budget. Used for tracking changes to capitalized project costs and asset valuation.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeJustification rdf:type rdf:Property ;
    rdfs:label 'Change Justification' ;
    rdfs:comment 'Business rationale and justification for the change order. Explains why the change is necessary, the risks of not implementing it, and the expected benefits or risk mitigation achieved.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Change Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for the change order, typically following organizational numbering convention (e.g., CO-000123). Used for communication, approvals, and audit trails.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Change Order Status' ;
    rdfs:comment 'Current lifecycle status of the change order in the approval and implementation workflow. Tracks progression from initial draft through approval to implementation and closure. [ENUM-REF-CANDIDATE: Draft|Submitted|Under Review|Approved|Rejected|Withdrawn|Implemented|Closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Total financial impact of the change order on the project budget, expressed in the project currency. Positive values indicate cost increases; negative values indicate cost savings. Used for budget amendment and cost control reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalPathImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether the change order impacts activities on the project critical path. True indicates the change affects critical path and may delay project completion; False indicates non-critical path impact.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Hse Impact Assessment' ;
    rdfs:comment 'Assessment of how the change order affects health, safety, and environmental aspects of the project. Identifies new HSE risks, mitigation measures, or improvements to HSE performance.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date when the approved change order was implemented and incorporated into the project baseline (scope, schedule, budget). Used for tracking change order execution and project baseline updates.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Impact Description' ;
    rdfs:comment 'Narrative description of how the change order affects key project milestones, including which milestones are impacted and the nature of the impact (delay, acceleration, scope change).' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Impact Amount' ;
    rdfs:comment 'Portion of the cost impact that affects operating expenditure budget. Used for tracking changes to operational costs during commissioning or early operations phases.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatorName rdf:type rdf:Property ;
    rdfs:label 'Originator Name' ;
    rdfs:comment 'Name of the individual or party who initiated the change order request. May be internal project team member, contractor, consultant, or regulatory authority.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorOrganization rdf:type rdf:Property ;
    rdfs:label 'Originator Organization' ;
    rdfs:comment 'Organization or company that the change order originator represents (e.g., owner, contractor, subcontractor, engineering firm, regulatory body).' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Assessment' ;
    rdfs:comment 'Assessment of how the change order affects project quality standards, specifications, or deliverable quality. Identifies any quality improvements or potential quality risks.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the change order was formally rejected by the approving authority. Null if not rejected.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'Target date by which the change order decision is required to avoid project delays or other negative impacts. Used for prioritizing review and approval activities.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Assessment' ;
    rdfs:comment 'Assessment of how the change order affects project risks, including new risks introduced, existing risks mitigated, or changes to risk exposure. Supports risk-informed decision-making.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Impact Description' ;
    rdfs:comment 'Detailed description of how the change order modifies the project scope, including additions, deletions, or modifications to deliverables, specifications, or work breakdown structure elements.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocuments rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents' ;
    rdfs:comment 'References or file paths to supporting documentation for the change order, such as technical drawings, cost estimates, schedule impact analysis, risk assessments, or regulatory correspondence.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user who last modified the change order record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Explanation provided by the originator for withdrawing the change order before approval decision. Null if the change order was not withdrawn.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorActivityCommissioningActivityId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Activity Commissioning Activity Id' ;
    rdfs:comment 'Reference to the preceding commissioning activity that must be completed before this activity can commence, establishing logical dependencies in the commissioning sequence.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissioningActivity .

ind:responsibleContractorId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contractor Id' ;
    rdfs:comment 'Reference to the contractor or vendor organization responsible for executing the commissioning activity, if applicable.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contractor .

ind:acceptanceCriteriaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Met Flag' ;
    rdfs:comment 'Boolean indicator of whether the commissioning activity met all defined acceptance criteria. True indicates criteria met; False indicates criteria not met.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the commissioning activity within the project commissioning plan. Used for tracking and reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityName rdf:type rdf:Property ;
    rdfs:label 'Activity Name' ;
    rdfs:comment 'Descriptive name of the commissioning activity, clearly identifying the work to be performed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'Actual duration of the commissioning activity in calendar days, calculated from actual start to actual completion. Null if activity is not yet completed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningSystem rdf:type rdf:Property ;
    rdfs:label 'Commissioning System' ;
    rdfs:comment 'The specific system or subsystem being commissioned, such as crushing circuit, conveyor system, flotation bank, SAG mill, tailings pipeline, or electrical distribution system.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPunchListCount rdf:type rdf:Property ;
    rdfs:label 'Critical Punch List Count' ;
    rdfs:comment 'Number of critical or high-priority punch list items that must be resolved before the system can be handed over to operations.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code identifying the primary reason for any delay in completing the commissioning activity, such as equipment unavailability, weather, resource constraints, or design changes.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'Detailed description of the reason for any delay in completing the commissioning activity.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplineCode rdf:type rdf:Property ;
    rdfs:label 'Discipline Code' ;
    rdfs:comment 'Engineering discipline responsible for the commissioning activity: mechanical, electrical, instrumentation and control, process, civil, structural, or piping. [ENUM-REF-CANDIDATE: mechanical|electrical|instrumentation|process|civil|structural|piping — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Handover Readiness Flag' ;
    rdfs:comment 'Boolean indicator of whether the commissioning activity has been completed to a standard that allows handover to operations. True indicates ready for handover; False indicates not ready.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Percentage completion of the commissioning activity, expressed as a value between 0.00 and 100.00. Based on physical progress assessment.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Planned duration of the commissioning activity in calendar days, from start to completion.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListItemCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Item Count' ;
    rdfs:comment 'Number of outstanding punch list items or deficiencies identified during commissioning that require resolution before final handover. Zero indicates no outstanding items.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Safety Permit Number' ;
    rdfs:comment 'Work permit or safety authorization number required for executing the commissioning activity, ensuring compliance with Health, Safety, and Environment (HSE) protocols.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffAuthority rdf:type rdf:Property ;
    rdfs:label 'Sign Off Authority' ;
    rdfs:comment 'Name or role of the person or authority who provided formal sign-off approval for the commissioning activity.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemTagNumber rdf:type rdf:Property ;
    rdfs:label 'System Tag Number' ;
    rdfs:comment 'Engineering tag number or identifier for the system or equipment being commissioned, as per Piping and Instrumentation Diagram (P&ID) or asset register.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Reference' ;
    rdfs:comment 'Document reference or identifier for the commissioning test procedure or work instruction that governs this activity.' ;
    rdfs:domain ind:CommissioningActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Cost Commitment Id' ;
    rdfs:comment 'Unique identifier for the cost commitment record. Primary key for the cost commitment entity.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCommitment .

ind:originalCommitmentCostCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Original Commitment Cost Commitment Id' ;
    rdfs:comment 'Reference to the original cost commitment if this is a change order or amendment. Enables tracking of commitment history and cumulative changes.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCommitment .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement buyer or contracts administrator responsible for managing this commitment. Provides procurement accountability and escalation contact.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business identifier for the cost commitment. Externally-known unique number used for tracking and reference in procurement and project management systems. Typically a purchase order number, contract number, or letter of intent reference.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned or contracted date for delivery of goods or completion of services. Used for project schedule integration and progress tracking.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Cumulative amount invoiced against this commitment to date. Tracks the progression from commitment to actual cost as invoices are received and processed.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChangeOrder rdf:type rdf:Property ;
    rdfs:label 'Is Change Order' ;
    rdfs:comment 'Indicates whether this commitment represents a change order or variation to an existing contract. Used for tracking scope changes and cost overruns.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingCommitment rdf:type rdf:Property ;
    rdfs:label 'Remaining Commitment' ;
    rdfs:comment 'Uncommitted balance remaining on this commitment. Calculated as committed amount minus invoiced amount, representing the outstanding obligation.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the person or role who initiated the purchase requisition or commitment request. Provides accountability and contact reference for commitment queries.' ;
    rdfs:domain ind:CostCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Percentage' ;
    rdfs:comment 'Percentage of payment withheld as retention until contract completion or defects liability period expiry. Common in construction and engineering contracts for quality assurance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Risk classification of the commitment based on vendor performance, contract complexity, delivery criticality, or financial exposure. Supports risk-based project management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseId rdf:type rdf:Property ;
    rdfs:label 'Phase Id' ;
    rdfs:comment 'Foreign key linking to project.phase. Business justification: Cost estimates are prepared for specific project phases (Concept, Pre-Feasibility, Feasibility, FEED, Execute). Currently cost_estimate has capex_phase as STRING which should be normalized to FK. This' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Phase .

ind:supersededByEstimateCostEstimateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Estimate Cost Estimate Id' ;
    rdfs:comment 'Reference to the subsequent cost estimate that supersedes this version, enabling tracking of estimate evolution and version lineage.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostEstimate .

ind:accuracyRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Accuracy Range High' ;
    rdfs:comment 'The upper bound of the expected accuracy range for this estimate class, expressed as a positive percentage (e.g., +30 for +30%). Indicates potential overestimation.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accuracyRangeLow rdf:type rdf:Property ;
    rdfs:label 'Accuracy Range Low' ;
    rdfs:comment 'The lower bound of the expected accuracy range for this estimate class, expressed as a negative percentage (e.g., -20 for -20%). Indicates potential underestimation.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Estimate Amount' ;
    rdfs:comment 'The total estimated capital cost at the base date, excluding contingency and escalation. Represents the direct and indirect costs for all project scope elements.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'The contingency amount expressed as a percentage of the base estimate, typically aligned with the estimate class accuracy range.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Amount' ;
    rdfs:comment 'The portion of the base estimate attributable to direct project costs including materials, equipment, labor, and subcontracts directly tied to physical construction and installation.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationAmount rdf:type rdf:Property ;
    rdfs:label 'Escalation Amount' ;
    rdfs:comment 'The monetary allowance for cost escalation from the base date to the expected expenditure period, accounting for inflation and market price movements.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Percentage' ;
    rdfs:comment 'The escalation amount expressed as a percentage of the base estimate, reflecting anticipated inflation rates over the project execution period.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimateBaseDate rdf:type rdf:Property ;
    rdfs:label 'Estimate Base Date' ;
    rdfs:comment 'The reference date for which all cost estimates are stated, representing the pricing basis before escalation adjustments. Critical for comparing estimates prepared at different times.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimateBasisNarrative rdf:type rdf:Property ;
    rdfs:label 'Estimate Basis Narrative' ;
    rdfs:comment 'Detailed textual description of the assumptions, scope boundaries, exclusions, data sources, and key drivers underlying this cost estimate. Provides context for estimate interpretation and comparison.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateClass rdf:type rdf:Property ;
    rdfs:label 'Estimate Class' ;
    rdfs:comment 'AACE International estimate classification indicating the level of project definition and expected accuracy range. Class 5 (concept screening, -20% to -50% / +30% to +100%), Class 4 (feasibility study, -15% to -30% / +20% to +50%), Class 3 (budget authorization, -10% to -20% / +10% to +30%), Class 2 (control/bid, -5% to -15% / +5% to +20%), Class 1 (check estimate, -3% to -10% / +3% to +15%).' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateNotes rdf:type rdf:Property ;
    rdfs:label 'Estimate Notes' ;
    rdfs:comment 'Additional comments, clarifications, or special considerations related to this cost estimate that provide context for users and decision-makers.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateNumber rdf:type rdf:Property ;
    rdfs:label 'Estimate Number' ;
    rdfs:comment 'Business identifier or document number assigned to this cost estimate for tracking and reference purposes.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatePreparationDate rdf:type rdf:Property ;
    rdfs:label 'Estimate Preparation Date' ;
    rdfs:comment 'The date when this cost estimate was prepared or finalized by the estimating team.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimateVersion rdf:type rdf:Property ;
    rdfs:label 'Estimate Version' ;
    rdfs:comment 'Version identifier for this estimate iteration, tracking evolution from initial concept through to final sanction estimate (e.g., V1.0, V2.1, Final).' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatingMethodology rdf:type rdf:Property ;
    rdfs:label 'Estimating Methodology' ;
    rdfs:comment 'The primary cost estimating approach or technique used to develop this estimate (e.g., parametric modeling, factored estimates from similar projects, detailed quantity takeoffs and unit rates).' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Amount' ;
    rdfs:comment 'The portion of the base estimate attributable to indirect project costs including engineering, procurement, construction management, commissioning, owner\'s costs, and other support functions.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAllowanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Risk Allowance Included' ;
    rdfs:comment 'Indicates whether a specific risk allowance (beyond standard contingency) has been included in this estimate to address identified project risks from the risk register.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDefinitionLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Definition Level' ;
    rdfs:comment 'The maturity level of project scope definition at the time this estimate was prepared, indicating the completeness of engineering, design, and planning deliverables.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Total Estimate Amount' ;
    rdfs:comment 'The total estimated capital cost including base estimate, contingency, and escalation. This is the all-in project cost estimate used for funding approvals and financial planning.' ;
    rdfs:domain ind:CostEstimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureActualId rdf:type rdf:Property ;
    rdfs:label 'Expenditure Actual Id' ;
    rdfs:comment 'Unique identifier for the actual capital expenditure transaction record. Primary key for the expenditure_actual product.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The monetary value of the actual expenditure posted in the transaction currency. This is the gross amount before any adjustments or allocations.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentItemReference rdf:type rdf:Property ;
    rdfs:label 'Commitment Item Reference' ;
    rdfs:comment 'Reference to the commitment line item (purchase order or contract line) that this actual expenditure settles or reduces.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'High-level classification of the expenditure as Capital Expenditure (CAPEX), Operating Expenditure (OPEX), sustaining capital, expansion capital, or exploration expenditure.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Element Description' ;
    rdfs:comment 'The descriptive name of the cost element, providing human-readable classification of the expenditure type.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Financial Document Number' ;
    rdfs:comment 'The unique financial document number in the general ledger that records this actual expenditure transaction. Provides full audit trail to FI posting.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Boolean flag indicating whether this expenditure actual record is currently active and valid for reporting, or has been logically deleted or archived.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:textDescription rdf:type rdf:Property ;
    rdfs:label 'Text Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context or explanation for this actual expenditure transaction.' ;
    rdfs:domain ind:ExpenditureActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'The legal or trading name of the vendor or supplier associated with this expenditure transaction.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Funding Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Mining feasibility studies often involve external funding partners, joint venture participants, or strategic offtake partners whose financial participation and commercial terms are documented in the s' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:annualProductionRate rdf:type rdf:Property ;
    rdfs:label 'Annual Production Rate' ;
    rdfs:comment 'Planned annual production rate of the primary commodity as determined by the feasibility study.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalCostClass rdf:type rdf:Property ;
    rdfs:label 'Capital Cost Class' ;
    rdfs:comment 'AACE International cost estimate classification: Class 5 (order of magnitude, -20% to -50% / +30% to +100%), Class 4 (study or feasibility, -15% to -30% / +20% to +50%), Class 3 (budget authorization or control, -10% to -20% / +10% to +30%), Class 2 (control or bid/tender, -5% to -15% / +5% to +20%), Class 1 (check estimate or bid/tender, -3% to -10% / +3% to +15%).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Capital Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the capital cost estimate (e.g., USD, AUD, CAD).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Capital Cost Estimate' ;
    rdfs:comment 'Total estimated capital expenditure required for the project as determined by the feasibility study, including mine development, plant construction, infrastructure, and pre-production costs.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Discount rate (as a percentage) used in the NPV and DCF calculations, typically representing the weighted average cost of capital (WACC) or hurdle rate.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irr rdf:type rdf:Property ;
    rdfs:label 'Irr' ;
    rdfs:comment 'Internal rate of return calculated in the feasibility study, representing the discount rate at which the NPV of the project equals zero.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadConsultant rdf:type rdf:Property ;
    rdfs:label 'Lead Consultant' ;
    rdfs:comment 'Name of the primary external consulting firm or engineering company responsible for conducting the feasibility study.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npv rdf:type rdf:Property ;
    rdfs:label 'Npv' ;
    rdfs:comment 'Net present value of the project calculated in the feasibility study, representing the present value of future cash flows discounted at the specified discount rate.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvCurrency rdf:type rdf:Property ;
    rdfs:label 'Npv Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the NPV calculation (e.g., USD, AUD, CAD).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Operating Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the operating cost estimate (e.g., USD, AUD, CAD).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Operating Cost Estimate' ;
    rdfs:comment 'Estimated annual or life-of-mine average operating expenditure as determined by the feasibility study, including mining, processing, general and administrative costs.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCostUnit rdf:type rdf:Property ;
    rdfs:label 'Operating Cost Unit' ;
    rdfs:comment 'Unit of measure for the operating cost estimate: per tonne ore processed, per tonne of product, per ounce of metal, per pound of metal, or per annum (annual total).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRateUnit rdf:type rdf:Property ;
    rdfs:label 'Production Rate Unit' ;
    rdfs:comment 'Unit of measure for the annual production rate: tonnes, ounces, pounds, or kilograms of the primary commodity.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Completed' ;
    rdfs:comment 'Indicates whether a comprehensive risk assessment was conducted as part of the feasibility study, covering technical, financial, environmental, social, and regulatory risks.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sensitivityAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Analysis Completed' ;
    rdfs:comment 'Indicates whether sensitivity analysis was performed to assess the impact of key variables (commodity price, operating costs, capital costs, exchange rates) on project economics.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:socialImpactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Social Impact Assessment Completed' ;
    rdfs:comment 'Indicates whether a social impact assessment was conducted to evaluate the projects effects on local communities, indigenous peoples, and other stakeholders.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'Date when the feasibility study was completed and finalized for submission.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Study Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the full feasibility study report document stored in the document management system.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Descriptive name of the feasibility study, typically including the project name and study type.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Externally-known unique business identifier for the feasibility study, typically assigned by the project management office or engineering team.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyScope rdf:type rdf:Property ;
    rdfs:label 'Study Scope' ;
    rdfs:comment 'Detailed description of the scope of work covered by the feasibility study, including technical, economic, environmental, and social aspects evaluated.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Date when the feasibility study work officially commenced.' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the feasibility study: Planned (scheduled but not started), In Progress (actively being conducted), Under Review (submitted for internal or external review), Completed (finalized and approved), Cancelled (terminated before completion), or On Hold (temporarily suspended).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the study level: Scoping Study (conceptual), Pre-Feasibility Study (PFS - preliminary economic assessment), Definitive Feasibility Study (DFS - detailed engineering and economics), Bankable Feasibility Study (BFS - investment-grade), Trade-Off Study (comparison of alternatives), or Optimization Study (refinement of existing design).' ;
    rdfs:domain ind:FeasibilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDecisionId rdf:type rdf:Property ;
    rdfs:label 'Gate Decision Id' ;
    rdfs:comment 'Unique identifier for the stage-gate decision record. Primary key for the gate decision entity.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved budget amount (e.g., USD, AUD, CAD).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendees rdf:type rdf:Property ;
    rdfs:label 'Attendees' ;
    rdfs:comment 'Comma-separated list of names or identifiers of key attendees present at the gate decision meeting. Provides audit trail of decision participants.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Status' ;
    rdfs:comment 'Status of regulatory and compliance review at the time of the gate decision. Indicates whether the project meets all applicable legal, environmental, safety, and regulatory requirements.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsAttached rdf:type rdf:Property ;
    rdfs:label 'Conditions Attached' ;
    rdfs:comment 'Detailed list of conditions that must be satisfied for a Conditional Approval decision. May include requirements for additional studies, risk mitigation actions, budget adjustments, or stakeholder approvals. Null for Approved, Deferred, or Rejected outcomes.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Name' ;
    rdfs:comment 'Full name of the individual or committee who made the gate decision (e.g., Chief Executive Officer, Capital Allocation Committee, Board of Directors).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Role' ;
    rdfs:comment 'Role or title of the decision authority (e.g., CEO, CFO, Capital Steering Committee Chair, Board Investment Committee).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the stage-gate decision was formally made by the decision authority. Represents the official sanction or rejection date for project progression.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionNotes rdf:type rdf:Property ;
    rdfs:label 'Decision Notes' ;
    rdfs:comment 'Additional notes, comments, or observations recorded during the gate decision process. Captures context and nuances not covered in other structured fields.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Final outcome of the stage-gate review. Approved: project may proceed to next stage unconditionally. Conditional Approval: project may proceed subject to conditions. Deferred: decision postponed pending additional information. Rejected: project not sanctioned to proceed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Summary of the business rationale and key considerations that led to the decision outcome. Captures strategic alignment, risk assessment, financial justification, and other factors.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrAtDecision rdf:type rdf:Property ;
    rdfs:label 'Irr At Decision' ;
    rdfs:comment 'Internal Rate of Return (IRR) percentage of the project as presented at the time of the gate decision. Expressed as a percentage (e.g., 15.50 represents 15.50%).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meetingReference rdf:type rdf:Property ;
    rdfs:label 'Meeting Reference' ;
    rdfs:comment 'Reference identifier for the governance meeting or board session at which the gate decision was made (e.g., meeting ID, minutes reference number).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGateCode rdf:type rdf:Property ;
    rdfs:label 'Next Gate Code' ;
    rdfs:comment 'Code of the next stage-gate the project will face following this decision. Null if project is rejected or closed out.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGateTargetDate rdf:type rdf:Property ;
    rdfs:label 'Next Gate Target Date' ;
    rdfs:comment 'Target date for the next stage-gate review. Establishes the timeline expectation for project progression. Null if project is rejected or closed out.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npvAtDecision rdf:type rdf:Property ;
    rdfs:label 'Npv At Decision' ;
    rdfs:comment 'Net Present Value (NPV) of the project as presented at the time of the gate decision. Key financial metric used in the decision-making process.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Review Status' ;
    rdfs:comment 'Status of health and safety review at the time of the gate decision. Ensures project design and execution plans meet occupational health and safety standards.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderConsultationStatus rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Status' ;
    rdfs:comment 'Status of stakeholder consultation and engagement activities at the time of the gate decision. Includes community, indigenous groups, government, and other key stakeholders.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Strategic Alignment Score' ;
    rdfs:comment 'Quantitative score (typically 1-10 or 1-100) representing how well the project aligns with the organization\'s strategic objectives and priorities. Higher scores indicate stronger alignment.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentReferences rdf:type rdf:Property ;
    rdfs:label 'Supporting Document References' ;
    rdfs:comment 'Comma-separated list of document identifiers or file paths referencing supporting materials for the gate decision (e.g., feasibility study reports, financial models, risk registers, environmental impact assessments, board papers).' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingOutcome rdf:type rdf:Property ;
    rdfs:label 'Voting Outcome' ;
    rdfs:comment 'Summary of voting results if the decision was made by committee vote (e.g., 5 for, 1 against, 0 abstentions). Null if decision was made by single authority.' ;
    rdfs:domain ind:GateDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCertificateId rdf:type rdf:Property ;
    rdfs:label 'Handover Certificate Id' ;
    rdfs:comment 'Unique identifier for the handover certificate record. Primary key for this entity.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandoverCertificate .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Foreign key linking to project.milestone. Business justification: Handover certificates are often contractual milestones (mechanical completion, substantial completion, final acceptance). Currently handover_certificate has contract_milestone_reference as STRING whic' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:primaryHandoverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Handover Employee Id' ;
    rdfs:comment 'Unique identifier of the operations manager who accepted the handover. Links to the employee or workforce master data.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaLocation rdf:type rdf:Property ;
    rdfs:label 'Area Location' ;
    rdfs:comment 'Physical location or geographic area of the system being handed over within the mine site (e.g., Processing Plant Area, Pit 3 North Wall, ROM Pad 2).' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPunchItemsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Punch Items Count' ;
    rdfs:comment 'Number of critical or safety-related punch list items outstanding at handover. Critical items typically require expedited resolution and may impact operational readiness.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designCapacityAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Achieved Flag' ;
    rdfs:comment 'Indicates whether the system achieved its design capacity or performance targets during commissioning. True if design capacity was met or exceeded; False otherwise.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationPackageCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Package Complete Flag' ;
    rdfs:comment 'Indicates whether all required handover documentation has been delivered to operations, including as-built drawings, operating manuals, maintenance procedures, and spare parts lists. True if complete; False if outstanding.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverConditions rdf:type rdf:Property ;
    rdfs:label 'Handover Conditions' ;
    rdfs:comment 'Specific conditions, limitations, or constraints attached to the handover. May include restrictions on use, required follow-up actions, or dependencies on other systems.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Handover Meeting Date' ;
    rdfs:comment 'Date of the formal handover meeting where the certificate was reviewed and signed by all parties.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoverStatus rdf:type rdf:Property ;
    rdfs:label 'Handover Status' ;
    rdfs:comment 'Current lifecycle status of the handover certificate. Tracks the approval workflow from initial draft through final acceptance or rejection.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverType rdf:type rdf:Property ;
    rdfs:label 'Handover Type' ;
    rdfs:comment 'Classification of the handover milestone. Mechanical Completion indicates all equipment installed and tested; Practical Completion indicates the facility is ready for operational use with minor defects; Final Completion indicates all work complete including defects rectification.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsAcceptanceSignoff rdf:type rdf:Property ;
    rdfs:label 'Operations Acceptance Signoff' ;
    rdfs:comment 'Formal acceptance decision by the operations team. Indicates whether operations has agreed to take ownership of the system or area.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsManagerName rdf:type rdf:Property ;
    rdfs:label 'Operations Manager Name' ;
    rdfs:comment 'Full name of the operations manager who signed off on the handover certificate, accepting responsibility for the system or area.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Operations Signoff Date' ;
    rdfs:comment 'Date on which the operations manager formally signed the handover certificate.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingPunchItemsCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Punch Items Count' ;
    rdfs:comment 'Number of open defects, snags, or punch list items remaining at the time of handover. These are typically minor deficiencies that do not prevent operational use but require rectification within an agreed timeframe.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Trigger Flag' ;
    rdfs:comment 'Indicates whether this handover certificate triggers a contractual payment to the contractor or vendor. True if payment is due upon handover; False otherwise.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceTestDate rdf:type rdf:Property ;
    rdfs:label 'Performance Test Date' ;
    rdfs:comment 'Date on which performance testing or commissioning trials were completed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTestStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Test Status' ;
    rdfs:comment 'Status of performance testing or commissioning trials conducted prior to handover. Indicates whether the system met design performance criteria.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHandoverDate rdf:type rdf:Property ;
    rdfs:label 'Planned Handover Date' ;
    rdfs:comment 'The originally scheduled date for handover as per the project baseline schedule. Used for variance analysis and schedule performance tracking.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Full name of the project manager who signed off on the handover certificate, certifying that the system is ready for operational use.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Project Manager Signoff Date' ;
    rdfs:comment 'Date on which the project manager formally signed the handover certificate.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Status' ;
    rdfs:comment 'Status of safety certification or regulatory approval required before the system can be operated. Ensures compliance with Mine Safety and Health Administration (MSHA) or equivalent regulations.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsDeliveredFlag rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Delivered Flag' ;
    rdfs:comment 'Indicates whether the required commissioning and initial spare parts inventory has been delivered and transferred to operations. True if delivered; False otherwise.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemCode rdf:type rdf:Property ;
    rdfs:label 'System Code' ;
    rdfs:comment 'Engineering system or subsystem code being handed over (e.g., ELEC-HV-01 for high voltage electrical system, PROC-CRUSH-01 for crushing plant). Aligns with project Work Breakdown Structure (WBS) and Piping and Instrumentation Diagram (P&ID) tagging conventions.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Descriptive name of the system, area, or facility being handed over (e.g., Primary Crushing Plant, Tailings Storage Facility, Mine Dewatering System).' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Status of operator training and competency assessment for the system being handed over. Ensures operations personnel are qualified to operate the equipment safely and effectively.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearnedId rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Id' ;
    rdfs:comment 'Unique identifier for the lessons learned record. Primary key for the lessons learned entity.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issueId rdf:type rdf:Property ;
    rdfs:label 'Issue Id' ;
    rdfs:comment 'Foreign key linking to project.issue. Business justification: Lessons learned are often captured from project issues (what went wrong, root cause, what was learned, how to prevent). Currently lessons_learned links to capital_project and prospect but not to speci' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issue .

ind:applicableCommodity rdf:type rdf:Property ;
    rdfs:label 'Applicable Commodity' ;
    rdfs:comment 'Mining commodity or mineral type for which this lesson is most relevant (e.g., iron ore, copper, coal, lithium, nickel). Enables filtering lessons by commodity context.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProjectType rdf:type rdf:Property ;
    rdfs:label 'Applicable Project Type' ;
    rdfs:comment 'Type of capital project for which this lesson is most relevant (e.g., greenfield mine development, brownfield expansion, processing plant upgrade, infrastructure, mine closure).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the individual who authored or submitted this lessons learned record.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorOrganization rdf:type rdf:Property ;
    rdfs:label 'Author Organization' ;
    rdfs:comment 'Organization or company the author represents (e.g., owner, contractor, consultant, vendor).' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorRole rdf:type rdf:Property ;
    rdfs:label 'Author Role' ;
    rdfs:comment 'Job title or functional role of the lesson author at the time of capture (e.g., Project Manager, Construction Manager, HSE Advisor).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureDate rdf:type rdf:Property ;
    rdfs:label 'Capture Date' ;
    rdfs:comment 'Date when this lesson learned was formally captured and documented. Represents the business event timestamp for knowledge capture.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Quantified financial impact of the issue or opportunity captured in this lesson, expressed in the project currency. Positive values indicate cost savings or value gains; negative values indicate cost overruns or losses.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount (e.g., USD, AUD, CAD).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactArea rdf:type rdf:Property ;
    rdfs:label 'Impact Area' ;
    rdfs:comment 'Business area or project dimension most affected by this lesson (e.g., cost, schedule, safety, quality, stakeholder relations, environmental compliance).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Status tracking whether the recommendation from this lesson has been incorporated into organizational processes, standards, or future project plans.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of searchable keywords or tags to facilitate discovery and retrieval of this lesson from the knowledge base.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonCategory rdf:type rdf:Property ;
    rdfs:label 'Lesson Category' ;
    rdfs:comment 'Primary classification of the lesson learned by project discipline or knowledge area. Enables filtering and analysis by functional domain. [ENUM-REF-CANDIDATE: engineering|procurement|construction|commissioning|hse|cost_control|schedule_management|stakeholder_management|quality_management|risk_management — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonDescription rdf:type rdf:Property ;
    rdfs:label 'Lesson Description' ;
    rdfs:comment 'Detailed narrative describing the situation, context, and lesson learned. Captures what happened, what was learned, and why it matters for future projects.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonNumber rdf:type rdf:Property ;
    rdfs:label 'Lesson Number' ;
    rdfs:comment 'Business identifier for the lesson learned record, typically following organizational numbering convention (e.g., LL-2024-001).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonSubcategory rdf:type rdf:Property ;
    rdfs:label 'Lesson Subcategory' ;
    rdfs:comment 'Secondary classification providing more granular categorization within the primary lesson category (e.g., under Engineering: design, specifications, technical standards).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonTitle rdf:type rdf:Property ;
    rdfs:label 'Lesson Title' ;
    rdfs:comment 'Concise title summarizing the key lesson learned or knowledge transfer point.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonType rdf:type rdf:Property ;
    rdfs:label 'Lesson Type' ;
    rdfs:comment 'Classification of whether the lesson represents a success to be repeated, a problem to be avoided, or a general observation for awareness.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Date when the event or situation that generated this lesson actually occurred on the project.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'Actionable recommendation or best practice guidance for future projects based on this lesson. Describes what should be done differently or repeated.' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Related Document Reference' ;
    rdfs:comment 'Reference identifier or hyperlink to supporting documentation, reports, photos, or evidence related to this lesson (e.g., incident reports, design drawings, meeting minutes).' ;
    rdfs:domain ind:LessonsLearned ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Id' ;
    rdfs:comment 'Reference to the milestone that must be completed before this milestone can begin or be achieved. Used for schedule dependency tracking and critical path analysis.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:accountablePerson rdf:type rdf:Property ;
    rdfs:label 'Accountable Person' ;
    rdfs:comment 'The name or identifier of the individual who is ultimately accountable for milestone achievement. Typically a project manager, engineering lead, or contractor representative.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual date when the milestone was achieved and acceptance criteria were met. Populated only after milestone completion and formal sign-off.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractualObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Contractual Obligation Flag' ;
    rdfs:comment 'Indicates whether this milestone is a contractual obligation with financial or legal consequences. True means the milestone is tied to contract terms, payment schedules, or liquidated damages provisions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityFlag rdf:type rdf:Property ;
    rdfs:label 'Criticality Flag' ;
    rdfs:comment 'Indicates whether this milestone is on the critical path of the project schedule. True means any delay to this milestone will directly impact the overall project completion date.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or location of the supporting documentation that provides evidence of milestone completion. May include test reports, inspection certificates, regulatory approvals, or sign-off documents.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'The current projected date when the milestone is expected to be achieved, based on actual progress and updated schedule analysis. Updated regularly during project execution.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'The project phase or functional category to which the milestone belongs. Used for grouping milestones by lifecycle stage for reporting and tracking purposes.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Business identifier or code for the milestone, often used in project schedules and contractor agreements. May follow organizational or project-specific coding conventions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the milestone scope, deliverables, acceptance criteria, and any specific conditions that must be met for the milestone to be considered achieved.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'The descriptive name of the milestone representing a significant deliverable or decision point (e.g., \'Feasibility Study Approval\', \'First Ore to Mill\', \'Commissioning Complete\').' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone by its nature and purpose. Contractual milestones trigger payment or obligations; Internal milestones support project governance; Regulatory milestones satisfy compliance requirements; Financial milestones align with funding or budget releases; Stage Gate milestones represent formal decision points; Technical milestones mark engineering or construction achievements.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'The original baseline date when the milestone was planned to be achieved, as established during project planning or contract negotiation. This date remains fixed for variance analysis.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageGateFlag rdf:type rdf:Property ;
    rdfs:label 'Stage Gate Flag' ;
    rdfs:comment 'Indicates whether this milestone represents a formal stage-gate decision point requiring executive or board approval to proceed to the next project phase. True means formal governance review and approval is required.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user identifier or name of the person who last updated this milestone record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'The schedule variance in days between the planned date and the actual or forecast date. Positive values indicate delay; negative values indicate early completion. Used for schedule performance analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'The relative weight or importance of this milestone as a percentage of total project completion. Used for earned value calculations and overall project progress reporting. Sum of all milestone weights should equal 100%.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressClaimId rdf:type rdf:Property ;
    rdfs:label 'Progress Claim Id' ;
    rdfs:comment 'Unique identifier for the progress claim record. Primary key for the progress claim entity.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProgressEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Progress Employee Id' ;
    rdfs:comment 'Reference to the engineer or project manager responsible for reviewing and certifying the progress claim for payment.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Certified Amount' ;
    rdfs:comment 'Amount certified by the certifying engineer or project manager as valid and payable, after review and verification of work completed. May differ from claimed amount.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimNotes rdf:type rdf:Property ;
    rdfs:label 'Claim Notes' ;
    rdfs:comment 'Free-text notes or comments related to the progress claim, capturing additional context, clarifications, or special conditions.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Unique business identifier for the progress claim, typically assigned sequentially within a contract or project. Used for external reference and communication.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period End Date' ;
    rdfs:comment 'End date of the work period covered by this progress claim. Defines the conclusion of the claim period for which work is being claimed.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Claim Period Start Date' ;
    rdfs:comment 'Start date of the work period covered by this progress claim. Defines the beginning of the claim period for which work is being claimed.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSequence rdf:type rdf:Property ;
    rdfs:label 'Claim Sequence' ;
    rdfs:comment 'Sequential number of this claim within the contract lifecycle, indicating the chronological order of claims submitted (e.g., 1st claim, 2nd claim).' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the progress claim indicating its position in the review and payment workflow. [ENUM-REF-CANDIDATE: Submitted|Under Review|Certified|Disputed|Approved|Rejected|Paid — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the progress claim indicating the nature of the claim (e.g., regular periodic claim, final claim, variation claim, retention release).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Total gross amount claimed by the contractor for work completed during the claim period, before any adjustments, certifications, or deductions.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Detailed explanation of the reason for any disputed amount, documenting the basis for disagreement between contractor and project owner.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Payment transaction reference number or remittance advice number issued when payment was processed, used for financial reconciliation.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousClaimsCumulativeAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Claims Cumulative Amount' ;
    rdfs:comment 'Cumulative total of all certified amounts from previous progress claims under this contract, used to calculate the current claim net amount.' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Amount' ;
    rdfs:comment 'Amount withheld from the certified amount as retention, held as security until contract completion or defects liability period expiry, as per contract terms.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentsReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation submitted with the progress claim (e.g., timesheets, delivery dockets, photos, inspection reports).' ;
    rdfs:domain ind:ProgressClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalGate rdf:type rdf:Property ;
    rdfs:label 'Approval Gate' ;
    rdfs:comment 'The stage-gate milestone at which this budget was approved. Aligns with the organization\'s capital project governance framework (e.g., Gate 3 for detailed design approval).' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineBudgetFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Budget Flag' ;
    rdfs:comment 'Indicates whether this budget version is the baseline budget used for performance measurement and variance analysis. True if this is the baseline, False otherwise.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'The externally-known AFE or budget authorization number assigned to this approved budget. Used for tracking and audit purposes.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget record indicating whether it is the original sanctioned budget, a revised budget, supplementary allocation, contingency release, or baseline budget.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexPhase rdf:type rdf:Property ;
    rdfs:label 'Capex Phase' ;
    rdfs:comment 'The project phase or stage to which this budget applies. Aligns with stage-gate approval process for capital projects. [ENUM-REF-CANDIDATE: feasibility|pre_feasibility|definitive_feasibility|front_end_engineering_design|detailed_design|procurement|construction|commissioning|closeout — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyBudget rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget' ;
    rdfs:comment 'The portion of the approved budget allocated as contingency reserve to cover identified risks, scope changes, and unforeseen events within the project scope.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostBudget rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Budget' ;
    rdfs:comment 'The portion of the approved budget allocated to direct project costs including labor, materials, equipment, and subcontractors directly attributable to project deliverables.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostBudget rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Budget' ;
    rdfs:comment 'The portion of the approved budget allocated to indirect costs including project management, administration, overhead, and support services not directly tied to deliverables.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irrAtApproval rdf:type rdf:Property ;
    rdfs:label 'Irr At Approval' ;
    rdfs:comment 'The Internal Rate of Return percentage of the project as calculated and presented at the time of budget approval. Used for investment decision tracking.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvAtApproval rdf:type rdf:Property ;
    rdfs:label 'Npv At Approval' ;
    rdfs:comment 'The Net Present Value of the project as calculated and presented at the time of budget approval. Used for investment decision tracking and post-implementation review.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'The name or employee identifier of the individual accountable for managing and controlling expenditure against this budget (typically the Project Manager or Project Director).' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerCostBudget rdf:type rdf:Property ;
    rdfs:label 'Owner Cost Budget' ;
    rdfs:comment 'The portion of the approved budget allocated to owner costs including internal labor, owner-furnished equipment, permits, insurance, and owner-side project management.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'The expected payback period in months for the capital investment as calculated at the time of budget approval.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectContractAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Contract Administrator Employee Id' ;
    rdfs:comment 'Reference to the contract administrator responsible for day-to-day contract management, variations, and claims.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectContractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Contract Employee Id' ;
    rdfs:comment 'Reference to the project manager responsible for overseeing this contract on behalf of the mining company.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date' ;
    rdfs:comment 'Cumulative actual cost incurred to date under this contract, based on invoices received and payments made.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedCost rdf:type rdf:Property ;
    rdfs:label 'Committed Cost' ;
    rdfs:comment 'Total cost committed under this contract, including original value and approved variations. Used for project cost control and forecasting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total monetary value of the contract as agreed at execution. Represents the baseline contract sum before variations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectsLiabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Defects Liability End Date' ;
    rdfs:comment 'Date when the defects liability period expires and final retention can be released.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectsLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Days' ;
    rdfs:comment 'Duration in days of the defects liability period (also known as warranty period) during which the contractor is responsible for rectifying defects after completion.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether the contractor is required to maintain specific insurance coverage (e.g., public liability, professional indemnity, workers compensation) for this contract.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidatedDamagesApplicable rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Applicable' ;
    rdfs:comment 'Indicates whether liquidated damages (pre-agreed compensation for delay or non-performance) are applicable under this contract.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidatedDamagesRate rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Rate' ;
    rdfs:comment 'Daily or weekly rate of liquidated damages payable by the contractor for delay beyond the contract end date. Null if not applicable.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Monetary value of the performance bond or bank guarantee provided by the contractor. Null if no bond is required.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Expiry Date' ;
    rdfs:comment 'Expiry date of the performance bond or bank guarantee. Must be monitored to ensure coverage throughout contract duration.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether a performance bond or bank guarantee is required from the contractor to secure contract performance.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Summary' ;
    rdfs:comment 'High-level description of the contract scope, deliverables, and work packages covered by this contract.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVariationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variation Amount' ;
    rdfs:comment 'Cumulative monetary value of all approved variations to the original contract value. Can be positive (additions) or negative (omissions).' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variationOrderCount rdf:type rdf:Property ;
    rdfs:label 'Variation Order Count' ;
    rdfs:comment 'Total number of approved variation orders or change orders issued against this contract to date.' ;
    rdfs:domain ind:ProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the project document record. Primary key for the project document master register.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Document Id' ;
    rdfs:comment 'Reference to the newer document that replaces this document. Maintains document lineage and ensures users access the current revision.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:contractDeliverableFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Deliverable Flag' ;
    rdfs:comment 'Indicates whether this document is a contractually required deliverable. Used to track compliance with contract obligations and milestone payment triggers.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Dms Platform' ;
    rdfs:comment 'Name of the document management system platform where the document is stored. Supports multi-platform document ecosystems in large capital projects.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmsReference rdf:type rdf:Property ;
    rdfs:label 'Dms Reference' ;
    rdfs:comment 'Unique identifier or hyperlink reference to the document in the project document management system such as Aconex, Procore, or SharePoint. Enables direct retrieval of the physical document file.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingScale rdf:type rdf:Property ;
    rdfs:label 'Drawing Scale' ;
    rdfs:comment 'Scale ratio of the engineering drawing such as 1:100, 1:50, or NTS (Not To Scale). Critical for accurate interpretation of dimensions and spatial relationships.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingSize rdf:type rdf:Property ;
    rdfs:label 'Drawing Size' ;
    rdfs:comment 'Standard sheet size for engineering drawings. Determines plotting and printing requirements. Applicable only to drawing document types. [ENUM-REF-CANDIDATE: A0|A1|A2|A3|A4|ANSI_A|ANSI_B|ANSI_C|ANSI_D|ANSI_E — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTagNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag Number' ;
    rdfs:comment 'Unique equipment tag number to which this document relates. Links document to specific equipment items for maintenance and operational reference.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the document. Determines software requirements for viewing and editing, and influences long-term archival strategies. [ENUM-REF-CANDIDATE: pdf|dwg|xlsx|docx|mpp|xml|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the document file in megabytes. Used for storage capacity planning and download time estimation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Relevant for printing cost estimation and document complexity assessment.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedWbsCode rdf:type rdf:Property ;
    rdfs:label 'Related Wbs Code' ;
    rdfs:comment 'Work Breakdown Structure code to which this document is associated. Links document to specific project scope elements for cost and schedule integration.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittalNumber rdf:type rdf:Property ;
    rdfs:label 'Transmittal Number' ;
    rdfs:comment 'Reference number of the formal transmittal or submittal package through which the document was issued. Links document to its distribution record.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedRiskRiskItemId rdf:type rdf:Property ;
    rdfs:label 'Related Risk Risk Item Id' ;
    rdfs:comment 'Reference to a project risk register entry if this issue is the realization of a previously identified risk.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskItem .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Name of the individual assigned responsibility for investigating and resolving the issue.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerOrganisation rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Organisation' ;
    rdfs:comment 'Organisation or company that the assigned owner represents.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedByName rdf:type rdf:Property ;
    rdfs:label 'Closed By Name' ;
    rdfs:comment 'Name of the individual who formally closed the issue after verification of resolution.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the issue was escalated to a higher authority. Null if not escalated.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Flag' ;
    rdfs:comment 'Indicates whether the issue is related to or resulted from a health, safety, or environmental incident. True if HSE-related, False otherwise.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed narrative description of the issue, including context, observed symptoms, impact, and any relevant background information.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'Externally-known unique business identifier for the issue, typically formatted as a sequential or structured code used in project communications and reporting.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle state of the issue: Open (newly raised), In Progress (under investigation or remediation), Resolved (solution implemented), Closed (verified and archived), Escalated (elevated to higher authority), On Hold (temporarily suspended).' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueType rdf:type rdf:Property ;
    rdfs:label 'Issue Type' ;
    rdfs:comment 'Classification of the issue by functional domain: Technical (engineering, design), Commercial (contract, cost), HSE (Health Safety Environment), Quality (non-conformance), Schedule (delay, milestone), Resource (labour, equipment).' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key insights, best practices, or preventive measures identified from the issue for future project improvement and knowledge management.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByName rdf:type rdf:Property ;
    rdfs:label 'Raised By Name' ;
    rdfs:comment 'Name of the individual or party who identified and raised the issue.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByOrganisation rdf:type rdf:Property ;
    rdfs:label 'Raised By Organisation' ;
    rdfs:comment 'Organisation or company that the person who raised the issue represents (e.g., owner, contractor, consultant, vendor).' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether the issue has regulatory or compliance implications (e.g., environmental approval, mining permit, safety regulation). True if regulatory impact exists, False otherwise.' ;
    rdfs:domain ind:Issue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Actual date when the phase was completed and formally closed. Null if phase is still in progress or not started.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDurationDays rdf:type rdf:Property ;
    rdfs:label 'Baseline Duration Days' ;
    rdfs:comment 'Approved baseline duration for the phase in calendar days, calculated from planned start to planned finish.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Current cost variance calculated as phase budget minus phase forecast cost. Negative values indicate cost overrun.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCost rdf:type rdf:Property ;
    rdfs:label 'Forecast Cost' ;
    rdfs:comment 'Current forecast of total cost at completion for this phase, updated regularly based on actuals, commitments, and estimates to complete.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastFinishDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Finish Date' ;
    rdfs:comment 'Current best estimate of when the phase will complete, updated regularly based on progress and risks. Used for schedule variance analysis.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Authority' ;
    rdfs:comment 'Name or title of the governance body or individual who granted stage-gate approval (e.g., Executive Committee, Board of Directors, Capital Allocation Committee).' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Date' ;
    rdfs:comment 'Date when formal stage-gate approval was granted for this phase to proceed. Null if approval not yet obtained or not required.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Required' ;
    rdfs:comment 'Indicates whether formal stage-gate approval is required before this phase can commence. True if governance approval is mandatory.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyDeliverables rdf:type rdf:Property ;
    rdfs:label 'Key Deliverables' ;
    rdfs:comment 'Summary list of major deliverables and outputs expected from this phase (e.g., feasibility study report, detailed engineering drawings, procurement contracts, construction completion certificate).' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseCode rdf:type rdf:Property ;
    rdfs:label 'Phase Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the phase type within the organization\'s project methodology (e.g., CONCEPT, PREFEAS, FEAS, FEED, DETAIL_ENG, PROCURE, CONSTRUCT, COMMISSION, HANDOVER, CLOSEOUT).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseDescription rdf:type rdf:Property ;
    rdfs:label 'Phase Description' ;
    rdfs:comment 'Detailed description of the phase scope, objectives, key deliverables, and success criteria. Provides context for phase execution and governance.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Full descriptive name of the project phase (e.g., Concept Study, Pre-Feasibility Study, Feasibility Study, Front-End Engineering Design, Detailed Engineering, Procurement, Construction, Commissioning, Handover, Project Closeout).' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current execution status of the project phase indicating its lifecycle state.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Current schedule variance in calendar days, calculated as the difference between forecast finish and planned finish. Negative values indicate delay.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal position of this phase within the project\'s overall phase sequence. Used to enforce phase ordering and dependencies.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Unique identifier for the project schedule record. Primary key.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:baselineApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Approval Date' ;
    rdfs:comment 'Date when the schedule baseline was formally approved by the project governance board or steering committee. Critical for earned value management and schedule variance analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Completed Activities Count' ;
    rdfs:comment 'Number of activities that have been completed as of the schedule status date. Used to calculate percent complete and progress metrics.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compressionMethod rdf:type rdf:Property ;
    rdfs:label 'Compression Method' ;
    rdfs:comment 'Method applied to compress the schedule and reduce project duration. Fast tracking involves overlapping activities that were originally sequential. Crashing involves adding resources to critical path activities. Both may be applied simultaneously.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyDays rdf:type rdf:Property ;
    rdfs:label 'Contingency Days' ;
    rdfs:comment 'Time buffer or contingency reserve built into the schedule to account for schedule risks and uncertainties. Managed as part of schedule risk management.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Critical Activities Count' ;
    rdfs:comment 'Number of activities on the critical path. Used to assess schedule risk concentration and management focus areas.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataDate rdf:type rdf:Property ;
    rdfs:label 'Data Date' ;
    rdfs:comment 'Status date or as-of date for the schedule. Represents the point in time up to which actual progress has been recorded and from which forecasts are projected. Critical reference point for earned value calculations.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Update Date' ;
    rdfs:comment 'Date when the schedule was last updated with actual progress and forecast changes. Used to assess schedule data currency.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:longestPathDurationDays rdf:type rdf:Property ;
    rdfs:label 'Longest Path Duration Days' ;
    rdfs:comment 'Duration in days of the longest path through the schedule network from start to finish. Represents the minimum project duration assuming no resource constraints.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceIndex rdf:type rdf:Property ;
    rdfs:label 'Performance Index' ;
    rdfs:comment 'Earned value schedule performance index calculated as Earned Value (EV) divided by Planned Value (PV). Values less than 1.0 indicate schedule delays, values greater than 1.0 indicate schedule advancement. Key earned value metric for project control.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceIndexDate rdf:type rdf:Property ;
    rdfs:label 'Performance Index Date' ;
    rdfs:comment 'Date as of which the schedule performance index was calculated. Important for tracking SPI trends over time.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulingTool rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tool' ;
    rdfs:comment 'Software application used to create and maintain the project schedule. Common tools in mining include Primavera P6 for large capital projects, MS Project for smaller projects, and Deswik or Minex for mine-specific scheduling.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingToolFileReference rdf:type rdf:Property ;
    rdfs:label 'Scheduling Tool File Reference' ;
    rdfs:comment 'File path, document management system reference, or unique identifier for the native schedule file in the scheduling tool. Enables traceability to the source schedule data.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Total Activities Count' ;
    rdfs:comment 'Total number of activities or tasks in the project schedule. Provides a measure of schedule complexity and granularity.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total float or slack available in the schedule network. Represents the amount of time an activity can be delayed without delaying the project completion date. Critical for risk management and resource optimization.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Planned frequency for updating the project schedule with actual progress and forecast changes. Typically defined in the project management plan.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMemberId rdf:type rdf:Property ;
    rdfs:label 'Team Member Id' ;
    rdfs:comment 'Unique identifier for the project team member assignment record.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTeamEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Team Employee Id' ;
    rdfs:comment 'Reference to the employee or contractor personnel record assigned to the project team.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTeamFunctionalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Team Functional Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who serves as the functional or home department manager for this team member, maintaining the matrix management relationship outside the project structure.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the team member\'s working time allocated to this project, expressed as a decimal value between 0 and 100. Used for resource loading and capacity planning. A value of 100 indicates full-time dedication to the project.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The planned or actual date on which the team member will complete or completed their role on the project. Null for open-ended assignments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, special conditions, or remarks related to this team member assignment that do not fit structured fields.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which the team member officially commenced their role on the project, marking the beginning of their assignment period.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the employment arrangement for this project assignment, distinguishing between full-time dedicated resources, part-time shared resources, external contractors, consultants, internal secondments, and temporary assignments.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Rate Amount' ;
    rdfs:comment 'The daily billing or cost rate for this team member on the project, used for project cost estimation and tracking. Applicable primarily for contractors and consultants.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Demobilization Date' ;
    rdfs:comment 'The date on which the team member demobilized from the project site or ceased active project work, marking the physical conclusion of their project involvement.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hourlyRateAmount rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Amount' ;
    rdfs:comment 'The hourly billing or cost rate for this team member on the project, used for detailed time-based cost tracking and invoicing.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inductionCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Induction Completed Flag' ;
    rdfs:comment 'Boolean indicator of whether the team member has completed the required project site induction and safety training before commencing work.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inductionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Induction Completion Date' ;
    rdfs:comment 'The date on which the team member completed the mandatory project induction and safety training, establishing compliance with site access requirements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCriticalResource rdf:type rdf:Property ;
    rdfs:label 'Is Critical Resource' ;
    rdfs:comment 'Boolean indicator identifying whether this team member is considered a critical resource for project success, used for resource risk management and succession planning.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Mobilization Date' ;
    rdfs:comment 'The date on which the team member physically mobilized to the project site or commenced active project work, distinct from the formal assignment start date.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectRoleCode rdf:type rdf:Property ;
    rdfs:label 'Project Role Code' ;
    rdfs:comment 'Standardized code representing the role performed by the team member on the project. Common roles include Project Director (PROJ_DIR), Project Manager (PROJ_MGR), Construction Manager (CONSTR_MGR), Commissioning Manager (COMM_MGR), Cost Engineer (COST_ENG), Scheduler (SCHEDULER), Health Safety and Environment (HSE) Lead (HSE_LEAD), Design Manager (DESIGN_MGR), Procurement Manager (PROC_MGR), Quality Assurance/Quality Control (QA/QC) Manager (QA_QC_MGR), Site Engineer (SITE_ENG), Planning Engineer (PLAN_ENG), Contracts Administrator (CONTR_ADM), Environmental Coordinator (ENV_COORD), Commissioning Engineer (COMM_ENG). [ENUM-REF-CANDIDATE: PROJ_DIR|PROJ_MGR|CONSTR_MGR|COMM_MGR|COST_ENG|SCHEDULER|HSE_LEAD|DESIGN_MGR|PROC_MGR|QA_QC_MGR|SITE_ENG|PLAN_ENG|CONTR_ADM|ENV_COORD|COMM_ENG — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectRoleName rdf:type rdf:Property ;
    rdfs:label 'Project Role Name' ;
    rdfs:comment 'Full descriptive name of the role performed by the team member on the project, providing human-readable context for the role code.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the daily or hourly rate amounts, ensuring accurate financial reporting across multi-currency projects.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'The security clearance level held by the team member for this project, relevant for projects with restricted access requirements or sensitive operations.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for early termination of the assignment, if applicable. Used for workforce analytics and project risk management.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the reason for early termination of the assignment, providing context beyond the standardized termination reason code.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListItemId rdf:type rdf:Property ;
    rdfs:label 'Punch List Item Id' ;
    rdfs:comment 'Unique identifier for the punch list item. Primary key.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Code identifying the physical area or location within the project where the punch list item is located (e.g., plant section, building, zone).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the punch list item was formally closed in the system after completion and verification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of days the punch list item is overdue relative to the target completion date. Negative values indicate items completed early.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drawingReference rdf:type rdf:Property ;
    rdfs:label 'Drawing Reference' ;
    rdfs:comment 'Reference to the engineering drawing, Piping and Instrumentation Diagram (P&ID), or design document related to the punch list item.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name or identifier of the person or team who identified and raised the punch list item during inspection or walkthrough.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the punch list item was identified and recorded during mechanical completion inspection or commissioning walkthrough.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed description of the punch list item, including the deficiency, incomplete work, or issue identified during mechanical completion inspection or commissioning walkthrough.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the punch list item indicating progress from identification through closure.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'Reference or file path to photographic evidence documenting the punch list item before and after completion.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListItemCategory rdf:type rdf:Property ;
    rdfs:label 'Punch List Item Category' ;
    rdfs:comment 'Classification of the punch list item by criticality: A = must complete before start-up, B = complete before handover, C = complete within agreed period post-handover.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListNumber rdf:type rdf:Property ;
    rdfs:label 'Punch List Number' ;
    rdfs:comment 'Business identifier for the punch list item, typically assigned sequentially or by system/area. Used for tracking and communication.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContractor rdf:type rdf:Property ;
    rdfs:label 'Responsible Contractor' ;
    rdfs:comment 'Name or identifier of the contractor or subcontractor responsible for completing the punch list item.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDiscipline rdf:type rdf:Property ;
    rdfs:label 'Responsible Discipline' ;
    rdfs:comment 'Engineering or construction discipline responsible for the work (e.g., civil, mechanical, electrical, instrumentation, piping).' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the technical specification or standard that the punch list item must meet.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether formal verification or inspection is required before the punch list item can be closed.' ;
    rdfs:domain ind:PunchListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskItemId rdf:type rdf:Property ;
    rdfs:label 'Risk Item Id' ;
    rdfs:comment 'Unique identifier for the risk or opportunity item within the project risk register. Primary key.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Foreign key linking to project.risk_register. Business justification: Risk items belong to a risk register. Currently risk_item has risk_register_version (STRING) but no FK to risk_register. This is a clear parent-child relationship - risk items are managed within regis' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskRegister .

ind:affectedDisciplines rdf:type rdf:Property ;
    rdfs:label 'Affected Disciplines' ;
    rdfs:comment 'Engineering or functional disciplines impacted by this risk (e.g., civil, mechanical, electrical, process, geotechnical, environmental). Supports cross-functional risk coordination.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedWbsElements rdf:type rdf:Property ;
    rdfs:label 'Affected Wbs Elements' ;
    rdfs:comment 'Comma-separated list of Work Breakdown Structure codes or elements that would be impacted by this risk. Links risk to specific project deliverables or work packages.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Explanation of why the risk was closed. May include risk no longer applicable, risk realized and managed, project phase completed, or risk transferred.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceRatingPostMitigation rdf:type rdf:Property ;
    rdfs:label 'Consequence Rating Post Mitigation' ;
    rdfs:comment 'Qualitative assessment of the severity of impact if the risk event occurs after mitigation actions have been implemented. Represents residual consequence.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceRatingPreMitigation rdf:type rdf:Property ;
    rdfs:label 'Consequence Rating Pre Mitigation' ;
    rdfs:comment 'Qualitative assessment of the severity of impact if the risk event occurs before any mitigation actions are applied. Uses five-point scale from insignificant to catastrophic.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Documented response plan to be executed if the risk event occurs. Outlines specific actions, resources, and responsibilities for managing the realized risk impact.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Estimate Usd' ;
    rdfs:comment 'Estimated financial impact of the risk event if it occurs, expressed in US dollars. Used for quantitative risk analysis and contingency budget calculation. Positive value for threats (cost increase), negative value for opportunities (cost savings).' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:likelihoodRatingPostMitigation rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating Post Mitigation' ;
    rdfs:comment 'Qualitative assessment of the probability that the risk event will occur after mitigation actions have been implemented. Represents residual likelihood.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRatingPreMitigation rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating Pre Mitigation' ;
    rdfs:comment 'Qualitative assessment of the probability that the risk event will occur before any mitigation actions are applied. Uses five-point scale from rare to almost certain.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Quantitative probability that the risk event will occur, expressed as a percentage (0.00 to 100.00). Used for Quantitative Risk Analysis (QRA) and Monte Carlo simulation inputs.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskStatus rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Status' ;
    rdfs:comment 'Assessment of whether the post-mitigation risk level is acceptable to the project. Acceptable indicates risk within tolerance, monitor indicates ongoing surveillance required, escalate indicates senior management attention needed, further action required indicates additional mitigation needed.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClosedDate rdf:type rdf:Property ;
    rdfs:label 'Risk Closed Date' ;
    rdfs:comment 'Date when the risk item was formally closed or retired from active management. Null if risk remains open.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the risk item for tracking and reference purposes within the risk register.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative description of the risk event, including causes, potential impacts, and context. Provides comprehensive understanding of the risk scenario.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Risk Identified Date' ;
    rdfs:comment 'Date when the risk item was first identified and entered into the risk register. Tracks risk discovery timeline.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskProximity rdf:type rdf:Property ;
    rdfs:label 'Risk Proximity' ;
    rdfs:comment 'Timeframe within which the risk event is expected to occur or impact the project. Immediate indicates within current reporting period, near term within 3 months, medium term within 6-12 months, long term beyond 12 months.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskResponseStrategy rdf:type rdf:Property ;
    rdfs:label 'Risk Response Strategy' ;
    rdfs:comment 'Primary strategy selected for managing the risk. For threats: avoid (eliminate), mitigate (reduce), transfer (shift to third party), accept (acknowledge without action). For opportunities: exploit (ensure realization), enhance (increase probability/impact), share (allocate to partner), accept. [ENUM-REF-CANDIDATE: avoid|mitigate|transfer|accept|exploit|enhance|share — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScorePostMitigation rdf:type rdf:Property ;
    rdfs:label 'Risk Score Post Mitigation' ;
    rdfs:comment 'Numerical risk score calculated from likelihood and consequence ratings after mitigation. Represents residual risk level. Used to assess effectiveness of mitigation strategies.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskScorePreMitigation rdf:type rdf:Property ;
    rdfs:label 'Risk Score Pre Mitigation' ;
    rdfs:comment 'Numerical risk score calculated from likelihood and consequence ratings before mitigation. Typically derived from risk matrix (e.g., 1-25 scale). Used for risk prioritization and Quantitative Risk Analysis (QRA).' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the risk item. Open indicates newly identified, active indicates under management, mitigated indicates controls implemented, closed indicates risk no longer applicable, accepted indicates risk acknowledged without mitigation, transferred indicates risk passed to third party.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Concise title or name of the risk or opportunity that summarizes the risk event or condition.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Risk Trigger Event' ;
    rdfs:comment 'Description of the early warning indicator or event that signals the risk is about to occur or has increased in likelihood. Enables proactive risk response activation.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Indicates whether the risk item represents a threat (negative impact) or an opportunity (positive impact) to project objectives.' ;
    rdfs:domain ind:RiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeRiskCount rdf:type rdf:Property ;
    rdfs:label 'Active Risk Count' ;
    rdfs:comment 'Number of risks currently in active status, excluding closed, retired, or transferred risks.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalRiskCount rdf:type rdf:Property ;
    rdfs:label 'Critical Risk Count' ;
    rdfs:comment 'Number of risks classified as critical or high severity requiring executive attention and mitigation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Key assumptions underlying the risk assessment and quantification in this register (e.g., commodity price assumptions, regulatory environment).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monteCarloIterations rdf:type rdf:Property ;
    rdfs:label 'Monte Carlo Iterations' ;
    rdfs:comment 'Number of iterations used in Monte Carlo simulation for quantitative risk analysis, if applicable (typically 5,000 to 10,000).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectPhaseCode rdf:type rdf:Property ;
    rdfs:label 'Project Phase Code' ;
    rdfs:comment 'Code identifying the project phase to which this risk register applies (e.g., FEASIBILITY, DESIGN, CONSTRUCTION, COMMISSIONING).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerCode rdf:type rdf:Property ;
    rdfs:label 'Register Code' ;
    rdfs:comment 'Business identifier or code for the risk register, typically following organizational naming conventions (e.g., RR-PROJECT-001).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerDate rdf:type rdf:Property ;
    rdfs:label 'Register Date' ;
    rdfs:comment 'The effective date of this risk register version, representing the baseline date for the risk assessment snapshot.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registerDescription rdf:type rdf:Property ;
    rdfs:label 'Register Description' ;
    rdfs:comment 'Detailed description of the risk register purpose, scope, and context within the project lifecycle.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerName rdf:type rdf:Property ;
    rdfs:label 'Register Name' ;
    rdfs:comment 'Descriptive name of the risk register, typically including the project name and version or phase identifier.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerNotes rdf:type rdf:Property ;
    rdfs:label 'Register Notes' ;
    rdfs:comment 'Additional notes, comments, or context relevant to this risk register version, including changes from previous versions.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerStatus rdf:type rdf:Property ;
    rdfs:label 'Register Status' ;
    rdfs:comment 'Current lifecycle status of the risk register indicating its approval state and usability for decision-making.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registerVersion rdf:type rdf:Property ;
    rdfs:label 'Register Version' ;
    rdfs:comment 'Version number or identifier of the risk register, incremented with each major update or review cycle.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAppetiteStatement rdf:type rdf:Property ;
    rdfs:label 'Risk Appetite Statement' ;
    rdfs:comment 'Statement describing the organizations risk appetite and tolerance levels applicable to this project and risk register.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskFramework rdf:type rdf:Property ;
    rdfs:label 'Risk Framework' ;
    rdfs:comment 'The risk management framework or standard applied (e.g., ISO 31000, COSO ERM, PMI Risk Management).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Methodology' ;
    rdfs:comment 'The methodology used for risk quantification and analysis in this register (e.g., Monte Carlo simulation, deterministic analysis, qualitative scoring).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskThresholdCostUsd rdf:type rdf:Property ;
    rdfs:label 'Risk Threshold Cost Usd' ;
    rdfs:comment 'The cost impact threshold in USD above which a risk is escalated to executive management for review and decision.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskThresholdScheduleDays rdf:type rdf:Property ;
    rdfs:label 'Risk Threshold Schedule Days' ;
    rdfs:comment 'The schedule impact threshold in days above which a risk is escalated to executive management for review and decision.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostExposureP50Usd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Exposure P50 Usd' ;
    rdfs:comment 'Total quantified cost risk exposure at the 50th percentile (P50 or median) in USD, representing the expected cost impact of all risks.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostExposureP80Usd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Exposure P80 Usd' ;
    rdfs:comment 'Total quantified cost risk exposure at the 80th percentile (P80) in USD, representing a higher confidence level for cost contingency planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostExposureP90Usd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Exposure P90 Usd' ;
    rdfs:comment 'Total quantified cost risk exposure at the 90th percentile (P90) in USD, representing a conservative estimate for risk reserves.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRiskCount rdf:type rdf:Property ;
    rdfs:label 'Total Risk Count' ;
    rdfs:comment 'Total number of individual risk items recorded in this risk register version.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalScheduleExposureP50Days rdf:type rdf:Property ;
    rdfs:label 'Total Schedule Exposure P50 Days' ;
    rdfs:comment 'Total quantified schedule risk exposure at the 50th percentile (P50) in days, representing the expected schedule delay impact of all risks.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScheduleExposureP80Days rdf:type rdf:Property ;
    rdfs:label 'Total Schedule Exposure P80 Days' ;
    rdfs:comment 'Total quantified schedule risk exposure at the 80th percentile (P80) in days, used for schedule contingency planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScheduleExposureP90Days rdf:type rdf:Property ;
    rdfs:label 'Total Schedule Exposure P90 Days' ;
    rdfs:comment 'Total quantified schedule risk exposure at the 90th percentile (P90) in days, representing a conservative schedule buffer estimate.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Reference to the work calendar applied to this activity, defining working days, shifts, and holidays used for duration calculations.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:primaryScheduleWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Primary Schedule Wbs Element Id' ;
    rdfs:comment 'Reference to the WBS element under which this activity is organized.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:activityNotes rdf:type rdf:Property ;
    rdfs:label 'Activity Notes' ;
    rdfs:comment 'Free-text notes and comments related to the activity, capturing progress updates, issues, decisions, or other relevant information.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'The total budgeted cost allocated to this activity, representing the planned value for earned value management calculations.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedLabourHours rdf:type rdf:Property ;
    rdfs:label 'Budgeted Labour Hours' ;
    rdfs:comment 'The total planned labour hours allocated to this activity across all resources.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintDate rdf:type rdf:Property ;
    rdfs:label 'Constraint Date' ;
    rdfs:comment 'The date associated with the constraint type, defining the earliest, latest, or mandatory date for activity start or finish.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Type of schedule constraint applied to this activity, restricting when it can be scheduled relative to a constraint date. [ENUM-REF-CANDIDATE: as_soon_as_possible|as_late_as_possible|start_no_earlier_than|start_no_later_than|finish_no_earlier_than|finish_no_later_than|must_start_on|must_finish_on — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyFinishDate rdf:type rdf:Property ;
    rdfs:label 'Early Finish Date' ;
    rdfs:comment 'The earliest possible date the activity can finish based on network logic and predecessor constraints, calculated via Critical Path Method (CPM).' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyStartDate rdf:type rdf:Property ;
    rdfs:label 'Early Start Date' ;
    rdfs:comment 'The earliest possible date the activity can start based on network logic and predecessor constraints, calculated via Critical Path Method (CPM).' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeFloatDays rdf:type rdf:Property ;
    rdfs:label 'Free Float Days' ;
    rdfs:comment 'The amount of time in working days that the activity can be delayed without delaying the early start of any successor activity.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Boolean flag indicating whether this activity is on the critical path (True) or not (False). Critical path activities have zero or negative total float and directly impact project completion date.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateFinishDate rdf:type rdf:Property ;
    rdfs:label 'Late Finish Date' ;
    rdfs:comment 'The latest date the activity can finish without delaying the project finish date, calculated via Critical Path Method (CPM).' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateStartDate rdf:type rdf:Property ;
    rdfs:label 'Late Start Date' ;
    rdfs:comment 'The latest date the activity can start without delaying the project finish date, calculated via Critical Path Method (CPM).' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDurationDays rdf:type rdf:Property ;
    rdfs:label 'Original Duration Days' ;
    rdfs:comment 'The initially estimated duration of the activity in working days as defined in the baseline schedule.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Duration Days' ;
    rdfs:comment 'The estimated number of working days required to complete the activity from the data date, updated during schedule progress updates.' ;
    rdfs:domain ind:ScheduleActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryNextGateStageGateId rdf:type rdf:Property ;
    rdfs:label 'Primary Next Gate Stage Gate Id' ;
    rdfs:comment 'Reference to the subsequent stage gate in the project lifecycle sequence.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StageGate .

ind:actualReviewDate rdf:type rdf:Property ;
    rdfs:label 'Actual Review Date' ;
    rdfs:comment 'Actual date when the stage gate review meeting was conducted.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Specific conditions, requirements, or actions that must be satisfied for conditional approval or before proceeding to the next stage.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthority rdf:type rdf:Property ;
    rdfs:label 'Decision Authority' ;
    rdfs:comment 'Governance body or role authorized to approve or reject this stage gate (e.g., Board, ExCo, Project Review Committee).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCapexUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex Usd' ;
    rdfs:comment 'Estimated total capital expenditure for the project at this stage gate, expressed in USD.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedIrrPercent rdf:type rdf:Property ;
    rdfs:label 'Estimated Irr Percent' ;
    rdfs:comment 'Estimated internal rate of return for the project at this stage gate, expressed as a percentage.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNpvUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Npv Usd' ;
    rdfs:comment 'Estimated net present value of the project at this stage gate, used as a key financial decision criterion.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateChairName rdf:type rdf:Property ;
    rdfs:label 'Gate Chair Name' ;
    rdfs:comment 'Name of the individual who chaired the stage gate review meeting.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCode rdf:type rdf:Property ;
    rdfs:label 'Gate Code' ;
    rdfs:comment 'Standardized code identifying the stage gate (e.g., G0, G1, G2, G3, G4, G5).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCriteria rdf:type rdf:Property ;
    rdfs:label 'Gate Criteria' ;
    rdfs:comment 'Specific evaluation criteria and success metrics that must be met for gate approval (e.g., minimum NPV threshold, IRR target, risk assessment completion, regulatory approvals obtained).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDescription rdf:type rdf:Property ;
    rdfs:label 'Gate Description' ;
    rdfs:comment 'Detailed description of the purpose, scope, and objectives of this stage gate within the project governance framework.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDurationDays rdf:type rdf:Property ;
    rdfs:label 'Gate Duration Days' ;
    rdfs:comment 'Typical or actual duration in days allocated for completing the stage gate review process from submission to decision.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateName rdf:type rdf:Property ;
    rdfs:label 'Gate Name' ;
    rdfs:comment 'Descriptive name of the stage gate (e.g., Gate 0 Concept, Gate 1 Pre-Feasibility, Gate 2 Feasibility, Gate 3 Execution Approval, Gate 4 Commissioning, Gate 5 Handover).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateSequence rdf:type rdf:Property ;
    rdfs:label 'Gate Sequence' ;
    rdfs:comment 'Sequential order of this gate within the project lifecycle (e.g., 0, 1, 2, 3, 4, 5).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Status' ;
    rdfs:comment 'Current status of the stage gate review and decision process. [ENUM-REF-CANDIDATE: pending|in_review|approved|conditional_approval|rejected|deferred|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of the stage gate within the project lifecycle framework.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this stage gate is mandatory for all projects or optional based on project size, complexity, or risk profile.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredDeliverables rdf:type rdf:Property ;
    rdfs:label 'Required Deliverables' ;
    rdfs:comment 'Comprehensive list of mandatory deliverables, documents, and artifacts that must be completed and submitted for this stage gate review (e.g., feasibility study, resource estimate, environmental impact statement, financial model).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveEstimateConfidence rdf:type rdf:Property ;
    rdfs:label 'Reserve Estimate Confidence' ;
    rdfs:comment 'Confidence level of the ore reserve estimate at this stage gate, aligned with JORC or NI 43-101 classification (Probable, Proved).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceEstimateConfidence rdf:type rdf:Property ;
    rdfs:label 'Resource Estimate Confidence' ;
    rdfs:comment 'Confidence level of the mineral resource estimate at this stage gate, aligned with JORC or NI 43-101 classification (Inferred, Indicated, Measured).' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCommitteeMembers rdf:type rdf:Property ;
    rdfs:label 'Review Committee Members' ;
    rdfs:comment 'List of committee members who participated in the stage gate review and decision process.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of key risks identified and assessed at this stage gate, including technical, financial, environmental, regulatory, and operational risks.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledReviewDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Review Date' ;
    rdfs:comment 'Planned date for the stage gate review meeting and decision.' ;
    rdfs:domain ind:StageGate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchmarkPriceId rdf:type rdf:Property ;
    rdfs:label 'Benchmark Price Id' ;
    rdfs:comment 'Unique identifier for the benchmark price record. Primary key for the benchmark price data product.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceIndexId rdf:type rdf:Property ;
    rdfs:label 'Price Index Id' ;
    rdfs:comment 'Foreign key linking to sales.price_index. Business justification: benchmark_price is daily price data for commodity indices; price_index is the index master/reference. benchmark_price should reference price_index to normalize index metadata. The target price_index t' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceIndex .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Description of the methodology used by the publishing agency to assess or calculate this benchmark price (e.g., survey-based, transaction-based, bid-offer spread, volume-weighted average). Important for understanding price reliability and contract applicability.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGrade rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade' ;
    rdfs:comment 'The specific grade or quality specification of the commodity (e.g., 62% Fe, 65% Fe, Grade A Copper Cathode, Thermal Coal 6000 kcal/kg NAR, Battery Grade Lithium Carbonate).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSpecification rdf:type rdf:Property ;
    rdfs:label 'Contract Specification' ;
    rdfs:comment 'Detailed specification of the underlying contract or assessment criteria, including quality parameters, delivery terms, and any adjustments or premiums/discounts applied by the publishing agency.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Data Source Url' ;
    rdfs:comment 'The URL or reference to the publishing agency\'s official data source for this benchmark price. Used for audit trail and data lineage verification.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryBasis rdf:type rdf:Property ;
    rdfs:label 'Delivery Basis' ;
    rdfs:comment 'The Incoterms delivery basis for the benchmark price (e.g., CFR - Cost Insurance and Freight, FOB - Free on Board, CIF - Cost Insurance and Freight). Defines the point at which risk and cost transfer.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Index Effective Date' ;
    rdfs:comment 'The date from which this benchmark price index became active and available for use in offtake contracts. Defines the start of the index\'s lifecycle.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Index Expiry Date' ;
    rdfs:comment 'The date on which this benchmark price index was discontinued or became inactive. Null for currently active indices.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexStatus rdf:type rdf:Property ;
    rdfs:label 'Index Status' ;
    rdfs:comment 'Current lifecycle status of the benchmark price index. Active indices are currently published and used in contracts; Inactive or Discontinued indices are no longer published but historical data is retained.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceClose rdf:type rdf:Property ;
    rdfs:label 'Price Close' ;
    rdfs:comment 'The closing or settlement price value for the price_date, applicable for exchange-traded indices (e.g., LME). Often used as the official settlement price in contracts.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceDate rdf:type rdf:Property ;
    rdfs:label 'Price Date' ;
    rdfs:comment 'The date for which this benchmark price value is published. This is the business event date representing the pricing period or assessment date, not the publication timestamp.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceHigh rdf:type rdf:Property ;
    rdfs:label 'Price High' ;
    rdfs:comment 'The highest price value published for the price_date, if the publishing agency provides a price range or intraday high. Used for volatility analysis and risk assessment.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceLow rdf:type rdf:Property ;
    rdfs:label 'Price Low' ;
    rdfs:comment 'The lowest price value published for the price_date, if the publishing agency provides a price range or intraday low. Used for volatility analysis and risk assessment.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceOpen rdf:type rdf:Property ;
    rdfs:label 'Price Open' ;
    rdfs:comment 'The opening price value for the price_date, applicable for exchange-traded indices (e.g., LME). Used for intraday price movement analysis.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'The type of price represented by this index (e.g., Spot - immediate delivery, Forward - future delivery, Futures - exchange-traded contract, Assessment - agency-assessed price, Settlement - official settlement price).' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValue rdf:type rdf:Property ;
    rdfs:label 'Price Value' ;
    rdfs:comment 'The published benchmark price value for the given price_date, expressed in the unit_of_measure and currency_code. This is the core pricing data used in provisional pricing calculations and final settlement adjustments.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Publication Frequency' ;
    rdfs:comment 'How frequently the publishing agency releases new price values for this index (e.g., Daily, Weekly, Monthly, Real-time).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Publication Timestamp' ;
    rdfs:comment 'The exact date and time when the publishing agency released this price value. Used to track data freshness and ensure timely price updates for provisional pricing calculations.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quotationalPeriodConvention rdf:type rdf:Property ;
    rdfs:label 'Quotational Period Convention' ;
    rdfs:comment 'The time period convention used for price quotation and settlement in offtake contracts (e.g., Monthly Average of Daily Prices, Spot, Forward Month+1, Forward Month+2, Quarterly Average). Defines how prices are averaged or selected for provisional and final invoicing.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionIndicator rdf:type rdf:Property ;
    rdfs:label 'Revision Indicator' ;
    rdfs:comment 'Flag indicating whether this price value has been revised or corrected by the publishing agency after initial publication. True if revised, False if original publication.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revision Timestamp' ;
    rdfs:comment 'The date and time when this price value was revised by the publishing agency, if applicable. Null if no revision has occurred.' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volumeTraded rdf:type rdf:Property ;
    rdfs:label 'Volume Traded' ;
    rdfs:comment 'The total volume of commodity traded at this benchmark price on the price_date, if reported by the publishing agency (e.g., for exchange-traded indices). Expressed in the commodity\'s standard unit (tonnes, pounds, ounces).' ;
    rdfs:domain ind:BenchmarkPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfLadingId rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Id' ;
    rdfs:comment 'Unique identifier for the bill of lading record. Primary key for the bill of lading entity.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issued By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Bills of lading require issuance by authorized shipping personnel for legal validity, customs clearance, and title transfer. Essential for accountability, regulatory compliance, and dispute resolution' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryBillCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Bill Counterparty Id' ;
    rdfs:comment 'Reference to the shipper party (typically the mining company or seller) consigning the cargo.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:vesselId rdf:type rdf:Property ;
    rdfs:label 'Vessel Id' ;
    rdfs:comment 'Reference to the vessel transporting the commodity cargo.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vessel .

ind:blNumber rdf:type rdf:Property ;
    rdfs:label 'Bl Number' ;
    rdfs:comment 'Externally-known unique bill of lading number issued by the carrier. Legal document identifier used for title transfer and documentary credit in commodity trade.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blStatus rdf:type rdf:Property ;
    rdfs:label 'Bl Status' ;
    rdfs:comment 'Current lifecycle status of the bill of lading document.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blType rdf:type rdf:Property ;
    rdfs:label 'Bl Type' ;
    rdfs:comment 'Classification of the bill of lading document type indicating its legal status and usage.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Full address of the consignee party including street, city, state, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Legal name of the consignee party as stated on the bill of lading.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerNumbers rdf:type rdf:Property ;
    rdfs:label 'Container Numbers' ;
    rdfs:comment 'Comma-separated list of container identification numbers if cargo is shipped in containers.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Indicates whether freight charges are prepaid by the shipper or collected from the consignee.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightMt rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Mt' ;
    rdfs:comment 'Total weight of the commodity cargo including moisture and packaging, measured in metric tonnes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Indicates whether the bill of lading is negotiable (transferable title document) or non-negotiable (straight consignment).' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marksAndNumbers rdf:type rdf:Property ;
    rdfs:label 'Marks And Numbers' ;
    rdfs:comment 'Identifying marks, numbers, or labels on the packages or containers for cargo identification and tracking.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDryWeightMt rdf:type rdf:Property ;
    rdfs:label 'Net Dry Weight Mt' ;
    rdfs:comment 'Weight of the commodity cargo on a dry basis excluding all moisture content, measured in metric tonnes. Critical for pricing and settlement in commodity trade.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeightMt rdf:type rdf:Property ;
    rdfs:label 'Net Weight Mt' ;
    rdfs:comment 'Weight of the commodity cargo excluding packaging and moisture, measured in metric tonnes.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notifyPartyAddress rdf:type rdf:Property ;
    rdfs:label 'Notify Party Address' ;
    rdfs:comment 'Full address of the notify party including contact details.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifyPartyName rdf:type rdf:Property ;
    rdfs:label 'Notify Party Name' ;
    rdfs:comment 'Name of the party to be notified upon arrival of the cargo at the destination port.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfOriginals rdf:type rdf:Property ;
    rdfs:label 'Number Of Originals' ;
    rdfs:comment 'Total number of original bill of lading documents issued. Typically 3 originals are issued in international trade.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of packages, containers, or units comprising the shipment.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onBoardDate rdf:type rdf:Property ;
    rdfs:label 'On Board Date' ;
    rdfs:comment 'Date when the cargo was loaded on board the vessel. May differ from issue date for received-for-shipment bills of lading.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Type of packaging or container used for the commodity cargo.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Place Of Delivery' ;
    rdfs:comment 'Final destination where the cargo will be delivered to the consignee, which may differ from the port of discharge for multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfReceipt rdf:type rdf:Property ;
    rdfs:label 'Place Of Receipt' ;
    rdfs:comment 'Location where the carrier received the cargo from the shipper, which may differ from the port of loading for multimodal transport.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Code' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the port where cargo is unloaded from the vessel.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfDischargeName rdf:type rdf:Property ;
    rdfs:label 'Port Of Discharge Name' ;
    rdfs:comment 'Full name of the port where the commodity cargo is unloaded from the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingCode rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Code' ;
    rdfs:comment 'United Nations Code for Trade and Transport Locations (UN/LOCODE) for the port where cargo is loaded onto the vessel.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portOfLoadingName rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading Name' ;
    rdfs:comment 'Full name of the port where the commodity cargo is loaded onto the vessel.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperAddress rdf:type rdf:Property ;
    rdfs:label 'Shipper Address' ;
    rdfs:comment 'Full address of the shipper party including street, city, state, and country.' ;
    rdfs:domain ind:BillOfLading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Legal name of the shipper party as stated on the bill of lading.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityOrderId rdf:type rdf:Property ;
    rdfs:label 'Commodity Order Id' ;
    rdfs:comment 'Foreign key linking to sales.commodity_order. Business justification: cargo_shipment has sales_contract_number (STRING) which represents the link to the originating commodity_order. Adding commodity_order_id FK establishes proper parent-child relationship between order ' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityOrder .

ind:freightContractId rdf:type rdf:Property ;
    rdfs:label 'Freight Contract Id' ;
    rdfs:comment 'Foreign key linking to sales.freight_contract. Business justification: Each cargo shipment is executed under a governing freight contract. Adding freight_contract_id links the shipment to its contractual terms, enabling freight cost validation and contract utilization tr' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightContract .

ind:logisticsCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Logistics Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cargo shipments require a logistics coordinator responsible for vessel operations, port coordination, documentation, and demurrage management. Critical for operational accountability, dispute resoluti' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blIssueDate rdf:type rdf:Property ;
    rdfs:label 'Bl Issue Date' ;
    rdfs:comment 'Date on which the bill of lading was issued by the carrier. Principal business event timestamp for legal title transfer.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demurrageAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Demurrage Amount Usd' ;
    rdfs:comment 'Demurrage charges incurred when laytime used exceeds laytime allowed, expressed in United States Dollars.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:despatchAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Despatch Amount Usd' ;
    rdfs:comment 'Despatch money earned when laytime used is less than laytime allowed, expressed in United States Dollars.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeCommencedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharge Commenced Timestamp' ;
    rdfs:comment 'Date and time when cargo discharge operations commenced at the port of discharge.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dischargeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discharge Completed Timestamp' ;
    rdfs:comment 'Date and time when cargo discharge operations were completed at the port of discharge.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentaryCreditCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Documentary Credit Compliant Flag' ;
    rdfs:comment 'Indicates whether the shipment documentation complies with the terms and conditions of the letter of credit. True if compliant, False if discrepancies exist.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCostUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Cost Usd' ;
    rdfs:comment 'Total insurance cost for this shipment in United States Dollars. Applicable when insurance is borne by the seller under CIF terms.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Invoice Value Usd' ;
    rdfs:comment 'Total invoiced value of the cargo shipment in United States Dollars, used for revenue recognition and customs declaration.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laytimeAllowedHours rdf:type rdf:Property ;
    rdfs:label 'Laytime Allowed Hours' ;
    rdfs:comment 'Total laytime (loading and discharge time) allowed under the charter party or sales contract, expressed in hours.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laytimeUsedHours rdf:type rdf:Property ;
    rdfs:label 'Laytime Used Hours' ;
    rdfs:comment 'Actual laytime used for loading and discharge operations, expressed in hours.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingCommencedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Commenced Timestamp' ;
    rdfs:comment 'Date and time when cargo loading operations commenced at the port of loading.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loading Completed Timestamp' ;
    rdfs:comment 'Date and time when cargo loading operations were completed at the port of loading.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netDryWeightDmt rdf:type rdf:Property ;
    rdfs:label 'Net Dry Weight Dmt' ;
    rdfs:comment 'Net weight of cargo after adjusting for moisture content, expressed in dry metric tonnes. Used for invoicing and revenue recognition.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippedQuantityWmt rdf:type rdf:Property ;
    rdfs:label 'Shipped Quantity Wmt' ;
    rdfs:comment 'Total gross weight of cargo shipped in wet metric tonnes, including moisture content.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Name of the terminal or berth at the port of loading where the cargo was loaded.' ;
    rdfs:domain ind:CargoShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offtakeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Offtake Agreement Id' ;
    rdfs:comment 'Reference to the parent term offtake agreement under which this order was raised. Null for spot orders that are not tied to a long-term contract.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfftakeAgreement .

ind:orderManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Order Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Commodity orders require a sales coordinator or trader responsible for order execution, customer communication, and delivery coordination. Essential for operational accountability, customer relationsh' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:spotTradeId rdf:type rdf:Property ;
    rdfs:label 'Spot Trade Id' ;
    rdfs:comment 'Foreign key linking to sales.spot_trade. Business justification: commodity_order has spot_market_reference (STRING) which for spot orders should link to the spot_trade record. Adding spot_trade_id FK establishes the relationship between spot orders and their trade ' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpotTrade .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Timestamp when the order was confirmed and became a binding commitment. Marks the transition from draft to confirmed status.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryDestination rdf:type rdf:Property ;
    rdfs:label 'Delivery Destination' ;
    rdfs:comment 'Named port, terminal, or facility where the commodity is to be delivered. Examples include Port Hedland, Qingdao Port, Rotterdam.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Incoterms delivery terms defining the point at which risk and cost transfer from seller to buyer. Common terms include Free on Board (FOB), Cost Insurance and Freight (CIF), Cost and Freight (CFR).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End' ;
    rdfs:comment 'End date of the delivery window during which the commodity must be shipped or delivered to the buyer. Defines the latest acceptable delivery date.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start' ;
    rdfs:comment 'Start date of the delivery window during which the commodity must be shipped or delivered to the buyer. Defines the earliest acceptable delivery date.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPrice rdf:type rdf:Property ;
    rdfs:label 'Final Price' ;
    rdfs:comment 'Final settled price per unit after all adjustments for assay, quality, and market conditions. Null until final pricing is determined.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomForecastPeriod rdf:type rdf:Property ;
    rdfs:label 'Lom Forecast Period' ;
    rdfs:comment 'Reference to the Life of Mine (LOM) production forecast period against which this order is tracked. Used to reconcile actual sales commitments against long-term production plans.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text field for additional comments, special instructions, or contextual information related to this order. Used for operational coordination and audit trail.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally visible business identifier for the commodity order. Used in communications with buyers, logistics providers, and internal reporting.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'Committed volume of commodity to be delivered under this order. Measured in the unit of measure specified in the order.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the commodity order. Tracks progression from initial commitment through delivery and invoicing. [ENUM-REF-CANDIDATE: draft|confirmed|nominated|in_transit|delivered|invoiced|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Discriminator indicating whether this order is raised under a term offtake agreement or executed as a spot trade. Term orders are part of long-term contracts; spot orders are immediate market transactions.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'Total monetary value of the order calculated as order quantity multiplied by the applicable price (provisional or final). Represents the gross revenue commitment for this order.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceCurrency rdf:type rdf:Property ;
    rdfs:label 'Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the commodity price is denominated. Most mining commodities are priced in USD.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure for the price (e.g., USD per Dry Metric Tonne, USD per pound). Must align with the quantity unit of measure.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalPrice rdf:type rdf:Property ;
    rdfs:label 'Provisional Price' ;
    rdfs:comment 'Initial price per unit agreed at the time of order confirmation, subject to final adjustment based on assay results and market conditions. Used in provisional pricing arrangements.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitySpecification rdf:type rdf:Property ;
    rdfs:label 'Quality Specification' ;
    rdfs:comment 'Detailed quality parameters and tolerances agreed for this order (e.g., Fe content, moisture limits, impurity thresholds). Used for quality assurance and contract compliance.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for the order quantity. Common units include Dry Metric Tonnes (DMT), Wet Metric Tonnes (WMT), Metric Tonnes (MT), pounds, and troy ounces depending on commodity type.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Payment terms and conditions agreed for this order (e.g., 30 days after Bill of Lading, Letter of Credit, advance payment). Defines when and how the buyer will pay.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNominationReference rdf:type rdf:Property ;
    rdfs:label 'Shipment Nomination Reference' ;
    rdfs:comment 'Reference to the shipment nomination record that allocates this order to a specific vessel or transport movement. Links the order to the physical logistics execution.' ;
    rdfs:domain ind:CommodityOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demurrageClaimId rdf:type rdf:Property ;
    rdfs:label 'Demurrage Claim Id' ;
    rdfs:comment 'Unique identifier for the demurrage or despatch claim record. Primary key for the demurrage claim entity.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Claims Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Demurrage claims require a designated claims manager responsible for dispute resolution, negotiation, and recovery. Essential for accountability, performance tracking, legal compliance, and optimizing' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:settlementInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Settlement Invoice Id' ;
    rdfs:comment 'Foreign key linking to sales.invoice. Business justification: Demurrage claims result in settlement invoices (either demurrage charges to customer or despatch credits from carrier). Adding settlement_invoice_id (FK to invoice.sales_invoice_id) links the claim to' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:cargoQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Cargo Quantity Tonnes' ;
    rdfs:comment 'Total quantity of commodity loaded or discharged, measured in metric tonnes.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimAgreedDate rdf:type rdf:Property ;
    rdfs:label 'Claim Agreed Date' ;
    rdfs:comment 'Date on which the counterparty agreed to the claim amount and terms.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Claim Amount Usd' ;
    rdfs:comment 'Total monetary value of the demurrage or despatch claim in USD, calculated from laytime variance and applicable rate.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Claim Raised Date' ;
    rdfs:comment 'Date on which the demurrage or despatch claim was formally raised with the counterparty.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSettledDate rdf:type rdf:Property ;
    rdfs:label 'Claim Settled Date' ;
    rdfs:comment 'Date on which the demurrage or despatch claim was financially settled (payment received or credit applied).' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demurrageRateUsdPerDay rdf:type rdf:Property ;
    rdfs:label 'Demurrage Rate Usd Per Day' ;
    rdfs:comment 'Contractual demurrage rate in USD per day charged for exceeding the allowed laytime.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:despatchRateUsdPerDay rdf:type rdf:Property ;
    rdfs:label 'Despatch Rate Usd Per Day' ;
    rdfs:comment 'Contractual despatch rate in USD per day credited for completing operations within the allowed laytime.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Detailed notes on dispute resolution activities, arbitration proceedings, or settlement negotiations.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laytimeVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Laytime Variance Hours' ;
    rdfs:comment 'Difference between laytime used and laytime allowed (positive indicates demurrage, negative indicates despatch).' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBackImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Net Back Impact Usd' ;
    rdfs:comment 'Financial impact of the demurrage or despatch claim on the sales net-back realization (negative for demurrage, positive for despatch).' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticeOfReadinessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notice Of Readiness Timestamp' ;
    rdfs:comment 'Date and time when the vessel tendered Notice of Readiness (NOR) to commence loading or discharge operations.' ;
    rdfs:domain ind:DemurrageClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:portOfLoading rdf:type rdf:Property ;
    rdfs:label 'Port Of Loading' ;
    rdfs:comment 'Name of the port where the commodity was loaded onto the vessel.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Freight contracts require a commercial manager responsible for negotiation, execution, and ongoing management. Critical for contract accountability, renewal management, freight cost optimization, and ' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arbitrationClause rdf:type rdf:Property ;
    rdfs:label 'Arbitration Clause' ;
    rdfs:comment 'Terms defining dispute resolution mechanism, including arbitration venue and rules (e.g., London Maritime Arbitrators Association, Singapore Chamber of Maritime Arbitration).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bunkerAdjustmentClause rdf:type rdf:Property ;
    rdfs:label 'Bunker Adjustment Clause' ;
    rdfs:comment 'Terms defining how changes in bunker fuel prices affect the freight rate, including base fuel price and adjustment mechanism.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the freight contract becomes binding and operative.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when the freight contract terminates. Nullable for spot charters or open-ended arrangements.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Period Months' ;
    rdfs:comment 'Duration of the contract in months. Applicable primarily to time charters and contracts of affreightment.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demurrageRate rdf:type rdf:Property ;
    rdfs:label 'Demurrage Rate' ;
    rdfs:comment 'Daily penalty rate charged when loading or discharge operations exceed the agreed laytime. Typically expressed in USD per day.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:despatchRate rdf:type rdf:Property ;
    rdfs:label 'Despatch Rate' ;
    rdfs:comment 'Daily bonus rate paid when loading or discharge operations are completed ahead of the agreed laytime. Typically expressed in USD per day, often 50% of demurrage rate.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Contractual terms defining events beyond parties\' control that excuse performance (e.g., natural disasters, war, strikes, port closures).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightBasis rdf:type rdf:Property ;
    rdfs:label 'Freight Basis' ;
    rdfs:comment 'INCOTERM defining the freight responsibility. FOB (Free on Board) - buyer arranges freight, CFR (Cost and Freight) - seller pays freight, CIF (Cost Insurance and Freight) - seller pays freight and insurance, DAP (Delivered at Place), EXW (Ex Works).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRate rdf:type rdf:Property ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Contracted freight rate per unit. The unit is defined in freight_rate_unit (e.g., USD per tonne, USD per day for time charter).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightRateUnit rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Unit' ;
    rdfs:comment 'Unit of measure for the freight rate. Per tonne for voyage charters, per day for time charters, per voyage for lump sum arrangements.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of this contract (e.g., English Law, New York Law, Australian Law).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Party responsible for arranging and paying for cargo insurance during transit.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingPort rdf:type rdf:Property ;
    rdfs:label 'Loading Port' ;
    rdfs:comment 'Port or port range where the commodity cargo will be loaded onto the vessel.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCargoQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Cargo Quantity Tonnes' ;
    rdfs:comment 'Maximum cargo quantity in metric tonnes that can be shipped per voyage or contract period.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCargoQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Minimum Cargo Quantity Tonnes' ;
    rdfs:comment 'Minimum cargo quantity in metric tonnes that must be shipped per voyage or contract period.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBackImpactUsdPerTonne rdf:type rdf:Property ;
    rdfs:label 'Net Back Impact Usd Per Tonne' ;
    rdfs:comment 'Calculated impact of this freight contract on net-back realisation per tonne of commodity sold. Critical for sales margin analysis.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Days' ;
    rdfs:comment 'Number of days after invoice date or completion of voyage when payment is due.' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portRange rdf:type rdf:Property ;
    rdfs:label 'Port Range' ;
    rdfs:comment 'Geographic range of ports covered by this contract (e.g., Australian East Coast, Chinese North Ports, Rotterdam-Hamburg range).' ;
    rdfs:domain ind:FreightContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the freight contract was formally executed by all parties.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vesselType rdf:type rdf:Property ;
    rdfs:label 'Vessel Type' ;
    rdfs:comment 'Classification of vessel size and capability. Capesize (150,000+ DWT), Panamax (60,000-80,000 DWT), Handymax (40,000-60,000 DWT), Handysize (10,000-40,000 DWT), VLOC (Very Large Ore Carrier 200,000+ DWT), Supramax (50,000-60,000 DWT).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Primary key for invoice' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:qualityCertificateId rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Id' ;
    rdfs:comment 'Foreign key linking to sales.quality_certificate. Business justification: invoice has assay_certificate_reference (STRING) which identifies the quality certificate supporting the invoice. Adding quality_certificate_id FK establishes proper relationship. The assay_certificat' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityCertificate .

ind:adjustmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjustment Quantity' ;
    rdfs:comment 'Quantity adjustment applied during final settlement due to assay results, moisture content, or other quality factors that differ from provisional assumptions. May be positive or negative.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Status of the provisional-to-final price adjustment process. Indicates whether adjustments are pending, in progress, completed, or not applicable for this invoice.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'Monetary value of the price adjustment resulting from the difference between provisional and final prices, or from quantity adjustments. Represents the delta between provisional and final invoice value.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerReference rdf:type rdf:Property ;
    rdfs:label 'Buyer Reference' ;
    rdfs:comment 'External reference number or purchase order number provided by the buyer for invoice reconciliation and payment processing.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Total quantity of commodity invoiced, typically measured in dry metric tonnes (DMT) or wet metric tonnes (WMT) depending on the commodity and contract terms.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment is due from the buyer according to the agreed payment terms. Used for accounts receivable aging and cash flow forecasting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationalPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Quotational Period End' ;
    rdfs:comment 'End date of the quotational period during which benchmark prices are averaged. Marks the conclusion of the pricing window for final settlement calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationalPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Quotational Period Start' ;
    rdfs:comment 'Start date of the quotational period during which benchmark prices (Platts, TSI) are averaged to determine the final settlement price. Critical for provisional-to-final price adjustment calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date on which the commodity cargo was shipped or dispatched to the buyer. Used for revenue recognition timing and logistics tracking.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalInvoiceValue rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Value' ;
    rdfs:comment 'Total monetary value of the invoice after all adjustments, representing the final amount due from the buyer. This is the SSOT for revenue recognition.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the offtake agreement, used in commercial correspondence and invoicing.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Tonnes' ;
    rdfs:comment 'Annual contracted volume in metric tonnes for term agreements. Null for spot agreements.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePriceUsdPerTonne rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd Per Tonne' ;
    rdfs:comment 'Base or reference price per metric tonne in USD for fixed-price agreements, or the floor/ceiling price for index-linked agreements.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Tonnes' ;
    rdfs:comment 'Total volume of commodity contracted under this agreement, measured in metric tonnes. For term agreements, this is the aggregate volume over the agreement tenure.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationPort rdf:type rdf:Property ;
    rdfs:label 'Destination Port' ;
    rdfs:comment 'Name of the destination port or delivery location specified in the agreement (e.g., Qingdao, Rotterdam, Yokohama).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumShipmentSizeTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Shipment Size Tonnes' ;
    rdfs:comment 'Maximum cargo size per shipment in metric tonnes, as stipulated in the agreement.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumShipmentSizeTonnes rdf:type rdf:Property ;
    rdfs:label 'Minimum Shipment Size Tonnes' ;
    rdfs:comment 'Minimum cargo size per shipment in metric tonnes, as stipulated in the agreement (e.g., Panamax 60,000 tonnes, Capesize 150,000 tonnes).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offtakeAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Offtake Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the offtake agreement: draft (under negotiation), active (in force), suspended (temporarily paused), expired (reached end date), terminated (cancelled before expiry).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermDays rdf:type rdf:Property ;
    rdfs:label 'Payment Term Days' ;
    rdfs:comment 'Number of days from invoice date or bill of lading date within which payment is due (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingMechanism rdf:type rdf:Property ;
    rdfs:label 'Pricing Mechanism' ;
    rdfs:comment 'Method by which the commodity price is determined: index-linked (tied to Platts, TSI, LME), fixed (agreed price), benchmark (reference price with adjustments), or formula (custom calculation).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Quality Penalty Clause' ;
    rdfs:comment 'Indicates whether the agreement includes penalties or price adjustments for commodity quality deviations from specification.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to expiry by which a party must provide notice of intent to renew or terminate.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Terms governing renewal of the agreement upon expiry: automatic (auto-renews unless terminated), mutual_consent (both parties must agree), buyer_option (buyer can extend), seller_option (seller can extend), none (no renewal).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Shipment Frequency' ;
    rdfs:comment 'Expected frequency of shipments under the agreement (e.g., monthly, quarterly, as-nominated).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureYears rdf:type rdf:Property ;
    rdfs:label 'Tenure Years' ;
    rdfs:comment 'Duration of the agreement in years, calculated from effective date to expiry date. Null for spot agreements.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offtakeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Offtake Schedule Id' ;
    rdfs:comment 'Unique identifier for the offtake schedule record. Primary key.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentNominationId rdf:type rdf:Property ;
    rdfs:label 'Shipment Nomination Id' ;
    rdfs:comment 'Reference to the shipment nomination record associated with this scheduled lifting, if nominated.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentNomination .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'End date of the delivery window during which the cargo lifting must occur.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'Start date of the delivery window during which the cargo lifting must occur.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Status indicating whether the scheduled lifting is being fulfilled according to plan, tracking shortfall or excess against contracted volumes. [ENUM-REF-CANDIDATE: not_started|on_track|at_risk|delayed|fulfilled|shortfall|excess — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftingNumber rdf:type rdf:Property ;
    rdfs:label 'Lifting Number' ;
    rdfs:comment 'Sequential number of the cargo lifting within the schedule period.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nominatedVesselName rdf:type rdf:Property ;
    rdfs:label 'Nominated Vessel Name' ;
    rdfs:comment 'Name of the vessel nominated by the buyer for this cargo lifting.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Port Allocation Code' ;
    rdfs:comment 'Code representing the specific port berth or allocation slot assigned for this lifting.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleMonth rdf:type rdf:Property ;
    rdfs:label 'Schedule Month' ;
    rdfs:comment 'Calendar month (1-12) to which this offtake schedule applies, if applicable.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulePeriodType rdf:type rdf:Property ;
    rdfs:label 'Schedule Period Type' ;
    rdfs:comment 'Frequency of scheduled deliveries under this offtake schedule.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleQuarter rdf:type rdf:Property ;
    rdfs:label 'Schedule Quarter' ;
    rdfs:comment 'Calendar quarter (1-4) to which this offtake schedule applies, if applicable.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleYear rdf:type rdf:Property ;
    rdfs:label 'Schedule Year' ;
    rdfs:comment 'Calendar year to which this offtake schedule applies.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledLiftingDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Lifting Date' ;
    rdfs:comment 'Target date for the cargo lifting within the delivery window.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledPricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Scheduled Price Per Tonne' ;
    rdfs:comment 'Planned or estimated price per tonne for this scheduled lifting at the time of schedule creation.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Revenue Amount' ;
    rdfs:comment 'Planned revenue amount for this scheduled lifting, calculated as scheduled volume multiplied by scheduled price.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Volume Tonnes' ;
    rdfs:comment 'Planned volume of commodity to be delivered in this lifting, measured in metric tonnes.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselNominationDeadline rdf:type rdf:Property ;
    rdfs:label 'Vessel Nomination Deadline' ;
    rdfs:comment 'Deadline by which the buyer must nominate the vessel for this cargo lifting.' ;
    rdfs:domain ind:OfftakeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:volumeVarianceTonnes rdf:type rdf:Property ;
    rdfs:label 'Volume Variance Tonnes' ;
    rdfs:comment 'Difference between scheduled and actual volume (actual minus scheduled), measured in metric tonnes.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sales performance actuals require preparation by commercial analysts for management reporting, variance analysis, and board reporting. Critical for accountability, audit trails, and ensuring data qual' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Amount' ;
    rdfs:comment 'The total revenue realized from commodity sales during the period, in the reporting currency.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Tonnes' ;
    rdfs:comment 'The actual volume of commodity sold during the period, measured in metric tonnes.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aiscPerTonne rdf:type rdf:Property ;
    rdfs:label 'Aisc Per Tonne' ;
    rdfs:comment 'The All-In Sustaining Cost per tonne for the commodity during the period, used for margin calculation.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkPricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Benchmark Price Per Tonne' ;
    rdfs:comment 'The benchmark or reference price per tonne for the commodity during the period (e.g., Platts, TSI index price).' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lomForecastAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lom Forecast Alignment Flag' ;
    rdfs:comment 'Indicates whether the actual performance aligns with the Life of Mine production forecast (True/False).' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginPerTonne rdf:type rdf:Property ;
    rdfs:label 'Margin Per Tonne' ;
    rdfs:comment 'The AISC-adjusted margin per tonne, calculated as realised price minus AISC per tonne.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'The status of the actuals record (e.g., confirmed, provisional, adjusted, final) indicating the level of finalization.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodMonth rdf:type rdf:Property ;
    rdfs:label 'Period Month' ;
    rdfs:comment 'The calendar month (1-12) for which this actual performance is recorded.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodQuarter rdf:type rdf:Property ;
    rdfs:label 'Period Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) for which this actual performance is recorded.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodYear rdf:type rdf:Property ;
    rdfs:label 'Period Year' ;
    rdfs:comment 'The calendar year for which this actual performance is recorded (e.g., 2024).' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Revenue Amount' ;
    rdfs:comment 'The planned or budgeted revenue for the period, in the reporting currency, used for variance calculation.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Planned Volume Tonnes' ;
    rdfs:comment 'The planned or budgeted volume of commodity for the period, measured in metric tonnes, used for variance calculation.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariancePerTonne rdf:type rdf:Property ;
    rdfs:label 'Price Variance Per Tonne' ;
    rdfs:comment 'The variance between realised price and benchmark price per tonne (realised minus benchmark).' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Variance Percentage' ;
    rdfs:comment 'The percentage variance between realised and benchmark price, calculated as (realised - benchmark) / benchmark * 100.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realisedPricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Realised Price Per Tonne' ;
    rdfs:comment 'The actual average price achieved per tonne of commodity sold during the period, calculated as actual revenue divided by actual volume.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Variance Amount' ;
    rdfs:comment 'The variance between actual and planned revenue (actual minus planned), in the reporting currency.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Variance Percentage' ;
    rdfs:comment 'The percentage variance between actual and planned revenue, calculated as (actual - planned) / planned * 100.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'The primary geographic market or region to which the commodity was sold (e.g., China, Europe, Domestic).' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Total Margin Amount' ;
    rdfs:comment 'The total AISC-adjusted margin for the period, calculated as margin per tonne multiplied by actual volume.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Variance Percentage' ;
    rdfs:comment 'The percentage variance between actual and planned volume, calculated as (actual - planned) / planned * 100.' ;
    rdfs:domain ind:PerformanceActual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentFactorApplicable rdf:type rdf:Property ;
    rdfs:label 'Adjustment Factor Applicable' ;
    rdfs:comment 'Indicates whether quality or specification adjustments are typically applied when using this index in pricing formulas (e.g., Fe content adjustments, moisture adjustments, impurity penalties).' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeIndexCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Index Code' ;
    rdfs:comment 'Reference to an alternative or successor index code that should be used if this index is deprecated or unavailable. Supports continuity planning for pricing formulas.' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date on which this index was discontinued or deprecated by the publishing agency. Null if the index is still active.' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexCategory rdf:type rdf:Property ;
    rdfs:label 'Index Category' ;
    rdfs:comment 'The type or category of price index (e.g., Spot market index, Forward curve, Futures settlement, Benchmark reference).' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCode rdf:type rdf:Property ;
    rdfs:label 'Index Code' ;
    rdfs:comment 'Unique business identifier code for the price index (e.g., PLATTS_62FE, TSI_COKING, LME_COPPER_CASH). Used in pricing formulas and offtake agreements.' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexFamily rdf:type rdf:Property ;
    rdfs:label 'Index Family' ;
    rdfs:comment 'Grouping or family name for related indices from the same publisher (e.g., Platts IODEX Family, TSI Coking Coal Suite, LME Base Metals). Used for hierarchical organization and reporting.' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMethodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Index Methodology Description' ;
    rdfs:comment 'Brief description of how the index is calculated or derived by the publishing agency (e.g., volume-weighted average of spot transactions, survey-based assessment, exchange settlement price).' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Full descriptive name of the price index (e.g., Platts IODEX 62% Fe CFR China, TSI Premium Hard Coking Coal FOB Australia).' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishingAgency rdf:type rdf:Property ;
    rdfs:label 'Publishing Agency' ;
    rdfs:comment 'The organization that publishes and maintains this price index (e.g., Platts, TSI - The Steel Index, LME - London Metal Exchange, Fastmarkets). [ENUM-REF-CANDIDATE: Platts|TSI|LME|Fastmarkets|Metal Bulletin|Argus|Bloomberg|CME|ICE|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceIndex ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Provisional Adjustment Id' ;
    rdfs:comment 'Unique identifier for the provisional price adjustment record. Primary key for the provisional adjustment entity.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Invoice Date' ;
    rdfs:comment 'Date on which the adjustment invoice or credit/debit note was issued to the counterparty.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Invoice Number' ;
    rdfs:comment 'Invoice document number issued for the provisional adjustment. May be a credit note (for negative adjustments) or debit note (for positive adjustments).' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Business identifier for the provisional adjustment transaction. Externally visible reference number used in financial reconciliation and customer communication.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment event. Distinguishes between initial provisional-to-final settlement, interim adjustments during quotational period, and supplementary corrections.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayAdjustmentApplied rdf:type rdf:Property ;
    rdfs:label 'Assay Adjustment Applied' ;
    rdfs:comment 'Indicates whether final assay results triggered a quantity or quality adjustment that impacts the provisional adjustment calculation. True if final assay differed from provisional assay.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the master sales contract or offtake agreement under which the provisional pricing terms are defined.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Actual date on which payment for the adjustment was received from (or paid to) the counterparty. Null if payment is still outstanding.' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceDifference rdf:type rdf:Property ;
    rdfs:label 'Price Difference' ;
    rdfs:comment 'Calculated difference between final price and provisional price per unit. Positive values indicate upward adjustment (additional revenue), negative values indicate downward adjustment (revenue reversal).' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingFormula rdf:type rdf:Property ;
    rdfs:label 'Pricing Formula' ;
    rdfs:comment 'Text description of the contractual pricing formula used to calculate the final price from the benchmark (e.g., \'Average of Platts IODEX CFR China 62% Fe over QP minus USD 2.50 discount\').' ;
    rdfs:domain ind:ProvisionalAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSignatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized Signatory Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Quality certificates require sign-off by authorized personnel (chief geologist, quality manager) for regulatory compliance and legal validity. Essential for dispute resolution, audit trails, and ensur' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aluminaContentPercent rdf:type rdf:Property ;
    rdfs:label 'Alumina Content Percent' ;
    rdfs:comment 'Percentage of alumina content in the ore sample. Penalty element for iron ore quality.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the quality certificate in the commercial workflow.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of quality certificate issued for the shipment (e.g., certificate of analysis, inspection certificate, weight certificate).' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironContentPercent rdf:type rdf:Property ;
    rdfs:label 'Iron Content Percent' ;
    rdfs:comment 'Percentage of iron content in the ore sample. Key quality parameter for iron ore shipments.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingLaboratoryName rdf:type rdf:Property ;
    rdfs:label 'Issuing Laboratory Name' ;
    rdfs:comment 'Name of the accredited laboratory or inspection body that issued the quality certificate.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation number of the issuing laboratory under ISO/IEC 17025 or equivalent standard.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossOnIgnitionPercent rdf:type rdf:Property ;
    rdfs:label 'Loss On Ignition Percent' ;
    rdfs:comment 'Percentage of weight loss when the sample is heated to high temperature. Indicates volatile content and combined water.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Deduction Amount' ;
    rdfs:comment 'Total monetary penalty deduction applied to the invoice based on quality parameters exceeding contractual limits (e.g., high silica, high alumina).' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyDeductionCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Deduction Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty deduction amount.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phosphorusContentPercent rdf:type rdf:Property ;
    rdfs:label 'Phosphorus Content Percent' ;
    rdfs:comment 'Percentage of phosphorus content in the ore sample. Penalty element affecting steel quality.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to the base price based on quality results. Values above 1.0 indicate premium, below 1.0 indicate discount.' ;
    rdfs:domain ind:Sales ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date when the physical samples were collected from the cargo for laboratory analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentQuantityTonnes rdf:type rdf:Property ;
    rdfs:label 'Shipment Quantity Tonnes' ;
    rdfs:comment 'Total quantity of commodity in the shipment covered by this certificate, measured in metric tonnes.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:silicaContentPercent rdf:type rdf:Property ;
    rdfs:label 'Silica Content Percent' ;
    rdfs:comment 'Percentage of silica content in the ore sample. Penalty element for iron ore quality.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeFractionMinus63mmPercent rdf:type rdf:Property ;
    rdfs:label 'Size Fraction Minus 6 3mm Percent' ;
    rdfs:comment 'Percentage of material passing through 6.3mm screen. Part of size distribution specification for fines content.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeFractionPlus315mmPercent rdf:type rdf:Property ;
    rdfs:label 'Size Fraction Plus 31 5mm Percent' ;
    rdfs:comment 'Percentage of material retained on 31.5mm screen. Part of size distribution specification for lump ore.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulfurContentPercent rdf:type rdf:Property ;
    rdfs:label 'Sulfur Content Percent' ;
    rdfs:comment 'Percentage of sulfur content in the ore sample. Penalty element affecting steel quality.' ;
    rdfs:domain ind:QualityCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRevenueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Revenue Employee Id' ;
    rdfs:comment 'Reference to the user (typically CFO, Commercial Director, or authorized approver) who approved this forecast version.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:revenuePreparedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Revenue Prepared By User Employee Id' ;
    rdfs:comment 'Reference to the user (typically Sales Analyst, Commercial Planner, or Finance Analyst) who prepared this forecast.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assumedBenchmarkPrice rdf:type rdf:Property ;
    rdfs:label 'Assumed Benchmark Price' ;
    rdfs:comment 'The assumed benchmark price per unit used in the revenue forecast (e.g., Platts Iron Ore Index, LME Copper, TSI Coal Index).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumptionsNotes rdf:type rdf:Property ;
    rdfs:label 'Assumptions Notes' ;
    rdfs:comment 'Free-text field capturing key assumptions, market conditions, risk factors, or qualitative commentary supporting this forecast (e.g., \'Assumes stable Chinese steel demand\', \'Includes impact of new mine ramp-up\').' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Board Reporting Flag' ;
    rdfs:comment 'Indicates whether this forecast version is designated for board-level reporting and external guidance (True = board-level, False = internal planning only).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Amount' ;
    rdfs:comment 'The total estimated revenue for the forecast period, calculated as forecast volume × assumed benchmark price × price adjustment factor.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter to which this forecast period belongs: Q1, Q2, Q3, Q4.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Forecast Confidence Level' ;
    rdfs:comment 'The confidence level assigned to this forecast based on market conditions, contract certainty, and production reliability: high (>80% confidence), medium (50-80% confidence), low (<50% confidence).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPreparationDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Preparation Date' ;
    rdfs:comment 'The date on which this forecast was prepared or last updated.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Forecast Volume Tonnes' ;
    rdfs:comment 'Forecasted sales volume in metric tonnes for the commodity in the specified period.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastVolumeUom rdf:type rdf:Property ;
    rdfs:label 'Forecast Volume Uom' ;
    rdfs:comment 'Unit of measure for the forecast volume: tonnes (metric tonnes), dmt (dry metric tonnes), wmt (wet metric tonnes), pounds, ounces.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomProductionAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Lom Production Alignment Flag' ;
    rdfs:comment 'Indicates whether this forecast is aligned with the approved Life of Mine (LOM) production schedule (True = aligned, False = not aligned or deviation exists).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the estimated revenue amount (e.g., USD for US Dollar, AUD for Australian Dollar).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment applied to the forecast to account for identified risks (e.g., market volatility, production uncertainty, geopolitical risk). Negative values indicate downward risk adjustment.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentDestinationRegion rdf:type rdf:Property ;
    rdfs:label 'Shipment Destination Region' ;
    rdfs:comment 'The primary geographic region or market for the forecasted shipments (e.g., China, Europe, Japan, India).' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToPriorForecastPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast Percentage' ;
    rdfs:comment 'The percentage variance in revenue compared to the immediately prior forecast version for the same period.' ;
    rdfs:domain ind:RevenueForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryShipmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shipment Employee Id' ;
    rdfs:comment 'Reference to the sales or logistics user who created and submitted this shipment nomination.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when this shipment nomination was cancelled.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the shipment nomination was confirmed and locked in for logistics execution.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractPriceUsdPerTonne rdf:type rdf:Property ;
    rdfs:label 'Contract Price Usd Per Tonne' ;
    rdfs:comment 'Agreed contract price per tonne for this shipment nomination, expressed in United States Dollars.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargePortCode rdf:type rdf:Property ;
    rdfs:label 'Discharge Port Code' ;
    rdfs:comment 'Five-character UN/LOCODE for the destination port or terminal where the commodity will be discharged.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargePortName rdf:type rdf:Property ;
    rdfs:label 'Discharge Port Name' ;
    rdfs:comment 'Human-readable name of the destination port or terminal where the commodity will be discharged.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDischargeDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Discharge Date' ;
    rdfs:comment 'Estimated date when discharge operations are expected to commence at the destination port.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedLoadingDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Loading Date' ;
    rdfs:comment 'Estimated date when loading operations are expected to commence at the loading port.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Usd' ;
    rdfs:comment 'Estimated total revenue for this shipment nomination, calculated as nominated quantity multiplied by contract price.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingPortCode rdf:type rdf:Property ;
    rdfs:label 'Loading Port Code' ;
    rdfs:comment 'Five-character UN/LOCODE for the port or terminal where the commodity will be loaded onto the vessel.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingPortName rdf:type rdf:Property ;
    rdfs:label 'Loading Port Name' ;
    rdfs:comment 'Human-readable name of the port or terminal where the commodity will be loaded.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Nominated Quantity' ;
    rdfs:comment 'Quantity of commodity nominated for this shipment, expressed in the unit of measure specified.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Date when this shipment nomination was formally submitted to the counterparty or logistics provider.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominationNumber rdf:type rdf:Property ;
    rdfs:label 'Nomination Number' ;
    rdfs:comment 'Externally-known unique business identifier for this shipment nomination, used in communications with counterparties and logistics providers.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatus rdf:type rdf:Property ;
    rdfs:label 'Nomination Status' ;
    rdfs:comment 'Current lifecycle status of the shipment nomination in the commercial and logistics workflow.' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingPeriod rdf:type rdf:Property ;
    rdfs:label 'Pricing Period' ;
    rdfs:comment 'Time period over which the benchmark price will be averaged or fixed for this shipment (e.g., M+1, M+2, quotational period).' ;
    rdfs:domain ind:ShipmentNomination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Trader Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Spot trades require attribution to the specific trader who executed the transaction for performance measurement, risk management, and trading desk accountability. Replaces denormalized trader_name wit' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreedPricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Agreed Price Per Tonne' ;
    rdfs:comment 'The negotiated unit price per metric tonne for this spot trade. Business-confidential pricing information.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Broker Commission Rate' ;
    rdfs:comment 'Commission rate (as a decimal percentage) paid to the broker for facilitating the trade. Business-confidential commercial information.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brokerInvolved rdf:type rdf:Property ;
    rdfs:label 'Broker Involved' ;
    rdfs:comment 'Indicates whether a third-party broker or intermediary was involved in facilitating this spot trade transaction.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'Name of the brokerage firm or intermediary that facilitated the spot trade, if applicable.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAdjustmentClause rdf:type rdf:Property ;
    rdfs:label 'Quality Adjustment Clause' ;
    rdfs:comment 'Terms defining price adjustments based on actual delivered quality versus specification (e.g., penalties for off-spec material, bonuses for premium quality).' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTradeValue rdf:type rdf:Property ;
    rdfs:label 'Total Trade Value' ;
    rdfs:comment 'Total monetary value of the spot trade, calculated as trade volume multiplied by agreed price. Business-confidential financial information.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeNotes rdf:type rdf:Property ;
    rdfs:label 'Trade Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, or remarks related to this spot trade transaction.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeNumber rdf:type rdf:Property ;
    rdfs:label 'Trade Number' ;
    rdfs:comment 'Externally-known unique business identifier for the spot trade, used in contracts and communications.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Status' ;
    rdfs:comment 'Current lifecycle status of the spot trade transaction. Tracks progression from draft through settlement or cancellation.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Trade Timestamp' ;
    rdfs:comment 'Precise date and time when the spot trade was executed, including timezone information.' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tradeVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Trade Volume Tonnes' ;
    rdfs:comment 'The quantity of commodity being traded, measured in metric tonnes (dry metric tonnes for bulk commodities).' ;
    rdfs:domain ind:SpotTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumePlanId rdf:type rdf:Property ;
    rdfs:label 'Volume Plan Id' ;
    rdfs:comment 'Primary key for volume_plan' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Type of customer or end-user segment targeted by this volume plan.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logisticsMode rdf:type rdf:Property ;
    rdfs:label 'Logistics Mode' ;
    rdfs:comment 'Primary transportation mode planned for commodity delivery to market.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomProductionForecastAlignment rdf:type rdf:Property ;
    rdfs:label 'Lom Production Forecast Alignment' ;
    rdfs:comment 'Indicates whether this volume plan is aligned with the Life of Mine production forecast. Critical for ensuring offtake agreements match production capacity.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offtakeCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Offtake Coverage Percentage' ;
    rdfs:comment 'Percentage of planned volume already covered by executed offtake agreements. Used to track commercial risk and contract coverage.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'Date from which this volume plan becomes effective and is used for commercial baseline.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiry Date' ;
    rdfs:comment 'Date when this volume plan ceases to be effective. Typically end of quarter or year.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planQuarter rdf:type rdf:Property ;
    rdfs:label 'Plan Quarter' ;
    rdfs:comment 'Fiscal quarter for which this volume plan applies. ANNUAL indicates a full-year plan.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year for which this volume plan applies.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Planned Price Per Tonne' ;
    rdfs:comment 'Target or assumed price per metric tonne used for revenue planning. Confidential commercial information.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Product Specification Code' ;
    rdfs:comment 'Reference code for the detailed product specification document defining quality parameters, impurity limits, and physical characteristics.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Forecast Amount' ;
    rdfs:comment 'Projected revenue for the plan period calculated from planned volume and price. Used for financial planning and budgeting.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentNominationWindow rdf:type rdf:Property ;
    rdfs:label 'Shipment Nomination Window' ;
    rdfs:comment 'Time period or month range during which shipments are planned to occur (e.g., Jan-Mar 2024, Q2 2024).' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Percentage' ;
    rdfs:comment 'Acceptable percentage variance from planned volume before triggering plan revision or escalation.' ;
    rdfs:domain ind:VolumePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ardAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Ard Assessment Id' ;
    rdfs:comment 'Unique identifier for the acid rock drainage assessment record.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancKgCaco3PerTonne rdf:type rdf:Property ;
    rdfs:label 'Anc Kg Caco3 Per Tonne' ;
    rdfs:comment 'Acid neutralization capacity expressed as kilograms of calcium carbonate equivalent per tonne of material.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ardRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Ard Risk Classification' ;
    rdfs:comment 'Classification of acid rock drainage risk: PAF (Potentially Acid Forming), NAF (Non-Acid Forming), UC (Uncertain), or risk level (low, moderate, high).' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arsenicLeachateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Arsenic Leachate Mg Per L' ;
    rdfs:comment 'Arsenic concentration in leachate solution expressed in milligrams per liter.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedBy rdf:type rdf:Property ;
    rdfs:label 'Assessed By' ;
    rdfs:comment 'Name of the geochemist or environmental specialist who interpreted the test results and assigned the ARD risk classification.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonateContentPercent rdf:type rdf:Property ;
    rdfs:label 'Carbonate Content Percent' ;
    rdfs:comment 'Carbonate mineral content expressed as weight percentage, primary source of acid neutralization capacity.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copperLeachateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Copper Leachate Mg Per L' ;
    rdfs:comment 'Copper concentration in leachate solution expressed in milligrams per liter.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadLeachateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Lead Leachate Mg Per L' ;
    rdfs:comment 'Lead concentration in leachate solution expressed in milligrams per liter.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lithology rdf:type rdf:Property ;
    rdfs:label 'Lithology' ;
    rdfs:comment 'Geological rock type or lithological unit of the sample (e.g., granite, basalt, shale, schist).' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementStrategy rdf:type rdf:Property ;
    rdfs:label 'Management Strategy' ;
    rdfs:comment 'Recommended waste management strategy based on ARD and ML assessment results (e.g., encapsulation, co-disposal with NAF material, underwater storage, lime treatment).' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPotentialAcidityKgH2so4PerTonne rdf:type rdf:Property ;
    rdfs:label 'Maximum Potential Acidity Kg H2so4 Per Tonne' ;
    rdfs:comment 'Maximum potential acidity calculated from total sulfur content, representing worst-case acid generation potential.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalLeachingRisk rdf:type rdf:Property ;
    rdfs:label 'Metal Leaching Risk' ;
    rdfs:comment 'Assessment of metal leaching risk based on leachate test results and metal concentrations.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nagPh rdf:type rdf:Property ;
    rdfs:label 'Nag Ph' ;
    rdfs:comment 'Final pH value from Net Acid Generation test, indicating the acid-generating potential after oxidation.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nagValueKgH2so4PerTonne rdf:type rdf:Property ;
    rdfs:label 'Nag Value Kg H2so4 Per Tonne' ;
    rdfs:comment 'Net acid generation potential expressed as kilograms of sulfuric acid equivalent per tonne of material.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netNeutralizationPotentialRatio rdf:type rdf:Property ;
    rdfs:label 'Net Neutralization Potential Ratio' ;
    rdfs:comment 'Ratio of acid neutralization capacity to maximum potential acidity (ANC/MPA), used to classify ARD risk.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pastePh rdf:type rdf:Property ;
    rdfs:label 'Paste Ph' ;
    rdfs:comment 'pH value measured from paste pH test, indicating acidity or alkalinity of the sample when mixed with water.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleDepthM rdf:type rdf:Property ;
    rdfs:label 'Sample Depth M' ;
    rdfs:comment 'Depth in meters below surface at which the sample was collected, relevant for drill core or pit samples.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Location Description' ;
    rdfs:comment 'Textual description of the specific location within the TSF, waste rock dump, or mine site where the sample was collected.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfateSulfurPercent rdf:type rdf:Property ;
    rdfs:label 'Sulfate Sulfur Percent' ;
    rdfs:comment 'Sulfate sulfur content expressed as weight percentage, representing pre-oxidized sulfur that does not contribute to further acid generation.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulfideSulfurPercent rdf:type rdf:Property ;
    rdfs:label 'Sulfide Sulfur Percent' ;
    rdfs:comment 'Sulfide sulfur content expressed as weight percentage, representing the acid-generating sulfur fraction.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Geochemical test method applied: NAG (Net Acid Generation), ANC (Acid Neutralization Capacity), paste pH, SPLP (Synthetic Precipitation Leaching Procedure), kinetic cell, humidity cell, column leach, or other. [ENUM-REF-CANDIDATE: NAG|ANC|paste_pH|SPLP|kinetic_cell|humidity_cell|column_leach|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSulfurPercent rdf:type rdf:Property ;
    rdfs:label 'Total Sulfur Percent' ;
    rdfs:comment 'Total sulfur content of the sample expressed as weight percentage, primary indicator of acid generation potential.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincLeachateMgPerL rdf:type rdf:Property ;
    rdfs:label 'Zinc Leachate Mg Per L' ;
    rdfs:comment 'Zinc concentration in leachate solution expressed in milligrams per liter.' ;
    rdfs:domain ind:ArdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureLiabilityId rdf:type rdf:Property ;
    rdfs:label 'Closure Liability Id' ;
    rdfs:comment 'Unique identifier for the mine closure and rehabilitation financial liability record.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closurePlanId rdf:type rdf:Property ;
    rdfs:label 'Closure Plan Id' ;
    rdfs:comment 'Foreign key linking to tailings.closure_plan. Business justification: Financial liability records are calculated based on a specific closure plan version. The existing closure_plan_reference is a STRING reference number; adding a proper FK enables relational integrity a' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosurePlan .

ind:approvedEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Estimate Amount' ;
    rdfs:comment 'The closure cost estimate amount that was formally approved by the regulatory authority, used as the baseline for variance analysis.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assuranceAmountLodged rdf:type rdf:Property ;
    rdfs:label 'Assurance Amount Lodged' ;
    rdfs:comment 'Total amount of financial assurance currently lodged with the regulatory body to cover the closure liability.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Assurance Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the financial assurance amount is denominated.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceClassification rdf:type rdf:Property ;
    rdfs:label 'Consequence Classification' ;
    rdfs:comment 'Risk-based consequence classification of the facility requiring closure, based on potential environmental, social, and economic impacts of failure.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateBasis rdf:type rdf:Property ;
    rdfs:label 'Estimate Basis' ;
    rdfs:comment 'Description of the methodology, assumptions, and data sources used to calculate the closure cost estimate.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateDate rdf:type rdf:Property ;
    rdfs:label 'Estimate Date' ;
    rdfs:comment 'Date on which the current closure cost estimate was prepared or last updated.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatePreparedBy rdf:type rdf:Property ;
    rdfs:label 'Estimate Prepared By' ;
    rdfs:comment 'Name of the individual or consulting firm responsible for preparing the closure cost estimate.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedClosureCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Closure Cost' ;
    rdfs:comment 'Total estimated cost to complete closure and rehabilitation activities for the facility, expressed in the reporting currency.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closure Completion Date' ;
    rdfs:comment 'Anticipated date when all closure and rehabilitation activities are expected to be completed and the site relinquished.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Closure Start Date' ;
    rdfs:comment 'Anticipated date when closure and rehabilitation activities are expected to commence, based on the current life of mine plan.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssuranceInstrumentType rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Instrument Type' ;
    rdfs:comment 'Type of financial instrument lodged with the regulatory authority to secure the closure liability obligation.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Independent Review Date' ;
    rdfs:comment 'Date on which the independent review of the closure liability estimate was completed.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Independent Review Required' ;
    rdfs:comment 'Indicates whether an independent third-party review of the closure liability estimate is required by regulation or company policy.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:independentReviewer rdf:type rdf:Property ;
    rdfs:label 'Independent Reviewer' ;
    rdfs:comment 'Name of the independent third-party reviewer or firm that validated the closure cost estimate.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Liability Notes' ;
    rdfs:comment 'Free-text field for additional comments, assumptions, or context related to the closure liability estimate and financial assurance arrangement.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Liability Reference Number' ;
    rdfs:comment 'External business identifier for the closure liability record, used in financial reporting and regulatory submissions.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Liability Status' ;
    rdfs:comment 'Current lifecycle status of the closure liability estimate in the financial provisioning and regulatory approval process.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityType rdf:type rdf:Property ;
    rdfs:label 'Liability Type' ;
    rdfs:comment 'Classification of the closure liability by the type of facility or activity requiring rehabilitation.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPresentValue rdf:type rdf:Property ;
    rdfs:label 'Net Present Value' ;
    rdfs:comment 'Discounted present value of the estimated closure cost, calculated using the discount rate and expected timing of expenditures.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionAccountCode rdf:type rdf:Property ;
    rdfs:label 'Provision Account Code' ;
    rdfs:comment 'General ledger account code in the enterprise resource planning system where the closure liability provision is recorded.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory approval or permit under which the closure liability estimate was accepted.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceToApprovedEstimate rdf:type rdf:Property ;
    rdfs:label 'Variance To Approved Estimate' ;
    rdfs:comment 'Difference between the current estimated closure cost and the approved estimate amount, indicating cost escalation or reduction.' ;
    rdfs:domain ind:ClosureLiability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Closure plans require tracking responsible engineer for design accountability and regulatory approval. Engineer name/registration are denormalized. Essential for closure liability management and regul' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Assurance Expiry Date' ;
    rdfs:comment 'Expiry or renewal date of the financial assurance instrument, requiring periodic review and renewal to maintain regulatory compliance.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assuranceLodgementDate rdf:type rdf:Property ;
    rdfs:label 'Assurance Lodgement Date' ;
    rdfs:comment 'Date on which the financial assurance instrument was lodged with or accepted by the regulatory authority.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Closure Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated closure cost and financial assurance amounts.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureCostNpv rdf:type rdf:Property ;
    rdfs:label 'Closure Cost Npv' ;
    rdfs:comment 'Net present value of the closure liability, discounted to current date using the specified discount rate, for financial provisioning and balance sheet reporting.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureStrategy rdf:type rdf:Property ;
    rdfs:label 'Closure Strategy' ;
    rdfs:comment 'High-level description of the closure approach, including final landform design philosophy, rehabilitation objectives, and post-closure land use intent.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationDate rdf:type rdf:Property ;
    rdfs:label 'Consultation Date' ;
    rdfs:comment 'Date on which formal stakeholder consultation activities were completed for this closure plan version.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'Annual discount rate applied to calculate the net present value of future closure costs, typically aligned with corporate weighted average cost of capital or regulatory guidance.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalLandformDesign rdf:type rdf:Property ;
    rdfs:label 'Final Landform Design' ;
    rdfs:comment 'Detailed description of the engineered final landform configuration, including slope angles, drainage patterns, vegetation cover, and integration with surrounding topography.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Plan Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal closure plan document, drawings, and supporting technical reports.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Completion Date' ;
    rdfs:comment 'Target date for completion of all closure and rehabilitation works, after which post-closure monitoring and maintenance phase begins.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Start Date' ;
    rdfs:comment 'Scheduled date for commencement of final closure activities for the facility, aligned with Life of Mine (LOM) planning.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureMonitoringPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring Period Years' ;
    rdfs:comment 'Duration in years for which post-closure environmental and geotechnical monitoring will be conducted before final relinquishment.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:progressiveRehabilitationFlag rdf:type rdf:Property ;
    rdfs:label 'Progressive Rehabilitation Flag' ;
    rdfs:comment 'Indicates whether the closure plan incorporates progressive rehabilitation activities during the operational Life of Mine (LOM) phase.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Authority' ;
    rdfs:comment 'Name of the government agency or regulatory body responsible for reviewing and approving the closure plan and financial assurance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationObjectives rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Objectives' ;
    rdfs:comment 'Documented rehabilitation goals including ecosystem restoration targets, water quality outcomes, geotechnical stability criteria, and community land use expectations.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyYears rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Years' ;
    rdfs:comment 'Regulatory or corporate mandated frequency in years for periodic review and update of the closure plan.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stakeholderConsultationFlag rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Flag' ;
    rdfs:comment 'Indicates whether community and stakeholder consultation was conducted as part of closure plan development, as required by ICMM GISTM.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceToApprovedEstimatePercent rdf:type rdf:Property ;
    rdfs:label 'Variance To Approved Estimate Percent' ;
    rdfs:comment 'Percentage variance between the current estimated closure cost and the last regulatory-approved estimate, triggering re-approval if threshold exceeded.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consequenceClassificationId rdf:type rdf:Property ;
    rdfs:label 'Consequence Classification Id' ;
    rdfs:comment 'Unique identifier for the consequence classification assessment record.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCommunityStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Affected Community Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Consequence classifications identify population at risk and downstream communities requiring engagement for emergency preparedness, inundation mapping, and evacuation planning. Stakeholder register tr' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consequence classifications require tracking qualified assessor for regulatory compliance and professional accountability. Assessor name/credentials/organization are denormalized. Critical for dam saf' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'Version identifier for the consequence classification assessment, used to track revisions and updates over the facility lifecycle.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationCategory rdf:type rdf:Property ;
    rdfs:label 'Classification Category' ;
    rdfs:comment 'The assigned consequence classification category based on potential downstream impact in the event of failure. Drives dam safety review frequency and design standards per ANCOLD and ICMM GISTM.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationNotes rdf:type rdf:Property ;
    rdfs:label 'Classification Notes' ;
    rdfs:comment 'Additional notes, assumptions, limitations, and key considerations documented during the consequence classification assessment process.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalHeritageImpact rdf:type rdf:Property ;
    rdfs:label 'Cultural Heritage Impact' ;
    rdfs:comment 'Assessment of potential impact to cultural heritage sites, indigenous sacred sites, and archaeological resources in the downstream zone.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damSafetyReviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Dam Safety Review Frequency Months' ;
    rdfs:comment 'Required frequency in months for comprehensive dam safety reviews based on the assigned consequence classification category.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designStandardReference rdf:type rdf:Property ;
    rdfs:label 'Design Standard Reference' ;
    rdfs:comment 'Reference to the applicable design standard and criteria required for the assigned consequence classification category.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downstreamInfrastructureImpact rdf:type rdf:Property ;
    rdfs:label 'Downstream Infrastructure Impact' ;
    rdfs:comment 'Description of critical infrastructure at risk downstream including roads, railways, utilities, industrial facilities, and residential areas.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicImpactRating rdf:type rdf:Property ;
    rdfs:label 'Economic Impact Rating' ;
    rdfs:comment 'Assessment of potential economic consequences including property damage, business interruption, agricultural losses, and infrastructure replacement costs.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Rating' ;
    rdfs:comment 'Assessment of potential environmental consequences including water quality, aquatic ecosystems, terrestrial habitat, and protected areas.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of facility being classified for consequence assessment.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeScenario rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Scenario' ;
    rdfs:comment 'Description of the credible failure mode scenario used for consequence assessment, including breach mechanism, release volume, and inundation extent.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Independent Review Outcome' ;
    rdfs:comment 'Outcome of the independent review process indicating whether the consequence classification was endorsed by the reviewer.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Independent Review Required Flag' ;
    rdfs:comment 'Indicates whether independent third-party review of the consequence classification is required based on the assigned category.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:independentReviewerName rdf:type rdf:Property ;
    rdfs:label 'Independent Reviewer Name' ;
    rdfs:comment 'Name of the independent reviewer who validated the consequence classification assessment, if applicable.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inundationAreaKm2 rdf:type rdf:Property ;
    rdfs:label 'Inundation Area Km2' ;
    rdfs:comment 'Estimated area of downstream inundation in square kilometers based on dam break analysis for the credible failure scenario.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossOfLifePotential rdf:type rdf:Property ;
    rdfs:label 'Loss Of Life Potential' ;
    rdfs:comment 'Qualitative assessment of potential loss of life in the event of facility failure, based on population at risk and warning time availability.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reassessment Due Date' ;
    rdfs:comment 'Scheduled date for the next consequence classification reassessment, typically triggered by material changes to the facility or downstream conditions.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakDischargeM3PerSec rdf:type rdf:Property ;
    rdfs:label 'Peak Discharge M3 Per Sec' ;
    rdfs:comment 'Estimated peak discharge rate in cubic meters per second at the breach point for the credible failure scenario.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationAtRisk rdf:type rdf:Property ;
    rdfs:label 'Population At Risk' ;
    rdfs:comment 'Estimated number of people potentially affected in the downstream impact zone in the event of facility failure. Critical factor in determining consequence category.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance Date' ;
    rdfs:comment 'Date when the regulatory authority formally accepted the consequence classification assessment.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance Status' ;
    rdfs:comment 'Current status of regulatory acceptance for the consequence classification assessment. Drives compliance with dam safety regulations.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory authority for the consequence classification submission and approval.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningTimeHours rdf:type rdf:Property ;
    rdfs:label 'Warning Time Hours' ;
    rdfs:comment 'Estimated time available for downstream warning and evacuation from detection of failure precursors to breach occurrence.' ;
    rdfs:domain ind:ConsequenceClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damSafetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Dam Safety Inspection Id' ;
    rdfs:comment 'Unique identifier for the dam safety inspection record.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectorOrganizationStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Inspector organizations conducting dam safety inspections are regulatory and professional stakeholders requiring engagement tracking for scheduling, credentials verification, and regulatory submission' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:stabilityAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Stability Analysis Id' ;
    rdfs:comment 'Foreign key linking to tailings.stability_analysis. Business justification: Dam safety inspections reference specific stability analyses as the technical basis for safety ratings. The inspection documents that a stability analysis was conducted and uses its results. Creating ' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityAnalysis .

ind:engineerOfRecordName rdf:type rdf:Property ;
    rdfs:label 'Engineer Of Record Name' ;
    rdfs:comment 'Full name of the Engineer of Record who is accountable for the design, construction, operation, and closure of the TSF, as required by ICMM GISTM Requirement 5.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eorSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Eor Signoff Date' ;
    rdfs:comment 'Date on which the Engineer of Record formally signed off on the inspection report and stability analysis results.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:factorOfSafety rdf:type rdf:Property ;
    rdfs:label 'Factor Of Safety' ;
    rdfs:comment 'Calculated factor of safety from the stability analysis, representing the ratio of resisting forces to driving forces. Minimum FoS thresholds are defined by ANCOLD, CDA, and ICMM GISTM based on loading condition and consequence classification.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureModeAssessed rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Assessed' ;
    rdfs:comment 'Description of the failure mode evaluated in the stability analysis (e.g., circular slip, wedge failure, liquefaction, foundation failure, overtopping).' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fosComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Fos Compliance Status' ;
    rdfs:comment 'Assessment of whether the calculated factor of safety meets or exceeds the minimum design criteria and regulatory requirements.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeboardComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Freeboard Compliance Status' ;
    rdfs:comment 'Assessment of whether the measured freeboard meets the design criteria and regulatory requirements.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeboardMeasurementM rdf:type rdf:Property ;
    rdfs:label 'Freeboard Measurement M' ;
    rdfs:comment 'Vertical distance in meters between the current water level in the TSF and the crest of the dam, a critical safety parameter to prevent overtopping.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Reference' ;
    rdfs:comment 'Document reference or file path to the formal inspection report, including photographs, drawings, and detailed findings.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentationCompliance rdf:type rdf:Property ;
    rdfs:label 'Instrumentation Compliance' ;
    rdfs:comment 'Assessment of whether the instrumentation array meets the design and regulatory requirements for monitoring.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentationStatus rdf:type rdf:Property ;
    rdfs:label 'Instrumentation Status' ;
    rdfs:comment 'Summary of the operational status of geotechnical instrumentation (piezometers, inclinometers, settlement monuments, flow meters), including any malfunctioning or missing instruments.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStrengthParameters rdf:type rdf:Property ;
    rdfs:label 'Material Strength Parameters' ;
    rdfs:comment 'Summary of the geotechnical material strength parameters used in the analysis, including cohesion, friction angle, and unit weight for tailings, foundation, and embankment materials.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Overall Safety Rating' ;
    rdfs:comment 'Summary assessment of the dam safety condition: satisfactory (no concerns), fair (minor issues), marginal (requires monitoring), unsatisfactory (remedial action needed), urgent (immediate intervention required).' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phreaticSurfaceAssumption rdf:type rdf:Property ;
    rdfs:label 'Phreatic Surface Assumption' ;
    rdfs:comment 'Description of the phreatic surface (water table) assumptions used in the stability analysis, including piezometric data sources and interpolation methods.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this inspection report must be submitted to a regulatory authority or governing body.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remedialActionPriority rdf:type rdf:Property ;
    rdfs:label 'Remedial Action Priority' ;
    rdfs:comment 'Priority level assigned to the remedial actions: none (no action needed), low (routine maintenance), medium (planned intervention), high (near-term action), urgent (immediate response).' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remedialActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Remedial Actions Required' ;
    rdfs:comment 'Detailed description of any corrective or remedial actions identified during the inspection, including repairs, monitoring enhancements, or operational changes.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seepageObservation rdf:type rdf:Property ;
    rdfs:label 'Seepage Observation' ;
    rdfs:comment 'Qualitative description of seepage conditions observed during the inspection, including location, flow rate, clarity, and any signs of internal erosion or piping.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seepageSeverity rdf:type rdf:Property ;
    rdfs:label 'Seepage Severity' ;
    rdfs:comment 'Classification of seepage severity: none (no seepage detected), minor (expected and controlled), moderate (requires monitoring), significant (remedial action needed), critical (immediate intervention required).' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slopeCondition rdf:type rdf:Property ;
    rdfs:label 'Slope Condition' ;
    rdfs:comment 'Description of the physical condition of the upstream and downstream slopes, including observations of cracking, slumping, erosion, vegetation, or other surface anomalies.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slopeStabilityRating rdf:type rdf:Property ;
    rdfs:label 'Slope Stability Rating' ;
    rdfs:comment 'Assessment of slope stability based on visual inspection: stable (no concerns), minor concern (cosmetic issues), moderate concern (requires monitoring), unstable (remedial action needed).' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityAnalysisConducted rdf:type rdf:Property ;
    rdfs:label 'Stability Analysis Conducted' ;
    rdfs:comment 'Indicates whether a formal geotechnical stability analysis was performed as part of this inspection cycle.' ;
    rdfs:domain ind:DamSafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decantOperationId rdf:type rdf:Property ;
    rdfs:label 'Decant Operation Id' ;
    rdfs:comment 'Unique identifier for the decant operation record. Primary key for the decant operation entity.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decantStructureId rdf:type rdf:Property ;
    rdfs:label 'Decant Structure Id' ;
    rdfs:comment 'Unique identifier or tag of the specific decant structure or equipment used (e.g., pump ID, tower ID, penstock reference).' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DecantStructure .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Identifier of the specific facility or location where the decanted water was sent (e.g., process plant ID, evaporation pond ID, treatment plant ID).' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DestinationFacility .

ind:primaryDecantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Decant Employee Id' ;
    rdfs:comment 'Identifier of the employee or operator who performed or supervised the decant operation.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:waterBalanceId rdf:type rdf:Property ;
    rdfs:label 'Water Balance Id' ;
    rdfs:comment 'Foreign key linking to tailings.water_balance. Business justification: Decant operations are water outflow events that contribute to TSF water balance calculations. Each decant operation occurs within a specific water balance period and its volume is accounted for in tha' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WaterBalance .

ind:decantEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decant End Timestamp' ;
    rdfs:comment 'Precise timestamp when the decant operation was completed.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decantEventDate rdf:type rdf:Property ;
    rdfs:label 'Decant Event Date' ;
    rdfs:comment 'The date on which the decant operation was performed. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decantEventReference rdf:type rdf:Property ;
    rdfs:label 'Decant Event Reference' ;
    rdfs:comment 'Business reference number or code assigned to this decant operation event for tracking and reporting purposes.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decantStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decant Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the decant operation commenced, including time of day.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decantStructureType rdf:type rdf:Property ;
    rdfs:label 'Decant Structure Type' ;
    rdfs:comment 'Type of decant structure or mechanism used to extract supernatant water from the TSF (e.g., penstock, decant tower, pump, spillway, siphon).' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateM3PerHour rdf:type rdf:Property ;
    rdfs:label 'Flow Rate M3 Per Hour' ;
    rdfs:comment 'Average flow rate of water during the decant operation, measured in cubic meters per hour.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeboardAfterDecantM rdf:type rdf:Property ;
    rdfs:label 'Freeboard After Decant M' ;
    rdfs:comment 'Vertical distance between the water level and the crest of the TSF embankment after the decant operation, measured in meters. Critical safety parameter.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Flag' ;
    rdfs:comment 'Boolean flag indicating whether any incident, anomaly, or safety event occurred during the decant operation.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceConditionReference rdf:type rdf:Property ;
    rdfs:label 'Licence Condition Reference' ;
    rdfs:comment 'Reference to the specific water licence condition or permit requirement that governs this decant operation.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Detailed explanation of any non-compliance issues identified during or after the decant operation.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationNotes rdf:type rdf:Property ;
    rdfs:label 'Operation Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the operator or supervisor regarding the decant operation, including any anomalies or special conditions.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the decant operation (planned, in progress, completed, suspended, aborted, failed).' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rainfallDuringOperationMm rdf:type rdf:Property ;
    rdfs:label 'Rainfall During Operation Mm' ;
    rdfs:comment 'Total rainfall recorded during the decant operation period, measured in millimeters. Relevant for water balance calculations.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDecantedM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Decanted M3' ;
    rdfs:comment 'Total volume of supernatant water decanted from the TSF during this operation, measured in cubic meters.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterLevelAfterM rdf:type rdf:Property ;
    rdfs:label 'Water Level After M' ;
    rdfs:comment 'Elevation of the supernatant water level in the TSF pond after the decant operation was completed, measured in meters above datum.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterLevelBeforeM rdf:type rdf:Property ;
    rdfs:label 'Water Level Before M' ;
    rdfs:comment 'Elevation of the supernatant water level in the TSF pond before the decant operation commenced, measured in meters above datum.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityPh rdf:type rdf:Property ;
    rdfs:label 'Water Quality Ph' ;
    rdfs:comment 'pH level of the decanted water measured at the point of decant. Critical water quality parameter.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityTdsMgPerL rdf:type rdf:Property ;
    rdfs:label 'Water Quality Tds Mg Per L' ;
    rdfs:comment 'Total dissolved solids concentration in the decanted water, measured in milligrams per liter.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityTssMgPerL rdf:type rdf:Property ;
    rdfs:label 'Water Quality Tss Mg Per L' ;
    rdfs:comment 'Total suspended solids concentration in the decanted water, measured in milligrams per liter.' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterQualityTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Water Quality Turbidity Ntu' ;
    rdfs:comment 'Turbidity of the decanted water measured in Nephelometric Turbidity Units (NTU).' ;
    rdfs:domain ind:DecantOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionId rdf:type rdf:Property ;
    rdfs:label 'Deposition Id' ;
    rdfs:comment 'Primary key for deposition' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityModelId rdf:type rdf:Property ;
    rdfs:label 'Capacity Model Id' ;
    rdfs:comment 'Foreign key reference to the capacity model used for survey calculations.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityModel .

ind:depositionApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deposition Approved By Employee Id' ;
    rdfs:comment 'Foreign key reference to the competent person or supervisor who approved the record.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:depositionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deposition Employee Id' ;
    rdfs:comment 'Foreign key reference to the operator or surveyor who recorded the event.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key reference to the approved deposition plan governing this event.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositionPlan .

ind:beachElevationM rdf:type rdf:Property ;
    rdfs:label 'Beach Elevation M' ;
    rdfs:comment 'Average elevation of the tailings beach surface at time of survey, measured in meters above sea level. Null for deposition event records.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beachLengthM rdf:type rdf:Property ;
    rdfs:label 'Beach Length M' ;
    rdfs:comment 'Length of the tailings beach from the deposition point to the pond edge, measured in meters.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentStorageVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Current Storage Volume M3' ;
    rdfs:comment 'Volume of tailings currently stored in the TSF at time of survey, measured in cubic meters. Null for deposition event records.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeboardM rdf:type rdf:Property ;
    rdfs:label 'Freeboard M' ;
    rdfs:comment 'Vertical distance between the pond water level and the crest of the dam at time of event, measured in meters.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointLatitude rdf:type rdf:Property ;
    rdfs:label 'Point Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the deposition point or spigot location. Null for capacity survey records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointLongitude rdf:type rdf:Property ;
    rdfs:label 'Point Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the deposition point or spigot location. Null for capacity survey records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pondLevelM rdf:type rdf:Property ;
    rdfs:label 'Pond Level M' ;
    rdfs:comment 'Elevation of the pond water surface at time of event, measured in meters above sea level.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pondSurfaceAreaM2 rdf:type rdf:Property ;
    rdfs:label 'Pond Surface Area M2' ;
    rdfs:comment 'Surface area of the supernatant pond at time of survey, measured in square meters. Null for deposition event records.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raiseTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Raise Trigger Flag' ;
    rdfs:comment 'Boolean flag indicating whether the survey results trigger the need for a dam raise or expansion. Null for deposition event records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingAirspaceM3 rdf:type rdf:Property ;
    rdfs:label 'Remaining Airspace M3' ;
    rdfs:comment 'Available storage volume remaining in the TSF at time of survey, measured in cubic meters. Null for deposition event records.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Life Years' ;
    rdfs:comment 'Calculated remaining operational life of the TSF based on current storage volume and deposition rate, measured in years. Null for deposition event records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slurryDensityTPerM3 rdf:type rdf:Property ;
    rdfs:label 'Slurry Density T Per M3' ;
    rdfs:comment 'Density of the tailings slurry at time of deposition, measured in tonnes per cubic meter. Null for capacity survey records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidsTonnageT rdf:type rdf:Property ;
    rdfs:label 'Solids Tonnage T' ;
    rdfs:comment 'Dry tonnage of solid tailings material deposited, measured in tonnes. Null for capacity survey records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spigotConfiguration rdf:type rdf:Property ;
    rdfs:label 'Spigot Configuration' ;
    rdfs:comment 'Configuration of spigots used during deposition: single, multiple, rotating, or fixed. Null for capacity survey records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAccuracyClass rdf:type rdf:Property ;
    rdfs:label 'Survey Accuracy Class' ;
    rdfs:comment 'Classification of survey accuracy based on method and conditions: high, medium, or low. Null for deposition event records.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStorageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Total Storage Capacity M3' ;
    rdfs:comment 'Total design storage capacity of the TSF at time of survey, measured in cubic meters. Null for deposition event records.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromPlanM3 rdf:type rdf:Property ;
    rdfs:label 'Variance From Plan M3' ;
    rdfs:comment 'Variance between actual deposition volume and planned volume, measured in cubic meters. Positive indicates over-plan, negative indicates under-plan.' ;
    rdfs:domain ind:Deposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Action Plan Id' ;
    rdfs:comment 'Unique identifier for the Emergency Action Plan record. Primary key for the emergency action plan entity.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Emergency action plans require designated community emergency contacts for notification procedures and evacuation coordination. Stakeholder register tracks emergency contact details, notification prot' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:communityEngagementStatus rdf:type rdf:Property ;
    rdfs:label 'Community Engagement Status' ;
    rdfs:comment 'Status of engagement activities with downstream communities to inform them of the Emergency Action Plan and their role in emergency response.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillExerciseFrequency rdf:type rdf:Property ;
    rdfs:label 'Drill Exercise Frequency' ;
    rdfs:comment 'Required frequency for conducting emergency response drills and exercises to test the effectiveness of the Emergency Action Plan (e.g., annually, bi-annually).' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyNotificationProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Notification Procedure' ;
    rdfs:comment 'Description of the procedure for notifying internal personnel, emergency services, regulatory authorities, and downstream communities in the event of a TSF emergency.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationProcedure rdf:type rdf:Property ;
    rdfs:label 'Evacuation Procedure' ;
    rdfs:comment 'Detailed description of evacuation procedures for on-site personnel and downstream communities, including evacuation routes, assembly points, and transportation arrangements.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationTriggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Evacuation Trigger Criteria' ;
    rdfs:comment 'Specific observable conditions or monitoring thresholds that trigger the activation of evacuation procedures, such as critical deformation rates, seepage increases, or seismic events.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inundationStudyDate rdf:type rdf:Property ;
    rdfs:label 'Inundation Study Date' ;
    rdfs:comment 'Date when the downstream inundation zone mapping study was completed or last updated.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inundationZoneMappingReference rdf:type rdf:Property ;
    rdfs:label 'Inundation Zone Mapping Reference' ;
    rdfs:comment 'Reference identifier or document number for the downstream inundation zone mapping study that defines the area at risk in the event of a TSF failure. Critical for evacuation planning.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrillExerciseDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Exercise Date' ;
    rdfs:comment 'Date of the most recent emergency response drill or exercise conducted to test the Emergency Action Plan.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDrillExerciseDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Exercise Date' ;
    rdfs:comment 'Scheduled date for the next emergency response drill or exercise.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Additional notes, comments, or observations related to the Emergency Action Plan, including lessons learned from drills or actual incidents.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Emergency Contact Phone' ;
    rdfs:comment '24/7 contact phone number for the primary emergency contact person.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAcceptanceReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Acceptance Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory authority upon acceptance of the Emergency Action Plan.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Status of the Emergency Action Plan submission to the relevant regulatory authority for review and acceptance.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineerRegistration rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Registration' ;
    rdfs:comment 'Professional registration or license number of the responsible engineer, demonstrating their qualification to prepare emergency action plans.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Secondary Emergency Contact Name' ;
    rdfs:comment 'Name of the secondary or backup emergency contact person in case the primary contact is unavailable.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Emergency Contact Phone' ;
    rdfs:comment '24/7 contact phone number for the secondary emergency contact person.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdLevel1 rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Level 1' ;
    rdfs:comment 'First level alert threshold value for the instrument reading. When exceeded, triggers initial investigation and increased monitoring frequency per the TSF management plan.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdLevel2 rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Level 2' ;
    rdfs:comment 'Second level alert threshold value for the instrument reading. When exceeded, triggers escalated response including engineering review and potential operational restrictions.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdLevel3 rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Level 3' ;
    rdfs:comment 'Third level critical alert threshold value for the instrument reading. When exceeded, triggers emergency response protocols and may require immediate operational shutdown.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Date by which the next calibration or verification must be performed to maintain instrument certification and data validity. Drives preventive maintenance scheduling.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataAcquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Acquisition Method' ;
    rdfs:comment 'Method by which readings are collected from the instrument. Automated and SCADA-integrated instruments provide real-time data; manual instruments require field visits.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the instrument was taken out of service, either due to failure, replacement, or completion of monitoring requirements. Null for active instruments.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityZone rdf:type rdf:Property ;
    rdfs:label 'Facility Zone' ;
    rdfs:comment 'Specific zone or section within the TSF or waste rock facility where the instrument is located, such as upstream face, downstream toe, crest, or foundation. Used for spatial analysis and reporting.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationContractor rdf:type rdf:Property ;
    rdfs:label 'Installation Contractor' ;
    rdfs:comment 'Name of the contractor or company that performed the instrument installation. Used for warranty claims and installation quality tracking.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDepthM rdf:type rdf:Property ;
    rdfs:label 'Installation Depth M' ;
    rdfs:comment 'Depth below ground surface at which the instrument sensor is installed, measured in meters. Applicable to subsurface instruments such as piezometers and inclinometers. Null for surface instruments.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationNotes rdf:type rdf:Property ;
    rdfs:label 'Installation Notes' ;
    rdfs:comment 'Free-text field capturing important details about the installation process, site conditions, deviations from design, or special considerations that may affect instrument performance or data interpretation.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentSubtype rdf:type rdf:Property ;
    rdfs:label 'Instrument Subtype' ;
    rdfs:comment 'Further classification or model specification of the instrument type, such as standpipe piezometer, pneumatic piezometer, or in-place inclinometer. Provides additional technical detail beyond the primary type.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentTag rdf:type rdf:Property ;
    rdfs:label 'Instrument Tag' ;
    rdfs:comment 'Unique alphanumeric tag or serial number assigned to the instrument for field identification and tracking. Used by field technicians and in monitoring reports.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this instrument is required by regulatory permits, Environmental Impact Statement (EIS) conditions, or dam safety orders. True if mandated by external authority; false if installed for internal monitoring purposes.' ;
    rdfs:domain ind:GeotechnicalInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Maximum value of the instruments design measurement range. Defines the upper bound of valid readings the instrument can produce.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Minimum value of the instruments design measurement range. Defines the lower bound of valid readings the instrument can produce.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Primary purpose or objective for which this instrument was installed, such as phreatic surface monitoring, settlement tracking, slope stability assessment, or seepage quantification. Guides data interpretation and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalReadingId rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Reading Id' ;
    rdfs:comment 'Unique identifier for the geotechnical instrument reading record.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionThreshold rdf:type rdf:Property ;
    rdfs:label 'Action Threshold' ;
    rdfs:comment 'The action threshold value defined in the Trigger Action Response Plan (TARP) that triggers immediate intervention and response protocols.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThreshold rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold' ;
    rdfs:comment 'The alert threshold value defined in the Trigger Action Response Plan (TARP) that indicates elevated monitoring attention is required.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationFromBaseline rdf:type rdf:Property ;
    rdfs:label 'Deviation From Baseline' ;
    rdfs:comment 'The calculated difference between the current reading value and the established baseline value.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateOfChange rdf:type rdf:Property ;
    rdfs:label 'Rate Of Change' ;
    rdfs:comment 'The calculated rate of change in the measured parameter over time, critical for identifying accelerating deformation or pore pressure trends.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateOfChangeUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Of Change Unit' ;
    rdfs:comment 'The unit expressing the rate of change calculation (e.g., millimeters per day, kilopascals per day).' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingMethod rdf:type rdf:Property ;
    rdfs:label 'Reading Method' ;
    rdfs:comment 'The method by which the reading was captured: manual field measurement, automated SCADA system, or remote telemetry.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingNotes rdf:type rdf:Property ;
    rdfs:label 'Reading Notes' ;
    rdfs:comment 'Free-text field for operator or engineer comments regarding anomalies, field conditions, or contextual information relevant to the reading.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Date and time when the geotechnical reading was captured in the field, representing the actual measurement event time.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readingValue rdf:type rdf:Property ;
    rdfs:label 'Reading Value' ;
    rdfs:comment 'The measured numeric value captured by the geotechnical instrument at the reading timestamp.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdBreachStatus rdf:type rdf:Property ;
    rdfs:label 'Threshold Breach Status' ;
    rdfs:comment 'Indicates whether the reading value has breached alert or action thresholds defined in the TARP.' ;
    rdfs:domain ind:GeotechnicalReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCharacterisationId rdf:type rdf:Property ;
    rdfs:label 'Material Characterisation Id' ;
    rdfs:comment 'Primary key for material_characterisation' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acidNeutralisationCapacityKgH2so4PerTonne rdf:type rdf:Property ;
    rdfs:label 'Acid Neutralisation Capacity Kg H2so4 Per Tonne' ;
    rdfs:comment 'Capacity of the material to neutralise acid, expressed as kilograms of sulphuric acid equivalent per tonne, measured through ANC testing.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ardClassification rdf:type rdf:Property ;
    rdfs:label 'Ard Classification' ;
    rdfs:comment 'Classification of the material\'s acid rock drainage risk: PAF (Potentially Acid Forming), NAF (Non-Acid Forming), or UC (Uncertain), based on geochemical test results and NPR ratio.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arsenicConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Arsenic Concentration Mg Per Kg' ;
    rdfs:comment 'Total arsenic content in the material, measured in milligrams per kilogram, critical heavy metal for environmental risk assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadmiumConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Cadmium Concentration Mg Per Kg' ;
    rdfs:comment 'Total cadmium content in the material, measured in milligrams per kilogram, critical heavy metal for environmental risk assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:characterisationNotes rdf:type rdf:Property ;
    rdfs:label 'Characterisation Notes' ;
    rdfs:comment 'Free-text field for additional observations, anomalies, limitations, or contextual information related to the characterisation testing and results.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:characterisationStatus rdf:type rdf:Property ;
    rdfs:label 'Characterisation Status' ;
    rdfs:comment 'Current status of the characterisation record in the data lifecycle: draft (preliminary results), validated (quality-checked), approved (accepted for design use), or superseded (replaced by newer testing).' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionIndex rdf:type rdf:Property ;
    rdfs:label 'Compression Index' ;
    rdfs:comment 'Slope of the virgin compression curve in a consolidation test, indicating the compressibility of the material under loading.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationCoefficientM2PerYear rdf:type rdf:Property ;
    rdfs:label 'Consolidation Coefficient M2 Per Year' ;
    rdfs:comment 'Rate at which the material consolidates under load, expressed in square metres per year, critical for settlement prediction in TSF design.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copperConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Copper Concentration Mg Per Kg' ;
    rdfs:comment 'Total copper content in the material, measured in milligrams per kilogram, relevant for copper mining operations and environmental assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyanideConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Cyanide Concentration Mg Per Kg' ;
    rdfs:comment 'Concentration of cyanide compounds in the material, measured in milligrams per kilogram, critical for tailings from gold processing operations using cyanide leaching.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:encapsulationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Encapsulation Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the material requires encapsulation within non-acid-forming material to prevent acid generation and metal leaching.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Lead Concentration Mg Per Kg' ;
    rdfs:comment 'Total lead content in the material, measured in milligrams per kilogram, critical heavy metal for environmental risk assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Liquid Limit Percent' ;
    rdfs:comment 'Moisture content at which the material transitions from plastic to liquid state, expressed as a percentage.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialSource rdf:type rdf:Property ;
    rdfs:label 'Material Source' ;
    rdfs:comment 'Description of the ore body, processing plant, or mining area from which the material originated.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mercuryConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Mercury Concentration Mg Per Kg' ;
    rdfs:comment 'Total mercury content in the material, measured in milligrams per kilogram, critical heavy metal for environmental risk assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalLeachingRiskRating rdf:type rdf:Property ;
    rdfs:label 'Metal Leaching Risk Rating' ;
    rdfs:comment 'Risk rating for metal leaching potential from the material: low, moderate, high, or very high, based on leachate test results and regulatory thresholds.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAcidGenerationKgH2so4PerTonne rdf:type rdf:Property ;
    rdfs:label 'Net Acid Generation Kg H2so4 Per Tonne' ;
    rdfs:comment 'Net acid generation potential of the material, expressed as kilograms of sulphuric acid equivalent per tonne of material, calculated from NAG test results.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAcidProducingPotentialKgH2so4PerTonne rdf:type rdf:Property ;
    rdfs:label 'Net Acid Producing Potential Kg H2so4 Per Tonne' ;
    rdfs:comment 'Net acid producing potential calculated as the difference between Maximum Potential Acidity (MPA) and Acid Neutralisation Capacity (ANC), expressed as kilograms of sulphuric acid equivalent per tonne.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:neutralisationPotentialRatio rdf:type rdf:Property ;
    rdfs:label 'Neutralisation Potential Ratio' ;
    rdfs:comment 'Ratio of Acid Neutralisation Capacity (ANC) to Maximum Potential Acidity (MPA), used to classify ARD risk: NPR less than 1 indicates Potentially Acid Forming (PAF), NPR greater than 3 indicates Non-Acid Forming (NAF), and NPR between 1 and 3 indicates Uncertain (UC).' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nickelConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Nickel Concentration Mg Per Kg' ;
    rdfs:comment 'Total nickel content in the material, measured in milligrams per kilogram, relevant for nickel mining operations and environmental assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeD10Mm rdf:type rdf:Property ;
    rdfs:label 'Particle Size D10 Mm' ;
    rdfs:comment 'Particle size distribution metric representing the diameter at which 10% of the sample mass is finer, measured in millimetres.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeD50Mm rdf:type rdf:Property ;
    rdfs:label 'Particle Size D50 Mm' ;
    rdfs:comment 'Median particle size (D50) representing the diameter at which 50% of the sample mass is finer, measured in millimetres.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeD90Mm rdf:type rdf:Property ;
    rdfs:label 'Particle Size D90 Mm' ;
    rdfs:comment 'Particle size distribution metric representing the diameter at which 90% of the sample mass is finer, measured in millimetres.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permeabilityMPerS rdf:type rdf:Property ;
    rdfs:label 'Permeability M Per S' ;
    rdfs:comment 'Hydraulic conductivity of the material, representing the rate at which water can flow through the material under a hydraulic gradient, measured in metres per second.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Plastic Limit Percent' ;
    rdfs:comment 'Moisture content at which the material transitions from semi-solid to plastic state, expressed as a percentage.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticityIndex rdf:type rdf:Property ;
    rdfs:label 'Plasticity Index' ;
    rdfs:comment 'Difference between the liquid limit and plastic limit of the material, indicating the range of moisture content over which the material exhibits plastic behaviour.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulphideContentPercent rdf:type rdf:Property ;
    rdfs:label 'Sulphide Content Percent' ;
    rdfs:comment 'Total sulphide mineral content in the material, expressed as a percentage by weight, key indicator for Acid Rock Drainage (ARD) potential.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulphurContentPercent rdf:type rdf:Property ;
    rdfs:label 'Sulphur Content Percent' ;
    rdfs:comment 'Total sulphur content in the material, expressed as a percentage by weight, used in conjunction with sulphide content for ARD assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'Name of the accredited laboratory that performed the characterisation testing.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Regulatory waste classification assigned to the material based on characterisation results and jurisdictional waste classification frameworks.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zincConcentrationMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Zinc Concentration Mg Per Kg' ;
    rdfs:comment 'Total zinc content in the material, measured in milligrams per kilogram, relevant for environmental risk assessment.' ;
    rdfs:domain ind:MaterialCharacterisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationActivityId rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Activity Id' ;
    rdfs:comment 'Unique identifier for the rehabilitation activity record. Primary key.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Contractor Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Rehabilitation contractors are stakeholders requiring engagement for local content commitments, contractor registration verification, and performance monitoring. Stakeholder register tracks contractor' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:siteSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Site Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Rehabilitation activities require tracking site supervisor for field execution accountability and quality control. Supervisor name is denormalized. Critical for rehabilitation program management and c' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Reference Number' ;
    rdfs:comment 'Business identifier or work order number assigned to this rehabilitation activity for tracking and reporting purposes.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaTreatedHectares rdf:type rdf:Property ;
    rdfs:label 'Area Treated Hectares' ;
    rdfs:comment 'Total area in hectares that has been or will be rehabilitated under this activity.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Required' ;
    rdfs:comment 'Flag indicating whether ongoing environmental monitoring is required following completion of this rehabilitation activity.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsUsedDescription rdf:type rdf:Property ;
    rdfs:label 'Materials Used Description' ;
    rdfs:comment 'Description of materials used in the rehabilitation activity including topsoil, seed mix, mulch, geotextiles, rock, or other materials.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationPhase rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Phase' ;
    rdfs:comment 'Phase of mine rehabilitation lifecycle this activity belongs to (progressive, interim, final, post-closure).' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedApplicationRateKgPerHa rdf:type rdf:Property ;
    rdfs:label 'Seed Application Rate Kg Per Ha' ;
    rdfs:comment 'Rate at which seed was applied measured in kilograms per hectare.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedMixType rdf:type rdf:Property ;
    rdfs:label 'Seed Mix Type' ;
    rdfs:comment 'Type or specification of seed mix used for revegetation (e.g., native species blend, pasture mix, erosion control mix).' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Site Location Description' ;
    rdfs:comment 'Textual description of the specific location within the TSF or waste rock dump where the rehabilitation activity is taking place.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Success Criteria Description' ;
    rdfs:comment 'Description of the success criteria or performance indicators that will be used to assess the effectiveness of the rehabilitation activity (e.g., vegetation cover percentage, erosion rate, species diversity).' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVegetationCoverPercent rdf:type rdf:Property ;
    rdfs:label 'Target Vegetation Cover Percent' ;
    rdfs:comment 'Target percentage of vegetation cover to be achieved as part of the rehabilitation success criteria.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topsoilVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Topsoil Volume M3' ;
    rdfs:comment 'Volume of topsoil in cubic meters placed during the rehabilitation activity.' ;
    rdfs:domain ind:RehabilitationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seepageMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Seepage Monitoring Id' ;
    rdfs:comment 'Unique identifier for the seepage monitoring record.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringLocationId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Id' ;
    rdfs:comment 'Foreign key reference to the specific monitoring location (toe drain, seepage collection pond, underdrain) where the measurement was taken.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringLocation .

ind:alertTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered Flag' ;
    rdfs:comment 'Boolean flag indicating whether this measurement triggered an automated alert or notification due to threshold exceedance (True = alert triggered, False = no alert).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arsenicConcentration rdf:type rdf:Property ;
    rdfs:label 'Arsenic Concentration' ;
    rdfs:comment 'Arsenic concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conductivityUnit rdf:type rdf:Property ;
    rdfs:label 'Conductivity Unit' ;
    rdfs:comment 'Unit of measure for electrical conductivity.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperConcentration rdf:type rdf:Property ;
    rdfs:label 'Copper Concentration' ;
    rdfs:comment 'Copper metal concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Design Exceedance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured flow rate exceeds the design seepage rate (True = exceeded, False = within design).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designSeepageRate rdf:type rdf:Property ;
    rdfs:label 'Design Seepage Rate' ;
    rdfs:comment 'Expected design seepage flow rate for this monitoring location in liters per second (L/s), used for comparison against actual measurements.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electricalConductivity rdf:type rdf:Property ;
    rdfs:label 'Electrical Conductivity' ;
    rdfs:comment 'Electrical conductivity of seepage water in microsiemens per centimeter (µS/cm), indicating dissolved ion concentration.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalLicenceLimit rdf:type rdf:Property ;
    rdfs:label 'Environmental Licence Limit' ;
    rdfs:comment 'Maximum allowable concentration or flow rate as specified in the environmental operating licence for this parameter.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRate rdf:type rdf:Property ;
    rdfs:label 'Flow Rate' ;
    rdfs:comment 'Measured seepage flow rate in liters per second (L/s).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateUnit rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Unit' ;
    rdfs:comment 'Unit of measure for the seepage flow rate.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalErosionRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'Internal Erosion Risk Indicator' ;
    rdfs:comment 'Risk assessment indicator for potential internal erosion based on turbidity, flow rate trends, and other seepage characteristics.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ironConcentration rdf:type rdf:Property ;
    rdfs:label 'Iron Concentration' ;
    rdfs:comment 'Iron metal concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Laboratory Analysis Flag' ;
    rdfs:comment 'Boolean flag indicating whether the sample was sent for laboratory analysis (True) or measured in-field (False).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadConcentration rdf:type rdf:Property ;
    rdfs:label 'Lead Concentration' ;
    rdfs:comment 'Lead metal concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenceExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Licence Exceedance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measurement exceeds the environmental licence limit (True = exceeded, False = compliant).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceLimitParameter rdf:type rdf:Property ;
    rdfs:label 'Licence Limit Parameter' ;
    rdfs:comment 'The specific parameter to which the environmental licence limit applies. [ENUM-REF-CANDIDATE: flow_rate|turbidity|ph|copper|iron|manganese|zinc|arsenic|lead|sulfate|tds — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manganeseConcentration rdf:type rdf:Property ;
    rdfs:label 'Manganese Concentration' ;
    rdfs:comment 'Manganese metal concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Quality status of the measurement indicating whether the data is valid for reporting and analysis.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phLevel rdf:type rdf:Property ;
    rdfs:label 'Ph Level' ;
    rdfs:comment 'pH measurement of seepage water on a scale of 0-14, indicating acidity or alkalinity.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Method' ;
    rdfs:comment 'Method used to collect the seepage water sample for analysis.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfateConcentration rdf:type rdf:Property ;
    rdfs:label 'Sulfate Concentration' ;
    rdfs:comment 'Sulfate ion concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDissolvedSolids rdf:type rdf:Property ;
    rdfs:label 'Total Dissolved Solids' ;
    rdfs:comment 'Total dissolved solids concentration in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidity rdf:type rdf:Property ;
    rdfs:label 'Turbidity' ;
    rdfs:comment 'Turbidity measurement of seepage water in Nephelometric Turbidity Units (NTU), indicating suspended solids and potential internal erosion.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbidityUnit rdf:type rdf:Property ;
    rdfs:label 'Turbidity Unit' ;
    rdfs:comment 'Unit of measure for turbidity reading.' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zincConcentration rdf:type rdf:Property ;
    rdfs:label 'Zinc Concentration' ;
    rdfs:comment 'Zinc metal concentration in seepage water in milligrams per liter (mg/L).' ;
    rdfs:domain ind:SeepageMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineerOfRecordEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Engineer Of Record Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Stability analyses require tracking engineer of record for professional liability and regulatory compliance. Engineer name/registration are denormalized. Essential for geotechnical governance and dam ' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisNotes rdf:type rdf:Property ;
    rdfs:label 'Analysis Notes' ;
    rdfs:comment 'Free-text field for additional comments, assumptions, limitations, or observations related to the stability analysis that are not captured in other structured fields.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Reference Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this stability analysis report by the engineering firm or internal team.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisSoftware rdf:type rdf:Property ;
    rdfs:label 'Analysis Software' ;
    rdfs:comment 'Name and version of the geotechnical software used to perform the stability analysis (e.g., SLOPE/W, PLAXIS, GeoStudio, FLAC).' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle status of the stability analysis: draft (in preparation), under review (submitted for peer review), approved (accepted by engineer of record), superseded (replaced by newer analysis), or archived (historical record).' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Type of geotechnical stability analysis performed: static (steady-state), pseudo-static (simplified seismic), dynamic (time-history seismic), limit equilibrium, finite element method, or probabilistic risk assessment.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohesionKpa rdf:type rdf:Property ;
    rdfs:label 'Cohesion Kpa' ;
    rdfs:comment 'Effective cohesion parameter (c\') of the critical soil or tailings material used in the stability analysis, measured in kilopascals.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalSlipSurfaceDescription rdf:type rdf:Property ;
    rdfs:label 'Critical Slip Surface Description' ;
    rdfs:comment 'Textual description or coordinates of the critical slip surface or failure plane identified in the analysis, including depth, geometry, and location relative to the embankment.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fosComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fos Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the calculated factor of safety meets or exceeds the minimum required FoS. True indicates compliance; False indicates non-compliance requiring remedial action.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frictionAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Friction Angle Degrees' ;
    rdfs:comment 'Effective internal friction angle (φ\') of the critical soil or tailings material used in the stability analysis, measured in degrees.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadingCondition rdf:type rdf:Property ;
    rdfs:label 'Loading Condition' ;
    rdfs:comment 'Operational or environmental loading scenario under which the stability analysis was performed (e.g., end of construction, long-term steady state, rapid drawdown, seismic event, post-seismic, extreme precipitation).' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRequiredFos rdf:type rdf:Property ;
    rdfs:label 'Minimum Required Fos' ;
    rdfs:comment 'Minimum acceptable factor of safety as specified by design standards (e.g., ANCOLD, ICMM GISTM) for the given loading condition and consequence classification.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakGroundAccelerationG rdf:type rdf:Property ;
    rdfs:label 'Peak Ground Acceleration G' ;
    rdfs:comment 'Peak ground acceleration (PGA) used in seismic stability analysis, expressed as a fraction of gravitational acceleration (g).' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Boolean indicator of whether this stability analysis was submitted to a regulatory authority as part of a permit application, annual review, or compliance reporting. True indicates submission; False indicates internal use only.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Return Period Years' ;
    rdfs:comment 'Design return period in years for the loading condition assessed (e.g., 1000-year seismic event, 10000-year flood event), used to determine the design criteria.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seismicCoefficient rdf:type rdf:Property ;
    rdfs:label 'Seismic Coefficient' ;
    rdfs:comment 'Horizontal seismic coefficient (kh) applied in pseudo-static or dynamic stability analysis, representing the fraction of gravity used to simulate earthquake loading.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeightKnM3 rdf:type rdf:Property ;
    rdfs:label 'Unit Weight Kn M3' ;
    rdfs:comment 'Bulk or saturated unit weight of the critical soil or tailings material used in the stability analysis, measured in kilonewtons per cubic meter.' ;
    rdfs:domain ind:StabilityAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tarpTriggerId rdf:type rdf:Property ;
    rdfs:label 'Tarp Trigger Id' ;
    rdfs:comment 'Unique identifier for the TARP trigger event record. Primary key for the tarp_trigger product.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Response Equipment Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Emergency response equipment (pumps, excavators, generators) pre-assigned to TARP trigger levels for rapid deployment. Critical for emergency preparedness planning, TARP drill exercises, equipment rea' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'The date and time when the TARP trigger was activated due to the parameter threshold breach. This is the principal business event timestamp for the trigger record.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By' ;
    rdfs:comment 'Name or identifier of the authority who approved the closure of the TARP trigger event, confirming that all required actions have been satisfactorily completed.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'The date and time when the TARP trigger event was formally closed after all response actions, investigations, and corrective measures were completed and verified.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Description of corrective actions implemented to address the root cause and prevent recurrence of similar TARP trigger events.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Summary of any environmental impacts resulting from the TARP trigger event, including potential or actual effects on water quality, soil, air, or surrounding ecosystems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time when key personnel and authorities were notified of the TARP trigger activation.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notifiedPersonnel rdf:type rdf:Property ;
    rdfs:label 'Notified Personnel' ;
    rdfs:comment 'List of personnel, roles, or positions that were notified of the TARP trigger activation as per the emergency response protocol (e.g., TSF Manager, Chief Geotechnical Engineer, Site Manager, Regulatory Authority).' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Response Actions Taken' ;
    rdfs:comment 'Detailed description of the immediate response actions taken following the TARP trigger activation, including operational adjustments, additional monitoring, engineering interventions, or emergency procedures initiated.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Initiated Timestamp' ;
    rdfs:comment 'The date and time when the formal response actions were initiated following the TARP trigger activation.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis findings that identified the underlying factors contributing to the parameter threshold breach.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Assessment' ;
    rdfs:comment 'Summary of any health and safety impacts or risks to personnel, communities, or infrastructure resulting from the TARP trigger event.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The defined threshold limit for the parameter that was breached, triggering the TARP response. This value corresponds to the trigger level (green, yellow, orange, or red) in the TARP framework.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerLevel rdf:type rdf:Property ;
    rdfs:label 'Trigger Level' ;
    rdfs:comment 'Severity classification of the TARP trigger event. Green indicates normal operations, yellow indicates alert threshold breach, orange indicates action threshold breach requiring immediate response, and red indicates emergency threshold breach requiring critical intervention.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Trigger Reference Number' ;
    rdfs:comment 'Business identifier for the TARP trigger event, used for external reporting and communication with regulatory authorities and management.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerStatus rdf:type rdf:Property ;
    rdfs:label 'Trigger Status' ;
    rdfs:comment 'Current lifecycle status of the TARP trigger event, tracking progression from initial activation through investigation and resolution.' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringParameter rdf:type rdf:Property ;
    rdfs:label 'Triggering Parameter' ;
    rdfs:comment 'The specific geotechnical or operational parameter that breached its threshold and activated the TARP trigger (e.g., piezometric level, settlement rate, seepage flow, freeboard, beach length, dam crest displacement).' ;
    rdfs:domain ind:TarpTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountableExecutiveStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Accountable Executive Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Accountable executives for TSFs are key stakeholders requiring engagement tracking for regulatory compliance, consequence classification reviews, and social licence management. Mining operations track' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:catchmentAreaKm2 rdf:type rdf:Property ;
    rdfs:label 'Catchment Area Km2' ;
    rdfs:comment 'Size of the watershed or catchment area draining into the TSF measured in square kilometers. Critical for water balance calculations and flood risk assessment.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classificationAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Classification Assessment Date' ;
    rdfs:comment 'Date when the consequence classification was last assessed or updated. ICMM GISTM requires regular reassessment of consequence classification.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationAssessor rdf:type rdf:Property ;
    rdfs:label 'Classification Assessor' ;
    rdfs:comment 'Name and credentials of the qualified professional who conducted the consequence classification assessment.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Current Capacity M3' ;
    rdfs:comment 'Current available storage capacity of the TSF in cubic meters at the present raise level and configuration. Updated as raises are completed.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeightM rdf:type rdf:Property ;
    rdfs:label 'Current Height M' ;
    rdfs:comment 'Current height of the dam structure measured in meters from the foundation to the crest at the present raise level.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRaiseLevel rdf:type rdf:Property ;
    rdfs:label 'Current Raise Level' ;
    rdfs:comment 'Current stage or level of dam raise construction. Tailings dams are typically built in stages called raises, with each raise increasing the height and capacity.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damType rdf:type rdf:Property ;
    rdfs:label 'Dam Type' ;
    rdfs:comment 'Construction method and configuration of the tailings dam. Upstream dams are built on top of tailings, downstream dams are built on foundation material, centreline dams combine both methods, dry stack and filtered methods minimize water content.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Design Capacity M3' ;
    rdfs:comment 'Maximum designed storage capacity of the TSF measured in cubic meters. Represents the total volume the facility was engineered to contain at full build-out.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designHeightM rdf:type rdf:Property ;
    rdfs:label 'Design Height M' ;
    rdfs:comment 'Maximum designed height of the dam structure in meters at full build-out. Represents the ultimate height when all planned raises are completed.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downstreamInfrastructureExposure rdf:type rdf:Property ;
    rdfs:label 'Downstream Infrastructure Exposure' ;
    rdfs:comment 'Description of critical infrastructure, facilities, and environmental features located downstream that would be impacted by a dam failure. Includes roads, bridges, utilities, water sources, and ecological assets.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eisReference rdf:type rdf:Property ;
    rdfs:label 'Eis Reference' ;
    rdfs:comment 'Reference number or identifier of the Environmental Impact Statement prepared for the TSF. Links to environmental assessment and approval documentation.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyPreparednessPlanReference rdf:type rdf:Property ;
    rdfs:label 'Emergency Preparedness Plan Reference' ;
    rdfs:comment 'Reference identifier for the Emergency Preparedness and Response Plan specific to this TSF. ICMM GISTM Requirement 15 requires site-specific emergency plans.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineerOfRecord rdf:type rdf:Property ;
    rdfs:label 'Engineer Of Record' ;
    rdfs:comment 'Name and credentials of the qualified professional engineer responsible for the design, construction oversight, and ongoing technical review of the TSF. ICMM GISTM Requirement 5 mandates appointment of an EoR.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedClosureLiabilityUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Closure Liability Usd' ;
    rdfs:comment 'Estimated financial liability for closure and rehabilitation of the TSF measured in United States Dollars. Used for financial provisioning and reporting under IFRS and regulatory requirements.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Unique business identifier or code assigned to the TSF for operational tracking, reporting, and cross-system reference.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official name or designation of the Tailings Storage Facility as registered with regulatory authorities and used in operational documentation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itrbAssignment rdf:type rdf:Property ;
    rdfs:label 'Itrb Assignment' ;
    rdfs:comment 'Name of the Independent Tailings Review Board assigned to provide independent review and oversight of the TSF. ICMM GISTM Requirement 13 requires ITRB for consequence classifications of High, Very High, or Extreme.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRaiseLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Raise Level' ;
    rdfs:comment 'Maximum planned raise level in the facility design. Represents the final stage of construction when the TSF reaches its ultimate design capacity.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inspection Date' ;
    rdfs:comment 'Date when the next formal inspection of the TSF is scheduled. Inspection frequency is determined by consequence classification per ICMM GISTM.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPermitReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Reference' ;
    rdfs:comment 'Reference number or identifier of the primary regulatory permit or license authorizing construction and operation of the TSF. Links to regulatory compliance documentation.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seepageMonitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Seepage Monitoring System' ;
    rdfs:comment 'Description of the seepage monitoring and detection system installed at the TSF. May include piezometers, weirs, visual inspection points, and automated monitoring equipment.' ;
    rdfs:domain ind:Tsf ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsfCapacitySurveyId rdf:type rdf:Property ;
    rdfs:label 'Tsf Capacity Survey Id' ;
    rdfs:comment 'Unique identifier for the TSF capacity survey record. Primary key.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validation Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Capacity surveys require validation by qualified engineer for regulatory acceptance and design compliance. Validation engineer name is denormalized. Critical for survey quality assurance and regulator' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of total storage capacity currently utilized, calculated as (current storage volume / total storage capacity) × 100. Key indicator for TSF filling rate monitoring.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crestElevationM rdf:type rdf:Property ;
    rdfs:label 'Crest Elevation M' ;
    rdfs:comment 'Current elevation of the TSF embankment crest in meters above sea level or site datum at the time of survey.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedFillingRateM3PerDay rdf:type rdf:Property ;
    rdfs:label 'Estimated Filling Rate M3 Per Day' ;
    rdfs:comment 'Estimated average daily rate at which the TSF is being filled with tailings material in cubic meters per day, calculated from historical deposition data.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeboardComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Freeboard Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured freeboard meets or exceeds the minimum required freeboard. True indicates compliance, False indicates non-compliance requiring immediate action.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumRequiredFreeboardM rdf:type rdf:Property ;
    rdfs:label 'Minimum Required Freeboard M' ;
    rdfs:comment 'Minimum freeboard distance in meters required by design specifications and regulatory requirements. Used to assess compliance and trigger operational responses.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pondElevationM rdf:type rdf:Property ;
    rdfs:label 'Pond Elevation M' ;
    rdfs:comment 'Elevation of the supernatant pond water surface in meters above sea level or site datum, measured during the survey.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCapacityExhaustionDate rdf:type rdf:Property ;
    rdfs:label 'Projected Capacity Exhaustion Date' ;
    rdfs:comment 'Forecasted date when the TSF will reach full capacity based on remaining airspace and estimated filling rate. Critical for raise scheduling and operational planning.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyAccuracyClassification rdf:type rdf:Property ;
    rdfs:label 'Survey Accuracy Classification' ;
    rdfs:comment 'Classification of the survey accuracy level based on surveying standards and methodology. High accuracy surveys use advanced methods like LiDAR or drone photogrammetry with ground control.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyNotes rdf:type rdf:Property ;
    rdfs:label 'Survey Notes' ;
    rdfs:comment 'Free-text field for additional observations, conditions, limitations, or contextual information relevant to the capacity survey.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Reference' ;
    rdfs:comment 'Document reference number or identifier for the detailed survey report containing methodology, data, calculations, and certifications.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorCompany rdf:type rdf:Property ;
    rdfs:label 'Surveyor Company' ;
    rdfs:comment 'Name of the surveying company or contractor that performed the capacity survey.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor Registration Number' ;
    rdfs:comment 'Professional registration or license number of the surveyor who conducted the capacity survey, as required by regulatory authorities.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromDesignM3 rdf:type rdf:Property ;
    rdfs:label 'Variance From Design M3' ;
    rdfs:comment 'Difference in cubic meters between the surveyed total storage capacity and the design capacity. Positive values indicate capacity exceeding design; negative values indicate capacity below design.' ;
    rdfs:domain ind:TsfCapacitySurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsfRaiseId rdf:type rdf:Property ;
    rdfs:label 'Tsf Raise Id' ;
    rdfs:comment 'Unique identifier for each TSF raise event. Primary key for the tsf_raise data product.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalStabilityAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Approval Stability Analysis Id' ;
    rdfs:comment 'Foreign key linking to tailings.stability_analysis. Business justification: Each TSF raise requires geotechnical stability analysis for regulatory approval. The raise is approved based on a specific stability analysis that demonstrates the raised embankment will be stable. Th' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityAnalysis .

ind:designEngineerStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Design Engineer Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Design engineers for TSF raises are professional stakeholders requiring engagement tracking for regulatory approvals, independent reviews, and geotechnical sign-offs. Stakeholder management tracks the' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:additionalStorageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Additional Storage Capacity M3' ;
    rdfs:comment 'Incremental tailings storage capacity gained from this raise event, measured in cubic meters. Critical for Life of Mine (LOM) planning and production scheduling.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asBuiltCrestElevationM rdf:type rdf:Property ;
    rdfs:label 'As Built Crest Elevation M' ;
    rdfs:comment 'Actual surveyed elevation of the embankment crest after construction completion, measured in meters above mean sea level. Captured from as-built survey and compared to design target.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:asBuiltDrawingReference rdf:type rdf:Property ;
    rdfs:label 'As Built Drawing Reference' ;
    rdfs:comment 'Document management system reference for the as-built survey drawings and construction completion documentation.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionContractor rdf:type rdf:Property ;
    rdfs:label 'Construction Contractor' ;
    rdfs:comment 'Name of the contractor or construction company responsible for executing the raise construction works.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Design Document Reference' ;
    rdfs:comment 'Document management system reference or identifier for the detailed design report and engineering drawings for this raise.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Sign Off Date' ;
    rdfs:comment 'Date when the geotechnical engineer provided formal sign-off that the raise construction meets design specifications and is safe for commissioning.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raiseHeightM rdf:type rdf:Property ;
    rdfs:label 'Raise Height M' ;
    rdfs:comment 'Vertical height increment added to the embankment by this raise event, measured in meters. Calculated as the difference between new crest elevation and previous crest elevation.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raiseMethod rdf:type rdf:Property ;
    rdfs:label 'Raise Method' ;
    rdfs:comment 'Engineering method used for the embankment raise. Upstream: constructed on the upstream side of the previous crest. Downstream: constructed on the downstream side (most stable). Centreline: constructed directly above the previous crest.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseNotes rdf:type rdf:Property ;
    rdfs:label 'Raise Notes' ;
    rdfs:comment 'Free-text field for additional notes, observations, or comments related to the raise event. May include construction challenges, design changes, or lessons learned.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseNumber rdf:type rdf:Property ;
    rdfs:label 'Raise Number' ;
    rdfs:comment 'Sequential business identifier for the raise event (e.g., RAISE-001, RAISE-002). Used for external communication and documentation.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseStatus rdf:type rdf:Property ;
    rdfs:label 'Raise Status' ;
    rdfs:comment 'Current state of the raise event in its lifecycle. Tracks progression from planning through design, regulatory approval, construction, and completion. [ENUM-REF-CANDIDATE: planned|design|approved|construction|completed|suspended|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Raise Volume M3' ;
    rdfs:comment 'Total volume of embankment material (fill, rockfill, tailings) placed during the raise, measured in cubic meters. Key metric for construction planning and cost estimation.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCrestElevationM rdf:type rdf:Property ;
    rdfs:label 'Target Crest Elevation M' ;
    rdfs:comment 'Design elevation of the embankment crest after completion of the raise, measured in meters above mean sea level. Critical parameter for storage capacity and dam safety.' ;
    rdfs:domain ind:TsfRaise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastePlacementId rdf:type rdf:Property ;
    rdfs:label 'Waste Placement Id' ;
    rdfs:comment 'Unique identifier for the waste placement event. Primary key for the waste placement record.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWasteAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Asset Id' ;
    rdfs:comment 'Identifier of the primary equipment unit (dozer, grader, compactor) used to place and spread the waste material.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryWasteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Employee Id' ;
    rdfs:comment 'Identifier of the equipment operator responsible for the waste placement activity, enabling accountability and performance tracking.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compactionMethod rdf:type rdf:Property ;
    rdfs:label 'Compaction Method' ;
    rdfs:comment 'The method used to compact the placed waste material, critical for geotechnical stability and compliance with dump design specifications.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionPasses rdf:type rdf:Property ;
    rdfs:label 'Compaction Passes' ;
    rdfs:comment 'The number of compaction passes performed on the placed material, ensuring compliance with geotechnical design requirements for density and stability.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:densityAchievedTM3 rdf:type rdf:Property ;
    rdfs:label 'Density Achieved T M3' ;
    rdfs:comment 'The in-situ density achieved after compaction, measured in tonnes per cubic meter (t/m³), critical for geotechnical stability assessment.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Design Compliance Status' ;
    rdfs:comment 'Indicates whether the waste placement complies with the approved waste dump design specifications and geotechnical requirements.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dumpLocationCode rdf:type rdf:Property ;
    rdfs:label 'Dump Location Code' ;
    rdfs:comment 'The specific location or cell code within the waste dump where material was placed, enabling spatial tracking within the facility.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Flag' ;
    rdfs:comment 'Boolean flag indicating whether environmental clearance was obtained prior to waste placement, ensuring compliance with Environmental Impact Statement (EIS) requirements.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geochemicalClassification rdf:type rdf:Property ;
    rdfs:label 'Geochemical Classification' ;
    rdfs:comment 'Geochemical classification indicating whether the material is Potentially Acid Forming (PAF) or Non-Acid Forming (NAF), critical for environmental management and acid rock drainage prevention.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsCoordinates rdf:type rdf:Property ;
    rdfs:label 'Gps Coordinates' ;
    rdfs:comment 'The GPS coordinates (latitude, longitude) of the waste placement location, enabling precise spatial tracking and GIS integration.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftNumber rdf:type rdf:Property ;
    rdfs:label 'Lift Number' ;
    rdfs:comment 'The sequential lift or layer number within the waste dump structure, tracking the vertical build-up against approved design specifications.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonConformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Description' ;
    rdfs:comment 'Detailed description of any non-conformance, deviation, or issue identified during the waste placement activity, supporting corrective action tracking.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceFlag rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Flag' ;
    rdfs:comment 'Boolean flag indicating whether any non-conformance or deviation from design specifications was identified during the waste placement.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'The date when the waste rock or overburden was placed at the waste rock dump. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementEndTime rdf:type rdf:Property ;
    rdfs:label 'Placement End Time' ;
    rdfs:comment 'The timestamp when the waste placement activity was completed, enabling duration calculation and productivity analysis.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:placementStartTime rdf:type rdf:Property ;
    rdfs:label 'Placement Start Time' ;
    rdfs:comment 'The timestamp when the waste placement activity commenced, providing precise timing for operational tracking and shift reconciliation.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of the waste placement event, tracking progression from initiation through completion or cancellation.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Planned Volume M3' ;
    rdfs:comment 'The planned or scheduled volume of waste material to be placed, enabling variance analysis between planned and actual placement.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether quality control inspection was performed on the waste placement, ensuring compliance with operational standards.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceMiningArea rdf:type rdf:Property ;
    rdfs:label 'Source Mining Area' ;
    rdfs:comment 'The specific mining area, bench, or excavation zone from which the waste material was extracted, providing detailed source traceability.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tonnagePlacedT rdf:type rdf:Property ;
    rdfs:label 'Tonnage Placed T' ;
    rdfs:comment 'The mass of waste material placed during this event, measured in tonnes (t). Used for reconciliation with haulage records and capacity planning.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumePlacedM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Placed M3' ;
    rdfs:comment 'The volume of waste material placed during this event, measured in cubic meters (m³). Principal quantitative measurement for waste placement tracking.' ;
    rdfs:domain ind:WastePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory approval or permit authorizing construction and operation of this waste rock dump.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batterAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Batter Angle Degrees' ;
    rdfs:comment 'Design slope angle of the dump face in degrees from horizontal, as per geotechnical stability requirements.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compactionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compaction Required Flag' ;
    rdfs:comment 'Indicates whether compaction of placed material is required per the geotechnical design specification.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionStartDate rdf:type rdf:Property ;
    rdfs:label 'Construction Start Date' ;
    rdfs:comment 'Date when construction of the waste rock dump facility commenced.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentLiftNumber rdf:type rdf:Property ;
    rdfs:label 'Current Lift Number' ;
    rdfs:comment 'Current lift or layer number being actively placed or most recently completed.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Current Volume M3' ;
    rdfs:comment 'Current total volume of material placed in the dump facility in cubic meters, updated from placement events and surveys.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dominantMaterialType rdf:type rdf:Property ;
    rdfs:label 'Dominant Material Type' ;
    rdfs:comment 'Primary lithology or material type of waste rock placed in this dump facility.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drainageSystemType rdf:type rdf:Property ;
    rdfs:label 'Drainage System Type' ;
    rdfs:comment 'Type of drainage system installed to manage surface water runoff and seepage from the dump facility.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geochemicalRiskRating rdf:type rdf:Property ;
    rdfs:label 'Geochemical Risk Rating' ;
    rdfs:comment 'Overall geochemical risk rating for acid rock drainage and metal leaching potential based on material characterization and environmental assessment.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Outcome or finding classification from the most recent inspection of this dump facility.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLiftHeightM rdf:type rdf:Property ;
    rdfs:label 'Maximum Lift Height M' ;
    rdfs:comment 'Maximum approved vertical lift height for each placement layer in meters as per geotechnical design.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date when the waste rock dump facility became operational and began receiving material.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rehabilitationProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Provision Amount' ;
    rdfs:comment 'Financial provision amount set aside for future rehabilitation and closure of this waste rock dump facility in the reporting currency.' ;
    rdfs:domain ind:WasteRockDump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rehabilitationStatus rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Status' ;
    rdfs:comment 'Current status of rehabilitation and closure activities for this dump facility.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity M3' ;
    rdfs:comment 'Remaining available capacity in cubic meters, calculated as design capacity minus current volume.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceCalculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Calculation Timestamp' ;
    rdfs:comment 'Date and time when the water balance calculation was performed. Supports audit trail and version control for reconciliation purposes.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceNotes rdf:type rdf:Property ;
    rdfs:label 'Balance Notes' ;
    rdfs:comment 'Free-text field for recording observations, assumptions, data quality issues, or operational events that affected the water balance during the period. Supports interpretation and future reference.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Balance Period End Date' ;
    rdfs:comment 'End date of the water balance calculation period. Defines the reporting interval for inflows, outflows, and storage changes.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Balance Period Start Date' ;
    rdfs:comment 'Start date of the water balance calculation period. Typically daily, weekly, or monthly depending on operational requirements and regulatory reporting frequency.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceReconciliationVarianceM3 rdf:type rdf:Property ;
    rdfs:label 'Balance Reconciliation Variance M3' ;
    rdfs:comment 'Difference between calculated storage change and measured storage change, measured in cubic meters. Represents the water balance closure error and indicates measurement accuracy and unaccounted losses or gains.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceReconciliationVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Balance Reconciliation Variance Percent' ;
    rdfs:comment 'Balance reconciliation variance expressed as a percentage of total inflow. Provides a normalized measure of water balance accuracy. Acceptable variance thresholds are typically defined in operational procedures.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingPondLevelM rdf:type rdf:Property ;
    rdfs:label 'Closing Pond Level M' ;
    rdfs:comment 'Elevation of the TSF pond water surface at the end of the balance period, measured in meters above a defined datum. Used to calculate closing storage volume and freeboard.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingStorageVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Closing Storage Volume M3' ;
    rdfs:comment 'Volume of water stored in the TSF pond at the end of the balance period, measured in cubic meters. Derived from pond level survey and storage-elevation relationship.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decantReturnOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Decant Return Outflow M3' ;
    rdfs:comment 'Volume of water returned from the TSF to the process plant or water storage via decant structures during the balance period, measured in cubic meters. Primary mechanism for water recovery and freeboard management.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designFreeboardM rdf:type rdf:Property ;
    rdfs:label 'Design Freeboard M' ;
    rdfs:comment 'Minimum required freeboard specified in the TSF design for the current operational stage, measured in meters. Used to assess compliance with design criteria and trigger operational responses.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaporationOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Evaporation Outflow M3' ;
    rdfs:comment 'Volume of water lost from the TSF pond through evaporation during the balance period, measured in cubic meters. Calculated from evaporation rate and pond surface area.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundwaterInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Groundwater Inflow M3' ;
    rdfs:comment 'Volume of groundwater ingress into the TSF pond during the balance period, measured in cubic meters. Typically estimated from piezometric monitoring and seepage models.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingPondLevelM rdf:type rdf:Property ;
    rdfs:label 'Opening Pond Level M' ;
    rdfs:comment 'Elevation of the TSF pond water surface at the start of the balance period, measured in meters above a defined datum. Used to calculate opening storage volume.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingStorageVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Opening Storage Volume M3' ;
    rdfs:comment 'Volume of water stored in the TSF pond at the start of the balance period, measured in cubic meters. Derived from pond level survey and storage-elevation relationship.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Other Inflow M3' ;
    rdfs:comment 'Volume of any other water sources entering the TSF during the balance period not captured in standard inflow categories, measured in cubic meters. May include emergency water transfers or unplanned sources.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Other Outflow M3' ;
    rdfs:comment 'Volume of any other water losses from the TSF during the balance period not captured in standard outflow categories, measured in cubic meters. May include emergency releases or unplanned discharges.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processWaterInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Process Water Inflow M3' ;
    rdfs:comment 'Volume of process water discharged to the TSF from mineral processing operations during the balance period, measured in cubic meters. Includes tailings slurry water and any additional process water streams.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rainfallInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Rainfall Inflow M3' ;
    rdfs:comment 'Volume of direct rainfall onto the TSF pond surface during the balance period, calculated from rainfall depth and pond area, measured in cubic meters.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runoffInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Runoff Inflow M3' ;
    rdfs:comment 'Volume of surface water runoff from the TSF catchment area entering the pond during the balance period, measured in cubic meters. Includes runoff from embankment slopes and upstream catchment if not diverted.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seepageOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Seepage Outflow M3' ;
    rdfs:comment 'Volume of water lost through seepage from the TSF embankment and foundation during the balance period, measured in cubic meters. Estimated from piezometric data, seepage collection systems, and geotechnical models.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spillwayDischargeOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Spillway Discharge Outflow M3' ;
    rdfs:comment 'Volume of water discharged through the TSF spillway during the balance period, measured in cubic meters. Typically occurs during extreme rainfall events when pond capacity is exceeded.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageChangeM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Change M3' ;
    rdfs:comment 'Net change in water storage volume during the balance period, measured in cubic meters. Calculated as closing storage minus opening storage. Should reconcile with total inflow minus total outflow.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInflowM3 rdf:type rdf:Property ;
    rdfs:label 'Total Inflow M3' ;
    rdfs:comment 'Sum of all water inflows to the TSF during the balance period, measured in cubic meters. Calculated as process water + rainfall + runoff + groundwater + other inflows.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOutflowM3 rdf:type rdf:Property ;
    rdfs:label 'Total Outflow M3' ;
    rdfs:comment 'Sum of all water outflows from the TSF during the balance period, measured in cubic meters. Calculated as evaporation + seepage + decant return + spillway discharge + other outflows.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterLicenceComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Water Licence Compliance Status' ;
    rdfs:comment 'Assessment of whether the water balance period operations complied with water licence conditions including discharge limits, return water quality, and reporting requirements.' ;
    rdfs:domain ind:WaterBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Id' ;
    rdfs:comment 'Unique identifier for the expenditure commitment record. Primary key for this entity.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carryForwardAmount rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Amount' ;
    rdfs:comment 'The amount of surplus expenditure from this reporting period that is eligible to be carried forward to offset future period commitments, where permitted by regulation.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carryForwardExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Expiry Date' ;
    rdfs:comment 'The date by which any carry-forward expenditure credit must be utilized, after which it expires and can no longer be applied to future commitments.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'External reference number or code assigned by the mining authority or internal system to uniquely identify this expenditure commitment obligation.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Granted Flag' ;
    rdfs:comment 'Indicates whether an exemption from the expenditure commitment has been granted by the mining authority for this reporting period. True if exemption granted, False otherwise.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'The reason or justification provided for the exemption from the expenditure commitment, if an exemption was granted. May reference force majeure, regulatory delays, or other circumstances.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forfeitureRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Risk Flag' ;
    rdfs:comment 'Indicates whether the tenement is at risk of forfeiture due to non-compliance with this expenditure commitment. True if forfeiture risk exists, False otherwise.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'The date by which the expenditure report must be submitted to the mining authority to demonstrate compliance with the commitment. Typically falls after the reporting period end date.' ;
    rdfs:domain ind:ExpenditureCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nativeTitleAgreementId rdf:type rdf:Property ;
    rdfs:label 'Native Title Agreement Id' ;
    rdfs:comment 'Foreign key linking to tenement.native_title_agreement. Business justification: Heritage clearances often require consent from traditional owners under a specific native title agreement. The clearance record currently has traditional_owner_group (string), traditional_owner_consen' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NativeTitleAgreement .

ind:clearanceAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Clearance Area Hectares' ;
    rdfs:comment 'Total area in hectares covered by this heritage clearance. Represents the spatial extent of the surveyed and cleared area for ground disturbance activities.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Expiry Date' ;
    rdfs:comment 'Date on which the heritage clearance expires and a new survey or renewal is required. Nullable for clearances with indefinite validity subject to ongoing compliance.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceOutcome rdf:type rdf:Property ;
    rdfs:label 'Clearance Outcome' ;
    rdfs:comment 'Detailed outcome of the heritage survey. Indicates whether no heritage sites were identified, sites were identified and will be avoided, sites were salvaged, sites require restricted access zones, or clearance was denied due to significant heritage values.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Clearance Reference Number' ;
    rdfs:comment 'External reference number or code assigned to this heritage clearance by the surveying authority, consultant, or regulatory body. Used for tracking and correspondence.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Clearance Status' ;
    rdfs:comment 'Current lifecycle status of the heritage clearance. Indicates whether the area is pending assessment, cleared for disturbance, cleared with spatial or activity restrictions, refused clearance, expired, or under regulatory review.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Valid From Date' ;
    rdfs:comment 'Date from which the heritage clearance becomes effective and ground disturbance activities may commence. Represents the start of the clearance validity period.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionsAndRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditions And Restrictions' ;
    rdfs:comment 'Detailed textual description of any conditions, restrictions, or mitigation measures imposed as part of the heritage clearance. May include activity limitations, monitoring requirements, or salvage protocols.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageSiteRegisterNumbers rdf:type rdf:Property ;
    rdfs:label 'Heritage Site Register Numbers' ;
    rdfs:comment 'Comma-separated list of heritage site register numbers identified during the survey. References official heritage site databases such as state Aboriginal heritage registers, National Heritage List, or Commonwealth Heritage List.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Required' ;
    rdfs:comment 'Indicates whether ongoing heritage monitoring is required during ground disturbance activities. True if a heritage monitor must be present during excavation or earthworks, false otherwise.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedZoneDescription rdf:type rdf:Property ;
    rdfs:label 'Restricted Zone Description' ;
    rdfs:comment 'Textual description of any restricted zones or exclusion areas identified in the clearance. Describes spatial boundaries, buffer distances, and activity restrictions to protect heritage sites.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedZoneSpatialReference rdf:type rdf:Property ;
    rdfs:label 'Restricted Zone Spatial Reference' ;
    rdfs:comment 'Geographic Information System (GIS) spatial reference or coordinate set defining the boundaries of restricted heritage zones. May include polygon coordinates, GIS layer references, or map grid references.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Salvage Completion Date' ;
    rdfs:comment 'Date on which required archaeological salvage operations were completed. Nullable if salvage is not required or is still in progress.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salvageRequired rdf:type rdf:Property ;
    rdfs:label 'Salvage Required' ;
    rdfs:comment 'Indicates whether archaeological salvage operations are required before ground disturbance. True if artifacts or sites must be salvaged and relocated, false otherwise.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Survey Completion Date' ;
    rdfs:comment 'Date on which the heritage survey report was finalized and submitted. May differ from survey_date if report preparation takes additional time.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyCostAud rdf:type rdf:Property ;
    rdfs:label 'Survey Cost Aud' ;
    rdfs:comment 'Total cost in Australian Dollars incurred for conducting the heritage survey, including consultant fees, traditional owner consultation costs, and report preparation. Business-confidential financial data.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyReportDocumentPath rdf:type rdf:Property ;
    rdfs:label 'Survey Report Document Path' ;
    rdfs:comment 'File path or document management system reference to the full heritage survey report. Enables retrieval of detailed survey findings, site maps, and recommendations.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Surveying Authority' ;
    rdfs:comment 'Name of the heritage consultant, archaeological firm, or traditional owner group that conducted the heritage survey. May include accredited heritage practitioners or registered native title bodies corporate.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Surveyor Contact Email' ;
    rdfs:comment 'Primary email address of the surveying authority or lead consultant for correspondence regarding this clearance.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Surveyor Contact Phone' ;
    rdfs:comment 'Primary phone number of the surveying authority or lead consultant for urgent clearance inquiries.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalOwnerConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Consent Obtained' ;
    rdfs:comment 'Indicates whether formal consent from the traditional owner group was obtained for ground disturbance activities. True if consent was granted, false if consent was not obtained or not required.' ;
    rdfs:domain ind:HeritageClearance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traditionalOwnerGroup rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Group' ;
    rdfs:comment 'Name of the Aboriginal traditional owner group or native title claimant group consulted during the heritage survey. Identifies the Indigenous custodians of the land with cultural heritage rights.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traditionalOwnerStakeholderId rdf:type rdf:Property ;
    rdfs:label 'Traditional Owner Stakeholder Id' ;
    rdfs:comment 'Foreign key linking to community.stakeholder. Business justification: Native title agreements are executed with specific traditional owner groups registered as stakeholders. Essential for tracking agreement parties, consultation obligations, and benefit distribution. Re' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stakeholder .

ind:consultationRequirements rdf:type rdf:Property ;
    rdfs:label 'Consultation Requirements' ;
    rdfs:comment 'Description of ongoing consultation, engagement, and notification requirements with traditional owners for mining activities.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalHeritageObligations rdf:type rdf:Property ;
    rdfs:label 'Cultural Heritage Obligations' ;
    rdfs:comment 'Description of the cultural heritage protection obligations and requirements imposed on the mining company under this agreement, including survey requirements, site avoidance, and consultation protocols.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryPath rdf:type rdf:Property ;
    rdfs:label 'Document Repository Path' ;
    rdfs:comment 'File path or URI to the location where the executed agreement document and related legal documents are stored in the document management system.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentCommitment rdf:type rdf:Property ;
    rdfs:label 'Employment Commitment' ;
    rdfs:comment 'Description of commitments to provide employment, training, and business opportunities to traditional owner group members.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalObligations rdf:type rdf:Property ;
    rdfs:label 'Environmental Obligations' ;
    rdfs:comment 'Description of environmental management and rehabilitation obligations specific to this agreement, beyond standard regulatory requirements.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Description' ;
    rdfs:comment 'Textual description of the geographic area covered by this agreement. Detailed spatial boundaries are maintained in GIS systems.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iluaType rdf:type rdf:Property ;
    rdfs:label 'Ilua Type' ;
    rdfs:comment 'The specific sub-category of ILUA if agreement_type is ILUA. Area Agreement covers a defined area, Body Corporate Agreement is with a registered native title body corporate, Alternative Procedure Agreement uses alternative state/territory processes.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landAccessRights rdf:type rdf:Property ;
    rdfs:label 'Land Access Rights' ;
    rdfs:comment 'Description of the land access rights granted to the mining company under this agreement, including permitted activities and geographic scope.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Audit Date' ;
    rdfs:comment 'The date of the most recent compliance audit or review conducted for this agreement.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselName rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Name' ;
    rdfs:comment 'Name of the legal firm or counsel that advised on or drafted this agreement on behalf of the mining company.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes an option for renewal or extension beyond the initial term.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Description of the terms and conditions under which the agreement may be renewed or extended, if renewal_option_flag is true.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Royalty Basis' ;
    rdfs:comment 'The basis on which royalty payments are calculated, if royalty compensation is included in the agreement.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'The percentage royalty rate payable to traditional owners on mineral production or revenue, if applicable.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCompensationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Compensation Amount' ;
    rdfs:comment 'The total monetary compensation amount payable under the agreement, in the currency specified. Excludes in-kind or royalty-based compensation.' ;
    rdfs:domain ind:NativeTitleAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: POWs require an accountable employee (geologist, mine planner, environmental officer) for approval workflows, regulatory reporting, and competency verification. Real business process: POW submission a' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closeOutDate rdf:type rdf:Property ;
    rdfs:label 'Close Out Date' ;
    rdfs:comment 'The date on which the programme of work was formally closed out with the regulatory authority, including submission of completion reports and rehabilitation evidence.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current status of the programme of work execution and close-out, indicating whether activities have commenced, are in progress, completed, or formally closed out with the regulator.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disturbanceAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Disturbance Area Hectares' ;
    rdfs:comment 'The total area in hectares proposed to be disturbed by the planned activities under this programme of work.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalManagementCommitments rdf:type rdf:Property ;
    rdfs:label 'Environmental Management Commitments' ;
    rdfs:comment 'Detailed description of the environmental management measures, mitigation strategies, and commitments made as part of the programme of work submission to minimize environmental impact.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Expenditure Amount' ;
    rdfs:comment 'The estimated total expenditure amount in the base currency for the planned activities under this programme of work.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heritageClearanceObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Obtained Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required heritage clearance has been obtained before programme of work approval for ground-disturbing activities. True if clearance obtained, False otherwise.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heritageClearanceReference rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Reference' ;
    rdfs:comment 'Reference number or identifier of the heritage clearance approval that is a prerequisite for this programme of work.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pow Reference Number' ;
    rdfs:comment 'The externally-known reference number or identifier assigned by the regulatory authority or internal system for this programme of work submission.' ;
    rdfs:domain ind:ProgrammeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryConditionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Condition Id' ;
    rdfs:comment 'Unique identifier for the regulatory condition record. Primary key for the regulatory condition entity.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachDate rdf:type rdf:Property ;
    rdfs:label 'Breach Date' ;
    rdfs:comment 'Date on which the breach or non-compliance with this condition was identified or formally notified by the granting authority.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breachDescription rdf:type rdf:Property ;
    rdfs:label 'Breach Description' ;
    rdfs:comment 'Detailed description of the nature and circumstances of the breach or non-compliance event, including any formal notices or directions issued by the granting authority.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicator of whether this regulatory condition has been breached or is currently subject to a non-compliance notice, show-cause notice, or enforcement action.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Date' ;
    rdfs:comment 'Deadline by which the condition must be satisfied or the required action/deliverable must be completed. Used for tracking compliance milestones and reporting obligations.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Full text description of the regulatory condition, including detailed requirements, restrictions, obligations, and any specific actions or deliverables mandated by the granting authority.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Reference Number' ;
    rdfs:comment 'The official reference number or code assigned by the granting authority (e.g., DMIRS, DPE) to uniquely identify this condition within the tenement approval documentation.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current compliance status of the regulatory condition. Tracks whether the condition is being met, breached, or is under regulatory review or enforcement action. [ENUM-REF-CANDIDATE: active|compliant|non_compliant|under_review|suspended|revoked|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionTitle rdf:type rdf:Property ;
    rdfs:label 'Condition Title' ;
    rdfs:comment 'Short descriptive title or summary of the regulatory condition as stated in the approval documentation.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the regulatory condition based on its nature and purpose. Defines the category of obligation or restriction imposed by the granting authority. [ENUM-REF-CANDIDATE: environmental_management_plan|operational_restriction|annual_reporting_obligation|access_limitation|heritage_protection|rehabilitation_requirement|water_management|noise_emission_limit|dust_control|blasting_restriction|operating_hours|community_consultation|financial_assurance|other — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionDate rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Date' ;
    rdfs:comment 'Date on which the enforcement action was formally issued or commenced by the granting authority.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionType rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Type' ;
    rdfs:comment 'Type of enforcement action taken or threatened by the granting authority in response to non-compliance with this condition. [ENUM-REF-CANDIDATE: warning_letter|show_cause_notice|remediation_direction|penalty_notice|prosecution|suspension|revocation|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantingAuthority rdf:type rdf:Property ;
    rdfs:label 'Granting Authority' ;
    rdfs:comment 'Name of the government department, agency, or regulatory body that imposed this condition (e.g., Department of Mines, Industry Regulation and Safety - DMIRS, Department of Planning and Environment - DPE).' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicator of whether this condition requires periodic regulatory inspections or site visits by the granting authority to verify compliance.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date of the most recent internal or external compliance review or audit conducted to assess adherence to this regulatory condition.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastComplianceReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Outcome' ;
    rdfs:comment 'Result of the most recent compliance review or audit for this condition. Indicates whether the condition was found to be satisfied or breached.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legislationReference rdf:type rdf:Property ;
    rdfs:label 'Legislation Reference' ;
    rdfs:comment 'Citation of the specific legislation, act, regulation, or statutory instrument under which this condition was imposed (e.g., Mining Act 1978 Section 82, Environmental Protection Act 1986).' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'Date by which the next statutory report or compliance submission is due to the granting authority for this condition.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty amount (e.g., AUD, USD, CAD).' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Deadline by which remediation or corrective action must be completed to satisfy the granting authority and restore compliance.' ;
    rdfs:domain ind:RegulatoryCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relinquishmentId rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Id' ;
    rdfs:comment 'Unique identifier for the tenement relinquishment event. Primary key.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaRelinquishedHectares rdf:type rdf:Property ;
    rdfs:label 'Area Relinquished Hectares' ;
    rdfs:comment 'The total area surrendered in this relinquishment event, measured in hectares.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Status' ;
    rdfs:comment 'Status of environmental conditions and rehabilitation obligations for the relinquished area at the time of surrender.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureCommitmentImpact rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Impact' ;
    rdfs:comment 'Describes the impact of the relinquishment on ongoing expenditure commitments for the remaining tenement area.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisBoundaryFileReference rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary File Reference' ;
    rdfs:comment 'Reference to the GIS spatial data file or layer that defines the precise geographic boundaries of the relinquished area.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Flag' ;
    rdfs:comment 'Indicates whether cultural heritage clearance was required and obtained for the relinquished area prior to surrender.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nativeTitleClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Native Title Clearance Flag' ;
    rdfs:comment 'Indicates whether native title clearance or consultation was required and obtained prior to relinquishment approval.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which formal notification of the relinquishment was sent to relevant stakeholders, including regulatory authorities and affected parties.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'The percentage of the original tenement area that is being relinquished, calculated as (area_relinquished / original_tenement_area) * 100.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicNoticeFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notice Flag' ;
    rdfs:comment 'Indicates whether a public notice of the relinquishment was required and published as per regulatory requirements.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relinquishmentDate rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Date' ;
    rdfs:comment 'The effective date on which the relinquished area was formally surrendered back to the Crown or regulatory authority.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relinquishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Status' ;
    rdfs:comment 'Current lifecycle status of the relinquishment event in the regulatory approval workflow.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relinquishmentType rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Type' ;
    rdfs:comment 'Classification of the relinquishment event indicating whether it is partial, full, voluntary, statutory obligation, or conditional.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Remaining Area Hectares' ;
    rdfs:comment 'The area of the tenement that remains under the company\'s control after this relinquishment, measured in hectares.' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statutoryObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Statutory Obligation Flag' ;
    rdfs:comment 'Indicates whether this relinquishment is mandated by statutory relinquishment obligations at renewal (True) or is a voluntary surrender (False).' ;
    rdfs:domain ind:Relinquishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalObligationId rdf:type rdf:Property ;
    rdfs:label 'Renewal Obligation Id' ;
    rdfs:comment 'Unique identifier for the tenement renewal obligation record. Primary key for the renewal obligation entity.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Renewal obligations require task assignment to specific employees for reminder workflows, accountability tracking, and performance management. Real business process: renewal deadline management and lo' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Date' ;
    rdfs:comment 'The date on which the system or responsible person should be alerted about the upcoming renewal deadline, typically set several months before the lodgement deadline.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaRelinquishmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Area Relinquishment Required Flag' ;
    rdfs:comment 'Indicates whether the renewal requires the tenement holder to relinquish a portion of the tenement area as a condition of renewal (True if relinquishment is required, False otherwise).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Status' ;
    rdfs:comment 'The environmental compliance status of the tenement at the time of renewal application: compliant (meets all requirements), non_compliant (violations identified), under_review (being assessed), or remediation_required (corrective action needed before renewal).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Amount' ;
    rdfs:comment 'The minimum exploration or mining expenditure amount that the tenement holder commits to spend during the renewed term as a condition of renewal.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureCommitmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the expenditure commitment amount.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Heritage Clearance Required Flag' ;
    rdfs:comment 'Indicates whether cultural heritage clearance or survey is required as a condition of this renewal (True if required, False otherwise).' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodgementDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Lodgement Deadline Date' ;
    rdfs:comment 'The final date by which the renewal application must be lodged with the regulatory authority, typically occurring before the renewal due date to allow processing time.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lodgementSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Lodgement Submitted Date' ;
    rdfs:comment 'The actual date on which the renewal application was submitted to the regulatory authority.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nativeTitleClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Native Title Clearance Required Flag' ;
    rdfs:comment 'Indicates whether native title consultation or clearance is required as a condition of this renewal (True if required, False otherwise).' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nativeTitleClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Native Title Clearance Status' ;
    rdfs:comment 'The current status of native title clearance for this renewal: not_required (no clearance needed), pending (clearance process not started), in_progress (consultation underway), obtained (clearance granted), or refused (clearance denied).' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newExpiryDate rdf:type rdf:Property ;
    rdfs:label 'New Expiry Date' ;
    rdfs:comment 'The new expiry date of the tenement following successful renewal, marking the end of the renewed term.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'The name of the government department or regulatory body responsible for processing and deciding on this renewal application (e.g., Department of Mines, Ministry of Natural Resources).' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The state, province, or national jurisdiction under whose mining legislation this renewal is governed (e.g., Western Australia, Queensland, British Columbia).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relinquishmentAreaHectares rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Area Hectares' ;
    rdfs:comment 'The area in hectares that must be relinquished from the tenement as a condition of renewal, if area relinquishment is required.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relinquishmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Relinquishment Percentage' ;
    rdfs:comment 'The percentage of the original tenement area that must be relinquished as a condition of renewal, expressed as a decimal (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalConditions rdf:type rdf:Property ;
    rdfs:label 'Renewal Conditions' ;
    rdfs:comment 'Detailed description of any conditions, restrictions, or obligations attached to the renewal by the regulatory authority (e.g., environmental monitoring requirements, heritage clearance obligations, reporting requirements).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The total fee amount payable to the regulatory authority for processing and granting the tenement renewal, expressed in the operating currency.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the renewal fee amount (e.g., AUD, USD, CAD).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeePaidDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Paid Date' ;
    rdfs:comment 'The date on which the renewal fee was paid to the regulatory authority.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOutcome rdf:type rdf:Property ;
    rdfs:label 'Renewal Outcome' ;
    rdfs:comment 'The final outcome of the renewal application: granted (renewal approved), refused (renewal denied by authority), lapsed (tenement expired without renewal), withdrawn (application withdrawn by holder), or pending (decision not yet made).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalPriority rdf:type rdf:Property ;
    rdfs:label 'Renewal Priority' ;
    rdfs:comment 'The business priority assigned to this renewal obligation based on strategic importance, production impact, and resource value: critical (active mining operations), high (near-term development), medium (exploration with potential), or low (non-core assets).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Reference Number' ;
    rdfs:comment 'The official reference number or application identifier assigned by the regulatory authority for this renewal submission.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Years' ;
    rdfs:comment 'The duration in years for which the tenement is renewed upon approval of this renewal application.' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'The category of renewal being processed: standard (routine renewal), expedited (fast-track), conditional (subject to additional requirements), extension (temporary extension pending decision), or variation (renewal with modified terms).' ;
    rdfs:domain ind:RenewalObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Royalty Agreement Id' ;
    rdfs:comment 'Unique identifier for the royalty agreement record. Primary key for the royalty agreement entity.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyAgreement .

ind:payeeCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Payee Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Royalty payees (landowners, previous tenement holders, state entities, traditional owners) are registered counterparties for payment processing via bank_account, credit limit management, and commercia' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:accrualMethod rdf:type rdf:Property ;
    rdfs:label 'Accrual Method' ;
    rdfs:comment 'The accounting method used to accrue royalty obligations. Production-based accrues royalties when minerals are extracted; sales-based accrues when minerals are sold; cash basis recognizes when payment is made; shipment-based accrues when minerals are shipped.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the royalty agreement for business reference and reporting purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRestrictions rdf:type rdf:Property ;
    rdfs:label 'Assignment Restrictions' ;
    rdfs:comment 'Description of any restrictions on the company\'s ability to assign or transfer the royalty agreement to another party, or on the payee\'s ability to assign their royalty entitlement.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRights rdf:type rdf:Property ;
    rdfs:label 'Audit Rights' ;
    rdfs:comment 'Description of the payee\'s rights to audit the company\'s books and records to verify royalty calculations, including frequency, notice period, and scope of audit rights as specified in the agreement.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference to the physical or electronic location of the executed royalty agreement contract document in the document management system.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAllowances rdf:type rdf:Property ;
    rdfs:label 'Deduction Allowances' ;
    rdfs:comment 'Description of any allowable deductions from the royalty calculation basis, such as transportation costs, processing costs, marketing costs, or other expenses that may be deducted before calculating the royalty payment.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationClause rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Description of any escalation provisions in the royalty agreement, such as rate increases tied to commodity price thresholds, inflation indices (CPI), or production volume milestones.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsClassification rdf:type rdf:Property ;
    rdfs:label 'Ifrs Classification' ;
    rdfs:comment 'The classification of the royalty obligation under IFRS accounting standards for financial reporting purposes. Determines how the royalty is recognized in financial statements.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Royalty Amount' ;
    rdfs:comment 'The maximum royalty payment amount cap per period, if specified in the agreement. Used in some profit-sharing or capped royalty structures.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyFormula rdf:type rdf:Property ;
    rdfs:label 'Royalty Formula' ;
    rdfs:comment 'The detailed formula or algorithm used to calculate the royalty payment, including any tiered rates, thresholds, or complex calculation logic. Used when a simple rate is insufficient to capture the calculation method.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityInterest rdf:type rdf:Property ;
    rdfs:label 'Security Interest' ;
    rdfs:comment 'Description of any security interests, liens, or encumbrances granted to the payee to secure royalty payment obligations, such as charges over mining assets or revenue streams.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationConditions rdf:type rdf:Property ;
    rdfs:label 'Termination Conditions' ;
    rdfs:comment 'Description of the conditions under which the royalty agreement may be terminated by either party, including breach provisions, notice periods, and termination payments.' ;
    rdfs:domain ind:RoyaltyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceRightId rdf:type rdf:Property ;
    rdfs:label 'Surface Right Id' ;
    rdfs:comment 'Unique identifier for the surface right record. Primary key for the surface right entity.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Agreement Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the legal agreement document or contract governing this surface right. Links to document management system.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaDescription rdf:type rdf:Property ;
    rdfs:label 'Area Description' ;
    rdfs:comment 'Textual description of the geographic area or land parcel covered by the surface right. May include lot numbers, cadastral references, or natural feature descriptions.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationFrequency rdf:type rdf:Property ;
    rdfs:label 'Compensation Frequency' ;
    rdfs:comment 'The frequency or schedule on which compensation payments are made to the grantor. Indicates whether payment is a single lump sum or recurring.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisBoundaryReference rdf:type rdf:Property ;
    rdfs:label 'Gis Boundary Reference' ;
    rdfs:comment 'Reference identifier or file name linking this surface right to its spatial boundary representation in the corporate GIS system. Enables mapping and spatial analysis.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Grantor Contact Email' ;
    rdfs:comment 'Primary email address for the grantor contact. Used for formal correspondence and notifications related to the surface right.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorContactName rdf:type rdf:Property ;
    rdfs:label 'Grantor Contact Name' ;
    rdfs:comment 'The name of the primary contact person representing the grantor for correspondence and negotiation related to this surface right.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Grantor Contact Phone' ;
    rdfs:comment 'Primary telephone number for the grantor contact. Used for operational communication regarding the surface right agreement.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'The legal name of the party granting the surface right. May be a private landowner, government authority, indigenous group, or other entity holding surface title.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantorType rdf:type rdf:Property ;
    rdfs:label 'Grantor Type' ;
    rdfs:comment 'Classification of the grantor entity. Distinguishes between private landowners, government bodies, indigenous or native title holders, corporate entities, trusts, and other grantor types.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAuthority rdf:type rdf:Property ;
    rdfs:label 'Registered Authority' ;
    rdfs:comment 'The name of the government department, land registry, or regulatory body with which the surface right is registered or lodged. Relevant for compliance and legal standing.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Textual description of any restrictions, limitations, or conditions placed on the use of the surface right. May include environmental conditions, access limitations, or operational constraints.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightNumber rdf:type rdf:Property ;
    rdfs:label 'Right Number' ;
    rdfs:comment 'The externally-known unique identifier or registration number assigned to this surface right by the grantor or regulatory authority. Used for legal reference and tracking.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightType rdf:type rdf:Property ;
    rdfs:label 'Right Type' ;
    rdfs:comment 'Classification of the surface right indicating the nature of the right granted. Distinguishes between access rights, water rights, pipeline easements, road access, and other infrastructure or utility rights. [ENUM-REF-CANDIDATE: access|water|pipeline|road|easement|infrastructure|utility|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceRightStatus rdf:type rdf:Property ;
    rdfs:label 'Surface Right Status' ;
    rdfs:comment 'Current lifecycle status of the surface right agreement. Indicates whether the right is currently in force, awaiting approval, has lapsed, or has been terminated.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termYears rdf:type rdf:Property ;
    rdfs:label 'Term Years' ;
    rdfs:comment 'The duration of the surface right agreement expressed in whole years. Calculated from effective start to end date, or specified contractually.' ;
    rdfs:domain ind:SurfaceRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualExpenditureCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Expenditure Commitment' ;
    rdfs:comment 'The minimum annual expenditure amount (in local currency) that must be spent on exploration or development activities to maintain the tenement in good standing. Failure to meet this commitment may result in forfeiture.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureCurrency rdf:type rdf:Property ;
    rdfs:label 'Expenditure Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the annual expenditure commitment (e.g., AUD, CAD, USD, ZAR).' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'The date on which the tenement was officially granted by the regulatory authority, marking the commencement of the licence term.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantedCommodities rdf:type rdf:Property ;
    rdfs:label 'Granted Commodities' ;
    rdfs:comment 'Comma-separated list of minerals or commodities for which the tenement grants exploration or extraction rights (e.g., \'Iron Ore, Gold, Copper\', \'Lithium, Nickel\'). Defines the scope of permitted mineral activities.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'The legal name of the entity or individual registered as the holder of the tenement. May be the company itself or a subsidiary.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderPercentage rdf:type rdf:Property ;
    rdfs:label 'Holder Percentage' ;
    rdfs:comment 'The percentage ownership interest held by the registered holder in this tenement. Relevant for joint ventures or partial interests. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:licenceType rdf:type rdf:Property ;
    rdfs:label 'Licence Type' ;
    rdfs:comment 'The category of mineral tenement defining the permitted activities and rights. Exploration Licence (EL) allows exploration activities; Mining Lease (ML) permits extraction; Prospecting Licence (PL) for small-scale exploration; Retention Licence (RL) to retain discovered resources not yet economically viable; Miscellaneous Licence for ancillary purposes.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeTitleStatus rdf:type rdf:Property ;
    rdfs:label 'Native Title Status' ;
    rdfs:comment 'The status of native title considerations for the tenement. Not Applicable: jurisdiction does not recognize native title; Determined: native title has been legally determined; Registered Claim: a native title claim is registered over the area; Agreement in Place: native title agreement (e.g., ILUA) executed; Negotiation Required: consultation or agreement process underway.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReportingDate rdf:type rdf:Property ;
    rdfs:label 'Next Reporting Date' ;
    rdfs:comment 'The date by which the next statutory report (e.g., annual expenditure report, exploration report) must be submitted to the regulatory authority. Critical for compliance tracking.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date by which a renewal application must be submitted to extend the tenement term. Nullable for tenements not yet requiring renewal.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statutoryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Statutory Identifier' ;
    rdfs:comment 'The official government-issued unique identifier for the tenement as registered with the mining authority (e.g., EL12345, ML67890, PL54321). This is the externally-known business identifier used in all regulatory correspondence and public registers.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Internal classification of the tenement\'s strategic importance to the company\'s portfolio. Tier 1: highest priority, active development or production; Tier 2: medium priority, advanced exploration; Tier 3: early-stage or prospective; Non-Core: retained but not strategic; Divestment Candidate: targeted for sale or surrender.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Surface Rights Status' ;
    rdfs:comment 'The status of surface land access rights for the tenement. Owned: company owns the surface land; Leased: surface land leased from owner; Access Agreement: formal access agreement in place; Negotiation Required: access rights being negotiated; Restricted: surface access limited or denied.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenementName rdf:type rdf:Property ;
    rdfs:label 'Tenement Name' ;
    rdfs:comment 'The common or project name assigned to the tenement for internal reference and communication (e.g., \'Iron Ridge North\', \'Copper Creek Prospect\').' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicantCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Applicant Counterparty Id' ;
    rdfs:comment 'Foreign key linking to customer.counterparty. Business justification: Applications by external parties (farm-in partners, acquisition targets, joint venture applicants) require counterparty linkage for due diligence reviews, commercial negotiation tracking, KYC complian' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:grantedTenementId rdf:type rdf:Property ;
    rdfs:label 'Granted Tenement Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement. Business justification: When a tenement application is granted, it results in the creation of a tenement record. This FK tracks the outcome of the application process. The FK is populated when application_status = \'Granted\' ' ;
    rdfs:domain ind:Application ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tenement .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'The externally-known unique reference number assigned by the regulatory authority to this tenement application upon lodgement. This is the official identifier used in all correspondence and regulatory filings.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current state of the application in its regulatory approval workflow, from initial lodgement through final decision. [ENUM-REF-CANDIDATE: lodged|under_review|objection_period|hearing_scheduled|approved|refused|withdrawn|lapsed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'The category of tenement being applied for, determining the rights and obligations associated with the application.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfGrant rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Grant' ;
    rdfs:comment 'A description of any special conditions, restrictions, or obligations imposed by the regulatory authority as part of the tenement grant (e.g., environmental monitoring requirements, access restrictions, rehabilitation bonds).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Assessment Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether an Environmental Impact Statement (EIS) or environmental assessment is required as part of the application approval process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Environmental Assessment Status' ;
    rdfs:comment 'The current status of the environmental assessment or EIS submission and approval process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenditureCommitmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the expenditure commitment amount. [ENUM-REF-CANDIDATE: AUD|USD|CAD|ZAR|CLP|PEN|BRL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The total fee payable to the regulatory authority for processing the tenement application, typically calculated based on area and application type.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the application fee amount. [ENUM-REF-CANDIDATE: AUD|USD|CAD|ZAR|CLP|PEN|BRL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Scheduled Date' ;
    rdfs:comment 'The date scheduled for a formal hearing or tribunal to adjudicate the objection. Null if no hearing is required or scheduled.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mineralSought rdf:type rdf:Property ;
    rdfs:label 'Mineral Sought' ;
    rdfs:comment 'The primary mineral, metal, or commodity that the applicant intends to explore for or extract under this tenement. May list multiple commodities separated by commas (e.g., \'iron ore, copper, gold\').' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionGrounds rdf:type rdf:Property ;
    rdfs:label 'Objection Grounds' ;
    rdfs:comment 'A description of the legal, environmental, cultural, or other grounds on which the objection is based (e.g., native title conflict, environmental impact, overlapping tenure, heritage site protection).' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionLodgementDate rdf:type rdf:Property ;
    rdfs:label 'Objection Lodgement Date' ;
    rdfs:comment 'The date on which the objection was formally lodged with the regulatory authority. Null if no objection received.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectionReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Objection Received Flag' ;
    rdfs:comment 'Boolean flag indicating whether any formal objections have been lodged against this application by third parties, native title claimants, environmental groups, or other stakeholders.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectionResolution rdf:type rdf:Property ;
    rdfs:label 'Objection Resolution' ;
    rdfs:comment 'The outcome of the objection process: whether the objection was upheld (application refused or modified), dismissed (application proceeds), settled (parties reached agreement), withdrawn by objector, or still pending.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Objection Resolution Date' ;
    rdfs:comment 'The date on which the objection was formally resolved through hearing, settlement, or withdrawal. Null if objection is still pending.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectorName rdf:type rdf:Property ;
    rdfs:label 'Objector Name' ;
    rdfs:comment 'The name of the individual, organization, or entity that lodged an objection to the application. Null if no objection received. May contain multiple objectors separated by semicolons if multiple objections exist.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The final disposition of the application after regulatory review and decision-making process.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDate rdf:type rdf:Property ;
    rdfs:label 'Priority Date' ;
    rdfs:comment 'The date from which the applicant\'s priority rights are calculated, which may differ from lodgement date in cases of renewals, conversions, or transfers. Critical for determining precedence over competing applications.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refusalReason rdf:type rdf:Property ;
    rdfs:label 'Refusal Reason' ;
    rdfs:comment 'A description of the reason(s) the regulatory authority refused the application, if applicable. Null if application was granted or is still pending.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boundaryId rdf:type rdf:Property ;
    rdfs:label 'Boundary Id' ;
    rdfs:comment 'Unique identifier for the tenement boundary record. Primary key for the tenement boundary data product.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Area Calculation Method' ;
    rdfs:comment 'Method used to calculate the tenement area. Planar for flat-earth approximation, geodesic for spherical earth, ellipsoidal for precise WGS84 calculations, or surveyed for official cadastral measurements.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSquareKilometers rdf:type rdf:Property ;
    rdfs:label 'Area Square Kilometers' ;
    rdfs:comment 'Total area of the tenement boundary in square kilometers. Alternative area measurement for reporting and analysis.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryStatus rdf:type rdf:Property ;
    rdfs:label 'Boundary Status' ;
    rdfs:comment 'Current lifecycle status of the boundary definition. Indicates whether the boundary is in draft, under regulatory review, officially approved, or has been superseded by a newer version.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateReferenceSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate Reference System' ;
    rdfs:comment 'The spatial reference system used for the boundary coordinates. Typically an EPSG code (e.g., EPSG:4326 for WGS84, EPSG:28350 for GDA94 MGA Zone 50). Critical for accurate spatial alignment and regulatory compliance.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalOverlayFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Overlay Flag' ;
    rdfs:comment 'Boolean flag indicating whether the tenement boundary intersects with environmental protection zones, national parks, or conservation areas. Impacts permitting and operational constraints.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geometryWkb rdf:type rdf:Property ;
    rdfs:label 'Geometry Wkb' ;
    rdfs:comment 'Spatial polygon geometry of the tenement boundary in Well-Known Binary format. Binary representation for efficient storage and processing in GIS systems.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryWkt rdf:type rdf:Property ;
    rdfs:label 'Geometry Wkt' ;
    rdfs:comment 'Spatial polygon geometry of the tenement boundary in Well-Known Text format. Represents the precise geographic coordinates defining the tenement perimeter. Used for GIS integration and spatial analysis.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gisLayerName rdf:type rdf:Property ;
    rdfs:label 'Gis Layer Name' ;
    rdfs:comment 'Name of the GIS layer or feature class where this boundary is stored in the corporate GIS system. Supports integration with spatial data platforms.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageAreaOverlapFlag rdf:type rdf:Property ;
    rdfs:label 'Heritage Area Overlap Flag' ;
    rdfs:comment 'Boolean flag indicating whether the tenement boundary intersects with registered heritage sites or protected cultural areas. Triggers heritage clearance requirements.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentBoundary rdf:type rdf:Property ;
    rdfs:label 'Is Current Boundary' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active boundary for the tenement. True for the latest approved version, false for historical versions.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mapSheetReference rdf:type rdf:Property ;
    rdfs:label 'Map Sheet Reference' ;
    rdfs:comment 'Reference to the topographic map sheet or cadastral map on which the tenement boundary is depicted. Used for regulatory submissions and field operations.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nativeTitleOverlapFlag rdf:type rdf:Property ;
    rdfs:label 'Native Title Overlap Flag' ;
    rdfs:comment 'Boolean flag indicating whether the tenement boundary intersects with registered native title claims or determinations. Used for heritage and consultation planning.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perimeterMeters rdf:type rdf:Property ;
    rdfs:label 'Perimeter Meters' ;
    rdfs:comment 'Total perimeter length of the tenement boundary in meters. Calculated from the polygon geometry. Used for boundary management and overlap analysis.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionalAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Positional Accuracy Meters' ;
    rdfs:comment 'Estimated positional accuracy of the boundary coordinates in meters. Represents the maximum expected deviation from true ground position. Critical for spatial analysis and overlap detection.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyDatum rdf:type rdf:Property ;
    rdfs:label 'Survey Datum' ;
    rdfs:comment 'The geodetic datum used for the boundary survey. Common values include GDA94 (Geocentric Datum of Australia 1994), GDA2020, WGS84. Ensures consistency with regulatory mapping standards.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyPlanReference rdf:type rdf:Property ;
    rdfs:label 'Survey Plan Reference' ;
    rdfs:comment 'Official reference number or identifier for the survey plan document lodged with the regulatory authority. Links to the formal cadastral record.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorLicenceNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor Licence Number' ;
    rdfs:comment 'Professional licence number of the surveyor who certified the boundary. Required for regulatory compliance and validation of survey accuracy.' ;
    rdfs:domain ind:Boundary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderId rdf:type rdf:Property ;
    rdfs:label 'Holder Id' ;
    rdfs:comment 'Unique identifier for the tenement holder record. Primary key for this association entity tracking ownership interests in tenements over time.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualReturnLodgementFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Return Lodgement Flag' ;
    rdfs:comment 'Indicates whether this ownership interest has been included in the most recent annual return lodged with the mining registrar. True if reported; False if not yet reported. Used to track compliance with annual reporting obligations.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialOwnerDisclosedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Disclosed Flag' ;
    rdfs:comment 'Indicates whether the ultimate beneficial owner of this interest has been disclosed to the mining registrar, as required by anti-money laundering and transparency regulations. True if disclosed; False if not yet disclosed or not required.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:considerationAmount rdf:type rdf:Property ;
    rdfs:label 'Consideration Amount' ;
    rdfs:comment 'Monetary consideration paid for this ownership interest transfer. Used for financial reporting, tax calculations, and asset valuation. Null if no consideration (e.g., initial grant, inheritance, or corporate restructure). Confidential commercial information.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:considerationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Consideration Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the consideration amount. Examples: AUD (Australian Dollar), USD (United States Dollar), CAD (Canadian Dollar). Null if no consideration amount.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Contributing Interest Flag' ;
    rdfs:comment 'Indicates whether this holder is contributing to ongoing expenditure commitments and operations. True if actively funding; False if carried or diluted. Used for cost allocation and expenditure commitment tracking.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dilutionTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Dilution Trigger Event' ;
    rdfs:comment 'Description of the event or milestone that triggered a dilution of this holders interest. Examples include failure to contribute to expenditure, decision not to participate in development, or automatic dilution clause in joint venture agreement. Null if no dilution has occurred.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeCarriedPercentage rdf:type rdf:Property ;
    rdfs:label 'Free Carried Percentage' ;
    rdfs:comment 'Percentage of this holders interest that is free-carried (not required to contribute to costs) through a specified stage or milestone. Common in farm-in agreements where one party funds exploration in exchange for equity. Null if not applicable.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeCarriedUntilDate rdf:type rdf:Property ;
    rdfs:label 'Free Carried Until Date' ;
    rdfs:comment 'Date until which the free-carried interest applies. After this date, the holder must contribute pro-rata to costs or face dilution. Null if free-carried arrangement is perpetual or not applicable.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jointVentureAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Agreement Reference' ;
    rdfs:comment 'Reference to the joint venture agreement document that governs this ownership interest and the relationship between multiple holders. Used to link to contract management systems and legal repositories.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Notification Acknowledgement Date' ;
    rdfs:comment 'Date on which the mining registrar acknowledged receipt and acceptance of the ownership change notification. Used to confirm regulatory compliance and avoid penalties for late notification.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationLodgedDate rdf:type rdf:Property ;
    rdfs:label 'Notification Lodged Date' ;
    rdfs:comment 'Date on which notification of this ownership change was lodged with the mining registrar or regulatory authority. Required for compliance with mining legislation that mandates timely notification of ownership transfers.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorFlag rdf:type rdf:Property ;
    rdfs:label 'Operator Flag' ;
    rdfs:comment 'Indicates whether this holder is the designated operator of the tenement. True if this party manages day-to-day operations and regulatory compliance; False if non-operator (passive investor). Only one holder per tenement should be operator at any given time.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current status of this ownership interest with the mining registrar. Registered indicates formal acceptance; Pending indicates lodged but not yet approved; Lodged indicates submitted for processing; Rejected indicates application denied; Cancelled indicates ownership revoked; Transferred indicates interest moved to another party.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Royalty Obligation Flag' ;
    rdfs:comment 'Indicates whether this holder has a royalty obligation attached to their interest. True if holder must pay royalties on production; False if no royalty applies. Used for revenue forecasting and financial modeling.' ;
    rdfs:domain ind:Tenement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:royaltyRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percentage' ;
    rdfs:comment 'Percentage rate of royalty payable on production or revenue from this tenement interest. Expressed as a decimal (e.g., 2.50 for 2.5%). Null if no royalty applies. Confidential commercial term.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stampDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Stamp Duty Amount' ;
    rdfs:comment 'Amount of stamp duty or transfer tax paid on this ownership transfer. Used for financial reporting and tax reconciliation. Null if no stamp duty applies or not yet paid.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stampDutyPaidFlag rdf:type rdf:Property ;
    rdfs:label 'Stamp Duty Paid Flag' ;
    rdfs:comment 'Indicates whether stamp duty or transfer tax has been paid on this ownership transfer. True if paid; False if not yet paid or not applicable. Required for registration in many jurisdictions.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Reference to the source transaction document or system record that created this ownership change. May be a contract number, transfer deed reference, or internal transaction identifier. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDeedReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Deed Reference' ;
    rdfs:comment 'Reference number of the transfer deed or instrument that legally transferred this ownership interest. Required for mining registrar lodgement and audit trail. Null if this is an initial grant rather than a transfer.' ;
    rdfs:domain ind:Holder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique identifier for the tenement royalty payment transaction record. Primary key for this entity.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Actual date on which the royalty payment was remitted to the payee. Null if payment has not yet been made.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Total adjustments applied to the calculated royalty amount, including credits, deductions, prior period corrections, or dispute resolutions. Positive values increase the payment; negative values reduce it.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Royalty Amount' ;
    rdfs:comment 'Gross royalty amount calculated by applying the royalty rate to the production value or tonnage, before any adjustments or deductions.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityGradePercent rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade Percent' ;
    rdfs:comment 'Average grade or quality of the commodity produced during the period, expressed as a percentage (e.g., iron ore Fe content, copper Cu content). Used for royalty rate determination where applicable.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Finance Gl Account Code' ;
    rdfs:comment 'General ledger account code in the finance system to which this royalty payment liability is posted for reconciliation with the finance domain.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Amount' ;
    rdfs:comment 'Final net royalty amount payable after applying all adjustments to the calculated royalty amount. This is the amount remitted to the payee.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payeeAccountReference rdf:type rdf:Property ;
    rdfs:label 'Payee Account Reference' ;
    rdfs:comment 'Reference to the payee\'s bank account or payment destination to which the royalty payment is remitted. May be an account number, payment reference, or identifier in the finance system.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Production Period End Date' ;
    rdfs:comment 'End date of the production period for which this royalty payment is calculated. Defines the conclusion of the reporting period covered by this payment.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Production Period Start Date' ;
    rdfs:comment 'Start date of the production period for which this royalty payment is calculated. Defines the beginning of the reporting period covered by this payment.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionTonnage rdf:type rdf:Property ;
    rdfs:label 'Production Tonnage' ;
    rdfs:comment 'Total tonnage of mineral commodity produced or sold during the production period that is subject to royalty calculation, measured in metric tonnes.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionValueAmount rdf:type rdf:Property ;
    rdfs:label 'Production Value Amount' ;
    rdfs:comment 'Total value of production during the period used as the basis for royalty calculation. For revenue-based royalties, this is the sales revenue; for profit-based, this is the net profit.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReturnReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Return Reference' ;
    rdfs:comment 'Reference number of the regulatory royalty return or report submitted to government authorities (e.g., Mining Rehabilitation Fund return, state royalty return) that includes this payment.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the tenement transfer transaction. Primary key for the tenement transfer record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTransfereePartyCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Transferee Party Counterparty Id' ;
    rdfs:comment 'Reference to the party receiving or acquiring interest in the tenement. The buyer or assignee in the transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:transferCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Transfer Counterparty Id' ;
    rdfs:comment 'Reference to the party transferring or assigning their interest in the tenement. The seller or assignor in the transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Counterparty .

ind:transferorHolderId rdf:type rdf:Property ;
    rdfs:label 'Transferor Holder Id' ;
    rdfs:comment 'Foreign key linking to tenement.tenement_holder. Business justification: Transfer records currently store transferor_legal_name as a string. This should normalize to reference the actual tenement_holder record representing the transferor\'s ownership position at the time of' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Holder .

ind:contingentPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Payment Flag' ;
    rdfs:comment 'Indicates whether the transfer agreement includes contingent or deferred payments tied to future events such as production milestones, resource upgrades, or commodity price thresholds.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dueDiligenceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Due Diligence Completion Date' ;
    rdfs:comment 'The date on which the transferee completed due diligence on the tenement. Marks the end of the investigation period and typically precedes the transfer execution date.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Approval Flag' ;
    rdfs:comment 'Indicates whether environmental approvals or notifications were required for the transfer. May be required when the transfer involves change of operator or modification of environmental management plans.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenditureCommitmentTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Expenditure Commitment Transferred Flag' ;
    rdfs:comment 'Indicates whether outstanding expenditure commitments on the tenement were transferred to the transferee. Relevant for exploration licences with minimum annual expenditure obligations.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestPercentageTransferred rdf:type rdf:Property ;
    rdfs:label 'Interest Percentage Transferred' ;
    rdfs:comment 'The percentage of ownership interest in the tenement being transferred. For full assignments this is 100.00; for partial assignments this reflects the fractional interest transferred.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nativeTitleConsentDate rdf:type rdf:Property ;
    rdfs:label 'Native Title Consent Date' ;
    rdfs:comment 'The date on which native title holder consent was formally obtained or the notification period expired. Required for compliance with indigenous land rights legislation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nativeTitleConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Native Title Consent Flag' ;
    rdfs:comment 'Indicates whether native title holder consent or notification was required and obtained for the transfer. Relevant in jurisdictions with indigenous land rights frameworks such as Australia and Canada.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityBondTransferredFlag rdf:type rdf:Property ;
    rdfs:label 'Security Bond Transferred Flag' ;
    rdfs:comment 'Indicates whether environmental or rehabilitation security bonds were transferred to the transferee or whether new bonds were required. Critical for mining leases with rehabilitation obligations.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transfereeLegalName rdf:type rdf:Property ;
    rdfs:label 'Transferee Legal Name' ;
    rdfs:comment 'The full legal name of the transferee party as registered with the regulatory authority. Captured for regulatory notification and audit trail purposes.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferorRetainedInterestPercentage rdf:type rdf:Property ;
    rdfs:label 'Transferor Retained Interest Percentage' ;
    rdfs:comment 'The percentage of ownership interest retained by the transferor after the transfer. For full assignments this is 0.00; for partial assignments this reflects the remaining interest.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competencyId rdf:type rdf:Property ;
    rdfs:label 'Competency Id' ;
    rdfs:comment 'Unique identifier for the competency record. Serves as the primary key for both framework-level competency definitions and individual worker attainment records.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Competency .

ind:competencyAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Competency Assessor Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee or contractor who conducted the competency assessment. Null for third-party certifications or framework definitions.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:competencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Competency Employee Id' ;
    rdfs:comment 'Foreign key reference to the individual employee or contractor who holds this competency attainment. Null for framework-level competency definitions that are not yet attained by any worker.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRole rdf:type rdf:Property ;
    rdfs:label 'Applicable Role' ;
    rdfs:comment 'The job role, position, or position family to which this competency applies (e.g., Haul Truck Operator, Shotfirer, Surface Supervisor, Mill Operator). May be a comma-separated list for competencies applicable to multiple roles.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The method by which the worker was assessed for this competency: written_exam, practical_assessment, on_job_observation, simulation, portfolio (evidence-based), interview, third_party_certification (external body). [ENUM-REF-CANDIDATE: written_exam|practical_assessment|on_job_observation|simulation|portfolio|interview|third_party_certification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attainmentDate rdf:type rdf:Property ;
    rdfs:label 'Attainment Date' ;
    rdfs:comment 'The date on which the worker successfully attained or was awarded this competency. Null for framework-level definitions.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attainmentStatus rdf:type rdf:Property ;
    rdfs:label 'Attainment Status' ;
    rdfs:comment 'Current lifecycle status of the competency attainment: current (valid and in-date), expiring_soon (within alert threshold), expired (past expiry_date), suspended (temporarily invalid), revoked (permanently withdrawn), pending_renewal (renewal in progress).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCategory rdf:type rdf:Property ;
    rdfs:label 'Competency Category' ;
    rdfs:comment 'Hierarchical grouping or discipline area for the competency (e.g., Mining Operations, Processing, Maintenance, HSE, Geology, Engineering). Supports competency framework navigation and gap analysis reporting.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCode rdf:type rdf:Property ;
    rdfs:label 'Competency Code' ;
    rdfs:comment 'Unique business identifier for the competency. Used for external reference and integration with training systems, MSHA reporting, and SAP HR competency catalogs.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyName rdf:type rdf:Property ;
    rdfs:label 'Competency Name' ;
    rdfs:comment 'Full descriptive name of the competency (e.g., Shotfirer Certificate, Surface Supervisor Examination, Haul Truck Operation Level 3, First Aid CPR).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyType rdf:type rdf:Property ;
    rdfs:label 'Competency Type' ;
    rdfs:comment 'Classification of the competency by purpose: statutory (legally mandated certificates), operational (production skills), safety (HSE training), technical (specialized equipment or process), leadership (supervisory), environmental (environmental management).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerAttainment rdf:type rdf:Property ;
    rdfs:label 'Cost Per Attainment' ;
    rdfs:comment 'The total cost incurred to attain this competency, including training fees, assessor costs, travel, and lost production time. Used for training budget planning and OPEX allocation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference to the supporting evidence or documentation for this competency attainment (e.g., file path, document management system ID, training record reference). Supports audit and compliance verification.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryAlertDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Days' ;
    rdfs:comment 'The number of days before expiry_date at which an alert should be triggered to initiate renewal. Supports proactive competency management and compliance risk mitigation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority, industry body, or certification organization that defines or mandates this competency (e.g., MSHA, State Mining Inspectorate, ICMM, internal company standard). Critical for statutory competency tracking.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The organization or authority that issued the certificate or credential (e.g., State Mining Inspectorate, MSHA, Registered Training Organization, internal company training department).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this competency is mandatory for the applicable role (True) or optional/recommended (False). Mandatory competencies trigger compliance alerts if not held.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prerequisiteCompetencies rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Competencies' ;
    rdfs:comment 'Comma-separated list of competency codes or IDs that must be held before this competency can be attained. Supports competency pathway modeling and training sequencing.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalMethod rdf:type rdf:Property ;
    rdfs:label 'Renewal Method' ;
    rdfs:comment 'The method by which the competency is renewed: reassessment (full practical reassessment), refresher_training (attend training course), continuing_education (accumulate CPD points), reexamination (written or practical exam), automatic (no action required).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether the competency must be renewed or reassessed upon expiry (True) or is a one-time attainment (False).' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Required Proficiency Level' ;
    rdfs:comment 'The minimum proficiency or mastery level required for the competency: awareness (general understanding), basic (can perform with supervision), intermediate (can perform independently), advanced (can train others), expert (subject matter expert).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Site Specific Flag' ;
    rdfs:comment 'Indicates whether this competency is specific to a particular mine site (True) or is portable across all company sites (False). Site-specific competencies require retraining on site transfer.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'The total number of training hours completed to attain this competency. Used for MSHA annual training hour reporting and training cost allocation.' ;
    rdfs:domain ind:Competency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'The name of the training organization, Registered Training Organization (RTO), or internal training department that delivered the training leading to this competency attainment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Foreign key linking to workforce.roster. Business justification: contractor.roster_pattern is currently a STRING (denormalized). Should be normalized to contractor.roster_id → roster.roster_id. Contractors follow defined roster patterns just like employees. Adding ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:contractorNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor Number' ;
    rdfs:comment 'Business identifier assigned to the contractor for external reference and integration with procurement and payroll systems. Typically assigned by SAP HR or contractor management system.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorStatus rdf:type rdf:Property ;
    rdfs:label 'Contractor Status' ;
    rdfs:comment 'Current lifecycle status of the contractor record. Active contractors are available for roster assignment. Suspended contractors cannot access sites pending investigation. Terminated or completed contractors have ended their engagement.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the contractor\'s nominated emergency contact person. Used for critical incident notification and medical emergency coordination.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the contractor\'s nominated emergency contact person. Must be verified and kept current for critical incident response.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact person to the contractor. Used to determine notification priority and next-of-kin status in critical incidents. [ENUM-REF-CANDIDATE: spouse|partner|parent|sibling|child|friend|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'Planned or actual end date of the contractor\'s engagement. Null for ongoing engagements. Populated for fixed-term contracts or upon termination.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'Date on which the contractor\'s engagement commenced. Used for tenure calculation, anniversary tracking, and long-service leave accrual where applicable.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the contractor engagement model. Labour-hire for general workforce augmentation, specialist for technical expertise, EPCM for engineering/construction, shutdown for planned maintenance campaigns, and trade-specific categories for mining operations. [ENUM-REF-CANDIDATE: labour_hire|specialist|epcm|shutdown|maintenance|drilling|processing|haulage|exploration — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The surname or family name of the contractor as recorded on official identification documents. Required for site access and emergency contact purposes.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The first or given name of the contractor as recorded on official identification documents. Required for site access and emergency contact purposes.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionStatus rdf:type rdf:Property ;
    rdfs:label 'Induction Status' ;
    rdfs:comment 'Status of the contractor\'s site-specific safety induction training. Completed status is mandatory before first site entry. Inductions expire annually and require refresher training.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Status' ;
    rdfs:comment 'Status of the contractor\'s required insurance coverage including public liability, professional indemnity, and workers compensation. Current status is mandatory for site access. Managed by procurement and risk teams.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEngagementDurationDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Engagement Duration Days' ;
    rdfs:comment 'Maximum allowable duration in days for this contractor engagement as specified in the master services agreement or labour-hire contract. Used to prevent inadvertent permanent employment obligations.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Medical Assessment Date' ;
    rdfs:comment 'Date of the contractor\'s most recent pre-employment or periodic medical assessment. Medical assessments are required every 1-3 years depending on role and age.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Expiry Date' ;
    rdfs:comment 'Date on which the current medical fitness certification expires. Contractors must complete reassessment before this date to maintain site access.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalFitnessStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Status' ;
    rdfs:comment 'Current medical fitness status for mine site work. Fit status is required for operational roles. Fit-with-restrictions status requires documented work limitations. Assessment results are managed by occupational health provider.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Flag' ;
    rdfs:comment 'Indicates whether the contractor is eligible for future re-engagement. False for contractors terminated for safety violations, performance issues, or policy breaches. Used in contractor selection and onboarding processes.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteAccessClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Site Access Clearance Date' ;
    rdfs:comment 'Date on which site access clearance was granted. Used to calculate clearance age and trigger periodic re-verification.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAccessClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Site Access Clearance Status' ;
    rdfs:comment 'Current status of the contractor\'s site access clearance. Approved status is required for physical entry to mine sites. Suspended or revoked status triggers immediate access card deactivation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Site Access Expiry Date' ;
    rdfs:comment 'Date on which site access clearance expires. Contractors must complete re-induction and medical assessment before this date to maintain site access.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statutoryRoleAuthorisation rdf:type rdf:Property ;
    rdfs:label 'Statutory Role Authorisation' ;
    rdfs:comment 'Statutory mining role that the contractor is authorised to perform under mining safety legislation. Most contractors have \'none\' as statutory roles typically require direct employment. Specific authorisation and appointment documentation required for non-none values. [ENUM-REF-CANDIDATE: none|site_senior_executive|mine_manager|deputy|supervisor|competent_person|shotfirer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFileNumber rdf:type rdf:Property ;
    rdfs:label 'Tax File Number' ;
    rdfs:comment 'Tax file number for payroll tax withholding and reporting. Encrypted at rest and access-controlled per Australian Taxation Office requirements.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeClassification rdf:type rdf:Property ;
    rdfs:label 'Trade Classification' ;
    rdfs:comment 'Primary trade or skill classification for the contractor (e.g., Electrician, Fitter, Boilermaker, Geologist, Surveyor, Heavy Equipment Operator, Process Technician). Used for competency matching and roster planning. [ENUM-REF-CANDIDATE: electrician|fitter|boilermaker|geologist|surveyor|operator|technician|engineer|rigger|welder — promote to reference product]' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Classification of the contractor\'s work location arrangement. FIFO (Fly-In Fly-Out) and DIDO (Drive-In Drive-Out) require accommodation and travel logistics. Residential contractors live in nearby towns. Remote contractors work at isolated sites.' ;
    rdfs:domain ind:Contractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Reference to the organizational department or operational unit to which this crew belongs. Used for cost allocation and reporting hierarchy.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Primary radio channel, frequency, or communication system identifier used by this crew for operational coordination and emergency response.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Unique business identifier code for the crew, used in operational systems and shift reporting. Typically alphanumeric format assigned by site management.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name of the crew, typically reflecting shift pattern, operational area, or supervisor name (e.g., \'Alpha Day Shift\', \'Bravo Night Crew\', \'Processing Team 3\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current operational status of the crew. Active crews are available for shift scheduling; inactive/disbanded crews are historical records.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of crew by primary operational function. Determines skill requirements, equipment assignments, and production reporting categories.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyMusterPoint rdf:type rdf:Property ;
    rdfs:label 'Emergency Muster Point' ;
    rdfs:comment 'Designated emergency assembly location for this crew in case of evacuation or emergency. Critical for emergency response and headcount verification.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFleetAssignment rdf:type rdf:Property ;
    rdfs:label 'Equipment Fleet Assignment' ;
    rdfs:comment 'Description of primary equipment or fleet assigned to this crew (e.g., \'Haul Trucks 101-110\', \'Excavator EX-05\', \'Processing Train 2\'). Used for equipment utilization and maintenance coordination.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskRating rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Rating' ;
    rdfs:comment 'Assessed fatigue risk level for this crew\'s roster pattern and shift configuration. Used for ISO 45001 compliance and fatigue management planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumConsecutiveShifts rdf:type rdf:Property ;
    rdfs:label 'Maximum Consecutive Shifts' ;
    rdfs:comment 'Maximum number of consecutive shifts allowed for crew members under this crew\'s roster pattern. Enforced for fatigue management and regulatory compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRestHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Rest Hours' ;
    rdfs:comment 'Minimum rest period in hours required between shifts for crew members. Enforced for fatigue management and regulatory compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominalHeadcount rdf:type rdf:Property ;
    rdfs:label 'Nominal Headcount' ;
    rdfs:comment 'Standard or planned number of workers assigned to this crew when fully staffed. Used for roster planning and manning variance analysis.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalArea rdf:type rdf:Property ;
    rdfs:label 'Operational Area' ;
    rdfs:comment 'Primary operational area or zone where this crew works (e.g., \'Pit 3 East\', \'Processing Plant A\', \'Underground Level 5\'). Used for location-based safety and production reporting.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preStartMeetingLocation rdf:type rdf:Property ;
    rdfs:label 'Pre Start Meeting Location' ;
    rdfs:comment 'Designated location for crew pre-start safety meetings and toolbox talks. Critical for safety communication and attendance tracking.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTargetPerShift rdf:type rdf:Property ;
    rdfs:label 'Production Target Per Shift' ;
    rdfs:comment 'Standard production target for this crew per shift, measured in the unit specified in production_target_unit. Used for performance tracking and incentive calculations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionTargetUnit rdf:type rdf:Property ;
    rdfs:label 'Production Target Unit' ;
    rdfs:comment 'Unit of measure for this crew\'s production targets (e.g., tonnes for haulage crews, BCM for mining crews, hours for maintenance crews).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Standard duration of a single shift for this crew in hours. Used for fatigue management and labor cost calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift timing pattern for this crew. Determines start/end times and handover protocols.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Standard start time for this crew\'s shift in HH:mm format (24-hour clock). Used for pre-start meeting scheduling and attendance tracking.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Employee date of birth. Used for age verification for hazardous work assignments, retirement planning, and demographic reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employment relationship. Active employees are eligible for rostering and payroll.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment arrangement. Determines entitlements, rostering rules, and payroll processing.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fte rdf:type rdf:Property ;
    rdfs:label 'Fte' ;
    rdfs:comment 'Full-time equivalent value representing the proportion of full-time hours worked. 1.0000 = full-time, 0.5000 = half-time. Used for headcount reporting and labor cost allocation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the employee commenced employment with the organization. Used for seniority calculations, leave accruals, and service awards.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Induction Completed Date' ;
    rdfs:comment 'Date the employee completed mandatory site safety induction training. Required before site access is granted.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Induction Expiry Date' ;
    rdfs:comment 'Date when the site induction certification expires and refresher training is required.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized code representing the job classification. Used for competency mapping, training requirements, and workforce planning.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFitnessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Expiry Date' ;
    rdfs:comment 'Date when the current medical fitness certification expires. Triggers re-examination requirements for continued mine site access.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationalIdNumber rdf:type rdf:Property ;
    rdfs:label 'National Id Number' ;
    rdfs:comment 'Government-issued national identification number (e.g., Social Security Number, Tax File Number, National Insurance Number). Used for tax reporting and legal compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Salary grade or pay band assigned to the employee. Determines compensation range and eligibility for benefits.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizeBoots rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Boots' ;
    rdfs:comment 'Boot size for safety footwear issuance. Used for procurement and inventory management of safety boots.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizeHardhat rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Hardhat' ;
    rdfs:comment 'Hard hat size for head protection issuance. Used for procurement and inventory management of safety helmets.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizePants rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Pants' ;
    rdfs:comment 'Pants size for PPE uniform issuance. Used for procurement and inventory management of safety clothing.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizeShirt rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Shirt' ;
    rdfs:comment 'Shirt size for PPE uniform issuance. Used for procurement and inventory management of safety clothing. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|XXXL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in workplace communications and systems. May differ from legal name.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPersonnelNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Personnel Number' ;
    rdfs:comment 'Eight-digit personnel number assigned in SAP S/4HANA HR module. Used for payroll integration, time management, and organizational assignment.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAssignment rdf:type rdf:Property ;
    rdfs:label 'Site Assignment' ;
    rdfs:comment 'Primary mine site or operational location where the employee is assigned. Used for site access control, roster planning, and HSE compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembership rdf:type rdf:Property ;
    rdfs:label 'Union Membership' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. Used for collective bargaining agreement application and dues deduction.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Name of the labor union to which the employee belongs, if applicable. Null for non-union employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workSchedulePattern rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Pattern' ;
    rdfs:comment 'Standard roster pattern for the employee (e.g., 4-on-3-off, 7-on-7-off, day shift, night shift). Used for fatigue management and roster generation.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentAgreementId rdf:type rdf:Property ;
    rdfs:label 'Employment Agreement Id' ;
    rdfs:comment 'Primary key for employment_agreement' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededAgreementEmploymentAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded Agreement Employment Agreement Id' ;
    rdfs:comment 'Identifier of the previous employment agreement that this agreement replaces, establishing agreement lineage and succession.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmploymentAgreement .

ind:annualLeaveEntitlementWeeks rdf:type rdf:Property ;
    rdfs:label 'Annual Leave Entitlement Weeks' ;
    rdfs:comment 'Number of weeks of annual leave accrued per year under this agreement. May exceed statutory minimum for certain rosters or classifications.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballotApprovalPercentage rdf:type rdf:Property ;
    rdfs:label 'Ballot Approval Percentage' ;
    rdfs:comment 'Percentage of employees who voted in favor of the agreement during the ballot process.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ballotDate rdf:type rdf:Property ;
    rdfs:label 'Ballot Date' ;
    rdfs:comment 'Date on which employees voted to approve the agreement, if a ballot was conducted as part of the approval process.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:basePayRate rdf:type rdf:Property ;
    rdfs:label 'Base Pay Rate' ;
    rdfs:comment 'Standard base hourly or annual pay rate specified in the agreement for the covered classification. Excludes allowances and overtime.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionProcess rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Process' ;
    rdfs:comment 'Description of the formal process for resolving disputes between employer and employees under this agreement, including escalation steps and arbitration provisions.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerParty rdf:type rdf:Property ;
    rdfs:label 'Employer Party' ;
    rdfs:comment 'Legal name of the employer entity that is a party to the agreement. May be the parent company or a specific subsidiary operating the mine site.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Nominal Expiry Date' ;
    rdfs:comment 'Scheduled expiry date as stated in the agreement document, which may differ from actual cessation date if the agreement continues to apply post-expiry pending replacement.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodWeeks rdf:type rdf:Property ;
    rdfs:label 'Notice Period Weeks' ;
    rdfs:comment 'Required notice period in weeks for termination of employment by either party, as specified in the agreement.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base pay rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time).' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateUnit rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Unit' ;
    rdfs:comment 'Unit of measure for the base pay rate (hourly, daily, annual, or per shift).' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyEntitlementWeeks rdf:type rdf:Property ;
    rdfs:label 'Redundancy Entitlement Weeks' ;
    rdfs:comment 'Number of weeks of redundancy pay per year of service as specified in the agreement, which may exceed statutory minimums.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryLodgementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lodgement Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory authority (e.g., Fair Work Commission) upon lodgement or approval of the agreement.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Allowance Amount' ;
    rdfs:comment 'Fixed allowance amount payable per shift for shift work, night work, or roster-specific conditions as specified in the agreement.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Ordinary hours of work per week as defined in the agreement, before overtime provisions apply.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionParty rdf:type rdf:Property ;
    rdfs:label 'Union Party' ;
    rdfs:comment 'Name of the trade union or employee representative body that is a party to the agreement. Null for individual non-union agreements.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceClassification rdf:type rdf:Property ;
    rdfs:label 'Workforce Classification' ;
    rdfs:comment 'Category of workforce covered by this agreement, such as production operators, maintenance technicians, administrative staff, or contractors. Determines applicability of terms.' ;
    rdfs:domain ind:EmploymentAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRecordId rdf:type rdf:Property ;
    rdfs:label 'Fatigue Record Id' ;
    rdfs:comment 'Primary key for fatigue_record' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFatigueEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fatigue Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor being assessed for fatigue risk.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDatetime rdf:type rdf:Property ;
    rdfs:label 'Assessment Datetime' ;
    rdfs:comment 'Date and time when the fatigue risk assessment was conducted.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentLocation rdf:type rdf:Property ;
    rdfs:label 'Assessment Location' ;
    rdfs:comment 'Physical location where the fatigue assessment was conducted (e.g., mine gate, pre-start area, occupational health clinic, control room).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Assessment Trigger' ;
    rdfs:comment 'Event or condition that triggered the fatigue assessment: Scheduled Pre-Start, Random Check, Supervisor Concern, Self-Report, Post-Incident, or Extended Hours Threshold.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consecutiveDaysOnSite rdf:type rdf:Property ;
    rdfs:label 'Consecutive Days On Site' ;
    rdfs:comment 'Number of consecutive days the worker has been on-site without a rest day, used to assess cumulative fatigue risk.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Cumulative Hours Worked' ;
    rdfs:comment 'Total number of hours worked by the individual over the assessment period (typically 7, 14, or 28 days) leading up to the assessment.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Exemption Approved By' ;
    rdfs:comment 'Identifier of the manager or authority who approved the fatigue policy exemption.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Level' ;
    rdfs:comment 'Categorical classification of fatigue risk level based on the risk score: Low, Moderate, High, or Severe.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Score' ;
    rdfs:comment 'Quantitative fatigue risk score calculated by the assessment method, typically on a scale (e.g., 0-100) where higher values indicate greater fatigue risk.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpDueDatetime rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Datetime' ;
    rdfs:comment 'Scheduled date and time for the required follow-up assessment or medical review.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up fatigue assessment or medical review is required based on this assessment outcome.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousAssessmentDatetime rdf:type rdf:Property ;
    rdfs:label 'Previous Assessment Datetime' ;
    rdfs:comment 'Date and time of the most recent prior fatigue assessment for this worker, used to track assessment frequency and trend analysis.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousFatigueRiskScore rdf:type rdf:Property ;
    rdfs:label 'Previous Fatigue Risk Score' ;
    rdfs:comment 'Fatigue risk score from the most recent prior assessment, enabling trend comparison.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sleepOpportunityHours rdf:type rdf:Property ;
    rdfs:label 'Sleep Opportunity Hours' ;
    rdfs:comment 'Estimated or reported hours of sleep opportunity available to the worker in the 24-hour period prior to assessment.' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeOfDayCategory rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Category' ;
    rdfs:comment 'Classification of the time of day when the assessment occurred, relevant for circadian rhythm considerations (Day Shift, Night Shift, Swing Shift, Circadian Low Point).' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workRestrictionDescription rdf:type rdf:Property ;
    rdfs:label 'Work Restriction Description' ;
    rdfs:comment 'Description of any work restrictions or limitations imposed as a result of the fatigue assessment (e.g., no heavy equipment operation, reduced shift length, mandatory rest break).' ;
    rdfs:domain ind:FatigueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labourCaseId rdf:type rdf:Property ;
    rdfs:label 'Labour Case Id' ;
    rdfs:comment 'Unique identifier for the labour case record. Primary key.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLabourSubjectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Labour Subject Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of the labour case (e.g., the employee facing disciplinary action or lodging a grievance).' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLabourEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Labour Employee Id' ;
    rdfs:comment 'Identifier of the Human Resources (HR) Business Partner assigned to manage and oversee the labour case.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLabourInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Labour Investigator Employee Id' ;
    rdfs:comment 'Identifier of the employee or Human Resources (HR) professional assigned to conduct the investigation.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealLodgementDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Lodgement Date' ;
    rdfs:comment 'Date when an appeal against the labour case decision was formally lodged.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Final outcome of the appeal process, indicating whether the original decision was upheld, overturned, or modified.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any appeal lodged against the original decision or outcome of the labour case.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Specific sub-classification of the case type. For disciplinary cases: verbal warning, written warning, Performance Improvement Plan (PIP), suspension, termination. For grievances: pay dispute, discrimination, bullying, harassment, Enterprise Bargaining Agreement (EBA) interpretation, working conditions. [ENUM-REF-CANDIDATE: verbal_warning|written_warning|pip|suspension|termination|pay_dispute|discrimination|bullying|harassment|eba_interpretation|working_conditions|safety_breach|policy_violation|other — promote to reference product]' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'General notes and observations recorded throughout the lifecycle of the labour case for internal reference and documentation.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-known unique case reference number assigned to the labour case for tracking and documentation purposes.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the labour case indicating its progression through the resolution workflow.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the labour case indicating the nature of the workforce relations matter being managed.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationHistory rdf:type rdf:Property ;
    rdfs:label 'Escalation History' ;
    rdfs:comment 'Chronological record of escalation events, including dates, escalation reasons, and parties involved at each level.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairWorkNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Fair Work Notification Date' ;
    rdfs:comment 'Date when the labour case was formally notified to Fair Work Australia or Fair Work Commission.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairWorkNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Work Notification Flag' ;
    rdfs:comment 'Indicates whether the case has been notified to Fair Work Australia or Fair Work Commission as required by legislation.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the incident, issue, or circumstances that led to the labour case being opened.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Representation Flag' ;
    rdfs:comment 'Indicates whether either party has engaged legal representation or legal counsel in the labour case proceedings.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyBreachReference rdf:type rdf:Property ;
    rdfs:label 'Policy Breach Reference' ;
    rdfs:comment 'Reference code or identifier of the company policy, Standard Operating Procedure (SOP), or regulation that was breached, if applicable.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the labour case was formally resolved and a final outcome was determined.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionInvolvementFlag rdf:type rdf:Property ;
    rdfs:label 'Union Involvement Flag' ;
    rdfs:comment 'Indicates whether a union representative or union official is involved in the labour case proceedings.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the union representative or official involved in the case, if applicable.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessEmployeeIds rdf:type rdf:Property ;
    rdfs:label 'Witness Employee Ids' ;
    rdfs:comment 'Comma-separated list of employee identifiers for witnesses involved in or providing testimony for the labour case.' ;
    rdfs:domain ind:LabourCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalFitnessId rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Id' ;
    rdfs:comment 'Unique identifier for the occupational health and medical fitness assessment record.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMedicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Medical Employee Id' ;
    rdfs:comment 'Identifier of the mine worker or contractor undergoing the medical fitness assessment.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentTime rdf:type rdf:Property ;
    rdfs:label 'Assessment Time' ;
    rdfs:comment 'Precise date and time when the medical fitness assessment was performed.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:audiogramBaselineEstablished rdf:type rdf:Property ;
    rdfs:label 'Audiogram Baseline Established' ;
    rdfs:comment 'Indicates whether this assessment established a baseline audiogram for future noise-induced hearing loss comparisons.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biologicalMarkersTested rdf:type rdf:Property ;
    rdfs:label 'Biological Markers Tested' ;
    rdfs:comment 'List of biological markers or substances tested during biological monitoring (e.g., blood lead level, urinary arsenic, silica exposure markers).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biologicalMonitoringConducted rdf:type rdf:Property ;
    rdfs:label 'Biological Monitoring Conducted' ;
    rdfs:comment 'Indicates whether biological monitoring for occupational exposure to hazardous substances (e.g., heavy metals, silica) was conducted.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biologicalMonitoringResult rdf:type rdf:Property ;
    rdfs:label 'Biological Monitoring Result' ;
    rdfs:comment 'Result of biological monitoring for occupational exposure (within limits, elevated, action level exceeded, or medical removal required).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugAlcoholTestConducted rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Conducted' ;
    rdfs:comment 'Indicates whether a drug and alcohol screening test was conducted as part of this assessment.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugAlcoholTestDatetime rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Datetime' ;
    rdfs:comment 'Date and time when the drug and alcohol screening test sample was collected.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drugAlcoholTestMethod rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Method' ;
    rdfs:comment 'Method used for drug and alcohol testing (urine, breath, saliva, blood, or hair follicle analysis).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugAlcoholTestResult rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Result' ;
    rdfs:comment 'Result of the drug and alcohol screening test (negative, positive, inconclusive, refused, or not tested).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitnessOutcome rdf:type rdf:Property ;
    rdfs:label 'Fitness Outcome' ;
    rdfs:comment 'Overall medical fitness determination outcome (fit, fit with restrictions, temporarily unfit, permanently unfit, or pending review).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitnessOutcomeDate rdf:type rdf:Property ;
    rdfs:label 'Fitness Outcome Date' ;
    rdfs:comment 'Date on which the fitness outcome determination was finalized and communicated.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceCertificateIssued rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Certificate Issued' ;
    rdfs:comment 'Indicates whether a formal medical clearance certificate was issued to the worker following the assessment.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nihlMonitoringConducted rdf:type rdf:Property ;
    rdfs:label 'Nihl Monitoring Conducted' ;
    rdfs:comment 'Indicates whether noise-induced hearing loss audiometric monitoring was conducted as part of this assessment.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nihlMonitoringResult rdf:type rdf:Property ;
    rdfs:label 'Nihl Monitoring Result' ;
    rdfs:comment 'Result of the noise-induced hearing loss audiometric monitoring (normal, threshold shift detected, significant hearing loss, or follow-up required).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respiratoryFunctionResult rdf:type rdf:Property ;
    rdfs:label 'Respiratory Function Result' ;
    rdfs:comment 'Result of respiratory function testing (normal, mild impairment, moderate impairment, severe impairment, or follow-up required).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respiratoryFunctionTestConducted rdf:type rdf:Property ;
    rdfs:label 'Respiratory Function Test Conducted' ;
    rdfs:comment 'Indicates whether respiratory function testing (spirometry) was conducted to assess lung capacity and detect occupational lung disease.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictedTasks rdf:type rdf:Property ;
    rdfs:label 'Restricted Tasks' ;
    rdfs:comment 'Specific mining tasks or activities that the worker is restricted from performing based on the medical assessment.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCategory rdf:type rdf:Property ;
    rdfs:label 'Restriction Category' ;
    rdfs:comment 'Category of work restriction imposed if the worker is deemed fit with restrictions (physical limitation, environmental restriction, task restriction, equipment restriction, or none).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionDetails rdf:type rdf:Property ;
    rdfs:label 'Restriction Details' ;
    rdfs:comment 'Detailed description of specific work restrictions, limitations, or accommodations required for the worker to perform duties safely.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substancesDetected rdf:type rdf:Property ;
    rdfs:label 'Substances Detected' ;
    rdfs:comment 'List of substances detected in the drug and alcohol screening test if result was positive.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visionTestConducted rdf:type rdf:Property ;
    rdfs:label 'Vision Test Conducted' ;
    rdfs:comment 'Indicates whether vision testing was conducted to assess visual acuity and fitness for safety-critical tasks.' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visionTestResult rdf:type rdf:Property ;
    rdfs:label 'Vision Test Result' ;
    rdfs:comment 'Result of vision testing (meets standard, corrective lenses required, does not meet standard, or follow-up required).' ;
    rdfs:domain ind:MedicalFitness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilisationId rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Id' ;
    rdfs:comment 'Unique identifier for the workforce mobilisation record. Primary key for tracking individual worker movement events to and from mine sites.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accommodationAllocationId rdf:type rdf:Property ;
    rdfs:label 'Accommodation Allocation Id' ;
    rdfs:comment 'Identifier of the accommodation room or unit allocated to the worker during their site rotation. Links to camp management systems.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccommodationAllocation .

ind:rosterCycleId rdf:type rdf:Property ;
    rdfs:label 'Roster Cycle Id' ;
    rdfs:comment 'Identifier of the roster cycle this mobilisation supports. Links the movement to the planned work schedule and rotation pattern.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RosterCycle .

ind:accommodationCheckInDatetime rdf:type rdf:Property ;
    rdfs:label 'Accommodation Check In Datetime' ;
    rdfs:comment 'Date and time the worker checked into their allocated accommodation. Used for occupancy tracking and billing.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accommodationCheckOutDatetime rdf:type rdf:Property ;
    rdfs:label 'Accommodation Check Out Datetime' ;
    rdfs:comment 'Date and time the worker checked out of their accommodation. Used for occupancy tracking and room turnover planning.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accommodationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Accommodation Cost Amount' ;
    rdfs:comment 'Cost of accommodation for this rotation period. Allocated to the appropriate cost centre for workforce budgeting.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accommodationType rdf:type rdf:Property ;
    rdfs:label 'Accommodation Type' ;
    rdfs:comment 'Type of accommodation provided to the worker during their site rotation. Varies by site facilities and worker grade.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDemobilisationDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Demobilisation Datetime' ;
    rdfs:comment 'Actual date and time the worker departed from site. Captured from site exit systems or travel manifest.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualMobilisationDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Mobilisation Datetime' ;
    rdfs:comment 'Actual date and time the worker departed for site. Captured from travel manifest or check-in systems.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalLocation rdf:type rdf:Property ;
    rdfs:label 'Arrival Location' ;
    rdfs:comment 'City, airport code, or location where the worker arrived. Typically the nearest airport or transport hub to the mine site.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureLocation rdf:type rdf:Property ;
    rdfs:label 'Departure Location' ;
    rdfs:comment 'City, airport code, or location from which the worker departed. Typically the workers home base for FIFO operations.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Flight number for air travel mobilisations. Used for manifest tracking and arrival/departure confirmation.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestConfirmed rdf:type rdf:Property ;
    rdfs:label 'Manifest Confirmed' ;
    rdfs:comment 'Flag indicating whether the worker has been confirmed on the flight or bus manifest. Used for headcount reconciliation and safety accountability.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalClearanceVerified rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Verified' ;
    rdfs:comment 'Flag indicating whether current medical fitness clearance has been verified prior to mobilisation. Mandatory for MSHA and ISO 45001 compliance.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilisationNumber rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Number' ;
    rdfs:comment 'Business reference number for the mobilisation event. Used for tracking and reporting purposes across travel booking, accommodation, and payroll systems.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilisationStatus rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Status' ;
    rdfs:comment 'Current lifecycle status of the mobilisation event. Tracks progression from planning through to completion or cancellation. [ENUM-REF-CANDIDATE: planned|booked|in_transit|arrived|completed|cancelled|delayed|no_show — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilisationType rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Type' ;
    rdfs:comment 'Classification of the movement event. Distinguishes between standard mobilisation, demobilisation, rotation changes, emergency movements, and inter-site transfers.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noShowFlag rdf:type rdf:Property ;
    rdfs:label 'No Show Flag' ;
    rdfs:comment 'Flag indicating whether the worker failed to appear for scheduled travel. Triggers workforce planning adjustments and potential disciplinary action.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preMobilisationChecklistCompleted rdf:type rdf:Property ;
    rdfs:label 'Pre Mobilisation Checklist Completed' ;
    rdfs:comment 'Flag indicating whether the pre-mobilisation checklist has been completed. Includes medical fitness, training currency, and PPE readiness.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDemobilisationDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Demobilisation Date' ;
    rdfs:comment 'Planned date for the worker to demobilise from site. Used for return travel booking and roster planning.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledMobilisationDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Mobilisation Date' ;
    rdfs:comment 'Planned date for the worker to mobilise to site. Used for travel booking and accommodation planning.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Site Arrival Datetime' ;
    rdfs:comment 'Confirmed date and time the worker arrived at the mine site. Captured from site access control or check-in systems.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Site Departure Datetime' ;
    rdfs:comment 'Confirmed date and time the worker departed from the mine site. Captured from site exit control systems.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteInductionCompletedDatetime rdf:type rdf:Property ;
    rdfs:label 'Site Induction Completed Datetime' ;
    rdfs:comment 'Date and time the site-specific induction was completed. Required before the worker can commence work on site.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteInductionRequired rdf:type rdf:Property ;
    rdfs:label 'Site Induction Required' ;
    rdfs:comment 'Flag indicating whether a site-specific induction is required upon arrival. Typically true for first-time mobilisations or after extended absence.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalMobilisationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Mobilisation Cost Amount' ;
    rdfs:comment 'Total cost of the mobilisation event including travel, accommodation, and any other associated costs. Key metric for workforce logistics cost management.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCurrencyVerified rdf:type rdf:Property ;
    rdfs:label 'Training Currency Verified' ;
    rdfs:comment 'Flag indicating whether all mandatory training and competencies are current prior to mobilisation. Critical for site access authorization.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelBookingReference rdf:type rdf:Property ;
    rdfs:label 'Travel Booking Reference' ;
    rdfs:comment 'Booking confirmation number or reference code from the travel provider. Used for manifest reconciliation and travel expense tracking.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelCostAmount rdf:type rdf:Property ;
    rdfs:label 'Travel Cost Amount' ;
    rdfs:comment 'Total cost of travel for this mobilisation event including flights, bus, or other transport. Major cost component for remote mine operations.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelProvider rdf:type rdf:Property ;
    rdfs:label 'Travel Provider' ;
    rdfs:comment 'Name of the airline, bus company, or charter service provider used for the journey. Used for vendor management and cost reconciliation.' ;
    rdfs:domain ind:Mobilisation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique identifier for the payroll processing record. Primary key for the payroll record entity.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankBsbCode rdf:type rdf:Property ;
    rdfs:label 'Bank Bsb Code' ;
    rdfs:comment 'The six-digit BSB code identifying the bank branch for electronic funds transfer. Used in Australian banking systems.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePayAmount rdf:type rdf:Property ;
    rdfs:label 'Base Pay Amount' ;
    rdfs:comment 'The base salary or wage amount for the pay period, excluding allowances, overtime, and other variable pay components. Calculated based on contracted hours and hourly or annual rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus payment included in this payroll record. May include safety bonuses, production bonuses, or annual incentive payments.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Fifo Allowance Amount' ;
    rdfs:comment 'Allowance paid to workers on FIFO rosters to compensate for travel and time away from home. Common in remote mining operations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentAmount rdf:type rdf:Property ;
    rdfs:label 'Garnishment Amount' ;
    rdfs:comment 'Court-ordered or statutory deduction from the employee\'s pay for child support, debt repayment, or other legal obligations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total gross pay for the pay period, calculated as the sum of base pay, all allowances, overtime, bonuses, and other earnings before any deductions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total number of regular hours worked during the pay period, excluding overtime. Used as the basis for base pay calculation for hourly workers.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadingHandAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Leading Hand Allowance Amount' ;
    rdfs:comment 'Additional allowance paid to workers in supervisory or leading hand roles who coordinate small teams or work groups.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaveHoursPaid rdf:type rdf:Property ;
    rdfs:label 'Leave Hours Paid' ;
    rdfs:comment 'Total number of leave hours paid during the pay period, including annual leave, sick leave, and other paid time off.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'The final take-home pay amount for the employee, calculated as gross pay minus total deductions. This is the amount paid to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Sum of all other voluntary or mandatory deductions not otherwise categorized, such as health insurance premiums, salary sacrifice arrangements, or loan repayments.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Amount' ;
    rdfs:comment 'Total overtime pay calculated for the pay period based on overtime hours worked and applicable overtime rates.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last date of the pay period covered by this payroll record. Defines the end of the earnings calculation window.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first date of the pay period covered by this payroll record. Defines the beginning of the earnings calculation window.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payRunReference rdf:type rdf:Property ;
    rdfs:label 'Pay Run Reference' ;
    rdfs:comment 'Unique reference number assigned to the payroll batch or pay run in which this record was processed. Used for audit and reconciliation purposes.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'SAP HR payroll area code representing the organizational grouping for payroll processing (e.g., by site, region, or pay frequency). Determines pay calendar and processing rules.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of the payroll record. Tracks the record through the payroll lifecycle from draft calculation to final payment.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Site Allowance Amount' ;
    rdfs:comment 'Allowance paid to workers assigned to remote or challenging mine sites. Compensates for site-specific conditions and living arrangements.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:superannuationAmount rdf:type rdf:Property ;
    rdfs:label 'Superannuation Amount' ;
    rdfs:comment 'Employer superannuation (pension) contribution made on behalf of the employee. Mandatory in jurisdictions such as Australia under the Superannuation Guarantee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deductions Amount' ;
    rdfs:comment 'Sum of all deductions applied to the gross pay, including tax, superannuation, union dues, garnishments, and other deductions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDuesAmount rdf:type rdf:Property ;
    rdfs:label 'Union Dues Amount' ;
    rdfs:comment 'Union membership dues deducted from the employee\'s pay as authorized by the employee. Remitted to the relevant labor union.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique identifier for the position record. Primary key for the position master data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:incumbentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incumbent Employee Id' ;
    rdfs:comment 'Reference to the employee currently filling this position. Null if position is vacant.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportingPositionId rdf:type rdf:Property ;
    rdfs:label 'Reporting Position Id' ;
    rdfs:comment 'Reference to the position_id of the direct manager or supervisor position. Defines the reporting hierarchy for organizational structure.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:contractorEmployeeRatio rdf:type rdf:Property ;
    rdfs:label 'Contractor Employee Ratio' ;
    rdfs:comment 'Planned ratio of contractor FTE to employee FTE for this position or role family. Used for workforce mix optimization and OPEX planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalSkillsGap rdf:type rdf:Property ;
    rdfs:label 'Critical Skills Gap' ;
    rdfs:comment 'Assessment of the difficulty in filling this position due to skills scarcity in the labor market. Used for workforce planning and talent acquisition strategy.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directReportsCount rdf:type rdf:Property ;
    rdfs:label 'Direct Reports Count' ;
    rdfs:comment 'Number of positions that directly report to this position. Used for span-of-control analysis and organizational design.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fifoResidentialSplit rdf:type rdf:Property ;
    rdfs:label 'Fifo Residential Split' ;
    rdfs:comment 'Planned split of workforce between FIFO and residential arrangements for this position, expressed as a ratio (e.g., 70/30 means 70% FIFO, 30% residential). Used for accommodation and logistics planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Salary grade and band classification for the position, used for compensation benchmarking and career progression. Format: Letter (A-E) followed by number (1-5).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved full-time equivalent (FTE) headcount allocation for this position. May be fractional for part-time or shared roles (e.g., 0.5 FTE, 1.0 FTE).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLeadershipRole rdf:type rdf:Property ;
    rdfs:label 'Is Leadership Role' ;
    rdfs:comment 'Flag indicating whether this position has direct reports and is classified as a leadership or management role. True if leadership; False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatutoryRole rdf:type rdf:Property ;
    rdfs:label 'Is Statutory Role' ;
    rdfs:comment 'Flag indicating whether this position is a statutory or regulatory-required role under MSHA, state mining acts, or ISO 45001 (e.g., Mine Manager, Ventilation Officer, Explosives Controller). True if statutory; False otherwise.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational category grouping similar roles together for workforce planning and career development purposes. [ENUM-REF-CANDIDATE: operations|processing|maintenance|geology|engineering|hse|supply_chain|finance|hr|it|corporate — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lomAlignment rdf:type rdf:Property ;
    rdfs:label 'Lom Alignment' ;
    rdfs:comment 'Classification of the position\'s duration relative to the mine\'s Life of Mine plan. LOM-aligned positions are tied to the mine\'s operational lifespan; project-based positions are tied to specific capital projects.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHeadcountFy rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount Fy' ;
    rdfs:comment 'Planned full-time equivalent (FTE) headcount for this position in the current financial year, used for annual budget workforce modeling.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHeadcountFyPlus1 rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount Fy Plus 1' ;
    rdfs:comment 'Planned full-time equivalent (FTE) headcount for this position in the next financial year (FY+1), used for multi-year workforce planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHeadcountFyPlus2 rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount Fy Plus 2' ;
    rdfs:comment 'Planned full-time equivalent (FTE) headcount for this position two financial years ahead (FY+2), used for long-term workforce planning aligned with LOM.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed narrative description of the position\'s responsibilities, accountabilities, and key performance indicators. May reference formal position description documents.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active: filled and operational; Vacant: approved but unfilled; Frozen: temporarily suspended; Planned: future position for LOM planning; Closed: permanently eliminated.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterPattern rdf:type rdf:Property ;
    rdfs:label 'Roster Pattern' ;
    rdfs:comment 'Standard roster or shift pattern for the position (e.g., 2-weeks-on-1-week-off, 8-days-on-6-days-off, day-shift-only, 12-hour-rotating). Used for fatigue management and workforce planning.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Succession Plan Status' ;
    rdfs:comment 'Current state of succession planning for this position. Critical for statutory roles and key leadership positions to ensure continuity.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceType rdf:type rdf:Property ;
    rdfs:label 'Workforce Type' ;
    rdfs:comment 'Classification of the workforce engagement model for this position. FIFO: Fly-In Fly-Out roster; Residential: permanent site-based.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceCode rdf:type rdf:Property ;
    rdfs:label 'Allowance Code' ;
    rdfs:comment 'Code identifying the standard allowance or loading applicable to this roster pattern (e.g., FIFO_ALLOW, REMOTE_ALLOW, SHIFT_LOAD). Links to payroll allowance master data for compensation calculations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLeaveAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Annual Leave Accrual Rate' ;
    rdfs:comment 'Rate at which annual leave accrues per day worked under this roster pattern, expressed as a decimal (e.g., 0.0833 for 1/12th of a day per day worked). Used for payroll integration and leave balance calculations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleLengthDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Length Days' ;
    rdfs:comment 'Total number of days in one complete roster rotation cycle (e.g., 14 for an 8/6 roster, 21 for a 14/7 roster, 7 for a 4/3 roster). Used to calculate roster recurrence and workforce planning.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOff rdf:type rdf:Property ;
    rdfs:label 'Days Off' ;
    rdfs:comment 'Number of consecutive rest days in the roster cycle (e.g., 6 in an 8/6 roster, 7 in a 14/7 roster, 14 in a 28/14 roster).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOn rdf:type rdf:Property ;
    rdfs:label 'Days On' ;
    rdfs:comment 'Number of consecutive working days in the roster cycle (e.g., 8 in an 8/6 roster, 14 in a 14/7 roster, 28 in a 28/14 roster).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demobilisationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Demobilisation Lead Time Days' ;
    rdfs:comment 'Number of days required to demobilise workers from this roster pattern, including handover, travel arrangements, and exit procedures. Supports workforce transition planning.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilisationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Mobilisation Lead Time Days' ;
    rdfs:comment 'Number of days required to mobilise workers onto this roster pattern, including travel arrangements, accommodation booking, and induction scheduling. Critical for workforce planning and project ramp-up.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligibility Flag' ;
    rdfs:comment 'Indicates whether workers on this roster pattern are eligible for overtime payments. True if overtime applies, False if roster includes all-in compensation or salary arrangements.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rosterCode rdf:type rdf:Property ;
    rdfs:label 'Roster Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the roster pattern (e.g., FIFO_8_6, DIDO_14_7, RES_4_3). Used for operational reference and system integration.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterName rdf:type rdf:Property ;
    rdfs:label 'Roster Name' ;
    rdfs:comment 'Full descriptive name of the roster pattern (e.g., \'Fly-In Fly-Out 8 Days On 6 Days Off\', \'Drive-In Drive-Out 14/7 Day Shift\', \'Residential 4 On 3 Off Continental\').' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'Current lifecycle status of the roster pattern. Active indicates in use, Inactive indicates temporarily suspended, Pending indicates awaiting approval or implementation, Retired indicates permanently discontinued.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterType rdf:type rdf:Property ;
    rdfs:label 'Roster Type' ;
    rdfs:comment 'Classification of the roster arrangement. FIFO (Fly-In Fly-Out) for air-transported workers, DIDO (Drive-In Drive-Out) for road-commuting workers, Residential for permanent on-site or local workers, Casual for irregular schedules, Contractor for third-party labor.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or system account that last modified this shift schedule record.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Reference to the employee assigned as the shift supervisor or shift boss responsible for this shift.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual number of workers who reported for duty on this shift. Updated after shift commencement for attendance tracking.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualProductionTonnes rdf:type rdf:Property ;
    rdfs:label 'Actual Production Tonnes' ;
    rdfs:comment 'Actual production achieved during the shift measured in tonnes. Updated after shift completion for performance analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Date and time when this shift schedule record was first created in the system. Used for audit trail and data lineage.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Equipment Availability Percent' ;
    rdfs:comment 'Percentage of planned equipment that was available and operational during the shift. Key metric for Overall Equipment Effectiveness (OEE) calculation.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatigueOverrideApproved rdf:type rdf:Property ;
    rdfs:label 'Fatigue Override Approved' ;
    rdfs:comment 'Indicates whether a fatigue management override has been approved by authorized personnel (True/False). Used when operational requirements necessitate deviation from standard fatigue limits.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatigueRiskAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Assessment Completed' ;
    rdfs:comment 'Indicates whether fatigue risk assessment has been completed for this shift (True/False). Required for ISO 45001 fatigue management compliance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of safety incidents, near-misses, or reportable events that occurred during the shift. Used for Lost Time Injury Frequency Rate (LTIFR) and Total Recordable Injury Frequency Rate (TRIFR) calculations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Date and time when this shift schedule record was last updated. Used for audit trail and change tracking.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Integration Status' ;
    rdfs:comment 'Status of shift hours integration with SAP HR payroll system (pending, submitted, approved, rejected, processed).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSubmissionDatetime rdf:type rdf:Property ;
    rdfs:label 'Payroll Submission Datetime' ;
    rdfs:comment 'Date and time when shift hours were submitted to the payroll system for processing.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'Target number of workers planned to be assigned to this shift. Used for capacity planning and resource allocation.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionArea rdf:type rdf:Property ;
    rdfs:label 'Production Area' ;
    rdfs:comment 'Specific production area, pit, underground level, or processing plant section where the shift crew will operate (e.g., North Pit, Level 5 West, Concentrator Plant 2).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTargetTonnes rdf:type rdf:Property ;
    rdfs:label 'Production Target Tonnes' ;
    rdfs:comment 'Planned production target for the shift measured in tonnes of ore or material to be moved. Used for shift performance tracking.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyBriefingCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Completed' ;
    rdfs:comment 'Indicates whether the mandatory pre-shift safety briefing has been completed (True/False). Required for MSHA and ISO 45001 compliance.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyBriefingDatetime rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Datetime' ;
    rdfs:comment 'Date and time when the pre-shift safety briefing was conducted. Required for regulatory compliance documentation.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDurationHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Duration Hours' ;
    rdfs:comment 'Planned duration of the shift in hours (e.g., 8.00, 10.00, 12.00). Used for shift planning and fatigue management calculations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned end date and time for the shift in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for the shift in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftHandoverNotes rdf:type rdf:Property ;
    rdfs:label 'Shift Handover Notes' ;
    rdfs:comment 'Free-text notes documenting key information to be handed over from the previous shift or to the next shift (equipment status, incidents, production issues, safety concerns).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPriority rdf:type rdf:Property ;
    rdfs:label 'Shift Priority' ;
    rdfs:comment 'Priority classification of the shift based on operational criticality (critical, high, normal, low). Used for resource allocation and contingency planning.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateValidityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Certificate Validity Period Months' ;
    rdfs:comment 'Number of months that the certification remains valid before refresher or recertification training is required. Used to trigger training renewal notifications and maintain compliance. Nullable for courses with no expiry.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether successful completion of this course results in a formal certificate or credential being issued to the participant. True for statutory, regulatory, and competency-based training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyFrameworkCode rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Code' ;
    rdfs:comment 'Code linking this training course to the organizational competency framework or national qualifications framework. Used to map training outcomes to required competencies for roles and positions.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost charged per participant for delivery of this training course. Includes instructor fees, materials, facility hire, and assessment costs. Used for training budget planning and cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'High-level classification of the training course type. Induction covers site orientation and onboarding; safety statutory includes MSHA-mandated and regulatory training; equipment operation covers mobile equipment and machinery; technical skills includes trade and specialist competencies; leadership covers supervisory and management development; compliance includes HSE and legal requirements; emergency response covers first aid and crisis management. [ENUM-REF-CANDIDATE: induction|safety_statutory|equipment_operation|technical_skills|leadership|compliance|emergency_response — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the training course for identification and scheduling purposes. Used across training management systems and employee records.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseContentSummary rdf:type rdf:Property ;
    rdfs:label 'Course Content Summary' ;
    rdfs:comment 'High-level summary of the topics, modules, and learning outcomes covered in the training course. Used for course selection, training needs analysis, and compliance documentation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsProvided rdf:type rdf:Property ;
    rdfs:label 'Course Materials Provided' ;
    rdfs:comment 'Description of training materials, resources, and equipment provided to participants, such as manuals, workbooks, personal protective equipment, or access to online learning platforms.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full descriptive name of the training course as it appears in the training catalogue and on certificates.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course in the catalogue. Active courses are available for scheduling; inactive courses are temporarily unavailable; under review courses are being updated or audited; retired courses are no longer offered; pending approval courses are awaiting accreditation or management sign-off.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Indicates whether the course is an initial qualification, periodic refresher, mandatory recertification, advanced level, or specialized competency training.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the training is delivered. Classroom is instructor-led in-person; online is e-learning or virtual; blended combines classroom and online; on-the-job is workplace-based practical training; simulation uses equipment simulators; field practical is hands-on training at operational sites.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total duration of the training course measured in working days. Used for multi-day courses and workforce planning. Nullable for courses under one day.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso45001ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Compliance Flag' ;
    rdfs:comment 'Indicates whether this course supports ISO 45001 Occupational Health and Safety Management System requirements for worker competence, awareness, and participation. True for courses aligned with ISO 45001 clauses 7.2 and 7.3.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Language Of Delivery' ;
    rdfs:comment 'Primary language in which the training course is delivered, using ISO 639-3 three-letter language codes. Used for workforce planning and ensuring training accessibility for diverse workforces.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:learningObjectives rdf:type rdf:Property ;
    rdfs:label 'Learning Objectives' ;
    rdfs:comment 'Specific, measurable learning objectives that participants will achieve upon successful completion of the training course. Used for competency mapping and training effectiveness evaluation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedCompetencies rdf:type rdf:Property ;
    rdfs:label 'Linked Competencies' ;
    rdfs:comment 'Comma-separated list of competency codes or identifiers that this training course develops or certifies. Used to track which competencies are satisfied upon successful course completion.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumParticipants rdf:type rdf:Property ;
    rdfs:label 'Maximum Participants' ;
    rdfs:comment 'Maximum number of participants that can be enrolled in a single delivery of this training course. Determined by classroom capacity, equipment availability, or instructor-to-student ratio requirements.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mshaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Msha Compliance Flag' ;
    rdfs:comment 'Indicates whether this course satisfies MSHA Part 48 training requirements for new miner training, annual refresher training, or task training. True for courses that meet MSHA standards and are reported to MSHA.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passMarkPercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Mark Percentage' ;
    rdfs:comment 'Minimum percentage score required to successfully complete the training course and receive certification. Nullable for courses without formal assessment.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before a worker can enroll in this training course. Used to enforce training pathways and competency progression.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Provider Accreditation Number' ;
    rdfs:comment 'Official accreditation or registration number of the training provider issued by relevant regulatory or industry body. Required for statutory and compliance training courses.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the organization or entity delivering the training course. May be internal training department, external Registered Training Organization (RTO), equipment manufacturer, or industry association.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refresherRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Refresher Required Flag' ;
    rdfs:comment 'Indicates whether periodic refresher training is required to maintain competency or certification. True for MSHA annual refresher, first aid recertification, and time-limited competencies.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this training course is mandated by mining regulations, occupational health and safety law, or industry standards. True for MSHA Part 48 training, statutory safety training, and ISO 45001 required competencies.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended participants for this training course, such as new hires, equipment operators, supervisors, contractors, or specific job roles. Used for course assignment and workforce planning.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingEnrolmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrolment Id' ;
    rdfs:comment 'Unique identifier for the training enrolment record. Primary key for the training enrolment entity.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousEnrolmentTrainingEnrolmentId rdf:type rdf:Property ;
    rdfs:label 'Previous Enrolment Training Enrolment Id' ;
    rdfs:comment 'Identifier of the previous training enrolment record that this refresher training is renewing or updating.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEnrolment .

ind:tertiaryTrainingAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Assessor Employee Id' ;
    rdfs:comment 'Identifier of the assessor who evaluated the worker\'s competency.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Access Clearance Date' ;
    rdfs:comment 'Date when site or area access clearance was granted to the worker following induction completion.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessClearanceGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Access Clearance Granted Flag' ;
    rdfs:comment 'Indicates whether site or area access clearance was granted to the worker upon successful completion of the induction.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendancePercentage rdf:type rdf:Property ;
    rdfs:label 'Attendance Percentage' ;
    rdfs:comment 'Percentage of training sessions attended by the worker, calculated as attended hours divided by required hours.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a training certificate was issued to the worker upon successful completion.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyLevelAchieved rdf:type rdf:Property ;
    rdfs:label 'Competency Level Achieved' ;
    rdfs:comment 'Level of competency achieved by the worker upon completion of the training.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrolment Date' ;
    rdfs:comment 'Date when the worker was enrolled in the training course.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrolment Status' ;
    rdfs:comment 'Current status of the training enrolment in its lifecycle.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionModulesCompleted rdf:type rdf:Property ;
    rdfs:label 'Induction Modules Completed' ;
    rdfs:comment 'Comma-separated list or description of specific induction modules completed by the worker.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionType rdf:type rdf:Property ;
    rdfs:label 'Induction Type' ;
    rdfs:comment 'Type of site induction completed by the worker, categorizing the scope and level of access granted.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Training Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory for the worker\'s role or site access under regulatory or company policy.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment, typically as a percentage.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refresherTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Refresher Training Flag' ;
    rdfs:comment 'Indicates whether this enrolment is for refresher or recertification training rather than initial training.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Training Date' ;
    rdfs:comment 'Scheduled date for the training session or course commencement.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Total number of training hours completed by the worker for this enrolment.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'Total number of training hours required to complete the course or meet regulatory requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingOutcome rdf:type rdf:Property ;
    rdfs:label 'Training Outcome' ;
    rdfs:comment 'Final outcome or result of the training assessment.' ;
    rdfs:domain ind:TrainingEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceProjectContractId rdf:type rdf:Property ;
    rdfs:label 'Workforce Project Contract Id' ;
    rdfs:comment 'Primary key for workforce_project_contract' ;
    rdfs:domain ind:WorkforceProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:practicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Practical Completion Date' ;
    rdfs:comment 'Date on which the contractor achieved practical completion of their scope under this contract, triggering defects liability period and retention release.' ;
    rdfs:domain ind:WorkforceProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentShutdownScopeId rdf:type rdf:Property ;
    rdfs:label 'Equipment Shutdown Scope Id' ;
    rdfs:comment 'Primary key for equipment_shutdown_scope' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorScopeItemEquipmentShutdownScopeId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Scope Item Equipment Shutdown Scope Id' ;
    rdfs:comment 'Reference to another shutdown_scope record that must be completed before work on this asset can commence, establishing sequencing dependencies within the shutdown critical path' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentShutdownScope .

ind:responsibleSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Supervisor Employee Id' ;
    rdfs:comment 'Identifier of the maintenance supervisor or foreman accountable for coordinating and completing work on this asset during the shutdown' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shutdownScopeId rdf:type rdf:Property ;
    rdfs:label 'Shutdown Scope Id' ;
    rdfs:comment 'Unique identifier for this asset-shutdown scope record' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceShutdownScope .

ind:actualAssetDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Asset Downtime Hours' ;
    rdfs:comment 'Actual duration in hours that this asset was unavailable during shutdown execution, measured from isolation to return-to-service' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCriticalityForShutdown rdf:type rdf:Property ;
    rdfs:label 'Asset Criticality For Shutdown' ;
    rdfs:comment 'Criticality classification indicating whether this asset is on the shutdown critical path, near-critical (within float tolerance), or non-critical for overall shutdown duration' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Readiness Status' ;
    rdfs:comment 'Current lifecycle status of this asset within the shutdown workflow, tracking progression through readiness gates from pre-shutdown preparation to return-to-service' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetShutdownPriority rdf:type rdf:Property ;
    rdfs:label 'Asset Shutdown Priority' ;
    rdfs:comment 'Priority classification for this asset within the shutdown scope, indicating urgency and resource allocation precedence' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Isolation Timestamp' ;
    rdfs:comment 'Date and time when this asset was formally isolated and locked out for shutdown work, marking the start of asset-specific downtime' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedAssetDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Asset Downtime Hours' ;
    rdfs:comment 'Estimated duration in hours that this specific asset will be unavailable during the shutdown, used for production loss calculations and resource planning' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postShutdownCommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Post Shutdown Commissioning Date' ;
    rdfs:comment 'Date when post-shutdown commissioning and performance testing was completed, authorizing return-to-service' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postShutdownCommissioningRequired rdf:type rdf:Property ;
    rdfs:label 'Post Shutdown Commissioning Required' ;
    rdfs:comment 'Indicates whether this asset requires formal commissioning and performance testing before being returned to operational service after shutdown work completion' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preShutdownInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Pre Shutdown Inspection Date' ;
    rdfs:comment 'Date when the pre-shutdown inspection was completed for this asset, establishing baseline condition and confirming scope' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preShutdownInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Pre Shutdown Inspection Required' ;
    rdfs:comment 'Indicates whether this asset requires a formal pre-shutdown inspection to assess condition and finalize work scope before shutdown commencement' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradeRequired rdf:type rdf:Property ;
    rdfs:label 'Trade Required' ;
    rdfs:comment 'Primary trade or craft skill required for work on this asset (e.g., mechanical fitter, electrician, boilermaker, millwright), used for resource leveling' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Work Package Description' ;
    rdfs:comment 'Detailed description of the maintenance work to be performed on this asset during the shutdown, including specific tasks, inspections, and repairs' ;
    rdfs:domain ind:EquipmentShutdownScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitAnalyticalProtocolId rdf:type rdf:Property ;
    rdfs:label 'Circuit Analytical Protocol Id' ;
    rdfs:comment 'Unique surrogate identifier for this circuit-method protocol assignment record' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalJustification rdf:type rdf:Property ;
    rdfs:label 'Approval Justification' ;
    rdfs:comment 'Business or technical rationale for selecting this analytical method for this circuit (e.g., detection limit requirements, matrix compatibility, accreditation needs)' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percent' ;
    rdfs:comment 'Percentage of this circuit\'s analytical budget allocated to this specific method, used for cost tracking and budget forecasting' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Method Approval Date' ;
    rdfs:comment 'Date on which this analytical method was formally approved for use on this processing circuit by the technical authority' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:methodPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Method Priority Level' ;
    rdfs:comment 'Priority classification of this method for this circuit (primary for routine use, secondary for confirmation, backup for contingency, research for trials)' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Status' ;
    rdfs:comment 'Current operational status of this circuit-method protocol assignment' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaqcInsertionRate rdf:type rdf:Property ;
    rdfs:label 'Qaqc Insertion Rate' ;
    rdfs:comment 'Required frequency of quality control sample insertion for this circuit-method combination, expressed as percentage (e.g., 5.00 means one QC sample per 20 production samples)' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleFrequencyPerShift rdf:type rdf:Property ;
    rdfs:label 'Sample Frequency Per Shift' ;
    rdfs:comment 'Required number of samples to be collected and analyzed using this method per operating shift for this circuit' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundRequirementHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Requirement Hours' ;
    rdfs:comment 'Maximum allowable turnaround time from sample submission to result reporting for this circuit-method combination, driven by process control requirements' ;
    rdfs:domain ind:CircuitAnalyticalProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Test Specification Id' ;
    rdfs:comment 'Unique identifier for this product-method testing requirement. Primary key.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Pass/fail criteria or acceptable range for analytical results when this method is applied to this product. Defines the quality thresholds that must be met for the product to be released for sale or shipment.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForExportCertification rdf:type rdf:Property ;
    rdfs:label 'Approved For Export Certification' ;
    rdfs:comment 'Indicates whether results from this method applied to this product are acceptable for inclusion in export quality certificates and customs documentation.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestRequiredOnFailure rdf:type rdf:Property ;
    rdfs:label 'Retest Required On Failure' ;
    rdfs:comment 'Indicates whether a failed test result requires automatic retesting using the same method, or whether failure triggers immediate product hold.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleSizeMinimum rdf:type rdf:Property ;
    rdfs:label 'Sample Size Minimum' ;
    rdfs:comment 'Minimum sample mass or volume required for this test on this product, measured in kilograms or liters. Ensures sufficient material for reliable analysis.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingProtocol rdf:type rdf:Property ;
    rdfs:label 'Sampling Protocol' ;
    rdfs:comment 'Specific sampling procedure and protocol that must be followed when collecting samples of this product for analysis using this method. May reference standards like ISO 3082 for iron ore sampling or ASTM D2234 for coal sampling.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'Required frequency at which this analytical method must be applied to this saleable product. Driven by quality control requirements, customer contract specifications, and regulatory mandates.' ;
    rdfs:domain ind:TestSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productApprovedVendorMaterialId rdf:type rdf:Property ;
    rdfs:label 'Product Approved Vendor Material Id' ;
    rdfs:comment 'Primary key for product_approved_vendor_material' ;
    rdfs:domain ind:ProductApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedVendorMaterialId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Material Id' ;
    rdfs:comment 'Unique identifier for each vendor-product approval record. Primary key.' ;
    rdfs:domain ind:ProductApprovedVendorMaterial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementApprovedVendorMaterial .

ind:qualitySpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Reference' ;
    rdfs:comment 'Reference to the specific quality specification document or agreement governing this vendor\'s supply of this product. May differ from the general product specification.' ;
    rdfs:domain ind:ProductApprovedVendorMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Unique identifier for this laboratory approval record. Primary key.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationScopeApproved rdf:type rdf:Property ;
    rdfs:label 'Accreditation Scope Approved' ;
    rdfs:comment 'The specific subset of the laboratory\'s accreditation scope (analytes, methods, matrices) that this Competent Person has approved for their work. May be narrower than the laboratory\'s full accreditation scope based on CP commodity expertise.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedCommodityList rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity List' ;
    rdfs:comment 'Comma-separated list of mineral commodities for which this CP has approved this laboratory, aligned with the CP\'s commodity expertise and the laboratory\'s analytical capabilities.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this laboratory service agreement. Primary key.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this laboratory service agreement record, typically the project geologist or contracts administrator.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this laboratory service agreement record.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analyticalSuiteScope rdf:type rdf:Property ;
    rdfs:label 'Analytical Suite Scope' ;
    rdfs:comment 'Detailed description of the analytical methods, analytes, and sample types covered under this specific project-laboratory agreement, which may be a subset of the laboratory\'s full accreditation scope tailored to project requirements.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'External contract or purchase order reference number used in procurement and financial systems to track this laboratory service agreement.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryRole rdf:type rdf:Property ;
    rdfs:label 'Laboratory Role' ;
    rdfs:comment 'The role this laboratory plays in the project\'s quality assurance framework: primary (main analytical provider), check (independent verification of primary results), umpire (dispute resolution when primary and check disagree), or specialist (specific testwork such as metallurgical or geotechnical).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolumeCommitment rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Commitment' ;
    rdfs:comment 'Minimum number of samples the project commits to submit to this laboratory over the contract period, used to negotiate preferential pricing and secure laboratory capacity allocation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundSlaDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Sla Days' ;
    rdfs:comment 'Contracted service level agreement for turnaround time in calendar days from sample receipt to result delivery, negotiated specifically for this project and may differ from the laboratory\'s standard turnaround time based on project priority and volume commitments.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitAssetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Circuit Asset Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each circuit-asset assignment record' ;
    rdfs:domain ind:CircuitAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitPosition rdf:type rdf:Property ;
    rdfs:label 'Circuit Position' ;
    rdfs:comment 'Specific position or location code of the asset within the circuit flowsheet (e.g., PRIMARY_MILL_1, ROUGHER_CELL_3, CYCLONE_BANK_A). Used for circuit configuration management and maintenance work order routing.' ;
    rdfs:domain ind:CircuitAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyClassification rdf:type rdf:Property ;
    rdfs:label 'Duty Classification' ;
    rdfs:comment 'Operational duty classification of the asset within the circuit indicating whether it operates as primary equipment, secondary/parallel unit, or standby/backup capacity. Drives maintenance prioritization and availability calculations.' ;
    rdfs:domain ind:CircuitAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceContributionPct rdf:type rdf:Property ;
    rdfs:label 'Performance Contribution Pct' ;
    rdfs:comment 'Percentage contribution of this asset to the overall circuit throughput or recovery performance. Used for metallurgical accounting, bottleneck analysis, and asset performance attribution in multi-unit circuits.' ;
    rdfs:domain ind:CircuitAssetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circuitTailingsRoutingId rdf:type rdf:Property ;
    rdfs:label 'Circuit Tailings Routing Id' ;
    rdfs:comment 'Unique surrogate identifier for this circuit-to-TSF routing configuration record' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Id' ;
    rdfs:comment 'Identifier of the physical tailings pipeline infrastructure used for this circuit-to-TSF routing. Links routing configuration to physical asset register.' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pipeline .

ind:designSolidsRateTph rdf:type rdf:Property ;
    rdfs:label 'Design Solids Rate Tph' ;
    rdfs:comment 'Design basis dry solids flow rate from this circuit to this TSF expressed in tonnes per hour (tph). Used for TSF capacity planning and deposition rate modeling.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designWaterRecoveryPct rdf:type rdf:Property ;
    rdfs:label 'Design Water Recovery Pct' ;
    rdfs:comment 'Target percentage of process water to be recovered from this tailings stream at the receiving TSF. Varies by TSF design (thickened tailings, paste, conventional) and water balance strategy.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geochemicalRoutingRule rdf:type rdf:Property ;
    rdfs:label 'Geochemical Routing Rule' ;
    rdfs:comment 'Business rule describing the geochemical criteria governing this routing decision (e.g., \'ARD-generating tailings from copper rougher circuit routed to lined TSF-3\', \'Benign tailings from final cleaner routed to unlined TSF-1\'). Critical for environmental compliance and acid rock drainage management.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Integer priority ranking for this routing configuration when multiple TSF destinations are available for a circuit (1=primary, 2=secondary, 3=tertiary). Drives automated routing logic and operational decision-making during TSF transitions.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current operational status of this routing configuration. ACTIVE routings are currently in use, PLANNED are future configurations, INACTIVE are temporarily suspended, DECOMMISSIONED are permanently retired.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tailingsDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Tailings Destination Code' ;
    rdfs:comment 'Code identifying the Tailings Storage Facility (TSF) or waste stream destination for tailings generated by this circuit. Critical for environmental compliance, TSF capacity planning, and regulatory reporting. [Moved from processing_circuit: This attribute in processing_circuit currently stores a single TSF destination code, implying a 1:N relationship. In the true M:N business reality where circuits can route to multiple TSFs based on operational conditions, this attribute should be removed and replaced by the circuit_tailings_routing association which captures the full many-to-many routing configuration with time-based and priority-based routing rules.]' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tailingsStreamDesignation rdf:type rdf:Property ;
    rdfs:label 'Tailings Stream Designation' ;
    rdfs:comment 'Classification of the tailings stream type for this routing (e.g., PRIMARY for main tailings flow, ARD for acid-generating tailings requiring lined storage, BENIGN for non-reactive tailings, EMERGENCY for overflow routing). Drives environmental compliance and TSF selection logic.' ;
    rdfs:domain ind:CircuitTailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circuitProductConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Circuit Product Configuration Id' ;
    rdfs:comment 'Unique surrogate identifier for each circuit-product configuration record. Primary key for the association.' ;
    rdfs:domain ind:CircuitProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Circuit Configuration Code' ;
    rdfs:comment 'Code identifying the specific operating configuration or mode used when producing this product from this circuit (e.g., CLEANER_ONLY, SCAV_RECYCLE, HIGH_GRADE_CAMPAIGN, BULK_PRODUCTION). Captures the operational setup that differentiates how different products are produced.' ;
    rdfs:domain ind:CircuitProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrateProductCode rdf:type rdf:Property ;
    rdfs:label 'Concentrate Product Code' ;
    rdfs:comment 'Product code of the primary output concentrate or processed product from this circuit (e.g., CU-CON-01 for copper concentrate). Links to sales contracts, logistics, and product quality specifications. [Moved from processing_circuit: This attribute in processing_circuit currently captures a single primary output product code. In a flexible processing operation where circuits can produce multiple products, this attribute should be removed from the circuit entity and the relationship should be captured through the circuit_product_configuration association. Each circuit-product configuration record will link to the saleable_product via FK, eliminating the need for a single product code on the circuit.]' ;
    rdfs:domain ind:CircuitProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionPriority rdf:type rdf:Property ;
    rdfs:label 'Production Priority' ;
    rdfs:comment 'Integer ranking indicating the priority of this product within the circuit\'s production portfolio. Lower numbers indicate higher priority. Used for production scheduling and campaign planning when a circuit can produce multiple products.' ;
    rdfs:domain ind:CircuitProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetGradePct rdf:type rdf:Property ;
    rdfs:label 'Target Grade Pct' ;
    rdfs:comment 'Target product grade for this specific circuit-product combination expressed as a percentage of valuable mineral content. This is configuration-specific as different products from the same circuit may have different grade targets (e.g., cleaner concentrate vs. rougher concentrate).' ;
    rdfs:domain ind:CircuitProductConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsRoutingId rdf:type rdf:Property ;
    rdfs:label 'Tailings Routing Id' ;
    rdfs:comment 'Unique surrogate identifier for this specific plant-to-TSF routing configuration. Primary key for the tailings routing association.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designFlowRateM3ph rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate M3ph' ;
    rdfs:comment 'Design volumetric flow rate of tailings slurry through this routing configuration, expressed in cubic meters per hour (m³/h). This is specific to the routing because it depends on pipeline diameter, pump capacity, elevation change, and distance between the specific plant and TSF. Critical for hydraulic design and operational planning.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationGainM rdf:type rdf:Property ;
    rdfs:label 'Elevation Gain M' ;
    rdfs:comment 'Net elevation gain (or loss if negative) from the processing plant discharge point to the TSF deposition point for this specific routing, measured in meters. This is a relationship attribute because it describes the topographic profile of this specific plant-TSF connection. Critical for pump sizing and energy consumption calculations.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryDestination rdf:type rdf:Property ;
    rdfs:label 'Is Primary Destination' ;
    rdfs:comment 'Boolean flag indicating whether this TSF is the primary (normal operating) destination for tailings from this processing plant. True = primary destination; False = secondary/emergency destination. A plant typically has one primary TSF and may have one or more secondary TSFs for contingency operations, maintenance periods, or capacity management. This attribute belongs to the routing relationship because it describes the operational priority of this specific plant-TSF connection.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineLengthKm rdf:type rdf:Property ;
    rdfs:label 'Pipeline Length Km' ;
    rdfs:comment 'Total length of the tailings pipeline for this specific plant-to-TSF routing, measured in kilometers. This is a relationship attribute because it describes the physical connection infrastructure between this specific plant-TSF pair. Relevant for pumping energy calculations, maintenance planning, and risk assessment.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tailingsStreamType rdf:type rdf:Property ;
    rdfs:label 'Tailings Stream Type' ;
    rdfs:comment 'Classification of the tailings stream type being routed from this plant to this TSF. Conventional tailings are slurry with 20-30% solids; thickened tailings are 45-55% solids; paste tailings are 65-75% solids; filtered tailings are dewatered to 80%+ solids; co-disposal includes waste rock. This attribute belongs to the routing relationship because the same plant may produce different stream types for different TSFs depending on processing method and TSF design requirements.' ;
    rdfs:domain ind:TailingsRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantProductCampaignId rdf:type rdf:Property ;
    rdfs:label 'Plant Product Campaign Id' ;
    rdfs:comment 'Primary key for the plant_product_campaign association' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Unique business identifier for this production campaign used in operational reporting and plant scheduling systems' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign End Date' ;
    rdfs:comment 'The date on which this production campaign concluded or is planned to conclude. Null for ongoing campaigns. Used for campaign duration analysis and scheduling.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignNotes rdf:type rdf:Property ;
    rdfs:label 'Campaign Notes' ;
    rdfs:comment 'Free-text operational notes capturing campaign-specific conditions, challenges, process adjustments, or quality issues encountered during production.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Start Date' ;
    rdfs:comment 'The date on which this production campaign commenced. Represents when the plant began processing ore to produce this specific saleable product variant.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the production campaign. Planned: scheduled but not started; Active: currently producing; Suspended: temporarily halted; Completed: finished successfully; Cancelled: terminated before completion.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedOreSource rdf:type rdf:Property ;
    rdfs:label 'Feed Ore Source' ;
    rdfs:comment 'Identification of the primary ore source (pit, stockpile, or blend) feeding this production campaign. Critical for traceability and understanding quality variations.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityGradeAchievedPct rdf:type rdf:Property ;
    rdfs:label 'Quality Grade Achieved Pct' ;
    rdfs:comment 'Average grade of the valuable mineral component achieved in the saleable product during this campaign, expressed as percentage. Campaign-specific quality outcome that may vary from target grade specification based on feed ore characteristics and plant performance.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryRateAchievedPct rdf:type rdf:Property ;
    rdfs:label 'Recovery Rate Achieved Pct' ;
    rdfs:comment 'Actual metallurgical recovery rate achieved during this campaign expressed as percentage. Campaign-specific performance metric comparing valuable mineral in product to valuable mineral in feed.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProductionRateTph rdf:type rdf:Property ;
    rdfs:label 'Target Production Rate Tph' ;
    rdfs:comment 'Planned throughput rate for this campaign expressed in dry metric tonnes per hour (tph). Campaign-specific target that may differ from plant nameplate capacity based on ore characteristics and product specifications.' ;
    rdfs:domain ind:PlantProductCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCommunityContributionId rdf:type rdf:Property ;
    rdfs:label 'Plant Community Contribution Id' ;
    rdfs:comment 'Unique surrogate identifier for this plant-program contribution record. Primary key.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitSharingAgreementClause rdf:type rdf:Property ;
    rdfs:label 'Benefit Sharing Agreement Clause' ;
    rdfs:comment 'Reference to the specific clause or section in the benefit-sharing agreement that governs this plant\'s contribution obligations to this program.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionAmount rdf:type rdf:Property ;
    rdfs:label 'Contribution Amount' ;
    rdfs:comment 'The monetary contribution amount from this specific processing plant to this specific community investment program. Represents the plant\'s share of program funding.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contribution Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contribution amount (e.g., USD, AUD, CAD, ZAR). May differ from the program\'s budget currency if plants operate in different jurisdictions.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionStatus rdf:type rdf:Property ;
    rdfs:label 'Contribution Status' ;
    rdfs:comment 'Current status of this plant\'s contribution to the program: committed (pledged but not yet active), active (currently funding), suspended (temporarily paused), completed (funding period ended), or cancelled (commitment withdrawn).' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'The nature of the contribution from the processing plant to the program: direct_funding (cash), in_kind (goods/services), technical_support, infrastructure, equipment, or personnel secondment.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Funding Period End' ;
    rdfs:comment 'The date when this processing plant\'s contribution commitment to this community investment program ends. May differ from the program\'s overall end date if plants have different commitment periods.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Funding Period Start' ;
    rdfs:comment 'The date when this processing plant\'s contribution commitment to this community investment program begins. May differ from the program\'s overall start date if plants join at different times.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programParticipationLevel rdf:type rdf:Property ;
    rdfs:label 'Program Participation Level' ;
    rdfs:comment 'The level of involvement and responsibility this processing plant has in the community investment program: primary_sponsor (lead funder), co_sponsor (major partner), supporting (moderate contribution), or minor_contributor.' ;
    rdfs:domain ind:PlantCommunityContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentScheduleAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Schedule Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment schedule assignment record in the lakehouse' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Reference to the mine planner or production supervisor who created this equipment assignment. Used for accountability and assignment audit trail.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'The date and time when this equipment schedule assignment record was first created in the system. Supports audit trail and assignment history tracking.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Updated Timestamp' ;
    rdfs:comment 'The date and time when this equipment schedule assignment record was last modified. Supports change tracking and audit trail for fleet reallocation decisions.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking of this equipment assignment relative to other concurrent assignments for the same asset. Lower numbers indicate higher priority. Used when an asset is assigned to multiple overlapping schedules to determine allocation precedence.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFuelBudgetLitres rdf:type rdf:Property ;
    rdfs:label 'Scheduled Fuel Budget Litres' ;
    rdfs:comment 'The planned fuel consumption budget in litres allocated for this asset during the schedule period. Used for fuel logistics planning and cost control.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledMaintenanceWindow rdf:type rdf:Property ;
    rdfs:label 'Scheduled Maintenance Window' ;
    rdfs:comment 'Planned maintenance window or downtime period scheduled for this asset during the production schedule period (e.g., \'Week 2 Day Shift\', \'Mid-period 24hr service\'). Used to coordinate production planning with maintenance planning.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Operating Hours' ;
    rdfs:comment 'The planned number of operating hours for this asset during the schedule period. Used to calculate equipment availability and utilisation targets for the mining block or bench.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Scheduled Utilisation Pct' ;
    rdfs:comment 'The target utilisation percentage for this asset during the schedule period, calculated as productive hours divided by available hours. Used for fleet performance planning and KPI tracking.' ;
    rdfs:domain ind:EquipmentScheduleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectLaboratoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Prospect Laboratory Assignment Id' ;
    rdfs:comment 'Unique identifier for this prospect-laboratory assignment relationship. Primary key.' ;
    rdfs:domain ind:ProspectLaboratoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerSampleNegotiated rdf:type rdf:Property ;
    rdfs:label 'Cost Per Sample Negotiated' ;
    rdfs:comment 'Negotiated cost per sample for this prospect-laboratory pairing, which may differ from the laboratory\'s standard pricing due to volume commitments, contract terms, or analytical suite customization. Used for prospect-level budget forecasting and cost control.' ;
    rdfs:domain ind:ProspectLaboratoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programEquipmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Program Equipment Assignment Id' ;
    rdfs:comment 'Unique identifier for each equipment assignment to a sample program. Primary key.' ;
    rdfs:domain ind:ProgramEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentRole rdf:type rdf:Property ;
    rdfs:label 'Equipment Role' ;
    rdfs:comment 'The functional role the asset performed within this sample program: primary_drilling (main drill rig for sample collection), support_drilling (infill or verification drilling), excavation (pit access or trench sampling), sample_collection (dedicated sampling equipment), sample_transport (moving samples to storage), site_preparation (access roads, pads), other. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ProgramEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Utilization Hours' ;
    rdfs:comment 'Total engine hours or operating hours the asset spent working on this specific sample program. Used for cost allocation and program budget tracking. Identified in detection phase relationship data.' ;
    rdfs:domain ind:ProgramEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Utilization Hours' ;
    rdfs:comment 'Estimated or planned engine hours for this asset to complete its role in the sample program. Used for resource planning and variance analysis against actual utilization hours.' ;
    rdfs:domain ind:ProgramEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'The phase of the sample program during which this equipment assignment is active: planning (equipment reserved but not yet deployed), mobilization (equipment being moved to site), active_sampling (equipment actively collecting samples), demobilization (equipment being removed from program), completed (assignment finished). Identified in detection phase relationship data.' ;
    rdfs:domain ind:ProgramEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyAnalyticalSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Study Analytical Specification Id' ;
    rdfs:comment 'Unique identifier for this study analytical specification record. Primary key.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForStudyFlag rdf:type rdf:Property ;
    rdfs:label 'Approved For Study Flag' ;
    rdfs:comment 'Boolean flag indicating whether this method has been formally approved for use in this specific feasibility study by the competent person or study lead consultant.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionLimitAdequacy rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Adequacy' ;
    rdfs:comment 'Assessment of whether the methods detection limits are adequate for the expected grade ranges and resource estimation requirements of this specific feasibility study. Values: adequate, marginal, inadequate.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSampleCount rdf:type rdf:Property ;
    rdfs:label 'Expected Sample Count' ;
    rdfs:comment 'Estimated number of samples that will be analyzed using this method during this feasibility study, used for cost estimation and laboratory capacity planning.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laboratoryProvider rdf:type rdf:Property ;
    rdfs:label 'Laboratory Provider' ;
    rdfs:comment 'Name of the specific laboratory (internal or external) that will perform this analytical method for this feasibility study, as different studies may use different laboratory providers.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodSelectionRationale rdf:type rdf:Property ;
    rdfs:label 'Method Selection Rationale' ;
    rdfs:comment 'Documented business justification for why this specific analytical method was selected for this feasibility study, including technical suitability, cost considerations, accreditation requirements, and matrix compatibility with expected sample types.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAnalyteTarget rdf:type rdf:Property ;
    rdfs:label 'Primary Analyte Target' ;
    rdfs:comment 'The primary element or compound of interest for this method in the context of this feasibility study (e.g., Au for gold projects, Cu for copper projects), which may be a subset of the methods full analyte list.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDate rdf:type rdf:Property ;
    rdfs:label 'Specification Date' ;
    rdfs:comment 'Date when this analytical method was formally specified and approved for use in this feasibility study.' ;
    rdfs:domain ind:StudyAnalyticalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetCrewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Crew Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each asset-crew assignment record. Primary key.' ;
    rdfs:domain ind:AssetCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility Flag' ;
    rdfs:comment 'Indicates whether this crew has maintenance responsibility for this asset (true) or purely operational responsibility (false). Maintenance crews are accountable for preventive maintenance tasks, pre-start inspections, and minor repairs during their shift.' ;
    rdfs:domain ind:AssetCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryOperatorFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Operator Flag' ;
    rdfs:comment 'Indicates whether this crew is the primary operator responsible for this asset (true) or a secondary/backup crew (false). Used to determine accountability for production targets and asset care. An asset may have one primary crew per shift pattern.' ;
    rdfs:domain ind:AssetCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftPatternCode rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern Code' ;
    rdfs:comment 'Code identifying the shift pattern during which this crew operates this asset (e.g., DAY, NIGHT, SWING). An asset may be assigned to different crews for different shift patterns. Critical for 24/7 operations planning.' ;
    rdfs:domain ind:AssetCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Pct' ;
    rdfs:comment 'Target equipment utilization percentage for this asset when operated by this crew, expressed as a percentage (0.00-100.00). Used for crew performance measurement and production planning. Varies by crew type and shift pattern.' ;
    rdfs:domain ind:AssetCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetStakeholderConcernId rdf:type rdf:Property ;
    rdfs:label 'Asset Stakeholder Concern Id' ;
    rdfs:comment 'Unique identifier for each asset-stakeholder concern record. Primary key for the association.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concernCategory rdf:type rdf:Property ;
    rdfs:label 'Concern Category' ;
    rdfs:comment 'Classification of the type of concern or impact the stakeholder has regarding this specific asset. Identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concernDescription rdf:type rdf:Property ;
    rdfs:label 'Concern Description' ;
    rdfs:comment 'Free-text description of the specific concern this stakeholder has about this asset, including context and stakeholder perspective.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concernRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Concern Raised Date' ;
    rdfs:comment 'Date when the stakeholder first raised this concern about the asset. Establishes the timeline for the concern relationship.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concernResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Concern Resolved Date' ;
    rdfs:comment 'Date when the concern was formally resolved to the stakeholder\'s satisfaction, if applicable.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grievanceLodged rdf:type rdf:Property ;
    rdfs:label 'Grievance Lodged' ;
    rdfs:comment 'Indicates whether the stakeholder has lodged a formal grievance through the grievance mechanism regarding this asset.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grievanceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Grievance Reference Number' ;
    rdfs:comment 'Reference number of the formal grievance lodged regarding this asset-stakeholder concern, if applicable.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Completed' ;
    rdfs:comment 'Indicates whether a formal impact assessment has been completed for this asset-stakeholder concern combination.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current status of mitigation measures implemented to address the stakeholder concern about this asset. Identified in detection phase relationship data.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Next Engagement Date' ;
    rdfs:comment 'Scheduled date for the next engagement activity with this stakeholder regarding this specific asset concern.' ;
    rdfs:domain ind:AssetStakeholderConcern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer' ;
    rdfs:comment 'Name or employee ID of the community relations officer responsible for managing this specific asset-stakeholder concern.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetContractCoverageId rdf:type rdf:Property ;
    rdfs:label 'Asset Contract Coverage Id' ;
    rdfs:comment 'Primary key for the asset_contract_coverage association' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedToContractDate rdf:type rdf:Property ;
    rdfs:label 'Added To Contract Date' ;
    rdfs:comment 'Date when this asset was formally added to the contract coverage. Used for audit trail and amendment tracking.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualCoverageValue rdf:type rdf:Property ;
    rdfs:label 'Annual Coverage Value' ;
    rdfs:comment 'Annualized monetary value of coverage for this specific asset under this contract. Used for cost allocation, budget tracking, and contract value analysis.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Date when contract coverage expires for this specific asset. Used to trigger renewal processes and prevent coverage gaps.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageNotes rdf:type rdf:Property ;
    rdfs:label 'Coverage Notes' ;
    rdfs:comment 'Free-text notes capturing special conditions, exclusions, or requirements specific to this asset-contract coverage (e.g., \'Excludes tire replacement\', \'Requires monthly inspection report\').' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'Date when contract coverage becomes effective for this specific asset. May differ from the master contract start date if assets are added mid-term.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of the coverage relationship: active (in force), suspended (temporarily paused), expired (coverage period ended), pending activation (scheduled future start), or cancelled (terminated early).' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Type of service coverage provided under this contract for this asset: full maintenance (parts and labor), parts supply only, labor only, preventive maintenance only, breakdown support only, telematics monitoring, or warranty extension.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedServiceHours rdf:type rdf:Property ;
    rdfs:label 'Included Service Hours' ;
    rdfs:comment 'Number of service labor hours included in the coverage for this asset during the coverage period. Nullable if coverage is parts-only or unlimited hours.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removedFromContractDate rdf:type rdf:Property ;
    rdfs:label 'Removed From Contract Date' ;
    rdfs:comment 'Date when this asset was removed from contract coverage (if applicable). Nullable for currently covered assets.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Contractually committed maximum response time in hours for service calls on this asset. Used for SLA compliance monitoring and vendor performance measurement.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'SLA tier or service level commitment applicable to this asset under this contract (e.g., gold, silver, bronze). Defines priority, response times, and service scope.' ;
    rdfs:domain ind:AssetContractCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockpileTenementContributionId rdf:type rdf:Property ;
    rdfs:label 'Stockpile Tenement Contribution Id' ;
    rdfs:comment 'Unique surrogate identifier for each stockpile-tenement contribution record' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageGradePct rdf:type rdf:Property ;
    rdfs:label 'Average Grade Pct' ;
    rdfs:comment 'Average assay grade (%) of the concentrate contributed from this tenement during the source production period. Used for blend quality reconciliation and tenement performance tracking.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'Percentage of the stockpile\'s total inventory contributed by this tenement, calculated as (contribution_tonnage_dmt / stockpile.inventory_dmt) * 100. Used for blend composition reporting.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionTonnageDmt rdf:type rdf:Property ;
    rdfs:label 'Contribution Tonnage Dmt' ;
    rdfs:comment 'Dry metric tonnes of concentrate contributed from this tenement to this stockpile during the source production period. Used for royalty allocation and origin certification.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordedDate rdf:type rdf:Property ;
    rdfs:label 'Recorded Date' ;
    rdfs:comment 'Timestamp when this contribution record was created in the system, typically when material from the tenement was added to the stockpile.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:royaltyAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Allocation Amount' ;
    rdfs:comment 'Calculated royalty amount (in local currency) attributable to this tenement\'s contribution to the stockpile, based on contribution tonnage and the tenement\'s royalty rate. Used for financial accrual and payment processing.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceProductionPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Source Production Period End' ;
    rdfs:comment 'End date of the production period during which this tenement\'s material was added to the stockpile. Supports traceability and time-based royalty calculations.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceProductionPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Source Production Period Start' ;
    rdfs:comment 'Start date of the production period during which this tenement\'s material was added to the stockpile. Supports traceability and time-based royalty calculations.' ;
    rdfs:domain ind:StockpileTenementContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorTenementEngagementId rdf:type rdf:Property ;
    rdfs:label 'Contractor Tenement Engagement Id' ;
    rdfs:comment 'Primary key for contractor_tenement_engagement' ;
    rdfs:domain ind:ContractorTenementEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Unique identifier for this contractor-tenement engagement record. Primary key.' ;
    rdfs:domain ind:ContractorTenementEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Description of the contractor\'s work scope and responsibilities at this specific tenement. Varies by site and engagement.' ;
    rdfs:domain ind:ContractorTenementEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Project Cost Allocation Id' ;
    rdfs:comment 'Unique surrogate key identifying each cost centre to capital project allocation record' ;
    rdfs:domain ind:ProjectCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCostCentreSpendId rdf:type rdf:Property ;
    rdfs:label 'Vendor Cost Centre Spend Id' ;
    rdfs:comment 'Unique surrogate key identifying each vendor-cost centre spend relationship record' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyVendorId rdf:type rdf:Property ;
    rdfs:label 'Supply Vendor Id' ;
    rdfs:comment 'Foreign key to procurement.vendor - the vendor supplying this cost centre' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:contractedAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Contracted Annual Spend' ;
    rdfs:comment 'The contracted or budgeted annual spend limit for this cost centre with this specific vendor, used for spend control and vendor allocation planning' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPoDate rdf:type rdf:Property ;
    rdfs:label 'Last Po Date' ;
    rdfs:comment 'Date of the most recent purchase order issued by this cost centre to this vendor, used to identify inactive vendor relationships' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsOverride rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Override' ;
    rdfs:comment 'Cost-centre-specific payment terms that override the vendor\'s default payment terms, negotiated for specific sites or operational units' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poCountYtd rdf:type rdf:Property ;
    rdfs:label 'Po Count Ytd' ;
    rdfs:comment 'Number of purchase orders issued by this cost centre to this vendor in the current fiscal year, used for vendor performance and procurement activity analysis' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date when this cost centre first began procuring from this vendor, establishing the vendor-cost centre relationship' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendYtd rdf:type rdf:Property ;
    rdfs:label 'Spend Ytd' ;
    rdfs:comment 'Cumulative actual spend posted to this cost centre from this vendor in the current fiscal year, used for budget tracking and variance analysis' ;
    rdfs:domain ind:VendorCostCentreSpend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Rating' ;
    rdfs:comment 'Performance rating assigned by this cost centre to this vendor based on delivery timeliness, quality, and service, specific to this cost centre\'s experience' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerProjectContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Project Contract Id' ;
    rdfs:comment 'Primary key for customer_project_contract' ;
    rdfs:domain ind:CustomerProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingMilestone rdf:type rdf:Property ;
    rdfs:label 'Billing Milestone' ;
    rdfs:comment 'Description of the billing milestone or payment schedule terms for this contract (e.g., \'30% on mobilization, 60% on progress, 10% on completion\'). Used for cash flow planning and payment processing.' ;
    rdfs:domain ind:CustomerProjectContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderEngagementId rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Engagement Id' ;
    rdfs:comment 'Unique identifier for this stakeholder engagement relationship record. Primary key for the association.' ;
    rdfs:domain ind:StakeholderEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designationAuthority rdf:type rdf:Property ;
    rdfs:label 'Designation Authority' ;
    rdfs:comment 'Name or role of the person or body that authorized this engagement designation (e.g., Community Relations Manager, Site General Manager). Used for governance and accountability.' ;
    rdfs:domain ind:StakeholderEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRole rdf:type rdf:Property ;
    rdfs:label 'Engagement Role' ;
    rdfs:comment 'Specific role or function the employee performs in engaging with this stakeholder. May include responsibilities such as consultation lead, benefit negotiation, cultural protocol advisor, or grievance resolution coordinator.' ;
    rdfs:domain ind:StakeholderEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent documented interaction between this employee and this stakeholder. Used for tracking engagement frequency and relationship maintenance.' ;
    rdfs:domain ind:StakeholderEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this employee is the primary/lead contact for this stakeholder. True means this is the main point of contact; false indicates a supporting or secondary role. Used for escalation protocols and communication routing.' ;
    rdfs:domain ind:StakeholderEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeholderConsultationId rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Consultation Id' ;
    rdfs:comment 'Unique surrogate identifier for each stakeholder consultation record' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consultationConductedBy rdf:type rdf:Property ;
    rdfs:label 'Consultation Conducted By' ;
    rdfs:comment 'Name or identifier of the company representative or team who conducted this consultation. Used for accountability and follow-up.' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationOutcome rdf:type rdf:Property ;
    rdfs:label 'Consultation Outcome' ;
    rdfs:comment 'Free-text summary of the consultation outcome, including key concerns raised, commitments made, and any conditions attached to stakeholder support.' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementPhase rdf:type rdf:Property ;
    rdfs:label 'Engagement Phase' ;
    rdfs:comment 'The mine lifecycle phase during which this consultation occurred. Critical for tracking consultation requirements across different regulatory and planning stages.' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextConsultationRequiredDate rdf:type rdf:Property ;
    rdfs:label 'Next Consultation Required Date' ;
    rdfs:comment 'The date by which follow-up consultation with this stakeholder on this LOM plan is required, based on regulatory requirements or agreement terms.' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The method used to notify and engage this stakeholder about this LOM plan. Must align with stakeholder\'s preferred communication channel and cultural considerations.' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementMet rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Met' ;
    rdfs:comment 'Indicates whether this consultation satisfied applicable regulatory requirements for stakeholder engagement (e.g., Environmental Impact Assessment consultation requirements).' ;
    rdfs:domain ind:StakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementStakeholderConsultationId rdf:type rdf:Property ;
    rdfs:label 'Agreement Stakeholder Consultation Id' ;
    rdfs:comment 'Primary key for the agreement_stakeholder_consultation association' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Acceptance Date' ;
    rdfs:comment 'Date on which this stakeholder formally accepted or provided consent for this offtake agreement. Null if consent not yet obtained or not required.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitEntitlementPercentage rdf:type rdf:Property ;
    rdfs:label 'Benefit Entitlement Percentage' ;
    rdfs:comment 'Percentage of revenue or benefits from this specific offtake agreement that this stakeholder is entitled to receive under benefit-sharing arrangements. Null if stakeholder has no financial entitlement.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Free-text description of any conditions or requirements this stakeholder imposed as part of their consent or consultation response for this agreement. May include environmental conditions, benefit requirements, or operational constraints.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationMethod rdf:type rdf:Property ;
    rdfs:label 'Consultation Method' ;
    rdfs:comment 'The method or process used to consult this stakeholder on this agreement. Captures whether traditional protocols, FPIC processes, or regulatory hearings were used.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consultationStatus rdf:type rdf:Property ;
    rdfs:label 'Consultation Status' ;
    rdfs:comment 'Current status of the consultation process with this stakeholder for this agreement. Tracks progress through the engagement lifecycle.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stakeholderRole rdf:type rdf:Property ;
    rdfs:label 'Stakeholder Role' ;
    rdfs:comment 'The specific role this stakeholder plays in relation to this offtake agreement. Consulted party indicates formal consultation requirement, consent authority indicates FPIC or regulatory approval authority, beneficiary indicates entitled to benefits from the agreement.' ;
    rdfs:domain ind:AgreementStakeholderConsultation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orebodyPermitId rdf:type rdf:Property ;
    rdfs:label 'Orebody Permit Id' ;
    rdfs:comment 'Unique identifier for this orebody-permit authorization relationship. Primary key.' ;
    rdfs:domain ind:OrebodyPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextMonitoringDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Due Date' ;
    rdfs:comment 'Date by which the next environmental monitoring activity must be completed for this orebody-permit combination.' ;
    rdfs:domain ind:OrebodyPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orebodySpecificConditions rdf:type rdf:Property ;
    rdfs:label 'Orebody Specific Conditions' ;
    rdfs:comment 'Free-text description of any special permit conditions that apply specifically to extraction from this orebody (e.g., seasonal restrictions, proximity to sensitive areas, specific mitigation measures).' ;
    rdfs:domain ind:OrebodyPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedExtractionVolume rdf:type rdf:Property ;
    rdfs:label 'Permitted Extraction Volume' ;
    rdfs:comment 'Maximum volume or tonnage of material authorized for extraction from this specific orebody under this permit. Varies by orebody-permit combination based on environmental impact assessments and regulatory approvals.' ;
    rdfs:domain ind:OrebodyPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedExtractionVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Permitted Extraction Volume Unit' ;
    rdfs:comment 'Unit of measure for the permitted extraction volume (tonnes, cubic meters, million tonnes).' ;
    rdfs:domain ind:OrebodyPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orebodyAllocationId rdf:type rdf:Property ;
    rdfs:label 'Orebody Allocation Id' ;
    rdfs:comment 'Unique identifier for this orebody-to-offtake allocation record. Primary key.' ;
    rdfs:domain ind:OrebodyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedVolumeTonnes rdf:type rdf:Property ;
    rdfs:label 'Allocated Volume Tonnes' ;
    rdfs:comment 'Total volume of material in metric tonnes allocated from this orebody to fulfill this specific offtake agreement. This is a commitment volume that drives mine planning and production scheduling.' ;
    rdfs:domain ind:OrebodyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority ranking for this allocation when multiple offtake agreements draw from the same orebody. Lower numbers indicate higher priority. Used in production scheduling and allocation optimization.' ;
    rdfs:domain ind:OrebodyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendingStrategy rdf:type rdf:Property ;
    rdfs:label 'Blending Strategy' ;
    rdfs:comment 'Description of the blending approach used when this orebody is combined with others to meet the offtake agreement specification. Captures operational knowledge for mine planning and metallurgical processing.' ;
    rdfs:domain ind:OrebodyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSpecification rdf:type rdf:Property ;
    rdfs:label 'Product Specification' ;
    rdfs:comment 'Specific product grade or quality specification that this orebody must meet to fulfill this offtake agreement (e.g., \'Fines 62% Fe\', \'Lump 64% Fe\', \'Coking Coal Premium\'). Drives blending strategies when a single orebody supplies multiple specifications or multiple orebodies blend to meet one specification.' ;
    rdfs:domain ind:OrebodyAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCompetencyRequirementId rdf:type rdf:Property ;
    rdfs:label 'Position Competency Requirement Id' ;
    rdfs:comment 'Unique identifier for this position-competency requirement record. Primary key for the association.' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Onboarding Grace Period Days' ;
    rdfs:comment 'Number of days after position commencement within which this competency must be attained if not held at hire. Null if competency must be held before position start. Used for workforce planning and training scheduling.' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCompetencies rdf:type rdf:Property ;
    rdfs:label 'Required Competencies' ;
    rdfs:comment 'Comma-separated list of mandatory competencies, certifications, or qualifications required for the position (e.g., First Aid, Confined Space Entry, Shotfirer License, Engineering Degree). Used for compliance and succession planning. [Moved from position: This STRING field in position contains a comma-separated list of competency codes, which is a denormalized representation of the M:N relationship. This data belongs in the association table as individual position_competency_requirement records, enabling proper normalization, competency gap queries, and proficiency-level tracking per competency per position.]' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Verification Frequency Months' ;
    rdfs:comment 'The frequency (in months) at which this competency requirement should be verified for incumbents in this position. Used for compliance auditing and competency gap monitoring. This attribute was explicitly identified in the detection phase relationship data.' ;
    rdfs:domain ind:PositionCompetencyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circuitDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Circuit Delivery Id' ;
    rdfs:comment 'Unique surrogate identifier for this circuit delivery record, serving as the primary key for the association between a capital project and a processing circuit' ;
    rdfs:domain ind:CircuitDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryCost rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Cost' ;
    rdfs:comment 'Actual capital expenditure incurred to deliver this specific processing circuit as part of the broader capital project. Used for cost tracking and variance analysis at circuit level.' ;
    rdfs:domain ind:CircuitDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectsLiabilityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Months' ;
    rdfs:comment 'Duration in months of the defects liability period during which the project team or contractor remains responsible for rectifying defects in the delivered circuit. Typically 12-24 months from provisional acceptance.' ;
    rdfs:domain ind:CircuitDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Final Acceptance Date' ;
    rdfs:comment 'Date on which the processing circuit received final acceptance after successful completion of the defects liability period, formally closing out the project delivery obligation' ;
    rdfs:domain ind:CircuitDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionalAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Acceptance Date' ;
    rdfs:comment 'Date on which the processing circuit was provisionally accepted by operations, marking the start of the defects liability period and transfer of operational responsibility' ;
    rdfs:domain ind:CircuitDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plantContractorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Plant Contractor Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for this specific engagement relationship between a processing plant and a contractor. Primary key.' ;
    rdfs:domain ind:PlantContractorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyRateAud rdf:type rdf:Property ;
    rdfs:label 'Daily Rate Aud' ;
    rdfs:comment 'Daily billing rate in Australian dollars for this contractor at this specific plant. May vary by plant due to remoteness, FIFO arrangements, or specialized equipment requirements.' ;
    rdfs:domain ind:PlantContractorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the permit-to-work authorization for this contractor engagement at this plant. Links to HSE permit management system for high-risk work activities.' ;
    rdfs:domain ind:PlantContractorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessZones rdf:type rdf:Property ;
    rdfs:label 'Site Access Zones' ;
    rdfs:comment 'Comma-separated list of plant zones and areas this contractor is authorized to access for this engagement (e.g., \'crushing-circuit,flotation-area,control-room,maintenance-workshop\'). Plant-specific access control.' ;
    rdfs:domain ind:PlantContractorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workScope rdf:type rdf:Property ;
    rdfs:label 'Work Scope' ;
    rdfs:comment 'Detailed description of the work scope and responsibilities for this contractor at this specific processing plant (e.g., \'SAG mill maintenance\', \'flotation circuit electrical work\', \'shutdown campaign - conveyor systems\').' ;
    rdfs:domain ind:PlantContractorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCrewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Schedule Crew Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each production schedule crew assignment record' ;
    rdfs:domain ind:ScheduleCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewRole rdf:type rdf:Property ;
    rdfs:label 'Crew Role' ;
    rdfs:comment 'The specific operational role this crew performs within this production schedule (e.g., drilling, blasting, loading, hauling). Identified in detection phase as relationship-specific data. A crew may have different roles in different schedules.' ;
    rdfs:domain ind:ScheduleCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'The total planned hours this crew is allocated to work on this production schedule. Identified in detection phase as relationship-specific data. Used for capacity planning and cost estimation.' ;
    rdfs:domain ind:ScheduleCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedShiftCount rdf:type rdf:Property ;
    rdfs:label 'Planned Shift Count' ;
    rdfs:comment 'The number of shifts this crew is planned to work on this production schedule during the assignment period. Derived from scheduled dates and crew roster pattern.' ;
    rdfs:domain ind:ScheduleCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'The date when this crew is scheduled to complete work on this production schedule. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:ScheduleCrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prospectProcessingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Prospect Processing Campaign Id' ;
    rdfs:comment 'Unique identifier for this prospect-plant processing campaign record. Primary key.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageRecoveryAchieved rdf:type rdf:Property ;
    rdfs:label 'Average Recovery Achieved' ;
    rdfs:comment 'Actual average metallurgical recovery rate achieved for ore from this prospect when processed through this plant, expressed as percentage (0-100). Tracks real performance vs nameplate.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blendPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Blend Percentage Target' ;
    rdfs:comment 'Target percentage (0-100) of this prospects ore in the plant feed blend when multiple prospects are being processed simultaneously. Used for blending optimization.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeTonnesProcessed rdf:type rdf:Property ;
    rdfs:label 'Cumulative Tonnes Processed' ;
    rdfs:comment 'Total cumulative tonnage of ore from this prospect that has been processed through this plant, measured in metric tonnes. Updated as processing occurs.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreRoutingPriority rdf:type rdf:Property ;
    rdfs:label 'Ore Routing Priority' ;
    rdfs:comment 'Business priority classification for routing ore from this prospect to this plant. Primary = preferred plant; secondary = backup plant; opportunistic = capacity-dependent; trial = test campaign.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndDate rdf:type rdf:Property ;
    rdfs:label 'Processing End Date' ;
    rdfs:comment 'Date when ore from this prospect ceased being processed through this plant for this campaign. Null if currently active.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingStartDate rdf:type rdf:Property ;
    rdfs:label 'Processing Start Date' ;
    rdfs:comment 'Date when ore from this prospect first entered this processing plant for this campaign or processing period.' ;
    rdfs:domain ind:ProspectProcessingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prospectProcessingRouteId rdf:type rdf:Property ;
    rdfs:label 'Prospect Processing Route Id' ;
    rdfs:comment 'Unique identifier for this prospect-circuit routing relationship record. Primary key.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageFeedGradePct rdf:type rdf:Property ;
    rdfs:label 'Average Feed Grade Pct' ;
    rdfs:comment 'Average head grade of ore from this prospect when fed to this circuit, expressed as percentage of primary commodity. Tracks prospect-specific feed characteristics.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageRecovery rdf:type rdf:Property ;
    rdfs:label 'Average Recovery' ;
    rdfs:comment 'Average metallurgical recovery rate achieved for ore from this prospect when processed through this circuit, expressed as a percentage. Tracks circuit-specific performance by ore source.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circuitAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Circuit Assignment Date' ;
    rdfs:comment 'Date when this prospect ore was first routed to this specific processing circuit. Tracks when the routing relationship was established.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:circuitSuitabilityRating rdf:type rdf:Property ;
    rdfs:label 'Circuit Suitability Rating' ;
    rdfs:comment 'Metallurgical assessment of how suitable this circuit is for processing ore from this prospect based on ore characteristics and circuit design. Values: Optimal, Suitable, Marginal, Unsuitable.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Last Processed Date' ;
    rdfs:comment 'Date when ore from this prospect was most recently processed through this circuit. Tracks recency of the routing relationship.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCommodityTarget rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity Target' ;
    rdfs:comment 'Primary commodity being targeted for recovery when processing this prospect ore through this circuit (e.g., copper, gold, iron ore). May differ from prospect primary commodity if circuit is optimized for specific recovery.' ;
    rdfs:domain ind:ProspectProcessingRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of this prospect-circuit routing relationship. Values: Active (currently processing), Inactive (temporarily suspended), Planned (future routing), Decommissioned (no longer used).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentId rdf:type rdf:Property ;
    rdfs:label 'Deployment Id' ;
    rdfs:comment 'Unique identifier for each equipment deployment assignment record. Primary key.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Code' ;
    rdfs:comment 'Financial cost center or WBS element code to which equipment operating costs and utilization hours are allocated for this deployment. Used for prospect-level cost tracking and financial reporting.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current operational status of the equipment deployment assignment (planned, active, suspended, completed, cancelled). Used for resource planning and deployment tracking.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Operational role or function of the equipment asset during this deployment to the prospect (e.g., drilling, trenching, sampling, geophysical survey, site preparation). Used for activity-based cost allocation and resource planning.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationHours rdf:type rdf:Property ;
    rdfs:label 'Utilization Hours' ;
    rdfs:comment 'Total operational hours the equipment asset was actively utilized on exploration activities for this prospect during the deployment period. Used for cost allocation, productivity analysis, and equipment performance tracking.' ;
    rdfs:domain ind:Deployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prospectVendorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Prospect Vendor Engagement Id' ;
    rdfs:comment 'Unique identifier for this prospect-vendor engagement record. Primary key.' ;
    rdfs:domain ind:ProspectVendorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenementRecoveryTargetId rdf:type rdf:Property ;
    rdfs:label 'Tenement Recovery Target Id' ;
    rdfs:comment 'Primary key for tenement_recovery_target' ;
    rdfs:domain ind:TenementRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenementContributionPct rdf:type rdf:Property ;
    rdfs:label 'Tenement Contribution Pct' ;
    rdfs:comment 'Percentage of the total recovery target throughput that is expected to come from this specific tenement' ;
    rdfs:domain ind:TenementRecoveryTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockpileCircuitFeedId rdf:type rdf:Property ;
    rdfs:label 'Stockpile Circuit Feed Id' ;
    rdfs:comment 'Unique surrogate identifier for the stockpile-circuit feed relationship record. Primary key.' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blendRatioPct rdf:type rdf:Property ;
    rdfs:label 'Blend Ratio Pct' ;
    rdfs:comment 'Target percentage contribution of this stockpile to the total feed blend for this circuit. Used in multi-stockpile blending strategies to achieve target feed grade and quality.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conveyorRouteCode rdf:type rdf:Property ;
    rdfs:label 'Conveyor Route Code' ;
    rdfs:comment 'Code identifying the conveyor system route used to transport material from this stockpile to this circuit. Supports logistics and maintenance planning.' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedPriority rdf:type rdf:Property ;
    rdfs:label 'Feed Priority' ;
    rdfs:comment 'Integer ranking indicating the priority order in which this stockpile should feed this specific circuit. Lower numbers indicate higher priority. Used when multiple stockpiles can feed the same circuit.' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedStatus rdf:type rdf:Property ;
    rdfs:label 'Feed Status' ;
    rdfs:comment 'Current operational status of this stockpile-circuit feed relationship. Active = currently feeding, Planned = scheduled future feed, Suspended = temporarily halted, Completed = historical feed relationship ended.' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclaimMethod rdf:type rdf:Property ;
    rdfs:label 'Reclaim Method' ;
    rdfs:comment 'Method used to reclaim material from this stockpile for feeding this circuit (e.g., Front-End Loader, Reclaimer, Apron Feeder). Drives operational planning and equipment allocation.' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclaimPriority rdf:type rdf:Property ;
    rdfs:label 'Reclaim Priority' ;
    rdfs:comment 'Integer ranking indicating the priority order in which this stockpile should be reclaimed to the processing plant feed. Lower number = higher priority. Used by plant feed scheduling to manage blend quality and FIFO/grade-based reclaim strategies. [Moved from rom_stockpile: Reclaim priority is not an absolute property of the ROM stockpile itself, but rather depends on which circuit is being fed. A stockpile may have high priority for one circuit (e.g., oxide ore to leach circuit) but low priority for another (e.g., same stockpile to flotation circuit). This attribute belongs in the association as feed_priority.]' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reclaimRateTHr rdf:type rdf:Property ;
    rdfs:label 'Reclaim Rate T Hr' ;
    rdfs:comment 'Design or operational reclaim rate of material from this stockpile to the processing plant in tonnes per hour. Used for plant feed scheduling and production planning. [Moved from rom_stockpile: Reclaim rate varies by destination circuit based on circuit capacity, feed requirements, and blending strategy. A stockpile may feed different circuits at different rates. This attribute belongs in the association as feed_rate_tph.]' ;
    rdfs:domain ind:StockpileCircuitFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockpileBlendId rdf:type rdf:Property ;
    rdfs:label 'Stockpile Blend Id' ;
    rdfs:comment 'Unique surrogate identifier for this ROM stockpile to saleable product blend record. Primary key.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReclaimTonnes rdf:type rdf:Property ;
    rdfs:label 'Actual Reclaim Tonnes' ;
    rdfs:comment 'Actual tonnes reclaimed from this ROM stockpile for this saleable product blend to date. Used for reconciliation against target and inventory tracking.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blendRecipeVersion rdf:type rdf:Property ;
    rdfs:label 'Blend Recipe Version' ;
    rdfs:comment 'Version identifier for the blend recipe specification. Blend recipes are versioned as they are refined based on actual quality outcomes and changing stockpile characteristics.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityContributionFePct rdf:type rdf:Property ;
    rdfs:label 'Quality Contribution Fe Pct' ;
    rdfs:comment 'Contribution of this ROM stockpile to the iron (Fe) grade of the final saleable product, expressed as percentage. Used for blend quality modeling and product specification achievement. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityContributionSio2Pct rdf:type rdf:Property ;
    rdfs:label 'Quality Contribution Sio2 Pct' ;
    rdfs:comment 'Contribution of this ROM stockpile to the silica (SiO2) content of the final saleable product, expressed as percentage. Critical for managing impurity levels in product specifications. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reclaimSequence rdf:type rdf:Property ;
    rdfs:label 'Reclaim Sequence' ;
    rdfs:comment 'Integer indicating the order in which this ROM stockpile should be reclaimed when producing this saleable product. Governs operational scheduling of reclaim equipment and material flow to processing plant. Identified in detection phase relationship data.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReclaimTonnes rdf:type rdf:Property ;
    rdfs:label 'Target Reclaim Tonnes' ;
    rdfs:comment 'Planned tonnes to be reclaimed from this ROM stockpile for this saleable product blend over the effective period. Used for production planning and stockpile inventory management.' ;
    rdfs:domain ind:StockpileBlend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Specification Assignment Id' ;
    rdfs:comment 'Unique identifier for each product specification assignment record. Primary key.' ;
    rdfs:domain ind:SpecificationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Flag' ;
    rdfs:comment 'Indicates whether this specification assignment is customer-specific (true) or applies to general market sales (false). Enables differentiated specifications for different customer segments.' ;
    rdfs:domain ind:SpecificationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractAllocationId rdf:type rdf:Property ;
    rdfs:label 'Contract Allocation Id' ;
    rdfs:comment 'Unique system identifier for the tenement-contract allocation record. Primary key.' ;
    rdfs:domain ind:ContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedByUser rdf:type rdf:Property ;
    rdfs:label 'Allocated By User' ;
    rdfs:comment 'Username or identifier of the person who created or last modified this allocation record. Supports audit trail and accountability.' ;
    rdfs:domain ind:ContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The date on which this allocation record was created or last modified in the system. Supports audit trail and change tracking.' ;
    rdfs:domain ind:ContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationReason rdf:type rdf:Property ;
    rdfs:label 'Allocation Reason' ;
    rdfs:comment 'Business justification or reason for allocating this contract to this tenement (e.g., \'Drilling services for exploration program\', \'Equipment hire for site development\', \'Shared infrastructure maintenance\').' ;
    rdfs:domain ind:ContractAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSiteAccessId rdf:type rdf:Property ;
    rdfs:label 'Vendor Site Access Id' ;
    rdfs:comment 'Primary key uniquely identifying each vendor-tenement authorization record' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'Access Revocation Date' ;
    rdfs:comment 'Date when site access was revoked for this vendor on this tenement, if applicable.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedActivities rdf:type rdf:Property ;
    rdfs:label 'Approved Activities' ;
    rdfs:comment 'Comma-separated list or description of specific activities the vendor is authorized to perform on this tenement (e.g., \'explosives delivery\', \'drilling services\', \'reagent supply\', \'equipment maintenance\'). Scope of work is tenement-specific.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s authorization for this tenement expires and must be renewed. Driven by insurance, certification, or contract term requirements.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Start Date' ;
    rdfs:comment 'Date when the vendor\'s authorization to operate on this tenement became effective.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Date' ;
    rdfs:comment 'Date when insurance coverage was last verified for this vendor-tenement combination.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Flag' ;
    rdfs:comment 'Indicates whether the vendor\'s insurance coverage has been verified as adequate for the activities on this specific tenement.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSiteVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Site Visit Date' ;
    rdfs:comment 'Date of the vendor\'s most recent visit or service delivery to this tenement. Used for activity tracking and access audit.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation of why site access was revoked for this vendor on this tenement (e.g., safety incident, contract termination, compliance breach).' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactName rdf:type rdf:Property ;
    rdfs:label 'Site Contact Name' ;
    rdfs:comment 'Name of the vendor\'s designated contact person for this specific tenement site. May differ from the vendor\'s primary contact.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactPhone rdf:type rdf:Property ;
    rdfs:label 'Site Contact Phone' ;
    rdfs:comment 'Phone number of the vendor\'s site-specific contact for this tenement.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteInductionCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Site Induction Completed Flag' ;
    rdfs:comment 'Indicates whether the vendor has completed the mandatory site-specific safety and operational induction for this tenement. Required before physical site access is permitted.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteInductionDate rdf:type rdf:Property ;
    rdfs:label 'Site Induction Date' ;
    rdfs:comment 'Date when the vendor completed the site-specific induction training for this tenement.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteInductionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Site Induction Expiry Date' ;
    rdfs:comment 'Date when the site induction expires and must be renewed. Typically annual or biennial depending on site requirements.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenementSpecificConditions rdf:type rdf:Property ;
    rdfs:label 'Tenement Specific Conditions' ;
    rdfs:comment 'Special conditions, restrictions, or requirements imposed on this vendor for this specific tenement. May include environmental restrictions, heritage site protocols, or operational limitations unique to the site.' ;
    rdfs:domain ind:VendorSiteAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Primary key for purchase_order' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Primary key for vendor_performance' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the land compensation or benefit-sharing agreement that mandates this trust fund.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitSharingAgreement .

ind:annualContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Contribution Amount' ;
    rdfs:comment 'The committed annual contribution amount from the mining operation to the trust fund.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'The scheduled frequency at which independent audits of the trust fund are conducted.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'The current total balance of the trust fund including all contributions, earnings, and disbursements to date.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementFrequency rdf:type rdf:Property ;
    rdfs:label 'Disbursement Frequency' ;
    rdfs:comment 'The scheduled frequency at which funds are disbursed to beneficiaries or projects.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Description of the criteria that individuals or groups must meet to qualify as beneficiaries of the fund.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'The date on which the beneficiary trust fund was formally established and became operational.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the trust fund for internal tracking and reporting purposes.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'The official name of the beneficiary trust fund established for community benefit sharing.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundPurposeDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Purpose Description' ;
    rdfs:comment 'Detailed description of the intended purpose and objectives of the trust fund as defined in the trust deed.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current operational status of the beneficiary trust fund in its lifecycle.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'Classification of the trust fund based on its primary purpose and benefit area.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceMechanismAvailable rdf:type rdf:Property ;
    rdfs:label 'Grievance Mechanism Available' ;
    rdfs:comment 'Indicates whether a formal grievance mechanism is available for beneficiaries to raise concerns about fund management.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Capital Amount' ;
    rdfs:comment 'The initial capital contribution made to establish the trust fund at inception.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy' ;
    rdfs:comment 'Description of the investment approach used to grow the trust fund capital while managing risk.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold' ;
    rdfs:comment 'The minimum balance that must be maintained in the trust fund to ensure sustainability.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingRequirements rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirements' ;
    rdfs:comment 'Description of the reporting obligations and transparency requirements for the trust fund to stakeholders.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Sustainability End Date' ;
    rdfs:comment 'The projected date until which the trust fund is expected to remain sustainable based on current balance and disbursement rates.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Indicates whether the trust fund has been granted tax-exempt status by relevant authorities.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDisbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Disbursed Amount' ;
    rdfs:comment 'Cumulative total amount disbursed from the trust fund since establishment.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trusteeContactPerson rdf:type rdf:Property ;
    rdfs:label 'Trustee Contact Person' ;
    rdfs:comment 'Name of the primary contact person at the trustee organization for fund administration matters.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Trustee Email Address' ;
    rdfs:comment 'Primary email address for communication with the trustee organization.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Trustee Organization Name' ;
    rdfs:comment 'Name of the organization or entity serving as the trustee responsible for managing the fund.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Trustee Phone Number' ;
    rdfs:comment 'Primary contact phone number for the trustee organization.' ;
    rdfs:domain ind:BeneficiaryTrustFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualProductionCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Production Capacity Tonnes' ;
    rdfs:comment 'Nameplate annual production capacity of the mine site in metric tonnes of ore or product.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityPrimary rdf:type rdf:Property ;
    rdfs:label 'Commodity Primary' ;
    rdfs:comment 'The primary mineral or ore extracted at this mine site.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySecondary rdf:type rdf:Property ;
    rdfs:label 'Commodity Secondary' ;
    rdfs:comment 'Secondary or by-product minerals extracted at this mine site, if applicable. Comma-separated list.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJointVenture rdf:type rdf:Property ;
    rdfs:label 'Is Joint Venture' ;
    rdfs:comment 'Indicates whether the mine site is operated as a joint venture with other mining companies.' ;
    rdfs:domain ind:MineSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the current mining lease or permit expires. Nullable for indefinite leases subject to renewal.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Number' ;
    rdfs:comment 'Official mining lease or permit number issued by the regulatory authority.' ;
    rdfs:domain ind:MineSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Date when the mining lease or permit became effective.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nearestTown rdf:type rdf:Property ;
    rdfs:label 'Nearest Town' ;
    rdfs:comment 'Name of the nearest populated town or city to the mine site.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCompany rdf:type rdf:Property ;
    rdfs:label 'Operating Company' ;
    rdfs:comment 'Legal name of the company or joint venture entity that operates the mine site.' ;
    rdfs:domain ind:MineSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Current safety performance rating of the mine site based on incident frequency and severity metrics.' ;
    rdfs:domain ind:MineSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceCount rdf:type rdf:Property ;
    rdfs:label 'Workforce Count' ;
    rdfs:comment 'Total number of employees and contractors working at the mine site.' ;
    rdfs:domain ind:MineSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landParcelId rdf:type rdf:Property ;
    rdfs:label 'Land Parcel Id' ;
    rdfs:comment 'Primary key for land_parcel' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Compensation Agreement Id' ;
    rdfs:comment 'Reference identifier for the land compensation or benefit-sharing agreement associated with this parcel.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandCompensationAgreement .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'Method or mechanism through which the land parcel rights were acquired by the mining company.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Annual Lease Payment' ;
    rdfs:comment 'Annual payment amount required under lease or license agreement for ongoing land access rights.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Boundary Description' ;
    rdfs:comment 'Textual description of the land parcel boundaries including metes and bounds or reference to survey plans.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadastralLotNumber rdf:type rdf:Property ;
    rdfs:label 'Cadastral Lot Number' ;
    rdfs:comment 'Official lot number assigned by the government land registry or cadastral authority for legal land identification.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heritageSitePresent rdf:type rdf:Property ;
    rdfs:label 'Heritage Site Present' ;
    rdfs:comment 'Indicates whether cultural heritage sites or areas of archaeological significance are present on the land parcel.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdsAffected rdf:type rdf:Property ;
    rdfs:label 'Households Affected' ;
    rdfs:comment 'Number of households affected by land acquisition or mining operations on this parcel requiring compensation or resettlement.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landAccessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Land Access Restrictions' ;
    rdfs:comment 'Description of any restrictions on land access including seasonal restrictions, cultural protocols, or environmental constraints.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landUseCategory rdf:type rdf:Property ;
    rdfs:label 'Land Use Category' ;
    rdfs:comment 'Primary designated use of the land parcel within the mining operation context.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Expiration or termination date of the lease or license agreement, nullable for perpetual or freehold parcels.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current ownership or control status of the land parcel indicating the legal relationship between the mining company and the land.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelName rdf:type rdf:Property ;
    rdfs:label 'Parcel Name' ;
    rdfs:comment 'Common name or designation of the land parcel used for business reference and communication.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Parcel Reference Number' ;
    rdfs:comment 'External business identifier or cadastral reference number assigned to the land parcel by government land registry or internal tracking system.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelStatus rdf:type rdf:Property ;
    rdfs:label 'Parcel Status' ;
    rdfs:comment 'Current lifecycle status of the land parcel in relation to mining operations and community engagement activities.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parcelType rdf:type rdf:Property ;
    rdfs:label 'Parcel Type' ;
    rdfs:comment 'Classification of the land parcel based on ownership or tenure type relevant to mining operations.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehabilitationObligation rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Obligation' ;
    rdfs:comment 'Indicates whether the mining company has a legal or contractual obligation to rehabilitate the land parcel after operations cease.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionAvailable rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Available' ;
    rdfs:comment 'Indicates whether the lease or license agreement includes an option for renewal upon expiration.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:titleDeedNumber rdf:type rdf:Property ;
    rdfs:label 'Title Deed Number' ;
    rdfs:comment 'Legal title deed or certificate number registered with the land authority establishing ownership or tenure rights.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Date when the most recent land valuation was performed.' ;
    rdfs:domain ind:LandParcel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageOreGradePercent rdf:type rdf:Property ;
    rdfs:label 'Average Ore Grade Percent' ;
    rdfs:comment 'Average grade or concentration of the primary commodity in the ore body, expressed as a percentage.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceToPortKm rdf:type rdf:Property ;
    rdfs:label 'Distance To Port Km' ;
    rdfs:comment 'Distance from the site to the primary export port measured in kilometers.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Average elevation of the site above sea level measured in meters.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasPortFacility rdf:type rdf:Property ;
    rdfs:label 'Has Port Facility' ;
    rdfs:comment 'Indicates whether the site includes or operates a dedicated port or ship loading facility.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasProcessingPlant rdf:type rdf:Property ;
    rdfs:label 'Has Processing Plant' ;
    rdfs:comment 'Indicates whether the site has an on-site ore processing or beneficiation plant.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasRailConnection rdf:type rdf:Property ;
    rdfs:label 'Has Rail Connection' ;
    rdfs:comment 'Indicates whether the site is connected to a rail network for product transportation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:miningLeaseNumber rdf:type rdf:Property ;
    rdfs:label 'Mining Lease Number' ;
    rdfs:comment 'Government-issued mining lease or tenement identifier authorizing extraction activities.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreReserveTonnes rdf:type rdf:Property ;
    rdfs:label 'Ore Reserve Tonnes' ;
    rdfs:comment 'Total proven and probable ore reserves at the site measured in tonnes, as per JORC or NI 43-101 standards.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryCommodities rdf:type rdf:Property ;
    rdfs:label 'Secondary Commodities' ;
    rdfs:comment 'Additional minerals or ores extracted as by-products at this site, comma-separated list.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteManagerName rdf:type rdf:Property ;
    rdfs:label 'Site Manager Name' ;
    rdfs:comment 'Full name of the current site manager or general manager responsible for operations.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workforceCapacity rdf:type rdf:Property ;
    rdfs:label 'Workforce Capacity' ;
    rdfs:comment 'Maximum number of personnel that can be accommodated at the site including employees and contractors.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Location Id' ;
    rdfs:comment 'Reference to the starting location of the haul route, typically a pit, bench, or stockpile.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:dustSuppressionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dust Suppression Required Flag' ;
    rdfs:comment 'Indicates whether active dust suppression measures are required on this route for environmental and health compliance.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpsWaypoints rdf:type rdf:Property ;
    rdfs:label 'Gps Waypoints' ;
    rdfs:comment 'Comma-separated list of GPS coordinate waypoints defining the haul route path for Fleet Management System (FMS) integration.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightingAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Lighting Available Flag' ;
    rdfs:comment 'Indicates whether the haul route has permanent lighting infrastructure for night shift operations.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Standard interval in days between scheduled maintenance activities for the haul route.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumGradientPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Gradient Percent' ;
    rdfs:comment 'Steepest gradient section along the haul route, critical for equipment selection and safety assessment.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVehicleCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Vehicle Capacity Tonnes' ;
    rdfs:comment 'Maximum payload capacity in tonnes that vehicles are permitted to carry on this route, constrained by road design and gradient.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date when the next planned maintenance activity is scheduled for the haul route.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfLanes rdf:type rdf:Property ;
    rdfs:label 'Number Of Lanes' ;
    rdfs:comment 'Count of traffic lanes on the haul route. Single-lane routes require passing bays.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permittedVehicleClass rdf:type rdf:Property ;
    rdfs:label 'Permitted Vehicle Class' ;
    rdfs:comment 'Classification of vehicles authorized to use this haul route based on size, weight, and operational capability.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadSurfaceType rdf:type rdf:Property ;
    rdfs:label 'Road Surface Type' ;
    rdfs:comment 'Type of road surface material used on the haul route, affecting rolling resistance and maintenance requirements.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadWidthM rdf:type rdf:Property ;
    rdfs:label 'Road Width M' ;
    rdfs:comment 'Width of the haul road in meters, determining the size and number of vehicles that can safely operate.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the haul route. Used for operational communication and dispatch systems.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeConditionRating rdf:type rdf:Property ;
    rdfs:label 'Route Condition Rating' ;
    rdfs:comment 'Current assessed condition of the haul route based on surface quality, drainage, and structural integrity.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Route Distance Km' ;
    rdfs:comment 'Total physical distance of the haul route measured in kilometers, used for cycle time calculation and fuel consumption estimation.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeGradientPercent rdf:type rdf:Property ;
    rdfs:label 'Route Gradient Percent' ;
    rdfs:comment 'Average gradient or slope of the haul route expressed as a percentage. Positive values indicate uphill, negative values indicate downhill.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable descriptive name of the haul route, typically including origin and destination landmarks.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routePriority rdf:type rdf:Property ;
    rdfs:label 'Route Priority' ;
    rdfs:comment 'Operational priority level of the haul route for maintenance scheduling and resource allocation.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the haul route based on origin and destination function within the mining operation.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Level' ;
    rdfs:comment 'Assessed safety risk level of the haul route based on gradient, width, surface condition, and historical incident data.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedLimitKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Limit Kmh' ;
    rdfs:comment 'Maximum permitted vehicle speed on the haul route for safety and operational control.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficControlType rdf:type rdf:Property ;
    rdfs:label 'Traffic Control Type' ;
    rdfs:comment 'Method of traffic management and control used on the haul route to ensure safe vehicle movement.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherDependentFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Dependent Flag' ;
    rdfs:comment 'Indicates whether the route is significantly affected by weather conditions and may require closure during adverse weather.' ;
    rdfs:domain ind:HaulRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Designed By Employee Id' ;
    rdfs:comment 'Reference to the mining engineer or blast designer who created this drill pattern.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blastType rdf:type rdf:Property ;
    rdfs:label 'Blast Type' ;
    rdfs:comment 'Classification of the blast operation this pattern is designed for, determining explosive loading and timing requirements.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burdenM rdf:type rdf:Property ;
    rdfs:label 'Burden M' ;
    rdfs:comment 'Distance in meters from the blast hole to the free face, critical parameter for blast energy distribution and fragmentation.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillRigType rdf:type rdf:Property ;
    rdfs:label 'Drill Rig Type' ;
    rdfs:comment 'Recommended or required drilling equipment type for executing this pattern, ensuring operational compatibility.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosiveType rdf:type rdf:Property ;
    rdfs:label 'Explosive Type' ;
    rdfs:comment 'Primary explosive product specified for this drill pattern, determining blast performance characteristics.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holeDepthM rdf:type rdf:Property ;
    rdfs:label 'Hole Depth M' ;
    rdfs:comment 'Planned depth of blast holes in meters, typically including sub-drill below the bench floor.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holesPerRow rdf:type rdf:Property ;
    rdfs:label 'Holes Per Row' ;
    rdfs:comment 'Typical number of blast holes per row in this pattern configuration.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiationSystem rdf:type rdf:Property ;
    rdfs:label 'Initiation System' ;
    rdfs:comment 'Detonation initiation technology used for blast timing control and sequencing.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStandardPattern rdf:type rdf:Property ;
    rdfs:label 'Is Standard Pattern' ;
    rdfs:comment 'Indicates whether this is a standard, reusable pattern or a custom design for specific conditions.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfRows rdf:type rdf:Property ;
    rdfs:label 'Number Of Rows' ;
    rdfs:comment 'Typical number of hole rows in a blast using this pattern, affecting blast volume and timing complexity.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patternCode rdf:type rdf:Property ;
    rdfs:label 'Pattern Code' ;
    rdfs:comment 'Externally-known unique code identifying the drill pattern design, used for operational reference and communication.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternName rdf:type rdf:Property ;
    rdfs:label 'Pattern Name' ;
    rdfs:comment 'Human-readable name or designation of the drill pattern for identification and reporting purposes.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternNotes rdf:type rdf:Property ;
    rdfs:label 'Pattern Notes' ;
    rdfs:comment 'Additional operational notes, constraints, or special instructions for applying this drill pattern in the field.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternStatus rdf:type rdf:Property ;
    rdfs:label 'Pattern Status' ;
    rdfs:comment 'Current lifecycle status of the drill pattern indicating its availability for operational use.' ;
    rdfs:domain ind:DrillPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patternType rdf:type rdf:Property ;
    rdfs:label 'Pattern Type' ;
    rdfs:comment 'Classification of the drill pattern geometry used for blast design, determining hole spacing and burden configuration.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powderFactorKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Powder Factor Kg Per M3' ;
    rdfs:comment 'Target explosive consumption in kilograms per cubic meter of rock, indicating blast intensity and fragmentation energy.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rockStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Rock Strength Mpa' ;
    rdfs:comment 'Unconfined compressive strength of the target rock in megapascals, determining drilling difficulty and explosive requirements.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyExclusionZoneM rdf:type rdf:Property ;
    rdfs:label 'Safety Exclusion Zone M' ;
    rdfs:comment 'Minimum safe distance in meters required around the blast area when using this pattern, for personnel and equipment safety.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spacingM rdf:type rdf:Property ;
    rdfs:label 'Spacing M' ;
    rdfs:comment 'Distance in meters between adjacent blast holes in a row, determining blast coverage and fragmentation uniformity.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stemmingLengthM rdf:type rdf:Property ;
    rdfs:label 'Stemming Length M' ;
    rdfs:comment 'Length of inert material (stemming) placed at the top of the blast hole in meters to confine explosive gases.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subDrillM rdf:type rdf:Property ;
    rdfs:label 'Sub Drill M' ;
    rdfs:comment 'Additional drilling depth below the bench floor in meters to ensure complete breakage at the toe of the blast.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionChecklistId rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Id' ;
    rdfs:comment 'Primary key for inspection_checklist' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableShiftTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Shift Types' ;
    rdfs:comment 'Comma-separated list of shift types during which this inspection checklist must be executed, such as day shift, night shift, or all shifts.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSiteCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Site Codes' ;
    rdfs:comment 'Comma-separated list of mine site codes where this inspection checklist is applicable and must be used.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this inspection checklist was archived and removed from active operational use.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Externally-known unique business identifier for the inspection checklist used across systems and documentation.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'Detailed description of the inspection checklist including its objectives, scope, and application context.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the inspection checklist describing its purpose and scope.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'Classification of the inspection checklist by its operational purpose and timing in the asset lifecycle.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version number of the inspection checklist following semantic versioning to track revisions and updates.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalFormAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Form Available Flag' ;
    rdfs:comment 'Indicates whether a digital or mobile-enabled form is available for executing this inspection checklist in the field.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'Category of mining equipment or asset that this checklist applies to, aligned with fleet and plant classifications.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete the full inspection checklist under normal conditions.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatoryCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Checkpoint Count' ;
    rdfs:comment 'Number of checkpoints within this checklist that are mandatory and must be completed for the inspection to be considered valid.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileAppCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile App Compatible Flag' ;
    rdfs:comment 'Indicates whether this inspection checklist is compatible with mobile applications used by field operators and maintenance personnel.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Business department or functional area responsible for maintaining and governing this inspection checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Percentage' ;
    rdfs:comment 'Minimum percentage of checkpoints that must pass for the overall inspection to be considered successful and the asset to be cleared for operation.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoEvidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Required Flag' ;
    rdfs:comment 'Indicates whether photographic evidence must be captured and attached during execution of this inspection checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCompetencyLevel rdf:type rdf:Property ;
    rdfs:label 'Required Competency Level' ;
    rdfs:comment 'Minimum competency or qualification level required for personnel authorized to execute this inspection checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Certification Flag' ;
    rdfs:comment 'Indicates whether completion of this inspection checklist requires formal certification or sign-off by a qualified inspector or supervisor.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the inspection checklist indicating its availability for operational use.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Total Checkpoint Count' ;
    rdfs:comment 'Total number of individual inspection checkpoints or items included in this checklist.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Human-readable name of the mine area, used for identification in operational communications and planning.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSizeHectares rdf:type rdf:Property ;
    rdfs:label 'Area Size Hectares' ;
    rdfs:comment 'Total surface area of the mine area measured in hectares.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the mine area based on its operational purpose and extraction method.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blastZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Blast Zone Flag' ;
    rdfs:comment 'Indicates whether this area is designated for drill-and-blast operations.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closurePlannedDate rdf:type rdf:Property ;
    rdfs:label 'Closure Planned Date' ;
    rdfs:comment 'Planned date for closure of mining operations in this area based on life-of-mine planning.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depthMaxM rdf:type rdf:Property ;
    rdfs:label 'Depth Max M' ;
    rdfs:comment 'Maximum depth of the mine area below surface, measured in meters. Applicable to pits and underground workings.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentFleetAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Fleet Assigned' ;
    rdfs:comment 'Designation of the primary equipment fleet assigned to operate in this mine area.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotechnicalRiskRating rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Risk Rating' ;
    rdfs:comment 'Assessment of geotechnical stability and risk level for the mine area.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulageRoutePrimary rdf:type rdf:Property ;
    rdfs:label 'Haulage Route Primary' ;
    rdfs:comment 'Primary haulage route designation for material transport from this area to processing or stockpile locations.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oreGradePercent rdf:type rdf:Property ;
    rdfs:label 'Ore Grade Percent' ;
    rdfs:comment 'Average ore grade of the primary commodity in this area, expressed as percentage.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionCapacityTonnesPerYear rdf:type rdf:Property ;
    rdfs:label 'Production Capacity Tonnes Per Year' ;
    rdfs:comment 'Designed annual production capacity of the mine area, measured in tonnes per year.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleSuperintendent rdf:type rdf:Property ;
    rdfs:label 'Responsible Superintendent' ;
    rdfs:comment 'Name or identifier of the mining superintendent responsible for operations in this area.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Flag' ;
    rdfs:comment 'Indicates whether this area is integrated with SCADA systems for real-time operational monitoring.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterManagementZone rdf:type rdf:Property ;
    rdfs:label 'Water Management Zone' ;
    rdfs:comment 'Designated water management zone or catchment area for environmental and operational water control.' ;
    rdfs:domain ind:MineArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedCycleId rdf:type rdf:Property ;
    rdfs:label 'Reversed Cycle Id' ;
    rdfs:comment 'Reference to the allocation cycle that this cycle reverses, if this is a reversal cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationCycle .

ind:sourceCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Source Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Allocation cycles typically originate from a source cost centre (e.g., shared services cost centre allocating to operational cost centres). The existing source_cost_pool (STRING) should be replaced wi' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:allocationBasis rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis' ;
    rdfs:comment 'The basis or driver used for cost allocation in this cycle (e.g., headcount, production volume, machine hours, square footage).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the allocation cycle, used for external reference and reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Descriptive name of the allocation cycle for business user identification and reporting purposes.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the allocation cycle based on frequency and purpose (monthly, quarterly, annual, ad-hoc, project-based, or interim).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing End Timestamp' ;
    rdfs:comment 'The timestamp when allocation processing completed for this cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Start Timestamp' ;
    rdfs:comment 'The timestamp when allocation processing began for this cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Run Sequence Number' ;
    rdfs:comment 'Sequential number indicating the iteration or run number of this allocation cycle, used when cycles are re-run or adjusted.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetEntityType rdf:type rdf:Property ;
    rdfs:label 'Target Entity Type' ;
    rdfs:comment 'The type of entity to which costs are being allocated (cost center, project, asset, mine site, business unit, or product).' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Allocated Amount' ;
    rdfs:comment 'The total monetary amount allocated across all cost centers and entities during this allocation cycle.' ;
    rdfs:domain ind:AllocationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the corporate ownership hierarchy. Null for ultimate parent entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ultimateParentEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate ownership hierarchy. Self-referencing for ultimate parent entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The primary accounting standard framework used by the legal entity for financial reporting (e.g., IFRS, US GAAP, local GAAP).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'The accounting method used to consolidate this entity\'s financial results into group reporting (full consolidation, proportionate consolidation, equity method, or no consolidation).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or deregistered. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity (e.g., active, dormant, in liquidation, dissolved, suspended).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity structure within the corporate hierarchy (e.g., subsidiary, parent company, joint venture, branch, division, partnership).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditor rdf:type rdf:Property ;
    rdfs:label 'External Auditor' ;
    rdfs:comment 'The name of the external audit firm responsible for auditing the legal entity\'s financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndDay rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Day' ;
    rdfs:comment 'The day of the month on which the legal entity\'s fiscal year ends, represented as an integer (1-31).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month in which the legal entity\'s fiscal year ends, represented as an integer (1=January, 12=December).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'The primary currency of the economic environment in which the entity operates, using ISO 4217 three-letter currency codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs6ExplorationEntity rdf:type rdf:Property ;
    rdfs:label 'Ifrs6 Exploration Entity' ;
    rdfs:comment 'Indicates whether the legal entity is engaged in exploration and evaluation of mineral resources and applies IFRS 6 accounting standards.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the relevant regulatory authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'The country or jurisdiction where the legal entity is incorporated or registered, using ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'The standardized industry classification code (e.g., ISIC, NAICS, SIC) identifying the entity\'s primary business sector.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBusinessActivity rdf:type rdf:Property ;
    rdfs:label 'Primary Business Activity' ;
    rdfs:comment 'Description of the primary business activity or industry sector in which the legal entity operates (e.g., iron ore mining, copper extraction, coal production).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official registration or company number assigned by the incorporation jurisdiction\'s regulatory authority.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'The currency in which the entity presents its financial statements, using ISO 4217 three-letter currency codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeListing rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Listing' ;
    rdfs:comment 'The stock exchange(s) on which the legal entity\'s securities are listed, if publicly traded (e.g., ASX, NYSE, LSE). Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol or trading code used to identify the legal entity\'s securities on stock exchanges. Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:explosiveTypeId rdf:type rdf:Property ;
    rdfs:label 'Explosive Type Id' ;
    rdfs:comment 'Reference to the primary explosive product used in this blast pattern (e.g., ANFO, emulsion, heavy ANFO).' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExplosiveType .

ind:applicationNotes rdf:type rdf:Property ;
    rdfs:label 'Application Notes' ;
    rdfs:comment 'Free-text field capturing operational guidance, constraints, or special instructions for applying this blast pattern in the field.' ;
    rdfs:domain ind:BlastPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeLengthM rdf:type rdf:Property ;
    rdfs:label 'Charge Length M' ;
    rdfs:comment 'Total length of the explosive column in meters within the blast hole.' ;
    rdfs:domain ind:BlastPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayTimingMs rdf:type rdf:Property ;
    rdfs:label 'Delay Timing Ms' ;
    rdfs:comment 'Time delay in milliseconds between detonation of adjacent blast holes, used to control vibration, fragmentation, and muck pile throw.' ;
    rdfs:domain ind:BlastPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:explosiveMassPerHoleKg rdf:type rdf:Property ;
    rdfs:label 'Explosive Mass Per Hole Kg' ;
    rdfs:comment 'Total mass of explosive loaded into each blast hole in kilograms.' ;
    rdfs:domain ind:BlastPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfHoles rdf:type rdf:Property ;
    rdfs:label 'Number Of Holes' ;
    rdfs:comment 'Total count of blast holes in the pattern design.' ;
    rdfs:domain ind:BlastPattern ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyCampaignId rdf:type rdf:Property ;
    rdfs:label 'Survey Campaign Id' ;
    rdfs:comment 'Reference to the broader survey campaign or program that this run is part of, enabling grouping of related survey activities.' ;
    rdfs:domain ind:Geology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyCampaign .

ind:actualDrillMeters rdf:type rdf:Property ;
    rdfs:label 'Actual Drill Meters' ;
    rdfs:comment 'The actual total drilling depth in meters achieved during this survey run.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedBy rdf:type rdf:Property ;
    rdfs:label 'Certified By' ;
    rdfs:comment 'Name and credentials of the competent person or qualified professional who certified the survey run results.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gridSpacingMeters rdf:type rdf:Property ;
    rdfs:label 'Grid Spacing Meters' ;
    rdfs:comment 'The spacing between survey points or drill holes in meters, defining the resolution and density of the survey grid.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Level' ;
    rdfs:comment 'The level of quality assurance and quality control protocols applied to this survey run, determining the rigor of validation and certification.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incidents Count' ;
    rdfs:comment 'The number of safety incidents or near-misses recorded during the execution of this survey run.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyPurpose rdf:type rdf:Property ;
    rdfs:label 'Survey Purpose' ;
    rdfs:comment 'Detailed description of the business or technical objective for conducting this survey run, such as resource estimation, grade control, or geotechnical assessment.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDrillMeters rdf:type rdf:Property ;
    rdfs:label 'Target Drill Meters' ;
    rdfs:comment 'The planned total drilling depth in meters to be achieved during this survey run, applicable for drilling-based surveys.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSampleCount rdf:type rdf:Property ;
    rdfs:label 'Target Sample Count' ;
    rdfs:comment 'The planned number of samples or data points to be collected during this survey run.' ;
    rdfs:domain ind:SurveyRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Indicates whether corrective actions are required as a result of this investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated total financial impact of the incident including damage, downtime, remediation, and investigation costs.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Executive summary of the key findings from the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause Description' ;
    rdfs:comment 'Detailed description of the immediate or direct cause(s) that led to the incident or event.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date when the investigation was formally initiated.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'The precise date and time when the investigation was formally initiated.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationMethod rdf:type rdf:Property ;
    rdfs:label 'Investigation Method' ;
    rdfs:comment 'The structured investigation methodology or framework applied to analyze the event.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-known unique business identifier for the investigation, formatted as INV-YYYY-NNNNNN.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Comma-separated list of employee names or identifiers who are part of the investigation team.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation based on the triggering event or purpose.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Recordable' ;
    rdfs:comment 'Indicates whether the incident is recordable under MSHA or OSHA regulations for LTIFR/TRIFR tracking.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Detailed recommendations for corrective and preventive actions arising from the investigation findings.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the investigation findings require notification to regulatory authorities such as MSHA or environmental agencies.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'URL or file path to the full investigation report document stored in the document management system.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedJobRoles rdf:type rdf:Property ;
    rdfs:label 'Affected Job Roles' ;
    rdfs:comment 'Comma-separated list or description of the job roles, occupations, or worker categories that are exposed to or may encounter this hazard during their work activities (e.g., \'drill operators\', \'blasters\', \'maintenance technicians\', \'haul truck drivers\').' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedWorkAreas rdf:type rdf:Property ;
    rdfs:label 'Affected Work Areas' ;
    rdfs:comment 'Comma-separated list or description of the specific work areas, zones, or operational locations within the mine site where this hazard is present or may be encountered (e.g., \'underground stopes\', \'processing plant\', \'haul roads\', \'maintenance workshop\').' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure' ;
    rdfs:comment 'Summary or reference to the emergency response procedures, first aid measures, or incident response protocols to be followed if an incident involving this hazard occurs.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimit rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit' ;
    rdfs:comment 'The maximum permissible exposure level or threshold limit value for this hazard, including units of measure (e.g., \'0.05 mg/m³ for respirable crystalline silica\', \'85 dBA for noise\'). Applicable primarily to chemical, physical, and environmental hazards.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griDisclosureReference rdf:type rdf:Property ;
    rdfs:label 'Gri Disclosure Reference' ;
    rdfs:comment 'Reference to the applicable GRI disclosure standard or indicator related to this hazard, used for sustainability and ESG reporting (e.g., \'GRI 403: Occupational Health and Safety\').' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCode rdf:type rdf:Property ;
    rdfs:label 'Hazard Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the hazard type for reporting and classification purposes. Follows organizational hazard coding taxonomy.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed narrative description of the hazard, including its nature, potential sources, and circumstances under which it may be encountered in mining operations.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardName rdf:type rdf:Property ;
    rdfs:label 'Hazard Name' ;
    rdfs:comment 'The common business name or title of the hazard used for identification and communication across the organization.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReportable rdf:type rdf:Property ;
    rdfs:label 'Is Reportable' ;
    rdfs:comment 'Indicates whether incidents involving this hazard must be reported to external regulatory authorities such as MSHA, state mining departments, or environmental agencies. True if reportable, False otherwise.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'The date of the most recent recorded incident, injury, or near-miss event associated with this hazard. Used for trend analysis and control effectiveness evaluation.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether a work permit, hot work permit, confined space entry permit, or other authorization is required before work involving this hazard can commence. True if permit is mandatory, False otherwise.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Comma-separated list of personal protective equipment required when working in the presence of this hazard (e.g., \'hard hat\', \'safety glasses\', \'respirator\', \'hearing protection\', \'high-visibility vest\', \'steel-toed boots\').' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointCount rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Count' ;
    rdfs:comment 'Total number of inspection checkpoints or stops included in this route.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the inspection frequency value (e.g., daily, weekly, monthly).' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyValue rdf:type rdf:Property ;
    rdfs:label 'Frequency Value' ;
    rdfs:comment 'Numeric value representing how often the inspection route should be executed.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Enabled' ;
    rdfs:comment 'Indicates whether this inspection route can be executed using mobile devices or tablets.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertification rdf:type rdf:Property ;
    rdfs:label 'Required Certification' ;
    rdfs:comment 'Specific certifications or qualifications required for inspectors performing this route.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Required Skill Level' ;
    rdfs:comment 'Minimum competency level required for personnel assigned to execute this inspection route.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLockoutTagout rdf:type rdf:Property ;
    rdfs:label 'Requires Lockout Tagout' ;
    rdfs:comment 'Indicates whether lockout/tagout procedures are required for equipment isolation during inspection.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Permit' ;
    rdfs:comment 'Indicates whether a work permit is required before executing this inspection route.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresShutdown rdf:type rdf:Property ;
    rdfs:label 'Requires Shutdown' ;
    rdfs:comment 'Indicates whether equipment or process shutdown is required to perform the inspection route.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Detailed description of the inspection route including scope, objectives, and special instructions.' ;
    rdfs:domain ind:InspectionRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Safety risk category of the inspection route determining required safety protocols and permits.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'The class or type of mining assets this inspection template is designed for (e.g., haul trucks, crushers, conveyors, draglines).' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistItemCount rdf:type rdf:Property ;
    rdfs:label 'Checklist Item Count' ;
    rdfs:comment 'Total number of inspection points or checklist items included in this template.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost in local currency to execute one inspection using this template including labor and materials.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Primary category of inspection work covered by this template.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Recommended frequency in days between inspections when using this template for time-based maintenance scheduling.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionFrequencyHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Hours' ;
    rdfs:comment 'Recommended frequency in operating hours between inspections for usage-based maintenance scheduling.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory certifications or qualifications required to perform this inspection.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresPermitFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Permit Flag' ;
    rdfs:comment 'Indicates whether a work permit or isolation certificate is required before performing this inspection.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresShutdownFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Shutdown Flag' ;
    rdfs:comment 'Indicates whether the inspection requires equipment shutdown or can be performed during operation.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the inspection template used for external reference and system integration.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the inspection template including its objectives, scope, and application context.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the inspection template describing its purpose and scope.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the inspection template by maintenance strategy type.' ;
    rdfs:domain ind:InspectionTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backlogHours rdf:type rdf:Property ;
    rdfs:label 'Backlog Hours' ;
    rdfs:comment 'Current backlog of planned maintenance work hours assigned to this work centre but not yet completed.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Day' ;
    rdfs:comment 'Total available productive hours per day for this work centre based on crew size and shift patterns.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Cmms System Code' ;
    rdfs:comment 'Work centre identifier in the source CMMS system (Infor EAM) for integration and reconciliation purposes.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorCompanyName rdf:type rdf:Property ;
    rdfs:label 'Contractor Company Name' ;
    rdfs:comment 'Name of the contracting company managing this work centre if contractor-managed.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of maintenance personnel assigned to this work centre on a standard shift.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the work centre\'s purpose, capabilities, and scope of maintenance activities performed.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAssetClass rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Class' ;
    rdfs:comment 'Primary asset class or equipment type that this work centre is specialized to maintain (e.g., haul trucks, crushers, conveyors).' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContractorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Contractor Managed' ;
    rdfs:comment 'Indicates whether this work centre is operated by external contractors rather than internal maintenance personnel.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Human-readable name of the work centre describing its function or location within the maintenance organization.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningGroup rdf:type rdf:Property ;
    rdfs:label 'Planning Group' ;
    rdfs:comment 'Maintenance planning group responsible for scheduling and coordinating work orders assigned to this work centre.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required' ;
    rdfs:comment 'List of mandatory safety certifications or qualifications required for personnel working in this work centre.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Standard Hourly Rate' ;
    rdfs:comment 'Standard labor cost rate per hour for work performed by this work centre, used for maintenance cost estimation and actuals.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeSpecialization rdf:type rdf:Property ;
    rdfs:label 'Trade Specialization' ;
    rdfs:comment 'Specific trade skills or technical specialization of the work centre workforce (e.g., hydraulics, welding, conveyor systems).' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Percent' ;
    rdfs:comment 'Target utilization percentage for productive maintenance work hours as a proportion of available capacity.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCentreCode rdf:type rdf:Property ;
    rdfs:label 'Work Centre Code' ;
    rdfs:comment 'Externally-known unique business identifier for the work centre used in maintenance planning and work order assignment.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCentreType rdf:type rdf:Property ;
    rdfs:label 'Work Centre Type' ;
    rdfs:comment 'Classification of the work centre based on the primary maintenance discipline or trade specialization.' ;
    rdfs:domain ind:WorkCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRampCode rdf:type rdf:Property ;
    rdfs:label 'Access Ramp Code' ;
    rdfs:comment 'Reference to the primary access ramp or decline providing haulage access to this pit or level.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blastPatternCode rdf:type rdf:Property ;
    rdfs:label 'Blast Pattern Code' ;
    rdfs:comment 'Standard blast design pattern code used at this pit or level. References drill spacing, burden, and explosive configuration for this geological domain.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthM rdf:type rdf:Property ;
    rdfs:label 'Depth M' ;
    rdfs:comment 'Vertical depth of the pit or level from surface or reference datum, measured in meters. Used for geotechnical analysis and ventilation planning.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityTonnesPerDay rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tonnes Per Day' ;
    rdfs:comment 'Planned daily production capacity for this pit or level, measured in tonnes per day. Used for production scheduling and resource allocation.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dilutionFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Dilution Factor Percent' ;
    rdfs:comment 'Expected percentage of waste material mixed with ore during extraction at this pit or level. Used for grade reconciliation and mill feed planning.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulageDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Haulage Distance Km' ;
    rdfs:comment 'Average haulage distance from this pit or level to the primary destination (ROM pad, crusher, or waste dump), measured in kilometers. Used for cycle time and cost modeling.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Recovery Factor Percent' ;
    rdfs:comment 'Expected percentage of in-situ ore that will be successfully extracted and recovered from this pit or level. Accounts for mining losses and operational constraints.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slopeAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Slope Angle Degrees' ;
    rdfs:comment 'Design slope angle for pit walls or level access at this location, measured in degrees from horizontal. Critical for geotechnical stability and safety.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyedDate rdf:type rdf:Property ;
    rdfs:label 'Surveyed Date' ;
    rdfs:comment 'Date of the most recent survey measurement for this pit or level. Used for as-built reconciliation and spatial accuracy tracking.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the mining excavation structure: pit for open-cut operations, level for underground operations, bench for stepped excavation, stage for phased development, cutback for pit expansion, or pushback for sequential mining phases.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationRequirementM3PerSec rdf:type rdf:Property ;
    rdfs:label 'Ventilation Requirement M3 Per Sec' ;
    rdfs:comment 'Required airflow rate for underground levels, measured in cubic meters per second. Critical for occupational health and safety compliance.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteVolumeBcm rdf:type rdf:Property ;
    rdfs:label 'Waste Volume Bcm' ;
    rdfs:comment 'Estimated volume of waste material to be removed from this pit or level, measured in bank cubic meters. Critical for strip ratio calculation and waste dump planning.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterInflowRateLitersPerMin rdf:type rdf:Property ;
    rdfs:label 'Water Inflow Rate Liters Per Min' ;
    rdfs:comment 'Average groundwater inflow rate at this pit or level, measured in liters per minute. Used for dewatering system design and water management planning.' ;
    rdfs:domain ind:PitOrLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessRampId rdf:type rdf:Property ;
    rdfs:label 'Access Ramp Id' ;
    rdfs:comment 'Reference to the primary access ramp providing haulage access to this bench.' ;
    rdfs:domain ind:Mine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessRamp .

ind:benchCode rdf:type rdf:Property ;
    rdfs:label 'Bench Code' ;
    rdfs:comment 'Externally-known unique code for the bench used in mine planning and operational systems.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchStatus rdf:type rdf:Property ;
    rdfs:label 'Bench Status' ;
    rdfs:comment 'Current operational status of the bench in its lifecycle: planned for future extraction, actively being mined, depleted of material, temporarily suspended, or permanently closed.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchType rdf:type rdf:Property ;
    rdfs:label 'Bench Type' ;
    rdfs:comment 'Classification of the bench based on material type: ore-bearing, waste rock, mixed material, overburden, or interburden.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchWidthM rdf:type rdf:Property ;
    rdfs:label 'Bench Width M' ;
    rdfs:comment 'Horizontal width of the bench working area in meters, measured from crest to toe.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillHoleBurdenM rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Burden M' ;
    rdfs:comment 'Standard distance from the drill hole to the free face (burden) in the blast pattern, measured in meters.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillHoleDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Diameter Mm' ;
    rdfs:comment 'Standard diameter of blast holes drilled in the bench, measured in millimeters.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillHoleSpacingM rdf:type rdf:Property ;
    rdfs:label 'Drill Hole Spacing M' ;
    rdfs:comment 'Standard horizontal spacing between drill holes in the blast pattern, measured in meters.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationRlM rdf:type rdf:Property ;
    rdfs:label 'Elevation Rl M' ;
    rdfs:comment 'The reduced level elevation of the bench floor in meters above mean sea level, used for vertical positioning in mine design.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Face Angle Degrees' ;
    rdfs:comment 'Angle of the bench face in degrees from horizontal, critical for geotechnical stability and safety.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingVolumeBcm rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume Bcm' ;
    rdfs:comment 'Current remaining volume of material available for extraction from the bench in bank cubic meters.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rockMassRating rdf:type rdf:Property ;
    rdfs:label 'Rock Mass Rating' ;
    rdfs:comment 'Rock Mass Rating score for the bench, a geotechnical classification system indicating rock quality and stability.' ;
    rdfs:domain ind:Bench ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processAreaId rdf:type rdf:Property ;
    rdfs:label 'Process Area Id' ;
    rdfs:comment 'Reference to the process area or circuit section where this measurement point is located (e.g., comminution, flotation, dewatering).' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessArea .

ind:processStreamId rdf:type rdf:Property ;
    rdfs:label 'Process Stream Id' ;
    rdfs:comment 'Reference to the process stream or material flow being measured (e.g., ore feed, concentrate, tailings, reagent addition).' ;
    rdfs:domain ind:Processing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessStream .

ind:accuracy rdf:type rdf:Property ;
    rdfs:label 'Accuracy' ;
    rdfs:comment 'Specified accuracy or tolerance of the measurement instrument, typically expressed as a percentage of full scale or absolute value.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmHigh rdf:type rdf:Property ;
    rdfs:label 'Alarm High' ;
    rdfs:comment 'Upper warning alarm threshold indicating the measurement is approaching critical limits.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmHighHigh rdf:type rdf:Property ;
    rdfs:label 'Alarm High High' ;
    rdfs:comment 'Critical upper alarm threshold that triggers immediate operator intervention when exceeded.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmLow rdf:type rdf:Property ;
    rdfs:label 'Alarm Low' ;
    rdfs:comment 'Lower warning alarm threshold indicating the measurement is approaching critical limits.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alarmLowLow rdf:type rdf:Property ;
    rdfs:label 'Alarm Low Low' ;
    rdfs:comment 'Critical lower alarm threshold that triggers immediate operator intervention when breached.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlSystemTag rdf:type rdf:Property ;
    rdfs:label 'Control System Tag' ;
    rdfs:comment 'Tag identifier used in the distributed control system or SCADA system to reference this measurement point for real-time monitoring and control.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historianTag rdf:type rdf:Property ;
    rdfs:label 'Historian Tag' ;
    rdfs:comment 'Tag identifier used in the process historian system (e.g., OSIsoft PI, Aspen IP.21) for time-series data storage and retrieval.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalControlPoint rdf:type rdf:Property ;
    rdfs:label 'Is Critical Control Point' ;
    rdfs:comment 'Indicates whether this measurement point is designated as a critical control point for process safety, environmental compliance, or production quality.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKpiInput rdf:type rdf:Property ;
    rdfs:label 'Is Kpi Input' ;
    rdfs:comment 'Indicates whether this measurement point provides input data for calculating key performance indicators such as recovery rate, throughput, or product grade.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementPointName rdf:type rdf:Property ;
    rdfs:label 'Measurement Point Name' ;
    rdfs:comment 'Human-readable descriptive name of the measurement point indicating its location and purpose within the processing circuit.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequencySeconds rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency Seconds' ;
    rdfs:comment 'Interval in seconds at which the measurement point captures and records data values.' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Unique alphanumeric tag identifier assigned to the measurement instrument following plant instrumentation standards (e.g., FT-SAG-001, PT-FLOT-205).' ;
    rdfs:domain ind:MeasurementPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedPumpAssetId rdf:type rdf:Property ;
    rdfs:label 'Associated Pump Asset Id' ;
    rdfs:comment 'Reference to the primary pump equipment that drives flow through this pipeline, if applicable.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:coatingType rdf:type rdf:Property ;
    rdfs:label 'Coating Type' ;
    rdfs:comment 'Type of protective coating or lining applied to the internal or external surface of the pipeline to prevent corrosion or wear.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designFlowRateM3PerHour rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate M3 Per Hour' ;
    rdfs:comment 'Nominal volumetric flow rate the pipeline is designed to handle under normal operating conditions, measured in cubic meters per hour.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designLifeYears rdf:type rdf:Property ;
    rdfs:label 'Design Life Years' ;
    rdfs:comment 'Expected operational lifespan of the pipeline in years as specified in the original engineering design.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:designPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Design Pressure Kpa' ;
    rdfs:comment 'Maximum operating pressure the pipeline is designed to withstand, measured in kilopascals.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'End point or facility where the pipeline terminates, such as thickener feed, concentrate storage, or tailings dam.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diameterMm rdf:type rdf:Property ;
    rdfs:label 'Diameter Mm' ;
    rdfs:comment 'Internal diameter of the pipeline measured in millimeters, critical for flow rate and pressure calculations.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationChangeM rdf:type rdf:Property ;
    rdfs:label 'Elevation Change M' ;
    rdfs:comment 'Net vertical elevation change from source to destination measured in meters, positive for uphill flow and negative for downhill flow.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insulationType rdf:type rdf:Property ;
    rdfs:label 'Insulation Type' ;
    rdfs:comment 'Type of thermal insulation applied to the pipeline, if any, to maintain temperature or prevent freezing.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGravityFed rdf:type rdf:Property ;
    rdfs:label 'Is Gravity Fed' ;
    rdfs:comment 'Indicates whether the pipeline relies on gravity for flow (true) or requires pumping (false).' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Primary maintenance approach applied to the pipeline, determining inspection frequency and intervention triggers.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialOfConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Of Construction' ;
    rdfs:comment 'Primary material used in the construction of the pipeline, such as high-density polyethylene, steel, or rubber-lined steel.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialTransported rdf:type rdf:Property ;
    rdfs:label 'Material Transported' ;
    rdfs:comment 'Specific material, slurry, or substance that the pipeline is designed to transport, including ore type, concentrate grade, or reagent name.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature C' ;
    rdfs:comment 'Typical operating temperature of the material being transported through the pipeline, measured in degrees Celsius.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the pipeline used in operational systems and reporting.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Name' ;
    rdfs:comment 'Human-readable name of the pipeline used for identification and communication across operations and maintenance teams.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineType rdf:type rdf:Property ;
    rdfs:label 'Pipeline Type' ;
    rdfs:comment 'Classification of the pipeline based on the material or substance it transports within the processing plant.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingWallThicknessMm rdf:type rdf:Property ;
    rdfs:label 'Remaining Wall Thickness Mm' ;
    rdfs:comment 'Current minimum wall thickness of the pipeline measured in millimeters, monitored to ensure structural integrity and prevent failure.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementValueUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Value Usd' ;
    rdfs:comment 'Estimated current cost to replace the pipeline with equivalent new infrastructure, used for insurance and capital planning.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidsConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Solids Concentration Percent' ;
    rdfs:comment 'Design solids concentration by weight for slurry pipelines, expressed as a percentage, critical for rheology and pump selection.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Origin point or facility where the pipeline begins, such as crusher discharge, flotation cells, or storage tank.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wearRateMmPerYear rdf:type rdf:Property ;
    rdfs:label 'Wear Rate Mm Per Year' ;
    rdfs:comment 'Average rate of internal wear or erosion of the pipeline wall measured in millimeters per year, used for remaining life calculations.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Port Authority Id' ;
    rdfs:comment 'Reference to the governing port authority or operator organization responsible for this facility.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PortAuthority .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the port facility.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information such as building, suite, or terminal number.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Tonnes' ;
    rdfs:comment 'Maximum annual throughput capacity of the port facility measured in metric tonnes.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:berthCount rdf:type rdf:Property ;
    rdfs:label 'Berth Count' ;
    rdfs:comment 'Total number of berths or docking positions available at the port facility.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoHandlingEquipment rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Equipment' ;
    rdfs:comment 'Description of major cargo handling equipment available at the facility such as cranes, conveyors, loaders, and stackers.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySpecialization rdf:type rdf:Property ;
    rdfs:label 'Commodity Specialization' ;
    rdfs:comment 'Primary commodity types the port facility is specialized to handle, such as iron ore, coal, copper concentrate, lithium, or nickel.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Upgrade Date' ;
    rdfs:comment 'Date of the most recent major infrastructure upgrade or expansion of the port facility.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxDraftM rdf:type rdf:Property ;
    rdfs:label 'Max Draft M' ;
    rdfs:comment 'Maximum vessel draft in meters that the port facility can handle, representing the depth of water required.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxVesselLengthM rdf:type rdf:Property ;
    rdfs:label 'Max Vessel Length M' ;
    rdfs:comment 'Maximum length of vessel in meters that the port facility can accommodate.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:railConnectionAvailable rdf:type rdf:Property ;
    rdfs:label 'Rail Connection Available' ;
    rdfs:comment 'Indicates whether the port facility has direct rail connection for cargo transport.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roadAccessType rdf:type rdf:Property ;
    rdfs:label 'Road Access Type' ;
    rdfs:comment 'Classification of road access available to the port facility.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Security certifications held by the port facility such as ISPS (International Ship and Port Facility Security) code compliance.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity M3' ;
    rdfs:comment 'Total storage capacity available at the port facility in cubic meters for bulk materials.' ;
    rdfs:domain ind:PortFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the port facility for information and services.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finance Contact Employee Id' ;
    rdfs:comment 'Reference to the employee who is the primary finance or accounting contact for this business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who is the general manager or head of this business unit.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentBusinessUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Business Unit Id' ;
    rdfs:comment 'Reference to the parent business unit in the organizational hierarchy. Null for top-level business units.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:c1CashCostReportingFlag rdf:type rdf:Property ;
    rdfs:label 'C1 Cash Cost Reporting Flag' ;
    rdfs:comment 'Indicates whether this business unit reports C1 cash costs, a key performance metric in copper and base metals mining.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the business unit in financial systems and reports. Typically used in SAP FI/CO postings and management reporting.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs6ExplorationFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 6 Exploration Flag' ;
    rdfs:comment 'Indicates whether this business unit is subject to IFRS 6 exploration and evaluation asset accounting treatment.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingModel rdf:type rdf:Property ;
    rdfs:label 'Operating Model' ;
    rdfs:comment 'Business model under which the business unit operates, affecting cost structure and financial reporting.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter code representing the geographic region where the business unit operates (e.g., AUS for Australia, CHL for Chile, CAN for Canada).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code used for consolidated group reporting. May differ from functional currency.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRegime rdf:type rdf:Property ;
    rdfs:label 'Royalty Regime' ;
    rdfs:comment 'Description of the mining royalty regime applicable to this business unit, including rate structure and calculation basis.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarDate rdf:type rdf:Property ;
    rdfs:label 'Calendar Date' ;
    rdfs:comment 'The actual calendar date in yyyy-MM-dd format. Business key for date-based lookups and joins across all transactional and operational data.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Type of calendar this date belongs to (e.g., Gregorian, fiscal, mining operational, project-specific). Allows for multiple calendar views to support different business processes.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Day Of Month' ;
    rdfs:comment 'Day number within the month (1-31). Used for monthly reporting cycles, payroll processing, and contract milestone tracking.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfQuarter rdf:type rdf:Property ;
    rdfs:label 'Day Of Quarter' ;
    rdfs:comment 'Day number within the fiscal or calendar quarter (1-92). Supports quarterly project tracking and financial reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Full name of the day of the week. Used for operational scheduling, shift planning, and workforce rostering in mining operations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfWeekNumber rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Number' ;
    rdfs:comment 'Numeric representation of the day of week where 1=Monday through 7=Sunday. Supports sorting and analytics on weekly patterns.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfYear rdf:type rdf:Property ;
    rdfs:label 'Day Of Year' ;
    rdfs:comment 'Day number within the calendar year (1-366). Used for annual production planning, maintenance schedules, and environmental compliance reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysInMonth rdf:type rdf:Property ;
    rdfs:label 'Days In Month' ;
    rdfs:comment 'Total number of days in the month (28-31). Used for pro-rata calculations, monthly target normalization, and capacity planning.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBusinessDay rdf:type rdf:Property ;
    rdfs:label 'Is Business Day' ;
    rdfs:comment 'Boolean flag indicating whether the date is a business operating day (excludes weekends and public holidays). Used for SLA calculations, project scheduling, and financial settlement dates.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMonthEnd rdf:type rdf:Property ;
    rdfs:label 'Is Month End' ;
    rdfs:comment 'Boolean flag indicating whether the date is the last day of the month. Critical for financial close processes, accruals, and period-end reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMonthStart rdf:type rdf:Property ;
    rdfs:label 'Is Month Start' ;
    rdfs:comment 'Boolean flag indicating whether the date is the first day of the month. Used for monthly reporting triggers and period-end processing.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Public Holiday' ;
    rdfs:comment 'Boolean flag indicating whether the date is a recognized public holiday. Critical for workforce planning, shift scheduling, and labor cost calculations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarterEnd rdf:type rdf:Property ;
    rdfs:label 'Is Quarter End' ;
    rdfs:comment 'Boolean flag indicating whether the date is the last day of the fiscal or calendar quarter. Critical for quarterly financial close and regulatory reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarterStart rdf:type rdf:Property ;
    rdfs:label 'Is Quarter Start' ;
    rdfs:comment 'Boolean flag indicating whether the date is the first day of the fiscal or calendar quarter. Used for quarterly planning and reporting cycles.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekday rdf:type rdf:Property ;
    rdfs:label 'Is Weekday' ;
    rdfs:comment 'Boolean flag indicating whether the date is a weekday (Monday through Friday). Used for business day calculations and operational planning.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekend rdf:type rdf:Property ;
    rdfs:label 'Is Weekend' ;
    rdfs:comment 'Boolean flag indicating whether the date falls on a weekend (Saturday or Sunday). Used for workforce planning and operational scheduling.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEnd rdf:type rdf:Property ;
    rdfs:label 'Is Year End' ;
    rdfs:comment 'Boolean flag indicating whether the date is the last day of the calendar or fiscal year. Critical for annual financial close, tax reporting, and year-end audits.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearStart rdf:type rdf:Property ;
    rdfs:label 'Is Year Start' ;
    rdfs:comment 'Boolean flag indicating whether the date is the first day of the calendar or fiscal year. Used for annual planning and budget initialization.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Month Abbreviation' ;
    rdfs:comment 'Three-letter abbreviation of the month name. Used for compact reporting displays and chart labels. [ENUM-REF-CANDIDATE: Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec — promote to reference product]' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthName rdf:type rdf:Property ;
    rdfs:label 'Month Name' ;
    rdfs:comment 'Full name of the month. Used for human-readable reporting and executive dashboards. [ENUM-REF-CANDIDATE: January|February|March|April|May|June|July|August|September|October|November|December — promote to reference product]' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthNumber rdf:type rdf:Property ;
    rdfs:label 'Month Number' ;
    rdfs:comment 'Numeric month within the year (1-12). Used for monthly financial close, production reporting, and regulatory submissions.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicHolidayName rdf:type rdf:Property ;
    rdfs:label 'Public Holiday Name' ;
    rdfs:comment 'Name of the public holiday if applicable. Null for non-holiday dates. Used for reporting and workforce management.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterName rdf:type rdf:Property ;
    rdfs:label 'Quarter Name' ;
    rdfs:comment 'Quarter designation (Q1, Q2, Q3, Q4). Used for executive reporting and strategic planning cycles.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'Fiscal or calendar quarter number (1-4). Critical for quarterly financial reporting, board presentations, and investor relations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'Meteorological season classification. Used for seasonal production planning, weather-dependent operations, and environmental monitoring in mining operations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weekOfMonth rdf:type rdf:Property ;
    rdfs:label 'Week Of Month' ;
    rdfs:comment 'Week number within the month (1-5). Supports weekly operational reporting and short-term production tracking.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekOfYear rdf:type rdf:Property ;
    rdfs:label 'Week Of Year' ;
    rdfs:comment 'ISO week number within the year (1-53). Critical for weekly production reporting, shipment scheduling, and operational KPI tracking.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDaysInMonth rdf:type rdf:Property ;
    rdfs:label 'Working Days In Month' ;
    rdfs:comment 'Total number of business working days in the month (excludes weekends and public holidays). Critical for workforce capacity planning and productivity calculations.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'Four-digit calendar year. Foundation for annual reporting, long-term planning, and multi-year project tracking.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearMonth rdf:type rdf:Property ;
    rdfs:label 'Year Month' ;
    rdfs:comment 'Year and month in YYYY-MM format. Commonly used for month-level aggregations, time-series analysis, and reporting hierarchies.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearQuarter rdf:type rdf:Property ;
    rdfs:label 'Year Quarter' ;
    rdfs:comment 'Year and quarter in YYYY-QN format (e.g., 2024-Q1). Used for quarterly trend analysis and executive reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearWeek rdf:type rdf:Property ;
    rdfs:label 'Year Week' ;
    rdfs:comment 'ISO year and week number in YYYY-WNN format. Used for weekly production tracking and operational reporting.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beamWidthM rdf:type rdf:Property ;
    rdfs:label 'Beam Width M' ;
    rdfs:comment 'Maximum width of the vessel in meters, critical for determining port and canal passage feasibility.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildYear rdf:type rdf:Property ;
    rdfs:label 'Build Year' ;
    rdfs:comment 'Year the vessel was constructed, used to assess vessel age, maintenance requirements, and insurance premiums.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callSign rdf:type rdf:Property ;
    rdfs:label 'Call Sign' ;
    rdfs:comment 'Unique radio call sign assigned to the vessel for maritime communication and identification purposes.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoHoldCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Cargo Hold Capacity M3' ;
    rdfs:comment 'Total volumetric capacity of all cargo holds in cubic meters, used to determine maximum commodity volume that can be loaded.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:charterEndDate rdf:type rdf:Property ;
    rdfs:label 'Charter End Date' ;
    rdfs:comment 'Date when the current charter agreement for the vessel expires, critical for long-term shipment nomination planning.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:charterStartDate rdf:type rdf:Property ;
    rdfs:label 'Charter Start Date' ;
    rdfs:comment 'Date when the current charter agreement for the vessel becomes effective, used for shipment planning and cost allocation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:charterType rdf:type rdf:Property ;
    rdfs:label 'Charter Type' ;
    rdfs:comment 'Type of charter agreement under which the vessel operates, affecting cost structure and operational control for commodity shipments.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationSociety rdf:type rdf:Property ;
    rdfs:label 'Classification Society' ;
    rdfs:comment 'Name of the independent organization that certifies the vessel meets safety and construction standards (e.g., Lloyd\'s Register, DNV GL, ABS).' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyCharterRateUsd rdf:type rdf:Property ;
    rdfs:label 'Daily Charter Rate Usd' ;
    rdfs:comment 'Daily cost in USD for chartering the vessel under time charter agreements, used for freight cost forecasting and budget planning.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadweightTonnage rdf:type rdf:Property ;
    rdfs:label 'Deadweight Tonnage' ;
    rdfs:comment 'Maximum weight in metric tonnes that the vessel can safely carry including cargo, fuel, crew, provisions, and ballast. Critical for matching vessel capacity to shipment volume requirements.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:draftDepthM rdf:type rdf:Property ;
    rdfs:label 'Draft Depth M' ;
    rdfs:comment 'Vertical distance between the waterline and the bottom of the vessel hull in meters when fully loaded, used to assess port depth requirements and loading limits.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flagCountryCode rdf:type rdf:Property ;
    rdfs:label 'Flag Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the nation under whose laws the vessel is registered, affecting regulatory compliance and taxation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionBallastMtPerDay rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Ballast Mt Per Day' ;
    rdfs:comment 'Daily fuel consumption in metric tonnes when the vessel is traveling without cargo, used for repositioning cost calculations.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumptionLadenMtPerDay rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Laden Mt Per Day' ;
    rdfs:comment 'Daily fuel consumption in metric tonnes when the vessel is fully loaded, used for voyage cost estimation and carbon footprint calculation.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossTonnage rdf:type rdf:Property ;
    rdfs:label 'Gross Tonnage' ;
    rdfs:comment 'Measure of the overall internal volume of the vessel in register tonnes, used for regulatory compliance and port fee calculations.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iceClassRating rdf:type rdf:Property ;
    rdfs:label 'Ice Class Rating' ;
    rdfs:comment 'Classification indicating the vessels capability to operate in ice-covered waters, critical for winter shipments from northern ports.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVettingApproved rdf:type rdf:Property ;
    rdfs:label 'Is Vetting Approved' ;
    rdfs:comment 'Indicates whether the vessel has passed the companys vetting process for safety, environmental compliance, and operational standards.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthOverallM rdf:type rdf:Property ;
    rdfs:label 'Length Overall M' ;
    rdfs:comment 'Maximum length of the vessel from bow to stern in meters, used to determine port berthing compatibility and canal transit eligibility.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mmsiNumber rdf:type rdf:Property ;
    rdfs:label 'Mmsi Number' ;
    rdfs:comment 'Nine-digit unique identifier used by maritime digital selective calling, automatic identification systems, and other radio applications for vessel tracking.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netTonnage rdf:type rdf:Property ;
    rdfs:label 'Net Tonnage' ;
    rdfs:comment 'Measure of the usable cargo volume of the vessel in register tonnes, used for calculating port charges and canal transit fees.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextSurveyDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Survey Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory classification society survey, critical for planning vessel availability and maintenance downtime.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfHolds rdf:type rdf:Property ;
    rdfs:label 'Number Of Holds' ;
    rdfs:comment 'Total count of separate cargo holds on the vessel, relevant for segregating different commodity grades or types during shipment.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portOfRegistry rdf:type rdf:Property ;
    rdfs:label 'Port Of Registry' ;
    rdfs:comment 'Name of the port where the vessel is officially registered, determining the legal jurisdiction and regulatory framework.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipyardName rdf:type rdf:Property ;
    rdfs:label 'Shipyard Name' ;
    rdfs:comment 'Name of the shipyard where the vessel was constructed, relevant for quality assessment and maintenance history.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedBallastKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Ballast Knots' ;
    rdfs:comment 'Average cruising speed of the vessel in knots when traveling without cargo (in ballast condition), used for repositioning time calculations.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedLadenKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Laden Knots' ;
    rdfs:comment 'Average cruising speed of the vessel in knots when fully loaded with cargo, used for voyage duration estimation and shipment scheduling.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vesselStatus rdf:type rdf:Property ;
    rdfs:label 'Vessel Status' ;
    rdfs:comment 'Current operational status of the vessel indicating availability for commodity shipment nominations and offtake agreements.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vettingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Vetting Expiry Date' ;
    rdfs:comment 'Date when the current vetting approval expires and the vessel must be re-evaluated for continued use in commodity shipments.' ;
    rdfs:domain ind:Vessel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockageRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Blockage Risk Level' ;
    rdfs:comment 'Assessment of the risk level for blockage or clogging of the decant structure.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityM3PerHour rdf:type rdf:Property ;
    rdfs:label 'Design Capacity M3 Per Hour' ;
    rdfs:comment 'Maximum designed flow rate capacity of the decant structure measured in cubic meters per hour.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designStandard rdf:type rdf:Property ;
    rdfs:label 'Design Standard' ;
    rdfs:comment 'Engineering standard or code used in the design of the decant structure.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePlanReference rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Reference' ;
    rdfs:comment 'Reference identifier to the emergency response plan applicable to this decant structure.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inletElevationM rdf:type rdf:Property ;
    rdfs:label 'Inlet Elevation M' ;
    rdfs:comment 'Elevation of the decant structure inlet measured in meters above sea level.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceNotes rdf:type rdf:Property ;
    rdfs:label 'Maintenance Notes' ;
    rdfs:comment 'Free-text notes documenting maintenance activities, observations, and recommendations for the decant structure.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Monitoring System Installed' ;
    rdfs:comment 'Indicates whether an automated monitoring system is installed on the decant structure.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outletElevationM rdf:type rdf:Property ;
    rdfs:label 'Outlet Elevation M' ;
    rdfs:comment 'Elevation of the decant structure outlet measured in meters above sea level.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeDiameterMm rdf:type rdf:Property ;
    rdfs:label 'Pipe Diameter Mm' ;
    rdfs:comment 'Internal diameter of the decant pipe measured in millimeters.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Pipe Material' ;
    rdfs:comment 'Material composition of the decant pipe used in the structure.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Permit Number' ;
    rdfs:comment 'Official permit or authorization number issued by regulatory authorities for the decant structure operation.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureCode rdf:type rdf:Property ;
    rdfs:label 'Structure Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the decant structure for identification and tracking purposes.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structureName rdf:type rdf:Property ;
    rdfs:label 'Structure Name' ;
    rdfs:comment 'Business name or designation of the decant structure for operational reference.' ;
    rdfs:domain ind:DecantStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTsfId rdf:type rdf:Property ;
    rdfs:label 'Destination Tsf Id' ;
    rdfs:comment 'Foreign key linking to tailings.tsf. Business justification: Destination facilities are where decanted water is sent. In mining operations, one common destination is transfer to another TSF for water reuse. When the destination facility IS a TSF, this FK links ' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tsf .

ind:rehabilitationPlanId rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Plan Id' ;
    rdfs:comment 'Reference to the approved rehabilitation and closure plan for this destination facility.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosurePlan .

ind:constructionMethod rdf:type rdf:Property ;
    rdfs:label 'Construction Method' ;
    rdfs:comment 'Engineering construction methodology used for the tailings storage facility, critical for risk assessment and regulatory compliance.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damHeightM rdf:type rdf:Property ;
    rdfs:label 'Dam Height M' ;
    rdfs:comment 'Maximum vertical height of the tailings dam structure measured from the foundation to the crest, in meters.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotechnicalMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Monitoring Frequency' ;
    rdfs:comment 'Required frequency of geotechnical monitoring activities including piezometer readings, settlement surveys, and stability assessments.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedClosureDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Date' ;
    rdfs:comment 'Anticipated date for facility closure and commencement of rehabilitation activities as per mine closure plan.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seepageMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Seepage Monitoring Required' ;
    rdfs:comment 'Indicates whether continuous seepage monitoring is mandated for this facility based on risk classification and regulatory requirements.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositionPlanId rdf:type rdf:Property ;
    rdfs:label 'Deposition Plan Id' ;
    rdfs:comment 'Primary key for deposition_plan' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:raiseScheduleId rdf:type rdf:Property ;
    rdfs:label 'Raise Schedule Id' ;
    rdfs:comment 'Reference to the dam raise schedule associated with this deposition plan, coordinating embankment construction with tailings placement.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:supersededByPlanId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Plan Id' ;
    rdfs:comment 'Reference to the deposition plan that supersedes this plan, establishing plan lineage and succession. Nullable if plan is current.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepositionPlan .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Official reference or permit number assigned by the approval authority for tracking and compliance purposes.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureRehabilitationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Closure Rehabilitation Plan Reference' ;
    rdfs:comment 'Reference to the closure and rehabilitation plan document that outlines post-deposition reclamation activities and long-term stewardship.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionMethod rdf:type rdf:Property ;
    rdfs:label 'Deposition Method' ;
    rdfs:comment 'Specific technique used for tailings placement: spigot (point discharge), cyclone (classification discharge), subaerial (above water), subaqueous (below water), beach discharge (distributed along beach), or tower discharge (central tower distribution).' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositionRateM3PerDay rdf:type rdf:Property ;
    rdfs:label 'Deposition Rate M3 Per Day' ;
    rdfs:comment 'Planned average daily rate of tailings deposition in cubic meters per day.' ;
    rdfs:domain ind:Tailings ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designEngineerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Design Engineer License Number' ;
    rdfs:comment 'Professional engineering license or registration number of the design engineer, required for regulatory compliance.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designEngineerName rdf:type rdf:Property ;
    rdfs:label 'Design Engineer Name' ;
    rdfs:comment 'Name of the professional engineer or engineering firm responsible for designing the deposition plan.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactStatementReference rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Statement Reference' ;
    rdfs:comment 'Reference number or identifier of the Environmental Impact Statement document associated with this deposition plan.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedClosureLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Closure Liability Amount' ;
    rdfs:comment 'Estimated financial liability for closure and rehabilitation activities associated with this deposition plan, in the operating currency.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotechnicalStabilityRating rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Stability Rating' ;
    rdfs:comment 'Assessment of the planned deposition configurations geotechnical stability: very high (excellent stability), high (good stability), moderate (acceptable with monitoring), low (requires mitigation), or very low (significant risk).' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPlanReference rdf:type rdf:Property ;
    rdfs:label 'Monitoring Plan Reference' ;
    rdfs:comment 'Reference to the geotechnical and environmental monitoring plan document that defines surveillance requirements during plan execution.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Planned Capacity M3' ;
    rdfs:comment 'Total volume of tailings material planned for deposition under this plan, measured in cubic meters.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Planned Capacity Tonnes' ;
    rdfs:comment 'Total mass of tailings material planned for deposition under this plan, measured in metric tonnes.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seepageControlStrategy rdf:type rdf:Property ;
    rdfs:label 'Seepage Control Strategy' ;
    rdfs:comment 'Description of the planned approach for managing and controlling seepage from the tailings facility, including drainage systems, liners, and collection methods.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBeachSlopePercent rdf:type rdf:Property ;
    rdfs:label 'Target Beach Slope Percent' ;
    rdfs:comment 'Planned slope angle of the tailings beach expressed as a percentage, critical for stability and drainage management.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetFreeboardM rdf:type rdf:Property ;
    rdfs:label 'Target Freeboard M' ;
    rdfs:comment 'Planned vertical distance between the water surface and the crest of the dam, measured in meters, required for flood containment and safety.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterManagementStrategy rdf:type rdf:Property ;
    rdfs:label 'Water Management Strategy' ;
    rdfs:comment 'Description of the planned approach for managing water balance, including reclaim water, stormwater, and process water within the deposition plan.' ;
    rdfs:domain ind:DepositionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Current Capacity Tonnes' ;
    rdfs:comment 'Remaining mass capacity available for tailings deposition at the time of model calculation, measured in metric tonnes.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentElevationM rdf:type rdf:Property ;
    rdfs:label 'Current Elevation M' ;
    rdfs:comment 'Current elevation of the tailings surface above sea level at the time of model calculation, measured in meters.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositionRateTonnesPerDay rdf:type rdf:Property ;
    rdfs:label 'Deposition Rate Tonnes Per Day' ;
    rdfs:comment 'Average daily mass rate at which tailings are deposited into the storage facility, measured in metric tonnes per day.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLifeYears rdf:type rdf:Property ;
    rdfs:label 'Estimated Life Years' ;
    rdfs:comment 'Projected number of years until the tailings storage facility reaches full capacity based on current deposition rates and available capacity.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeboardRequirementM rdf:type rdf:Property ;
    rdfs:label 'Freeboard Requirement M' ;
    rdfs:comment 'Minimum required vertical distance between the tailings surface and the crest of the dam for safety and operational purposes, measured in meters.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumElevationM rdf:type rdf:Property ;
    rdfs:label 'Maximum Elevation M' ;
    rdfs:comment 'Maximum elevation above sea level that the tailings storage facility is designed to reach, measured in meters.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelAssumptions rdf:type rdf:Property ;
    rdfs:label 'Model Assumptions' ;
    rdfs:comment 'Key assumptions and constraints underlying the capacity model calculations and projections.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Model Confidence Level' ;
    rdfs:comment 'Qualitative assessment of the confidence level in the capacity model predictions based on data quality, methodology robustness, and validation results.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed textual description of the capacity model including methodology, assumptions, and key parameters.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the capacity model methodology used for tailings storage facility capacity estimation and forecasting.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raiseStageNumber rdf:type rdf:Property ;
    rdfs:label 'Raise Stage Number' ;
    rdfs:comment 'Sequential number identifying the current or planned raise stage of the tailings dam embankment.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementFactor rdf:type rdf:Property ;
    rdfs:label 'Settlement Factor' ;
    rdfs:comment 'Factor accounting for consolidation and settlement of tailings over time, applied to capacity calculations.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidsConcentrationPercentage rdf:type rdf:Property ;
    rdfs:label 'Solids Concentration Percentage' ;
    rdfs:comment 'Average percentage of solids by weight in the tailings slurry deposited into the storage facility.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidsDensityTonnesPerM3 rdf:type rdf:Property ;
    rdfs:label 'Solids Density Tonnes Per M3' ;
    rdfs:comment 'Average density of tailings solids used in capacity calculations, measured in metric tonnes per cubic meter.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDesignCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity M3' ;
    rdfs:comment 'Maximum volumetric capacity of the tailings storage facility as designed, measured in cubic meters.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDesignCapacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity Tonnes' ;
    rdfs:comment 'Maximum mass capacity of the tailings storage facility as designed, measured in metric tonnes.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of total design capacity currently utilized by deposited tailings, calculated as (used capacity / total design capacity) × 100.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidRatio rdf:type rdf:Property ;
    rdfs:label 'Void Ratio' ;
    rdfs:comment 'Ratio of void volume to solids volume in deposited tailings, used for capacity and settlement calculations.' ;
    rdfs:domain ind:CapacityModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessDifficulty rdf:type rdf:Property ;
    rdfs:label 'Access Difficulty' ;
    rdfs:comment 'Classification of the difficulty level for field personnel to physically access the monitoring location for manual readings or maintenance.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Lower' ;
    rdfs:comment 'Lower boundary threshold value that triggers an alert condition when readings fall below this level.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Upper' ;
    rdfs:comment 'Upper boundary threshold value that triggers an alert condition when readings exceed this level.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Lower' ;
    rdfs:comment 'Lower boundary critical threshold value that triggers emergency response protocols when readings fall below this level.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold Upper' ;
    rdfs:comment 'Upper boundary critical threshold value that triggers emergency response protocols when readings exceed this level.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataLoggerCode rdf:type rdf:Property ;
    rdfs:label 'Data Logger Code' ;
    rdfs:comment 'Identifier of the automated data logger or telemetry system connected to this monitoring location for continuous data capture.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentManufacturer rdf:type rdf:Property ;
    rdfs:label 'Instrument Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or supplier of the monitoring instrument installed at this location.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentModel rdf:type rdf:Property ;
    rdfs:label 'Instrument Model' ;
    rdfs:comment 'Model number or designation of the monitoring instrument installed at this location.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPurpose rdf:type rdf:Property ;
    rdfs:label 'Monitoring Purpose' ;
    rdfs:comment 'Primary purpose or objective of the monitoring location within the tailings management framework.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reading Frequency' ;
    rdfs:comment 'Scheduled frequency at which readings are collected from this monitoring location as per the monitoring plan.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Geotechnical zone or area within the tailings storage facility where the monitoring location is positioned.' ;
    rdfs:domain ind:MonitoringLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Id' ;
    rdfs:comment 'Reference to the competency framework that defines required skills, certifications, and training for employees in this department. Used to ensure workforce capability and compliance with industry standards.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyFramework .

ind:parentDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Department Id' ;
    rdfs:comment 'Reference to the parent department in the organizational hierarchy. Null for top-level departments. Enables hierarchical reporting structures and roll-up of workforce metrics.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'Annual budget allocated to this department for operational expenses including payroll, equipment, supplies, and training. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Full official name of the department as used in organizational charts and formal communications.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Classification of the department based on its primary function within the mining operation. Operations departments are directly involved in extraction and processing, maintenance departments handle equipment upkeep, engineering departments manage technical design and planning, safety departments oversee health and safety compliance, administration departments provide corporate support, and support departments provide auxiliary services.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the department was officially created or established within the organization. Used for historical tracking and organizational evolution analysis.' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fatigueManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Fatigue Management Required' ;
    rdfs:comment 'Indicates whether this department is subject to formal fatigue management protocols due to shift work, extended hours, or safety-critical operations. True for departments requiring fatigue risk assessment and monitoring, false for standard office-based departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Headcount Capacity' ;
    rdfs:comment 'Maximum number of employees and contractors that can be assigned to this department based on operational requirements and budget allocation. Used for workforce planning and resource allocation.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isUnionized rdf:type rdf:Property ;
    rdfs:label 'Is Unionized' ;
    rdfs:comment 'Indicates whether this department is covered by a collective bargaining agreement. True for unionized departments, false for non-union departments. Affects payroll rules, grievance procedures, and workforce policies.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Payroll Integration Enabled' ;
    rdfs:comment 'Indicates whether this department is integrated with the SAP HR payroll system for automated time and attendance processing. True for departments with active payroll integration, false for departments managed outside the standard payroll system.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalLocation rdf:type rdf:Property ;
    rdfs:label 'Physical Location' ;
    rdfs:comment 'Physical location or building where the department is primarily based within the mine site. Examples include administration building, maintenance workshop, processing plant, underground level 5, or pit operations office.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMshaCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Msha Certification' ;
    rdfs:comment 'Indicates whether employees in this department must hold valid MSHA certifications to perform their duties. True for departments with direct mining operations exposure, false for administrative and support departments.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Name of the labor union representing employees in this department, if applicable. Null for non-unionized departments. Used for labor relations, collective bargaining, and compliance with union agreements.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSiteTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Site Types' ;
    rdfs:comment 'Comma-separated list of mine site types where this roster cycle is applicable (e.g., underground, open_pit, processing_plant, port_facility). [ENUM-REF-CANDIDATE: underground|open_pit|processing_plant|port_facility|exploration|maintenance_facility|administrative — promote to reference product]' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursPerShift rdf:type rdf:Property ;
    rdfs:label 'Hours Per Shift' ;
    rdfs:comment 'Standard number of hours per shift within this roster cycle (e.g., 12.0 for twelve-hour shifts).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isContinuousOperation rdf:type rdf:Property ;
    rdfs:label 'Is Continuous Operation' ;
    rdfs:comment 'Indicates whether this roster cycle supports 24/7 continuous operations (True) or standard operational hours (False).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxConsecutiveWorkDays rdf:type rdf:Property ;
    rdfs:label 'Max Consecutive Work Days' ;
    rdfs:comment 'Maximum number of consecutive work days permitted under this roster cycle before mandatory rest period. Used for fatigue risk management.' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRestHoursBetweenShifts rdf:type rdf:Property ;
    rdfs:label 'Min Rest Hours Between Shifts' ;
    rdfs:comment 'Minimum required rest hours between consecutive shifts to ensure fatigue management compliance.' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollCycleAlignment rdf:type rdf:Property ;
    rdfs:label 'Payroll Cycle Alignment' ;
    rdfs:comment 'Indicates how this roster cycle aligns with payroll processing periods for SAP HR integration.' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAccommodation rdf:type rdf:Property ;
    rdfs:label 'Requires Accommodation' ;
    rdfs:comment 'Indicates whether workers on this roster cycle require on-site or company-provided accommodation (True for FIFO/DIDO/residential rosters).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restDays rdf:type rdf:Property ;
    rdfs:label 'Rest Days' ;
    rdfs:comment 'Number of consecutive rest/off days in the roster cycle (e.g., 7 days for a 1-week-off roster).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Shifts Per Day' ;
    rdfs:comment 'Number of shifts per 24-hour period in this roster cycle (e.g., 2 for day/night rotation, 3 for continuous operations).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCycleDays rdf:type rdf:Property ;
    rdfs:label 'Total Cycle Days' ;
    rdfs:comment 'Total number of days in one complete roster cycle (work_days + rest_days). Used for scheduling and rotation planning.' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelAllowanceEligible rdf:type rdf:Property ;
    rdfs:label 'Travel Allowance Eligible' ;
    rdfs:comment 'Indicates whether workers on this roster cycle are eligible for travel allowances (typically True for FIFO/DIDO arrangements).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Reference' ;
    rdfs:comment 'Reference to the enterprise bargaining agreement or union contract that governs this roster cycle arrangement.' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDays rdf:type rdf:Property ;
    rdfs:label 'Work Days' ;
    rdfs:comment 'Number of consecutive work days in the roster cycle (e.g., 14 days for a 2-week-on roster).' ;
    rdfs:domain ind:RosterCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accommodationUnitId rdf:type rdf:Property ;
    rdfs:label 'Accommodation Unit Id' ;
    rdfs:comment 'Reference to the specific accommodation unit (room, cabin, dormitory) allocated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccommodationUnit .

ind:accessibilityRequired rdf:type rdf:Property ;
    rdfs:label 'Accessibility Required' ;
    rdfs:comment 'Indicates whether the allocation requires accessibility features for persons with disabilities.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Number' ;
    rdfs:comment 'Business-facing unique identifier for the accommodation allocation, used in operational communications and reporting.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInDate rdf:type rdf:Property ;
    rdfs:label 'Check In Date' ;
    rdfs:comment 'Date when the employee is scheduled to or did check into the allocated accommodation.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkOutDate rdf:type rdf:Property ;
    rdfs:label 'Check Out Date' ;
    rdfs:comment 'Date when the employee is scheduled to or did check out of the allocated accommodation.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Date' ;
    rdfs:comment 'Date when compliance verification was completed for this accommodation allocation.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether the accommodation allocation has been verified for compliance with Mine Safety and Health Administration (MSHA) and ISO 45001 requirements.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Included' ;
    rdfs:comment 'Indicates whether a meal plan is included as part of the accommodation allocation.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occupancyType rdf:type rdf:Property ;
    rdfs:label 'Occupancy Type' ;
    rdfs:comment 'Type of occupancy arrangement for the allocated accommodation unit.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Requirements' ;
    rdfs:comment 'Free-text description of any special accommodation requirements such as accessibility needs, medical considerations, or cultural preferences.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationProvided rdf:type rdf:Property ;
    rdfs:label 'Transportation Provided' ;
    rdfs:comment 'Indicates whether transportation between accommodation and work site is provided as part of the allocation.' ;
    rdfs:domain ind:AccommodationAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDrillHoles rdf:type rdf:Property ;
    rdfs:label 'Actual Drill Holes' ;
    rdfs:comment 'Number of drill holes or survey points actually completed during the campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTotalMeters rdf:type rdf:Property ;
    rdfs:label 'Actual Total Meters' ;
    rdfs:comment 'Total actual drilling or survey distance in meters completed during the campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Assay Laboratory Id' ;
    rdfs:comment 'Reference to the laboratory conducting assay analysis for samples collected during the campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the survey campaign describing its purpose or location focus.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Detailed description of the geological objectives and expected outcomes of the survey campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the survey campaign based on its geological purpose and scope.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Environmental Clearance Date' ;
    rdfs:comment 'Date when environmental clearance or approval was granted for the survey campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDrillHoles rdf:type rdf:Property ;
    rdfs:label 'Planned Drill Holes' ;
    rdfs:comment 'Number of drill holes or survey points planned for the campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTotalMeters rdf:type rdf:Property ;
    rdfs:label 'Planned Total Meters' ;
    rdfs:comment 'Total planned drilling or survey distance in meters for the campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the parent exploration or mining project under which this campaign is executed.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Government or regulatory body approval or permit number authorizing the survey campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleGeologistId rdf:type rdf:Property ;
    rdfs:label 'Responsible Geologist Id' ;
    rdfs:comment 'Reference to the geologist responsible for overseeing the survey campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleRecoveryPercent rdf:type rdf:Property ;
    rdfs:label 'Sample Recovery Percent' ;
    rdfs:comment 'Average sample recovery rate as a percentage, indicating the quality of core or chip recovery during drilling.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCommodity rdf:type rdf:Property ;
    rdfs:label 'Target Commodity' ;
    rdfs:comment 'Primary mineral commodity targeted by the survey campaign.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDepthM rdf:type rdf:Property ;
    rdfs:label 'Target Depth M' ;
    rdfs:comment 'Planned maximum depth in meters for drilling or survey penetration.' ;
    rdfs:domain ind:SurveyCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'Access control classification for the location. Used for safety management and operational security.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Surface area of the location in square meters. Used for capacity planning, rehabilitation costing, and environmental impact assessment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityTonnes rdf:type rdf:Property ;
    rdfs:label 'Capacity Tonnes' ;
    rdfs:comment 'Maximum material capacity of the location in tonnes. Used for stockpile management, ROM pad planning, and dump scheduling.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageZone rdf:type rdf:Property ;
    rdfs:label 'Drainage Zone' ;
    rdfs:comment 'Water drainage zone or catchment area identifier for the location. Used for water management and environmental compliance.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Zone' ;
    rdfs:comment 'Environmental management zone classification for the location (e.g., rehabilitation zone, buffer zone, heritage area).' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradePercent rdf:type rdf:Property ;
    rdfs:label 'Grade Percent' ;
    rdfs:comment 'Average ore grade at this location expressed as a percentage. Critical for mine planning, blending, and economic evaluation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Haul Distance Km' ;
    rdfs:comment 'Average haul distance from this location to the primary destination (e.g., crusher, ROM pad, waste dump) in kilometers.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the location in its lifecycle.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Business unit or department responsible for managing this location (e.g., Mining Operations, Processing, Maintenance).' ;
    rdfs:domain ind:Mining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Id' ;
    rdfs:comment 'Reference to the parent location in a hierarchical location structure (e.g., a bench within a pit, a drive within a stope). Nullable for top-level locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rehabilitationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rehabilitation Required Flag' ;
    rdfs:comment 'Indicates whether the location requires environmental rehabilitation upon closure or depletion.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibilityGroup rdf:type rdf:Property ;
    rdfs:label 'Compatibility Group' ;
    rdfs:comment 'Single letter (A-S) indicating which explosives can be stored and transported together based on hazard compatibility.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerKg rdf:type rdf:Property ;
    rdfs:label 'Cost Per Kg' ;
    rdfs:comment 'Standard cost per kilogram of this explosive type in the base currency. Used for blast cost estimation and budgeting.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:densityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per M3' ;
    rdfs:comment 'Typical density of the explosive in kilograms per cubic meter. Critical for blast design calculations and loading specifications.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyContentMjPerKg rdf:type rdf:Property ;
    rdfs:label 'Energy Content Mj Per Kg' ;
    rdfs:comment 'Energy released per kilogram of explosive, measured in megajoules. Used for blast energy calculations and fragmentation modeling.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fumeClass rdf:type rdf:Property ;
    rdfs:label 'Fume Class' ;
    rdfs:comment 'Classification of toxic fume production (Class 1 = lowest toxicity, Class 3 = highest). Important for underground operations and ventilation planning.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPrimingRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Priming Requirement' ;
    rdfs:comment 'Minimum primer or booster size and type required to reliably initiate this explosive type. Critical for blast design and safety.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'Manufacturer\'s product family or series name to which this explosive type belongs. Groups related explosive products.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeBulkStrengthPercent rdf:type rdf:Property ;
    rdfs:label 'Relative Bulk Strength Percent' ;
    rdfs:comment 'Explosive strength per unit volume relative to ANFO. Accounts for density differences in blast design calculations.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relativeWeightStrengthPercent rdf:type rdf:Property ;
    rdfs:label 'Relative Weight Strength Percent' ;
    rdfs:comment 'Explosive strength relative to ANFO (100%). Used to calculate equivalent explosive quantities and blast design parameters.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sensitivityRating rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Rating' ;
    rdfs:comment 'Sensitivity of the explosive to initiation by impact, friction, or heat (very_low, low, moderate, high, very_high). Affects handling and storage requirements.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum ambient temperature in Celsius at which the explosive maintains reliable performance and safety characteristics.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum ambient temperature in Celsius at which the explosive maintains reliable performance and safety characteristics.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalHoleDiameterMaxMm rdf:type rdf:Property ;
    rdfs:label 'Typical Hole Diameter Max Mm' ;
    rdfs:comment 'Maximum blast hole diameter in millimeters for which this explosive type is typically suitable. Guides blast design parameters.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalHoleDiameterMinMm rdf:type rdf:Property ;
    rdfs:label 'Typical Hole Diameter Min Mm' ;
    rdfs:comment 'Minimum blast hole diameter in millimeters for which this explosive type is typically suitable. Guides blast design parameters.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:velocityOfDetonationMPerS rdf:type rdf:Property ;
    rdfs:label 'Velocity Of Detonation M Per S' ;
    rdfs:comment 'Speed at which the detonation wave travels through the explosive, measured in meters per second. Key performance indicator for explosive effectiveness.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterResistance rdf:type rdf:Property ;
    rdfs:label 'Water Resistance' ;
    rdfs:comment 'Ability of the explosive to maintain performance in wet conditions (none, poor, fair, good, excellent). Critical for wet hole applications.' ;
    rdfs:domain ind:ExplosiveType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Completion Date' ;
    rdfs:comment 'Date when construction of the access ramp was completed and the ramp was ready for commissioning.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designCapacityTonnesPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tonnes Per Hour' ;
    rdfs:comment 'The planned maximum haulage throughput capacity of the ramp in tonnes per hour based on engineering design specifications.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drainageSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Drainage System Installed' ;
    rdfs:comment 'Indicates whether a drainage system is installed to manage water ingress and prevent flooding or erosion.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyEgressRoute rdf:type rdf:Property ;
    rdfs:label 'Emergency Egress Route' ;
    rdfs:comment 'Indicates whether this ramp is designated as an emergency evacuation route for personnel safety.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryElevationMeters rdf:type rdf:Property ;
    rdfs:label 'Entry Elevation Meters' ;
    rdfs:comment 'Elevation above sea level in meters at the ramp entry point.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitElevationMeters rdf:type rdf:Property ;
    rdfs:label 'Exit Elevation Meters' ;
    rdfs:comment 'Elevation above sea level in meters at the ramp exit point.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotechnicalRating rdf:type rdf:Property ;
    rdfs:label 'Geotechnical Rating' ;
    rdfs:comment 'Current geotechnical stability assessment rating of the ramp based on rock mass quality and ground conditions.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradientPercent rdf:type rdf:Property ;
    rdfs:label 'Gradient Percent' ;
    rdfs:comment 'The slope or incline of the ramp expressed as a percentage, critical for haulage equipment performance and safety calculations.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundSupportType rdf:type rdf:Property ;
    rdfs:label 'Ground Support Type' ;
    rdfs:comment 'Type of ground support system installed to maintain ramp stability and prevent rock falls.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthMeters rdf:type rdf:Property ;
    rdfs:label 'Length Meters' ;
    rdfs:comment 'Total length of the access ramp in meters from entry to exit point.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lightingInstalled rdf:type rdf:Property ;
    rdfs:label 'Lighting Installed' ;
    rdfs:comment 'Indicates whether permanent lighting infrastructure is installed along the ramp for operational safety.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumVehicleWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Maximum Vehicle Weight Tonnes' ;
    rdfs:comment 'Maximum gross vehicle weight in tonnes permitted to use this ramp based on structural and geotechnical design limits.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oreTypeAccess rdf:type rdf:Property ;
    rdfs:label 'Ore Type Access' ;
    rdfs:comment 'Type of ore or mineral that this ramp provides access to, relevant for production planning and scheduling.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitId rdf:type rdf:Property ;
    rdfs:label 'Pit Id' ;
    rdfs:comment 'Reference to the specific open pit or underground mine area that this ramp provides access to.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryUse rdf:type rdf:Property ;
    rdfs:label 'Primary Use' ;
    rdfs:comment 'The primary operational purpose or function that this ramp serves in the mine operations.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampCode rdf:type rdf:Property ;
    rdfs:label 'Ramp Code' ;
    rdfs:comment 'Externally-known unique business identifier code for the access ramp used in operational systems and mine planning documentation.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampName rdf:type rdf:Property ;
    rdfs:label 'Ramp Name' ;
    rdfs:comment 'Human-readable name or designation of the access ramp for operational reference and communication.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampStatus rdf:type rdf:Property ;
    rdfs:label 'Ramp Status' ;
    rdfs:comment 'Current operational lifecycle status of the access ramp indicating its availability for use.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampType rdf:type rdf:Property ;
    rdfs:label 'Ramp Type' ;
    rdfs:comment 'Classification of the ramp based on its primary operational purpose within the mine infrastructure.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surfaceType rdf:type rdf:Property ;
    rdfs:label 'Surface Type' ;
    rdfs:comment 'Type of surface material used on the ramp floor for traction and durability.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficDirection rdf:type rdf:Property ;
    rdfs:label 'Traffic Direction' ;
    rdfs:comment 'Permitted traffic flow direction on the ramp for operational safety and efficiency.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationType rdf:type rdf:Property ;
    rdfs:label 'Ventilation Type' ;
    rdfs:comment 'Type of ventilation system installed in the ramp for air quality and safety management, particularly relevant for underground ramps.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verticalDepthMeters rdf:type rdf:Property ;
    rdfs:label 'Vertical Depth Meters' ;
    rdfs:comment 'The vertical distance in meters that the ramp descends or ascends, representing the elevation change from surface or reference level.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthMeters rdf:type rdf:Property ;
    rdfs:label 'Width Meters' ;
    rdfs:comment 'The operational width of the ramp in meters, determining the size of equipment that can safely traverse it.' ;
    rdfs:domain ind:AccessRamp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation and control system integration for this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Target Percent' ;
    rdfs:comment 'Target mechanical availability percentage for equipment in this process area, calculated as available time divided by total time.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlSystemType rdf:type rdf:Property ;
    rdfs:label 'Control System Type' ;
    rdfs:comment 'Type of distributed control system (DCS), programmable logic controller (PLC), or supervisory control and data acquisition (SCADA) system managing this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedSizeP80Microns rdf:type rdf:Property ;
    rdfs:label 'Feed Size P80 Microns' ;
    rdfs:comment 'Target feed particle size distribution P80 (80th percentile) in microns for material entering this process area.' ;
    rdfs:domain ind:ProcessArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialsPresent rdf:type rdf:Property ;
