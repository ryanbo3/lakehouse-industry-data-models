    rdfs:comment 'Document reference number for the process flow diagram showing this stream in the overall plant flowsheet.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPlantId rdf:type rdf:Property ;
    rdfs:label 'Processing Plant Id' ;
    rdfs:comment 'Reference to the processing plant or concentrator facility where this stream exists.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reagentAdditionPointFlag rdf:type rdf:Property ;
    rdfs:label 'Reagent Addition Point Flag' ;
    rdfs:comment 'Indicates whether this stream is a reagent addition point where chemicals are introduced into the process.' ;
    rdfs:domain ind:ProcessStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplingFrequencyMinutes rdf:type rdf:Property ;
