ind:rfmTier rdf:type rdf:Property ;
    rdfs:label 'Rfm Tier' ;
    rdfs:comment 'Segment tier derived from the RFM score (platinum, gold, silver, bronze).' ;
    rdfs:domain ind:ShopperBehaviorFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSpend rdf:type rdf:Property ;
    rdfs:label 'Total Spend' ;
    rdfs:comment 'Aggregate monetary amount (USD) spent by the shopper across all purchases in the period.' ;
    rdfs:domain ind:ShopperBehaviorFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitCount rdf:type rdf:Property ;
    rdfs:label 'Visit Count' ;
    rdfs:comment 'Number of distinct store or channel visits made by the shopper in the period.' ;
    rdfs:domain ind:ShopperBehaviorFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shrinkAnalyticsFactId rdf:type rdf:Property ;
    rdfs:label 'Shrink Analytics Fact Id' ;
    rdfs:comment 'Unique surrogate key for each shrink analytics record.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCountVarianceDollars rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance Dollars' ;
    rdfs:comment 'Dollar variance between recorded inventory and cycle count.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountVarianceUnits rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance Units' ;
    rdfs:comment 'Units variance identified during cycle count reconciliation.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Indicates whether the shrink values are estimated (true) or based on actual count (false).' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownDollars rdf:type rdf:Property ;
    rdfs:label 'Markdown Dollars' ;
    rdfs:comment 'Dollar value of shrink attributable to markdowns.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:markdownUnits rdf:type rdf:Property ;
    rdfs:label 'Markdown Units' ;
    rdfs:comment 'Units lost due to markdown-driven shrink.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perishableShrinkDollars rdf:type rdf:Property ;
    rdfs:label 'Perishable Shrink Dollars' ;
    rdfs:comment 'Dollar value of shrink due to spoilage or perishable loss.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perishableShrinkUnits rdf:type rdf:Property ;
    rdfs:label 'Perishable Shrink Units' ;
    rdfs:comment 'Units of perishable items lost to spoilage.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkPercentOfSales rdf:type rdf:Property ;
    rdfs:label 'Shrink Percent Of Sales' ;
    rdfs:comment 'Shrink expressed as a percentage of total sales dollars for the period.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkReasonCode rdf:type rdf:Property ;
    rdfs:label 'Shrink Reason Code' ;
    rdfs:comment 'Internal code describing the specific reason for the shrink event.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkType rdf:type rdf:Property ;
    rdfs:label 'Shrink Type' ;
    rdfs:comment 'Category of shrink loss (e.g., theft, administrative, vendor, spoilage, markdown, cycle count variance).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSalesDollars rdf:type rdf:Property ;
    rdfs:label 'Total Sales Dollars' ;
    rdfs:comment 'Gross sales dollars for the store-department-period grain.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSalesUnits rdf:type rdf:Property ;
    rdfs:label 'Total Sales Units' ;
    rdfs:comment 'Total number of units sold for the store-department-period grain.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unknownShrinkDollars rdf:type rdf:Property ;
    rdfs:label 'Unknown Shrink Dollars' ;
    rdfs:comment 'Dollar value of shrink with no identified cause (administrative).' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unknownShrinkUnits rdf:type rdf:Property ;
    rdfs:label 'Unknown Shrink Units' ;
    rdfs:comment 'Units lost with unknown cause.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorShrinkDollars rdf:type rdf:Property ;
    rdfs:label 'Vendor Shrink Dollars' ;
    rdfs:comment 'Shrink dollars attributed to vendor-related loss (e.g., short shipments).' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorShrinkUnits rdf:type rdf:Property ;
    rdfs:label 'Vendor Shrink Units' ;
    rdfs:comment 'Units lost due to vendor-related issues.' ;
    rdfs:domain ind:ShrinkAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Sales facts need to be tied to the fiscal period entity for period-based financial consolidation and SOX reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:paymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: Needed for Transaction Detail Drill-Down report that joins sales fact to underlying payment transaction for finance reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:pricingPriceZoneId rdf:type rdf:Property ;
    rdfs:label 'Pricing Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: REQUIRED: Zone-level sales reporting needs each sales fact linked to its price zone for accurate margin and pricing analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Store sales are allocated to profit centers for profit-and-loss reporting; linking enables profit-center level sales performance dashboards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:promoZoneId rdf:type rdf:Property ;
    rdfs:label 'Promo Zone Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_zone. Business justification: Required for zone-level sales reporting used in regional performance dashboards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoZone .

ind:retailPriceId rdf:type rdf:Property ;
    rdfs:label 'Retail Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.retail_price. Business justification: REQUIRED: Transaction-level price audit links each sales fact to the exact retail price used, enabling compliance and margin verification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailPrice .

ind:averageMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Average Margin Percent' ;
    rdfs:comment 'Gross margin expressed as a percentage of net sales.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Average Price Per Unit' ;
    rdfs:comment 'Average selling price per item unit (net_sales_amount / total_units_sold).' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageTicketUsd rdf:type rdf:Property ;
    rdfs:label 'Average Ticket Usd' ;
    rdfs:comment 'Average sales amount per transaction (net_sales_amount divided by transaction_count).' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageUnitsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Average Units Per Transaction' ;
    rdfs:comment 'Mean number of items purchased per transaction (total_units_sold / transaction_count).' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Name of the weekday for sales_date. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Sales Amount' ;
    rdfs:comment 'Revenue from fuel transactions at the store (if applicable) for the day.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSalesPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Sales Percent' ;
    rdfs:comment 'Fuel sales amount expressed as a percentage of total net sales.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'True if sales_date is a recognized public or store-specific holiday.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalDay rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Day' ;
    rdfs:comment 'True if any store-wide promotion was active on sales_date.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnDay rdf:type rdf:Property ;
    rdfs:label 'Is Return Day' ;
    rdfs:comment 'True if the store processed a high volume of returns on sales_date.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltySalesPercent rdf:type rdf:Property ;
    rdfs:label 'Loyalty Sales Percent' ;
    rdfs:comment 'Loyalty sales amount expressed as a percentage of net sales.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthOfYear rdf:type rdf:Property ;
    rdfs:label 'Month Of Year' ;
    rdfs:comment 'Numeric month (1-12) for the sales_date.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netSalesPerSqft rdf:type rdf:Property ;
    rdfs:label 'Net Sales Per Sqft' ;
    rdfs:comment 'Net sales amount divided by store_sqft, a key productivity metric.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceIndex rdf:type rdf:Property ;
    rdfs:label 'Price Index' ;
    rdfs:comment 'Inflation/deflation factor applied to sales for price normalization.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Promo Sales Amount' ;
    rdfs:comment 'Sales dollars attributable to promotional pricing, BOGO, TPR, and ad circular offers.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoSalesPercent rdf:type rdf:Property ;
    rdfs:label 'Promo Sales Percent' ;
    rdfs:comment 'Promotional sales amount expressed as a percentage of net sales.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesDate rdf:type rdf:Property ;
    rdfs:label 'Sales Date' ;
    rdfs:comment 'Calendar date representing the day of sales aggregation (store local time).' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sales Timestamp' ;
    rdfs:comment 'Timestamp when the daily sales record was materialized in the silver layer.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shrinkAmount rdf:type rdf:Property ;
    rdfs:label 'Shrink Amount' ;
    rdfs:comment 'Dollar value of inventory loss due to theft, spoilage, or damage for the day.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shrinkPercent rdf:type rdf:Property ;
    rdfs:label 'Shrink Percent' ;
    rdfs:comment 'Shrink amount expressed as a percentage of net sales.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeSalesFactStatus rdf:type rdf:Property ;
    rdfs:label 'Store Sales Fact Status' ;
    rdfs:comment 'Current lifecycle status of the daily sales record: provisional (pre-validation), final (validated), or adjusted (post-close correction).' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeSqft rdf:type rdf:Property ;
    rdfs:label 'Store Sqft' ;
    rdfs:comment 'Total selling area of the store in square feet.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeType rdf:type rdf:Property ;
    rdfs:label 'Store Type' ;
    rdfs:comment 'Classification of the store format based on size and service offering.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Total Units Sold' ;
    rdfs:comment 'Aggregate count of all items (units) sold across all transactions.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weekOfYear rdf:type rdf:Property ;
    rdfs:label 'Week Of Year' ;
    rdfs:comment 'ISO week number (1-53) for the sales_date.' ;
    rdfs:domain ind:StoreSalesFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'Four-digit year for the sales_date.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAnalyticsFactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Analytics Fact Id' ;
    rdfs:comment 'Unique identifier for each vendor performance record. _canonical_skip_reason: Entity does not fit predefined role categories.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Total monetary value of chargebacks assessed against the vendor.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackCount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Count' ;
    rdfs:comment 'Number of chargeback events recorded for the vendor during the period.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundShipmentVolume rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Volume' ;
    rdfs:comment 'Total volume (e.g., pallets or cubic meters) of goods received from the vendor.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeActualDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Actual Days' ;
    rdfs:comment 'Average number of days from purchase order issuance to receipt of goods.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeSlaDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Sla Days' ;
    rdfs:comment 'Contractual target lead time defined in the vendor service level agreement.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of deliveries that arrived at the store on or before the promised delivery window.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Order Accuracy Rate' ;
    rdfs:comment 'Percentage of orders delivered without discrepancies between ordered and received quantities.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Date-time when the record was materialized into the silver layer.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrders rdf:type rdf:Property ;
    rdfs:label 'Total Orders' ;
    rdfs:comment 'Count of purchase orders placed with the vendor in the period.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:comment 'Aggregate number of individual units (SKUs) received from the vendor.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsShipped rdf:type rdf:Property ;
    rdfs:label 'Total Units Shipped' ;
    rdfs:comment 'Aggregate number of units shipped by the vendor to distribution centers.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Compliance Score' ;
    rdfs:comment 'Composite score reflecting overall vendor adherence to contractual and operational metrics.' ;
    rdfs:domain ind:VendorAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentItemId rdf:type rdf:Property ;
    rdfs:label 'Assortment Item Id' ;
    rdfs:comment 'Unique identifier for the assortment item record. Primary key for this entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentItem .

ind:assortmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Assortment Plan Id' ;
    rdfs:comment 'Reference to the parent assortment plan that this item belongs to. Links this SKU inclusion decision to the broader merchandise planning strategy.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentPlan .

ind:planogramId rdf:type rdf:Property ;
    rdfs:label 'Planogram Id' ;
    rdfs:comment 'Reference to the planogram that defines the physical shelf layout for this assortment item. Links assortment strategy to visual merchandising execution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Planogram .

ind:storeClusterId rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Id' ;
    rdfs:comment 'Reference to the store cluster for which this assortment item is defined. Enables localized assortment strategies by grouping stores with similar demographics, format, or demand patterns.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreCluster .

ind:subcategoryId rdf:type rdf:Property ;
    rdfs:label 'Subcategory Id' ;
    rdfs:comment 'Reference to the merchandise subcategory for finer-grained assortment segmentation. Enables detailed space allocation and assortment breadth analysis within categories.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when this assortment item was approved for inclusion in the plan. Tracks decision timing and supports audit trails for assortment changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the merchandising manager or category manager who approved this assortment item inclusion. Supports governance and accountability for assortment decisions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentTier rdf:type rdf:Property ;
    rdfs:label 'Assortment Tier' ;
    rdfs:comment 'Strategic importance tier of this SKU within the assortment. Defines priority for space allocation, inventory investment, and promotional support.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Brand name of the product included in the assortment. Enables brand-level assortment analysis, private-label vs national-brand mix reporting, and brand performance tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this assortment item is discontinued or removed from the plan. Null for ongoing items. Enables SKU rationalization, seasonal exits, and planned discontinuations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this assortment item becomes active and should be carried in stores. Supports phased rollouts, seasonal transitions, and new item introduction timing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global trade item number (UPC, EAN, or GTIN-14) for the product. Enables cross-enterprise product identification and EDI transactions with suppliers.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this SKU within the assortment plan. Indicates whether the item is actively carried, newly introduced, discontinued, or represents a localized override decision. [ENUM-REF-CANDIDATE: active|discontinued|new|localized_add|localized_remove|pending|seasonal_inactive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this SKU was first introduced into the assortment. Enables new item maturity analysis and time-to-productivity measurement.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localizationSource rdf:type rdf:Property ;
    rdfs:label 'Localization Source' ;
    rdfs:comment 'Primary driver for localized assortment decision. Identifies the business factor that triggered inclusion or exclusion of this SKU at the local level. [ENUM-REF-CANDIDATE: demographic_demand|local_supplier|store_format|competitive_response|customer_request|test_market|ethnic_community — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingRole rdf:type rdf:Property ;
    rdfs:label 'Merchandising Role' ;
    rdfs:comment 'Strategic role this SKU plays in the assortment. Defines whether the item is a core year-round offering, seasonal rotation, localized for demographic demand, ethnic specialty, private-label brand, promotional driver, or test item. [ENUM-REF-CANDIDATE: core|seasonal|local|ethnic|private_label|promotional|test — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFacings rdf:type rdf:Property ;
    rdfs:label 'Minimum Facings' ;
    rdfs:comment 'Minimum number of product facings (front-facing units on shelf) required for this SKU. Drives planogram execution and ensures adequate shelf presence for sales velocity and customer visibility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this assortment item record was last modified. Tracks changes to assortment decisions and supports change management processes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newItemFlag rdf:type rdf:Property ;
    rdfs:label 'New Item Flag' ;
    rdfs:comment 'Indicates whether this is a new item introduction within the current planning cycle. Supports new item performance tracking and innovation pipeline management.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this assortment item represents a localized override to the standard cluster plan. True when a store or sub-cluster has deviated from the base assortment strategy.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Business rationale for localized assortment override. Captures the reason for deviation from standard plan such as demographic demand, competitive response, local supplier availability, or store format requirements.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this SKU is a store-owned private-label brand product. Supports private-label penetration analysis and margin optimization strategies.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rationalizationCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Rationalization Candidate Flag' ;
    rdfs:comment 'Indicates whether this SKU has been identified as a candidate for removal during SKU rationalization analysis. Flags underperforming items for review and potential discontinuation.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rationalizationReason rdf:type rdf:Property ;
    rdfs:label 'Rationalization Reason' ;
    rdfs:comment 'Primary reason this SKU is flagged for rationalization. Captures the business driver for potential discontinuation such as poor sales velocity, margin erosion, or assortment duplication. [ENUM-REF-CANDIDATE: low_sales|low_margin|duplication|supplier_exit|quality_issues|regulatory|space_optimization — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedFacings rdf:type rdf:Property ;
    rdfs:label 'Recommended Facings' ;
    rdfs:comment 'Optimal number of facings recommended by space planning algorithms based on sales velocity, margin, and shelf capacity. Guides planogram design and space allocation decisions.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Seasonal period or event this SKU is associated with. Enables seasonal assortment transitions, promotional calendar alignment, and year-over-year seasonal performance comparison. [ENUM-REF-CANDIDATE: spring|summer|fall|winter|holiday|back_to_school|easter|fourth_of_july — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this SKU is a seasonal item with recurring annual availability windows. Supports seasonal planning, space resets, and inventory flow management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfPositionCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Position Code' ;
    rdfs:comment 'Recommended shelf position or merchandising location for this SKU. Indicates optimal vertical and horizontal placement to maximize visibility, accessibility, and sales performance. [ENUM-REF-CANDIDATE: eye_level|reach_level|stoop_level|endcap|gondola_end|power_aisle|checkout — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal stock keeping unit identifier for the product included in this assortment. The unique item-level identifier used across merchandising, inventory, and POS systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceAllocationLinearFeet rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Linear Feet' ;
    rdfs:comment 'Allocated shelf space for this SKU measured in linear feet. Drives planogram design and ensures space allocation aligns with sales velocity and strategic importance.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAssortmentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Associate Id' ;
    rdfs:comment 'Identifier for the merchandise planning manager or director who approved this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryAssortmentBuyerUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Assortment Buyer User Associate Id' ;
    rdfs:comment 'Identifier for the buyer responsible for procurement and vendor negotiations for SKUs in this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualSkuCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sku Count' ;
    rdfs:comment 'Actual number of unique SKUs approved and included in the final assortment plan after merchandise planning review.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Strategy' ;
    rdfs:comment 'Strategic approach for this assortment plan: broad (wide variety), focused (narrow depth), premium (high-end), value (price-focused), seasonal (time-limited), or promotional (event-driven).' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Plan Amount' ;
    rdfs:comment 'Planned cost of goods sold (COGS) for this assortment plan during the planning period.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuedItemCount rdf:type rdf:Property ;
    rdfs:label 'Discontinued Item Count' ;
    rdfs:comment 'Number of SKUs being discontinued or removed from the assortment compared to the previous planning period.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target GMROI (Gross Margin Return on Investment) ratio for this assortment plan, calculated as gross margin divided by average inventory investment. Key metric for assortment productivity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryInvestmentPlan rdf:type rdf:Property ;
    rdfs:label 'Inventory Investment Plan' ;
    rdfs:comment 'Planned average inventory investment at cost required to support this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this assortment plan record was last updated in the Oracle Retail Merchandising System.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:localizationLevel rdf:type rdf:Property ;
    rdfs:label 'Localization Level' ;
    rdfs:comment 'Geographic granularity of this assortment plan: national (all stores), regional (multi-state), cluster (store groups), or store (individual location).' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Plan Amount' ;
    rdfs:comment 'Planned gross margin (sales minus cost) for this assortment plan during the planning period.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPlanPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Plan Percent' ;
    rdfs:comment 'Planned gross margin percentage (margin divided by sales) target for this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newItemCount rdf:type rdf:Property ;
    rdfs:label 'New Item Count' ;
    rdfs:comment 'Number of new SKUs being introduced in this assortment plan that were not in the previous period\'s assortment.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier code for the assortment plan used for external reference and reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Business-friendly name for the assortment plan, typically including category and season identifiers (e.g., \'Spring 2024 Fresh Produce Assortment\').' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the assortment plan: draft (being created), in_review (under merchandise planning review), approved (ready for execution), active (currently in effect), completed (planning period ended), or cancelled (plan abandoned).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Type of planning horizon for this assortment plan (season, quarter, year, promotional event, or ad circular cycle).' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningSeason rdf:type rdf:Property ;
    rdfs:label 'Planning Season' ;
    rdfs:comment 'Season identifier for seasonal assortment plans (e.g., \'Spring 2024\', \'Holiday 2024\', \'Back to School 2024\').' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelSalesPlanPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Sales Plan Percent' ;
    rdfs:comment 'Target percentage of total sales plan that should come from private label products in this assortment.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelSkuCount rdf:type rdf:Property ;
    rdfs:label 'Private Label Sku Count' ;
    rdfs:comment 'Number of private label (store-owned brand) SKUs included in this assortment plan. Used for private label penetration tracking.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Plan Amount' ;
    rdfs:comment 'Planned sales revenue target for this assortment plan during the planning period. Used for financial planning and GMROI (Gross Margin Return on Investment) calculation.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSkuCount rdf:type rdf:Property ;
    rdfs:label 'Target Sku Count' ;
    rdfs:comment 'Planned number of unique SKUs (Stock Keeping Units) to be carried in this assortment plan. Used for SKU rationalization and space planning.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacings rdf:type rdf:Property ;
    rdfs:label 'Total Facings' ;
    rdfs:comment 'Total number of product facings (product fronts visible on shelf) allocated across all SKUs in this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnRateTarget rdf:type rdf:Property ;
    rdfs:label 'Turn Rate Target' ;
    rdfs:comment 'Target inventory turn rate (number of times inventory is sold and replaced during the planning period) for this assortment plan.' ;
    rdfs:domain ind:AssortmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewId rdf:type rdf:Property ;
    rdfs:label 'Review Id' ;
    rdfs:comment 'Unique identifier for the assortment review event. Primary key.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReviewCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Review Category Id' ;
    rdfs:comment 'Reference to the merchandise category being reviewed in this assortment review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:reviewApprovedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Review Approved By Associate Id' ;
    rdfs:comment 'Reference to the associate or executive who approved the assortment review recommendations.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:reviewAssociateId rdf:type rdf:Property ;
    rdfs:label 'Review Associate Id' ;
    rdfs:comment 'Reference to the buyer or merchandise planner who led or participated in the assortment review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:reviewCategoryId rdf:type rdf:Property ;
    rdfs:label 'Review Category Id' ;
    rdfs:comment 'Reference to the merchandise subcategory being reviewed, providing finer granularity within the category.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:reviewCategoryManagerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Review Category Manager Associate Id' ;
    rdfs:comment 'Reference to the category manager responsible for the category under review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Comma-separated list or description of follow-up action items assigned as a result of the assortment review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether formal approval from senior management or merchandising leadership is required for the recommendations from this review.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryCaptainInputFlag rdf:type rdf:Property ;
    rdfs:label 'Category Captain Input Flag' ;
    rdfs:comment 'Indicates whether the category captain vendor provided formal input or recommendations during this review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Target Date' ;
    rdfs:comment 'The target date by which the assortment changes recommended in this review should be implemented in stores.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryTurnRating rdf:type rdf:Property ;
    rdfs:label 'Inventory Turn Rating' ;
    rdfs:comment 'Overall qualitative rating of the category inventory turnover performance during the review period.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Margin Performance Rating' ;
    rdfs:comment 'Overall qualitative rating of the category gross margin performance during the review period.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next assortment review for this category, driving the assortment planning cycle.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oosPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Oos Performance Rating' ;
    rdfs:comment 'Overall qualitative rating of the category out-of-stock performance during the review period.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricsReviewed rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics Reviewed' ;
    rdfs:comment 'Comma-separated list or description of the key performance metrics evaluated during the review, such as sales velocity, GMROI, turn rate, out-of-stock rate, shrink.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Update Required Flag' ;
    rdfs:comment 'Indicates whether planogram updates are required as a result of this assortment review.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which the assortment review meeting or evaluation was conducted.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business-facing unique identifier for the assortment review event, formatted as AR-YYYYMMDD or similar convention.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the assortment review event.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'The type or cadence of the assortment review: quarterly, annual, ad hoc, seasonal, new store opening, or planogram reset.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Sales Performance Rating' ;
    rdfs:comment 'Overall qualitative rating of the category sales performance during the review period.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skusRecommendedAdd rdf:type rdf:Property ;
    rdfs:label 'Skus Recommended Add' ;
    rdfs:comment 'The number of new SKUs recommended for addition to the assortment as a result of this review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skusRecommendedDrop rdf:type rdf:Property ;
    rdfs:label 'Skus Recommended Drop' ;
    rdfs:comment 'The number of existing SKUs recommended for discontinuation or removal from the assortment as a result of this review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skusRecommendedRetain rdf:type rdf:Property ;
    rdfs:label 'Skus Recommended Retain' ;
    rdfs:comment 'The number of existing SKUs recommended to remain in the assortment without changes.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaceReallocationFlag rdf:type rdf:Property ;
    rdfs:label 'Space Reallocation Flag' ;
    rdfs:comment 'Indicates whether shelf space reallocation decisions were made during this review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSkusEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Skus Evaluated' ;
    rdfs:comment 'The total number of SKUs that were evaluated during this assortment review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchy. Null for top-level departments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:averageShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Average Shelf Life Days' ;
    rdfs:comment 'Average shelf life in days for products in this category. Used for inventory planning and shrink management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Business identifier code for the category used across systems and reporting. Typically alphanumeric code assigned by merchandising team.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the category scope, including product types, brands, and assortment guidelines.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full business name of the merchandise category (e.g., Yogurt, Fresh Produce, Bakery).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification of the category node type within the merchandise hierarchy.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether this category is eligible for direct store delivery from vendors, bypassing the distribution center.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endcapEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Endcap Eligible Flag' ;
    rdfs:comment 'Indicates whether products in this category are eligible for end-of-aisle endcap promotional displays.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Required Flag' ;
    rdfs:comment 'Indicates whether this category requires HACCP food safety protocols for handling and storage.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the category tree (1=Department, 2=Class, 3=Subclass, 4=Category, 5=Sub-Category).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full path from root to this category (e.g., Grocery > Dairy > Yogurt). Used for navigation and rollup reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizedAssortmentFlag rdf:type rdf:Property ;
    rdfs:label 'Localized Assortment Flag' ;
    rdfs:comment 'Indicates whether this category supports localized assortment variations by store cluster based on demographics and regional preferences.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Strategy' ;
    rdfs:comment 'Pricing markdown strategy for clearance and slow-moving items in this category.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether this category requires USDA organic certification for included products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether this category contains perishable items requiring cold chain management and FIFO inventory practices.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Required Flag' ;
    rdfs:comment 'Indicates whether this category requires formal planogram execution for visual merchandising and space allocation.' ;
    rdfs:domain ind:Grocery ;
