    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Demand Document Number' ;
    rdfs:comment 'Reference to the originating demand document (sales order, transfer order, production order, or OMS allocation).' ;
