    rdfs:comment 'Name or identifier of the person/team responsible for remediation.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Any extra free-text comments from stakeholders.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'How the issue was discovered.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Dq Issue Status' ;
    rdfs:comment 'Current lifecycle state of the data quality issue.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Quantitative score (0-100) representing overall business impact.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'True if the issue is deemed critical for business operations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatory rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory' ;
    rdfs:comment 'Indicates whether the issue affects regulatory reporting or compliance.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueCategory rdf:type rdf:Property ;
    rdfs:label 'Issue Category' ;
    rdfs:comment 'Higher-level grouping of the issue type.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed narrative describing the nature, scope, and impact of the data quality problem.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueType rdf:type rdf:Property ;
    rdfs:label 'Issue Type' ;
    rdfs:comment 'Category of data quality problem (e.g., completeness, accuracy).' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent review of the issue by the owner.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Numeric priority (e.g., 1-5) used for internal triage.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:product rdf:type rdf:Property ;
    rdfs:label 'Product' ;
    rdfs:comment 'Specific data product or dataset where the issue was detected. [ENUM-REF-CANDIDATE: assortment|pricing|replenishment|sales|loyalty|pharmacy|supply_chain|store|finance — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Regulatory authority impacted (e.g., FDA, HIPAA). [ENUM-REF-CANDIDATE: FDA|USDA|DEA|FTC|OSHA|EPA|PCI_DSS|HIPAA|SOX — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Planned or executed action to correct the data quality problem.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-form notes describing how the issue was resolved or why it was waived.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of the underlying cause of the issue.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level indicating the business impact of the issue.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'Service-level-agreement date by which the issue must be addressed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Planned date by which the issue should be resolved.' ;
    rdfs:domain ind:DqIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title of the data quality issue.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqResultId rdf:type rdf:Property ;
    rdfs:label 'Dq Result Id' ;
    rdfs:comment 'System-generated unique identifier for the data quality result record.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productItemId rdf:type rdf:Property ;
    rdfs:label 'Product Item Id' ;
    rdfs:comment 'Foreign key linking to product.product_item. Business justification: Data-quality rule results need to reference the exact product item they evaluate for traceability and remediation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductItem .

ind:dataAsset rdf:type rdf:Property ;
    rdfs:label 'Data Asset' ;
    rdfs:comment 'Logical name of the data asset (product) that the rule validates.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAssetVersion rdf:type rdf:Property ;
    rdfs:label 'Data Asset Version' ;
    rdfs:comment 'Version identifier of the data asset at the time of validation.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dqResultStatus rdf:type rdf:Property ;
    rdfs:label 'Dq Result Status' ;
    rdfs:comment 'Overall pass/fail status of the rule execution against the defined threshold.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Evaluated Record Count' ;
    rdfs:comment 'Number of records examined by the rule during this run.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Execution Environment' ;
    rdfs:comment 'Identifier of the compute environment or cluster where the rule was executed.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Failed Record Count' ;
    rdfs:comment 'Number of records that violated the rule conditions.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passRatePct rdf:type rdf:Property ;
    rdfs:label 'Pass Rate Pct' ;
    rdfs:comment 'Percentage of records that passed the rule (passed / evaluated * 100).' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Passed Record Count' ;
    rdfs:comment 'Number of records that satisfied the rule conditions.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Remediation Ticket Number' ;
    rdfs:comment 'Reference identifier of the ticket created to address the data quality issue.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Classification of the rule type (e.g., completeness, uniqueness, range).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the data quality rule.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Date and time when the data quality rule execution was performed.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleFailedKeys rdf:type rdf:Property ;
    rdfs:label 'Sample Failed Keys' ;
    rdfs:comment 'JSON-encoded list of primary-key values for a sample of records that failed the rule.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact severity assigned to the rule failure.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetColumn rdf:type rdf:Property ;
    rdfs:label 'Target Column' ;
    rdfs:comment 'Column within the target product that the rule evaluated.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDomain rdf:type rdf:Property ;
    rdfs:label 'Target Domain' ;
    rdfs:comment 'Business domain (e.g., product, customer, inventory) to which the rule was applied.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProduct rdf:type rdf:Property ;
    rdfs:label 'Target Product' ;
    rdfs:comment 'Name of the data product (table or view) that was validated.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric threshold that the rule\'s pass rate must meet or exceed.' ;
    rdfs:domain ind:DqResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Metric Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.metric_definition. Business justification: Data quality rules are often scoped to a metric; add metric reference.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetricDefinition .

ind:dqRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Dq Rule Description' ;
    rdfs:comment 'Detailed narrative explaining the purpose and logic of the rule.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether the rule is executed automatically as part of data pipelines.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPassRate rdf:type rdf:Property ;
    rdfs:label 'Last Pass Rate' ;
    rdfs:comment 'Observed pass percentage from the most recent rule execution.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent execution of the rule.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the rule definition.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Pct' ;
    rdfs:comment 'Minimum acceptable pass rate for the rule expressed as a percentage.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Team or individual responsible for addressing rule violations.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'SQL or Great Expectations expression that defines the rule logic.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of rule such as completeness, uniqueness, validity, referential integrity, timeliness, or consistency.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEntity rdf:type rdf:Property ;
    rdfs:label 'Target Entity' ;
    rdfs:comment 'Name of the entity/table that the rule validates.' ;
    rdfs:domain ind:DqRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastBaselineId rdf:type rdf:Property ;
    rdfs:label 'Forecast Baseline Id' ;
    rdfs:comment 'System-generated unique identifier for the forecast baseline record.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineCode rdf:type rdf:Property ;
    rdfs:label 'Baseline Code' ;
    rdfs:comment 'Business code used to reference the baseline in external systems.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineName rdf:type rdf:Property ;
    rdfs:label 'Baseline Name' ;
    rdfs:comment 'Human-readable name describing the forecast baseline.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Category of metric the baseline represents.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Primary forecasted metric value for the defined grain and horizon.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Lower' ;
    rdfs:comment 'Lower bound of the statistical confidence interval for the baseline value.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Upper' ;
    rdfs:comment 'Upper bound of the statistical confidence interval for the baseline value.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBaselineStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Baseline Status' ;
    rdfs:comment 'Current lifecycle state of the baseline record.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastFrequency rdf:type rdf:Property ;
    rdfs:label 'Forecast Frequency' ;
    rdfs:comment 'Regularity at which the baseline is refreshed or recalculated.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grain rdf:type rdf:Property ;
    rdfs:label 'Grain' ;
    rdfs:comment 'Granularity of the forecast (e.g., SKU-store-week).' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:horizonWeeks rdf:type rdf:Property ;
    rdfs:label 'Horizon Weeks' ;
    rdfs:comment 'Number of weeks forward the baseline forecasts cover.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether the baseline value has been manually adjusted.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Description of the statistical or ML method used to generate the baseline.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Multiplier applied to capture seasonal effects in the baseline.' ;
    rdfs:domain ind:ForecastBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryAnalyticsFactId rdf:type rdf:Property ;
    rdfs:label 'Inventory Analytics Fact Id' ;
    rdfs:comment 'Surrogate primary key for the inventory analytics fact record.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Unique identifier of the stock keeping unit (SKU) being measured.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Enables Stock Position Detail Report that analyzes on-hand value and shrink per stock position across stores.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.storage_location. Business justification: Supports Location-Level Inventory Dashboard tracking on-hand units per storage location for capacity planning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Unique identifier of the vendor or supplier that provides the SKU.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.wave. Business justification: Inventory snapshot per wave supports inventory turn and stock-out analysis tied to wave execution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Originating operational system that supplied the source inventory data.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'Estimated number of days the current on-hand inventory will satisfy forecasted demand.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Fifo Compliance Rate' ;
    rdfs:comment 'Percentage of inventory moves that adhered to First-In-First-Out rotation policy.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmroi rdf:type rdf:Property ;
    rdfs:label 'Gmroi' ;
    rdfs:comment 'Financial efficiency metric calculated as gross margin divided by average inventory cost.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inStockRate rdf:type rdf:Property ;
    rdfs:label 'In Stock Rate' ;
    rdfs:comment 'Percentage of time the SKU was available for sale during the reporting period.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTurns rdf:type rdf:Property ;
    rdfs:label 'Inventory Turns' ;
    rdfs:comment 'Number of times inventory was sold and replaced over the period.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPerishable rdf:type rdf:Property ;
    rdfs:label 'Is Perishable' ;
    rdfs:comment 'Indicates whether the SKU is classified as perishable (true) or non-perishable (false).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'True if the SKU is a store-owned private label product; otherwise false.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReplenishmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Date' ;
    rdfs:comment 'Date of the most recent replenishment receipt for the SKU at the store.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReplenishmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Replenishment Quantity' ;
    rdfs:comment 'Units received in the most recent replenishment event.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastStockoutDate rdf:type rdf:Property ;
    rdfs:label 'Last Stockout Date' ;
    rdfs:comment 'Date when the SKU most recently went out of stock at the store.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStockoutDurationDays rdf:type rdf:Property ;
    rdfs:label 'Last Stockout Duration Days' ;
    rdfs:comment 'Number of days the SKU remained out of stock during the most recent stock-out event.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandDollars rdf:type rdf:Property ;
    rdfs:label 'On Hand Dollars' ;
    rdfs:comment 'Monetary value of on-hand units based on standard cost or average cost.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandUnits rdf:type rdf:Property ;
    rdfs:label 'On Hand Units' ;
    rdfs:comment 'Quantity of units physically available on the sales floor or backroom at snapshot time.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onOrderDollars rdf:type rdf:Property ;
    rdfs:label 'On Order Dollars' ;
    rdfs:comment 'Monetary value of units on order based on purchase price.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onOrderUnits rdf:type rdf:Property ;
    rdfs:label 'On Order Units' ;
    rdfs:comment 'Quantity of units that have been ordered from the distribution center or vendor but not yet received.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shrinkUnits rdf:type rdf:Property ;
    rdfs:label 'Shrink Units' ;
    rdfs:comment 'Units lost due to theft, damage, spoilage, or administrative error.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Date of the inventory snapshot representing the grain of the fact (SKU-store-day).' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotType rdf:type rdf:Property ;
    rdfs:label 'Snapshot Type' ;
    rdfs:comment 'Granularity of the inventory snapshot; typically daily for operational reporting.' ;
    rdfs:domain ind:InventoryAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: KPIs are defined to monitor performance of compliance programs; linking KPI to its governing program enables program-level scorecards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Plain-text description of the formula or logic used to compute the KPI.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityRule rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rule' ;
    rdfs:comment 'Rule or constraint ensuring data quality for the KPI (e.g., non-null sales amount).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Primary source system or data domain feeding the KPI (e.g., POS, ERP, WMS).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionCategory rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Category' ;
    rdfs:comment 'High-level business domain the KPI belongs to.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionCode rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Code' ;
    rdfs:comment 'Business identifier or short code for the KPI (e.g., COMP_SALES_QTR).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Description' ;
    rdfs:comment 'Detailed narrative describing the KPI purpose and calculation context.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionName rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Name' ;
    rdfs:comment 'Human-readable name of the KPI as used in reports and dashboards.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Status' ;
    rdfs:comment 'Current lifecycle state of the KPI definition.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the KPI definition was last reviewed for relevance or accuracy.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often the KPI is calculated and reported.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'Enterprise strategic goal that the KPI supports (e.g., Increase Same-Store Sales).' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThreshold rdf:type rdf:Property ;
    rdfs:label 'Target Threshold' ;
    rdfs:comment 'Acceptable lower/upper threshold range for the KPI; stored as a single numeric bound when only one side is defined.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Target or goal value for the KPI (e.g., 5.0 for 5%).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Measurement unit for the KPI value (e.g., percent, dollars, count).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the KPI definition (e.g., v1.0, v2.1).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Id' ;
    rdfs:comment 'System-generated unique identifier for each KPI target record.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associateId rdf:type rdf:Property ;
