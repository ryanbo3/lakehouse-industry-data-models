    rdfs:range xsd:boolean .

ind:kpiTargetDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Description' ;
    rdfs:comment 'Free-form description of the KPI target purpose and scope.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAcceptableThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Acceptable Threshold' ;
    rdfs:comment 'Lowest acceptable performance level before corrective action is required.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organizationLevel rdf:type rdf:Property ;
    rdfs:label 'Organization Level' ;
    rdfs:comment 'Level of the organization to which the target applies.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'Aggressive stretch target value for the KPI, used for high-performance incentives.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Target Approval Date' ;
    rdfs:comment 'Date when the KPI target was officially approved.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Business code used to reference the KPI target (e.g., TM_SALES_Q1).' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMethodology rdf:type rdf:Property ;
    rdfs:label 'Target Methodology' ;
    rdfs:comment 'Method used to derive the target (e.g., top-down corporate goal, bottom-up store forecast).' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Target Owner Department' ;
    rdfs:comment 'Business department responsible for the KPI target.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReviewDate rdf:type rdf:Property ;
    rdfs:label 'Target Review Date' ;
    rdfs:comment 'Scheduled date for formal review of the KPI target performance.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetStatus rdf:type rdf:Property ;
    rdfs:label 'Target Status' ;
    rdfs:comment 'Current lifecycle status of the KPI target record.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Category of the KPI target indicating its business domain.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborAnalyticsFactId rdf:type rdf:Property ;
    rdfs:label 'Labor Analytics Fact Id' ;
    rdfs:comment 'System-generated unique identifier for each labor analytics fact record.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Labor cost reporting requires mapping each labor record to the cost center for budgeting and variance analysis; finance cost_center defines the budget structure.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Unique identifier of the store department (e.g., produce, pharmacy) for which labor metrics are recorded.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total number of labor hours actually worked during the period.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Timestamp when the labor analytics event was recorded (typically period_end_timestamp).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Discriminator indicating the type of event; fixed value \'labor_analytics\' for this fact.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostPercentOfSales rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Percent Of Sales' ;
    rdfs:comment 'Labor cost expressed as a percentage of total sales for the period.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostUsd rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Usd' ;
    rdfs:comment 'Total labor cost in U.S. dollars incurred during the period, including regular and overtime wages.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openShiftCount rdf:type rdf:Property ;
    rdfs:label 'Open Shift Count' ;
    rdfs:comment 'Number of shifts that remained open (unfilled) at the end of the period.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of labor hours worked beyond scheduled hours that are classified as overtime.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodDate rdf:type rdf:Property ;
    rdfs:label 'Period Date' ;
    rdfs:comment 'Calendar date representing the labor reporting period (typically the day for daily grain).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period End Timestamp' ;
    rdfs:comment 'Timestamp marking the end of the labor measurement window.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Period Start Timestamp' ;
    rdfs:comment 'Timestamp marking the start of the labor measurement window.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesPerLaborHourUsd rdf:type rdf:Property ;
    rdfs:label 'Sales Per Labor Hour Usd' ;
    rdfs:comment 'Gross sales generated per labor hour worked, expressed in U.S. dollars.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Schedule Adherence Rate' ;
    rdfs:comment 'Percentage of scheduled labor hours that were actually worked.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total number of labor hours that were scheduled for the period.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionsPerLaborHour rdf:type rdf:Property ;
    rdfs:label 'Transactions Per Labor Hour' ;
    rdfs:comment 'Number of POS transactions processed per labor hour.' ;
    rdfs:domain ind:LaborAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyAnalyticsFactId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Analytics Fact Id' ;
    rdfs:comment 'System-generated unique identifier for each loyalty analytics fact record.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipId rdf:type rdf:Property ;
