    rdfs:range xsd:string .

ind:receivingRecordId rdf:type rdf:Property ;
    rdfs:label 'Receiving Record Id' ;
    rdfs:comment 'System-generated unique identifier for the inbound receiving record.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
