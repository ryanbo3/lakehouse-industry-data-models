ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Category describing why the markdown was applied (e.g., clearance, near-expiry, seasonal, damage, shrink).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownVersion rdf:type rdf:Property ;
    rdfs:label 'Markdown Version' ;
    rdfs:comment 'Version counter for the markdown record to support audit of changes.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'Standard retail price of the SKU before any markdown.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityMarkedDown rdf:type rdf:Property ;
    rdfs:label 'Quantity Marked Down' ;
    rdfs:comment 'Number of units of the SKU that were subject to the markdown.' ;
