    rdfs:domain ind:RecallHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityOnHold rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hold' ;
    rdfs:comment 'Total amount of product units placed on hold.' ;
