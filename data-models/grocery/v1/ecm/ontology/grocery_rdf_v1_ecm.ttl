    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Hold Status' ;
    rdfs:comment 'Current lifecycle status of the hold.' ;
    rdfs:domain ind:RecallHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationReference rdf:type rdf:Property ;
