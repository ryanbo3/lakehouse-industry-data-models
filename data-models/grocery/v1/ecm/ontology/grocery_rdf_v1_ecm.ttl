ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Indicates whether the count was performed manually or by an automated system.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Physical quantity recorded by the associate during the count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCountStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Status' ;
    rdfs:comment 'Current lifecycle status of the count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOutOfStock rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Stock' ;
    rdfs:comment 'True if the SKU is considered out-of-stock after the count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the SKU reserved for open orders at count time.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkFlag rdf:type rdf:Property ;
    rdfs:label 'Shrink Flag' ;
    rdfs:comment 'Indicates whether the variance is classified as shrink (loss).' ;
