ind:temperatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Temperature Timestamp' ;
    rdfs:comment 'Date-time when the temperature_celsius value was recorded.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockReservationId rdf:type rdf:Property ;
    rdfs:label 'Stock Reservation Id' ;
