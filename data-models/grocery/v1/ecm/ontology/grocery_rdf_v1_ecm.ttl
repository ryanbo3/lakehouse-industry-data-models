ind:dashboardName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Name' ;
    rdfs:comment 'Human-readable name of the dashboard as displayed to users.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardStatus rdf:type rdf:Property ;
    rdfs:label 'Dashboard Status' ;
    rdfs:comment 'Current lifecycle state of the dashboard.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardType rdf:type rdf:Property ;
    rdfs:label 'Dashboard Type' ;
    rdfs:comment 'Category of the dashboard indicating its primary purpose or audience.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataGovernanceClassification rdf:type rdf:Property ;
    rdfs:label 'Data Governance Classification' ;
    rdfs:comment 'Classification of the dashboard\'s data according to corporate data policy.' ;
    rdfs:domain ind:Dashboard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSummary rdf:type rdf:Property ;
