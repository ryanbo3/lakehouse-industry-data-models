ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current processing status of the valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotBatchId rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Id' ;
    rdfs:comment 'Unique surrogate key for each lot or batch record.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotBatch .

ind:bestByDate rdf:type rdf:Property ;
    rdfs:label 'Best By Date' ;
    rdfs:comment 'Recommended date for optimal quality consumption.' ;
