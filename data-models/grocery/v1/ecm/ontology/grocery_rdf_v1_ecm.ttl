    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoLifoIndicator rdf:type rdf:Property ;
    rdfs:label 'Fifo Lifo Indicator' ;
    rdfs:comment 'Specifies whether the SKU is managed using First-In-First-Out or Last-In-First-Out rotation.' ;
