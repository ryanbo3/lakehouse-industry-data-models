    rdfs:range xsd:string .

ind:quantityAdjusted rdf:type rdf:Property ;
    rdfs:label 'Quantity Adjusted' ;
    rdfs:comment 'Signed quantity change; positive for additions, negative for reductions.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the original SAP MM document or other source supporting the adjustment.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAdjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Adjustment Status' ;
    rdfs:comment 'Current processing state of the adjustment.' ;
    rdfs:domain ind:StockAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdjustedCost rdf:type rdf:Property ;
    rdfs:label 'Total Adjusted Cost' ;
    rdfs:comment 'Monetary impact of the adjustment (quantity_adjusted * cost_per_unit).' ;
