    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:promoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Allows setting KPI targets per promotional campaign for marketing ROI tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter (1-4) within the fiscal year.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomatedTarget rdf:type rdf:Property ;
    rdfs:label 'Is Automated Target' ;
    rdfs:comment 'True if the target value is generated automatically by a forecasting system.' ;
    rdfs:domain ind:KpiTarget ;
