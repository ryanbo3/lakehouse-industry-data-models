ind:rotationMethod rdf:type rdf:Property ;
    rdfs:label 'Rotation Method' ;
    rdfs:comment 'Policy used to rotate inventory: First-In-First-Out, First-Expired-First-Out, or Last-In-First-Out.' ;
    rdfs:domain ind:Inventory ;
