    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentSignal .

ind:actualSalesQty rdf:type rdf:Property ;
    rdfs:label 'Actual Sales Qty' ;
    rdfs:comment 'Number of units actually sold during the OOS period (typically zero).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the out-of-stock event expressed in hours (difference between end and start timestamps).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLostSalesValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Sales Value' ;
    rdfs:comment 'Monetary estimate of sales lost due to the OOS condition, expressed in the store\'s currency.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedDemandQty rdf:type rdf:Property ;
    rdfs:label 'Forecasted Demand Qty' ;
    rdfs:comment 'Projected quantity of the SKU expected to sell during the OOS window based on demand planning.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isResolved rdf:type rdf:Property ;
    rdfs:label 'Is Resolved' ;
    rdfs:comment 'Indicates whether the OOS event has been closed (true) or is still open (false).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oosEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos End Timestamp' ;
    rdfs:comment 'Date-time when the item was replenished and the OOS condition ended.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosSeverity rdf:type rdf:Property ;
    rdfs:label 'Oos Severity' ;
    rdfs:comment 'Business impact severity of the OOS event based on expected sales loss and product importance.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Start Timestamp' ;
    rdfs:comment 'Date-time when the inventory quantity first reached zero and the OOS event began.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityAfter rdf:type rdf:Property ;
    rdfs:label 'Quantity After' ;
    rdfs:comment 'On-hand quantity of the SKU after the OOS was resolved (post-replenishment).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBefore rdf:type rdf:Property ;
    rdfs:label 'Quantity Before' ;
    rdfs:comment 'On-hand quantity of the SKU immediately before it reached zero.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perishableRotationId rdf:type rdf:Property ;
    rdfs:label 'Perishable Rotation Id' ;
    rdfs:comment 'System-generated unique identifier for each perishable rotation record.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToExpiryAtCheck rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry At Check' ;
    rdfs:comment 'Number of calendar days remaining until the lot expires at the moment of the check.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
