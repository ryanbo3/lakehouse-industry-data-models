ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business driver for the inventory movement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Unique identifier for the loyalty engagement event record. Primary key.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEngagementShopperId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Shopper Id' ;
    rdfs:comment 'Reference to the customer who performed the engagement activity.' ;
