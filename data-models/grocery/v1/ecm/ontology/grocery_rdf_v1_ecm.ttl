    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFacings rdf:type rdf:Property ;
    rdfs:label 'Number Of Facings' ;
    rdfs:comment 'The number of product fronts allocated to the new item on the shelf for visibility and inventory capacity.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'The size or quantity of the item package (e.g., 16 oz, 500 ml, 12 count).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided when a new item introduction is rejected, including business rationale.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRefrigeration rdf:type rdf:Property ;
    rdfs:label 'Requires Refrigeration' ;
    rdfs:comment 'Indicates whether the new item requires cold chain temperature-controlled storage and handling (True) or not (False).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the category review process was completed and a decision was made on the new item.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the category review process began for the new item introduction.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Specific shelf location assigned to the new item within the planogram (e.g., aisle, shelf level, position).' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the vendor submitted the new item introduction request to the retailer for review.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suggestedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Suggested Retail Price' ;
    rdfs:comment 'Vendor-recommended retail price for the new item at point of sale.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned date when the new item should be available for sale in stores.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code assigned to the new item for point-of-sale scanning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramApprovedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Planogram Approved By User Associate Id' ;
    rdfs:comment 'Reference to the user or category manager who approved this planogram for deployment. Supports governance and approval workflow tracking.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:planogramAssociateId rdf:type rdf:Property ;
    rdfs:label 'Planogram Associate Id' ;
    rdfs:comment 'Reference to the user or space planner who created this planogram. Supports accountability and workflow tracking.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this planogram was approved. Captures approval event in the planogram lifecycle for audit and compliance tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether strict compliance to this planogram is mandatory. True for corporate-mandated sets, false for suggested guidelines. Drives store execution accountability.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Compliance Tolerance Pct' ;
    rdfs:comment 'Acceptable variance percentage from the planogram specification before a store is considered non-compliant. Used for compliance scoring and audit thresholds.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeeklySalesAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Weekly Sales Amount' ;
    rdfs:comment 'Projected weekly sales revenue in dollars for all SKUs (Stock Keeping Units) in this planogram. Supports space-to-sales ratio analysis and fixture ROI evaluation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeeklySalesUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Weekly Sales Units' ;
    rdfs:comment 'Projected weekly sales volume in units for all SKUs (Stock Keeping Units) in this planogram. Used for space productivity forecasting and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixtureDepthInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Depth Inches' ;
    rdfs:comment 'Total depth of the fixture in inches. Constrains product depth and facing orientation for shelf placement.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureHeightInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Height Inches' ;
    rdfs:comment 'Total height of the fixture in inches. Determines vertical space available for product placement and shelf allocation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureWidthInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Width Inches' ;
    rdfs:comment 'Total width of the fixture in inches. Critical dimension for space planning and ensuring planogram fits physical store layout.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) or file path to the visual rendering or photograph of the planogram. Provides reference image for store teams during reset execution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutOrientation rdf:type rdf:Property ;
    rdfs:label 'Layout Orientation' ;
    rdfs:comment 'Primary orientation of product placement within the planogram. Horizontal for side-by-side shelf arrangements, vertical for top-to-bottom brand blocking, mixed for combination layouts.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingStrategy rdf:type rdf:Property ;
    rdfs:label 'Merchandising Strategy' ;
    rdfs:comment 'Primary merchandising strategy applied in this planogram. Brand blocking groups products by manufacturer, price point arranges by cost tiers, size progression orders by package size, color blocking groups by visual appeal, cross merchandising combines complementary categories.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramName rdf:type rdf:Property ;
    rdfs:label 'Planogram Name' ;
    rdfs:comment 'Human-readable name or title of the planogram, typically describing the category, fixture, or section it represents (e.g., \'Cereal Aisle Endcap Q1 2024\').' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramNumber rdf:type rdf:Property ;
    rdfs:label 'Planogram Number' ;
    rdfs:comment 'Business identifier for the planogram, typically used in space planning systems and store communications. Externally-known unique code for this visual merchandise display plan.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramStatus rdf:type rdf:Property ;
    rdfs:label 'Planogram Status' ;
    rdfs:comment 'Current lifecycle status of the planogram. Draft indicates work-in-progress, approved indicates ready for deployment, active indicates currently in use in stores, inactive indicates temporarily suspended, archived indicates historical record.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramType rdf:type rdf:Property ;
    rdfs:label 'Planogram Type' ;
    rdfs:comment 'Classification of the planogram by merchandising purpose. Standard for regular shelf sets, promotional for temporary displays, seasonal for holiday or seasonal merchandise, endcap for end-of-aisle displays, power aisle for high-traffic promotional zones, checkout for point-of-sale impulse areas.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelFacingPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Facing Pct' ;
    rdfs:comment 'Percentage of total facings allocated to private label or store-owned brand products. Key metric for private label penetration and margin optimization strategy.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spacePlanningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Space Planning System Code' ;
    rdfs:comment 'Identifier or code from the source space planning system (e.g., Blue Yonder, JDA, Oracle Retail) where this planogram was designed. Supports system integration and data lineage.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Units' ;
    rdfs:comment 'Total product capacity of the fixture in units, summing all SKU (Stock Keeping Unit) positions and depths. Represents maximum inventory that can be displayed on the fixture at full stock.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacingCount rdf:type rdf:Property ;
    rdfs:label 'Total Facing Count' ;
    rdfs:comment 'Total number of product facings (product fronts visible to shoppers) across all shelves in this planogram. Key metric for space productivity and SKU (Stock Keeping Unit) representation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShelfCount rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Count' ;
    rdfs:comment 'Total number of shelves or levels within the fixture. Used for vertical space allocation and capacity planning.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of unique SKUs (Stock Keeping Units) included in this planogram. Measures assortment breadth and variety for the fixture.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramComplianceId rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Id' ;
    rdfs:comment 'Unique identifier for the planogram compliance record. Primary key for the planogram compliance lifecycle event.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedCrewAssociateId rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Associate Id' ;
    rdfs:comment 'Identifier of the reset crew or team assigned to execute the planogram reset.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual labor hours spent executing the planogram reset, used for labor cost tracking and productivity analysis.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method used to conduct the compliance audit: manual (human inspection), image_recognition (automated scan), or hybrid (combination).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Actual date when the planogram reset or audit was completed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Score Percentage' ;
    rdfs:comment 'Overall compliance score expressed as a percentage (0.00 to 100.00) measuring adherence to the planogram specifications.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions needed to achieve planogram compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which corrective actions must be completed to restore planogram compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Flag indicating whether corrective action is required to bring the shelf execution into compliance with the planogram.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endcapFlag rdf:type rdf:Property ;
    rdfs:label 'Endcap Flag' ;
    rdfs:comment 'Flag indicating whether this planogram compliance event applies to an endcap (end-of-aisle display) location.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated labor hours required to complete the planogram reset, used for crew scheduling and labor planning.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date when the planogram reset or compliance audit was scheduled or executed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:missingFacingCount rdf:type rdf:Property ;
    rdfs:label 'Missing Facing Count' ;
    rdfs:comment 'Number of facings that were specified in the planogram but not present on the shelf during the audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfPositionCount rdf:type rdf:Property ;
    rdfs:label 'Out Of Position Count' ;
    rdfs:comment 'Number of SKUs (Stock Keeping Units) found in incorrect shelf positions during the audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramVersion rdf:type rdf:Property ;
    rdfs:label 'Planogram Version' ;
    rdfs:comment 'Version identifier of the planogram being implemented or audited, supporting version control and change tracking.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resetType rdf:type rdf:Property ;
    rdfs:label 'Reset Type' ;
    rdfs:comment 'Type of planogram reset: full (complete category reset), partial (minor adjustments), seasonal (seasonal merchandise change), or promotional (temporary promotional display).' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Originally scheduled date for the planogram reset or audit event.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sectionNumber rdf:type rdf:Property ;
    rdfs:label 'Section Number' ;
    rdfs:comment 'Section identifier within the aisle where the planogram reset or audit occurred.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFacingsActual rdf:type rdf:Property ;
    rdfs:label 'Total Facings Actual' ;
    rdfs:comment 'Actual number of product facings found during the compliance audit.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacingsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Facings Planned' ;
    rdfs:comment 'Total number of product facings specified in the planogram design.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unauthorizedSubstitutionCount rdf:type rdf:Property ;
    rdfs:label 'Unauthorized Substitution Count' ;
    rdfs:comment 'Number of SKUs (Stock Keeping Units) found on the shelf that were not authorized in the planogram.' ;
    rdfs:domain ind:PlanogramCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of post-reset verification: pending (awaiting verification), verified (passed verification), failed (did not meet standards), or waived (verification not required).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalPlanId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Plan Id' ;
    rdfs:comment 'Unique identifier for the seasonal merchandise plan. Primary key.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySeasonalAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Seasonal Associate Id' ;
    rdfs:comment 'Merchandise planner responsible for developing and executing this seasonal plan. Links to workforce domain.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:adCircularWeekCount rdf:type rdf:Property ;
    rdfs:label 'Ad Circular Week Count' ;
    rdfs:comment 'Number of weekly ad circular periods featuring this seasonal assortment. Measures promotional support duration.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Comments and notes from merchandising leadership during plan approval process. Captures decision rationale.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdVendorCount rdf:type rdf:Property ;
    rdfs:label 'Dsd Vendor Count' ;
    rdfs:comment 'Number of DSD vendors participating in this seasonal plan. Tracks direct delivery partnerships.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endcapCount rdf:type rdf:Property ;
    rdfs:label 'Endcap Count' ;
    rdfs:comment 'Number of endcap displays allocated to this seasonal plan. Tracks premium merchandising placement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionNotes rdf:type rdf:Property ;
    rdfs:label 'Execution Notes' ;
    rdfs:comment 'Operational notes and observations during seasonal plan execution. Captures in-season adjustments and learnings.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalesLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Sales Lift Pct' ;
    rdfs:comment 'Projected percentage increase in sales versus baseline due to seasonal assortment and promotions. Measures anticipated business impact.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gondolaCount rdf:type rdf:Property ;
    rdfs:label 'Gondola Count' ;
    rdfs:comment 'Number of gondola shelving units allocated to this seasonal assortment. Measures standard shelving commitment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incrementalSpaceSqft rdf:type rdf:Property ;
    rdfs:label 'Incremental Space Sqft' ;
    rdfs:comment 'Additional square footage allocated beyond base assortment for seasonal merchandise. Measures seasonal space expansion.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'Date when planning activities for this season began. Tracks the planning cycle timeline.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalTieInFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Tie In Flag' ;
    rdfs:comment 'Indicates whether this seasonal plan is coordinated with promotional campaigns. True if promotional tie-ins are planned.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Inventory replenishment approach for seasonal SKUs. Defines how stock levels are maintained during the season.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Season End Date' ;
    rdfs:comment 'Date when the seasonal merchandise period ends. Marks the conclusion of the seasonal assortment.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Business-friendly name of the seasonal period (e.g., Holiday 2024, Back-to-School 2024, Summer Grilling 2024). Human-readable identifier for the seasonal plan.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Season Start Date' ;
    rdfs:comment 'Date when the seasonal merchandise period begins. Marks the effective start of the assortment strategy.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the seasonal period by merchandising category. Segments seasonal plans by business purpose. [ENUM-REF-CANDIDATE: holiday|back_to_school|summer|spring|fall|winter|special_event — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceAllocationSqft rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Sqft' ;
    rdfs:comment 'Total selling floor space allocated to this seasonal assortment in square feet. Measures physical space commitment.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcategoryList rdf:type rdf:Property ;
    rdfs:label 'Subcategory List' ;
    rdfs:comment 'Comma-separated list of subcategory identifiers included in the seasonal assortment. Defines the scope of merchandise planning.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Pct' ;
    rdfs:comment 'Planned gross margin percentage for the seasonal assortment. Defines profitability goal.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Amount' ;
    rdfs:comment 'Planned revenue target for this seasonal period in USD. Defines financial goal for the seasonal plan.' ;
    rdfs:domain ind:SeasonalPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuRationalizationId rdf:type rdf:Property ;
    rdfs:label 'Sku Rationalization Id' ;
    rdfs:comment 'Unique identifier for the SKU rationalization event record.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAffectedSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Affected Sku Id' ;
    rdfs:comment 'Reference to the primary SKU being discontinued, consolidated, or replaced in this rationalization event.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primarySkuAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Sku Associate Id' ;
    rdfs:comment 'Reference to the user or role who provided final approval for the rationalization decision, supporting audit and accountability requirements.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiarySkuLastModifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sku Last Modified By User Associate Id' ;
    rdfs:comment 'Reference to the user who most recently updated the rationalization event record.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:affectedSkuDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Sku Description' ;
    rdfs:comment 'Human-readable description of the SKU being rationalized for business user reference.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSkuUpc rdf:type rdf:Property ;
    rdfs:label 'Affected Sku Upc' ;
    rdfs:comment 'The UPC barcode of the SKU being rationalized, used for cross-reference and validation.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionInstruction rdf:type rdf:Property ;
    rdfs:label 'Disposition Instruction' ;
    rdfs:comment 'The prescribed method for handling remaining inventory of the affected SKU: markdown (price reduction for clearance sale), return_to_vendor (send back to supplier), donate (charitable contribution), destroy (disposal for safety or quality reasons), transfer (move to other locations), or liquidate (sell through third-party channels).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDiscontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Effective Discontinuation Date' ;
    rdfs:comment 'The date on which the affected SKU will be officially discontinued from the assortment and removed from active ordering and replenishment.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedInventoryUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Inventory Units' ;
    rdfs:comment 'The estimated total number of units of the affected SKU remaining in inventory across all locations at the time of rationalization decision.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedInventoryValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Inventory Value Amount' ;
    rdfs:comment 'The estimated total dollar value of remaining inventory for the affected SKU at cost, used for financial impact analysis.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facingsReleased rdf:type rdf:Property ;
    rdfs:label 'Facings Released' ;
    rdfs:comment 'The number of product facings (front-facing positions on shelf) being released by the discontinuation of the affected SKU, available for reallocation to other items.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'The estimated financial impact of the rationalization decision, including potential write-offs, markdown costs, or savings from improved space productivity.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'The date on which the rationalization was fully implemented across all affected systems, stores, and processes.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'The current status of rationalization implementation across systems and stores: not_started (approved but not yet begun), in_progress (actively executing), completed (fully implemented), on_hold (temporarily paused), or failed (implementation encountered errors).' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'The final date by which deliveries of the affected SKU will be accepted at stores or distribution centers.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The final date by which stores or distribution centers can place orders for the affected SKU before it is removed from ordering systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markdownPercentage rdf:type rdf:Property ;
    rdfs:label 'Markdown Percentage' ;
    rdfs:comment 'The percentage price reduction to be applied if the disposition instruction is markdown, used to accelerate sell-through of remaining inventory.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Planogram Version Number' ;
    rdfs:comment 'The version number of the planogram that will incorporate this rationalization change, used for tracking and implementation coordination.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationalizationNumber rdf:type rdf:Property ;
    rdfs:label 'Rationalization Number' ;
    rdfs:comment 'Business-facing unique identifier for the rationalization event, used for tracking and reference in category management systems.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationalizationReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Rationalization Reason Detail' ;
    rdfs:comment 'Additional narrative detail explaining the specific circumstances and business justification for the rationalization decision.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationalizationType rdf:type rdf:Property ;
    rdfs:label 'Rationalization Type' ;
    rdfs:comment 'The type of rationalization action being taken: discontinue (remove without replacement), consolidate (merge with another SKU), replace (substitute with new SKU), phase_out (gradual removal), or delist (remove from assortment).' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementSkuDescription rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Description' ;
    rdfs:comment 'Human-readable description of the replacement SKU for business user reference and communication.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementSkuUpc rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Upc' ;
    rdfs:comment 'The UPC barcode of the replacement SKU for cross-reference and planogram updates.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceReallocationPlan rdf:type rdf:Property ;
    rdfs:label 'Space Reallocation Plan' ;
    rdfs:comment 'Description of how the shelf space previously occupied by the affected SKU will be reallocated, including which SKUs will receive additional facings or whether the space will be used for new item introductions.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeClusterScope rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Scope' ;
    rdfs:comment 'The store cluster or grouping to which this rationalization applies, enabling localized assortment decisions based on store demographics and performance. [ENUM-REF-CANDIDATE: all_stores|cluster_a|cluster_b|cluster_c|cluster_d|regional|test_stores — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Notification Date' ;
    rdfs:comment 'The date on which the affected SKU vendor was formally notified of the rationalization decision, important for vendor relationship management and contractual obligations.' ;
    rdfs:domain ind:SkuRationalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slottingFeeId rdf:type rdf:Property ;
    rdfs:label 'Slotting Fee Id' ;
    rdfs:comment 'Unique identifier for the slotting fee agreement record.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Business identifier for the slotting fee agreement contract.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the slotting fee agreement.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNotes rdf:type rdf:Property ;
    rdfs:label 'Contract Notes' ;
    rdfs:comment 'Additional notes, terms, or special conditions related to the slotting fee agreement.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedSalesUnits rdf:type rdf:Property ;
    rdfs:label 'Expected Sales Units' ;
    rdfs:comment 'Projected number of units expected to sell during the slotting fee agreement period, used to justify the fee investment.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total monetary amount of the slotting fee charged to the vendor for shelf space allocation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Type of slotting fee based on the nature of shelf space allocation (new item introduction, planogram reset, endcap placement, promotional display, seasonal placement, or category expansion).' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPromotional rdf:type rdf:Property ;
    rdfs:label 'Is Promotional' ;
    rdfs:comment 'Flag indicating whether the slotting fee is associated with a promotional display or temporary promotional placement.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearFeetAllocated rdf:type rdf:Property ;
    rdfs:label 'Linear Feet Allocated' ;
    rdfs:comment 'Total linear feet of shelf space allocated to the product under this slotting fee agreement.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'Date when the slotting fee terms were negotiated between the retailer and vendor.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the vendor must remit the slotting fee payment.' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when the slotting fee payment was received from the vendor.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the slotting fee obligation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms specifying when and how the vendor must remit the slotting fee.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Geographic or organizational scope of the slotting fee agreement (all stores, specific cluster, individual store, region, or division).' ;
    rdfs:domain ind:SlottingFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeCount rdf:type rdf:Property ;
    rdfs:label 'Store Count' ;
    rdfs:comment 'Number of stores covered by this slotting fee agreement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spaceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Id' ;
    rdfs:comment 'Unique identifier for the space allocation record. Primary key.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpaceAllocation .

ind:primarySpaceCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Space Category Id' ;
    rdfs:comment 'Identifier of the product category for which space is allocated. Links to the product category hierarchy.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Business identifier code for the space allocation record. Used for external reference and reporting.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority level of the space allocation. High-priority allocations receive preferential space and visibility (e.g., high-margin categories, promotional items). Used for space optimization and conflict resolution.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the space allocation. Indicates whether the allocation is in planning, approved for execution, actively in use, temporarily suspended, expired, or cancelled.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endcapPosition rdf:type rdf:Property ;
    rdfs:label 'Endcap Position' ;
    rdfs:comment 'Physical position of the endcap display within the store. Endcaps are high-visibility promotional displays at the end of aisles. Position affects traffic flow and sales lift. [ENUM-REF-CANDIDATE: front_left|front_right|mid_left|mid_right|back_left|back_right|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Total number of product facings (product fronts visible on shelf) allocated to the category or sub-category. Determines SKU (Stock Keeping Unit) capacity and visual merchandising impact.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredSku rdf:type rdf:Property ;
    rdfs:label 'Featured Sku' ;
    rdfs:comment 'Primary SKU (Stock Keeping Unit) featured in the endcap or promotional display. Used for endcap rotation scheduling and promotional tie-in tracking.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gondolaSectionCount rdf:type rdf:Property ;
    rdfs:label 'Gondola Section Count' ;
    rdfs:comment 'Number of gondola sections (standard 4-foot shelving units) allocated to the category or sub-category. Used for planogram development and space planning.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfCount rdf:type rdf:Property ;
    rdfs:label 'Shelf Count' ;
    rdfs:comment 'Number of shelves allocated to the category or sub-category within the fixture. Determines vertical space capacity.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfHeightInches rdf:type rdf:Property ;
    rdfs:label 'Shelf Height Inches' ;
    rdfs:comment 'Total vertical height in inches of the shelving allocated to the category or sub-category. Used for vertical space planning and fixture capacity calculation.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:squareFootageAllocated rdf:type rdf:Property ;
    rdfs:label 'Square Footage Allocated' ;
    rdfs:comment 'Total square footage allocated to the category or sub-category. Used for floor space planning and productivity measurement.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGmroiPerLinearFoot rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi Per Linear Foot' ;
    rdfs:comment 'Target Gross Margin Return on Investment (GMROI) per linear foot for the space allocation. Used for category space productivity analysis and performance benchmarking. Measures profitability per unit of space.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Flag' ;
    rdfs:comment 'Indicates whether the space allocation is funded by a vendor through slotting fees (vendor payment for shelf space) or promotional allowances. True if vendor-funded, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assortmentDepthStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Strategy' ;
    rdfs:comment 'Strategic approach to SKU (Stock Keeping Unit) selection and variety within categories for this cluster. Narrow-deep offers fewer brands with more sizes/flavors; broad-shallow offers many brands with limited variety per brand.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageStoreSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Average Store Size Sqft' ;
    rdfs:comment 'Mean selling square footage of stores in this cluster. Used for space planning and planogram capacity estimation.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageWeeklySales rdf:type rdf:Property ;
    rdfs:label 'Average Weekly Sales' ;
    rdfs:comment 'Mean weekly sales volume across stores in this cluster. Used for volume-based assortment planning and inventory allocation. Business-sensitive financial metric.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Predominant climate classification for the cluster geography. Influences seasonal assortment planning for weather-dependent categories such as beverages, apparel, and outdoor products.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Business identifier code for the store cluster used in merchandising and planning systems. Externally visible identifier used in Oracle Retail and Blue Yonder systems.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Email' ;
    rdfs:comment 'Business email address of the cluster manager for operational communication and escalation. Business-confidential contact information.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerName rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Name' ;
    rdfs:comment 'Name of the category manager or merchandising leader responsible for assortment strategy and performance for this cluster.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterName rdf:type rdf:Property ;
    rdfs:label 'Cluster Name' ;
    rdfs:comment 'Descriptive name of the store cluster for business user identification and reporting purposes.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Status' ;
    rdfs:comment 'Current lifecycle status of the store cluster. Active clusters are in use for assortment planning, inactive clusters are temporarily disabled, pending clusters are under review, and archived clusters are historical.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterType rdf:type rdf:Property ;
    rdfs:label 'Cluster Type' ;
    rdfs:comment 'Classification of the clustering methodology used to group stores. Demographic clusters group by customer profile, volume clusters by sales tier, format clusters by store size/layout, geographic clusters by region, competitive clusters by market dynamics, and hybrid clusters use multiple factors.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusteringMethodology rdf:type rdf:Property ;
    rdfs:label 'Clustering Methodology' ;
    rdfs:comment 'Description of the analytical approach and business rules used to define cluster membership. May reference statistical models, business criteria, or hybrid approaches.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure in the markets served by this cluster. High-intensity clusters may require more aggressive promotional assortments and pricing strategies.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic region or market area covered by stores in this cluster. Supports regional assortment localization and distribution planning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the cluster definition and membership were last recalculated or reviewed. Used to track data freshness and trigger next refresh cycle.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberStoreCount rdf:type rdf:Property ;
    rdfs:label 'Member Store Count' ;
    rdfs:comment 'Total number of stores currently assigned to this cluster. Used for assortment scale planning and distribution allocation.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Methodology Version' ;
    rdfs:comment 'Version identifier for the clustering algorithm or business rules applied. Enables tracking of methodology changes over time and impact analysis.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newItemIntroductionPriority rdf:type rdf:Property ;
    rdfs:label 'New Item Introduction Priority' ;
    rdfs:comment 'Sequencing priority for rolling out new SKUs (Stock Keeping Units) to stores in this cluster. First-wave clusters receive new items earliest; test-only clusters are used for market testing before broader rollout.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Date' ;
    rdfs:comment 'Planned date for the next cluster review and update cycle. Supports proactive planning and resource allocation for cluster maintenance.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification based on sales productivity, profitability, and strategic importance. Platinum and gold tiers receive priority for new item introductions and promotional support.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramTemplateSet rdf:type rdf:Property ;
    rdfs:label 'Planogram Template Set' ;
    rdfs:comment 'Reference to the collection of planogram (visual merchandise display plan) templates assigned to this cluster. Links cluster to specific shelf layout and facing strategies.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Category Focus' ;
    rdfs:comment 'Dominant merchandise categories or departments emphasized in this cluster\'s assortment strategy, such as fresh produce, organic, ethnic foods, or premium selections.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDemographicProfile rdf:type rdf:Property ;
    rdfs:label 'Primary Demographic Profile' ;
    rdfs:comment 'Dominant customer demographic characteristics of stores in this cluster, such as income level, household composition, age distribution, or ethnicity mix. Used for targeted assortment selection.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTarget rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target' ;
    rdfs:comment 'Target percentage of sales from private-label (store-owned brand) products for this cluster. Used to guide assortment mix and shelf space allocation decisions.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which cluster membership and definitions are reviewed and updated. Aligns with merchandise planning cycles and seasonal resets.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

