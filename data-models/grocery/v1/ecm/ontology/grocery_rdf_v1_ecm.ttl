ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Method used to calculate inventory cost (e.g., FIFO, LIFO, weighted average, retail inventory method, standard cost).' ;
