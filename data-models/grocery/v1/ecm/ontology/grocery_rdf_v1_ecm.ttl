ind:rotationSequence rdf:type rdf:Property ;
    rdfs:label 'Rotation Sequence' ;
    rdfs:comment 'Numeric order of the lot within the chosen rotation method at its current location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usdaFdaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Usda Fda Certified Flag' ;
    rdfs:comment 'True if the lot complies with USDA or FDA certification requirements.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownEventId rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Id' ;
    rdfs:comment 'Primary key for markdown_event' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:markdownId rdf:type rdf:Property ;
    rdfs:label 'Markdown Id' ;
    rdfs:comment 'Foreign key linking to pricing.markdown. Business justification: Required for the Markdown Audit Report that ties each inventory markdown event to its pricing markdown record for compliance and margin analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Markdown .

ind:costAtMarkdown rdf:type rdf:Property ;
    rdfs:label 'Cost At Markdown' ;
    rdfs:comment 'Standard cost of the SKU at the time of markdown, used for margin analysis.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispositionOutcome rdf:type rdf:Property ;
    rdfs:label 'Disposition Outcome' ;
    rdfs:comment 'Final disposition of the markdown inventory (e.g., sold, donated, disposed, returned).' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownEventStatus rdf:type rdf:Property ;
    rdfs:label 'Markdown Event Status' ;
    rdfs:comment 'Current processing state of the markdown event.' ;
    rdfs:domain ind:MarkdownEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownPrice rdf:type rdf:Property ;
    rdfs:label 'Markdown Price' ;
    rdfs:comment 'Reduced price applied to the SKU during the markdown event.' ;
