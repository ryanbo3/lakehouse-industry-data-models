ind:temperatureRangeMaxFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Fahrenheit' ;
    rdfs:comment 'Maximum temperature in Fahrenheit that the fixture maintains, applicable to refrigerated and frozen fixtures for food safety compliance.' ;
    rdfs:domain ind:Fixture ;
