ind:regulatoryFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Status' ;
    rdfs:comment 'Current lifecycle state of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySection rdf:type rdf:Property ;
    rdfs:label 'Regulatory Section' ;
    rdfs:comment 'Specific legal section or code referenced by the filing (e.g., 21 CFR Part 11).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'True if a future renewal is mandatory based on regulatory rules.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'How the filing was delivered to the agency.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionId rdf:type rdf:Property ;
    rdfs:label 'Training Completion Id' ;
    rdfs:comment 'Unique surrogate key for each training completion record.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Associate Id' ;
    rdfs:comment 'Identifier of the associate who completed the training.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:trainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Id' ;
    rdfs:comment 'Identifier of the required training program.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:assessmentPassScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Pass Score' ;
    rdfs:comment 'Minimum score required to pass the assessment.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'Log of changes made to the training completion record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number issued upon successful completion.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNumber rdf:type rdf:Property ;
    rdfs:label 'Completion Number' ;
    rdfs:comment 'Business identifier assigned to the training completion record.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the associate completed the training.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method used to deliver the training to the associate.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Length of the training session in minutes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Language in which the training was delivered.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the associate passed the training.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'Regulatory program satisfied by this training (e.g., FDA, OSHA, HIPAA).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleRequired rdf:type rdf:Property ;
    rdfs:label 'Role Required' ;
    rdfs:comment 'Job role for which the training is required.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score achieved by the associate on the training assessment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Broad category of the training (e.g., Safety, Data Privacy, Food Safety).' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Current lifecycle status of the training completion.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTitle rdf:type rdf:Property ;
    rdfs:label 'Training Title' ;
    rdfs:comment 'Descriptive title of the training program.' ;
    rdfs:domain ind:TrainingCompletion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightsMeasuresId rdf:type rdf:Property ;
    rdfs:label 'Weights Measures Id' ;
    rdfs:comment 'Unique surrogate identifier for each weights and measures compliance record.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Reference number of the calibration certificate issued by the certifying authority.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationMethod rdf:type rdf:Property ;
    rdfs:label 'Calibration Method' ;
    rdfs:comment 'Method used to calibrate the device.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date the device received its initial compliance certification.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date the current certification becomes invalid and must be renewed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deviceName rdf:type rdf:Property ;
    rdfs:label 'Device Name' ;
    rdfs:comment 'Human-readable name or label assigned to the weighing or measuring device.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number that uniquely identifies the device across the enterprise.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of the device used for weight or measure capture.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'U.S. state code governing the metrology requirements for the device. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY — promote to reference product] ' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Calibrated Timestamp' ;
    rdfs:comment 'Exact timestamp when the device was last calibrated.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementCategory rdf:type rdf:Property ;
    rdfs:label 'Measurement Category' ;
    rdfs:comment 'High-level classification of what the device measures (e.g., weight, volume, dimension).' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure used by the device for reporting values.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDue rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due' ;
    rdfs:comment 'Scheduled date for the next mandatory calibration of the device.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceToleranceKg rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Kg' ;
    rdfs:comment 'Maximum allowable weight variance in kilograms as defined by state metrology standards.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Tolerance Percent' ;
    rdfs:comment 'Maximum allowable variance expressed as a percentage of the measured value.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightsMeasuresStatus rdf:type rdf:Property ;
    rdfs:label 'Weights Measures Status' ;
    rdfs:comment 'Current operational status of the device within the store.' ;
    rdfs:domain ind:WeightsMeasures ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerBenefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Benefit Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for each benefit program enrollment record. Primary key for the benefit_enrollment data product in the customer domain.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crmCaseId rdf:type rdf:Property ;
    rdfs:label 'Crm Case Id' ;
    rdfs:comment 'Reference to the Salesforce CRM case record associated with this enrollment, if the enrollment was initiated or managed through a customer service interaction. Enables end-to-end traceability from CRM engagement to benefit enrollment outcome.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Date by which the shopper must file a formal appeal with the issuing agency if the enrollment was denied or suspended. Populated when enrollment_status is denied or suspended. Supports shopper advocacy and regulatory fair hearing compliance.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedRetailerNumber rdf:type rdf:Property ;
    rdfs:label 'Authorized Retailer Number' ;
    rdfs:comment 'USDA FNS-assigned retailer authorization number for the grocery store location where the benefit is redeemable. Required for SNAP and WIC regulatory compliance reporting and EBT transaction settlement with the state processor.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the shopper has consented to automatic recertification or renewal processing for this benefit enrollment where permitted by the issuing agency. Supports streamlined recertification workflows and reduces benefit lapse rates.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent synchronization of the benefit_balance field with the state EBT processor or WIC management information system. Indicates data freshness for POS eligibility decisions.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:benefitBalance rdf:type rdf:Property ;
    rdfs:label 'Benefit Balance' ;
    rdfs:comment 'Current remaining benefit balance available on the shopper\'s EBT or WIC benefit account as of the last synchronization with the state EBT processor. Used for POS tender limit enforcement and shopper balance inquiry support.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCardLast4 rdf:type rdf:Property ;
    rdfs:label 'Benefit Card Last4' ;
    rdfs:comment 'Last four digits of the EBT or WIC benefit card number, retained for customer service identification and POS receipt display purposes. Not sufficient to reconstruct the full card number.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCardToken rdf:type rdf:Property ;
    rdfs:label 'Benefit Card Token' ;
    rdfs:comment 'Tokenized representation of the shopper\'s EBT or WIC benefit card number. The actual card number is never stored; only the secure token is retained for POS tender matching and transaction reconciliation. Tokenization complies with PCI DSS and state EBT security requirements.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the benefit amount (typically USD for US government programs). Supports multi-currency readiness for future program expansions.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoricalEligibility rdf:type rdf:Property ;
    rdfs:label 'Categorical Eligibility' ;
    rdfs:comment 'Indicates whether the shopper qualifies for the benefit program through categorical eligibility (i.e., automatic eligibility based on participation in another qualifying program such as TANF or SSI) rather than through standard income and resource testing. Simplifies eligibility determination and reduces documentation burden.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized agency-issued code indicating the reason an enrollment application was denied or an active enrollment was suspended. Populated only when enrollment_status is denied or suspended. Used for regulatory reporting and shopper appeals support. [ENUM-REF-CANDIDATE: income_exceeds_limit|residency_not_verified|identity_not_verified|incomplete_application|duplicate_enrollment|ineligible_category|other — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the shopper completed the benefit program enrollment process. Supports omnichannel analytics and process optimization for enrollment workflows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the shopper was officially enrolled and approved into the benefit program by the issuing agency. Represents the effective start of benefit eligibility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known enrollment reference number assigned by the issuing government agency or program administrator. Used for cross-referencing with agency records and POS tender eligibility lookups.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the benefit program enrollment. Active indicates the shopper is currently eligible; pending indicates application submitted but not yet approved; expired indicates the benefit period has lapsed; denied indicates the application was rejected by the issuing agency; suspended indicates temporary hold by the agency.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Calendar date on which the current benefit enrollment period expires and the shopper must re-certify or re-enroll to maintain eligibility. Null for open-ended enrollments. Critical for POS tender eligibility validation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incomeEligibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Income Eligibility Level' ;
    rdfs:comment 'Federal Poverty Level (FPL) income bracket certified by the issuing agency at the time of enrollment. Determines benefit amount tiers and program eligibility thresholds. Expressed as a percentage range of the Federal Poverty Level per USDA FNS guidelines.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Code' ;
    rdfs:comment 'Standardized code identifying the government agency that issued the benefit enrollment. Aligns with USDA FNS state agency codes and enables automated agency-level regulatory reporting.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Name' ;
    rdfs:comment 'Name of the government agency or authorized body that issued and administers the benefit enrollment (e.g., state Department of Social Services, county health department, USDA FNS regional office). Used for regulatory reporting and agency reconciliation.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateCode rdf:type rdf:Property ;
    rdfs:label 'Issuing State Code' ;
    rdfs:comment 'Two-letter ISO 3166-2 US state code of the government agency that issued the benefit enrollment. Supports state-level regulatory compliance reporting and cross-state benefit portability tracking.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Benefit Amount' ;
    rdfs:comment 'Dollar value of government assistance benefits allocated to the shopper per calendar month. Used for POS tender limit enforcement, financial reconciliation with USDA FNS, and regulatory reporting on benefit utilization.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationConsent rdf:type rdf:Property ;
    rdfs:label 'Notification Consent' ;
    rdfs:comment 'Indicates whether the shopper has consented to receive benefit-related notifications (e.g., expiry reminders, recertification alerts, balance updates) via their preferred communication channel. Supports CRM-driven benefit engagement campaigns.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTenderEligible rdf:type rdf:Property ;
    rdfs:label 'Pos Tender Eligible' ;
    rdfs:comment 'Indicates whether this enrollment record currently qualifies the shopper to use the associated benefit card as a valid tender type at the NCR POS system. Derived from enrollment_status and expiry_date but stored as an operational flag for real-time POS eligibility checks.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the government assistance or special benefit program in which the shopper is enrolled. SNAP (Supplemental Nutrition Assistance Program), WIC (Women, Infants, and Children), EBT (Electronic Benefits Transfer), TANF (Temporary Assistance for Needy Families), MEDICAID. Drives POS tender eligibility rules at checkout.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Date' ;
    rdfs:comment 'Date by which the shopper must complete recertification with the issuing agency to maintain uninterrupted benefit eligibility. Used to trigger proactive outreach and prevent benefit lapses.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapHouseholdSize rdf:type rdf:Property ;
    rdfs:label 'Snap Household Size' ;
    rdfs:comment 'Number of individuals in the shopper\'s household as certified by the issuing agency for SNAP benefit calculation purposes. Directly determines the monthly SNAP allotment amount. Applicable only when program_type is SNAP.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this benefit enrollment record was ingested into the Databricks Silver Layer. Supports data lineage tracking and reconciliation across NCR POS, Salesforce CRM, agency portal feeds, and EBT processor interfaces.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the shopper\'s eligibility documents were verified and approved by the issuing agency or authorized grocery program administrator. Establishes the audit trail for enrollment approval.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDocReference rdf:type rdf:Property ;
    rdfs:label 'Verification Doc Reference' ;
    rdfs:comment 'Reference identifier pointing to the document management system record containing the eligibility verification documents submitted by the shopper (e.g., income verification, residency proof, identity documents). Supports audit trails for regulatory compliance without storing document content in the data lakehouse.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocType rdf:type rdf:Property ;
    rdfs:label 'Verification Doc Type' ;
    rdfs:comment 'Classification of the primary eligibility verification document type submitted by the shopper during enrollment. Used for compliance audit reporting and document completeness checks.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicFoodPackageCode rdf:type rdf:Property ;
    rdfs:label 'Wic Food Package Code' ;
    rdfs:comment 'USDA-assigned food package code designating the specific WIC food package category the shopper qualifies for (e.g., Package A for infants, Package D for women). Determines which product SKUs are WIC-eligible at POS. Applicable only when program_type is WIC.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicParticipantCategory rdf:type rdf:Property ;
    rdfs:label 'Wic Participant Category' ;
    rdfs:comment 'USDA WIC participant category classifying the shopper\'s eligibility basis within the WIC program. Determines food package entitlements and benefit amounts. Applicable only when program_type is WIC.' ;
    rdfs:domain ind:CustomerBenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer service case record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:escalatedToAgentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Escalated To Agent Associate Id' ;
    rdfs:comment 'Identifier of the supervisor or specialist agent to whom the case was escalated. Null if no escalation occurred. Supports escalation path analysis and supervisor workload reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the service team or queue to which the case is assigned (e.g., Pharmacy Support, Delivery Resolution, Store Operations, Loyalty & Promotions). Supports team-level SLA and volume reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the customer complaint, inquiry, or issue as captured at case creation. May include product details, incident circumstances, and customer-stated expectations.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case reference number assigned by Salesforce CRM Service Cloud. Used in all customer-facing communications and agent workflows (e.g., CAS-000012345678).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle state of the customer service case. Drives agent queue management, SLA monitoring, and reporting dashboards. Values: open (newly created), in_progress (agent working), escalated (elevated to supervisor or specialist), resolved (solution provided), closed (confirmed complete).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the nature of the customer service case. Drives routing, SLA assignment, and resolution workflows. [ENUM-REF-CANDIDATE: complaint|inquiry|refund_request|delivery_issue|product_recall_concern|pharmacy_inquiry|billing_dispute|product_quality_issue|loyalty_inquiry — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the case was formally closed after customer confirmation or automatic closure policy. Distinct from resolution_timestamp — a case may be resolved but not yet closed pending customer acknowledgment.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Type of compensation or goodwill gesture issued to the customer as part of case resolution. Drives compensation cost reporting and policy compliance monitoring.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Unique alphanumeric code of the coupon or store credit voucher issued to the customer as case compensation. Used to track redemption and prevent duplicate issuance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponValue rdf:type rdf:Property ;
    rdfs:label 'Coupon Value' ;
    rdfs:comment 'Face value of any coupon or promotional voucher issued to the customer as part of case resolution. Expressed in USD. Null if no coupon was issued. Supports promotions liability and compensation cost reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmCaseCode rdf:type rdf:Property ;
    rdfs:label 'Crm Case Code' ;
    rdfs:comment 'Native case record identifier from Salesforce CRM Service Cloud (the system of record). Used for cross-system traceability and reconciliation between the Databricks Silver Layer and the operational CRM platform.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Post-resolution customer satisfaction rating provided by the shopper via survey (typically 1–5 scale). Null if the customer did not respond to the satisfaction survey. Used for agent performance evaluation and NPS correlation analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the case was escalated to a supervisor, specialist team, or higher support tier. Null if the case was never escalated. Used for escalation rate and time-to-escalate analytics.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the assigned agent first responded to the customer after case creation. Used to measure First Response Time (FRT) against SLA targets and customer experience KPIs.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFoodSafety rdf:type rdf:Property ;
    rdfs:label 'Is Food Safety' ;
    rdfs:comment 'Indicates whether the case involves a food safety concern (e.g., foreign object in food, illness report, temperature abuse, HACCP violation). When true, triggers mandatory escalation and regulatory notification workflows per FDA FSMA requirements.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPharmacyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Pharmacy Related' ;
    rdfs:comment 'Indicates whether the case involves a pharmacy inquiry, prescription issue, or drug-related concern. When true, the case is subject to HIPAA non-PHI handling protocols and routed to the pharmacy support team. No PHI is stored in this record.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Calendar date on which the customer service case was officially opened and entered into the system. Used for SLA calculation, aging reports, and volume trend analysis.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'Precise date and time when the case was created in Salesforce Service Cloud. The principal business event timestamp for this transaction. Used for SLA elapsed-time calculations and intraday volume reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Free-text description of the product involved in the case as reported by the customer or agent. Captured independently of the UPC to handle cases where the product cannot be precisely identified by barcode.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productUpc rdf:type rdf:Property ;
    rdfs:label 'Product Upc' ;
    rdfs:comment 'Universal Product Code (UPC) or Global Trade Item Number (GTIN) of the specific product involved in the case (e.g., for product quality complaints, recall concerns, or pricing disputes). Null if no specific product is implicated.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official FDA or USDA recall reference number associated with the case, if the case is linked to a product recall event. Null for non-recall cases. Critical for regulatory traceability and recall response reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary value of the refund issued to the customer as compensation for the case. Expressed in USD. Zero or null if no monetary refund was issued. Used for financial reconciliation and compensation cost tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this case has been reopened after a prior resolution or closure. A non-zero value indicates the initial resolution was unsatisfactory. Used for first-contact resolution (FCR) rate analysis and quality assurance.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the case was marked as resolved by the assigned agent or automated workflow. Used to calculate total resolution time and SLA compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaBreached rdf:type rdf:Property ;
    rdfs:label 'Sla Breached' ;
    rdfs:comment 'Indicates whether the case exceeded its SLA due timestamp without resolution. Set to true when resolution_timestamp is null at sla_due_timestamp or when resolution occurred after the SLA deadline. Used for SLA compliance reporting and agent performance management.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Due Timestamp' ;
    rdfs:comment 'Target deadline by which the case must be resolved per the applicable Service Level Agreement (SLA) policy. Calculated from open_timestamp plus the SLA target hours for the assigned case type and priority.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:snapWicRelated rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Related' ;
    rdfs:comment 'Indicates whether the case involves a SNAP (Supplemental Nutrition Assistance Program), WIC (Women Infants and Children), or EBT (Electronic Benefits Transfer) transaction dispute or eligibility inquiry. Supports government program compliance reporting.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short, free-text summary or title of the case as entered by the customer or agent. Used for case list views, search, and initial triage in Salesforce Service Cloud.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvProfileId rdf:type rdf:Property ;
    rdfs:label 'Cltv Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for each CLTV profile record. Primary key for the cltv_profile data product in the customer domain.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgBasketSize rdf:type rdf:Property ;
    rdfs:label 'Avg Basket Size' ;
    rdfs:comment 'Average transaction value in USD per shopping trip for the shopper over the trailing 12-month period. Computed from POS and OMS transaction data. Reflects Average Selling Price (ASP) per visit.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryBreadthScore rdf:type rdf:Property ;
    rdfs:label 'Category Breadth Score' ;
    rdfs:comment 'Count of distinct merchandise departments (e.g., produce, deli, pharmacy, bakery, fuel) shopped by the customer over the trailing 12-month period. Higher scores indicate deeper store engagement and lower churn risk.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cltvEstimate rdf:type rdf:Property ;
    rdfs:label 'Cltv Estimate' ;
    rdfs:comment 'The current computed Customer Lifetime Value (CLTV) in USD representing the projected net revenue this shopper is expected to generate over their remaining relationship with Grocery. Produced by the analytics pipeline on a scheduled cadence.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'Value tier classification assigned to the shopper based on their CLTV estimate. Tiers are: platinum (highest value), gold, silver, bronze (lowest value). Used by CRM targeting and loyalty tier management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationDate rdf:type rdf:Property ;
    rdfs:label 'Computation Date' ;
    rdfs:comment 'The calendar date on which the CLTV estimate and all associated metrics were last computed by the analytics pipeline. Determines the effective date of the profile snapshot.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for the shopper record in the Salesforce CRM platform. Used to synchronize CLTV profile data back to CRM for targeted campaign execution and personalization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the data quality status of the CLTV profile computation. \'clean\' means all input signals were complete; \'low_transaction_volume\' means fewer than the minimum required transactions were available; \'missing_channel_data\' means one or more channel feeds were absent; \'stale\' means the profile has not been refreshed within the expected SLA window; \'excluded\' means the record was excluded from scoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Count' ;
    rdfs:comment 'Number of completed last-mile delivery (LMD) orders placed by the shopper over the trailing 12-month period. Indicates omnichannel delivery engagement and is a key input to digital CLTV segmentation.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalEngagementScore rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Score' ;
    rdfs:comment 'Composite score (0.00 to 100.00) measuring the shopper\'s engagement with Grocery\'s digital channels including the eCommerce storefront, mobile app, and click-and-collect services. Derived from Salesforce Commerce Cloud interaction data. Higher scores indicate stronger omnichannel engagement.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSpendTrailing12m rdf:type rdf:Property ;
    rdfs:label 'Fuel Spend Trailing 12m' ;
    rdfs:comment 'Total shopper spend in USD at Grocery fuel center locations over the trailing 12-month period. Used to assess fuel center contribution to overall CLTV and cross-category engagement.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current unredeemed loyalty points balance for the shopper as of the computation date. Sourced from the NCR POS loyalty integration. Used as a retention signal in the CLTV model.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Semantic version identifier of the CLTV predictive model used to compute the current cltv_estimate and associated metrics (e.g., \'2.4.1\'). Enables model lineage tracking, A/B comparison, and auditability of scoring changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledComputationDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Computation Date' ;
    rdfs:comment 'The calendar date on which the next scheduled CLTV pipeline run is expected to refresh this profile. Used for pipeline scheduling and SLA monitoring.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) survey response from the shopper, on a scale of 0 to 10. Segmented into Promoters (9-10), Passives (7-8), and Detractors (0-6). Incorporated into CLTV model as a loyalty signal.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSegment rdf:type rdf:Property ;
    rdfs:label 'Nps Segment' ;
    rdfs:comment 'Categorical NPS segment derived from the shopper\'s NPS score: \'promoter\' (score 9-10), \'passive\' (score 7-8), \'detractor\' (score 0-6), \'unknown\' (no survey response). Used for CRM segmentation and loyalty program targeting.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacySpendTrailing12m rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Spend Trailing 12m' ;
    rdfs:comment 'Total shopper spend in USD at Grocery pharmacy locations over the trailing 12-month period. Non-PHI financial metric only; no prescription or health data included. Used to assess cross-category value contribution to CLTV.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupOrderCount rdf:type rdf:Property ;
    rdfs:label 'Pickup Order Count' ;
    rdfs:comment 'Number of completed curbside pickup or click-and-collect orders placed by the shopper over the trailing 12-month period. Indicates omnichannel pickup engagement and is a key input to digital CLTV segmentation.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predictedChurnProbability rdf:type rdf:Property ;
    rdfs:label 'Predicted Churn Probability' ;
    rdfs:comment 'Model-generated probability (0.0000 to 1.0000) that the shopper will churn (cease purchasing) within the next 90 days. Produced alongside the CLTV estimate by the analytics pipeline. Used for proactive retention targeting in CRM.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predictedNextPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Predicted Next Purchase Date' ;
    rdfs:comment 'Model-predicted calendar date of the shopper\'s next expected purchase transaction. Used for personalized re-engagement campaigns and replenishment reminder targeting.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorCltvTier rdf:type rdf:Property ;
    rdfs:label 'Prior Cltv Tier' ;
    rdfs:comment 'The CLTV tier assigned to the shopper in the immediately preceding computation cycle. Enables tier migration tracking, loyalty program upgrade/downgrade communications, and trend analysis.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelSpendPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Spend Pct' ;
    rdfs:comment 'Proportion of the shopper\'s trailing 12-month spend attributable to Grocery\'s private-label brand products, expressed as a decimal (0.0000 to 1.0000). Higher values indicate stronger private-label affinity and margin contribution.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the CLTV profile record. \'active\' indicates the profile is current and in use for CRM targeting; \'inactive\' indicates the shopper is no longer active; \'pending\' indicates awaiting first computation; \'suppressed\' indicates excluded from targeting per opt-out or compliance rules.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoRedemptionRate rdf:type rdf:Property ;
    rdfs:label 'Promo Redemption Rate' ;
    rdfs:comment 'Proportion of targeted promotional offers (TPR, BOGO, ad circular) redeemed by the shopper over the trailing 12-month period, expressed as a decimal (0.0000 to 1.0000). Indicates price sensitivity and promotional responsiveness for CRM targeting.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recencyScore rdf:type rdf:Property ;
    rdfs:label 'Recency Score' ;
    rdfs:comment 'Number of days elapsed since the shopper\'s most recent completed purchase transaction across any channel. Lower values indicate higher recency and engagement. Key RFM (Recency, Frequency, Monetary) input to the CLTV model.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapEbtSpendTrailing12m rdf:type rdf:Property ;
    rdfs:label 'Snap Ebt Spend Trailing 12m' ;
    rdfs:comment 'Total spend in USD processed via SNAP/EBT Electronic Benefits Transfer payment method by the shopper over the trailing 12-month period. Used for government program participation analytics and CLTV segmentation. Non-PII financial aggregate.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetingEligible rdf:type rdf:Property ;
    rdfs:label 'Targeting Eligible' ;
    rdfs:comment 'Indicates whether the shopper is currently eligible for CRM-driven targeted marketing based on their CLTV profile. Set to false if the shopper has opted out of marketing communications, is suppressed, or is flagged for compliance exclusion.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierChangeDate rdf:type rdf:Property ;
    rdfs:label 'Tier Change Date' ;
    rdfs:comment 'The date on which the shopper\'s CLTV tier last changed. Null if the shopper has never changed tiers. Used to trigger loyalty communications and track tier stability.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trailing12mSpend rdf:type rdf:Property ;
    rdfs:label 'Trailing 12m Spend' ;
    rdfs:comment 'Total shopper spend in USD across all channels (in-store POS, digital commerce, pharmacy) over the trailing 12-month window ending on the profile computation date. Key input to CLTV model.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitFrequency rdf:type rdf:Property ;
    rdfs:label 'Visit Frequency' ;
    rdfs:comment 'Average number of shopping visits per calendar month for the shopper over the trailing 12-month period, across all channels including in-store, pickup, and delivery. Used to assess engagement and predict churn.' ;
    rdfs:domain ind:CltvProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent record. Primary key for the consent_record data product in the customer domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Previous Consent Record Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior consent record that this record supersedes or replaces. Enables consent history chain reconstruction for audit and regulatory investigation purposes. Null for the initial consent record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'The web or app session identifier active at the time the shopper submitted their consent decision. Used for digital audit trails and cross-referencing with Salesforce Commerce Cloud session logs. Null for non-digital consent sources.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebSession .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The exact date and time when the shopper granted consent for the specified consent type. Serves as the authoritative timestamp for consent activation and regulatory audit trails.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which this consent record is scheduled to expire and require renewal. Null for indefinite consents. Supports re-consent campaign triggers and ensures consent currency for regulatory compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'The IETF BCP 47 language code representing the language in which the consent notice was presented to the shopper (e.g., \'en\', \'es\', \'zh-TW\'). Supports multilingual compliance and ensures consent was presented in the shopper\'s preferred language.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint through which the shopper provided or withdrew consent. Used for compliance auditing and channel attribution. Includes digital (app, web), physical (in-store kiosk, POS), and assisted (call center, paper form) channels.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of this consent record. Indicates whether the shopper has actively granted, withdrawn, or is pending confirmation of consent for the specified consent type.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being captured. Defines the specific communication channel or data-use purpose for which the shopper has provided or withdrawn consent. [ENUM-REF-CANDIDATE: marketing_email|sms|push_notification|direct_mail|data_sharing_cpg|personalization|analytics — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the legal consent text or privacy notice that the shopper agreed to at the time of consent. Enables tracking of which version of terms was in effect and supports re-consent workflows when legal text changes.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Partner Code' ;
    rdfs:comment 'Identifies the specific Consumer Packaged Goods (CPG) partner or third-party organization with whom shopper data may be shared under this consent record. Applicable only when consent_type is \'data_sharing_cpg\'. Null for all other consent types.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the shopper completed a double opt-in confirmation step (e.g., clicked a confirmation link in a verification email or SMS) for this consent record. Relevant for email and SMS marketing consent under CAN-SPAM and TCPA best practices.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Date' ;
    rdfs:comment 'The date and time when the shopper completed the double opt-in confirmation step. Null if double_opt_in_confirmed is false or not applicable for the consent type.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guardianRelationship rdf:type rdf:Property ;
    rdfs:label 'Guardian Relationship' ;
    rdfs:comment 'Describes the relationship of the consenting adult to the minor shopper when minor_guardian_consent is true. Null for adult shoppers. Required for COPPA compliance documentation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address of the device from which the shopper submitted their consent decision. Captured for regulatory proof-of-consent and fraud detection. Null for non-digital consent sources. May be considered PII under CCPA.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuppressed rdf:type rdf:Property ;
    rdfs:label 'Is Suppressed' ;
    rdfs:comment 'Indicates whether this shopper is currently on the suppression list for the associated consent type. When true, the shopper must be excluded from all outbound communications of the corresponding type regardless of other consent flags.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyProgramConsent rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Consent' ;
    rdfs:comment 'Indicates whether the shopper has consented to the use of their loyalty program transaction data (purchase history, points activity) for personalization and targeted marketing purposes. Distinct from general analytics consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorGuardianConsent rdf:type rdf:Property ;
    rdfs:label 'Minor Guardian Consent' ;
    rdfs:comment 'Indicates whether consent was provided by a parent or legal guardian on behalf of a minor shopper. Relevant for COPPA compliance when the shopper is under 13 years of age.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfConsentReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Consent Reference' ;
    rdfs:comment 'An external reference identifier (e.g., document ID, screenshot hash, call recording ID, or form submission ID) that serves as auditable proof of the consent event. Supports regulatory investigations and legal hold processes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Re Consent Requested Date' ;
    rdfs:comment 'The date on which a re-consent request was sent to the shopper. Null if no re-consent request has been issued. Used to track re-consent campaign outreach and measure response rates.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the shopper, typically triggered by a legal text version change, consent expiry, or regulatory update. Drives re-consent campaign targeting in CRM.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Suppression Effective Date' ;
    rdfs:comment 'The date on which the suppression became active for this shopper and consent type. Used to determine when outbound communications must cease. Null when is_suppressed is false.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Suppression Expiry Date' ;
    rdfs:comment 'The date on which the suppression is scheduled to expire, if applicable. Null for permanent suppressions (e.g., deceased, fraud flag). Enables automated re-activation of communication eligibility after temporary suppression periods.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the shopper was added to the suppression list. Supports compliance reporting and operational triage. Null when is_suppressed is false.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Suppression Source System' ;
    rdfs:comment 'The operational system of record that triggered or originated the suppression event. Supports data lineage, audit trails, and cross-system reconciliation for compliance investigations. [ENUM-REF-CANDIDATE: salesforce_crm|ncr_pos|mckesson|sfcc|call_center|manual|legal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionType rdf:type rdf:Property ;
    rdfs:label 'Suppression Type' ;
    rdfs:comment 'The specific communication channel or data-use category for which the shopper is suppressed. Null when is_suppressed is false. Drives suppression list filtering in outbound marketing execution systems.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The exact date and time when the shopper withdrew or revoked consent for the specified consent type. Null if consent has not been withdrawn. Required for CCPA opt-out audit trails.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactInfoId rdf:type rdf:Property ;
    rdfs:label 'Contact Info Id' ;
    rdfs:comment 'Unique surrogate identifier for each contact information record in the Grocery customer domain. Serves as the primary key for the contact_info data product.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactInfo .

ind:addressResidentialIndicator rdf:type rdf:Property ;
    rdfs:label 'Address Residential Indicator' ;
    rdfs:comment 'USPS-derived classification indicating whether the address is a residential or commercial location. Impacts last-mile delivery (LMD) carrier surcharge calculations, delivery time window eligibility, and cold chain logistics planning.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the purpose of the physical or mailing address captured in this record (e.g., home, billing, delivery, pickup, mailing). Null when the record represents a non-address contact type such as email or phone.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. \'active\' indicates the contact is valid and in use; \'bounced\' indicates email hard-bounce or phone disconnection; \'suppressed\' indicates the contact is on a suppression list for compliance reasons; \'pending_verification\' indicates awaiting confirmation.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classifies the nature of the contact channel captured in this record (e.g., email, mobile phone, home phone, work phone, fax). Drives channel-specific communication routing and CAN-SPAM/TCPA compliance enforcement.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact detail for non-address contact types: email address, mobile phone number, home phone number, work phone number, or fax number. Null when the record represents a physical address. Contains PII and must be handled per GDPR/CCPA requirements.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name associated with the address. Used for local tax jurisdiction mapping, regulatory reporting, and geographic segmentation analytics.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryZoneCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Code' ;
    rdfs:comment 'Internal delivery zone identifier assigned to this address based on geographic proximity to fulfillment centers, micro-fulfillment centers (MFC), or store locations. Used by the Order Management System (OMS) and last-mile delivery (LMD) routing to determine delivery eligibility, time windows, and carrier assignment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dncRegistryCheckedDate rdf:type rdf:Property ;
    rdfs:label 'Dnc Registry Checked Date' ;
    rdfs:comment 'Most recent date on which this phone contact record was checked against the FTC National Do Not Call (DNC) Registry. Required for TCPA compliance; phone numbers must be scrubbed against the DNC registry at least every 31 days before telemarketing calls.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether all outbound communications to this contact record are suppressed regardless of opt-in status. Set when an entity is on a national Do Not Call (DNC) registry, has filed a legal complaint, or has requested complete communication cessation. Overrides all opt-in flags.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entityRef rdf:type rdf:Property ;
    rdfs:label 'Entity Ref' ;
    rdfs:comment 'Identifier of the parent entity (shopper, wholesale account, or pharmacy patient) to whom this contact record belongs. Supports multiple contact records per entity.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Discriminator indicating the type of entity this contact record belongs to, enabling the contact_info product to serve B2C shoppers, B2B wholesale accounts, and pharmacy patients (non-PHI) within the customer domain.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultAddress rdf:type rdf:Property ;
    rdfs:label 'Is Default Address' ;
    rdfs:comment 'Indicates whether this address record is the default address for the entity. Used by the Order Management System (OMS) and omnichannel fulfillment to pre-populate delivery and billing addresses at checkout.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this contact record is the primary contact of its type for the entity. Only one record per entity per contact_type should have is_primary = true. Used to determine the default channel for outbound communications.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the contact value (email or phone) or address has been verified through an active confirmation process (e.g., email click-through, SMS OTP, USPS validation). Drives communication eligibility and fraud risk scoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees, WGS84) derived from USPS address normalization and geocoding. Supports last-mile delivery (LMD) route optimization, store assignment, and geographic segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees, WGS84) derived from USPS address normalization and geocoding. Supports last-mile delivery (LMD) route optimization, store assignment, and geographic segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the entity has provided explicit opt-in consent to receive marketing email communications on this email contact record. Required for CAN-SPAM and GDPR compliance. Null or false for non-email contact types.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the entity has opted in to receive push notifications through the Grocery mobile application or digital commerce platform. Supports omnichannel personalization and promotional targeting via Salesforce Commerce Cloud.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the entity has provided explicit opt-in consent to receive SMS/text message communications on this mobile phone contact record. Required for TCPA compliance. Null or false for non-mobile-phone contact types.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag indicating the entity\'s preferred language for communications delivered to this contact (e.g., en-US, es-MX, zh-CN). Supports multilingual marketing, ad circular distribution, and omnichannel personalization.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContactCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Code' ;
    rdfs:comment 'The native identifier of this contact record in the originating operational system of record (e.g., Salesforce Contact Point ID, SAP partner address number). Supports cross-system reconciliation and master data management (MDM) deduplication.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone offset) when the entity unsubscribed or withdrew consent for communications on this contact record. Null if the entity has not unsubscribed. Required for CAN-SPAM 10-business-day honor period and GDPR right-to-withdraw-consent tracking.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uspsDeliveryPointCode rdf:type rdf:Property ;
    rdfs:label 'Usps Delivery Point Code' ;
    rdfs:comment 'Two-digit USPS Delivery Point Code appended to the ZIP+4 to form the full 11-digit delivery point barcode. Confirms precise deliverability and supports carrier route optimization for last-mile delivery (LMD).' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uspsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Usps Validation Status' ;
    rdfs:comment 'Result of USPS address normalization and validation process. \'verified\' indicates the address was confirmed deliverable by USPS; \'unverified\' indicates validation has not been performed or was inconclusive; \'invalid\' indicates the address failed USPS validation and is not deliverable.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment 'USPS ZIP or ZIP+4 postal code for the address record. Supports delivery zone routing, geographic segmentation, store assignment, and SNAP/WIC/EBT program eligibility determination.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for a customer segment record in the Grocery CRM and marketing analytics platform. Primary key for the customer_segment reference entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:adCircularResponsive rdf:type rdf:Property ;
    rdfs:label 'Ad Circular Responsive' ;
    rdfs:comment 'Indicates whether shoppers in this segment are known to respond to weekly promotional ad circulars (print or digital). Used to prioritize segment inclusion in weekly ad circular targeting and Temporary Price Reduction (TPR) campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableChannel rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel' ;
    rdfs:comment 'The shopping channel(s) to which this segment applies for targeting and personalization. \'digital\' applies to Salesforce Commerce Cloud eCommerce and app experiences; \'in_store\' applies to NCR POS loyalty and in-store promotions; \'all\' applies across omnichannel touchpoints.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which this segment definition was formally approved by the owning team or governance committee for use in live marketing and personalization activities. Null if the segment has not yet been approved.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgBasketSizeBand rdf:type rdf:Property ;
    rdfs:label 'Avg Basket Size Band' ;
    rdfs:comment 'Categorical band representing the typical transaction basket size (number of items or spend level) for shoppers in this segment. Used for assortment planning, endcap and gondola placement decisions, and targeted upsell promotions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPriority rdf:type rdf:Property ;
    rdfs:label 'Campaign Priority' ;
    rdfs:comment 'Numeric priority ranking used to resolve conflicts when a customer qualifies for multiple segments simultaneously. Lower values indicate higher priority. Used by the CRM and Salesforce Commerce Cloud personalization engine to determine which segment\'s offer or experience takes precedence.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalEngagementScoreBand rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Score Band' ;
    rdfs:comment 'Categorical band representing the digital engagement level of shoppers in this segment, derived from app usage, click-and-collect frequency, and eCommerce activity on Salesforce Commerce Cloud. Used to tailor digital vs. in-store communication strategies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSegmentCode rdf:type rdf:Property ;
    rdfs:label 'External Segment Code' ;
    rdfs:comment 'The identifier for this segment as known in the originating external system (e.g., Salesforce CRM segment ID, NCR loyalty group code). Used for cross-system reconciliation and integration mapping during ETL and API synchronization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelRewardsEligible rdf:type rdf:Property ;
    rdfs:label 'Fuel Rewards Eligible' ;
    rdfs:comment 'Indicates whether members of this segment are eligible for Fuel Rewards program benefits, including per-gallon discounts at Grocery fuel centers. Used to target fuel-related promotions and cross-sell fuel center offers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic scope at which this segment is defined and applied. National segments apply across all Grocery markets; regional segments apply to specific trade areas; local and store_cluster segments apply to specific store groups for hyper-local targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPharmacySegment rdf:type rdf:Property ;
    rdfs:label 'Is Pharmacy Segment' ;
    rdfs:comment 'Indicates whether this segment targets pharmacy patients or customers with pharmacy-related behaviors (e.g., prescription refill frequency, OTC purchase patterns). Pharmacy segments must be handled in compliance with HIPAA privacy requirements for non-PHI customer data.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Program' ;
    rdfs:comment 'Indicates whether this segment is associated with a government-regulated assistance program such as SNAP (Supplemental Nutrition Assistance Program), WIC (Women, Infants, and Children), or EBT (Electronic Benefits Transfer). Regulatory program segments require special handling for compliance and reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuppressionSegment rdf:type rdf:Property ;
    rdfs:label 'Is Suppression Segment' ;
    rdfs:comment 'Indicates whether this segment is used as a suppression list to exclude customers from specific campaigns or communications (e.g., opt-out customers, recently converted customers, do-not-contact lists). Suppression segments are applied as exclusion filters in campaign execution.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Linked' ;
    rdfs:comment 'Indicates whether this segment is linked to the Grocery loyalty program for targeted rewards, personalized offers, and NCR POS loyalty integration. Loyalty-linked segments receive differentiated promotional treatment at checkout.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxMemberCount rdf:type rdf:Property ;
    rdfs:label 'Max Member Count' ;
    rdfs:comment 'The configured upper limit on the number of customers that can be assigned to this segment at any given time. Used for capacity-constrained segments such as exclusive loyalty tiers or pilot program cohorts. Null indicates no cap.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsBand rdf:type rdf:Property ;
    rdfs:label 'Nps Band' ;
    rdfs:comment 'Net Promoter Score (NPS) classification band associated with this segment, indicating the general advocacy level of shoppers in the segment. Promoters are highly satisfied advocates; detractors are at-risk shoppers. Used to prioritize retention and win-back campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicAffinity rdf:type rdf:Property ;
    rdfs:label 'Organic Affinity' ;
    rdfs:comment 'Indicates whether shoppers in this segment show a preference for USDA-certified organic products. Used to drive organic assortment decisions, planogram placement, and targeted promotions for organic categories.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the primary business owner or data steward responsible for this segment. Used for governance notifications, approval workflows, and segment lifecycle management communications.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Name of the internal business team responsible for defining, maintaining, and governing this segment (e.g., \'CRM Analytics\', \'Marketing Strategy\', \'Loyalty Programs\', \'Pharmacy Marketing\'). Used for accountability and data stewardship.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Fulfillment Method' ;
    rdfs:comment 'The order fulfillment method most commonly used by shoppers in this segment. Pickup = curbside or click-and-collect; delivery = last-mile delivery (LMD); in_store = traditional in-store shopping. Used to optimize omnichannel campaign targeting and OMS routing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStoreFormatAffinity rdf:type rdf:Property ;
    rdfs:label 'Primary Store Format Affinity' ;
    rdfs:comment 'The Grocery store format that shoppers in this segment most frequently visit or are primarily associated with. Used to tailor assortment recommendations, planogram decisions, and format-specific promotions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelAffinity rdf:type rdf:Property ;
    rdfs:label 'Private Label Affinity' ;
    rdfs:comment 'Indicates whether shoppers in this segment demonstrate a preference for Grocery\'s private-label (store-owned brand) products. Used to target private-label promotions, ad circular placements, and category management decisions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Band' ;
    rdfs:comment 'Categorical band representing the typical purchase frequency of shoppers in this segment. Used for lifecycle marketing, replenishment-driven promotions, and churn risk identification. Lapsed indicates shoppers who have not purchased within a defined recency window.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Code' ;
    rdfs:comment 'Identifies the specific government assistance program associated with this segment when is_regulatory_program is true. SNAP = Supplemental Nutrition Assistance Program; WIC = Women, Infants, and Children; EBT = Electronic Benefits Transfer. NONE if not a regulatory program segment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short, externally-known alphanumeric code uniquely identifying the segment across systems (e.g., HCL-001, SNAP-EBT, ORG-ENT). Used as the business key in CRM integrations, Salesforce Commerce Cloud personalization rules, and NCR POS loyalty targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s defining criteria, business purpose, and intended use cases. Authored by the owning marketing or CRM analytics team for documentation and governance purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the market segment as displayed in CRM dashboards, marketing campaign tools, and personalization engines (e.g., \'High-CLTV Loyalists\', \'SNAP/EBT Shoppers\', \'Organic Enthusiasts\', \'Fuel Rewards Members\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment. Active segments are used in live campaigns and personalization. Draft segments are being defined. Under_review segments are pending approval. Archived segments are retained for historical analysis but no longer applied.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology used to define this segment. Behavioral segments are based on purchase patterns; demographic on age/income/household; value-based on Customer Lifetime Value (CLTV) tiers; lifecycle on shopper journey stage; dietary_preference on food choices (organic, gluten-free, etc.).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Unique surrogate identifier for the household record. Primary key for the household data product within the customer domain. Entity role: MASTER_PARTY — represents a household grouping that the business interacts with as a loyalty and marketing counterparty.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:fulfillmentDeliveryRouteId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Delivery Route Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.delivery_route. Business justification: Household-level default delivery route for scheduled deliveries, required for logistics planning and route scheduling.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentDeliveryRoute .

ind:mergedIntoHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Household Id' ;
    rdfs:comment 'When a household record is consolidated (status = \'merged\'), this field references the surviving household ID into which this record was merged. Enables data lineage tracking and prevents orphaned loyalty history. Null when the household has not been merged.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:primaryShopperId rdf:type rdf:Property ;
    rdfs:label 'Primary Shopper Id' ;
    rdfs:comment 'Reference to the customer record designated as the primary loyalty cardholder and decision-maker for this household. Used for personalization, targeted promotions, and CLTV modeling. The primary shopper holds the loyalty account in their name.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:slaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.sla_policy. Business justification: Household-level SLA policy defines delivery expectations; required for customer-service KPI tracking and breach notifications.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the household was first acquired as a loyalty member. Used for marketing attribution, channel ROI analysis, and acquisition cost modeling. Supports optimization of loyalty enrollment investment across channels. [ENUM-REF-CANDIDATE: in_store|digital|direct_mail|referral|pharmacy|fuel_center|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationOptInEmail rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Email' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing and promotional communications via email. Must be respected for all outbound email campaigns per CAN-SPAM Act and CCPA opt-out requirements.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInMail rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Mail' ;
    rdfs:comment 'Indicates whether the household has opted in to receive physical direct mail communications, including weekly ad circulars and promotional mailers. Used for print campaign targeting and postal budget allocation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInSms rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Sms' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing and promotional communications via SMS/text message. Must be respected per TCPA (Telephone Consumer Protection Act) consent requirements for automated text messaging.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmHouseholdCode rdf:type rdf:Property ;
    rdfs:label 'Crm Household Code' ;
    rdfs:comment 'External household identifier assigned by Salesforce CRM. Used to correlate the lakehouse household record with the corresponding Salesforce CRM household object for bi-directional integration and data lineage.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryPreferenceFlags rdf:type rdf:Property ;
    rdfs:label 'Dietary Preference Flags' ;
    rdfs:comment 'Comma-delimited list of self-reported or inferred dietary preferences for the household (e.g., \'organic,gluten_free,kosher,vegan\'). Used for personalized product recommendations, digital storefront filtering, and targeted promotions. [ENUM-REF-CANDIDATE: organic|gluten_free|kosher|halal|vegan|vegetarian|dairy_free|nut_free|low_sodium — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAccountLinked rdf:type rdf:Property ;
    rdfs:label 'Digital Account Linked' ;
    rdfs:comment 'Indicates whether the household\'s loyalty account is linked to a digital account on the Salesforce Commerce Cloud eCommerce platform, enabling online ordering, digital coupons, and personalized web/app experiences.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebtCardOnFile rdf:type rdf:Property ;
    rdfs:label 'Ebt Card On File' ;
    rdfs:comment 'Indicates whether the household has an EBT (Electronic Benefits Transfer) card registered for use in online/pickup/delivery orders. Required for omnichannel SNAP/WIC benefit redemption compliance per USDA online EBT pilot program requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualGrocerySpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Grocery Spend' ;
    rdfs:comment 'Estimated total annual grocery expenditure for the household across all channels (in-store, pickup, delivery), expressed in USD. Derived from loyalty transaction history and third-party spend data. Used as a key input for CLTV modeling, tier assignment, and promotional investment prioritization. Not a calculated aggregate — represents a modeled estimate stored as a business attribute.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRewardsEnrolled rdf:type rdf:Property ;
    rdfs:label 'Fuel Rewards Enrolled' ;
    rdfs:comment 'Indicates whether the household is enrolled in the fuel rewards program, enabling per-gallon discount accrual at Grocery fuel centers. Used for fuel center promotional targeting and cross-category basket-building incentives.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeOwnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Home Ownership Status' ;
    rdfs:comment 'Indicates whether the household owns or rents their primary residence. Used as a demographic segmentation variable for targeted promotions (e.g., home improvement, cleaning supplies) and CLTV modeling. Sourced from third-party demographic append or loyalty enrollment data.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable label for the household, typically derived from the primary shopper\'s surname (e.g., \'Smith Household\'). Used in CRM displays, loyalty communications, and household-level reporting. Serves as the IDENTITY_LABEL for this MASTER_PARTY entity.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record. \'active\' indicates an engaged household with recent loyalty activity. \'inactive\' indicates no transactions within the defined inactivity window. \'suspended\' indicates a temporary hold (e.g., fraud review). \'merged\' indicates the household was consolidated into another. \'deceased\' indicates all primary members are deceased.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household by its primary relationship with the grocery business. Distinguishes B2C retail shoppers, B2B wholesale accounts, SNAP/WIC/EBT program participants, pharmacy patient households, and employee households. Drives eligibility rules, pricing tiers, and program enrollment. [ENUM-REF-CANDIDATE: b2c_shopper|b2b_wholesale|snap_wic_participant|pharmacy_patient|employee — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Estimated annual household income range, derived from third-party demographic data or self-reported during loyalty enrollment. Used for private-label brand targeting, SNAP/WIC eligibility modeling, and CLTV segmentation. Stored as a band rather than exact income to reduce sensitivity.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestHousehold rdf:type rdf:Property ;
    rdfs:label 'Is Test Household' ;
    rdfs:comment 'Indicates whether this household record is a test or synthetic record created for QA, UAT, or system integration testing purposes. Test households must be excluded from all production analytics, reporting, and marketing campaign execution.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase transaction recorded for any member of this household across all channels (in-store, pickup, delivery). Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis, lapsed-shopper identification, and win-back campaign targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Categorical classification of the household\'s current life stage based on composition and demographics. Drives assortment recommendations, promotional targeting, and personalization strategies. Values: single (one adult), couple (two adults, no children), family_with_children, empty_nester (adults, children departed), senior (primary shopper 65+).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Number' ;
    rdfs:comment 'The externally-known loyalty program account number associated with this household. Serves as the primary business identifier printed on loyalty cards and referenced at NCR POS during transaction processing. Links household to loyalty accrual and redemption activity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the household was first enrolled in the grocery loyalty program. Marks the EFFECTIVE_FROM of the household\'s loyalty relationship. Used for tenure-based segmentation, anniversary promotions, and cohort analysis.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Expiry Date' ;
    rdfs:comment 'Date on which the household\'s loyalty program membership expires or is scheduled for review. Nullable for open-ended memberships. Serves as the EFFECTIVE_UNTIL for the loyalty relationship. Used for renewal campaigns and lapsed-member win-back programs.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberCountAdult rdf:type rdf:Property ;
    rdfs:label 'Member Count Adult' ;
    rdfs:comment 'Number of adult members (age 18+) currently associated with this household. Used to differentiate adult-targeted promotions, alcohol/tobacco eligibility, and per-adult spend benchmarking from total household size.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberCountChild rdf:type rdf:Property ;
    rdfs:label 'Member Count Child' ;
    rdfs:comment 'Number of minor members (age under 18) currently associated with this household. Drives targeting for baby/toddler, school-age, and family product categories, as well as WIC program eligibility assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent NPS survey response was recorded for this household. Used to determine survey recency, control re-survey frequency, and track NPS trend over time.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pharmacyHousehold rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Household' ;
    rdfs:comment 'Indicates whether one or more members of this household are active pharmacy patients at a Grocery-operated pharmacy location. Non-PHI flag used for household-level pharmacy service targeting and cross-sell of health/wellness products. No prescription or clinical data is stored in this product.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredFulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Fulfillment Channel' ;
    rdfs:comment 'The household\'s predominant order fulfillment preference based on historical transaction patterns. Values: in_store (traditional shopping), pickup (click-and-collect / curbside), delivery (last-mile delivery), mixed (no dominant channel). Used for omnichannel personalization and capacity planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialZipCode rdf:type rdf:Property ;
    rdfs:label 'Residential Zip Code' ;
    rdfs:comment 'Five-digit (or ZIP+4) US postal code of the household\'s primary residence. Used for geographic segmentation, store trade area analysis, last-mile delivery (LMD) zone assignment, and targeted ad circular distribution. Not a full address — ZIP-level granularity balances utility with privacy.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total number of individuals currently associated with this household, including primary, secondary, and dependent members. Used for basket size benchmarking, per-capita spend analysis, and product assortment planning. Updated dynamically as members join or depart.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Eligible' ;
    rdfs:comment 'Indicates whether the household has been identified as eligible for SNAP (Supplemental Nutrition Assistance Program) benefits. Used to enable EBT payment processing at POS, apply SNAP-eligible item filtering, and comply with USDA SNAP retailer authorization requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wicEligible rdf:type rdf:Property ;
    rdfs:label 'Wic Eligible' ;
    rdfs:comment 'Indicates whether the household has been identified as eligible for WIC (Women, Infants, and Children) program benefits. Enables WIC-approved item filtering at POS and supports USDA WIC vendor compliance reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityResolutionId rdf:type rdf:Property ;
    rdfs:label 'Identity Resolution Id' ;
    rdfs:comment 'Unique surrogate primary key for each identity resolution or deduplication event record in the Grocery customer Master Data Management (MDM) system.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorResolutionIdentityResolutionId rdf:type rdf:Property ;
    rdfs:label 'Prior Resolution Identity Resolution Id' ;
    rdfs:comment 'Reference to a previous identity_resolution_id that this event supersedes, reverses, or is related to (e.g., an UNMERGE event references the original MERGE event). Enables resolution event chaining for complete MDM audit trail and lineage tracking.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IdentityResolution .

ind:survivingShopperId rdf:type rdf:Property ;
    rdfs:label 'Surviving Shopper Id' ;
    rdfs:comment 'The shopper identifier designated as the golden record after a merge resolution. Null for linked or flagged-for-review resolutions where no merge has occurred. Supports the single view of the customer across all Grocery touchpoints.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:addressSimilarityScore rdf:type rdf:Property ;
    rdfs:label 'Address Similarity Score' ;
    rdfs:comment 'Numeric similarity score (0.0000–1.0000) measuring the degree of address match between Side A and Side B records. Used in probabilistic resolution methods alongside name_similarity_score to evaluate name+address composite signals.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmContactIdA rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Id A' ;
    rdfs:comment 'The Salesforce CRM contact identifier for the Side A record, as sourced from Salesforce Commerce Cloud or CRM platform. Preserved for cross-system reconciliation and to support CRM deduplication workflows.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactIdB rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Id B' ;
    rdfs:comment 'The Salesforce CRM contact identifier for the Side B record. Preserved for cross-system reconciliation and to support downstream CRM merge/deduplication operations in Salesforce.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailMatch rdf:type rdf:Property ;
    rdfs:label 'Email Match' ;
    rdfs:comment 'Indicates whether the email addresses on Side A and Side B records matched (exact or normalized) during the resolution evaluation. Supports granular analysis of which identity signals contributed to the match decision.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 under which the identity resolution processing activity is conducted. Required for compliance with privacy regulations applicable to Grocery\'s customer data processing. NOT_APPLICABLE for non-EU shoppers.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyIdMatch rdf:type rdf:Property ;
    rdfs:label 'Loyalty Id Match' ;
    rdfs:comment 'Indicates whether the loyalty program identifiers (Point of Sale (POS) loyalty IDs) on Side A and Side B records matched during the resolution evaluation. Loyalty ID is a high-confidence deterministic signal in grocery retail identity resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Match Confidence Score' ;
    rdfs:comment 'Numeric probability score between 0.0000 and 1.0000 representing the algorithm\'s confidence that Side A and Side B records belong to the same individual. Scores above the configured threshold trigger automatic merge; scores in the review band are flagged for manual review. Critical for data quality KPI reporting.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Match Rule Version' ;
    rdfs:comment 'The version identifier of the matching rule set or ML model that was applied during this resolution event (e.g., \'RULE_SET_v2.3\', \'ML_MODEL_v1.0.5\'). Enables retrospective analysis of resolution quality across rule engine versions and supports model governance.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchSignal rdf:type rdf:Property ;
    rdfs:label 'Match Signal' ;
    rdfs:comment 'The primary data attribute(s) that triggered the match between Side A and Side B records. Indicates which identity signal (e.g., email, phone, loyalty ID, name+address combination) drove the resolution decision. [ENUM-REF-CANDIDATE: EMAIL|PHONE|LOYALTY_ID|NAME_ADDRESS|EMAIL_PHONE|NAME_DOB|DEVICE_ID|PAYMENT_TOKEN — promote to reference product]' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchThreshold rdf:type rdf:Property ;
    rdfs:label 'Match Threshold' ;
    rdfs:comment 'The configured confidence score threshold that was in effect at the time of this resolution event. Records the threshold value used to classify the match as auto-merge, review, or reject, enabling retrospective audit of threshold policy changes.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nameSimilarityScore rdf:type rdf:Property ;
    rdfs:label 'Name Similarity Score' ;
    rdfs:comment 'Numeric similarity score (0.0000–1.0000) measuring the degree of name match between Side A and Side B records, computed using fuzzy string matching algorithms (e.g., Jaro-Winkler, Levenshtein). Used in probabilistic resolution methods.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneMatch rdf:type rdf:Property ;
    rdfs:label 'Phone Match' ;
    rdfs:comment 'Indicates whether the phone numbers on Side A and Side B records matched (exact or normalized) during the resolution evaluation. Supports granular signal-level analysis of match quality.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posLoyaltyIdA rdf:type rdf:Property ;
    rdfs:label 'Pos Loyalty Id A' ;
    rdfs:comment 'The NCR Point of Sale (POS) loyalty program identifier associated with the Side A record. A high-confidence deterministic identity signal in grocery retail. Preserved for audit trail and cross-system identity traceability.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posLoyaltyIdB rdf:type rdf:Property ;
    rdfs:label 'Pos Loyalty Id B' ;
    rdfs:comment 'The NCR Point of Sale (POS) loyalty program identifier associated with the Side B record. Paired with pos_loyalty_id_a to evaluate loyalty ID match signal during deterministic resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionBatchCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Batch Code' ;
    rdfs:comment 'Identifier of the batch deduplication run or scheduled job that generated this resolution event. Groups all resolution events produced in the same processing cycle for operational monitoring, reprocessing, and data quality KPI reporting.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionChannel rdf:type rdf:Property ;
    rdfs:label 'Resolution Channel' ;
    rdfs:comment 'The processing channel through which the resolution event was initiated. BATCH = overnight bulk deduplication run; REAL_TIME = triggered at point of customer interaction; MANUAL_UI = data steward action via MDM console; API = triggered by external system call; SCHEDULED = periodic reconciliation job.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Expiry Date' ;
    rdfs:comment 'The date after which a REJECTED or FLAGGED_FOR_REVIEW resolution decision should be re-evaluated. Supports periodic re-review of borderline cases as new identity signals become available. Null for permanent decisions (MERGED, LINKED).' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'The algorithmic or procedural approach used to determine that two records represent the same shopper. DETERMINISTIC = exact match on email, phone, or loyalty ID; PROBABILISTIC = fuzzy match on name and address; MANUAL_MERGE = data steward decision; RULE_BASED = configurable business rules; ML_MODEL = machine learning classifier.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current workflow state of the identity resolution event. MERGED = records combined into a single golden record; LINKED = records associated but kept separate; FLAGGED_FOR_REVIEW = queued for manual data steward review; REJECTED = determined to be distinct individuals; PENDING = awaiting processing or review.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The category of action taken during this resolution event. MERGE = two records collapsed into one golden record; LINK = records associated without merging; UNMERGE = previously merged records separated; UNLINK = previously linked records disassociated; RECLASSIFY = resolution status changed without structural change.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedByUser rdf:type rdf:Property ;
    rdfs:label 'Resolved By User' ;
    rdfs:comment 'The username, service account name, or system process identifier that executed the resolution action. For manual merges, this is the data steward\'s user ID. For automated resolutions, this is the system or batch process name (e.g., \'MDM_AUTO_MERGE_JOB\'). Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDecision rdf:type rdf:Property ;
    rdfs:label 'Review Decision' ;
    rdfs:comment 'The outcome decision made by the data steward during manual review of a flagged resolution event. APPROVED = steward confirmed the match and authorized the action; REJECTED = steward determined records are distinct; ESCALATED = referred to senior steward or governance committee; DEFERRED = decision postponed pending additional information.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes entered by the data steward during manual review, documenting the rationale for their decision. Supports audit trail completeness and institutional knowledge for recurring edge cases in identity resolution.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewQueueCode rdf:type rdf:Property ;
    rdfs:label 'Review Queue Code' ;
    rdfs:comment 'Identifier of the data steward review queue or work item to which this resolution event was assigned when flagged for manual review. Null for automated resolutions that did not require human intervention. Supports workflow management and SLA tracking for MDM operations.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'The date and time when the data steward completed their manual review and recorded a review_decision. Null for automated resolutions. Used to calculate review SLA compliance and MDM operational KPIs.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewerUser rdf:type rdf:Property ;
    rdfs:label 'Reviewer User' ;
    rdfs:comment 'The username of the data steward or MDM analyst who reviewed and adjudicated this resolution event when it was flagged for manual review. Null for fully automated resolutions. Distinct from resolved_by_user which captures the executor.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopperIdA rdf:type rdf:Property ;
    rdfs:label 'Shopper Id A' ;
    rdfs:comment 'Internal shopper identifier for the first (source) record participating in the identity resolution event. Represents one of the two candidate duplicate records being evaluated or merged.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shopperIdB rdf:type rdf:Property ;
    rdfs:label 'Shopper Id B' ;
    rdfs:comment 'Internal shopper identifier for the second (candidate duplicate) record participating in the identity resolution event. Paired with shopper_id_a to form the resolution pair.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemA rdf:type rdf:Property ;
    rdfs:label 'Source System A' ;
    rdfs:comment 'Operational system of record that originated the Side A shopper record. Identifies which platform (e.g., NCR Point of Sale (POS), Salesforce CRM, eCommerce, McKesson Pharmacy, mobile app, loyalty system) contributed the first identity.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemB rdf:type rdf:Property ;
    rdfs:label 'Source System B' ;
    rdfs:comment 'Operational system of record that originated the Side B shopper record. Identifies which platform contributed the second (candidate duplicate) identity for comparison against Side A.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdA rdf:type rdf:Property ;
    rdfs:label 'Source System Id A' ;
    rdfs:comment 'The native identifier of the Side A record as it exists in its originating source system (e.g., NCR POS loyalty ID, Salesforce CRM contact ID, eCommerce account ID). Preserved for audit trail and cross-system traceability.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdB rdf:type rdf:Property ;
    rdfs:label 'Source System Id B' ;
    rdfs:comment 'The native identifier of the Side B record as it exists in its originating source system. Preserved for audit trail and cross-system traceability alongside source_system_id_a.' ;
    rdfs:domain ind:IdentityResolution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each recorded shopper interaction or touchpoint event across all channels. Primary key for the interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Id' ;
    rdfs:comment 'Reference to the Point of Sale (POS) transaction associated with this interaction, when the interaction is triggered by or linked to a specific in-store purchase (e.g., post-purchase NPS, receipt-based complaint). Sourced from NCR POS Systems.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Specific classification of the complaint when interaction_type = \'complaint\' (e.g., \'Product Quality\', \'Pricing Error\', \'Staff Conduct\', \'Food Safety\', \'Delivery Failure\'). Supports regulatory reporting and operational improvement. [ENUM-REF-CANDIDATE: product_quality|pricing_error|staff_conduct|food_safety|delivery_failure|pharmacy_error|billing_dispute — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactReasonCode rdf:type rdf:Property ;
    rdfs:label 'Contact Reason Code' ;
    rdfs:comment 'Standardized code identifying the primary reason the shopper initiated contact, as classified by the contact center or CRM system (e.g., \'ORD-001\' for order inquiry, \'PHM-003\' for pharmacy question). Enables contact reason analytics and workforce planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'Source system activity or interaction record identifier from the CRM platform (Salesforce Commerce Cloud). Enables traceability and reconciliation between the lakehouse silver layer and the operational CRM system of record.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalTouchpointCode rdf:type rdf:Property ;
    rdfs:label 'Digital Touchpoint Code' ;
    rdfs:comment 'Identifier for the specific digital touchpoint associated with this interaction (e.g., app session ID, web session ID, email campaign ID). Used for digital journey analytics and attribution. Nullable for in-store or phone interactions.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalTouchpointType rdf:type rdf:Property ;
    rdfs:label 'Digital Touchpoint Type' ;
    rdfs:comment 'Classification of the digital touchpoint type for digital channel interactions (e.g., app session, web session, email campaign, push notification). Supports omnichannel attribution and digital engagement analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the interaction in seconds (e.g., call handle time, chat session length). Used for contact center efficiency metrics, average handle time (AHT) reporting, and workforce planning.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalated rdf:type rdf:Property ;
    rdfs:label 'Escalated' ;
    rdfs:comment 'Indicates whether this interaction was escalated to a supervisor, specialist team, or higher support tier. True when escalation occurred; False otherwise. Supports contact center quality and SLA reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Textual description of why the interaction was escalated (e.g., \'Shopper requested supervisor\', \'Regulatory complaint\', \'Unresolved after two contacts\'). Populated only when escalated = True.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContactResolution rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution' ;
    rdfs:comment 'Indicates whether the shopper\'s issue was fully resolved during this single interaction without requiring a follow-up contact. First Contact Resolution (FCR) is a key contact center performance metric.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date by which a follow-up action or contact must be completed. Populated when follow_up_required = True. Used for SLA tracking and agent task management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up action or contact is required after this interaction. Drives task creation and callback scheduling in CRM workflows.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionCategory rdf:type rdf:Property ;
    rdfs:label 'Interaction Category' ;
    rdfs:comment 'Business category classifying the root topic of the interaction (e.g., \'Order Fulfillment\', \'Pharmacy\', \'Loyalty & Promotions\', \'Product Quality\', \'Delivery\', \'Billing\'). Supports contact reason analytics and operational improvement initiatives. [ENUM-REF-CANDIDATE: order_fulfillment|pharmacy|loyalty_promotions|product_quality|delivery|billing|store_experience|fuel_center — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'Calendar date of the interaction, derived from interaction_timestamp. Used for day-level reporting, store-level NPS benchmarking, and date-partitioned analytics queries.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the interaction event occurred (e.g., when the call was connected, when the chat session started, when the NPS survey was submitted). This is the principal business event timestamp, distinct from record audit timestamps.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the nature of the shopper interaction. Determines which supplemental fields are applicable. [ENUM-REF-CANDIDATE: call_center_contact|chat_session|service_desk_visit|email_open|app_session|delivery_feedback|complaint|compliment|nps_survey — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsClassification rdf:type rdf:Property ;
    rdfs:label 'Nps Classification' ;
    rdfs:comment 'Derived classification of the shopper\'s NPS response: Promoter (9–10), Passive (7–8), or Detractor (0–6). Populated only for NPS survey interactions. Used for store-level NPS benchmarking and customer experience segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyTrigger rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Trigger' ;
    rdfs:comment 'The business event that triggered the NPS survey to be sent to the shopper (e.g., post-purchase, post-delivery, post-pharmacy-visit, post-pickup). Enables analysis of NPS scores by customer journey stage.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsVerbatimComment rdf:type rdf:Property ;
    rdfs:label 'Nps Verbatim Comment' ;
    rdfs:comment 'Open-text verbatim comment provided by the shopper as part of the NPS survey response. Captures qualitative feedback for customer experience analysis, sentiment analysis, and AI/ML text analytics. Populated only for NPS survey interactions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Free-text or coded description of the result of the interaction (e.g., \'refund issued\', \'order re-dispatched\', \'information provided\', \'complaint logged\'). Captures the actionable result for CRM and service quality reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this interaction, used in customer-facing communications (e.g., confirmation emails, chat transcripts). Sourced from CRM or contact center platform.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this interaction involves a regulatory or compliance matter requiring escalation or formal reporting (e.g., FDA food safety complaint, DEA pharmacy concern, HIPAA-related inquiry, OSHA workplace incident report). True triggers compliance workflow.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:satisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Rating' ;
    rdfs:comment 'Post-interaction satisfaction rating provided by the shopper, typically on a 1–5 scale (CSAT). Distinct from NPS score; captures immediate interaction-level satisfaction rather than overall brand loyalty. Null for interactions where no rating was solicited.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing more granular detail within the interaction_category (e.g., within \'Delivery\': \'Late Delivery\', \'Missing Item\', \'Damaged Item\'). Enables drill-down root cause analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Response Status' ;
    rdfs:comment 'Status of the shopper\'s response to a survey interaction: complete (all questions answered), partial (some questions answered), opted_out (shopper declined), or no_response (survey sent but not answered). Applicable to NPS and other survey interaction types.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Time Seconds' ;
    rdfs:comment 'Time in seconds the shopper waited before being connected to an agent or receiving a response. Used for service level agreement (SLA) monitoring and customer experience benchmarking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyPatientId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Patient Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacy patient profile record in the Grocery lakehouse Silver layer. Primary key for this entity. Entity role: MASTER_AGREEMENT — represents a long-running enrollment/registration relationship between a shopper and Grocery pharmacy services.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyPatient .

ind:pharmacistAssociateId rdf:type rdf:Property ;
    rdfs:label 'Pharmacist Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Pharmacy counseling assigns a pharmacist associate to each patient; required for compliance reporting and medication counseling audit.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:allergyDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Allergy Disclosure Date' ;
    rdfs:comment 'Date on which the patient most recently disclosed or updated their self-reported allergy information with pharmacy staff. Nullable when allergy_flag is False. Used to prompt periodic allergy review during counseling.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergyFlag rdf:type rdf:Property ;
    rdfs:label 'Allergy Flag' ;
    rdfs:comment 'Non-clinical, self-reported indicator that the patient has disclosed one or more drug or food allergies to pharmacy staff. This is a flag only — clinical allergy details reside in McKesson Pharmacy Systems and are excluded from this non-PHI profile per HIPAA compliance requirements.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRefillConsentDate rdf:type rdf:Property ;
    rdfs:label 'Auto Refill Consent Date' ;
    rdfs:comment 'Date on which the patient provided or last updated consent for the auto-refill program. Required for audit trail and regulatory compliance. Nullable when auto_refill_opt_in is False.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRefillOptIn rdf:type rdf:Property ;
    rdfs:label 'Auto Refill Opt In' ;
    rdfs:comment 'Indicates whether the patient has opted into the automatic prescription refill program. When True, eligible maintenance medications are automatically queued for refill before the supply runs out. Drives CAO (Computer-Assisted Ordering) logic for pharmacy inventory.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counselingPreference rdf:type rdf:Property ;
    rdfs:label 'Counseling Preference' ;
    rdfs:comment 'Patient\'s preferred method for receiving pharmacist counseling when picking up a new or changed prescription. \'waived\' indicates the patient has formally declined counseling. Required by OBRA-90 regulations for Medicaid patients; captured for all patients as best practice.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counselingWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Counseling Waiver Date' ;
    rdfs:comment 'Date on which the patient most recently waived pharmacist counseling. Nullable when counseling_preference is not \'waived\'. Supports compliance audit trail for OBRA-90 and State Board of Pharmacy inspections.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for prescription home delivery. Captured separately from the shopper\'s primary address to support patients who require delivery to a different location (e.g., workplace, caregiver address). Used by LMD (Last Mile Delivery) routing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for prescription home delivery (apartment, suite, unit number). Nullable. Complements delivery_address_line1 for complete delivery address specification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City component of the prescription home delivery address. Used for LMD (Last Mile Delivery) zone assignment and carrier routing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the prescription home delivery address. Used for delivery zone mapping, carrier selection, and geographic analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateCode rdf:type rdf:Property ;
    rdfs:label 'Delivery State Code' ;
    rdfs:comment 'Two-letter US state code for the prescription home delivery address. Used for carrier zone assignment and state-level pharmacy licensing compliance verification.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disenrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Date' ;
    rdfs:comment 'Date on which the pharmacy patient profile was deactivated or the patient relationship ended. Nullable for currently active patients. Used for record retention scheduling and compliance reporting.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Full name of the legally authorized representative or guardian for patients who cannot consent on their own behalf (e.g., pediatric patients, patients with power of attorney arrangements). Non-PHI reference field. Nullable for adult patients without a designated representative.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAcknowledgmentChannel rdf:type rdf:Property ;
    rdfs:label 'Hipaa Acknowledgment Channel' ;
    rdfs:comment 'Method by which the patient acknowledged the HIPAA Notice of Privacy Practices. Supports audit trail for HIPAA compliance. \'verbal_noted\' is used when the patient verbally acknowledged but declined to sign, per HIPAA good-faith effort documentation requirements.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Acknowledgment Date' ;
    rdfs:comment 'Date on which the patient acknowledged receipt of the HIPAA Notice of Privacy Practices. Nullable when hipaa_notice_acknowledged is False. Required for HIPAA compliance audit trail.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaNoticeAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Hipaa Notice Acknowledged' ;
    rdfs:comment 'Indicates whether the patient has acknowledged receipt of the pharmacy\'s HIPAA Notice of Privacy Practices (NPP). Required by HIPAA Privacy Rule for all new pharmacy patients. Pharmacies must make a good-faith effort to obtain written acknowledgment.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceBinNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Bin Number' ;
    rdfs:comment 'Six-digit Bank Identification Number (BIN) used to route pharmacy claims to the correct Pharmacy Benefit Manager (PBM) during adjudication. Non-PHI operational identifier. Standard NCPDP field used in electronic claims processing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceGroupNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Group Number' ;
    rdfs:comment 'Insurance group identifier associated with the patient\'s pharmacy benefit plan. Used during claims adjudication to identify the employer group or plan sponsor. Non-PHI operational field. Standard NCPDP field.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePcn rdf:type rdf:Property ;
    rdfs:label 'Insurance Pcn' ;
    rdfs:comment 'Processor Control Number (PCN) used in conjunction with the BIN to route pharmacy claims to the correct adjudication processor within a PBM network. Non-PHI operational field. Standard NCPDP field.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePlanName rdf:type rdf:Property ;
    rdfs:label 'Insurance Plan Name' ;
    rdfs:comment 'Name of the patient\'s primary pharmacy benefit insurance plan (e.g., \'BlueCross BlueShield Rx\', \'Aetna Pharmacy\'). Non-PHI operational field used for routing adjudication and patient communication. Detailed insurance/PBM data resides in McKesson.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Patient\'s preferred language for pharmacy communications, prescription labels, and counseling materials. Stored as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-TW\'). Used to route multilingual pharmacy staff and generate translated prescription materials per FDA labeling guidance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRxFillDate rdf:type rdf:Property ;
    rdfs:label 'Last Rx Fill Date' ;
    rdfs:comment 'Date of the patient\'s most recent prescription fill at any Grocery pharmacy location. Non-PHI operational field used for patient activity monitoring, inactive patient identification, and MedSync scheduling. Sourced from McKesson Pharmacy Systems.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyRxPointsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Rx Points Eligible' ;
    rdfs:comment 'Indicates whether the patient is eligible to earn loyalty program points for qualifying prescription fills. Integrates pharmacy activity with the Grocery loyalty program managed via NCR POS Systems and CRM. Certain prescription categories (e.g., controlled substances) may be ineligible per program rules.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mckessonPatientCode rdf:type rdf:Property ;
    rdfs:label 'Mckesson Patient Code' ;
    rdfs:comment 'External patient identifier assigned by McKesson Pharmacy Systems (the operational system of record for prescription management). Used to cross-reference non-PHI profile data in the lakehouse with clinical records in McKesson. Required for operational reconciliation.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medsyncEnrolled rdf:type rdf:Property ;
    rdfs:label 'Medsync Enrolled' ;
    rdfs:comment 'Indicates whether the patient is enrolled in the Medication Synchronization (MedSync) program, which aligns all of the patient\'s maintenance prescriptions to a single monthly pickup date. Improves adherence and reduces pharmacy counter traffic variability.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medsyncEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Medsync Enrollment Date' ;
    rdfs:comment 'Date on which the patient was enrolled in the MedSync program. Used for program tenure tracking and cohort analysis. Nullable when medsync_enrolled is False.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medsyncSyncDate rdf:type rdf:Property ;
    rdfs:label 'Medsync Sync Date' ;
    rdfs:comment 'The designated monthly calendar date on which all synchronized prescriptions for this patient are scheduled for pickup or delivery. Nullable when medsync_enrolled is False. Used for pharmacy workload planning and inventory pre-positioning.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:n340bEligible rdf:type rdf:Property ;
    rdfs:label 'N340b Eligible' ;
    rdfs:comment 'Indicates whether the patient is eligible for the 340B Drug Pricing Program, which provides discounted outpatient drugs to qualifying patients of covered entities. Non-PHI eligibility flag used for claims routing and pricing.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Status' ;
    rdfs:comment 'Current lifecycle status of the pharmacy patient profile. \'active\' indicates the patient is actively using Grocery pharmacy services. \'inactive\' indicates no recent activity. \'on_hold\' indicates a temporary suspension of services. \'transferred\' indicates the patient has moved to another pharmacy. \'deceased\' is set upon notification of patient death for record retention compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientType rdf:type rdf:Property ;
    rdfs:label 'Patient Type' ;
    rdfs:comment 'Classification of the pharmacy patient by service type. \'retail\' is the standard in-store patient. \'mail_order\' indicates the patient primarily uses mail-order fulfillment. \'specialty\' indicates enrollment in specialty pharmacy programs for high-cost or complex medications. \'long_term_care\' indicates a patient in a care facility. \'pediatric\' indicates a minor patient with a guardian on file.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarePhysicianName rdf:type rdf:Property ;
    rdfs:label 'Primary Care Physician Name' ;
    rdfs:comment 'Self-reported name of the patient\'s primary care physician (PCP). Used for prescription verification and physician outreach by pharmacy staff. This is a non-PHI reference field — clinical prescriber details reside in McKesson. Stored as a free-text name, not a structured provider record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarePhysicianPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Care Physician Phone' ;
    rdfs:comment 'Contact phone number for the patient\'s primary care physician office. Used by pharmacy staff to verify prescriptions or coordinate care. Non-PHI operational reference field. Stored in E.164 international format.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Rx Notification Channel' ;
    rdfs:comment 'Patient\'s preferred communication channel for prescription-related notifications, including ready-for-pickup alerts, refill reminders, and drug interaction notices. Drives outbound messaging routing in McKesson and NCR POS Systems.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxReadyPickupPreference rdf:type rdf:Property ;
    rdfs:label 'Rx Ready Pickup Preference' ;
    rdfs:comment 'Patient\'s preferred method for collecting ready prescriptions. Supports omnichannel fulfillment including in-store counter, curbside pickup (Click-and-Collect), drive-through pharmacy window, and home delivery. Drives OMS (Order Management System) routing for pharmacy fulfillment.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapBenefitEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Benefit Eligible' ;
    rdfs:comment 'Indicates whether the patient has been identified as eligible for SNAP (Supplemental Nutrition Assistance Program) benefits, which may affect OTC product eligibility at the pharmacy counter. Non-PHI flag aligned with the shopper master SNAP eligibility field.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wicBenefitEligible rdf:type rdf:Property ;
    rdfs:label 'Wic Benefit Eligible' ;
    rdfs:comment 'Indicates whether the patient has been identified as eligible for WIC (Women, Infants, and Children) program benefits, which may affect eligible OTC and formula purchases at the pharmacy counter. Non-PHI flag.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each shopper preference record in the Grocery customer preference data product. Serves as the primary key for all preference-related joins and lineage tracking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationPreference rdf:type rdf:Property ;
    rdfs:label 'Certification Preference' ;
    rdfs:comment 'Specifies a product certification standard that the shopper prefers when purchasing. Used to filter product catalog results in digital commerce and to drive assortment recommendations. Aligns with USDA organic certification and GS1 product attribute standards. Null for non-certification preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A numeric score between 0.0000 and 1.0000 representing the system\'s confidence in the accuracy of an inferred preference. A score of 1.0000 indicates a self-declared preference with full certainty. Lower scores indicate inferred preferences with varying degrees of certainty. Used by the personalization engine to weight recommendations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether the shopper has provided explicit consent for Grocery to collect, store, and use their preference data for personalization and targeted marketing purposes. Required for GDPR and CCPA compliance. When FALSE, preference data must not be used for marketing purposes.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The date and time when the shopper provided or last renewed consent for preference data collection and use. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dietaryRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Dietary Restriction Type' ;
    rdfs:comment 'Classifies the nature of a dietary restriction preference. \'allergy\' indicates a medically significant food allergy. \'intolerance\' indicates a food sensitivity. \'medical\' indicates a clinically prescribed dietary requirement. \'religious\' indicates a faith-based dietary rule (e.g., kosher, halal). \'ethical\' indicates a values-based choice (e.g., vegan). \'lifestyle\' indicates a personal wellness choice (e.g., keto). Null for non-dietary preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebtEligibleFilter rdf:type rdf:Property ;
    rdfs:label 'Ebt Eligible Filter' ;
    rdfs:comment 'Indicates whether the shopper has enabled the EBT (Electronic Benefits Transfer) eligible product filter in their digital commerce experience. When TRUE, product search and browse results are filtered to show only EBT-eligible items. Supports SNAP/WIC program compliance in the digital channel.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailFrequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Email Frequency Preference' ;
    rdfs:comment 'The shopper\'s declared preference for how often they wish to receive promotional email communications, including ad circulars and personalized offers. Governs email suppression logic in the CRM platform. Null for non-communication preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'The version identifier of the machine learning model used to infer this preference from purchase history or behavioral data (e.g., \'v1.3.2\'). Null for self-declared preferences. Enables model governance, A/B testing of inference models, and rollback of preferences generated by deprecated model versions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this preference record is currently active and should be applied in personalization, product filtering, and marketing targeting. Set to FALSE when a shopper removes or overrides a preference.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAllergy rdf:type rdf:Property ;
    rdfs:label 'Is Allergy' ;
    rdfs:comment 'Indicates whether this preference represents a food allergy or intolerance (e.g., nut allergy, lactose intolerance, celiac/gluten-free). When TRUE, this preference is treated with elevated priority in product filtering and warning displays to protect shopper safety. Aligns with FDA food allergen labeling requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifestyleDietType rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Diet Type' ;
    rdfs:comment 'Identifies the shopper\'s declared or inferred lifestyle diet pattern. Used to curate personalized product recommendations, recipe suggestions, and category affinities in the digital commerce experience. Null for non-lifestyle preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalGoalType rdf:type rdf:Property ;
    rdfs:label 'Nutritional Goal Type' ;
    rdfs:comment 'Specifies the primary nutritional goal the shopper is pursuing. Used to filter product catalog results and surface nutritionally aligned products in digital commerce. Aligns with FDA nutrition labeling standards. Null for non-nutritional preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why a preference was overridden. Populated when preference_status is \'overridden\', typically when a self-declared preference supersedes an inferred one, or when a customer service associate corrects a preference on behalf of the shopper. Supports audit and data quality review.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether this preference record is currently eligible to be consumed by the Salesforce Commerce Cloud personalization engine for product recommendations, digital commerce filtering, and targeted marketing. May be FALSE if consent is withdrawn, the preference is expired, or the confidence score is below the minimum threshold.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level grouping that classifies the type of preference being recorded. Drives routing to the correct personalization engine module in Salesforce Commerce Cloud. [ENUM-REF-CANDIDATE: dietary|lifestyle|nutritional_goal|certification|shopping|communication|product_affinity — promote to reference product if additional categories are added]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Indicates how this preference was captured. \'self_declared\' means the shopper explicitly set it via the app or web profile. \'purchase_inferred\' means it was derived from POS transaction history. \'loyalty_inferred\' means it was derived from loyalty program behavior. \'app_behavior\' means it was inferred from digital browsing or filtering actions in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference record. \'active\' means the preference is in use by the personalization engine. \'inactive\' means the shopper has disabled it. \'pending_review\' means the inferred preference awaits confidence threshold validation. \'overridden\' means a self-declared preference has superseded an inferred one. \'expired\' means the preference has passed its validity window.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Specific preference dimension within the category (e.g., \'nut_allergy\', \'gluten_free\', \'vegan\', \'keto\', \'low_sodium\', \'organic\', \'preferred_store\', \'email_frequency\', \'produce_affinity\'). Granular discriminator used by the personalization engine for product filtering and targeted marketing. [ENUM-REF-CANDIDATE: nut_allergy|lactose_intolerance|gluten_free|vegan|vegetarian|keto|paleo|mediterranean|low_sodium|low_sugar|high_protein|organic|non_gmo|usda_certified|preferred_store|preferred_fulfillment|preferred_day|preferred_time|email_frequency|push_notification|category_affinity — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The declared or inferred value for this preference dimension. For boolean preferences (e.g., nut allergy) this is \'true\' or \'false\'; for enumerated preferences (e.g., preferred fulfillment) this is the selected option (e.g., \'pickup\', \'delivery\'); for affinity scores this is a numeric string. Flexible string to accommodate all preference types.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredShoppingDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Shopping Day' ;
    rdfs:comment 'The day of the week the shopper most prefers to shop, either declared via app profile or inferred from POS transaction history. Used to time promotional communications (ad circulars, push notifications) and to optimize pickup/delivery slot recommendations. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShoppingTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Shopping Time' ;
    rdfs:comment 'The time-of-day window the shopper most prefers to shop, either declared or inferred from purchase history. Used to schedule push notifications and delivery/pickup slot suggestions. Complements preferred_shopping_day for precise timing of personalized outreach.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privateLabelPreference rdf:type rdf:Property ;
    rdfs:label 'Private Label Preference' ;
    rdfs:comment 'Indicates whether the shopper has a declared or inferred preference for Grocery\'s private-label (store-owned brand) products over national CPG (Consumer Packaged Goods) brands. Used to surface private-label alternatives in product recommendations and to support private-label brand development analytics.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategoryAffinity rdf:type rdf:Property ;
    rdfs:label 'Product Category Affinity' ;
    rdfs:comment 'The product category or department (e.g., \'fresh_produce\', \'bakery\', \'dairy\', \'organic\', \'private_label\', \'pharmacy_otc\') toward which the shopper has a declared or inferred affinity. Drives category-level personalization and targeted promotions. Aligns with Oracle Retail Merchandising System item hierarchy. Null for non-affinity preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive push notifications via the Grocery mobile app. When TRUE, the shopper is eligible to receive personalized push alerts for promotions, order status updates, and loyalty rewards. Governed by mobile consent regulations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushNotificationTopics rdf:type rdf:Property ;
    rdfs:label 'Push Notification Topics' ;
    rdfs:comment 'Comma-separated list of push notification topic categories the shopper has opted into (e.g., \'promotions,order_updates,loyalty_rewards,weekly_ad\'). Allows granular control over notification content beyond the binary opt-in flag. Managed via the Salesforce Commerce Cloud personalization module.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapWicParticipant rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Participant' ;
    rdfs:comment 'Indicates whether the shopper participates in SNAP (Supplemental Nutrition Assistance Program) or WIC (Women Infants and Children) federal benefit programs. When TRUE, the personalization engine surfaces SNAP/WIC-eligible products and EBT (Electronic Benefits Transfer) payment options. Treated as confidential due to program participation sensitivity.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The digital or physical channel through which this preference was captured or inferred. Distinguishes between mobile app self-declaration, web profile updates, in-store kiosk entry, POS transaction inference, and loyalty portal updates. Used for channel attribution in preference data quality reporting. [ENUM-REF-CANDIDATE: mobile_app|web|in_store_kiosk|associate_entry|pos|loyalty_portal|survey — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'The date after which this preference record is no longer valid and should be excluded from personalization logic. Null indicates an open-ended preference with no expiry. Supports temporary dietary restrictions, seasonal preferences, and time-limited program participation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date from which this preference record is considered valid and should be applied in personalization and product filtering. Supports time-bounded preferences such as seasonal dietary goals or temporary dietary restrictions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each shopper-to-segment assignment record in the Databricks Silver Layer. Serves as the primary key for this transactional association entity.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestExperimentId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Experiment Id' ;
    rdfs:comment 'Reference to the A/B or multivariate test experiment definition associated with this segment assignment. Populated only when ab_test_group is not null. Enables linking assignment outcomes to experiment results for segmentation strategy evaluation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestExperiment .

ind:primarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Segment Id' ;
    rdfs:comment 'Reference to the customer segment definition to which the shopper is being assigned. Links to the segment master in the Customer domain.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:abTestGroup rdf:type rdf:Property ;
    rdfs:label 'Ab Test Group' ;
    rdfs:comment 'Designates the experimental group to which this shopper-segment assignment belongs when the assignment is part of an A/B or multivariate segmentation test. \'control\' is the baseline group; \'treatment_a\' and \'treatment_b\' are variant groups; \'holdout\' is excluded from all treatments for measurement purposes. Null if the assignment is not part of an active test.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the shopper was formally assigned to the segment. Used for time-series segment membership tracking and cohort analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The mechanism by which the shopper was assigned to this segment. \'rule_based\' indicates a deterministic business rule engine; \'ml_model\' indicates a machine learning model prediction; \'manual_override\' indicates a CRM analyst or marketer directly assigned the shopper; \'batch_import\' indicates a bulk load from an external system; \'api_push\' indicates a real-time API-driven assignment from an integrated platform such as Salesforce Commerce Cloud.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The operational system of record that originated this segment assignment. Supports data lineage tracking and reconciliation across integrated platforms. Values correspond to known operational systems: Salesforce Commerce Cloud CRM, NCR POS loyalty integration, Blue Yonder demand planning, internal ML platform, manual CRM tooling, or batch ETL processes.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of this shopper-to-segment assignment. \'active\' means the shopper currently belongs to the segment; \'expired\' means the assignment passed its expiry date; \'revoked\' means it was manually removed; \'pending\' means awaiting activation; \'superseded\' means replaced by a newer assignment for the same segment.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the assignment event was recorded in the system. Supports real-time segmentation pipelines and audit trails. Distinct from assignment_date which captures the business date.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchRunCode rdf:type rdf:Property ;
    rdfs:label 'Batch Run Code' ;
    rdfs:comment 'The identifier of the batch processing run (e.g., Blue Yonder or internal ML platform job execution) that generated this segment assignment. Enables traceability of bulk assignment events back to a specific pipeline execution for debugging, reprocessing, and data lineage auditing. Null for real-time API-driven or manual assignments.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Defines the omnichannel shopping context in which this segment assignment is applicable. \'all_channels\' applies across all touchpoints; \'in_store\' applies only to physical store interactions; \'digital\' applies to eCommerce and app; \'pickup\' applies to Click-and-Collect (curbside or in-store order collection); \'delivery\' applies to last-mile delivery orders; \'pharmacy\' applies to pharmacy-specific interactions. Supports Grocery\'s omnichannel personalization strategy.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Consent Flag' ;
    rdfs:comment 'Indicates whether the shopper has provided consent for their data to be used in segmentation and targeted marketing activities at the time of this assignment. True means consent is on record. Supports CCPA and GDPR-aligned data privacy compliance for customer data usage in the Customer domain.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which the shopper\'s membership in this segment is considered active and eligible for targeted promotions, personalization, and loyalty offers. May differ from assignment_date if the assignment is scheduled for a future activation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicMarketCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Market Code' ;
    rdfs:comment 'The geographic market or trade area code associated with this segment assignment. Used for regional segmentation strategies and market-level reporting. Follows internal market hierarchy codes aligned with store trade area definitions.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Indicates whether this segment assignment represents the shopper\'s primary or dominant segment when a shopper belongs to multiple segments simultaneously. True means this is the primary segment used for default personalization and offer targeting. Supports single-segment fallback logic in downstream marketing and POS systems.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Nps Score At Assignment' ;
    rdfs:comment 'The shopper\'s most recent Net Promoter Score (NPS) at the time of segment assignment, on a scale of 0 to 10. Captured as a point-in-time snapshot to contextualize the segmentation decision. Supports analysis of whether segment membership correlates with shopper satisfaction and advocacy.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the shopper has opted out of marketing communications associated with this segment. True means the shopper should not receive outbound marketing for this segment even if the assignment is active. Distinct from data_consent_flag which governs data processing consent.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible Flag' ;
    rdfs:comment 'Indicates whether the shopper\'s segment assignment qualifies them for personalized digital experiences including eCommerce storefront personalization, app recommendations, and targeted email campaigns via Salesforce Commerce Cloud. Distinct from promotion_eligibility_flag which governs price-based offers.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligibility Flag' ;
    rdfs:comment 'Indicates whether the shopper is eligible to receive targeted promotions, TPR (Temporary Price Reduction) offers, or ad circular inclusions based on this segment assignment. True means the shopper qualifies for segment-specific promotional targeting. Supports the Promotions Management domain and FTC advertising compliance.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleSetCode rdf:type rdf:Property ;
    rdfs:label 'Rule Set Code' ;
    rdfs:comment 'Reference to the specific business rule set definition that triggered this assignment when assignment_method is \'rule_based\'. Enables traceability of which rule configuration produced the membership. Null for ml_model, manual_override, and batch_import methods.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'The high-level category of the segment to which the shopper is assigned. \'behavioral\' segments are based on shopping behavior patterns; \'demographic\' on age, income, or household composition; \'psychographic\' on lifestyle and values; \'transactional\' on purchase history and spend patterns; \'lifecycle\' on shopper journey stage (new, active, lapsed, churned); \'program_based\' on enrollment in specific programs such as SNAP, WIC, or pharmacy.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentRank rdf:type rdf:Property ;
    rdfs:label 'Segment Rank' ;
    rdfs:comment 'Numeric rank (1 = highest priority) indicating the relative priority of this segment assignment among all active segments for the shopper. Used to resolve conflicts when multiple segments offer competing promotions or personalization rules. Lower values indicate higher priority.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapWicEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Eligible' ;
    rdfs:comment 'Indicates whether this segment assignment is specifically associated with a SNAP (Supplemental Nutrition Assistance Program) or WIC (Women, Infants, and Children) program participant segment. True flags the shopper as a government assistance program participant for targeted compliance reporting and eligible product promotions. Supports USDA and FTC regulatory requirements.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionTrigger rdf:type rdf:Property ;
    rdfs:label 'Transition Trigger' ;
    rdfs:comment 'The business event or condition that triggered the shopper\'s transition into this segment. \'purchase_event\' indicates a qualifying transaction; \'loyalty_milestone\' indicates reaching a loyalty tier threshold; \'model_refresh\' indicates a scheduled ML model re-scoring run; \'manual_review\' indicates a CRM analyst-initiated change; \'program_enrollment\' indicates enrollment in SNAP, WIC, or pharmacy program; \'inactivity\' indicates a lapse-based re-segmentation.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatId rdf:type rdf:Property ;
    rdfs:label 'Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: MARKETING: Preferred store format drives targeted campaigns and inventory allocation; shoppers often indicate format preference in loyalty app.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:personalShopperAssociateId rdf:type rdf:Property ;
    rdfs:label 'Personal Shopper Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Personal shopper program assigns a dedicated associate to a shopper; needed for service scheduling, performance tracking, and loyalty reporting.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:preferredCategoryId rdf:type rdf:Property ;
    rdfs:label 'Preferred Category Id' ;
    rdfs:comment 'Foreign key linking to assortment.category. Business justification: Category Preference Marketing Report needs each shopper\'s preferred category to target promotions; shoppers naturally have a preferred category, so a FK preferred_category_id → category.category_id is' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:preferredPharmacyLocationId rdf:type rdf:Property ;
    rdfs:label 'Preferred Pharmacy Location Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pharmacy_location. Business justification: Supports loyalty program\'s preferred pharmacy assignment for auto-refill and targeted marketing.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyLocation .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date on which the shopper account was permanently closed or deactivated. Populated only when account_status = \'closed\'. Used for GDPR right-to-erasure compliance tracking, retention policy enforcement, and churn analysis.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the shopper account. \'active\' indicates a fully enrolled shopper; \'suspended\' indicates a temporarily restricted account; \'closed\' indicates a permanently deactivated account; \'pending_verification\' indicates registration awaiting email or identity confirmation; \'merged\' indicates the record was consolidated into another golden record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Marketing or operational source that drove the shopper\'s initial registration (e.g., \'weekly_ad_circular\', \'referral\', \'loyalty_kiosk\', \'digital_coupon\', \'fuel_center_promo\'). Used for marketing attribution, campaign ROI analysis, and Customer Lifetime Value (CLTV) modeling. [ENUM-REF-CANDIDATE: weekly_ad_circular|referral|loyalty_kiosk|digital_coupon|fuel_center_promo|organic_web|paid_search|social_media — promote to reference product]' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the shopper\'s primary residential address (street number and street name). Used for direct mail delivery, last-mile delivery (LMD) routing, and geographic segmentation analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the shopper\'s primary residential address (apartment, suite, unit number). Supplements address_line1 for complete delivery address resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Date of birth of the shopper in yyyy-MM-dd format. Used for age verification (alcohol, tobacco, pharmacy), birthday loyalty rewards, WIC (Women, Infants, and Children) program eligibility, and demographic segmentation analytics.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the shopper\'s primary residential address. Used for geographic market segmentation, delivery zone assignment, and local promotional targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the shopper\'s primary residential address (e.g., \'USA\'). Supports international shopper identification and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Direct Mail Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive physical direct mail communications such as weekly Ad Circulars, personalized coupons, and promotional mailers. True = opted in. Drives mailing list inclusion for print marketing campaigns.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for the shopper account. Used as the principal digital contact channel for order confirmations, promotional communications, loyalty program updates, and account recovery. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive marketing communications via email. True = opted in. Must be honored in all outbound email campaigns. Consent state is tracked per CAN-SPAM Act and GDPR Article 7 requirements.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the shopper as captured at registration. Used for identity verification, personalized communications, and loyalty program correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-reported gender identity of the shopper. Used for demographic segmentation, personalized product recommendations, and diversity analytics. Collected with explicit consent per GDPR and CCPA requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerified rdf:type rdf:Property ;
    rdfs:label 'Identity Verified' ;
    rdfs:comment 'Indicates whether the shopper\'s identity has been verified through an identity confirmation process (e.g., email verification, phone OTP, or in-store ID check). True = identity confirmed. Used for fraud prevention, age-restricted purchase eligibility, and pharmacy patient linking.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name of the shopper as captured at registration. Combined with first_name to form the full legal identity used in account management and regulatory compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrolled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrolled' ;
    rdfs:comment 'Indicates whether the shopper is currently enrolled in Grocery\'s loyalty rewards program. True = enrolled and eligible for points accrual, personalized offers, and loyalty pricing. False = not enrolled. Sourced from NCR POS loyalty integration.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyPatient rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Patient' ;
    rdfs:comment 'Indicates whether the shopper is also a registered pharmacy patient at a Grocery pharmacy location. True = pharmacy patient record exists (non-PHI flag only; clinical data is managed exclusively in McKesson Pharmacy Systems under HIPAA). Used for cross-domain identity linking without exposing protected health information.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the shopper, stored in E.164 international format. Used for SMS marketing opt-ins, order pickup notifications, delivery alerts, and two-factor authentication.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posLoyaltyCode rdf:type rdf:Property ;
    rdfs:label 'Pos Loyalty Code' ;
    rdfs:comment 'Loyalty card or account identifier assigned by the NCR POS (Point of Sale) system at the time of in-store loyalty enrollment. Used to link POS transaction history to the shopper golden record.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code of the shopper\'s primary residential address. Used for delivery zone mapping, trade area analysis, demographic append, and targeted ad circular distribution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the shopper prefers to be addressed by in communications and personalized experiences (e.g., nickname or chosen name). May differ from legal first name. Supports personalization in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Preferred language of the shopper expressed as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-TW\'). Drives localization of digital communications, app content, and in-store signage preferences for omnichannel personalization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'The channel through which the shopper originally registered their account. Supports acquisition source analytics, channel attribution, and omnichannel engagement strategy. Values align with Grocery\'s omnichannel touchpoints including NCR POS in-store enrollment and Salesforce Commerce Cloud digital channels.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Calendar date on which the shopper account was first created. Used for tenure calculations, cohort analysis, anniversary loyalty rewards, and CLTV (Customer Lifetime Value) segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive marketing and transactional communications via SMS text message. True = opted in. Consent is required under TCPA (Telephone Consumer Protection Act) prior to any commercial SMS transmission.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state or territory code of the shopper\'s primary residential address (e.g., \'CA\', \'TX\'). Used for state-level regulatory compliance (e.g., state WIC agency reporting, state pharmacy board jurisdiction), tax jurisdiction assignment, and regional marketing segmentation.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each status change event record in the shopper and wholesale account lifecycle audit trail. Primary key of this immutable history table.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryStatusAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Status Associate Id' ;
    rdfs:comment 'The identifier of the human user (associate, customer service representative, or administrator) who initiated the status change. Null when the change was triggered by an automated system process. Used for accountability and audit trail in compliance investigations.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryStatusShopperId rdf:type rdf:Property ;
    rdfs:label 'Primary Status Shopper Id' ;
    rdfs:comment 'Reference to the shopper or wholesale account record whose status changed. Links this history event to the customer master record in the customer domain.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:reversedEventStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Event Status History Id' ;
    rdfs:comment 'When reversal_flag is True, references the status_history_id of the original status change event that this record reverses or corrects. Null for non-reversal records. Maintains the immutable append-only audit trail while enabling error correction traceability.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusHistory .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this status change required managerial or compliance approval before being applied. Supports segregation-of-duties controls for high-risk transitions such as fraud suspensions and regulatory holds.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeChannel rdf:type rdf:Property ;
    rdfs:label 'Change Channel' ;
    rdfs:comment 'The interaction channel through which the status change was initiated. Supports omnichannel analytics and helps identify whether closures or suspensions originate from self-service digital channels, call center interactions, or automated back-office processes.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized code classifying the business reason that triggered the status change. Used for compliance reporting, fraud investigation workflows, and customer service escalation routing. [ENUM-REF-CANDIDATE: voluntary_closure|fraud_suspension|inactivity|reactivation|merge|duplicate_detected|deceased|regulatory_hold — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the status change beyond the standardized reason code. Supports customer service escalation notes, fraud investigation documentation, and compliance audit trails.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the status change event occurred in the operational system. This is the authoritative business event time, distinct from the record audit timestamp. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changedBySystem rdf:type rdf:Property ;
    rdfs:label 'Changed By System' ;
    rdfs:comment 'The name of the operational system or automated process that triggered the status change when no human user is responsible. Examples include the fraud detection engine, batch inactivity sweep, CRM automation, or account merge process. Null when changed_by_user_id is populated. [ENUM-REF-CANDIDATE: salesforce_crm|ncr_pos|sap_retail|oracle_rms|mckesson|manual|batch_inactivity|fraud_engine|merge_process — promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyBasis rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Basis' ;
    rdfs:comment 'The legal basis under which this status change event and associated personal data is processed and retained. Required for GDPR compliance documentation. Particularly relevant for closure and erasure events where the legal basis for continued data retention must be established.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudCaseReference rdf:type rdf:Property ;
    rdfs:label 'Fraud Case Reference' ;
    rdfs:comment 'Reference number linking this status change to an active fraud investigation case when the change_reason_code is fraud_suspension or regulatory_hold. Enables cross-referencing with the fraud management system for investigation workflows and regulatory reporting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedByCustomer rdf:type rdf:Property ;
    rdfs:label 'Initiated By Customer' ;
    rdfs:comment 'Indicates whether the status change was voluntarily initiated by the customer (True) or was applied by the business or an automated system without customer request (False). Critical for distinguishing voluntary closures from fraud suspensions or inactivity-driven deactivations in compliance and NPS analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The account lifecycle status applied as a result of this change event. Captures the to-state in the status transition pair. Together with previous_status, defines the complete transition vector for lifecycle analytics. [ENUM-REF-CANDIDATE: active|inactive|suspended|pending|closed|merged|fraud_hold — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a customer-facing notification (email, SMS, or push) was dispatched to inform the shopper of the status change. Supports compliance with consumer notification requirements and customer service follow-up tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time at which the customer notification was dispatched following the status change. Null when notification_sent is False. Used for SLA compliance tracking on customer communication obligations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pharmacyPatientImpact rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Patient Impact' ;
    rdfs:comment 'Indicates whether the status change affects a shopper who is also registered as a pharmacy patient (non-PHI flag only). When True, triggers a notification to the McKesson pharmacy system to review active prescription refill schedules and patient communication preferences.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousLoyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Previous Loyalty Tier' ;
    rdfs:comment 'The Customer Lifetime Value (CLTV) loyalty tier held by the shopper immediately before the status change. Captured at the time of the event to preserve the historical tier context for loyalty program compliance, reactivation offers, and NPS analysis.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSegment rdf:type rdf:Property ;
    rdfs:label 'Previous Segment' ;
    rdfs:comment 'The marketing or behavioral shopper segment assigned to the account immediately before the status change. Preserved as a point-in-time snapshot to support segmentation drift analysis, reactivation campaign targeting, and churn modeling.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The account lifecycle status immediately before this change event was applied. Captures the from-state in the status transition pair for audit and investigation purposes. [ENUM-REF-CANDIDATE: active|inactive|suspended|pending|closed|merged|fraud_hold — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationEligible rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligible' ;
    rdfs:comment 'Indicates whether the account is eligible for reactivation outreach following a closure or suspension event. Set to False for fraud suspensions, deceased records, or regulatory holds. Used by CRM and marketing automation to filter win-back campaign audiences.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reactivationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Expiry Date' ;
    rdfs:comment 'The date after which the account is no longer eligible for reactivation, typically driven by data retention policies or regulatory requirements. Null for accounts with no reactivation expiry. Supports GDPR right-to-erasure scheduling and loyalty win-back campaign timing.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date after which this status history record may be purged or anonymized in accordance with the applicable data retention policy. Driven by regulatory requirements (GDPR, CCPA, SOX) and the nature of the status change event. Null for records with indefinite retention requirements.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this record represents a reversal or correction of a previously applied status change. When True, the reversed_event_id field identifies the original event being corrected. Supports immutable audit trail integrity while allowing error correction.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapProgramImpact rdf:type rdf:Property ;
    rdfs:label 'Snap Program Impact' ;
    rdfs:comment 'Indicates whether the status change affects the shopper\'s Supplemental Nutrition Assistance Program (SNAP) / Electronic Benefits Transfer (EBT) eligibility or enrollment. Triggers downstream notification workflows to program administrators when True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceEventRef rdf:type rdf:Property ;
    rdfs:label 'Source Event Ref' ;
    rdfs:comment 'The native event or transaction identifier from the originating operational system (e.g., Salesforce case ID, SAP change document number). Enables exact-match reconciliation between the Silver layer audit trail and the source system\'s own change log.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicProgramImpact rdf:type rdf:Property ;
    rdfs:label 'Wic Program Impact' ;
    rdfs:comment 'Indicates whether the status change affects the shopper\'s Women, Infants, and Children (WIC) program enrollment or benefit access. Triggers downstream notification workflows to WIC program administrators when True.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Account Id' ;
    rdfs:comment 'Primary key for wholesale_account' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:accountOwnerShopperId rdf:type rdf:Property ;
    rdfs:label 'Account Owner Shopper Id' ;
    rdfs:comment 'Foreign key linking to customer.shopper. Business justification: Wholesale_account needs an in-domain relationship to identify the owning shopper (account owner). Adding account_owner_shopper_id creates this link without affecting existing structure.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Finance budgets are allocated to wholesale accounts for forecasting spend and tracking actuals against budgeted amounts.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:dedicatedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Carrier Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier. Business justification: Wholesale accounts often have dedicated carrier contracts; needed for carrier billing, SLA compliance, and contract reporting.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:ediPartnerProfileId rdf:type rdf:Property ;
    rdfs:label 'Edi Partner Profile Id' ;
    rdfs:comment 'The EDI interchange partner identifier (ISA qualifier + ID) assigned to the wholesale account for electronic order and invoice exchange. Required when edi_capable_flag is True. Used to route EDI transactions in the SAP EDI subsystem.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdiPartnerProfile .

ind:supplySupplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supply Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: Contract management: Supplier contracts are negotiated per wholesale account; linking enables contract compliance, SLA tracking, and account-specific pricing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplySupplierContract .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Segmentation tier assigned to the wholesale account based on revenue potential, purchase volume, and strategic importance. Determines service levels, dedicated account management, pricing tiers, and promotional eligibility. Values: strategic (top-tier, high-volume), standard (mid-market), small_business (emerging or low-volume).' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the wholesale account by business type, indicating the nature of the organizational buyer. Drives pricing eligibility, product assortment access, and compliance requirements. Satisfies CLASSIFICATION_OR_TYPE category for MASTER_PARTY role. [ENUM-REF-CANDIDATE: restaurant|caterer|institutional|corporate|food_service|school_district|hospital|hotel — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Estimate' ;
    rdfs:comment 'Estimated annual gross revenue (in USD) of the wholesale account\'s business, sourced from credit applications, Dun & Bradstreet data, or account manager input. Used for account tier assignment, credit limit setting, and strategic segmentation.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and accounts receivable correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary street address line for the wholesale account\'s billing address (suite, floor, unit number, etc.). Supplements billing_address_line1 for complete address representation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and geographic segmentation of B2B accounts.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the wholesale account\'s billing address (e.g., USA, CAN). Supports international wholesale accounts and cross-border tax compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code for the wholesale account\'s billing address. Used for tax jurisdiction mapping, delivery zone assignment, and geographic analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateCode rdf:type rdf:Property ;
    rdfs:label 'Billing State Code' ;
    rdfs:comment 'Two-letter US state or territory code for the wholesale account\'s billing address (e.g., CA, TX, NY). Used for state tax compliance, sales tax nexus determination, and regional reporting.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date on which the wholesale supply agreement or master service contract expires or is scheduled to terminate. Null indicates an open-ended or evergreen contract. Used for renewal alerts, pricing expiry, and account review workflows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The date on which the wholesale supply agreement or master service contract between Grocery and the wholesale account becomes effective. Used for contract lifecycle management, pricing eligibility, and compliance tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is currently on credit hold, blocking new order processing until outstanding balances are resolved or credit terms are renegotiated. Managed by the accounts receivable team in SAP FI.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The maximum outstanding accounts receivable balance (in USD) approved for the wholesale account by the credit department. Orders that would cause the balance to exceed this limit are blocked pending credit review. Managed in SAP FI credit management.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal credit risk rating assigned to the wholesale account based on payment history, Dun & Bradstreet data, and financial review. Informs credit limit decisions and payment term negotiations.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or \'Doing Business As\' (DBA) name under which the wholesale account operates, if different from the legal business name. Used for operational communications, order labels, and account management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the wholesale account\'s business entity globally. Used for credit risk assessment, supplier onboarding, and B2B identity verification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is set up to exchange orders, invoices, and advance ship notices via Electronic Data Interchange (EDI). EDI-capable accounts use automated order processing workflows, reducing manual entry.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'The federal Employer Identification Number (EIN) / Tax Identification Number (TIN) assigned by the IRS to the wholesale account. Required for tax reporting (1099 issuance), credit applications, and regulatory compliance. Format: XX-XXXXXXX.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBusinessName rdf:type rdf:Property ;
    rdfs:label 'Legal Business Name' ;
    rdfs:comment 'The full legal registered name of the wholesale account as it appears on official business registration documents, contracts, and tax filings. Used for invoicing, credit agreements, and regulatory compliance. Satisfies IDENTITY_LABEL category for MASTER_PARTY role.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Amount' ;
    rdfs:comment 'The minimum order value (in USD) required for the wholesale account to place a valid order. Orders below this threshold are flagged or blocked. Used to ensure order profitability and logistics efficiency.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date on which the wholesale account was formally onboarded and approved to begin placing orders with Grocery. Distinct from created_timestamp (system record creation); this reflects business approval completion.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredDeliveryDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Day' ;
    rdfs:comment 'The preferred day of the week for wholesale order deliveries to the account, as agreed during onboarding or account setup. Used by the Transportation Management System (TMS) for route optimization and scheduling.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The primary email address for the main business contact at the wholesale account. Used for order confirmations, invoices, promotional communications, and account management. Satisfies PRIMARY_CONTACT category for MASTER_PARTY role.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the wholesale account. Used for account communications, order confirmations, and relationship management. This is a business contact, not a personal consumer.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number for the primary business contact at the wholesale account. Used for order inquiries, delivery coordination, and account management communications.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary business contact at the wholesale account (e.g., Purchasing Manager, Executive Chef, Director of Operations). Used for targeted communications and account segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or organizational sales territory to which this wholesale account is assigned. Used for territory-based reporting, quota allocation, and account manager assignment.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapWicEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Eligible Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is authorized to purchase SNAP/WIC-eligible products for resale or institutional use under applicable federal program guidelines. Relevant for school districts, food banks, and institutional buyers.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'The state-issued tax exemption or resale certificate number for the wholesale account. Required when tax_exempt_flag is True. Used for sales tax audit compliance and exemption documentation.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the wholesale account holds a valid tax exemption certificate (e.g., resale certificate, government entity, non-profit). When True, applicable sales taxes are suppressed on invoices. Requires a valid tax_exempt_certificate_number.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wholesalePriceGroup rdf:type rdf:Property ;
    rdfs:label 'Wholesale Price Group' ;
    rdfs:comment 'Price group code assigned to the wholesale account that determines which wholesale pricing schedule or contract pricing tier applies when generating quotes and orders. Maps to pricing conditions in SAP SD.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key for the AP invoice lifecycle from receipt through payment clearing.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Identifier of the company bank account from which payment was disbursed. Supports multi-bank operations and cash management reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the warehouse or store goods receipt document used in three-way match. Confirms physical receipt of merchandise or materials before invoice approval.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier of the SAP automatic payment program run (F110) that processed this invoice. Groups invoices paid together in a batch for reconciliation and audit purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order for three-way match validation (PO, goods receipt, invoice). Null for non-PO invoices such as utility bills, rent, or service agreements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: Freight Invoice Reconciliation: AP Invoice for carrier freight must reference the Shipment it settles, enabling the Freight Cost Reconciliation report.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:clearedAmount rdf:type rdf:Property ;
    rdfs:label 'Cleared Amount' ;
    rdfs:comment 'The actual amount paid to the vendor after applying any last-minute adjustments, discounts taken, or partial payments. May differ from net_amount if early payment discount was exercised.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date the invoice was cleared in the GR/IR clearing account, completing the procure-to-pay cycle. Indicates the invoice liability has been settled in the general ledger.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The legal entity or subsidiary code within the enterprise structure. Supports multi-entity financial consolidation and SOX (Sarbanes-Oxley) compliance reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'The actual early payment discount amount deducted at payment time. Tracks discount capture performance and vendor payment optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:edi810Reference rdf:type rdf:Property ;
    rdfs:label 'Edi 810 Reference' ;
    rdfs:comment 'Reference number for the EDI 810 electronic invoice transaction received from the vendor. Supports automated invoice processing and vendor integration via EDI (Electronic Data Interchange).' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year when the invoice was posted. Supports monthly close processes and period-based accrual accounting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, including merchandise cost, freight, slotting fees, or service charges. Represents the vendor\'s billed amount before tax.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. Used to calculate payment due dates based on payment terms and to determine early payment discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The external invoice number assigned by the vendor. This is the business identifier printed on the vendor\'s invoice document and referenced in payment correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current state of the invoice in the accounts payable workflow. Tracks progression from receipt through three-way match, approval, payment scheduling, disbursement, and clearing in the GR/IR (Goods Receipt/Invoice Receipt) account. [ENUM-REF-CANDIDATE: received|pending_match|matched|approved|payment_blocked|scheduled|paid|cleared|cancelled|disputed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document. Standard invoices are typical vendor bills; credit memos reduce liability; debit memos increase liability; prepayments cover advance payments; recurring invoices are for subscription services.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is1099Reportable rdf:type rdf:Property ;
    rdfs:label 'Is 1099 Reportable' ;
    rdfs:comment 'Indicates whether this invoice payment must be reported to the IRS on Form 1099-MISC or 1099-NEC for vendor tax reporting. True for payments to non-corporate vendors exceeding the annual threshold.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Indicates whether the invoice has been successfully matched against the purchase order and goods receipt. Three-way match validates quantity, price, and terms alignment before payment approval.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The final payable amount after applying discounts and adding taxes. This is the amount that will be disbursed to the vendor (gross + tax - discount).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating a hold on payment processing. Common blocks include pricing disputes, quantity discrepancies, missing documentation, vendor compliance issues, or manual review requirements. Null when no block is active.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Detailed explanation of why the invoice payment is blocked. Provides context for AP analysts and vendor inquiry resolution.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date the payment was executed and funds were disbursed to the vendor. Null for unpaid invoices. Used for cash flow reporting and vendor payment tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number for the payment transaction (check number, ACH trace number, wire confirmation). Used for bank reconciliation and vendor inquiry resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The code representing the negotiated payment terms with the vendor (e.g., Net 30, Net 60, 2/10 Net 30 for 2% discount if paid within 10 days). Drives due date calculation and early payment discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date the invoice was posted to the general ledger. Determines the fiscal period for financial reporting and GAAP-compliant accrual accounting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (state, province, county) where the tax was assessed. Supports multi-jurisdictional tax reporting and compliance with state and local tax regulations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable invoice record. Primary key for the AR invoice entity.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Order-to-Invoice Matching: AR Invoice is generated from a Fulfillment Order; linking them supports the Customer Billing & Revenue Recognition process.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of invoice age based on days past due date. Used for Days Sales Outstanding (DSO) analysis and bad debt provisioning. Current = not yet due; other buckets represent days overdue.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankDepositReference rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Reference' ;
    rdfs:comment 'Bank deposit batch or transaction reference number linking the payment to the bank statement. Used for bank reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, CAD, MXN).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this invoice. Used for revenue recognition period matching and accrual accounting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this invoice. Relevant for subscription-based or periodic billing (e.g., fuel fleet monthly billing, pharmacy monthly claims).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number that records the payment application transaction. Links the invoice to the cash receipt document that closed or partially paid it.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of days since the invoice date. Used to calculate Days Sales Outstanding (DSO) metrics and identify slow-paying accounts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the invoice is overdue beyond the payment due date. Null or zero if invoice is not yet due. Used for dunning level determination.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the customer formally disputed the invoice. Used to track dispute resolution cycle time.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the customer has disputed this invoice. True if customer has raised a billing dispute, pricing disagreement, or quality claim that blocks payment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the customer dispute reason (e.g., pricing error, quantity discrepancy, damaged goods, service issue). Populated when dispute_flag is true.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current escalation level in the collections dunning process (0=no dunning, 1=first reminder, 2=second reminder, 3=final notice, 4=legal action). Increments based on days past due and payment history.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Shipping and freight charges included in the invoice for delivery of goods to the customer location.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date the invoice was posted to the general ledger for financial reporting. May differ from invoice date due to period-end cutoffs or batch processing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice or collection reminder was sent to the customer for this invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Identifier of the bank lockbox service used for automated payment processing. Relevant for high-volume check and remittance processing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice after applying all cash receipts, credit memos, and adjustments. Zero when invoice is fully paid.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount received and applied against this invoice across all payment transactions. Sum of all cash receipts allocated to this invoice.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer purchase order number provided for this invoice. Used for customer reconciliation and three-way matching in customer accounts payable systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order or delivery document that generated this invoice. Links AR invoice back to the order fulfillment transaction.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount of the invoice written off as uncollectible bad debt. Recorded when collection efforts are exhausted and the receivable is deemed unrecoverable.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the invoice (or portion thereof) was written off as bad debt. Triggers bad debt expense recognition in the general ledger.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Reason code for the write-off: customer bankruptcy, deemed uncollectible after collection efforts, small balance not worth pursuing, dispute settlement, goodwill adjustment, or other.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationAccountId rdf:type rdf:Property ;
    rdfs:label 'Concentration Account Id' ;
    rdfs:comment 'Foreign key to the master concentration account if this is a zero-balance account. Null for non-ZBA accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Must match legal entity name for corporate accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Full bank account number. Stored in encrypted form for PCI compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Business purpose of the account: operating (AP/AR), payroll (employee payments), tax (remittances), investment (short-term cash), debt_service (loan payments), escrow (restricted funds).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'Current balance minus outstanding checks and holds. Represents funds available for immediate disbursement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier. In US: ABA routing number (9 digits). In EU: Bank Identifier Code (BIC/SWIFT). Maps to SAP bank key (BNKA-BANKL).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Full street address of the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCity rdf:type rdf:Property ;
    rdfs:label 'Branch City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Branch Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the bank branch where the account is domiciled.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchPostalCode rdf:type rdf:Property ;
    rdfs:label 'Branch Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchState rdf:type rdf:Property ;
    rdfs:label 'Branch State' ;
    rdfs:comment 'Two-letter state or province code for the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date the bank account was closed. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Most recent closing balance from the last processed bank statement. Used for daily cash position reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'GL account number in the chart of accounts to which bank transactions are posted. Typically a cash or cash-equivalent account.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'SAP-assigned identifier for the house bank configuration. Links to SAP FI bank master (T012).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for SEPA and cross-border payments in Europe and other IBAN-participating countries.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate earned on positive balances or charged on overdrafts, expressed as a decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent completed bank reconciliation. Used for SOX compliance monitoring.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent bank statement received and processed for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxIndicator rdf:type rdf:Property ;
    rdfs:label 'Lockbox Indicator' ;
    rdfs:comment 'True if this account is a lockbox account used for automated AR collection processing. False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Account Number' ;
    rdfs:comment 'Masked account number showing only last 4 digits for display purposes (e.g., XXXXXX1234).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date the bank account was opened with the financial institution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum negative balance allowed by the bank under overdraft protection agreement. Zero if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing transit number for US domestic wire and ACH transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority1 rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority 1' ;
    rdfs:comment 'Name of the primary authorized signatory for the account. Required for SOX treasury controls and audit trail.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority2 rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority 2' ;
    rdfs:comment 'Name of the secondary authorized signatory. Used for dual-control requirements on high-value transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Signatory Threshold Amount' ;
    rdfs:comment 'Maximum transaction amount that can be authorized by a single signatory. Amounts above this require dual approval.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'Electronic format in which bank statements are received: MT940 (SWIFT standard), BAI2 (US cash management), CAMT053 (ISO 20022 XML), PDF, CSV.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'How often bank statements are issued: daily (for high-volume accounts), weekly, monthly.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'Bank Identifier Code (BIC) for international wire transfers. 8 or 11 character ISO 9362 code.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroBalanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Zero Balance Indicator' ;
    rdfs:comment 'True if this is a zero-balance account that is automatically swept to/from a concentration account daily. False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual amount spent or incurred to date for this budget line, as recorded in the general ledger. Used for variance analysis (actual vs plan).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this budget record to the audit trail or change log for compliance and SOX reporting. Tracks all modifications to budget amounts and approvals.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Hierarchical category or grouping for the budget line (e.g., Store Operations, Supply Chain, Marketing, IT Infrastructure). Used for rollup reporting and variance analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique business identifier for the budget, typically formatted as BUD-YYYYNNNN where YYYY is fiscal year and NNNN is sequence number.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget: draft (in preparation), submitted (awaiting approval), approved (authorized), active (in use), frozen (locked for changes), closed (period ended), or rejected (not approved). [ENUM-REF-CANDIDATE: draft|submitted|approved|active|frozen|closed|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by functional category: operating expenses, capital expenditures (CapEx), labor costs, marketing spend, administrative overhead, or Cost of Goods Sold (COGS).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of budget that has been committed through purchase orders, contracts, or other obligations but not yet expensed. Used for encumbrance accounting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The original planned budget amount for the fiscal period, as approved during the annual budgeting process. Represents the baseline target.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The revised budget amount after adjustments, reforecasts, or supplemental allocations. Reflects the current authorized budget target.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is subject to SOX internal control requirements and audit trails (True = SOX-controlled, False = not SOX-controlled).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdCriticalPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Critical Percentage' ;
    rdfs:comment 'The percentage of budget consumption at which a critical alert is triggered and spending may be blocked (e.g., 95.00 means critical alert when 95% of budget is consumed).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdWarningPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Warning Percentage' ;
    rdfs:comment 'The percentage of budget consumption at which a warning alert is triggered (e.g., 80.00 means alert when 80% of budget is consumed). Used for proactive budget monitoring.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The variance between planned and actual amounts (actual_amount minus planned_amount). Positive values indicate overspend; negative values indicate underspend.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the planned amount ((actual_amount - planned_amount) / planned_amount * 100). Used for threshold alerts and performance scorecards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Reference to the original cost_allocation_id that this record reverses. Populated only when reversal_indicator is True. Enables tracing of reversal chains for audit purposes.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costElementId rdf:type rdf:Property ;
    rdfs:label 'Cost Element Id' ;
    rdfs:comment 'Identifier of the cost element (expense category) being allocated. Cost elements represent the nature of the expense (utilities, rent, depreciation, IT services, HR services) and map to general ledger accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostElement .

ind:primarySenderCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Sender Cost Center Id' ;
    rdfs:comment 'Identifier of the cost center from which costs are being allocated. Sender cost centers typically represent shared service functions (IT, HR, facilities, corporate overhead, distribution center operations) whose costs are distributed to benefiting units.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:receiverProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Id' ;
    rdfs:comment 'Identifier of the profit center receiving the allocated costs. Used when costs are allocated directly to profit centers for segment reporting and profitability analysis. Nullable if allocation targets cost centers only.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'Monetary amount allocated from the sender cost center to the receiver cost center or profit center. Represents the share of shared costs assigned to the receiver based on the allocation method and driver quantities. Positive values indicate cost transfers; negative values may represent reversals or corrections.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationCycleName rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Name' ;
    rdfs:comment 'Name or identifier of the periodic cost allocation cycle run in SAP CO (Controlling). Examples include monthly overhead allocation, quarterly shared services distribution, or annual corporate cost assessment cycles.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate costs from sender to receiver objects. Percentage allocates based on proportional shares, quantity uses driver volumes (e.g., square footage, headcount), fixed uses predetermined amounts, assessment distributes full sender balance, distribution splits based on statistical key figures, direct assigns costs one-to-one, step_down cascades costs sequentially, reciprocal handles mutual service relationships. [ENUM-REF-CANDIDATE: percentage|quantity|fixed|assessment|distribution|direct|step_down|reciprocal — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the allocation. May include explanations for manual adjustments, special allocation rules, or business justifications for allocation method changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of sender cost center total costs allocated to this receiver. Used when allocation_method is percentage. Sum of all allocation_percentage values for a given sender and cycle should equal 100.00. Nullable if allocation method is not percentage-based.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRate rdf:type rdf:Property ;
    rdfs:label 'Allocation Rate' ;
    rdfs:comment 'Rate per unit of driver quantity used to calculate the allocated amount. Calculated as total sender costs divided by total driver quantity across all receivers. allocated_amount = driver_quantity × allocation_rate. Nullable if allocation method is fixed or percentage.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Co Document Number' ;
    rdfs:comment 'SAP CO document number generated when the allocation was posted. Links this allocation record to the controlling document for audit trail and drill-down analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP controlling area representing the organizational unit for cost accounting. Controlling areas may span multiple company codes for consolidated management reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleRunDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Run Date' ;
    rdfs:comment 'Date when the allocation cycle was executed in SAP CO. May differ from posting_date if the cycle was run in advance and posted later.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverQuantity rdf:type rdf:Property ;
    rdfs:label 'Driver Quantity' ;
    rdfs:comment 'Quantity of the allocation driver (statistical key figure) used to calculate the allocated amount. Examples: square footage, headcount, transaction volume, sales revenue, labor hours. Used when allocation_method is quantity-based. Nullable if allocation method is fixed or percentage.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Driver Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the driver quantity. Examples: square_feet, headcount, transactions, dollars, hours. Provides context for interpreting driver_quantity values.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fi Document Number' ;
    rdfs:comment 'SAP FI document number generated when the allocation was posted to the general ledger. Links this allocation record to the financial accounting document for SOX compliance and audit trail.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this allocation record is a reversal of a previous allocation. True if this is a reversal transaction, False if this is an original allocation posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code associated with this cost center, representing the primary type of work or service output produced (e.g., \'LABOR_HRS\', \'MACHINE_HRS\', \'DELIVERY_UNITS\'). Used for activity-based costing, internal order settlements, and COGS allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center for the current budget period, expressed in the cost center\'s operating currency. Used for budget vs. actual variance analysis, EBITDA reporting, and financial planning. Sourced from SAP CO cost center planning (KP06).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The fiscal year for which the current budget plan is active for this cost center (e.g., \'2025\'). Used to scope budget vs. actual variance analysis, EBITDA reporting, and departmental P&L reviews.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area assigned to this cost center, representing a distinct area of operations for internal balance sheet and P&L reporting (e.g., Grocery Retail, Pharmacy, Fuel). Supports segment-level financial disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'SAP FI chart of accounts code applicable to this cost center\'s company code. Defines the set of GL accounts available for cost postings. Ensures consistency in financial reporting across Grocery\'s legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same chart of accounts and fiscal year variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP CO cost center category code (single or two-character) that controls which activity types and statistical key figures can be posted to this cost center. Common values include \'A\' (General), \'B\' (Administration), \'F\' (Production), \'H\' (Auxiliary). Governs posting rules and planning behavior in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code assigned to the cost center in SAP CO, used across financial reporting, budgeting, and interoperability with ERP systems. Serves as the business-facing identifier (e.g., \'CC-STORE-0042\', \'CC-DC-WEST-01\').' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable descriptive name of the cost center as maintained in SAP CO (e.g., \'Store 042 - Produce Department\', \'Distribution Center West - Receiving\', \'Pharmacy - Store 101\'). Used in financial reports, P&L statements, and budget dashboards.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' — open for cost postings and budget planning; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings (SAP CO lock indicator); \'pending_activation\' — created but not yet effective; \'closed\' — permanently decommissioned after validity end date.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Categorical classification of the cost center indicating the type of organizational unit it represents within Grocery\'s operations. Drives departmental P&L segmentation, shrink financial impact allocation, and labor cost attribution. [ENUM-REF-CANDIDATE: store|distribution_center|pharmacy|fuel_center|corporate|administrative|manufacturing|logistics — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Organizational division code to which this cost center belongs (e.g., \'GROCERY_RETAIL\', \'PHARMACY\', \'FUEL_OPERATIONS\', \'ECOMMERCE\'). Supports divisional P&L reporting, EBITDA segmentation, and same-store sales analysis by business division.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP FI fiscal year variant code that defines the fiscal year structure (number of periods, start/end months) applicable to this cost center. Grocery typically uses a 52/53-week fiscal year. Drives period-based budget and actual cost comparisons.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP CO functional area classification used to differentiate cost by business function (e.g., Cost of Goods Sold, Selling, General & Administrative, Research & Development). Enables COGS vs. SG&A split in income statement reporting per GAAP.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'The node within the SAP CO standard cost center hierarchy to which this cost center is assigned. Enables roll-up reporting across organizational levels (e.g., region, division, banner). Used for enterprise-wide P&L consolidation, EBITDA reporting, and comp sales analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForActual rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Actual' ;
    rdfs:comment 'Indicates whether this cost center is locked for actual cost postings (True). When locked, no actual costs can be posted to this cost center in SAP CO. Used during period-end close, audit periods, or when a cost center is being decommissioned.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLockedForPlan rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Plan' ;
    rdfs:comment 'Indicates whether this cost center is locked for plan (budget) postings (True). When locked, no budget updates can be made to this cost center in SAP CO. Used to freeze budgets after approval for SOX compliance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (True) used only for informational/reporting purposes without actual cost postings, or a real cost center (False) that accumulates actual costs. Statistical cost centers are used in SAP CO for parallel reporting structures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Amount' ;
    rdfs:comment 'Portion of the annual budget specifically allocated to labor costs (wages, salaries, benefits) for this cost center. Enables labor cost attribution analysis, workforce planning integration with Kronos/Workday HCM, and COGS labor component reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center master record. Required for SOX compliance audit trails to establish accountability for master data changes. Corresponds to SAP CO change document user field.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cost center master record in SAP CO. Used for change tracking, SOX audit trails, and incremental data load processing in the Databricks Silver Layer.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Physical location type associated with this cost center. Distinguishes between store-level, DC (Distribution Center), MFC (Micro-Fulfillment Center), corporate office, fuel center, and pharmacy cost centers for geographic and operational segmentation in financial reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadRate rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate' ;
    rdfs:comment 'The overhead allocation rate applied to this cost center, expressed as a decimal percentage (e.g., 0.1250 = 12.50%). Used in SAP CO overhead costing sheets to allocate indirect costs (e.g., corporate overhead, DC overhead) to store or department cost centers for full-absorption costing and COGS calculation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The SAP CO profit center to which this cost center is assigned. Profit centers represent autonomous business units for internal P&L reporting (e.g., individual stores, pharmacy division, fuel operations). Enables same-store sales and comp sales analysis at the profit center level.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code to which this cost center belongs (e.g., \'NORTHEAST\', \'SOUTHEAST\', \'WEST\'). Used for regional P&L roll-up, comp sales analysis by region, and regional budget variance reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Code' ;
    rdfs:comment 'SAP CO settlement rule code that defines how costs accumulated on this cost center are settled (allocated) to other cost objects (e.g., other cost centers, internal orders, profitability segments). Drives period-end cost allocation and COGS calculation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name of the cost center used in condensed financial reports, POS system displays, and space-constrained UI contexts. Corresponds to the SAP CO short text field (up to 20 characters).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Shrink Allocation Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in shrink (inventory loss from theft, spoilage, or damage) financial impact allocation (True). When enabled, shrink costs calculated from inventory management systems are allocated to this cost center for departmental P&L and COGS reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'The date through which this cost center is active and valid for cost postings. Corresponds to the SAP CO validity period end date. A value of 9999-12-31 indicates an open-ended (indefinite) validity. Cost postings after this date are blocked.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'The date from which this cost center is active and valid for cost postings and budget planning. Corresponds to the SAP CO validity period start date. Cost postings before this date are not permitted.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorYearPeriodFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Fiscal Period Id' ;
    rdfs:comment 'Reference to the corresponding fiscal period in the prior fiscal year. Enables year-over-year comp sales and same-store sales calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Identifier for the budget version applicable to this fiscal period (e.g., \'Original\', \'Revised_Q2\', \'Forecast\'). Supports budget vs actual variance analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDayCount rdf:type rdf:Property ;
    rdfs:label 'Business Day Count' ;
    rdfs:comment 'Number of business operating days (excluding weekends and holidays) in this fiscal period. Used for labor budgeting and productivity metrics.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month number (1-12) in which the fiscal period primarily falls. Supports calendar-based reporting and seasonality analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year (Gregorian) in which the majority of this fiscal period falls. Used for calendar-year reporting and external benchmarking.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The actual calendar date when the fiscal period was closed and locked for posting. Null if period is still open. Critical for SOX compliance and audit trail.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Precise timestamp when the fiscal period close process was completed. Used for audit trail and SOX compliance documentation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayCount rdf:type rdf:Property ;
    rdfs:label 'Day Count' ;
    rdfs:comment 'Total number of calendar days in this fiscal period. Used for daily rate calculations and pro-rata adjustments.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date used for currency exchange rate determination for this fiscal period. Typically period-end date or average rate date for multi-currency consolidation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal period is subject to external audit review. Typically true for year-end and quarterly periods for publicly traded companies.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year (1-13 for 13-period retail calendar or 1-12 for standard calendar). Used for period-over-period comparisons and comp sales calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gaapCompliant rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliant' ;
    rdfs:comment 'Boolean flag indicating whether financial reporting for this period follows GAAP standards. True for US-based public company reporting.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active fiscal period for transaction posting. True if current, false otherwise.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Boolean flag indicating whether the fiscal year containing this period is a leap year. Affects day count calculations and year-over-year comparisons.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the fiscal period (e.g., \'FY2024-P01\', \'January 2024\', \'Q1-2024\'). Used in financial reports and dashboards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the fiscal period. Controls whether transactions can be posted. Open allows posting, closed prevents new postings, locked is permanently closed, pending_close indicates close process is underway.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for financial reporting in this period (e.g., \'USD\'). Supports multi-currency consolidation and GAAP compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Date' ;
    rdfs:comment 'Date when SOX certification and management attestation were completed for this fiscal period. Required for publicly traded companies.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Required' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal period requires SOX certification and management attestation. True for publicly traded company reporting periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekCount rdf:type rdf:Property ;
    rdfs:label 'Week Count' ;
    rdfs:comment 'Number of weeks in this fiscal period. Typically 4 or 5 weeks for 4-4-5 retail calendar. Critical for normalizing comp sales and same-store sales metrics.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key for the fixed asset entity.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since acquisition. This is the cumulative contra-asset amount reducing the net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or capitalized cost of the asset in USD. This is the gross base amount for depreciation calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date the asset was acquired or placed in service. This is the principal business event timestamp for the asset lifecycle and determines when depreciation begins.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification of the asset type (e.g., store equipment, refrigeration units, fuel pumps, POS terminals, MFC automation systems, delivery vehicles, leasehold improvements). Determines depreciation rules and account assignments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset, including make, model, and specific characteristics.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The main asset number assigned in SAP FI Asset Accounting. This is the externally-known unique identifier for the asset across the enterprise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Active assets are in service and depreciating; under construction assets are capitalized but not yet depreciating; retired/disposed assets are no longer in use.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-number for assets that are part of a larger asset group or complex asset. Used when a main asset has multiple components tracked separately for depreciation purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical tag or barcode identifier affixed to the asset for inventory tracking and physical verification during SOX audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date the asset was capitalized in the general ledger. For assets under construction, this may differ from the acquisition date.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPeriodDepreciation rdf:type rdf:Property ;
    rdfs:label 'Current Period Depreciation' ;
    rdfs:comment 'Depreciation expense recognized in the current fiscal period (month or quarter). Used for EBITDA reconciliation and P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'The valuation view for depreciation calculation: book (GAAP financial reporting), tax (IRS tax depreciation), group (consolidated reporting), or IFRS (international standards).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP-specific depreciation key that defines the calculation rules, useful life, and period control for depreciation posting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'The method used to calculate periodic depreciation expense (e.g., straight-line, declining balance). Aligns with GAAP and tax regulations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date the asset was retired, sold, or otherwise disposed of, marking the end of its service life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalGainLoss rdf:type rdf:Property ;
    rdfs:label 'Disposal Gain Loss' ;
    rdfs:comment 'Gain or loss recognized on disposal, calculated as disposal proceeds minus net book value at disposal date. Positive values indicate gain; negative values indicate loss.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized when the asset\'s recoverable amount falls below its net book value, per GAAP impairment testing requirements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'The date on which an impairment loss was recognized for the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLeasedAsset rdf:type rdf:Property ;
    rdfs:label 'Is Leased Asset' ;
    rdfs:comment 'Flag indicating whether the asset is leased rather than owned. Leased assets follow ASC 842 lease accounting rules.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'The date of the most recent physical inventory verification of the asset, required for SOX compliance and audit trails.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Reference to the lease agreement contract number if the asset is leased. Links to lease liability and right-of-use asset records.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Physical location code where the asset is deployed (store number, DC identifier, or facility code).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset, calculated as acquisition cost minus accumulated depreciation. Represents the remaining capitalized value on the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAccumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Tax Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation recognized for tax purposes to date. Used to track book-tax differences for deferred tax calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'The IRS-approved depreciation method used for tax reporting, which may differ from book depreciation (e.g., MACRS, Section 179 expensing, bonus depreciation).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years, used to calculate depreciation rates. Determined by asset class and IRS guidelines.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The externally-known alphanumeric GL account number as defined in the SAP FI Chart of Accounts (SKA1 table). This is the primary business identifier used across all financial postings, journal entries, and regulatory disclosures. Typically a 6–10 digit numeric code aligned with the company\'s chart of accounts structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'SAP FI account group (KTOKS) that controls the number range and field status for the GL account. Groups accounts by functional category such as balance sheet accounts, P&L accounts, cost accounts, or reconciliation accounts. Used for mass maintenance and reporting segmentation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Level' ;
    rdfs:comment 'Numeric level within the GL account hierarchy structure (e.g., 1=top-level group, 5=detail posting account). Supports financial statement rollup, management reporting hierarchies, and drill-down analytics in EBITDA and comp sales dashboards.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name for the GL account providing additional context beyond the short name. Used in detailed financial disclosures, SOX audit documentation, and ERP configuration reports.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The human-readable short description or title of the GL account as maintained in SAP FI (SKAT table). Used in financial reports, trial balances, and audit documentation. Example: \'Cost of Goods Sold – Grocery\', \'Accounts Payable – Trade\'.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Code' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for statutory reporting or financial consolidation mapping. Corresponds to SAP FI ALTKT field. Used when Grocery must report under multiple chart of accounts structures (e.g., local GAAP vs. group GAAP).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account Indicator' ;
    rdfs:comment 'Indicates whether this is a balance sheet account (True) or a profit and loss (P&L) income statement account (False). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Corresponds to SAP FI XBILK field in SKA1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cogs Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is classified as a Cost of Goods Sold (COGS) account. COGS accounts are used in gross margin and GMROI calculations, merchandise planning analysis, and EBITDA reporting. Supports Oracle Retail Merchandising System and SAP FI/CO integration for cost flow tracking.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Commitment Management Indicator' ;
    rdfs:comment 'Indicates whether this GL account participates in SAP CO commitment management, tracking purchase order commitments and budget reservations before actual expenditure. Relevant for capital expenditure accounts, store renovation budgets, and DC equipment procurement.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'SAP Controlling (CO) cost element category indicating whether this GL account is a primary cost element (direct costs posted from FI, e.g., COGS, labor), a secondary cost element (internal allocations, overhead), or not applicable (balance sheet accounts). Drives cost center accounting, EBITDA reporting, and shrink financial impact analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'Granular classification of the cost element within SAP CO, such as \'material costs\', \'personnel costs\', \'depreciation\', \'overhead allocation\', \'revenue\'. Supports detailed cost center reporting and profitability analysis (CO-PA) across store banners. [ENUM-REF-CANDIDATE: material_costs|personnel_costs|depreciation|overhead_allocation|revenue|settlement|assessment|distribution — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date after which this GL account is no longer valid for new financial postings. Null indicates the account has no defined end date and remains open-ended. Supports account lifecycle management and year-end close procedures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP FI field status group (FSTAG) assigned to this GL account, controlling which fields are required, optional, or suppressed during document entry. Ensures data completeness for cost center, profit center, and business area assignments on postings. Critical for CO integration and reporting accuracy.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementSection rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Section' ;
    rdfs:comment 'The primary financial statement section where this GL account is reported. Drives financial consolidation mapping and GAAP-compliant disclosure preparation. Used in EBITDA reporting, comp sales analysis, and SOX financial reporting controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP FI/CO functional area classification used for cost-of-sales accounting and segment reporting. Segments expenses by business function such as \'manufacturing\', \'sales\', \'administration\', \'research_development\'. Supports GAAP income statement by function presentation and SEC segment disclosures. [ENUM-REF-CANDIDATE: store_operations|supply_chain|merchandising|pharmacy|administration|marketing|finance|it|fuel_operations — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'Detailed GAAP line-item classification for the account, such as \'Current Assets\', \'Long-Term Liabilities\', \'Cost of Goods Sold (COGS)\', \'Selling General and Administrative (SG&A)\', \'Depreciation and Amortization\'. Supports EBITDA calculation, COGS tracking, and SEC financial disclosure. [ENUM-REF-CANDIDATE: current_assets|non_current_assets|current_liabilities|non_current_liabilities|equity|net_revenue|cogs|gross_profit|sga|depreciation_amortization|interest_expense|income_tax|other_income_expense — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is a bank account (house bank) used for cash management and treasury operations. Bank accounts require special reconciliation procedures and are subject to PCI DSS controls for payment processing. Supports daily cash position reporting and bank reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsMappingCode rdf:type rdf:Property ;
    rdfs:label 'Ifrs Mapping Code' ;
    rdfs:comment 'IFRS account mapping code for international financial reporting or cross-border consolidation purposes. Used when Grocery operates entities in jurisdictions requiring IFRS reporting alongside US GAAP. Supports dual-ledger accounting in SAP FI parallel ledger configuration.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used for intercompany transactions between Grocery\'s legal entities (e.g., store banners, distribution centers, pharmacy subsidiaries). Intercompany accounts require elimination during financial consolidation. Supports SOX-compliant consolidation and GAAP ASC 810 requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Posting Allowed' ;
    rdfs:comment 'Indicates whether direct financial postings are permitted to this GL account. False for summary/header accounts that only aggregate child accounts, or for accounts blocked for posting. Corresponds to SAP FI XLOEV (account blocked for posting) flag.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account for a subledger (Accounts Payable, Accounts Receivable, or Asset Accounting). Reconciliation accounts cannot receive direct manual postings; they are updated automatically from subledger transactions. Critical for AP/AR balance integrity and SOX controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Tax Relevant' ;
    rdfs:comment 'Indicates whether this GL account is subject to tax reporting obligations. True for accounts involving taxable sales, purchases, or excise duties (e.g., fuel center, alcohol, tobacco). Supports tax compliance reporting and FTC regulatory filings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this GL account in SAP FI. When True, auditors and finance analysts can drill down to individual posting details. Required for SOX audit trails and GAAP disclosure support. Corresponds to SAP FI XKRES field.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account. When True, individual line items remain open until cleared by a matching offsetting entry (e.g., GR/IR clearing accounts, bank clearing accounts). Essential for AP/AR reconciliation and month-end close processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the parent/summary account in the GL hierarchy. Enables hierarchical rollup of financial balances for management reporting, financial consolidation, and EBITDA calculation. Null for top-level accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Planning Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used in SAP CO budgeting and planning processes. Planning accounts are included in annual budget cycles, labor budget planning (Kronos integration), and Blue Yonder demand planning financial inputs. Supports comp sales and same-store sales budget vs. actual analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossStatementAccountType rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Statement Account Type' ;
    rdfs:comment 'Classifies P&L accounts into their income statement reporting category for EBITDA calculation, comp sales analysis, and same-store sales reporting. \'cogs\' accounts feed COGS tracking; \'ebitda_component\' accounts are used in EBITDA reporting. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: net_revenue|cogs|gross_profit|operating_expense|ebitda_component|interest|tax|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Specifies the subledger type this reconciliation account is linked to. Applicable only when is_reconciliation_account is True. Drives AP/AR aging reports, vendor payment reconciliation, and fixed asset depreciation schedules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Shrink Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is designated for recording shrink (inventory loss from theft, spoilage, or damage). Shrink accounts are critical for fresh produce and perishable inventory financial impact tracking, GMROI analysis, and loss prevention reporting across store banners.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP FI sort key (ZUAWA) that determines the assignment field populated in line items posted to this account. Controls how line items are sorted and displayed in account statements. Common values: \'001\' (posting date), \'003\' (document number), \'031\' (vendor invoice number). Supports efficient account reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevantIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Indicator' ;
    rdfs:comment 'Indicates whether this GL account is in scope for SOX Section 302/404 internal controls testing and audit. SOX-relevant accounts require documented controls, segregation of duties, and periodic reconciliation sign-off. Critical for Grocery\'s external audit and SEC financial reporting compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'SAP FI tax category assigned to the GL account, controlling whether tax codes are required, optional, or not allowed during posting. Relevant for sales tax on grocery transactions, fuel excise tax, and pharmacy prescription tax exemptions. Corresponds to SAP FI MWSKZ field. [ENUM-REF-CANDIDATE: input_tax_required|output_tax_required|tax_optional|no_tax|exempt — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for this entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The SAP business area classification for segment reporting, such as Retail, Pharmacy, Fuel, or eCommerce. Enables intercompany analysis by line of business.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The business date of the underlying transaction or invoice that triggered the intercompany posting. May differ from posting_date due to processing lag.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this intercompany transaction requires elimination during financial consolidation to prevent double-counting of revenue, expenses, or assets across legal entities.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Current status of the elimination process for this intercompany transaction: pending (awaiting consolidation run), eliminated (successfully removed in consolidated financials), not_required (no elimination needed), manual_review (requires finance team intervention).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied to convert transaction_amount to functional or group currency. Sourced from SAP FI exchange rate table at posting_date.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the functional currency of the sending company code for local statutory reporting. Conversion uses the exchange rate at posting_date.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency (typically USD) for consolidated financial statements. Critical for intercompany elimination at the corporate level.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Description' ;
    rdfs:comment 'Free-text description of the intercompany transaction providing business context, such as \'DC to Store 1234 inventory allocation for Q1\' or \'Corporate IT shared service charge for January\'. Supports audit trail and user understanding.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The SAP user ID or system process that last modified the intercompany transaction record. Tracks changes for audit and compliance purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingAmount rdf:type rdf:Property ;
    rdfs:label 'Netting Amount' ;
    rdfs:comment 'The net amount after offsetting reciprocal intercompany balances between sending and receiving entities. Used for intercompany settlement and cash pooling arrangements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving the intercompany transaction (e.g., distribution center, shared service center, subsidiary). Four-character alphanumeric identifier per SAP FI configuration.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The date on which the intercompany transaction was successfully reconciled and matched between sending and receiving entities. Null if reconciliation is pending or unmatched.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the intercompany reconciliation process indicating whether the transaction has been confirmed and matched between sending and receiving entities: matched (both sides agree), unmatched (discrepancy exists), partially_matched (amount variance), disputed (under investigation), resolved (discrepancy corrected).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The source document number that triggered the intercompany transaction, such as an invoice number, purchase order, transfer order, or allocation run ID. Provides audit trail back to originating transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The transaction_number of the original intercompany transaction that this record reverses. Populated only when reversal_flag is True, providing audit trail for corrections.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity originating the intercompany transaction (e.g., store, distribution center, corporate entity). Four-character alphanumeric identifier per SAP FI configuration.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The actual date on which the intercompany transaction was settled through cash transfer, netting, or other payment mechanism. Null if settlement is pending.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'The method used to settle the intercompany transaction: cash_transfer (actual funds moved), netting (offset against reciprocal balances), offset (applied against other intercompany transactions), accrual_only (no cash settlement, accounting entry only).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to the intercompany transaction for VAT, GST, or sales tax purposes. Some intercompany transactions may be tax-exempt depending on jurisdiction and transaction type.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary value of the intercompany transaction in the transaction currency, before any adjustments or eliminations. Represents the amount posted to both sending and receiving entities.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated (e.g., USD, CAD, MXN for North American operations).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number for intercompany postings, typically following format IC-XXXXXXXXXX for tracking and reconciliation purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the cross-entity posting: cost_allocation (store-to-DC allocations), shared_service_charge (corporate overhead), intercompany_loan (financing arrangements), management_fee (corporate services), inventory_transfer (goods movement), royalty (brand/IP licensing).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorAssociateId rdf:type rdf:Property ;
    rdfs:label 'Requestor Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Internal orders are initiated by an associate; linking enables approval workflow and cost accountability.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs posted to this internal order to date, in the company code currency. Includes direct costs, allocations, and internal activity charges. Updated in real-time as costs are posted.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amount. Typically matches the company code currency but may differ for multi-currency projects.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Flag' ;
    rdfs:comment 'Boolean indicator whether costs on this internal order are capitalized (True) or expensed (False). True for capital investments that will be settled to fixed assets; False for operating expenses settled to cost centers or GL accounts.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs (purchase requisitions and purchase orders) against this internal order. Used for funds availability checking and budget consumption reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Boolean indicator whether this internal order has been marked for deletion. True indicates the order is logically deleted but retained for audit purposes; False indicates an active or closed order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:comment 'Free-text description of the internal order purpose, scope, and business justification. Provides context for financial analysts and auditors reviewing project costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the internal order, externally visible and used in financial reporting and project tracking. Typically a 10-12 character alphanumeric code assigned by SAP CO.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the internal order. Controls whether costs can be posted, whether the order can be settled, and whether it appears in active project reports. Status progression: created → released → technically_complete → settled → closed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the internal order by business purpose. Determines cost collection rules, settlement targets, and reporting hierarchy. Common types include capital investments, store remodels, marketing campaigns, maintenance projects, and IT initiatives.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Project Manager Email' ;
    rdfs:comment 'Email address of the project manager for communication and escalation purposes. Used for automated budget alerts and approval workflows.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Full name of the individual responsible for managing this internal order project. Accountable for budget adherence, timeline, and deliverables.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name or code of the business department that requested this internal order. Used for chargeback and accountability reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Code' ;
    rdfs:comment 'Identifier of the specific cost object (asset number, cost center code, GL account number) to which costs will be settled. Format varies by receiver type.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Type of cost object to which this internal order will be settled upon completion. Common receivers include fixed assets (for CAPEX), cost centers (for OPEX), or GL accounts (for period costs).' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Profile' ;
    rdfs:comment 'Configuration key defining how costs accumulated on this internal order are settled to final cost objects (e.g., asset under construction, cost center, GL account). Determines settlement percentage, receiver type, and settlement period rules.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'Identifier of the WBS element if this internal order is part of a larger project structure. Links the order to a project hierarchy for integrated project and cost management.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry document. Primary key for the journal entry product.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJournalAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Associate Id' ;
    rdfs:comment 'The user ID of the person who created or entered this journal entry into the system. Used for SOX compliance audit trails and segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:quaternaryJournalPostedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Journal Posted By User Associate Id' ;
    rdfs:comment 'The user ID of the person who posted this journal entry to the general ledger. Null if entry is parked but not yet posted. Used for SOX compliance segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:quinaryJournalParkingUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Quinary Journal Parking User Associate Id' ;
    rdfs:comment 'The user ID of the person who parked this journal entry (saved without posting). Null if entry was never parked. Used for workflow tracking and segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:tertiaryJournalApprovedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Journal Approved By User Associate Id' ;
    rdfs:comment 'The user ID of the person who approved this journal entry for posting. Null if approval workflow is not required or entry is not yet approved. Used for SOX compliance segregation of duties and approval workflow tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date used for payment term calculation in accounts payable processing. Typically the invoice date or goods receipt date. Used for payment due date calculation and cash flow forecasting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The batch input session name if this journal entry was created via batch processing. Null for online entries. Used for batch processing tracking and error resolution.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned by the financial system (SAP FI document number). This is the business identifier used in audit trails and financial reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the journal entry document type. SA=General Ledger Document, KR=Vendor Invoice, DR=Customer Invoice, AB=Accounting Document, KG=Vendor Credit Memo, DZ=Payment Document. Determines posting rules and account determination logic.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date when the journal entry was first created or entered into the system by the user. Audit trail timestamp for SOX compliance and internal control monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form text description at the document header level providing context or explanation for the journal entry. Used for audit trail documentation and user communication.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between two company codes within the Grocery enterprise. True if intercompany, False otherwise. Used for intercompany reconciliation and elimination entries in consolidated financial statements.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'The ledger or ledger group to which this journal entry is posted. 0L=Leading Ledger (GAAP), 2L=IFRS Ledger, 9Z=Management Reporting Ledger. Supports parallel accounting for multiple accounting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The local (company code) currency in which amounts are also stored for statutory reporting. Three-letter ISO 4217 currency code. Typically USD for US-based grocery operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Parking Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was parked. Null if entry was never parked. Used for workflow tracking and aging analysis of parked documents.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'Code indicating the payment method for this journal entry. C=Check, T=Wire Transfer, W=ACH, Z=Other. Used for payment processing and cash management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was posted to the general ledger. Null if entry is parked but not yet posted. Used for posting workflow tracking and audit trail analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Posted=finalized and affecting GL balances, Parked=saved but not yet posted, Cleared=settled against another document, Reversed=negated by reversal entry, Cancelled=voided before posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversal. 01=Accrual Reversal, 02=Error Correction, 03=Period-End Adjustment, 04=Reclassification, 05=Duplicate Entry, 06=Other. Used for internal control monitoring and audit trail analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date used for tax reporting purposes. May differ from posting date due to tax jurisdiction rules. Used for sales tax remittance reporting, fuel excise tax reporting, and pharmacy dispensing tax compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner if this is an intercompany transaction. Null for non-intercompany entries. Used for intercompany reconciliation and automated elimination entry generation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the corporate hierarchy. Null for the ultimate parent holding company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate structure. Used for ultimate consolidation and group-level reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the external audit firm responsible for auditing this legal entity\'s financial statements. Required for SOX-scoped and public entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting unit to which this legal entity belongs. Used for financial consolidation and intercompany elimination.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or ceased operations. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or DBA name under which the legal entity operates. May differ from the legal name for customer-facing operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active entities are operational and filing; inactive or dissolved entities are no longer conducting business.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month (1-12) in which the legal entity\'s fiscal year ends. Used for annual financial statement preparation and tax filing deadlines.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which the legal entity conducts business and maintains its books.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Standard' ;
    rdfs:comment 'The accounting standard framework used by this legal entity for financial reporting (US GAAP, IFRS, or local GAAP).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the state. Used to calculate entity age and anniversary dates.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the legal entity in financial systems and reporting. Typically used in SAP FI company code configuration.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the entity as registered with the state or jurisdiction of incorporation. Used for all legal documents, contracts, and regulatory filings.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit code classifying the primary business activity of the legal entity. Used for industry benchmarking and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Public Company Flag' ;
    rdfs:comment 'Indicates whether this legal entity is publicly traded on a stock exchange. Determines SEC reporting requirements and audit obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal entity\'s registered address on file with the state. Used for official correspondence and legal service of process.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the registered address (suite, floor, building). Optional field for additional address details.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City of the legal entity\'s registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'ZIP code of the registered address. Supports 5-digit or 9-digit ZIP+4 format.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredState rdf:type rdf:Property ;
    rdfs:label 'Registered State' ;
    rdfs:comment 'Two-letter US state code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit code classifying the primary business activity. Legacy classification system still used by SEC and some regulatory bodies.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of SOX compliance and internal control testing. True for publicly traded entities and material subsidiaries.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'State Of Incorporation' ;
    rdfs:comment 'Two-letter US state code where the legal entity is incorporated or registered. Determines governing law and annual filing requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'Code identifying the primary stock exchange where the entity\'s shares are traded (e.g., NYSE, NASDAQ). Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol under which the entity\'s shares are traded. Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or sales tax registration number for entities operating in jurisdictions requiring VAT registration. Null for US-only entities without VAT obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerCode rdf:type rdf:Property ;
    rdfs:label 'Banner Code' ;
    rdfs:comment 'The retail banner or brand under which this profit center operates (e.g., \'KROGER\', \'RALPHS\', \'FREDS\', \'HARRIS\'). Used for banner-level comp sales and same-store sales reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date this profit center was permanently closed. Null for active profit centers. Used for historical analysis and asset impairment calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compSalesEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is eligible for comp sales (comparable store sales) reporting. True if the location has been open for at least 12 months and meets comp sales criteria.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCount rdf:type rdf:Property ;
    rdfs:label 'Department Count' ;
    rdfs:comment 'The number of distinct departments or categories within this profit center (e.g., produce, meat, dairy, bakery, pharmacy, fuel). Used for assortment complexity analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'The district code within a region, representing a cluster of stores managed by a district manager. Used for district-level P&L roll-up.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The current number of full-time equivalent (FTE) employees assigned to this profit center. Used for labor productivity and EBITDA per employee calculations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The SAP user ID of the person who last modified this profit center master record. Required for SOX audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is locked for new postings. True when locked (no new transactions allowed), False when open for posting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'The market or metropolitan area code (e.g., \'NYC\', \'LAX\', \'CHI\'). Used for market-level competitive analysis and same-store sales comparisons.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'The code of the parent profit center in the hierarchy. Null for top-level profit centers. Enables roll-up of comp sales, same-store sales, and EBITDA by region or division.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Extended text description providing additional context about the profit center\'s purpose, scope, and business model (e.g., \'High-volume urban supermarket with full-service pharmacy and fuel center\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center (e.g., \'Store 1234 - Downtown Seattle\', \'Pharmacy Division - West Region\', \'Private Label Bakery\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center: active (operational and posting transactions), inactive (temporarily suspended), planned (future opening), closed (permanently shut down).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by business function: store-level P&L, banner-level aggregation, pharmacy operations, fuel center operations, distribution center, private-label brand division, or corporate overhead. [ENUM-REF-CANDIDATE: store|banner|pharmacy|fuel_center|distribution_center|private_label|corporate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remodelDate rdf:type rdf:Property ;
    rdfs:label 'Remodel Date' ;
    rdfs:comment 'The date of the most recent major remodel or renovation. Significant remodels may reset comp sales eligibility timers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sameStoreSalesEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Same Store Sales Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center qualifies for same-store sales reporting (revenue comparison for existing locations year-over-year). Typically requires 13+ months of operation without major remodels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'The total retail square footage of the store or facility. Used to calculate sales per square foot and GMROI (Gross Margin Return on Investment) metrics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this profit center is valid and can accept financial postings. Used for time-dependent master data and historical reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this profit center is valid. Null for open-ended validity. Used to track store closures, division consolidations, and organizational changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Unique identifier for the SOX internal control record. Primary key for the sox_control data product.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySoxAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Sox Associate Id' ;
    rdfs:comment 'Identifier of the associate responsible for the design, execution, and monitoring of this control. Typically a manager or director in Finance, Operations, or IT.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:soxPerformerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Sox Performer Associate Id' ;
    rdfs:comment 'Identifier of the associate who actually executes the control activity. May differ from the control owner (e.g., staff accountant performs, manager owns).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:assertionCategory rdf:type rdf:Property ;
    rdfs:label 'Assertion Category' ;
    rdfs:comment 'The financial statement assertion this control addresses per audit standards: existence (transactions occurred), completeness (all transactions recorded), accuracy (amounts correct), valuation (proper measurement), rights and obligations (entity owns/owes), presentation and disclosure (proper classification and disclosure).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorRelianceFlag rdf:type rdf:Property ;
    rdfs:label 'Auditor Reliance Flag' ;
    rdfs:comment 'Indicates whether external auditors plan to rely on this control for their financial statement audit, which requires more extensive testing and documentation.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessProcess rdf:type rdf:Property ;
    rdfs:label 'Business Process' ;
    rdfs:comment 'The core business process or cycle this control supports (e.g., \'Revenue Recognition\', \'Inventory Valuation\', \'Accounts Payable\', \'Payroll Processing\', \'Financial Close\', \'Fixed Assets\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyLevelControlFlag rdf:type rdf:Property ;
    rdfs:label 'Company Level Control Flag' ;
    rdfs:comment 'Indicates whether this is a company-level (entity-level) control that operates across the entire organization (e.g., code of conduct, whistleblower hotline, board oversight) versus a process-level control.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensatingControlFlag rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Flag' ;
    rdfs:comment 'Indicates whether this control serves as a compensating control to mitigate risk when a primary control is deficient or not operating effectively.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlActivityDetail rdf:type rdf:Property ;
    rdfs:label 'Control Activity Detail' ;
    rdfs:comment 'Step-by-step procedures or specific actions performed as part of the control execution (e.g., \'Compare system-generated inventory report to physical count sheets; investigate variances exceeding $5,000 or 2%; document resolution in variance log\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or executed (e.g., daily reconciliations, monthly close reviews, quarterly management certifications, event-driven approvals). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|event_driven|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNature rdf:type rdf:Property ;
    rdfs:label 'Control Nature' ;
    rdfs:comment 'Indicates whether the control is performed manually by personnel, fully automated by system, or a hybrid where manual steps depend on IT-generated reports or system configurations.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business-facing unique control identifier used in audit documentation and control testing workpapers. Typically follows a pattern like FIN-001, INV-025, REV-100.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlObjective rdf:type rdf:Property ;
    rdfs:label 'Control Objective' ;
    rdfs:comment 'The specific financial reporting assertion or business objective this control is designed to achieve (e.g., \'Ensure completeness and accuracy of accounts payable balances\', \'Prevent unauthorized inventory adjustments\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlOwnerName rdf:type rdf:Property ;
    rdfs:label 'Control Owner Name' ;
    rdfs:comment 'Full name of the control owner for reporting and audit trail purposes.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPerformerName rdf:type rdf:Property ;
    rdfs:label 'Control Performer Name' ;
    rdfs:comment 'Full name of the associate who performs the control for audit documentation and segregation of duties analysis.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTitle rdf:type rdf:Property ;
    rdfs:label 'Control Title' ;
    rdfs:comment 'Short descriptive title of the control activity (e.g., \'Monthly Bank Reconciliation Review\', \'Inventory Valuation Approval\', \'Revenue Recognition Cut-off Verification\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of control based on its timing and purpose: preventive (stops errors before they occur), detective (identifies errors after occurrence), or corrective (remediates identified errors).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of any identified control deficiency: none (control operating effectively), control deficiency (minor issue not rising to significant deficiency), significant deficiency (important enough to merit attention by those charged with governance), material weakness (reasonable possibility of material misstatement not prevented or detected).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed description of the control deficiency identified during testing, including root cause analysis, impact assessment, and specific instances where the control failed to operate as designed.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Identified Date' ;
    rdfs:comment 'Date when the control deficiency was first identified through testing, self-assessment, or audit procedures.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when this control was retired, superseded, or no longer applicable. Null for active controls.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceOfPerformance rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Performance' ;
    rdfs:comment 'Description of the documentation or artifacts that demonstrate the control was performed (e.g., \'Signed reconciliation workpaper with preparer and reviewer signatures and dates\', \'System-generated approval workflow log\', \'Email confirmation from manager\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLineItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line Item' ;
    rdfs:comment 'The specific financial statement account or line item this control impacts (e.g., \'Revenue\', \'Cost of Goods Sold (COGS)\', \'Inventory\', \'Accounts Receivable\', \'Accrued Liabilities\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itGeneralControlFlag rdf:type rdf:Property ;
    rdfs:label 'It General Control Flag' ;
    rdfs:comment 'Indicates whether this is an IT general control (ITGC) covering system access, change management, backup/recovery, or operations versus an application control embedded in business processes.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyControlFlag rdf:type rdf:Property ;
    rdfs:label 'Key Control Flag' ;
    rdfs:comment 'Indicates whether this is a key control that external auditors rely upon for their financial statement audit opinion. Key controls are subject to more rigorous testing and documentation requirements.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date when the control was most recently tested by internal audit, external auditors, or control owners as part of ongoing monitoring or annual SOX compliance testing.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control test based on control frequency and testing plan. Used for test scheduling and compliance monitoring.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completion Date' ;
    rdfs:comment 'Actual date when remediation activities were completed and the control was redesigned or enhanced to address the identified deficiency.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed action plan to address and remediate the identified control deficiency, including specific steps, responsible parties, resources required, and interim compensating controls.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target completion date for remediation activities. Material weaknesses typically require remediation within the fiscal year to avoid adverse audit opinion.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Assessment of the inherent risk level associated with the business process or account balance this control mitigates. Critical and high-risk controls receive more frequent testing.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sec Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether deficiencies in this control must be disclosed in SEC filings (Form 10-K, Form 10-Q) per SOX Section 302 and 404 requirements. Typically true for material weaknesses and significant deficiencies.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxControlStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Control Status' ;
    rdfs:comment 'Current operational status of the control: active (in operation and being tested), inactive (temporarily suspended), under review (being evaluated for design effectiveness), retired (no longer in use).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSampleSize rdf:type rdf:Property ;
    rdfs:label 'Test Sample Size' ;
    rdfs:comment 'Number of control instances or transactions selected for testing during the most recent test cycle. Sample size is determined based on control frequency and risk rating.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingStatus rdf:type rdf:Property ;
    rdfs:label 'Testing Status' ;
    rdfs:comment 'Current status of control testing for the fiscal period: not tested (testing not yet started), in progress (testing underway), passed (no deficiencies identified), failed (deficiency identified), not applicable (control not in scope for current period).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorFuelPriceId rdf:type rdf:Property ;
    rdfs:label 'Competitor Fuel Price Id' ;
    rdfs:comment 'Unique identifier for each competitor fuel price observation record.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitivePosition rdf:type rdf:Property ;
    rdfs:label 'Competitive Position' ;
    rdfs:comment 'The calculated competitive pricing position of the Grocery fuel center relative to this observation: below_market (Grocery price is lower), at_market (prices are equal within tolerance), above_market (Grocery price is higher).' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorLatitude rdf:type rdf:Property ;
    rdfs:label 'Competitor Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the competitor fuel center. Enables distance calculations and competitive radius mapping.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorLongitude rdf:type rdf:Property ;
    rdfs:label 'Competitor Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the competitor fuel center. Enables distance calculations and competitive radius mapping.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'The brand or business name of the competitor fuel retailer whose street price is being observed. Null for wholesale/rack price sources.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Competitor Site Address' ;
    rdfs:comment 'The street address of the competitor fuel center location. Used for geographic proximity analysis and market segmentation.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceToFuelCenterMiles rdf:type rdf:Property ;
    rdfs:label 'Distance To Fuel Center Miles' ;
    rdfs:comment 'The calculated distance in miles from the competitor site to the benchmarked Grocery fuel center. Used for competitive radius analysis.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributorSource rdf:type rdf:Property ;
    rdfs:label 'Distributor Source' ;
    rdfs:comment 'The fuel distributor or supplier name associated with the wholesale rack or terminal price. Null for competitor street price observations.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'The specific fuel product grade being priced: regular unleaded (87 octane), midgrade (89 octane), premium (91-93 octane), diesel, E85 (85% ethanol blend), or E15 (15% ethanol blend).' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'The regional market or metropolitan area identifier for this pricing observation. Used to segment pricing intelligence by local market dynamics.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexProvider rdf:type rdf:Property ;
    rdfs:label 'Index Provider' ;
    rdfs:comment 'The third-party pricing index or data provider name for wholesale rack prices: OPIS (Oil Price Information Service), Platts, or DTN (Data Transmission Network).' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationMethod rdf:type rdf:Property ;
    rdfs:label 'Observation Method' ;
    rdfs:comment 'The method by which the price data was collected: manual field survey, automated web scraping, API data feed, email report from provider, or phone call to terminal.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The exact date and time when the competitor price or wholesale rack price was observed or recorded.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observedPricePerGallon rdf:type rdf:Property ;
    rdfs:label 'Observed Price Per Gallon' ;
    rdfs:comment 'The fuel price per gallon observed at the competitor site or reported by the wholesale index/terminal. Expressed in USD per gallon with three decimal precision.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observerName rdf:type rdf:Property ;
    rdfs:label 'Observer Name' ;
    rdfs:comment 'The name of the person or system that recorded the competitor price observation. Used for data quality auditing and manual survey accountability.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'The pricing level being captured: street_retail (consumer pump price at competitor), terminal_rack (wholesale terminal rack price), spot_market (commodity spot market price), or contract (negotiated supplier contract price).' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Price Change Trigger Flag' ;
    rdfs:comment 'Boolean indicator whether this observation triggered an automated price change recommendation or alert based on competitive pricing rules and thresholds.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceDifferentialCents rdf:type rdf:Property ;
    rdfs:label 'Price Differential Cents' ;
    rdfs:comment 'The calculated price difference in cents per gallon between the observed competitor/wholesale price and the current Grocery fuel center price for the same grade. Positive values indicate Grocery is more expensive.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source Identifier' ;
    rdfs:comment 'The specific name or code of the pricing source: competitor site name and location for surveys, data provider name for automated feeds, terminal or index name for rack/wholesale prices.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'The category of pricing intelligence source: competitor survey (manual street price observation), automated feed (third-party data provider), rack index (OPIS/Platts/DTN terminal rack price), spot market (real-time commodity market price), or contract terminal price (negotiated supplier terminal price).' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'The specific fuel terminal or distribution point name for wholesale rack prices. Null for competitor street price observations.' ;
    rdfs:domain ind:CompetitorFuelPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the fuel delivery schedule record. Primary key.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Identifier of the transportation carrier responsible for delivering the fuel shipment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:tankId rdf:type rdf:Property ;
    rdfs:label 'Tank Id' ;
    rdfs:comment 'Identifier of the specific underground storage tank at the fuel center that will receive this delivery.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tank .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The actual date and time when the fuel delivery was completed, if applicable.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualGallonsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Gallons Delivered' ;
    rdfs:comment 'The actual volume of fuel in gallons that was delivered, recorded upon completion.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'The bill of lading number issued by the carrier for this fuel shipment, serving as a receipt and contract.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledReason rdf:type rdf:Property ;
    rdfs:label 'Cancelled Reason' ;
    rdfs:comment 'Explanation or reason code if the delivery schedule was cancelled (e.g., supplier issue, weather, tank maintenance).' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationReference rdf:type rdf:Property ;
    rdfs:label 'Confirmation Reference' ;
    rdfs:comment 'External confirmation number or reference code provided by the distributor or carrier for this scheduled delivery.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the on-site contact person at the fuel center for coordinating the delivery.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the on-site contact person for delivery coordination.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the system user or automated process that created this delivery schedule record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTankLevelGallons rdf:type rdf:Property ;
    rdfs:label 'Current Tank Level Gallons' ;
    rdfs:comment 'The current fuel inventory level in gallons in the target tank at the time the delivery was scheduled.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions or notes for the carrier regarding site access, safety protocols, or delivery procedures.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver who delivered the fuel shipment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'The estimated total cost in USD for this fuel delivery, including product and transportation charges.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Gallons' ;
    rdfs:comment 'The estimated volume of fuel in gallons ordered for this delivery.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'The urgency or priority level assigned to this delivery to prevent out-of-stock (OOS) conditions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Number' ;
    rdfs:comment 'Certification or quality assurance reference number confirming the fuel meets EPA and industry standards.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderThresholdGallons rdf:type rdf:Property ;
    rdfs:label 'Reorder Threshold Gallons' ;
    rdfs:comment 'The inventory level in gallons at which a reorder is automatically triggered to prevent stockouts.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderTriggerType rdf:type rdf:Property ;
    rdfs:label 'Reorder Trigger Type' ;
    rdfs:comment 'The method that triggered the reorder: ATG (Automatic Tank Gauge) automated, CAO (Computer-Assisted Ordering) automated, manual, or emergency.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescheduledFromDate rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Date' ;
    rdfs:comment 'The original scheduled delivery date if this delivery was rescheduled from a prior date.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The planned date on which the fuel delivery is scheduled to occur.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The end of the scheduled delivery time window, including date and time.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The beginning of the scheduled delivery time window, including date and time.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Temperature At Delivery' ;
    rdfs:comment 'The fuel temperature in degrees Fahrenheit recorded at the time of delivery, used for volume correction calculations.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPricePerGallon rdf:type rdf:Property ;
    rdfs:label 'Unit Price Per Gallon' ;
    rdfs:comment 'The contracted or estimated price per gallon in USD for the fuel being delivered.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceGallons rdf:type rdf:Property ;
    rdfs:label 'Variance Gallons' ;
    rdfs:comment 'The difference in gallons between the estimated and actual delivered quantities (actual minus estimated).' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Number' ;
    rdfs:comment 'Identifier or license plate number of the delivery vehicle (tanker truck) used for this shipment.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalIncidentId rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Id' ;
    rdfs:comment 'Unique identifier for the environmental incident record. Primary key.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportedByAssociateId rdf:type rdf:Property ;
    rdfs:label 'Reported By Associate Id' ;
    rdfs:comment 'Identifier of the associate who reported the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:affectedMedia rdf:type rdf:Property ;
    rdfs:label 'Affected Media' ;
    rdfs:comment 'Environmental media impacted by the release (soil, groundwater, surface water, air). Determines scope of remediation and regulatory notification requirements.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeCategory rdf:type rdf:Property ;
    rdfs:label 'Cause Category' ;
    rdfs:comment 'Root cause category of the environmental incident. Used for trend analysis and preventive maintenance planning. [ENUM-REF-CANDIDATE: equipment_failure|corrosion|overfill|delivery_error|vandalism|natural_disaster|operator_error|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Detailed narrative description of the root cause and circumstances leading to the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponderNotified rdf:type rdf:Property ;
    rdfs:label 'Emergency Responder Notified' ;
    rdfs:comment 'Indicates whether local emergency responders (fire department, hazmat team) were notified of the incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyResponderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Emergency Responder Timestamp' ;
    rdfs:comment 'Date and time when emergency responders were notified of the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epaNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Epa Notification Timestamp' ;
    rdfs:comment 'Date and time when the EPA was notified of the environmental incident. Must be within 24 hours of discovery for reportable releases.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:epaNotified rdf:type rdf:Property ;
    rdfs:label 'Epa Notified' ;
    rdfs:comment 'Indicates whether the EPA was notified of the environmental release as required by federal regulations.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelGradeReleased rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade Released' ;
    rdfs:comment 'Type of fuel grade involved in the release. Determines environmental impact assessment and remediation approach.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate containment and response actions taken at the time of incident discovery, including emergency shutoff, spill containment, and site securing.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the environmental incident in the response and remediation workflow.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Date and time when the environmental incident occurred or was first detected. Principal business event timestamp for regulatory reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Insurance claim number associated with the environmental incident for cost recovery purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEndDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring End Date' ;
    rdfs:comment 'Scheduled or actual end date for post-remediation environmental monitoring activities.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Required' ;
    rdfs:comment 'Indicates whether ongoing environmental monitoring is required following remediation completion.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrcReportNumber rdf:type rdf:Property ;
    rdfs:label 'Nrc Report Number' ;
    rdfs:comment 'National Response Center report number assigned when the incident was reported to the federal hotline for oil and hazardous substance releases.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Total amount of regulatory penalties or fines assessed for the environmental incident, in USD.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryPenaltyAssessed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Penalty Assessed' ;
    rdfs:comment 'Indicates whether regulatory penalties or fines were assessed against the company for the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationContractor rdf:type rdf:Property ;
    rdfs:label 'Remediation Contractor' ;
    rdfs:comment 'Name of the environmental remediation contractor engaged to perform cleanup and restoration activities.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan Reference' ;
    rdfs:comment 'Reference identifier or document number for the approved remediation plan addressing the environmental contamination.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStartDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Start Date' ;
    rdfs:comment 'Date when active remediation activities commenced at the incident site.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Source Equipment Code' ;
    rdfs:comment 'Identifier or serial number of the specific equipment unit that was the source of the release.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Source Equipment Type' ;
    rdfs:comment 'Type of fuel center equipment that was the source of the environmental release. [ENUM-REF-CANDIDATE: underground_storage_tank|dispenser|piping|vent_system|delivery_connection|spill_bucket|overfill_prevention — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'State Agency Notification Timestamp' ;
    rdfs:comment 'Date and time when the state environmental agency was notified of the environmental incident.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stateAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'State Agency Notified' ;
    rdfs:comment 'Indicates whether the state environmental agency was notified of the environmental release as required by state regulations.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Total Remediation Cost' ;
    rdfs:comment 'Total cost incurred for environmental remediation, monitoring, and regulatory compliance activities related to the incident, in USD.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeReleased rdf:type rdf:Property ;
    rdfs:label 'Volume Released' ;
    rdfs:comment 'Estimated or measured volume of fuel or hazardous material released during the incident, in gallons. Critical for EPA release reporting thresholds.' ;
    rdfs:domain ind:EnvironmentalIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaComplianceReportId rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Report Id' ;
    rdfs:comment 'Unique identifier for the EPA compliance report record.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentClosureDate rdf:type rdf:Property ;
    rdfs:label 'Incident Closure Date' ;
    rdfs:comment 'Date when the regulatory agency formally closed the incident or compliance case, indicating all corrective actions completed and remediation verified. Null for open incidents or routine compliance reports.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the environmental incident or compliance violation occurred. Null for routine compliance reports.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'Precise timestamp when the environmental incident or compliance violation was detected. Null for routine compliance reports.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionFindings rdf:type rdf:Property ;
    rdfs:label 'Inspection Findings' ;
    rdfs:comment 'Summary of findings from regulatory inspection or compliance audit, including violations identified, equipment deficiencies, and procedural gaps. Null for reports without formal inspection.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency overseeing this compliance report or incident, typically EPA regional office or state environmental agency with delegated Underground Storage Tank (UST) program authority.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the regulatory agency was formally notified of the incident or compliance issue, as required by EPA 24-hour release reporting requirements. Null for routine compliance reports.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number or case identifier assigned by the regulatory agency for tracking this compliance report, incident, or enforcement action.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Business identifier for the compliance report or incident, used for external regulatory reference and tracking.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the EPA report: compliance reporting for routine submissions, environmental incident for release events, inspection finding for regulatory audit results, corrective action for required remediation, or remediation status for ongoing cleanup tracking.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the compliance reporting period covered by this report.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the compliance reporting period covered by this report.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name of the legal entity or party responsible for the Underground Storage Tank (UST) system and compliance obligations, typically the fuel center operator or corporate owner.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankNumber rdf:type rdf:Property ;
    rdfs:label 'Tank Number' ;
    rdfs:comment 'Physical tank number or designation at the fuel center involved in the incident or compliance report.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ustSystemCode rdf:type rdf:Property ;
    rdfs:label 'Ust System Code' ;
    rdfs:comment 'Identifier of the specific Underground Storage Tank system involved in the incident or compliance report, linking to tank registration and equipment records.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeReleasedGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Released Gallons' ;
    rdfs:comment 'Quantity of fuel or petroleum product released during the incident, measured in gallons. Null for routine compliance reports or incidents where volume cannot be determined.' ;
    rdfs:domain ind:EpaComplianceReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetCardId rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Id' ;
    rdfs:comment 'Unique identifier for the fleet card record. Primary key.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetCardAccountId rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Account Id' ;
    rdfs:comment 'Reference to the parent fleet card account that this individual card belongs to. Links to the fleet_card_account product.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetCardAccount .

ind:authorizedFuelGrades rdf:type rdf:Property ;
    rdfs:label 'Authorized Fuel Grades' ;
    rdfs:comment 'Comma-separated list of fuel grades that this fleet card is authorized to purchase (e.g., regular, mid-grade, premium, diesel). Used to enforce fuel type restrictions at the pump.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when the fleet card was permanently cancelled and removed from service. Nullable if the card is still active or suspended.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation of why the fleet card was cancelled (e.g., vehicle sold, driver terminated, account closed). Nullable if card is not cancelled.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardFormat rdf:type rdf:Property ;
    rdfs:label 'Card Format' ;
    rdfs:comment 'The physical format and technology of the fleet card: magnetic stripe, chip (EMV), RFID, contactless (NFC), or hybrid (multiple technologies).' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'The unique RFID fleet card number embossed or encoded on the physical card. Used for transaction authorization at fuel pumps.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardReplacementReason rdf:type rdf:Property ;
    rdfs:label 'Card Replacement Reason' ;
    rdfs:comment 'Reason why this fleet card was issued as a replacement for a previous card. Tracks the history of card reissuance events. [ENUM-REF-CANDIDATE: lost|stolen|damaged|expired|compromised|upgrade|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardStatus rdf:type rdf:Property ;
    rdfs:label 'Card Status' ;
    rdfs:comment 'Current lifecycle status of the fleet card indicating whether it is active and authorized for use, or inactive due to suspension, loss, theft, expiration, or cancellation.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Classification of the fleet card indicating its intended use: vehicle-specific, driver-specific, universal (any vehicle/driver), temporary, emergency, or contractor card.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailySpendLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Spend Limit Amount' ;
    rdfs:comment 'Maximum dollar amount that can be spent per day using this fleet card. Used for budget control and fraud prevention. Nullable if no limit is set.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum number of fuel transactions allowed per day using this fleet card. Used to detect and prevent fraudulent activity. Nullable if no limit is set.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekRestrictions rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Restrictions' ;
    rdfs:comment 'Days of the week when this fleet card is authorized for use (e.g., Monday-Friday for weekday-only vehicles). Formatted as comma-separated day names or codes. Nullable if no day restrictions apply.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyDiscountEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Discount Eligible Flag' ;
    rdfs:comment 'Indicates whether transactions using this fleet card are eligible for loyalty-linked fuel discount redemptions. True if eligible, false if excluded from loyalty programs.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchantCategoryRestrictions rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Restrictions' ;
    rdfs:comment 'Comma-separated list of merchant category codes (MCC) where this fleet card is authorized or restricted. Used to limit card usage to fuel purchases only or allow additional categories like maintenance.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerPromptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Odometer Prompt Required Flag' ;
    rdfs:comment 'Indicates whether the driver must enter the vehicle odometer reading at the pump when using this fleet card. True if odometer entry is mandatory, false otherwise.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perFillVolumeCapGallons rdf:type rdf:Property ;
    rdfs:label 'Per Fill Volume Cap Gallons' ;
    rdfs:comment 'Maximum number of gallons that can be purchased in a single transaction using this fleet card. Used to prevent fraud and enforce fueling limits. Nullable if no cap is set.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pinEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Enabled Flag' ;
    rdfs:comment 'Indicates whether a PIN is required for transactions using this fleet card. True if PIN authentication is enabled, false if card can be used without PIN.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinLastChangedDate rdf:type rdf:Property ;
    rdfs:label 'Pin Last Changed Date' ;
    rdfs:comment 'The date when the PIN for this fleet card was last changed or reset. Used for security auditing and PIN rotation policy enforcement.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Replaced Card Number' ;
    rdfs:comment 'The card number of the previous fleet card that this card replaces. Used to maintain card replacement history and link transactions across card generations. Nullable if this is the original card.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTechnologyType rdf:type rdf:Property ;
    rdfs:label 'Rfid Technology Type' ;
    rdfs:comment 'The type of RFID technology used in the fleet card: passive (no battery, powered by reader), active (battery-powered), or semi-passive (battery-assisted passive).' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date when the fleet card was suspended. Nullable if the card has never been suspended or is currently active.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text explanation of why the fleet card was suspended (e.g., suspected fraud, policy violation, vehicle out of service). Nullable if card is not suspended.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayRestrictions rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Restrictions' ;
    rdfs:comment 'Time windows when this fleet card is authorized for use (e.g., 06:00-22:00 for day-shift drivers). Formatted as comma-separated time ranges. Nullable if no time restrictions apply.' ;
    rdfs:domain ind:FleetCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Account manager associate oversees fleet card accounts; required for account audit and billing responsibility reports.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date when the fleet card account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date when the fleet card account was first opened and activated for use.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeCardsCount rdf:type rdf:Property ;
    rdfs:label 'Active Cards Count' ;
    rdfs:comment 'Current count of active fleet cards under this account that are authorized for transactions.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the fleet card account contract automatically renews upon expiration.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month (1-31) when the billing cycle closes and invoices are generated for this fleet account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'Two-letter state or province code for the billing address.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardProgramType rdf:type rdf:Property ;
    rdfs:label 'Card Program Type' ;
    rdfs:comment 'Type of fleet card program under which this account operates (proprietary store-branded, WEX, Voyager, Mastercard Fleet, Visa Fleet, Fleet One).' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date when the current fleet card contract or agreement expires and requires renewal.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit limit extended to the fleet account for fuel purchases and related transactions.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionLimitCount rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit Count' ;
    rdfs:comment 'Maximum number of fuel transactions allowed per card per day under this account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyVolumeLimitGallons rdf:type rdf:Property ;
    rdfs:label 'Daily Volume Limit Gallons' ;
    rdfs:comment 'Maximum total fuel volume (in gallons) that can be purchased per card per day under this account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePerGallon rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Per Gallon' ;
    rdfs:comment 'Per-gallon discount rate (in currency units) applied to fuel purchases for this fleet account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountTier rdf:type rdf:Property ;
    rdfs:label 'Discount Tier' ;
    rdfs:comment 'Pricing tier or discount level assigned to the fleet account based on volume commitments or negotiated contracts.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetOperatorName rdf:type rdf:Property ;
    rdfs:label 'Fleet Operator Name' ;
    rdfs:comment 'Legal or business name of the commercial fleet operator or company holding this account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Linked Flag' ;
    rdfs:comment 'Indicates whether this fleet account is linked to the retailer\'s loyalty program for additional fuel discount redemptions.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due (e.g., Net 30, Net 15).' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pin Required Flag' ;
    rdfs:comment 'Indicates whether a PIN is required for all card transactions under this account for enhanced security.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled Flag' ;
    rdfs:comment 'Indicates whether the fleet cards under this account use RFID technology for contactless pump authorization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the fleet operator, used for tax reporting and compliance.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCardsIssued rdf:type rdf:Property ;
    rdfs:label 'Total Cards Issued' ;
    rdfs:comment 'Total number of individual fleet cards issued under this account across all vehicles and drivers.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weeklySpendingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Weekly Spending Limit Amount' ;
    rdfs:comment 'Maximum total spending allowed per card per week under this account.' ;
    rdfs:domain ind:FleetCardAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultFuelCarrierId rdf:type rdf:Property ;
    rdfs:label 'Default Fuel Carrier Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier. Business justification: Fuel procurement contracts assign a primary carrier per fuel center; this FK supports carrier performance and contract compliance reporting.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:fulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.node. Business justification: Store Operations Dashboard combines fuel and grocery metrics; linking fuel_center to its fulfillment node enables unified reporting of sales, inventory, and labor.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:managerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Manager Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Required for Fuel Center Manager staffing report; each center has a manager associate for labor budgeting and compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the fuel center location. First line of the physical site address including street number and name.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information for the fuel center location. Optional field for suite, building, or additional location details.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeFuelAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Alternative Fuel Available Flag' ;
    rdfs:comment 'Indicates whether alternative fuels such as E85, biodiesel, or compressed natural gas are available at this fuel center. True if any alternative fuel is offered.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canopyConfiguration rdf:type rdf:Property ;
    rdfs:label 'Canopy Configuration' ;
    rdfs:comment 'Physical canopy structure configuration covering the fuel dispensing area. Describes the overhead shelter arrangement for customer protection.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carWashAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Car Wash Available Flag' ;
    rdfs:comment 'Indicates whether a car wash facility is available at this fuel center location. True if car wash services are offered.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convenienceStoreAttachedFlag rdf:type rdf:Property ;
    rdfs:label 'Convenience Store Attached Flag' ;
    rdfs:comment 'Indicates whether a convenience store or retail shop is physically attached to the fuel center. True if convenience store is present.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dieselAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Diesel Available Flag' ;
    rdfs:comment 'Indicates whether diesel fuel is available at this fuel center. True if diesel is offered, false otherwise.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispenserCount rdf:type rdf:Property ;
    rdfs:label 'Dispenser Count' ;
    rdfs:comment 'Total number of individual fuel dispensers (pumps) at the fuel center. Represents the maximum number of vehicles that can fuel simultaneously.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational status of the fuel center facility. Indicates whether the location is actively serving customers or in a non-operational state.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCenterCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Center Code' ;
    rdfs:comment 'Unique business identifier code for the fuel center. Externally-known alphanumeric code used in operational systems, reporting, and vendor communications. Format: FC followed by 6 digits.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCenterName rdf:type rdf:Property ;
    rdfs:label 'Fuel Center Name' ;
    rdfs:comment 'Business name or designation of the fuel center location. Human-readable identifier used for operational reference and customer communication.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelGradesOffered rdf:type rdf:Property ;
    rdfs:label 'Fuel Grades Offered' ;
    rdfs:comment 'Comma-separated list of fuel grades available at this fuel center. Examples: Regular 87, Mid-Grade 89, Premium 91, Diesel, E85. Defines the product mix for pricing and inventory management.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEquipmentMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Equipment Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance performed on fuel dispensing equipment. Used for equipment lifecycle management and reliability tracking.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyDiscountEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Discount Enabled Flag' ;
    rdfs:comment 'Indicates whether the fuel center participates in the loyalty program fuel discount redemption. True if loyalty-linked fuel discounts are available at this location.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required regulatory or safety inspection. Used for compliance planning and operational scheduling.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the fuel center on weekdays (Monday through Friday). Format: HH:MM-HH:MM or 24/7 for continuous operation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for the fuel center on weekends (Saturday and Sunday). Format: HH:MM-HH:MM or 24/7 for continuous operation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the fuel center location. Used for operational communication and customer inquiries.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether the fuel center is integrated with the store POS system for payment processing and transaction reconciliation. True if POS integration is active.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiumFuelAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Fuel Available Flag' ;
    rdfs:comment 'Indicates whether premium grade fuel is available at this fuel center. True if premium fuel is offered, false otherwise.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pumpIslandCount rdf:type rdf:Property ;
    rdfs:label 'Pump Island Count' ;
    rdfs:comment 'Total number of pump islands at the fuel center. Each island typically contains multiple dispensers. Used for capacity planning and operational analysis.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidFleetCardEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Fleet Card Enabled Flag' ;
    rdfs:comment 'Indicates whether the fuel center supports RFID-enabled fleet card transactions for commercial customers. True if RFID fleet card processing is available.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statePetroleumLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'State Petroleum License Number' ;
    rdfs:comment 'State-issued license number authorizing the fuel center to sell petroleum products. Required for regulatory compliance and operational authorization.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter state or province code for the fuel center location. ISO 3166-2 standard subdivision code.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tankCount rdf:type rdf:Property ;
    rdfs:label 'Tank Count' ;
    rdfs:comment 'Total number of underground storage tanks at the fuel center. Used for inventory management, compliance tracking, and capacity planning.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStorageCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Total Storage Capacity Gallons' ;
    rdfs:comment 'Total fuel storage capacity across all underground tanks at the fuel center, measured in gallons. Represents maximum inventory holding capacity.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:twentyFourHourOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Operation Flag' ;
    rdfs:comment 'Indicates whether the fuel center operates 24 hours per day, 7 days per week. True for continuous operation, false for limited hours.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ustRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Ust Registration Number' ;
    rdfs:comment 'Underground Storage Tank registration number issued by state or federal authorities. Required for environmental compliance and tank monitoring.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Unique identifier for the fuel delivery record. Primary key for the fuel delivery lifecycle from order placement through receipt confirmation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driverAssociateId rdf:type rdf:Property ;
    rdfs:label 'Driver Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Needed for driver performance, safety incident, and EPA reporting; delivery driver is an associate employee.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:supplierSiteId rdf:type rdf:Property ;
    rdfs:label 'Supplier Site Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier_site. Business justification: TRACEABILITY: Delivery manifests record the exact supplier site of origin for tax, traceability, and inventory reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierSite .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the fuel delivery occurred. Used for reconciliation and variance analysis against scheduled date.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDeliveryEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery End Timestamp' ;
    rdfs:comment 'Precise timestamp when the fuel delivery was completed. Marks the end of the physical fuel transfer and receipt confirmation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDeliveryStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the fuel delivery began. Marks the start of the physical fuel transfer process.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost of the fuel delivery in USD. Includes fuel product cost and may include transportation charges.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerGallon rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gallon' ;
    rdfs:comment 'Unit cost per gallon of fuel delivered in USD. Used for inventory valuation and margin analysis.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the fuel delivery. Tracks the delivery from scheduling through completion or cancellation. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|in_progress|completed|cancelled|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributorName rdf:type rdf:Property ;
    rdfs:label 'Distributor Name' ;
    rdfs:comment 'Name of the fuel distributor or supplier company. Business name of the vendor fulfilling the delivery.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Captured' ;
    rdfs:comment 'Indicates whether the driver signature was captured electronically or on paper at delivery completion. Used for proof of delivery validation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Epa Compliance Verified' ;
    rdfs:comment 'Indicates whether EPA emissions and environmental compliance was verified for the delivery. Tracks adherence to underground storage tank regulations.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedGallonsOrdered rdf:type rdf:Property ;
    rdfs:label 'Estimated Gallons Ordered' ;
    rdfs:comment 'Estimated volume of fuel ordered in gallons. Represents the planned quantity at the time of order placement.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Separate freight or transportation charge for the delivery in USD. May be itemized separately from fuel product cost.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossGallonsDelivered rdf:type rdf:Property ;
    rdfs:label 'Gross Gallons Delivered' ;
    rdfs:comment 'Gross volume of fuel delivered in gallons before temperature correction. Raw measurement from the delivery truck meter.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netGallonsDelivered rdf:type rdf:Property ;
    rdfs:label 'Net Gallons Delivered' ;
    rdfs:comment 'Net volume of fuel delivered in gallons after temperature correction to 60°F. Temperature-adjusted volume used for inventory and billing.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderConfirmationReference rdf:type rdf:Property ;
    rdfs:label 'Order Confirmation Reference' ;
    rdfs:comment 'Confirmation reference number from the fuel order placement system. Links the delivery to the original replenishment order.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postDeliveryTankLevelGallons rdf:type rdf:Property ;
    rdfs:label 'Post Delivery Tank Level Gallons' ;
    rdfs:comment 'Fuel tank level in gallons after the delivery was completed. Final measurement from Automatic Tank Gauge (ATG) system used for reconciliation and shrink analysis.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preDeliveryTankLevelGallons rdf:type rdf:Property ;
    rdfs:label 'Pre Delivery Tank Level Gallons' ;
    rdfs:comment 'Fuel tank level in gallons before the delivery began. Baseline measurement from Automatic Tank Gauge (ATG) system used for reconciliation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityTestPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Test Passed' ;
    rdfs:comment 'Indicates whether the delivered fuel passed quality testing at receipt. Used for quality assurance and compliance tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDeliveryEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery End Time' ;
    rdfs:comment 'End of the scheduled delivery time window. Defines the latest expected time for delivery completion.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDeliveryStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Start Time' ;
    rdfs:comment 'Beginning of the scheduled delivery time window. Precise timestamp for when the delivery is expected to begin.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Temperature of the fuel at the time of delivery in degrees Fahrenheit. Used for temperature correction calculations to determine net gallons.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'External delivery ticket number issued by the carrier or distributor. Serves as the business identifier for the delivery transaction.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckNumber rdf:type rdf:Property ;
    rdfs:label 'Truck Number' ;
    rdfs:comment 'Identification number of the delivery truck or tanker. Vehicle identifier for tracking and compliance purposes.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeId rdf:type rdf:Property ;
    rdfs:label 'Grade Id' ;
    rdfs:comment 'Unique identifier for the fuel grade. Primary key for the fuel grade reference catalog.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grade .

ind:apiGravity rdf:type rdf:Property ;
    rdfs:label 'Api Gravity' ;
    rdfs:comment 'Measure of how heavy or light a petroleum liquid is compared to water. Higher API gravity indicates lighter, less dense fuel. Typical range: 30-45 for gasoline, 30-42 for diesel. Used for inventory volume-to-weight conversions and quality control.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biodieselBlendPercentage rdf:type rdf:Property ;
    rdfs:label 'Biodiesel Blend Percentage' ;
    rdfs:comment 'Percentage of biodiesel (fatty acid methyl esters) blended into diesel fuel. Common blends include B5 (5%), B10 (10%), B20 (20%). Null for gasoline and non-diesel products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonIntensityScore rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Score' ;
    rdfs:comment 'Lifecycle greenhouse gas emissions intensity measured in grams of CO2 equivalent per megajoule of energy. Used for Low Carbon Fuel Standard (LCFS) compliance in California and other jurisdictions. Lower scores indicate cleaner fuels.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cetaneNumber rdf:type rdf:Property ;
    rdfs:label 'Cetane Number' ;
    rdfs:comment 'Measure of the combustion quality of diesel fuel during compression ignition. Higher cetane numbers indicate shorter ignition delay and better combustion. Typical range: 40-55. Null for gasoline and non-diesel products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Hexadecimal color code used for visual identification of the fuel grade on pump displays, signage, and digital interfaces. Standardized colors help customers quickly identify fuel types (e.g., green for diesel, yellow for mid-grade).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Integer value controlling the display order of fuel grades on pump interfaces, POS screens, and customer-facing applications. Lower values appear first. Typically ordered by octane rating or customer preference (e.g., 1=Regular, 2=Mid-Grade, 3=Premium).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:energyContentBtuPerGallon rdf:type rdf:Property ;
    rdfs:label 'Energy Content Btu Per Gallon' ;
    rdfs:comment 'Energy content of the fuel measured in British Thermal Units per gallon. Gasoline typically 115,000-125,000 BTU/gal; diesel typically 130,000-138,000 BTU/gal; E85 approximately 81,000 BTU/gal. Used for energy equivalency calculations and fleet efficiency analysis.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFuelCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Fuel Category' ;
    rdfs:comment 'EPA regulatory classification of the fuel product for emissions compliance and reporting. Categories include conventional gasoline, reformulated gasoline (RFG), ULSD, renewable diesel, and alternative fuels. Used for environmental compliance tracking.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethanolBlendPercentage rdf:type rdf:Property ;
    rdfs:label 'Ethanol Blend Percentage' ;
    rdfs:comment 'Percentage of ethanol blended into the gasoline product. Standard unleaded typically contains up to 10% (E10); E85 contains 51-83% ethanol. Null for diesel and non-ethanol products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flashPointFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Flash Point Fahrenheit' ;
    rdfs:comment 'Lowest temperature at which vapors of the fuel will ignite when exposed to an ignition source. Critical safety parameter for storage and handling. Gasoline typically -45°F; diesel typically 125-180°F.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetCardAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Accepted Flag' ;
    rdfs:comment 'Boolean flag indicating whether this fuel grade is available for purchase using RFID-enabled fleet cards and commercial fuel cards. True if accepted for fleet transactions; False if restricted to retail consumer purchases only.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the fuel grade within the system (e.g., REG87, MID89, PREM93, DSL, E85, DEF). Used for operational lookup and integration with POS and pricing systems.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Detailed textual description of the fuel grade including key characteristics, intended use, performance benefits, and any special handling or regulatory notes. Used for customer communication, training materials, and internal documentation.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeName rdf:type rdf:Property ;
    rdfs:label 'Grade Name' ;
    rdfs:comment 'Full business name of the fuel grade as displayed to customers and used in reporting (e.g., Regular Unleaded, Mid-Grade, Premium, Diesel, E85 Flex Fuel, Diesel Exhaust Fluid).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Status' ;
    rdfs:comment 'Current lifecycle status of the fuel grade. Active grades are available for sale; inactive grades are temporarily unavailable; discontinued grades are permanently retired; seasonal grades are available only during specific periods (e.g., winter blends).' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeType rdf:type rdf:Property ;
    rdfs:label 'Grade Type' ;
    rdfs:comment 'High-level classification of the fuel product type. Gasoline includes unleaded grades; diesel includes standard and bio-diesel blends; alternative fuel includes E85, CNG, electric; additive includes DEF and other supplemental products.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Department of Transportation hazardous materials classification code for the fuel grade. Used for transportation, storage, and emergency response planning. Example: UN1203 for gasoline, UN1202 for diesel fuel.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:octaneRating rdf:type rdf:Property ;
    rdfs:label 'Octane Rating' ;
    rdfs:comment 'The octane number representing the fuel\'s resistance to knocking or pinging during combustion. Typical values: 87 (Regular), 89 (Mid-Grade), 91-93 (Premium). Null for non-gasoline products such as diesel or DEF.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reformulatedGasolineIndicator rdf:type rdf:Property ;
    rdfs:label 'Reformulated Gasoline Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the fuel grade is reformulated gasoline designed to reduce smog-forming and toxic air pollutants. RFG is required in certain metropolitan areas with severe ozone pollution. True if RFG; False otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Renewable Identification Number' ;
    rdfs:comment '38-character unique identifier assigned to batches of renewable fuel under the EPA Renewable Fuel Standard. Used to track and trade renewable fuel credits for compliance with federal mandates. Null for non-renewable fuels.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfurContentPpm rdf:type rdf:Property ;
    rdfs:label 'Sulfur Content Ppm' ;
    rdfs:comment 'Sulfur content measured in parts per million. EPA Ultra-Low Sulfur Diesel (ULSD) standard requires maximum 15 ppm. Gasoline typically contains less than 10 ppm under Tier 3 standards. Critical for emissions compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierProductCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Product Code' ;
    rdfs:comment 'Product code or SKU used by the primary fuel supplier or refiner to identify this grade in purchase orders, invoices, and EDI transactions. Facilitates supply chain integration and vendor reconciliation.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Code identifying the applicable federal and state excise tax category for the fuel grade. Different grades and blends may have different tax rates (e.g., gasoline vs diesel vs alternative fuels). Used for tax calculation and regulatory reporting.' ;
    rdfs:domain ind:Grade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment '12-digit Universal Product Code used for point-of-sale scanning and inventory tracking. Aligns with GS1 standards for retail fuel products sold in packaged form or tracked via loyalty systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winterBlendIndicator rdf:type rdf:Property ;
    rdfs:label 'Winter Blend Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the fuel grade is formulated as a winter blend with higher Reid Vapor Pressure (RVP) to improve cold-weather starting and performance. True if winter blend; False if summer blend or year-round formulation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceId rdf:type rdf:Property ;
    rdfs:label 'Price Id' ;
    rdfs:comment 'Unique identifier for the fuel price record. Primary key for the fuel_price product.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'FK to pricing.price_zone' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Identifier of the promotional campaign associated with this price record. Links to promotion master data for campaign tracking and ROI analysis. Null for non-promotional pricing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'Net change in street price per gallon (current price minus prior price). Positive values indicate price increases, negative values indicate decreases.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeTriggerSource rdf:type rdf:Property ;
    rdfs:label 'Change Trigger Source' ;
    rdfs:comment 'System or process that initiated the price change. Automated competitive pricing feed, rack index threshold alert, manual manager decision, centralized pricing system recommendation, or promotional calendar event.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceReference rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Reference' ;
    rdfs:comment 'Reference price from competitive intelligence feed representing nearby competitor pricing. Used to justify competitive response price changes and maintain market positioning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Date and time when this fuel price becomes active and is displayed on signage and charged at the pump. Supports intraday price changes in response to competitive moves or rack price fluctuations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time when this fuel price is superseded by a new price record. Null for the current active price. Enables complete price history reconstruction and temporal queries.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marginPerGallon rdf:type rdf:Property ;
    rdfs:label 'Margin Per Gallon' ;
    rdfs:comment 'Gross profit margin per gallon calculated as street price minus cost per gallon. Key metric for fuel center profitability and pricing strategy effectiveness.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLoyaltyDiscountCents rdf:type rdf:Property ;
    rdfs:label 'Max Loyalty Discount Cents' ;
    rdfs:comment 'Maximum cents-per-gallon discount that can be applied through loyalty program redemption for this fuel grade. Caps the discount to protect margin floors and prevent negative pricing.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Pos Sync Status' ;
    rdfs:comment 'Status of price synchronization to the fuel center POS system and pump controllers. Confirmed indicates successful deployment, failed indicates synchronization error requiring intervention.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pos Sync Timestamp' ;
    rdfs:comment 'Date and time when the price change was successfully synchronized to the POS system and pump controllers. Critical for reconciling price effective time with actual system deployment.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorStreetPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Street Price' ;
    rdfs:comment 'Previous street price per gallon before this price change event. Used for price change magnitude analysis and competitive response tracking.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Flag' ;
    rdfs:comment 'Indicates whether this price is part of a temporary promotional campaign. True for limited-time offers, grand opening specials, or competitive market entry pricing.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rackPriceIndex rdf:type rdf:Property ;
    rdfs:label 'Rack Price Index' ;
    rdfs:comment 'Wholesale terminal rack price index at the time of this price record. Used as a benchmark for cost-based pricing strategies and margin protection rules.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryPostingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Posting Required Flag' ;
    rdfs:comment 'Indicates whether this price change requires regulatory notification or public posting under state fuel pricing transparency laws. True triggers compliance workflow for jurisdictions with price-posting requirements.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryPostingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Posting Timestamp' ;
    rdfs:comment 'Date and time when the price change was reported to regulatory authorities or posted to public transparency portals. Required for compliance audit trail in regulated jurisdictions.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:streetPrice rdf:type rdf:Property ;
    rdfs:label 'Street Price' ;
    rdfs:comment 'Customer-facing retail price per gallon displayed on the fuel center sign and charged at the pump. This is the base price before any loyalty discounts or promotions.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'System-generated unique identifier for each fuel tax record.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicability rdf:type rdf:Property ;
    rdfs:label 'Applicability' ;
    rdfs:comment 'Specifies whether the tax applies at the point of sale, during delivery, or both.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Timestamp when the most recent audit was performed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the tax record complies with current regulatory requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exempt Reason Code' ;
    rdfs:comment 'Code representing the reason for tax exemption (e.g., SNAP, EBT).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exempt Reason Description' ;
    rdfs:comment 'Detailed description of the exemption reason.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Exempt Transaction Flag' ;
    rdfs:comment 'True if the tax does not apply to the transaction under the exemption rules.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Exemption Rule Description' ;
    rdfs:comment 'Narrative description of rules that qualify a transaction for tax exemption.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineDay rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Day' ;
    rdfs:comment 'Day of the month by which the tax filing must be submitted.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idNumber rdf:type rdf:Property ;
    rdfs:label 'Id Number' ;
    rdfs:comment 'Government-issued identifier for the tax (e.g., state tax ID).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Standard code identifying the jurisdiction (e.g., state abbreviation, FIPS county code).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Level of government imposing the tax: federal, state, county, or city.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the jurisdiction imposing the tax.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEffectiveChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Effective Change Timestamp' ;
    rdfs:comment 'Timestamp when the effective date or rate was last modified.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the tax rate (e.g., USD).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Timestamp' ;
    rdfs:comment 'Exact timestamp when the tax rate became effective.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratePerGallon rdf:type rdf:Property ;
    rdfs:label 'Rate Per Gallon' ;
    rdfs:comment 'Monetary amount of tax charged per gallon of fuel, expressed in the applicable currency.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAccount rdf:type rdf:Property ;
    rdfs:label 'Remittance Account' ;
    rdfs:comment 'Internal finance account used for remitting the tax to the authority.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Remittance Frequency' ;
    rdfs:comment 'How often the tax must be remitted to the governing authority.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current lifecycle status of the tax record.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax, such as excise, environmental surcharge, underground storage tank (UST) fee, or other applicable tax.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for each fuel dispensing transaction event. Primary key for the fuel transaction record.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelTransaction .

ind:methodId rdf:type rdf:Property ;
    rdfs:label 'Method Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_method. Business justification: REQUIRED: Link fuel sale to stored payment method for refunds, tokenization, and loyalty reward calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:primaryFuelAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Fuel Associate Id' ;
    rdfs:comment 'Driver identifier captured during fleet card transaction. Used for driver-level fuel consumption reporting and expense allocation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Payment authorization code received from payment processor. Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carwashBundledFlag rdf:type rdf:Property ;
    rdfs:label 'Carwash Bundled Flag' ;
    rdfs:comment 'Indicates whether a carwash service was bundled with this fuel purchase. Used for cross-sell analytics and bundled promotion tracking.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Reporting Flag' ;
    rdfs:comment 'Indicates whether this transaction requires inclusion in EPA emissions compliance reporting. Used for regulatory reporting and environmental compliance tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:federalExciseTax rdf:type rdf:Property ;
    rdfs:label 'Federal Excise Tax' ;
    rdfs:comment 'Federal excise tax amount collected on this fuel transaction. Required for IRS Form 720 quarterly federal excise tax reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Number' ;
    rdfs:comment 'Fleet card number used for commercial vehicle fuel purchases. Supports RFID fleet card transaction processing and fleet account reconciliation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelDiscountCentsPerGallon rdf:type rdf:Property ;
    rdfs:label 'Fuel Discount Cents Per Gallon' ;
    rdfs:comment 'Discount amount in cents per gallon applied through loyalty program redemption. Used for loyalty-linked fuel discount reconciliation and program cost tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gallonsDispensed rdf:type rdf:Property ;
    rdfs:label 'Gallons Dispensed' ;
    rdfs:comment 'Volume of fuel dispensed in gallons. Primary measure for volume sales reporting, inventory depletion, and tank level management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSaleAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sale Amount' ;
    rdfs:comment 'Total sale amount before any discounts or loyalty redemptions are applied. Calculated as gallons dispensed multiplied by unit price.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localExciseTax rdf:type rdf:Property ;
    rdfs:label 'Local Excise Tax' ;
    rdfs:comment 'Local or municipal excise tax amount collected on this fuel transaction where applicable.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyCardNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Number' ;
    rdfs:comment 'Customer loyalty card number used for this transaction. Links to customer loyalty profile for discount redemption and points accrual tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmountCharged rdf:type rdf:Property ;
    rdfs:label 'Net Amount Charged' ;
    rdfs:comment 'Final amount charged to the customer after all discounts are applied. This is the revenue recognized for the transaction.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Reference' ;
    rdfs:comment 'Reference number linking this fuel transaction to the corresponding POS system transaction record for payment reconciliation and receipt generation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepayFlag rdf:type rdf:Property ;
    rdfs:label 'Prepay Flag' ;
    rdfs:comment 'Indicates whether this was a prepay transaction where payment was authorized before fuel dispensing. Used for fraud prevention and payment processing workflow.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional campaign code applied to this transaction. Used for tracking effectiveness of fuel pricing promotions and temporary price reductions.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pumpNumber rdf:type rdf:Property ;
    rdfs:label 'Pump Number' ;
    rdfs:comment 'Physical pump identifier at the fuel center where fuel was dispensed. Used for equipment tracking and maintenance scheduling.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Unique receipt number printed for the customer. Used for customer service inquiries and transaction lookup.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateExciseTax rdf:type rdf:Property ;
    rdfs:label 'State Excise Tax' ;
    rdfs:comment 'State excise tax amount collected on this fuel transaction. Required for state-level fuel tax reporting and remittance.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Code' ;
    rdfs:comment 'Payment terminal identifier where the transaction was processed. Used for terminal reconciliation and equipment tracking.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current status of the fuel transaction in its lifecycle. Tracks whether transaction was successfully completed, voided, refunded, or failed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the fuel dispensing transaction occurred at the pump. Primary business event timestamp for volume sales reporting and reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per gallon at the time of transaction. Reflects current fuel grade pricing including any temporary price reductions or promotional pricing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Identification Number' ;
    rdfs:comment 'Vehicle identification number for fleet card transactions. Standard 17-character VIN used for fleet vehicle tracking and reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOdometerReading rdf:type rdf:Property ;
    rdfs:label 'Vehicle Odometer Reading' ;
    rdfs:comment 'Odometer reading captured at time of fleet card transaction. Used for fleet management reporting and mileage tracking.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the fuel inventory reconciliation record. Primary key for this entity.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryReconciliation .

ind:atgPhysicalVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Atg Physical Volume Gallons' ;
    rdfs:comment 'Physical inventory volume in gallons measured by the Automatic Tank Gauge (ATG) system at the end of the reconciliation period. Represents actual measured inventory in the tank.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atgSystemCode rdf:type rdf:Property ;
    rdfs:label 'Atg System Code' ;
    rdfs:comment 'Identifier of the ATG system or device that provided the physical volume reading. Used for equipment tracking and calibration audit trails.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTankTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Average Tank Temperature Fahrenheit' ;
    rdfs:comment 'Average fuel temperature in the tank during the reconciliation period measured in degrees Fahrenheit. Used for temperature compensation calculations and thermal expansion adjustments.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingBookVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Closing Book Volume Gallons' ;
    rdfs:comment 'Calculated book inventory volume in gallons at the end of the reconciliation period. Formula: opening_book_volume + total_deliveries - total_dispensed. Represents theoretical ending inventory.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Of Variance Amount' ;
    rdfs:comment 'Financial impact of the inventory variance calculated by multiplying variance volume by the weighted average cost per gallon for the period. Used for shrink cost reporting and Profit and Loss (P&L) impact analysis.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Count' ;
    rdfs:comment 'Number of fuel delivery transactions received during the reconciliation period. Used to validate delivery volume totals and identify delivery frequency patterns.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelGradeCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade Code' ;
    rdfs:comment 'Code representing the fuel grade or product type stored in the tank (e.g., Regular 87, Premium 93, Diesel). Standardized fuel product classification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Free-text notes documenting investigation findings, root cause analysis, corrective actions taken, and resolution details for variances requiring investigation.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Boolean indicator whether the variance requires formal investigation by operations or compliance teams. True triggers investigation workflow and root cause analysis.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakDetectionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether this reconciliation meets EPA Underground Storage Tank (UST) leak detection compliance requirements. True indicates compliance, False indicates potential leak or non-compliance requiring immediate action.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBookVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Opening Book Volume Gallons' ;
    rdfs:comment 'Book inventory volume in gallons at the start of the reconciliation period. Represents the theoretical starting inventory based on prior period closing balance.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'Method used to perform the inventory reconciliation. Manual indicates human-performed reconciliation, automated indicates system-generated reconciliation, hybrid indicates combination of both.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period End Date' ;
    rdfs:comment 'End date of the inventory reconciliation period. Defines the close of the measurement window for this reconciliation cycle.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period Start Date' ;
    rdfs:comment 'Start date of the inventory reconciliation period. Defines the beginning of the measurement window for this reconciliation cycle.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Timestamp' ;
    rdfs:comment 'Date and time when the physical inventory reconciliation was performed and recorded. Primary business event timestamp for this reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shrinkCategory rdf:type rdf:Property ;
    rdfs:label 'Shrink Category' ;
    rdfs:comment 'Classification of the inventory variance into business-defined shrink categories based on variance magnitude and direction. Used for shrink management reporting and escalation workflows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCompensationAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compensation Applied Flag' ;
    rdfs:comment 'Boolean indicator whether temperature compensation was applied to volume measurements to adjust for thermal expansion/contraction of fuel. True indicates volumes are temperature-corrected to standard conditions.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDeliveriesVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Total Deliveries Volume Gallons' ;
    rdfs:comment 'Total volume of fuel delivered to the tank during the reconciliation period in gallons. Sum of all delivery receipts for this tank and fuel grade.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDispensedVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Total Dispensed Volume Gallons' ;
    rdfs:comment 'Total volume of fuel dispensed from the tank during the reconciliation period in gallons. Sum of all Point of Sale (POS) transactions for this tank and fuel grade.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Exceeded Flag' ;
    rdfs:comment 'Boolean indicator whether the variance exceeds the acceptable threshold defined by business policy or EPA leak detection requirements. True indicates variance requires investigation.' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Variance Volume Gallons' ;
    rdfs:comment 'Inventory variance in gallons between book and physical inventory. Formula: atg_physical_volume - closing_book_volume. Positive values indicate overage (gain), negative values indicate shrink (loss).' ;
    rdfs:domain ind:InventoryReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterLevelInches rdf:type rdf:Property ;
    rdfs:label 'Water Level Inches' ;
    rdfs:comment 'Water level detected at the bottom of the tank measured in inches. Water accumulation can indicate tank integrity issues or contamination. Part of EPA compliance monitoring.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyFuelRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Fuel Redemption Id' ;
    rdfs:comment 'Unique identifier for the loyalty fuel redemption transaction. Primary key.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pumpId rdf:type rdf:Property ;
    rdfs:label 'Pump Id' ;
    rdfs:comment 'Identifier of the specific fuel pump where the redemption was processed.' ;
    rdfs:domain ind:Fuel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pump .

ind:discountExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Discount Expiration Date' ;
    rdfs:comment 'Date by which the fuel discount offer must be redeemed. Format: yyyy-MM-dd. Null if no expiration.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountRateCentsPerGallon rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Cents Per Gallon' ;
    rdfs:comment 'The discount rate applied to the fuel purchase, expressed in cents per gallon (e.g., 10 cents off per gallon).' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fleetCardNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Number Masked' ;
    rdfs:comment 'Masked fleet card number used for the transaction (e.g., last 4 digits only). Applicable for fleet card transactions tracked via Radio Frequency Identification (RFID).' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gallonsDiscounted rdf:type rdf:Property ;
    rdfs:label 'Gallons Discounted' ;
    rdfs:comment 'Total number of gallons of fuel to which the loyalty discount was applied during this transaction.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Loyalty program tier or membership level of the customer at the time of redemption (e.g., silver, gold, platinum). May influence discount eligibility or rate.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDiscountLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Limit Amount' ;
    rdfs:comment 'Maximum dollar amount of discount allowed per transaction based on loyalty program rules or promotional terms. Used to cap total discount.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxGallonsLimit rdf:type rdf:Property ;
    rdfs:label 'Max Gallons Limit' ;
    rdfs:comment 'Maximum number of gallons eligible for discount per transaction based on loyalty program rules or promotional terms.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Loyalty member\'s points balance immediately after this fuel discount redemption.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Loyalty member\'s points balance immediately before this fuel discount redemption.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Code' ;
    rdfs:comment 'Identifier of the Point of Sale (POS) terminal or pump controller that processed the redemption transaction.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionSource rdf:type rdf:Property ;
    rdfs:label 'Redemption Source' ;
    rdfs:comment 'Source or origin of the fuel discount being redeemed (e.g., loyalty points accumulated, promotional offer, partner reward program, credit card linked discount).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current status of the fuel discount redemption transaction in its lifecycle (completed, pending, reversed, failed, expired).' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the loyalty fuel discount was redeemed at the pump. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason for reversing or voiding the fuel discount redemption, if applicable. Null if redemption was not reversed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Receipt Number' ;
    rdfs:comment 'Receipt or confirmation number printed for the customer at the pump, linking the fuel purchase to the loyalty redemption.' ;
    rdfs:domain ind:LoyaltyFuelRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeEventId rdf:type rdf:Property ;
    rdfs:label 'Price Change Event Id' ;
    rdfs:comment 'Unique identifier for the fuel price change event. Primary key.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeTrigger rdf:type rdf:Property ;
    rdfs:label 'Change Trigger' ;
    rdfs:comment 'The business reason or trigger that initiated this price change event. Competitive response indicates reaction to competitor pricing, rack price movement indicates wholesale cost changes, promotional indicates marketing campaign, manual override indicates manager discretion, scheduled adjustment indicates planned periodic changes, cost recovery indicates margin protection.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorReferencePrice rdf:type rdf:Property ;
    rdfs:label 'Competitor Reference Price' ;
    rdfs:comment 'The competitor fuel price that was used as a reference or benchmark for this price change decision, if applicable. Used for competitive positioning analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business-facing unique identifier or sequence number for the price change event, used for audit and reference purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Loyalty Discount Applied' ;
    rdfs:comment 'Boolean flag indicating whether this price change includes or is related to a loyalty program fuel discount redemption structure.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newPrice rdf:type rdf:Property ;
    rdfs:label 'New Price' ;
    rdfs:comment 'The new fuel price per gallon that became effective with this price change event.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeNotes rdf:type rdf:Property ;
    rdfs:label 'Price Change Notes' ;
    rdfs:comment 'Free-text notes or comments from the approving manager or pricing analyst explaining the rationale, context, or special circumstances for this price change.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Change Percentage' ;
    rdfs:comment 'The percentage change in price calculated as ((new_price - prior_price) / prior_price) * 100. Used for margin and competitive analysis.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceSignUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Price Sign Update Timestamp' ;
    rdfs:comment 'The date and time when the fuel center price sign was updated to display the new price.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priceSignUpdated rdf:type rdf:Property ;
    rdfs:label 'Price Sign Updated' ;
    rdfs:comment 'Boolean flag indicating whether the physical or digital price sign at the fuel center has been updated to reflect the new price. Required for customer transparency and regulatory compliance.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Price' ;
    rdfs:comment 'The fuel price per gallon that was in effect immediately before this price change event.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rackPrice rdf:type rdf:Property ;
    rdfs:label 'Rack Price' ;
    rdfs:comment 'The wholesale terminal or rack price for this fuel grade at the time of the price change. Used for margin analysis and cost-based pricing decisions.' ;
    rdfs:domain ind:PriceChangeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this price change was reviewed for compliance with state and federal fuel pricing regulations, including price gouging laws and EPA requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant' ;
    rdfs:comment 'Indicates whether the pump meets ADA accessibility requirements for customers with disabilities, including reach range, controls placement, and signage.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifiedAccuracy rdf:type rdf:Property ;
    rdfs:label 'Certified Accuracy' ;
    rdfs:comment 'Certified measurement accuracy of the fuel dispenser meter as a decimal percentage (e.g., 0.9995 represents 99.95% accuracy). Must meet EPA and state weights and measures standards.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyShutoffType rdf:type rdf:Property ;
    rdfs:label 'Emergency Shutoff Type' ;
    rdfs:comment 'Type of emergency fuel shutoff mechanism installed on the pump. Manual requires physical button activation. Automatic triggers on impact or fire detection. Both provides redundant safety systems.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Certification Number' ;
    rdfs:comment 'EPA-issued certification number for the fuel dispenser equipment, verifying compliance with federal emissions and vapor recovery standards.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCardEnabled rdf:type rdf:Property ;
    rdfs:label 'Fleet Card Enabled' ;
    rdfs:comment 'Indicates whether the pump supports RFID fleet card transactions for commercial fleet customers.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelGradeCapacity rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade Capacity' ;
    rdfs:comment 'Number of different fuel grades (octane levels or fuel types) that this pump can dispense. Common values are 3 (regular, mid-grade, premium) or 4 (including diesel).' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date when the fuel dispenser meter was last calibrated and certified by a licensed technician. Required for EPA compliance and state weights and measures regulations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Integration Enabled' ;
    rdfs:comment 'Indicates whether the pump supports loyalty program integration for fuel discount redemptions and rewards point accrual at the pump.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the fuel dispenser equipment.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer model number or designation for the fuel dispenser unit.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration and certification of the fuel dispenser meter. Typically required annually or per state regulation.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on the fuel dispenser.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nozzleCount rdf:type rdf:Property ;
    rdfs:label 'Nozzle Count' ;
    rdfs:comment 'Number of fuel nozzles (hoses) available on this dispenser unit. Typically ranges from 1 to 8 nozzles per pump.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTerminalType rdf:type rdf:Property ;
    rdfs:label 'Payment Terminal Type' ;
    rdfs:comment 'Type of payment technology supported by the pump terminal. RFID supports Radio Frequency Identification fleet cards. EMV supports chip-based credit/debit cards. NFC supports contactless mobile payments. Magnetic stripe supports legacy swipe cards. Hybrid supports multiple technologies.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled' ;
    rdfs:comment 'Indicates whether the pump is integrated with the store POS system for real-time transaction processing and inventory management.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prepayOnlyMode rdf:type rdf:Property ;
    rdfs:label 'Prepay Only Mode' ;
    rdfs:comment 'Indicates whether the pump is configured to require prepayment before fuel dispensing, typically enabled during high-risk hours to prevent drive-offs.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteShutoffCapable rdf:type rdf:Property ;
    rdfs:label 'Remote Shutoff Capable' ;
    rdfs:comment 'Indicates whether the pump can be remotely disabled from the fuel center control console or store POS system in emergency situations.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'State Certification Number' ;
    rdfs:comment 'State weights and measures certification number for the fuel dispenser meter accuracy, issued by the state regulatory authority.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaporRecoverySystem rdf:type rdf:Property ;
    rdfs:label 'Vapor Recovery System' ;
    rdfs:comment 'Type of EPA-mandated vapor recovery system installed on the pump. Stage 1 captures vapors during fuel delivery to underground tanks. Stage 2 captures vapors during customer fueling. Required for EPA emissions compliance.' ;
    rdfs:domain ind:Pump ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pumpMaintenanceId rdf:type rdf:Property ;
    rdfs:label 'Pump Maintenance Id' ;
    rdfs:comment 'Unique identifier for the pump maintenance record. Primary key for the pump maintenance transaction.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Performed Flag' ;
    rdfs:comment 'Indicates whether pump calibration was performed during this maintenance activity. Critical for regulatory compliance tracking.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the pump was out of service due to this maintenance activity. Critical for availability tracking and revenue impact analysis.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Classification of the failure or issue type (e.g., mechanical failure, electrical fault, calibration drift, leak detection). Used for root cause analysis and equipment reliability tracking.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPassedFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Passed Flag' ;
    rdfs:comment 'Indicates whether the pump passed inspection during this maintenance activity. False indicates failure requiring follow-up.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for the maintenance activity, in USD. Includes internal labor or vendor service fees.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance work order.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity: preventive (scheduled routine), corrective (repair), calibration (accuracy adjustment), inspection (regulatory check), emergency (unplanned critical), or compliance (regulatory requirement).' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Date when the next preventive maintenance or inspection is scheduled for this pump, based on maintenance intervals.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Amount' ;
    rdfs:comment 'Total cost of parts and materials used in the maintenance activity, in USD.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsReplaced rdf:type rdf:Property ;
    rdfs:label 'Parts Replaced' ;
    rdfs:comment 'Comma-separated list or description of parts and components replaced during the maintenance activity. Used for inventory tracking and warranty management.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed description of the corrective actions taken, repairs completed, and final resolution of the maintenance activity.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnToServiceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return To Service Timestamp' ;
    rdfs:comment 'Timestamp when the pump was officially returned to operational service and made available for customer transactions.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'Total cost of the maintenance activity including parts, labor, and any additional fees, in USD.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this maintenance activity is covered under manufacturer or vendor warranty.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'Warranty claim reference number if this maintenance is being claimed under warranty.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known work order number assigned to this maintenance activity. Used for tracking and vendor billing.' ;
    rdfs:domain ind:PumpMaintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackPriceId rdf:type rdf:Property ;
    rdfs:label 'Rack Price Id' ;
    rdfs:comment 'Unique identifier for the rack price record.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'The contract or agreement number under which this rack price is provided, if applicable.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract Term End Date' ;
    rdfs:comment 'The end date of the contract term for negotiated rack pricing agreements.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Term Start Date' ;
    rdfs:comment 'The start date of the contract term for negotiated rack pricing agreements.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributorCode rdf:type rdf:Property ;
    rdfs:label 'Distributor Code' ;
    rdfs:comment 'The internal or industry-standard code identifying the petroleum distributor.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFeePerGallon rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Per Gallon' ;
    rdfs:comment 'Environmental or regulatory fees per gallon (e.g., underground storage tank fees, emissions fees) applicable to this rack price.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostPerGallon rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Per Gallon' ;
    rdfs:comment 'The freight or transportation cost per gallon from the terminal to the fuel center, used to calculate delivered cost.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexSource rdf:type rdf:Property ;
    rdfs:label 'Index Source' ;
    rdfs:comment 'The published market index source for the rack price (e.g., OPIS, Platts, DTN, Argus) or Internal for proprietary pricing.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perGallon rdf:type rdf:Property ;
    rdfs:label 'Per Gallon' ;
    rdfs:comment 'The wholesale petroleum rack price per gallon from the distributor or spot market index, serving as the cost basis for fuel margin calculation.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Factor' ;
    rdfs:comment 'A multiplier or adjustment factor applied to the base rack price for volume discounts, loyalty programs, or contract terms.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'The business reason or trigger for this rack price change (e.g., market volatility, contract renewal, seasonal adjustment, regulatory change).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'The current lifecycle status of this rack price record: active (in use), pending (scheduled future), expired (past effective period), superseded (replaced by newer price), or cancelled.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'The classification of the price: wholesale (distributor rack), retail_reference (suggested retail), cost_plus (cost plus markup), or market_index (published index).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'The date on which this rack price was published or announced by the distributor or index source.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when this rack price record was received or ingested into the system from the distributor or index feed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxPerGallon rdf:type rdf:Property ;
    rdfs:label 'Tax Per Gallon' ;
    rdfs:comment 'The applicable federal, state, and local excise tax per gallon included in or added to the rack price.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalCity rdf:type rdf:Property ;
    rdfs:label 'Terminal City' ;
    rdfs:comment 'The city where the petroleum terminal is located.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalLocation rdf:type rdf:Property ;
    rdfs:label 'Terminal Location' ;
    rdfs:comment 'The name or identifier of the petroleum terminal or distribution point where this rack price applies.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalStateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'Terminal State Province Code' ;
    rdfs:comment 'The state or province code where the petroleum terminal is located.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDeliveredCostPerGallon rdf:type rdf:Property ;
    rdfs:label 'Total Delivered Cost Per Gallon' ;
    rdfs:comment 'The total delivered cost per gallon including rack price, freight, taxes, and fees, representing the true cost basis for margin calculation.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier rdf:type rdf:Property ;
    rdfs:label 'Volume Tier' ;
    rdfs:comment 'The volume tier or bracket that qualifies for this rack price (e.g., 0-10000 gallons, 10001-50000 gallons), supporting tiered pricing structures.' ;
    rdfs:domain ind:RackPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityGallons rdf:type rdf:Property ;
    rdfs:label 'Capacity Gallons' ;
    rdfs:comment 'Maximum storage capacity of the tank measured in gallons. Critical for inventory management and refill scheduling.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cathodicProtectionTestDate rdf:type rdf:Property ;
    rdfs:label 'Cathodic Protection Test Date' ;
    rdfs:comment 'Date of the most recent cathodic protection system test. Required every three years for tanks with cathodic protection per EPA regulations.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corrosionProtectionType rdf:type rdf:Property ;
    rdfs:label 'Corrosion Protection Type' ;
    rdfs:comment 'Method of corrosion protection applied to the tank (e.g., cathodic protection, protective coating, inherently non-corrosive material). EPA requires corrosion protection for steel tanks.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Current Volume Gallons' ;
    rdfs:comment 'Current fuel volume in the tank measured in gallons. Updated by automatic tank gauging systems. Used for inventory management and reorder triggers.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionMethod rdf:type rdf:Property ;
    rdfs:label 'Decommission Method' ;
    rdfs:comment 'Method used to decommission the tank (e.g., removed from ground, filled in place with inert material). EPA requires proper closure procedures.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaUstRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Ust Registration Number' ;
    rdfs:comment 'Official EPA registration number for this underground storage tank, required for federal compliance tracking and reporting.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLevelAlarmThresholdGallons rdf:type rdf:Property ;
    rdfs:label 'High Level Alarm Threshold Gallons' ;
    rdfs:comment 'Fuel volume level that triggers a high-level alarm during delivery to prevent overfill. Typically set at 90-95% of capacity.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCleaningDate rdf:type rdf:Property ;
    rdfs:label 'Last Cleaning Date' ;
    rdfs:comment 'Date when the tank was last cleaned and inspected internally. Periodic cleaning removes sediment and water accumulation that can cause fuel quality issues.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDeliveryVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Volume Gallons' ;
    rdfs:comment 'Volume of fuel delivered during the most recent delivery. Used for inventory reconciliation and variance analysis.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTightnessTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Tightness Test Date' ;
    rdfs:comment 'Date of the most recent precision tightness test performed on the tank to verify structural integrity and absence of leaks. EPA requires periodic testing.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leakDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Method' ;
    rdfs:comment 'EPA-approved method used to detect leaks from this tank (e.g., automatic tank gauging, vapor monitoring, interstitial monitoring). Required for EPA compliance.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liningType rdf:type rdf:Property ;
    rdfs:label 'Lining Type' ;
    rdfs:comment 'Type of protective lining installed inside the tank to prevent corrosion and leakage (e.g., epoxy, polyurethane). Critical for EPA compliance and leak prevention.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowLevelAlarmThresholdGallons rdf:type rdf:Property ;
    rdfs:label 'Low Level Alarm Threshold Gallons' ;
    rdfs:comment 'Fuel volume level that triggers a low-level alarm. Set above reorder threshold to provide early warning of potential stockout.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:material rdf:type rdf:Property ;
    rdfs:label 'Material' ;
    rdfs:comment 'Primary construction material of the tank shell (e.g., steel, fiberglass, composite). Impacts corrosion risk and maintenance requirements.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCleaningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Cleaning Due Date' ;
    rdfs:comment 'Scheduled date for the next tank cleaning. Typically performed every 3-5 years depending on fuel quality and contamination risk.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTightnessTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Tightness Test Due Date' ;
    rdfs:comment 'Scheduled date for the next required tightness test. Used for compliance tracking and maintenance scheduling.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overfillPreventionDevice rdf:type rdf:Property ;
    rdfs:label 'Overfill Prevention Device' ;
    rdfs:comment 'Type of overfill prevention equipment installed on the tank (e.g., automatic shutoff, high-level alarm). EPA requires overfill prevention for all USTs.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContainmentFlag rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Flag' ;
    rdfs:comment 'Indicates whether the tank has secondary containment (double-walled construction or external containment system). Reduces environmental risk and may lower insurance premiums.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spillPreventionDevice rdf:type rdf:Property ;
    rdfs:label 'Spill Prevention Device' ;
    rdfs:comment 'Type of spill prevention equipment installed at the fill pipe (e.g., catchment basin, spill bucket). EPA requires spill prevention for all USTs.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Flag' ;
    rdfs:comment 'Indicates whether the tank is equipped with temperature monitoring sensors. Temperature data is used for volume compensation and leak detection.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waterDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Water Detection Flag' ;
    rdfs:comment 'Indicates whether the tank is equipped with water detection sensors at the bottom. Water accumulation can cause fuel quality issues and microbial growth.' ;
    rdfs:domain ind:Tank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tankLevelReadingId rdf:type rdf:Property ;
    rdfs:label 'Tank Level Reading Id' ;
    rdfs:comment 'Unique identifier for the tank level reading record. Primary key for this event log entity.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alarmStatus rdf:type rdf:Property ;
    rdfs:label 'Alarm Status' ;
    rdfs:comment 'Alarm or alert status reported by the ATG system at the time of reading. Indicates operational issues requiring attention. [ENUM-REF-CANDIDATE: normal|low_level|high_level|water_detected|leak_suspected|sensor_fault|overfill_warning — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atgDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Atg Device Code' ;
    rdfs:comment 'Identifier of the ATG device or sensor that captured this reading. Used for equipment maintenance tracking and data quality auditing.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInProgressFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery In Progress Flag' ;
    rdfs:comment 'Indicates whether a fuel delivery was in progress at the time of this reading. True if delivery active; False otherwise. Used to exclude readings during delivery from leak detection calculations.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelHeightInches rdf:type rdf:Property ;
    rdfs:label 'Fuel Height Inches' ;
    rdfs:comment 'Height of fuel in the tank measured in inches from the tank bottom. Raw measurement used in conjunction with tank strapping tables to calculate volume.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Fuel Temperature Fahrenheit' ;
    rdfs:comment 'Temperature of the fuel in the tank measured in degrees Fahrenheit. Used for temperature correction calculations to derive net volume.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Gross Volume Gallons' ;
    rdfs:comment 'Total volume of fuel in the tank measured in gallons, not adjusted for temperature. Raw measurement from the ATG probe.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leakDetectionStatus rdf:type rdf:Property ;
    rdfs:label 'Leak Detection Status' ;
    rdfs:comment 'Result of the automatic leak detection test performed by the ATG system. EPA requires continuous leak detection monitoring for underground storage tanks.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Net Volume Gallons' ;
    rdfs:comment 'Temperature-corrected volume of fuel in the tank measured in gallons. Adjusted to standard temperature (60°F) for accurate inventory accounting and reconciliation.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reading Sequence Number' ;
    rdfs:comment 'Sequential number of this reading within the day or shift for the specific tank. Used to order readings chronologically and detect missing observations.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Source or method by which the tank level reading was obtained. ATG automated readings are continuous; manual dipstick readings are performed during inspections or system failures.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Date and time when the tank level reading was captured by the ATG system or manual measurement. Primary business event timestamp for this observation.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ullageGallons rdf:type rdf:Property ;
    rdfs:label 'Ullage Gallons' ;
    rdfs:comment 'Available capacity remaining in the tank measured in gallons. Calculated as tank capacity minus current gross volume. Used to determine reorder timing and delivery scheduling.' ;
    rdfs:domain ind:TankLevelReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apiIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Api Integration Flag' ;
    rdfs:comment 'Indicates whether the carrier provides API connectivity for real-time rate quotes, shipment booking, and tracking.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageTransitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Transit Time Days' ;
    rdfs:comment 'Mean number of days from shipment pickup to delivery across all service levels for this carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Legal business name of the carrier or delivery service provider.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current operational status of the carrier relationship in the fulfillment network.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of carrier based on service model: parcel (small package), LTL (Less Than Truckload), FTL (Full Truckload), last-mile (final delivery leg), gig-economy (on-demand platform), or courier (express delivery).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Certified Flag' ;
    rdfs:comment 'Indicates whether the carrier is certified to handle temperature-controlled shipments for perishable goods and pharmacy products, maintaining cold chain integrity per HACCP standards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the carrier service contract becomes active and rates/terms take effect.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference identifier for the master service agreement or transportation contract governing the carrier relationship.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageClaimRatePercent rdf:type rdf:Property ;
    rdfs:label 'Damage Claim Rate Percent' ;
    rdfs:comment 'Historical performance metric representing the percentage of shipments resulting in damage claims or loss incidents.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. Department of Transportation to carriers operating commercial motor vehicles, required for regulatory compliance and safety monitoring.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether the carrier applies variable fuel surcharges to shipment costs based on market fuel prices.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverageZones rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Zones' ;
    rdfs:comment 'Comma-separated list of geographic zones or regions where this carrier operates (e.g., Northeast, West Coast, National, International).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the carrier is certified to transport hazardous materials in compliance with DOT and EPA regulations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the carrier\'s corporate headquarters street address.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the carrier\'s corporate headquarters street address (suite, floor, building).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the carrier\'s corporate headquarters is located.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the carrier\'s headquarters location.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the carrier\'s corporate headquarters location.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province where the carrier\'s corporate headquarters is located.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Limit Amount' ;
    rdfs:comment 'Maximum cargo insurance coverage amount (in USD) provided by the carrier per shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by the Federal Motor Carrier Safety Administration (FMCSA) for interstate commerce carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Historical performance metric representing the percentage of shipments delivered within the committed service level agreement (SLA) window.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCarrierTier rdf:type rdf:Property ;
    rdfs:label 'Preferred Carrier Tier' ;
    rdfs:comment 'Internal classification indicating carrier preference level for routing decisions: tier_1 (primary preferred), tier_2 (secondary), tier_3 (tertiary), backup (emergency use only).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association (NMFTA) for transportation companies.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelOffered rdf:type rdf:Property ;
    rdfs:label 'Service Level Offered' ;
    rdfs:comment 'Comma-separated list of delivery service levels this carrier provides (e.g., same-day, next-day, two-day, standard, economy).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Tracking Url Template' ;
    rdfs:comment 'URL template for customer shipment tracking, with placeholder for tracking number substitution (e.g., https://carrier.com/track?id={TRACKING_NUMBER}).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Identifier of the vehicle assigned to this delivery route.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:actualDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Actual Distance Miles' ;
    rdfs:comment 'Actual distance traveled for the route measured in miles, captured from vehicle telematics or driver reporting.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Minutes' ;
    rdfs:comment 'Actual total duration taken to complete the route in minutes, measured from start to end time.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual time the driver completed the route and returned to the facility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual time the driver departed the facility to begin the route.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedStops rdf:type rdf:Property ;
    rdfs:label 'Completed Stops' ;
    rdfs:comment 'Number of stops successfully completed on this route.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchTime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Time' ;
    rdfs:comment 'Time when the route was dispatched and assigned to the driver for execution.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated total duration for completing the route in minutes, calculated during route optimization.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failedStops rdf:type rdf:Property ;
    rdfs:label 'Failed Stops' ;
    rdfs:comment 'Number of stops that failed delivery on this route.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelCostAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Amount' ;
    rdfs:comment 'Fuel cost incurred for this route based on distance traveled and fuel consumption rate.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Percentage' ;
    rdfs:comment 'Percentage of stops on this route that met their scheduled delivery window, calculated as (on-time stops / total stops) * 100.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationSource rdf:type rdf:Property ;
    rdfs:label 'Optimization Source' ;
    rdfs:comment 'System or method used to optimize and plan this route (JDA Transportation Management System, manual planning, or other optimization engine).' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled end time for the route completion and return to facility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start time for the route departure from the originating facility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeCostAmount rdf:type rdf:Property ;
    rdfs:label 'Route Cost Amount' ;
    rdfs:comment 'Total cost incurred for executing this route, including labor, fuel, vehicle, and carrier charges.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeDate rdf:type rdf:Property ;
    rdfs:label 'Route Date' ;
    rdfs:comment 'The scheduled date for this delivery route execution.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeNumber rdf:type rdf:Property ;
    rdfs:label 'Route Number' ;
    rdfs:comment 'Business identifier for the delivery route, externally known and used for operational tracking and communication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the delivery route indicating its execution state.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on delivery purpose and destination type.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Delivery service level commitment for this route, determining Service Level Agreement (SLA) targets.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the route met all Service Level Agreement (SLA) commitments for on-time delivery across all stops.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Total Distance Miles' ;
    rdfs:comment 'Total planned distance for the route measured in miles.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Order Count' ;
    rdfs:comment 'Total number of customer orders included in this route across all stops.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of delivery stops planned on this route.' ;
    rdfs:domain ind:FulfillmentDeliveryRoute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Feet' ;
    rdfs:comment 'Total volume of all shipments on this route measured in cubic feet.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Total Weight Lbs' ;
    rdfs:comment 'Total weight of all shipments on this route measured in pounds.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescriptionId rdf:type rdf:Property ;
    rdfs:label 'Prescription Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.prescription. Business justification: Required for Prescription Order Fulfillment process: each fulfillment order must reference the originating prescription for compliance and patient tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prescription .

ind:primaryFulfillmentAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Fulfillment Associate Id' ;
    rdfs:comment 'Identifier of the warehouse associate who performed the picking operations for this fulfillment order. Used for productivity tracking and quality accountability.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:alcoholFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order contains alcoholic beverages requiring age verification at delivery and compliance with state alcohol shipping regulations. True if alcohol is present, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when this fulfillment order was cancelled. Applicable when the order is cancelled after release to fulfillment but before completion.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'The transportation service level selected for this fulfillment order delivery. Same-day for ultra-fast delivery, next-day for overnight service, two-day for expedited service, standard for 3-5 day ground, economy for 5-7 day low-cost delivery.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order contains temperature-sensitive perishable items requiring cold chain integrity throughout pick, pack, and delivery. True if cold chain handling is required, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time when this fulfillment order was successfully delivered to the customer or confirmed as picked up by the customer. Marks the completion of the end-to-end fulfillment process.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'The date and time when this fulfillment order was dispatched from the fulfillment node and handed over to the carrier or made available for customer pickup. Marks the completion of warehouse operations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code identifying the type of fulfillment exception or issue encountered during order execution. Examples include damaged inventory, address validation failure, delivery attempt failure, or customer unavailable. Used for exception management and root cause analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing the fulfillment exception or issue in detail. Provides context for exception resolution and customer service follow-up.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The physical fulfillment channel through which this order is being executed. DC (Distribution Center) for traditional warehouse fulfillment, MFC (Micro-Fulfillment Center) for automated urban fulfillment, store backroom for in-store pickup or local delivery, DSD (Direct Store Delivery) for vendor-managed delivery, cross-dock for transfer without storage, or vendor direct for drop-ship scenarios.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Human-readable business identifier for the fulfillment order, used for tracking and operational reference across warehouse management systems and transportation systems.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'The method by which the order will be delivered to the customer. Home delivery for last-mile delivery to customer address, curbside pickup for click-and-collect at store parking, in-store pickup for customer collection inside store, ship-to-store for transfer to another location, or locker pickup for automated pickup point.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order contains hazardous materials requiring special handling, packaging, labeling, and transportation compliance. True if hazmat items are present, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:omsReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oms Release Timestamp' ;
    rdfs:comment 'The date and time when the order management system released this order to the fulfillment domain for physical execution. Marks the handoff from order orchestration to warehouse operations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Complete Timestamp' ;
    rdfs:comment 'The date and time when packing operations were completed for this fulfillment order. Marks the order as ready for staging and dispatch.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'The number of physical packages or parcels into which this fulfillment order was packed for shipment. Used for shipping cost calculation and carrier manifest generation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Complete Timestamp' ;
    rdfs:comment 'The date and time when all picking tasks for this fulfillment order were completed. Used for pick cycle time calculation and throughput analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'The date and time when picking operations began for this fulfillment order in the warehouse. Used for cycle time analysis and picker productivity measurement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:prescriptionFlag rdf:type rdf:Property ;
    rdfs:label 'Prescription Flag' ;
    rdfs:comment 'Indicates whether this fulfillment order contains prescription medications requiring pharmacy fulfillment, HIPAA-compliant handling, and controlled substance tracking. True if prescriptions are included, false otherwise.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'The fulfillment priority level assigned to this order based on SLA requirements, customer tier, order value, or business rules. Urgent for same-day or critical orders, high for premium customers or tight SLAs, standard for regular fulfillment, low for backorders or flexible delivery windows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortPickCount rdf:type rdf:Property ;
    rdfs:label 'Short Pick Count' ;
    rdfs:comment 'The number of line items in this fulfillment order where the picked quantity was less than the ordered quantity due to inventory discrepancies or stockouts. Used for fill rate calculation and inventory accuracy tracking.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Customer-provided or system-generated special handling instructions for this fulfillment order. Examples include delivery instructions, gift wrapping requests, or handling precautions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionCount rdf:type rdf:Property ;
    rdfs:label 'Substitution Count' ;
    rdfs:comment 'The number of line items in this fulfillment order where a substitute product was picked due to out-of-stock conditions on the originally ordered item. Used for substitution rate analytics and customer experience tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'The total number of distinct line items (SKUs) in this fulfillment order. Used for complexity assessment, wave planning, and picker productivity analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitCount rdf:type rdf:Property ;
    rdfs:label 'Total Unit Count' ;
    rdfs:comment 'The total number of individual units (eaches) across all line items in this fulfillment order. Represents the total pick quantity for the order.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'The total cubic volume of all items in this fulfillment order measured in cubic meters. Used for capacity planning, vehicle loading optimization, and dimensional weight calculations.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'The total weight of all items in this fulfillment order measured in kilograms. Used for carrier selection, freight cost calculation, and load planning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'The carrier-provided tracking number for this fulfillment order shipment. Used for customer shipment visibility and delivery status tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Line Id' ;
    rdfs:comment 'Unique identifier for the fulfillment order line. Primary key for this entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrderLine .

ind:productOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Product Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Required for Fulfillment Line Allocation Report linking each order line to its fulfillment order line for pick/pack tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductOrderLine .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Quantity allocated from inventory for this line. May differ from ordered quantity based on inventory availability.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancel Reason Code' ;
    rdfs:comment 'Reason code if this line was cancelled during fulfillment. OOS indicates out of stock condition.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Identifier of the shipping carton or tote this line was packed into. Links line to physical container for tracking.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainZone rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Zone' ;
    rdfs:comment 'Temperature control zone required for this item during fulfillment and delivery. Critical for food safety and quality.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the fulfillment order. Used for ordering and referencing specific lines.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of the fulfillment order line in the pick-pack-ship workflow. OOS indicates out of stock condition. [ENUM-REF-CANDIDATE: open|allocated|picking|picked|packing|packed|staged|shipped|delivered|cancelled|oos|substituted|short_picked — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total amount for this line calculated as picked quantity times unit price. Excludes taxes and fees.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the item originally ordered by the customer. Represents the customer demand for this line.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Timestamp when this line was packed into shipping containers. Marks completion of fulfillment processing.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity packed into shipping containers or bags. Final quantity prepared for delivery or pickup.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickLocation rdf:type rdf:Property ;
    rdfs:label 'Pick Location' ;
    rdfs:comment 'Warehouse or store location where the item should be picked from. Includes aisle, bay, shelf, and bin coordinates from WMS.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickZone rdf:type rdf:Property ;
    rdfs:label 'Pick Zone' ;
    rdfs:comment 'Logical zone within the fulfillment facility assigned for picking this item. Used for wave planning and task assignment.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'Actual quantity picked by warehouse or store associate. Reflects what was physically retrieved from inventory.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortPickReason rdf:type rdf:Property ;
    rdfs:label 'Short Pick Reason' ;
    rdfs:comment 'Explanation for why the picked quantity was less than the allocated quantity. Used for inventory accuracy analysis.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Special instructions for picking, packing, or handling this item. May include fragile, keep upright, or temperature requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteSku rdf:type rdf:Property ;
    rdfs:label 'Substitute Sku' ;
    rdfs:comment 'SKU of the substitute item picked when the original item was out of stock. Null if no substitution occurred.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteUpc rdf:type rdf:Property ;
    rdfs:label 'Substitute Upc' ;
    rdfs:comment 'UPC of the substitute item picked. Null if no substitution occurred.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether the customer has allowed product substitutions for this line if the original item is out of stock.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Made Flag' ;
    rdfs:comment 'Indicates whether a product substitution was actually made during fulfillment due to out of stock condition.' ;
    rdfs:domain ind:FulfillmentOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightActual rdf:type rdf:Property ;
    rdfs:label 'Weight Actual' ;
    rdfs:comment 'Actual weight of the picked item in pounds. Captured for variable-weight items like produce and meat.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nodeId rdf:type rdf:Property ;
    rdfs:label 'Node Id' ;
    rdfs:comment 'Primary key for node' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dc Facility Id' ;
    rdfs:comment 'Reference to the parent distribution center that supplies this fulfillment node. Null for top-level DCs.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:activeFromDate rdf:type rdf:Property ;
    rdfs:label 'Active From Date' ;
    rdfs:comment 'Date when the fulfillment node became operational and started accepting orders.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeToDate rdf:type rdf:Property ;
    rdfs:label 'Active To Date' ;
    rdfs:comment 'Date when the fulfillment node ceased operations. Null for currently active nodes.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation in the fulfillment node operations: manual (human-only), semi_automated (mix of human and automation), fully_automated (automated systems with human oversight), robotic (advanced robotics and AI).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePickTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Pick Time Minutes' ;
    rdfs:comment 'Average time in minutes to pick a standard order at this fulfillment node, used for capacity planning and SLA estimation.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainCapability rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capability' ;
    rdfs:comment 'Temperature control capabilities of the fulfillment node: ambient_only (no refrigeration), refrigerated (chilled products), frozen (frozen products), multi_temp (all temperature zones).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary contact email address for the fulfillment node operations team.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyOrderCapacity rdf:type rdf:Property ;
    rdfs:label 'Daily Order Capacity' ;
    rdfs:comment 'Maximum number of orders the fulfillment node can process per day under normal operating conditions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilitySquareFootage rdf:type rdf:Property ;
    rdfs:label 'Facility Square Footage' ;
    rdfs:comment 'Total square footage of the fulfillment node facility, used for capacity planning and space utilization analysis.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentChannelsSupported rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channels Supported' ;
    rdfs:comment 'Comma-separated list of fulfillment channels this node supports (e.g., \'delivery,pickup,ship_to_store\'). [ENUM-REF-CANDIDATE: delivery|pickup|ship_to_store|curbside|locker|same_day|next_day — promote to reference product]' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the operations manager responsible for this fulfillment node.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known unique business identifier for the fulfillment node, used in WMS and OMS integrations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Human-readable name of the fulfillment node (e.g., \'Atlanta Regional DC\', \'Store 1234 Backroom\', \'Brooklyn MFC\').' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the fulfillment node: DC (Distribution Center), MFC (Micro-Fulfillment Center), store_backroom (store backroom authorized for fulfillment), dark_store (dedicated fulfillment-only location), cross_dock (transfer without storage), vendor_direct (DSD fulfillment point).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatesHolidaysFlag rdf:type rdf:Property ;
    rdfs:label 'Operates Holidays Flag' ;
    rdfs:comment 'Indicates whether the fulfillment node operates on recognized holidays.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatesWeekendsFlag rdf:type rdf:Property ;
    rdfs:label 'Operates Weekends Flag' ;
    rdfs:comment 'Indicates whether the fulfillment node operates on weekends (Saturday and Sunday).' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily operating end time for the fulfillment node in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily operating start time for the fulfillment node in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyLicensedFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Licensed Flag' ;
    rdfs:comment 'Indicates whether the fulfillment node holds a pharmacy license and can fulfill prescription orders.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Service Area Radius Miles' ;
    rdfs:comment 'Maximum delivery radius in miles that this fulfillment node serves for last-mile delivery.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Sla Cutoff Time' ;
    rdfs:comment 'Daily cutoff time in HH:MM format (24-hour clock) for same-day fulfillment orders at this node.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'Two-letter state or province code for the fulfillment node location.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Feet' ;
    rdfs:comment 'Total storage capacity of the fulfillment node measured in cubic feet, used for inventory planning.' ;
    rdfs:domain ind:Node ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the fulfillment node location (e.g., \'America/New_York\'), used for scheduling and SLA calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemInstance rdf:type rdf:Property ;
    rdfs:label 'Wms System Instance' ;
    rdfs:comment 'Identifier of the WMS system instance managing this fulfillment node, used for system integration and troubleshooting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskId rdf:type rdf:Property ;
    rdfs:label 'Pack Task Id' ;
    rdfs:comment 'Unique identifier for the pack task record. Primary key.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPackerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Packer Associate Id' ;
    rdfs:comment 'Reference to the warehouse associate who performed the packing task. Used for labor tracking and productivity analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:toteId rdf:type rdf:Property ;
    rdfs:label 'Tote Id' ;
    rdfs:comment 'Identifier of the tote or container used during picking that is now being packed. Tracks the physical container through the fulfillment workflow.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tote .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Code identifying the shipping carrier assigned to transport this packed order. Links to carrier master data for routing and delivery management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Flag' ;
    rdfs:comment 'Temperature control classification for the packed items. Critical for maintaining food safety and quality during fulfillment and delivery.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerDimensions rdf:type rdf:Property ;
    rdfs:label 'Container Dimensions' ;
    rdfs:comment 'Physical dimensions of the packed container in format length x width x height (cm). Used for carrier selection and vehicle load optimization.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of container or packaging used for packing the order items. Determines handling requirements and shipping method compatibility.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerWeightKg rdf:type rdf:Property ;
    rdfs:label 'Container Weight Kg' ;
    rdfs:comment 'Total weight of the packed container in kilograms including items and packaging. Used for carrier selection, freight calculation, and load planning.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftMessageFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Message Flag' ;
    rdfs:comment 'Indicates whether a gift message was included in this packed order. Requires special handling during packing process.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelPrintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Print Timestamp' ;
    rdfs:comment 'Date and time when the shipping label was printed. Used for tracking label generation and shipment preparation timing.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:labelPrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Label Printed Flag' ;
    rdfs:comment 'Indicates whether the shipping label was successfully printed for this pack task. Required for shipment readiness verification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Pack Duration Seconds' ;
    rdfs:comment 'Total time in seconds taken to complete the pack task. Key performance indicator for labor efficiency and process optimization.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack End Timestamp' ;
    rdfs:comment 'Date and time when the packing task was completed. Used to calculate pack duration and throughput metrics.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Pack Exception Code' ;
    rdfs:comment 'Code identifying any exception or issue encountered during packing (e.g., damaged item, missing item, wrong item). Used for exception management and root cause analysis. [ENUM-REF-CANDIDATE: damaged_item|missing_item|wrong_item|quantity_mismatch|container_shortage|label_error|system_error — promote to reference product]' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Pack Exception Notes' ;
    rdfs:comment 'Free-text notes describing the pack exception or special handling instructions. Provides context for exception resolution and quality improvement.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Date and time when the packing task was started by the associate. Used for labor productivity analysis and SLA tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStationCode rdf:type rdf:Property ;
    rdfs:label 'Pack Station Code' ;
    rdfs:comment 'Identifier of the physical pack station or workstation where the packing activity occurred. Used for capacity planning and performance tracking.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskNumber rdf:type rdf:Property ;
    rdfs:label 'Pack Task Number' ;
    rdfs:comment 'Human-readable business identifier for the pack task. Used for operational tracking and communication.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTaskStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Task Status' ;
    rdfs:comment 'Current lifecycle status of the pack task. Tracks progression through the packing workflow from assignment to completion or exception handling.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedItemCount rdf:type rdf:Property ;
    rdfs:label 'Packed Item Count' ;
    rdfs:comment 'Total number of individual items packed into the container for this task. Used for quality control verification and productivity metrics.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Packed Unit Count' ;
    rdfs:comment 'Total number of units (quantity) packed across all items. Distinguishes between line count and total quantity for bulk items.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Check Status' ;
    rdfs:comment 'Status of quality control inspection for this pack task. Indicates whether the packed order passed quality verification before shipment.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Timestamp' ;
    rdfs:comment 'Date and time when the quality control check was performed. Used for compliance reporting and process timing analysis.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceLevelCode rdf:type rdf:Property ;
    rdfs:label 'Service Level Code' ;
    rdfs:comment 'Code identifying the shipping service level (e.g., same-day, next-day, standard). Determines delivery speed and cost.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetPackTime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Pack Time' ;
    rdfs:comment 'Target completion timestamp for this pack task based on order SLA and delivery commitments. Used for on-time performance tracking.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code identifying any special handling requirements for this pack task (e.g., fragile, hazmat, gift wrap, alcohol verification). Ensures proper handling and compliance.' ;
    rdfs:domain ind:PackTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether any items in this pack task were substituted due to out-of-stock conditions. Impacts customer satisfaction and requires communication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupStagingId rdf:type rdf:Property ;
    rdfs:label 'Pickup Staging Id' ;
    rdfs:comment 'Unique identifier for the pickup staging record. Primary key for the pickup staging entity.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberOfferId rdf:type rdf:Property ;
    rdfs:label 'Member Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member_offer. Business justification: Supports In-Store Pickup Offer Redemption tracking, a business rule that records which member offer was applied at the pickup stage.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberOffer .

ind:pickupAssociateId rdf:type rdf:Property ;
    rdfs:label 'Pickup Associate Id' ;
    rdfs:comment 'Reference to the store associate who staged the order for pickup. Used for performance tracking and accountability.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:primaryPickupHandoffAssociateId rdf:type rdf:Property ;
    rdfs:label 'Primary Pickup Handoff Associate Id' ;
    rdfs:comment 'Reference to the store associate who delivered the order to the customer. Used for performance tracking and customer service quality measurement.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:ageVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Verified Flag' ;
    rdfs:comment 'Indicates whether customer age was verified for restricted items (alcohol, tobacco, pharmacy). Required for regulatory compliance.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoholVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Verification Required Flag' ;
    rdfs:comment 'Indicates whether the order contains alcohol and requires age verification at handoff. Ensures compliance with state and federal alcohol sales regulations.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Channel or method used by the customer to notify the store of their arrival for pickup. Tracks customer preference and digital adoption.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainToteCount rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Tote Count' ;
    rdfs:comment 'Number of temperature-controlled totes containing perishable items (frozen, refrigerated, fresh produce). Critical for food safety and cold chain integrity compliance.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Arrival Timestamp' ;
    rdfs:comment 'Date and time when the customer arrived at the store or checked in for pickup. Used to calculate customer wait time and handoff speed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured Flag' ;
    rdfs:comment 'Indicates whether customer signature or digital acknowledgment was captured at handoff. Used for proof of delivery and dispute resolution.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerWaitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Customer Wait Time Minutes' ;
    rdfs:comment 'Calculated time in minutes between customer arrival and order handoff. Key performance indicator for curbside and BOPIS service quality and NPS impact.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Handoff Timestamp' ;
    rdfs:comment 'Date and time when the order was physically handed off to the customer. Marks completion of the pickup fulfillment process and is a key NPS (Net Promoter Score) driver.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Flag' ;
    rdfs:comment 'Indicates whether the customer is an active loyalty program member. Used for personalized service and loyalty point accrual.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderReadyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Ready Timestamp' ;
    rdfs:comment 'Date and time when the order was fully staged and marked ready for customer pickup. Critical SLA (Service Level Agreement) metric for BOPIS fulfillment speed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parkingSpotNumber rdf:type rdf:Property ;
    rdfs:label 'Parking Spot Number' ;
    rdfs:comment 'Designated curbside parking spot number where the customer is waiting. Used for efficient order delivery to the correct vehicle.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Prescription Included Flag' ;
    rdfs:comment 'Indicates whether the order includes pharmacy prescription items. Requires special handling and HIPAA compliance for patient privacy.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the staging SLA target was achieved. Key metric for operational performance and customer experience.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'Target time in minutes for order staging completion from the time the order is assigned. Defines the service level commitment for pickup readiness.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stagingBayNumber rdf:type rdf:Property ;
    rdfs:label 'Staging Bay Number' ;
    rdfs:comment 'Physical staging bay or holding area identifier where the order is placed for customer pickup. Used for curbside parking spot or in-store pickup zone designation.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Staging Duration Minutes' ;
    rdfs:comment 'Calculated time in minutes from staging start to order ready. Measures staging efficiency and associate productivity.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stagingExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Staging Exception Notes' ;
    rdfs:comment 'Free-text notes describing the staging exception or issue. Provides context for operational review and customer service follow-up.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagingExceptionType rdf:type rdf:Property ;
    rdfs:label 'Staging Exception Type' ;
    rdfs:comment 'Type of exception or issue encountered during the staging or handoff process. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stagingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Staging Start Timestamp' ;
    rdfs:comment 'Date and time when the staging associate began preparing the order for pickup. Marks the beginning of the staging workflow.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stagingStatus rdf:type rdf:Property ;
    rdfs:label 'Staging Status' ;
    rdfs:comment 'Current lifecycle status of the pickup staging process. Tracks progression from initial staging through customer handoff.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliance Flag' ;
    rdfs:comment 'Indicates whether cold chain temperature requirements were maintained throughout staging. Critical for food safety and HACCP compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toteCount rdf:type rdf:Property ;
    rdfs:label 'Tote Count' ;
    rdfs:comment 'Total number of totes or containers used to stage the order. Indicates order size and complexity for staging logistics.' ;
    rdfs:domain ind:PickupStaging ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Description' ;
    rdfs:comment 'Description of the customer vehicle for curbside pickup identification (make, model, color). Helps associates quickly locate the customer in the parking lot.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Fulfillment Node Id' ;
    rdfs:comment 'Identifier of the facility or customer address to which the shipment is being delivered.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:shipmentFulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Shipment Fulfillment Node Id' ;
    rdfs:comment 'Identifier of the facility (DC, MFC, or store) from which the shipment originates.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:actualShipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment departed the origin facility and was handed to the carrier.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Count' ;
    rdfs:comment 'Number of delivery attempts made by the carrier before successful delivery or final failure. Used for last-mile delivery performance analysis.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryOutcome rdf:type rdf:Property ;
    rdfs:label 'Delivery Outcome' ;
    rdfs:comment 'Final result of the delivery attempt. Delivered indicates successful handoff, failed outcomes require follow-up, returned indicates shipment sent back to origin. [ENUM-REF-CANDIDATE: delivered|failed_no_access|failed_refused|failed_damaged|returned_to_sender|left_at_door|left_with_neighbor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLocationType rdf:type rdf:Property ;
    rdfs:label 'Destination Location Type' ;
    rdfs:comment 'Classification of the destination type. Customer address for last-mile delivery, store for replenishment, DC for inter-facility transfer.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Carrier-provided estimated time of arrival at the destination, updated in real-time during transit.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total transportation cost charged by the carrier for this shipment, used for freight audit and cost allocation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Max Temperature F' ;
    rdfs:comment 'Maximum acceptable temperature in Fahrenheit for cold chain shipments. Violations trigger quality alerts and potential product rejection.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Min Temperature F' ;
    rdfs:comment 'Minimum acceptable temperature in Fahrenheit for cold chain shipments. Violations trigger quality alerts and potential product rejection.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLocationType rdf:type rdf:Property ;
    rdfs:label 'Origin Location Type' ;
    rdfs:comment 'Classification of the origin facility type. DC is large regional distribution center, MFC is micro-fulfillment center for rapid local delivery, store is retail location fulfilling online orders.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proNumber rdf:type rdf:Property ;
    rdfs:label 'Pro Number' ;
    rdfs:comment 'Freight bill number assigned by the carrier for less-than-truckload (LTL) shipments, used for tracking and billing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryPhotoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Photo Captured Flag' ;
    rdfs:comment 'Indicates whether a photo of the delivered shipment was captured at the delivery location as proof of delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfDeliverySignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a customer signature was captured at delivery as proof of receipt.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledShipDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Ship Date' ;
    rdfs:comment 'Planned date when the shipment is scheduled to leave the origin facility, based on wave planning and carrier pickup schedule.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-visible business identifier for the shipment, used for tracking and customer communication.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment in the fulfillment workflow. Tracks progression from creation through final delivery or exception resolution. [ENUM-REF-CANDIDATE: created|wave_assigned|picked|packed|staged|loaded|in_transit|out_for_delivery|delivered|failed|returned|cancelled — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment based on its purpose and destination type. Last-mile delivery serves end customers, store replenishment moves inventory from DC to stores, inter-DC transfer moves goods between distribution centers, DSD is direct vendor delivery to stores.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Order of this delivery stop within the assigned route. Used for route optimization and driver navigation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCubicFt rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Ft' ;
    rdfs:comment 'Total cubic volume of the shipment in cubic feet, used for truck loading optimization and dimensional weight calculations.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoCompensationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Compensation Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic customer compensation (refund, credit, discount) is triggered on breach.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachEscalationThresholdMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Escalation Threshold Minutes' ;
    rdfs:comment 'Number of minutes overdue before a breach triggers escalation to management.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachNotificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic customer notifications are sent when this SLA is breached.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDaysOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Business Days Only Flag' ;
    rdfs:comment 'Indicates whether SLA time calculations exclude weekends and holidays (true) or include all calendar days (false).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Fixed dollar amount of compensation provided to customer when this SLA is breached.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationPercentage rdf:type rdf:Property ;
    rdfs:label 'Compensation Percentage' ;
    rdfs:comment 'Percentage of order value provided as compensation when this SLA is breached.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer tier or segment this SLA policy applies to (standard, premium, VIP, wholesale, employee).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Daily cutoff time (HH:MM format) for orders to qualify for this SLA (e.g., \'14:00\' for 2 PM cutoff for same-day).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliverySlaHours rdf:type rdf:Property ;
    rdfs:label 'Delivery Sla Hours' ;
    rdfs:comment 'Maximum allowed time in hours from dispatch to final delivery to customer (for delivery orders only).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sla Minutes' ;
    rdfs:comment 'Maximum allowed time in minutes from pack completion to dispatch/handoff to carrier or customer.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionRules rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rules' ;
    rdfs:comment 'Text description of conditions under which this SLA does not apply (e.g., weather events, system outages, force majeure).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of fulfillment facility this SLA applies to (DC - Distribution Center, MFC - Micro-Fulfillment Center, store backroom, pharmacy). [ENUM-REF-CANDIDATE: dc|mfc|store_backroom|pharmacy|dark_store|cross_dock|hub — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementEndEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement End Event' ;
    rdfs:comment 'The business event that marks successful SLA completion (delivered, ready for pickup, dispatched, customer notified).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartEvent rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Event' ;
    rdfs:comment 'The business event that triggers the start of SLA time measurement (order placed, order confirmed, payment authorized, inventory allocated).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValueMaximum rdf:type rdf:Property ;
    rdfs:label 'Order Value Maximum' ;
    rdfs:comment 'Maximum order value threshold for this SLA policy to apply. Null indicates no maximum.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderValueMinimum rdf:type rdf:Property ;
    rdfs:label 'Order Value Minimum' ;
    rdfs:comment 'Minimum order value threshold for this SLA policy to apply. Null indicates no minimum.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Pack Sla Minutes' ;
    rdfs:comment 'Maximum allowed time in minutes from pick completion to pack completion.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Pick Sla Minutes' ;
    rdfs:comment 'Maximum allowed time in minutes from order receipt to pick completion.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAreaType rdf:type rdf:Property ;
    rdfs:label 'Service Area Type' ;
    rdfs:comment 'Geographic service area classification this SLA policy applies to (local, regional, national, metro, rural).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFulfillmentSlaHours rdf:type rdf:Property ;
    rdfs:label 'Total Fulfillment Sla Hours' ;
    rdfs:comment 'Total end-to-end fulfillment time commitment in hours from order placement to delivery or pickup availability.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotLocationId rdf:type rdf:Property ;
    rdfs:label 'Slot Location Id' ;
    rdfs:comment 'Unique identifier for the physical slot or bin location within a warehouse, distribution center, micro-fulfillment center, or store backroom. Primary key.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlotLocation .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the slot is currently active and available for warehouse operations. Inactive slots are excluded from putaway and picking logic, typically due to decommissioning, reconfiguration, or permanent removal.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode identifier printed on the slot label for scanning during warehouse operations. Used by handheld devices for location verification during putaway, picking, and cycle counting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'Individual bin or slot identifier within the level. Represents the smallest addressable storage unit.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the slot location was deactivated and removed from active warehouse operations. Nullable for active slots. Used for historical analysis of warehouse layout evolution and capacity planning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Reason code explaining why the slot was deactivated. Used for root cause analysis of capacity changes and warehouse optimization initiatives.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthInches rdf:type rdf:Property ;
    rdfs:label 'Depth Inches' ;
    rdfs:comment 'Front-to-back depth dimension of the slot in inches. Used for slotting optimization to ensure product dimensions fit within slot constraints.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the slot location was last physically counted during cycle count operations. Used to schedule recurring cycle counts and maintain inventory accuracy compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Pick Timestamp' ;
    rdfs:comment 'Timestamp when inventory was last picked from this slot location. Used for slot velocity analysis and slotting optimization to position fast-moving SKUs in ergonomic, accessible locations.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPutawayTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Putaway Timestamp' ;
    rdfs:comment 'Timestamp when inventory was last placed into this slot location. Used for slot utilization analytics and identifying slow-moving or stagnant inventory locations.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Vertical level or shelf position within the bay (e.g., ground, 1, 2, 3, mezzanine). Impacts picking ergonomics and slotting strategy.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyControlledSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Controlled Substance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the slot is authorized for storing DEA-controlled substances (Schedule II-V medications). Requires enhanced security controls including locked cages, access logging, and surveillance per DEA regulations.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence number used to optimize pick path routing. Lower numbers are visited first during wave-based picking operations to minimize travel time and improve productivity.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planogramSlotReference rdf:type rdf:Property ;
    rdfs:label 'Planogram Slot Reference' ;
    rdfs:comment 'Reference identifier linking this physical slot to a planogram definition. Used in store backrooms and retail display areas to ensure compliance with visual merchandising plans and category management strategies.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentTriggerQuantity rdf:type rdf:Property ;
    rdfs:label 'Replenishment Trigger Quantity' ;
    rdfs:comment 'Inventory quantity threshold that triggers automatic replenishment from reserve or bulk storage to the pick face. Used to maintain optimal pick face inventory levels and prevent stockouts during high-volume picking.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'Unique identifier of the RFID tag affixed to the slot location for automated inventory tracking and real-time location verification. Enables hands-free scanning during putaway and picking operations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCode rdf:type rdf:Property ;
    rdfs:label 'Slot Code' ;
    rdfs:comment 'Human-readable unique code for the slot location, typically formatted as zone-aisle-bay-level-bin (e.g., A-12-05-03-B). Used by warehouse associates for picking and putaway operations.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current operational status of the slot location. Empty indicates available for putaway, occupied indicates inventory present, blocked indicates temporarily unavailable, reserved indicates allocated for specific operation, maintenance indicates under repair or inspection.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Functional classification of the slot indicating its intended use in warehouse operations. Bulk slots hold large quantities for replenishment, pick face slots are optimized for order picking, reserve slots hold overflow inventory, and endcap slots are promotional display locations. [ENUM-REF-CANDIDATE: bulk|pick_face|reserve|endcap|pallet|case|each — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotVelocityClassification rdf:type rdf:Property ;
    rdfs:label 'Slot Velocity Classification' ;
    rdfs:comment 'Classification of the slot based on pick frequency and throughput velocity. Fast-moving slots are positioned in golden zones (waist-to-shoulder height, near shipping) while slow-moving slots are placed in less accessible areas. Recalculated periodically based on historical pick activity.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Fahrenheit' ;
    rdfs:comment 'Maximum allowable temperature for the slot location in Fahrenheit. Critical for cold chain compliance and perishable inventory management. Monitored continuously in refrigerated and frozen zones.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Fahrenheit' ;
    rdfs:comment 'Minimum allowable temperature for the slot location in Fahrenheit. Critical for cold chain compliance and perishable inventory management. Monitored continuously in refrigerated and frozen zones.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Feet' ;
    rdfs:comment 'Total volumetric capacity of the slot in cubic feet, calculated as height × width × depth. Used for space utilization analytics and slotting optimization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Lbs' ;
    rdfs:comment 'Maximum weight capacity of the slot in pounds. Critical for safety compliance and preventing structural damage to racking systems. Enforced during putaway operations.' ;
    rdfs:domain ind:SlotLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Warehouse zone identifier indicating the environmental or functional area (e.g., ambient, refrigerated, frozen, pharmacy, hazmat, returns, cross-dock). Critical for temperature-controlled cold chain compliance and product segregation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the environmental or functional zone type. Determines storage requirements and handling protocols for products assigned to this slot.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionId rdf:type rdf:Property ;
    rdfs:label 'Substitution Id' ;
    rdfs:comment 'Primary key for substitution' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item is from the same brand as the original item.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Category Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item is from the same product category as the original item.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Status' ;
    rdfs:comment 'The customers response to the substitution (accepted, rejected, pending, auto-accepted, or not notified).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the customer regarding the substitution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'The method used to notify the customer about the substitution (mobile app, SMS, email, phone call, or none).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'The date and time when the customer was notified about the substitution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Response Timestamp' ;
    rdfs:comment 'The date and time when the customer responded to the substitution notification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Numeric rating (1-5) provided by the customer indicating their satisfaction with the substitution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalItemDescription rdf:type rdf:Property ;
    rdfs:label 'Original Item Description' ;
    rdfs:comment 'Full product description of the originally ordered item.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Original Quantity Ordered' ;
    rdfs:comment 'The quantity of the original item that was ordered by the customer.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'The SKU of the originally ordered product that was unavailable.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'The unit price of the originally ordered item at the time of order placement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalUpc rdf:type rdf:Property ;
    rdfs:label 'Original Upc' ;
    rdfs:comment 'The UPC of the originally ordered product that was unavailable.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickerNotes rdf:type rdf:Property ;
    rdfs:label 'Picker Notes' ;
    rdfs:comment 'Free-text notes entered by the picker explaining the substitution decision or providing additional context.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Difference Amount' ;
    rdfs:comment 'The price difference between the original and substitute items (positive if substitute is more expensive, negative if cheaper).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityTierMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Tier Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item is from the same quality tier (e.g., premium, standard, value) as the original item.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'The reason why the original item was substituted (OOS, damaged, expired, recalled, discontinued, quality issue).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Reference to the specific substitution rule configuration that was applied.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sizeMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Size Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item has the same size or quantity as the original item.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substituteItemDescription rdf:type rdf:Property ;
    rdfs:label 'Substitute Item Description' ;
    rdfs:comment 'Full product description of the substitute item provided.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteQuantityProvided rdf:type rdf:Property ;
    rdfs:label 'Substitute Quantity Provided' ;
    rdfs:comment 'The quantity of the substitute item that was provided to the customer.' ;
    rdfs:domain ind:Substitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substituteUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Substitute Unit Price' ;
    rdfs:comment 'The unit price of the substitute item at the time of substitution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionStatus rdf:type rdf:Property ;
    rdfs:label 'Substitution Status' ;
    rdfs:comment 'The current lifecycle status of the substitution (proposed, approved, rejected, fulfilled, refunded).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Substitution Timestamp' ;
    rdfs:comment 'The date and time when the substitution was performed during the picking process.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Created By User Associate Id' ;
    rdfs:comment 'Identifier of the system user or process that created this tote record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:modifiedByUserAssociateId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Associate Id' ;
    rdfs:comment 'Identifier of the system user or process that last modified this tote record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:capacityLiters rdf:type rdf:Property ;
    rdfs:label 'Capacity Liters' ;
    rdfs:comment 'Maximum volumetric capacity of the tote measured in liters. Used for load planning and space optimization.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Physical condition assessment of the tote. Determines whether the tote is suitable for reuse or requires cleaning, repair, or disposal.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Current Weight Kg' ;
    rdfs:comment 'Current actual weight of the tote and its contents in kilograms. Updated during picking and packing operations.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatched Timestamp' ;
    rdfs:comment 'Date and time when the tote was loaded onto a delivery vehicle and dispatched for last-mile delivery. Marks the start of the delivery phase.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isColdChainCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain Compliant' ;
    rdfs:comment 'Indicates whether the tote has maintained required temperature controls throughout the fulfillment process. Critical for food safety and regulatory compliance.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInsulated rdf:type rdf:Property ;
    rdfs:label 'Is Insulated' ;
    rdfs:comment 'Indicates whether the tote has insulation for temperature-sensitive items. Used for cold chain segregation and routing decisions.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReusable rdf:type rdf:Property ;
    rdfs:label 'Is Reusable' ;
    rdfs:comment 'Indicates whether the tote is designed for multiple uses and must be returned to the facility. False for single-use disposable bags.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of individual items currently contained in the tote. Updated during picking operations and used for accuracy verification.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCleanedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Cleaned Timestamp' ;
    rdfs:comment 'Date and time when the tote was last cleaned and sanitized. Critical for food safety compliance and HACCP requirements.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastInspectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Inspected Timestamp' ;
    rdfs:comment 'Date and time when the tote was last inspected for damage or wear. Ensures tote quality and safety standards are maintained.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastScannedLocation rdf:type rdf:Property ;
    rdfs:label 'Last Scanned Location' ;
    rdfs:comment 'Physical location identifier where the tote was last scanned. Provides real-time tracking of tote movement through the fulfillment process.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastScannedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scanned Timestamp' ;
    rdfs:comment 'Date and time when the tote was last scanned at a location checkpoint. Critical for tracking tote movement and dwell time.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'Total number of distinct order lines or Stock Keeping Units (SKUs) contained in the tote. Used for pick complexity assessment.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Material composition of the tote. Impacts durability, cleaning requirements, and environmental sustainability.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Returned Timestamp' ;
    rdfs:comment 'Date and time when the tote was returned to the facility after delivery completion or failed delivery attempt. Enables tote reuse cycle tracking.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stagedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Staged Timestamp' ;
    rdfs:comment 'Date and time when the tote was moved to the staging area awaiting dispatch. Critical for tracking Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalUseCount rdf:type rdf:Property ;
    rdfs:label 'Total Use Count' ;
    rdfs:comment 'Cumulative number of times the tote has been used for order fulfillment. Tracks tote utilization and helps predict replacement needs.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toteStatus rdf:type rdf:Property ;
    rdfs:label 'Tote Status' ;
    rdfs:comment 'Current lifecycle status of the tote in the fulfillment workflow. Tracks tote availability and location in the pick-pack-ship process.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toteType rdf:type rdf:Property ;
    rdfs:label 'Tote Type' ;
    rdfs:comment 'Classification of the tote based on temperature control requirements. Critical for cold chain segregation in grocery fulfillment.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Kg' ;
    rdfs:comment 'Maximum weight capacity of the tote in kilograms. Ensures safe handling and prevents overloading during fulfillment operations.' ;
    rdfs:domain ind:Tote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitTempEventId rdf:type rdf:Property ;
    rdfs:label 'Transit Temp Event Id' ;
    rdfs:comment 'Unique identifier for the temperature monitoring event. Primary key.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Product Lot Numbers' ;
    rdfs:comment 'Comma-separated list of product lot numbers that were exposed to the temperature conditions during this event. Enables targeted recalls if needed.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertRecipient rdf:type rdf:Property ;
    rdfs:label 'Alert Recipient' ;
    rdfs:comment 'Email address or identifier of the person or system that received the temperature alert. Used for accountability and response tracking.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Flag' ;
    rdfs:comment 'Indicates whether an automated alert was sent to operations staff when this temperature event was recorded. Supports real-time intervention.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Minutes' ;
    rdfs:comment 'Duration in minutes that the temperature remained outside acceptable range. Null if no breach occurred. Critical for determining product disposition.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'Indicates whether the recorded temperature exceeded acceptable thresholds for the temperature zone. Triggers corrective action workflows.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachSeverity rdf:type rdf:Property ;
    rdfs:label 'Breach Severity' ;
    rdfs:comment 'Classification of the temperature breach severity based on duration and deviation magnitude. Drives escalation and corrective action protocols.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Calibration status of the sensor at the time of the reading. Sensors with failed or overdue calibration may produce unreliable data.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective action taken in response to a temperature breach. Required for HACCP compliance and FDA audit readiness.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Timestamp' ;
    rdfs:comment 'Date and time when corrective action was initiated or completed. Demonstrates timely response to food safety incidents.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haccpControlPoint rdf:type rdf:Property ;
    rdfs:label 'Haccp Control Point' ;
    rdfs:comment 'Reference to the specific HACCP critical control point associated with this monitoring event. Required for regulatory audit trails.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage at the time of the temperature reading. Important for produce quality and certain pharmaceutical products.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationIdentifier rdf:type rdf:Property ;
    rdfs:label 'Location Identifier' ;
    rdfs:comment 'Specific identifier of the location (slot number, tote barcode, vehicle license plate, bay number) where the event occurred. Enables precise traceability.' ;
    rdfs:domain ind:TransitTempEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Code' ;
    rdfs:comment 'Unique identifier of the temperature sensor or monitoring device that captured the reading. Used for device calibration tracking and maintenance scheduling.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Recorded temperature in degrees Celsius. Core measurement for cold chain compliance and food safety validation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoCalendarId rdf:type rdf:Property ;
    rdfs:label 'Promo Calendar Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_calendar. Business justification: Wave scheduling uses the promotional calendar to align wave start/end dates with campaign calendars.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCalendar .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Identifier of the delivery route assigned to this wave. Used for route optimization and last-mile delivery planning.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransportRoute .

ind:cancelledLineCount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Line Count' ;
    rdfs:comment 'Number of order lines cancelled during wave execution due to inventory issues, quality problems, or customer cancellations.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Primary material handling equipment type used for this wave: pallet jack, forklift, order picker, reach truck, cart, or automated system (AS/RS, AMR).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityZone rdf:type rdf:Property ;
    rdfs:label 'Facility Zone' ;
    rdfs:comment 'Physical zone or area within the facility where this wave is executed (e.g., ambient zone, refrigerated zone, freezer zone, backroom section).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percent' ;
    rdfs:comment 'Percentage of order lines successfully picked and fulfilled in this wave. Calculated as (lines picked / total lines) × 100. Key metric for inventory availability and fulfillment performance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRushWave rdf:type rdf:Property ;
    rdfs:label 'Is Rush Wave' ;
    rdfs:comment 'Boolean flag indicating whether this is an expedited rush wave requiring immediate processing outside of normal wave planning cycles. True for rush waves, False for standard waves.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'Picking methodology used for this wave: discrete (single order at a time), batch (multiple orders picked together), zone (pickers assigned to zones), wave (coordinated multi-zone), or cluster (cart-based multi-order).' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickerCount rdf:type rdf:Property ;
    rdfs:label 'Picker Count' ;
    rdfs:comment 'Number of warehouse pickers assigned to execute this wave. Used for labor productivity analysis and staffing optimization.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled date and time when wave picking is planned to be completed. Used for SLA tracking and downstream process coordination.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled date and time when wave picking is planned to begin. Used for labor scheduling and capacity planning.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Business priority level assigned to this wave for resource allocation and sequencing. Urgent waves are processed first, followed by high, normal, and low priority waves.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'Date and time when the wave was released to the warehouse floor for execution. Marks the transition from planned to active status.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaCutoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Cutoff Timestamp' ;
    rdfs:comment 'Service level agreement deadline by which this wave must be completed to meet customer delivery commitments. Used for on-time performance tracking.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:comment 'Total number of order lines (SKU-level picks) across all orders in this wave. Used for pick task generation and labor allocation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnits rdf:type rdf:Property ;
    rdfs:label 'Total Units' ;
    rdfs:comment 'Total number of individual units (eaches) to be picked in this wave across all orders and SKUs. Used for workload estimation and productivity tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waveNumber rdf:type rdf:Property ;
    rdfs:label 'Wave Number' ;
    rdfs:comment 'Business-facing wave identifier used for operational tracking and communication. Externally-known unique code for this wave.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveStatus rdf:type rdf:Property ;
    rdfs:label 'Wave Status' ;
    rdfs:comment 'Current lifecycle status of the wave: planned (created but not released), released (active for picking), in-progress (picking underway), completed (all tasks finished), cancelled (aborted), or on-hold (temporarily suspended).' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waveType rdf:type rdf:Property ;
    rdfs:label 'Wave Type' ;
    rdfs:comment 'Classification of the wave based on fulfillment purpose: replenishment (store restocking), ecommerce (online order fulfillment), DSD (Direct Store Delivery), store transfer, bulk pick, or cross-dock operations.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsWaveIdentifier rdf:type rdf:Property ;
    rdfs:label 'Wms Wave Identifier' ;
    rdfs:comment 'Native wave identifier from the source WMS system (Manhattan Associates, SAP WM, or other). Used for system integration and cross-reference.' ;
    rdfs:domain ind:Wave ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsTaskId rdf:type rdf:Property ;
    rdfs:label 'Wms Task Id' ;
    rdfs:comment 'Primary key for wms_task' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAssociateId rdf:type rdf:Property ;
    rdfs:label 'Assigned Associate Id' ;
    rdfs:comment 'Reference to the warehouse associate assigned to execute this task. Used for labor tracking and productivity analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:productOrderId rdf:type rdf:Property ;
    rdfs:label 'Product Order Id' ;
    rdfs:comment 'Reference to the customer or replenishment order that originated this task. Links warehouse execution back to order fulfillment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductOrder .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Quantity actually picked, put away, or counted by the warehouse associate. Variance from target quantity triggers exception handling.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cycle Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from task start to completion. Key performance indicator for labor productivity and process efficiency analysis.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Flag' ;
    rdfs:comment 'Indicates whether damaged goods were encountered during task execution. True when product damage was identified, triggering shrink recording and disposition workflows.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Code' ;
    rdfs:comment 'Reference to the material handling equipment used for task execution, such as forklift, pallet jack, or RF scanner device.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Detailed explanation of the exception or variance encountered during task execution. Provides context for root cause analysis and process improvement.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Logic used to determine target location for putaway tasks. Directed assigns specific slots; random uses any available location; FIFO (First In First Out) prioritizes oldest inventory; LIFO (Last In First Out) prioritizes newest; FEFO (First Expired First Out) prioritizes by expiration date; fixed location assigns dedicated slots per SKU.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Time' ;
    rdfs:comment 'Target timestamp by which the task must be completed to meet service level commitments. Used for on-time fulfillment tracking and carrier cutoff management.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceLocation rdf:type rdf:Property ;
    rdfs:label 'Source Location' ;
    rdfs:comment 'Origin location for putaway and replenishment tasks. For putaway, this is the receiving dock door or staging area. For replenishment, this is the reserve storage location.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutedSku rdf:type rdf:Property ;
    rdfs:label 'Substituted Sku' ;
    rdfs:comment 'SKU of the substitute product picked when the original item was out of stock. Used for order fulfillment accuracy tracking and customer communication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocation rdf:type rdf:Property ;
    rdfs:label 'Target Location' ;
    rdfs:comment 'Destination location for putaway and replenishment tasks. For putaway, this is the assigned storage slot. For replenishment, this is the forward pick location.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Expected quantity to be picked, put away, or counted as specified by the WMS. Measured in the item\'s unit of measure.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskAssignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Assigned Timestamp' ;
    rdfs:comment 'Timestamp when the task was assigned to a warehouse associate. Used to measure queue time and assignment efficiency.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completed Timestamp' ;
    rdfs:comment 'Timestamp when the task was successfully completed by the associate. Used for productivity measurement and SLA compliance tracking.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Created Timestamp' ;
    rdfs:comment 'Timestamp when the WMS task was generated by the system. Marks the beginning of the task lifecycle for cycle time measurement.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskMethod rdf:type rdf:Property ;
    rdfs:label 'Task Method' ;
    rdfs:comment 'Technology or interface used by the associate to receive and complete the task. Voice uses voice-directed picking; RF scanner uses handheld terminals; paper uses printed pick lists; mobile app uses smartphone applications; automated uses robotics or conveyor systems.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Started Timestamp' ;
    rdfs:comment 'Timestamp when the associate began actively working on the task. Marks the transition from assigned to in-progress status.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the WMS task. Pending tasks await assignment; assigned tasks have been allocated to an associate; in-progress tasks are actively being worked; completed tasks are finished; cancelled tasks were aborted; exception tasks encountered issues; suspended tasks are temporarily paused. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|cancelled|exception|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the warehouse task indicating the primary operation to be performed. Pick tasks retrieve inventory for orders; putaway tasks store received goods; replenishment tasks move inventory to forward pick locations; cycle count tasks verify inventory accuracy; cross-dock tasks transfer goods without storage; returns processing tasks handle customer returns.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceFeet rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Feet' ;
    rdfs:comment 'Total distance traveled by the associate in feet during task execution. Used for warehouse layout optimization and labor standards development.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTaskNumber rdf:type rdf:Property ;
    rdfs:label 'Wms Task Number' ;
    rdfs:comment 'Externally visible business identifier for the WMS task, used for tracking and reference across systems and by warehouse associates.' ;
    rdfs:domain ind:WmsTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainLogId rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Log Id' ;
    rdfs:comment 'Primary key for cold_chain_log' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batteryLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Battery Level Percent' ;
    rdfs:comment 'Remaining battery level of the sensor at time of reading.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Seconds' ;
    rdfs:comment 'Total duration of the out-of-range event in seconds.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion End Timestamp' ;
    rdfs:comment 'Timestamp when the condition returned to within thresholds.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionFlag rdf:type rdf:Property ;
    rdfs:label 'Excursion Flag' ;
    rdfs:comment 'True when temperature or humidity exceeds configured thresholds.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excursionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion Start Timestamp' ;
    rdfs:comment 'Timestamp when the first out-of-range condition was detected.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haccpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliance Status' ;
    rdfs:comment 'Indicates whether the reading complies with HACCP food-safety requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityDeviationPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Deviation Percent' ;
    rdfs:comment 'Difference between measured humidity and configured threshold.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Measured relative humidity as a percentage.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTempThresholdC rdf:type rdf:Property ;
    rdfs:label 'Max Temp Threshold C' ;
    rdfs:comment 'Configured upper bound for acceptable temperature in Celsius.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTempThresholdF rdf:type rdf:Property ;
    rdfs:label 'Max Temp Threshold F' ;
    rdfs:comment 'Configured upper bound for acceptable temperature in Fahrenheit.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTempThresholdC rdf:type rdf:Property ;
    rdfs:label 'Min Temp Threshold C' ;
    rdfs:comment 'Configured lower bound for acceptable temperature in Celsius.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTempThresholdF rdf:type rdf:Property ;
    rdfs:label 'Min Temp Threshold F' ;
    rdfs:comment 'Configured lower bound for acceptable temperature in Fahrenheit.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Reading Quality Flag' ;
    rdfs:comment 'Quality assessment of the sensor reading.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Indicates whether the record captures temperature, humidity, or both.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorStatus rdf:type rdf:Property ;
    rdfs:label 'Sensor Status' ;
    rdfs:comment 'Operational status of the sensor.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Measured temperature in degrees Celsius.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureDeviationC rdf:type rdf:Property ;
    rdfs:label 'Temperature Deviation C' ;
    rdfs:comment 'Difference between measured temperature and nearest threshold in Celsius.' ;
    rdfs:domain ind:ColdChainLog ;
