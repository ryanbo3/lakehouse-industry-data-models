    rdfs:comment 'Duration in seconds of the engagement activity from start to completion. Applicable for activities with measurable duration such as survey completion, app session, or content viewing. Null for instantaneous events.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Status of the engagement event indicating whether the activity was fully completed, partially completed, abandoned, or failed due to technical issues.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamificationAchievementType rdf:type rdf:Property ;
