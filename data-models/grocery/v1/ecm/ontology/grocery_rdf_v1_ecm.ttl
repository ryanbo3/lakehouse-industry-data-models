ind:sourceLocationType rdf:type rdf:Property ;
    rdfs:label 'Source Location Type' ;
    rdfs:comment 'Classification of the source location.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Temperature Compliance Status' ;
    rdfs:comment 'Result of temperature compliance checks for the transfer.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
