    rdfs:comment 'Internal code indicating the business reason for the markdown (e.g., slow_moving, overstock, promotional).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosEventId rdf:type rdf:Property ;
