    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Survey .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'The version of the mobile app or web application used during the engagement event. Null for non-digital events.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentVisited rdf:type rdf:Property ;
    rdfs:label 'Department Visited' ;
    rdfs:comment 'The store department or section visited during a store visit check-in event (e.g., Produce, Pharmacy, Deli, Bakery). Supports department-level dwell time and traffic analytics. Null for non-visit events.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'Duration in minutes that the customer spent in the store or department during a visit check-in event. Calculated from entry to exit detection. Supports dwell time analytics and customer journey insights. Null for non-visit events.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
