    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'Quantity that the inventory system recorded for the SKU at the time of the count.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureReadingC rdf:type rdf:Property ;
    rdfs:label 'Temperature Reading C' ;
    rdfs:comment 'Recorded temperature at the time of count for temperature-sensitive items.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceFlag rdf:type rdf:Property ;
    rdfs:label 'Tolerance Flag' ;
    rdfs:comment 'True if the variance exceeds predefined tolerance thresholds.' ;
