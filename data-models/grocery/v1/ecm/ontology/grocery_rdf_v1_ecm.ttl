ind:itemId rdf:type rdf:Property ;
    rdfs:label 'Item Id' ;
    rdfs:comment 'FK to product.item.item_id — Core inventory-to-product join enabling stock queries by product attributes (category, brand, vendor). Fundamental to replenishment, OOS analysis, and shrink reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductItem .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Units that can be sold to customers (on-hand minus reserved).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliance Flag' ;
    rdfs:comment 'True when temperature-controlled items meet required temperature range.' ;
