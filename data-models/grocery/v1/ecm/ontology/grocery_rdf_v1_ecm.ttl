    rdfs:comment 'True if the transferred items require temperature-controlled handling.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The business date on which the transfer order was initiated.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Business-visible reference number for the transfer order, used in communications and documentation.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Status' ;
    rdfs:comment 'Current lifecycle state of the transfer order.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
