    rdfs:comment 'System-generated unique identifier for the OOS event record.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentSignalId rdf:type rdf:Property ;
