ind:cycleCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Quantity' ;
    rdfs:comment 'Quantity difference identified during a cycle count.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference to the source document (e.g., material document number, WMS transaction ID).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsMovementStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Movement Status' ;
    rdfs:comment 'Current processing status of the movement record.' ;
    rdfs:domain ind:GoodsMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Method used to value inventory for this movement (FIFO, LIFO, average cost, or standard cost).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCycleCountCorrection rdf:type rdf:Property ;
    rdfs:label 'Is Cycle Count Correction' ;
    rdfs:comment 'True when the movement reflects a correction from a cycle-count process.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManualEntry rdf:type rdf:Property ;
    rdfs:label 'Is Manual Entry' ;
    rdfs:comment 'True if the movement was entered manually rather than via automated interface.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhysicalInventory rdf:type rdf:Property ;
    rdfs:label 'Is Physical Inventory' ;
    rdfs:comment 'Indicates whether the movement is part of a physical inventory count process.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReserved rdf:type rdf:Property ;
    rdfs:label 'Is Reserved' ;
    rdfs:comment 'Indicates whether the quantity was reserved for a pending order at the time of movement.' ;
