    rdfs:range xsd:decimal .

ind:lotBatchStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Batch Status' ;
    rdfs:comment 'Current lifecycle state of the lot within inventory management.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Category describing the nature of the lot for handling and compliance purposes.' ;
    rdfs:domain ind:LotBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'SKU of the product to which this lot or batch belongs.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date the product was manufactured or produced.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineEndDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine End Date' ;
