ind:temperatureF rdf:type rdf:Property ;
    rdfs:label 'Temperature F' ;
    rdfs:comment 'Measured temperature in degrees Fahrenheit.' ;
    rdfs:domain ind:ColdChainLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'System-generated unique identifier for each cycle count event.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used for the count (full inventory, cycle count, spot check, or ad-hoc).' ;
