    rdfs:range xsd:integer .

ind:lastReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Review Timestamp' ;
    rdfs:comment 'Date-time when the policy parameters were last reviewed or recalibrated.' ;
