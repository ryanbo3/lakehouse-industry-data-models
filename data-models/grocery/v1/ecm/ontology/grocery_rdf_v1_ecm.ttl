    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rotation Check Timestamp' ;
    rdfs:comment 'Date and time when the rotation check was performed.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallHoldId rdf:type rdf:Property ;
    rdfs:label 'Recall Hold Id' ;
    rdfs:comment 'Unique system-generated identifier for each recall hold record.' ;
    rdfs:domain ind:RecallHold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold End Timestamp' ;
    rdfs:comment 'Date and time when the hold was resolved or released.' ;
    rdfs:domain ind:RecallHold ;
    rdf:type owl:DatatypeProperty ;
