    rdfs:comment 'Unique identifier of the loyalty program member (customer).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:orderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Order Header Id' ;
    rdfs:comment 'Foreign key linking to order.order_header. Business justification: Loyalty Points Earned Report calculates points earned per order, requiring a direct link from loyalty fact rows to the order header.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:programConfigId rdf:type rdf:Property ;
    rdfs:label 'Program Config Id' ;
    rdfs:comment 'Identifier of the loyalty program to which the member belongs.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramConfig .

ind:activeMemberCount rdf:type rdf:Property ;
    rdfs:label 'Active Member Count' ;
    rdfs:comment 'Number of members actively participating in the loyalty program during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Avg Points Balance' ;
    rdfs:comment 'Mean points balance held by members at period end.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLapsedMember rdf:type rdf:Property ;
    rdfs:label 'Is Lapsed Member' ;
    rdfs:comment 'True if the member became inactive or lapsed during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewMember rdf:type rdf:Property ;
    rdfs:label 'Is New Member' ;
    rdfs:comment 'True if the member enrolled during the reporting period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lapsedMembers rdf:type rdf:Property ;
    rdfs:label 'Lapsed Members' ;
    rdfs:comment 'Number of members whose loyalty status became inactive or lapsed during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltySalesAmount rdf:type rdf:Property ;
    rdfs:label 'Loyalty Sales Amount' ;
    rdfs:comment 'Net sales revenue generated from transactions where the loyalty member received points or discounts.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loyaltySalesPenetration rdf:type rdf:Property ;
    rdfs:label 'Loyalty Sales Penetration' ;
    rdfs:comment 'Share of total sales attributable to loyalty members (loyalty_sales_amount / total_sales_amount).' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newEnrollments rdf:type rdf:Property ;
    rdfs:label 'New Enrollments' ;
    rdfs:comment 'Count of new members who enrolled in the loyalty program in the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Rate' ;
    rdfs:comment 'Percentage of personalized offers accepted by members (offers_accepted / offers_sent).' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAccrued rdf:type rdf:Property ;
    rdfs:label 'Points Accrued' ;
    rdfs:comment 'Total loyalty points earned by members in the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed' ;
    rdfs:comment 'Total loyalty points redeemed by members in the period.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current operational status of the loyalty program for the period.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate' ;
    rdfs:comment 'Percentage of accrued points that were redeemed (points_redeemed / points_accrued).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Business-defined segment classification of members based on value or behavior.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierBronzeCount rdf:type rdf:Property ;
    rdfs:label 'Tier Bronze Count' ;
    rdfs:comment 'Number of members in the Bronze loyalty tier during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierGoldCount rdf:type rdf:Property ;
    rdfs:label 'Tier Gold Count' ;
    rdfs:comment 'Number of members in the Gold loyalty tier during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierSilverCount rdf:type rdf:Property ;
    rdfs:label 'Tier Silver Count' ;
    rdfs:comment 'Number of members in the Silver loyalty tier during the period.' ;
    rdfs:domain ind:LoyaltyAnalyticsFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Financial KPI metrics are derived from specific GL accounts; linking provides traceability from metric to underlying account.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:metricOwnerAssociateId rdf:type rdf:Property ;
    rdfs:label 'Metric Owner Associate Id' ;
    rdfs:comment 'Foreign key linking to workforce.associate. Business justification: Metric definitions are authored and maintained by a data-analytics associate; the link supports metric stewardship and audit.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Associate .

ind:priceRuleId rdf:type rdf:Property ;
    rdfs:label 'Price Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_rule. Business justification: REQUIRED: KPI metrics track compliance and impact of pricing rules, so each metric definition references the rule it measures.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceRule .

ind:tenderTypeId rdf:type rdf:Property ;
    rdfs:label 'Tender Type Id' ;
    rdfs:comment 'Foreign key linking to payment.tender_type. Business justification: Defines metric tracking usage volume per tender type for strategic payment channel optimization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TenderType .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'Data type of the metric\'s result value.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricAudience rdf:type rdf:Property ;
    rdfs:label 'Metric Audience' ;
    rdfs:comment 'Intended consumer audience for the metric.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'High-level business category the metric belongs to.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricConfidentiality rdf:type rdf:Property ;
    rdfs:label 'Metric Confidentiality' ;
    rdfs:comment 'Data classification level for the metric definition.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Metric Data Quality Score' ;
    rdfs:comment 'Score (0-100) representing the assessed data quality of the metric\'s source data.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricDefinitionSource rdf:type rdf:Property ;
    rdfs:label 'Metric Definition Source' ;
    rdfs:comment 'System or process that originated the metric definition (e.g., SAP Retail, Blue Yonder).' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDescription rdf:type rdf:Property ;
    rdfs:label 'Metric Description' ;
    rdfs:comment 'Detailed description of what the metric measures and its business purpose.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricFormula rdf:type rdf:Property ;
    rdfs:label 'Metric Formula' ;
    rdfs:comment 'Expression or calculation logic that derives the metric from source data fields.' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricGrain rdf:type rdf:Property ;
    rdfs:label 'Metric Grain' ;
    rdfs:comment 'Granularity at which the metric is calculated (e.g., per store per day).' ;
    rdfs:domain ind:MetricDefinition ;
    rdf:type owl:DatatypeProperty ;
