ind:onlinePickupEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Pickup Enabled' ;
    rdfs:comment 'Indicates whether stores of this format support click-and-collect online order pickup services (curbside or in-store).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursTypical rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Typical' ;
    rdfs:comment 'Typical daily operating hours for stores of this format (e.g., 6am-11pm, 24/7). Used for labor scheduling and customer communication.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpacesMax rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces Max' ;
    rdfs:comment 'Maximum number of customer parking spaces typically provided for stores of this format.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingSpacesMin rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces Min' ;
    rdfs:comment 'Minimum number of customer parking spaces required for stores of this format, used for site selection and zoning compliance.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyIncluded rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Included' ;
    rdfs:comment 'Indicates whether stores of this format typically include a full-service pharmacy department.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramTemplateFamily rdf:type rdf:Property ;
    rdfs:label 'Planogram Template Family' ;
    rdfs:comment 'Identifier for the planogram template family used by this store format. Planograms are visual merchandise display plans that define product placement on shelves and fixtures.' ;
    rdfs:domain ind:Format ;
