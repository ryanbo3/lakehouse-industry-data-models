    rdfs:range xsd:boolean .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'Web address of the banner\'s logo image for digital assets.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Eligible' ;
    rdfs:comment 'True if stores under the banner participate in the corporate loyalty program.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
