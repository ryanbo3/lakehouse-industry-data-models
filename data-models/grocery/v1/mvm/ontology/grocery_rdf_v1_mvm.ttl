ind:skuCountMin rdf:type rdf:Property ;
    rdfs:label 'Sku Count Min' ;
    rdfs:comment 'Minimum number of unique SKUs (Stock Keeping Units) typically carried in stores of this format. Used for assortment planning and inventory management.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCountTypical rdf:type rdf:Property ;
    rdfs:label 'Sku Count Typical' ;
