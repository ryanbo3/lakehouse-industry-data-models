    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'True if the transfer is a cross-dock operation without storage.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'True if the transfer is processed with expedited handling.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFifoRotation rdf:type rdf:Property ;
    rdfs:label 'Is Fifo Rotation' ;
    rdfs:comment 'True if the items follow a First-In-First-Out rotation policy.' ;
