    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentBannerId rdf:type rdf:Property ;
    rdfs:label 'Parent Banner Id' ;
    rdfs:comment 'Identifier of the parent banner in a hierarchical banner structure; null if top-level.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banner .

ind:averageSalesPerStore rdf:type rdf:Property ;
    rdfs:label 'Average Sales Per Store' ;
    rdfs:comment 'Average annual sales (in local currency) generated per store under the banner.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bannerDescription rdf:type rdf:Property ;
    rdfs:label 'Banner Description' ;
    rdfs:comment 'Free-form textual description of the banner\'s market positioning and characteristics.' ;
