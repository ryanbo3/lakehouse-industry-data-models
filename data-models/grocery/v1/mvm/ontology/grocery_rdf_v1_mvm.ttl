ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Human-readable business identifier for the policy, often used in operational reports and communications.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the policy logic governing how reorder signals are generated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Sequential version number to track changes to the policy over time.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Reorder Policy Status' ;
    rdfs:comment 'Current lifecycle state of the policy.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'How often the policy parameters are evaluated and potentially updated.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Buffer stock kept to protect against demand variability and supply delays.' ;
    rdfs:domain ind:ReorderPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perishableRotationId rdf:type rdf:Property ;
    rdfs:label 'Perishable Rotation Id' ;
    rdfs:comment 'System-generated unique identifier for each perishable rotation record.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
