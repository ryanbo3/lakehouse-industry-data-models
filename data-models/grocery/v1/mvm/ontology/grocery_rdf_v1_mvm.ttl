ind:squareFootageMax rdf:type rdf:Property ;
    rdfs:label 'Square Footage Max' ;
    rdfs:comment 'Maximum total retail square footage for stores in this format, measured in square feet. Used for site selection and capital planning.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootageMin rdf:type rdf:Property ;
    rdfs:label 'Square Footage Min' ;
    rdfs:comment 'Minimum total retail square footage for stores in this format, measured in square feet. Used for site selection and capital planning.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootageTypical rdf:type rdf:Property ;
    rdfs:label 'Square Footage Typical' ;
    rdfs:comment 'Typical or average retail square footage for stores in this format, measured in square feet. Used as the baseline for new store planning and format conversion analysis.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffingModelTemplate rdf:type rdf:Property ;
    rdfs:label 'Staffing Model Template' ;
    rdfs:comment 'Identifier for the workforce staffing model template used for stores of this format, defining typical headcount, roles, and scheduling patterns.' ;
    rdfs:domain ind:Format ;
