ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric allowance rate applicable to this specific vendor item under the parent allowance program. May differ from the header-level allowance_rate_value when item-level overrides are negotiated. Interpretation depends on the parent allowance_rate_type (percentage, fixed amount per case, etc.).' ;
    rdfs:domain ind:TradeAllowanceItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circularOfferPlacementId rdf:type rdf:Property ;
    rdfs:label 'Circular Offer Placement Id' ;
