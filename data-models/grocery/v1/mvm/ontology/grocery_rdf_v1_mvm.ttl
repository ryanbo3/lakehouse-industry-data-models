    rdfs:range ind:Division .

ind:annualEbitdaTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Ebitda Target Usd' ;
    rdfs:comment 'Planned annual EBITDA target for the region in US dollars, representing operational profitability goal.' ;
    rdfs:domain ind:Region ;
