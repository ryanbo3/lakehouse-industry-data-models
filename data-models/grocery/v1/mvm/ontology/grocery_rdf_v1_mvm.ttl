    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'Current operational status of the location.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for the location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for the location.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Operational zone label used for routing and labor planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTransferStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Storage Location Id' ;
    rdfs:comment 'Identifier of the location (store, DC, MFC) from which inventory is being transferred.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:carrierMode rdf:type rdf:Property ;
    rdfs:label 'Carrier Mode' ;
    rdfs:comment 'Transportation mode used for the transfer.' ;
