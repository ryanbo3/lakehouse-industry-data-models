ind:checkoutLaneCountMin rdf:type rdf:Property ;
    rdfs:label 'Checkout Lane Count Min' ;
    rdfs:comment 'Minimum number of POS (Point of Sale) checkout lanes in stores of this format.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliIncluded rdf:type rdf:Property ;
    rdfs:label 'Deli Included' ;
    rdfs:comment 'Indicates whether stores of this format include a deli department with prepared foods and sliced meats.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
