ind:formatCategory rdf:type rdf:Property ;
    rdfs:label 'Format Category' ;
    rdfs:comment 'High-level classification of the store format type used for strategic segmentation and portfolio analysis.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'Short alphanumeric code representing the store format (e.g., SS for Superstore, NM for Neighborhood Market, EXP for Express). Used as a business identifier in operational systems and reporting.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatDescription rdf:type rdf:Property ;
    rdfs:label 'Format Description' ;
    rdfs:comment 'Detailed description of the store format including its purpose, target customer segment, and key differentiators.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Full descriptive name of the store format (e.g., Superstore, Neighborhood Market, Express Convenience, Warehouse Club, Fuel-Only).' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatStatus rdf:type rdf:Property ;
    rdfs:label 'Format Status' ;
    rdfs:comment 'Current lifecycle status of the store format in the portfolio. Active formats are in production use; pilot formats are being tested; discontinued formats are no longer used for new stores.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freshProduceIncluded rdf:type rdf:Property ;
    rdfs:label 'Fresh Produce Included' ;
    rdfs:comment 'Indicates whether stores of this format carry fresh produce departments with perishable inventory.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelCenterIncluded rdf:type rdf:Property ;
    rdfs:label 'Fuel Center Included' ;
    rdfs:comment 'Indicates whether stores of this format typically include an attached fuel center.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gondolaCountTypical rdf:type rdf:Property ;
    rdfs:label 'Gondola Count Typical' ;
    rdfs:comment 'Typical number of gondola shelving units in stores of this format. Gondolas are the primary shelving units in store aisles.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountTypical rdf:type rdf:Property ;
    rdfs:label 'Headcount Typical' ;
    rdfs:comment 'Typical total employee headcount for stores of this format, used for labor planning and budgeting.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeDeliveryEnabled rdf:type rdf:Property ;
    rdfs:label 'Home Delivery Enabled' ;
    rdfs:comment 'Indicates whether stores of this format support last-mile delivery (LMD) services to customer homes.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meatSeafoodIncluded rdf:type rdf:Property ;
    rdfs:label 'Meat Seafood Included' ;
    rdfs:comment 'Indicates whether stores of this format include fresh meat and seafood departments with butcher services.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfcEnabled rdf:type rdf:Property ;
    rdfs:label 'Mfc Enabled' ;
    rdfs:comment 'Indicates whether stores of this format include or are co-located with a Micro-Fulfillment Center (MFC) for automated online order fulfillment.' ;
    rdfs:domain ind:Format ;
