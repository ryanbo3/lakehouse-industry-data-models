# RDFS Schema for Business: Grocery

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/grocery#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Grocery ---
ind:Grocery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Grocery' ;
    rdfs:comment 'Grocery is a large-scale retail industry operating supermarkets, pharmacies, and fuel centers, offering fresh produce, private-label brands, and omnichannel shopping experiences with delivery and pickup services.' .

# --- Domain Classes ---
ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all grocery shopper identities, profiles, households, segments, and preferences. Manages B2C shoppers, B2B wholesale accounts, SNAP/WIC/EBT program participants, and pharmacy patients (non-PHI). Owns demographics, contact preferences, NPS scores, CLTV metrics, and segmentation data. Integrates with CRM platforms and supports personalization and targeted marketing.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog of all sellable items including CPG products, private-label brands, fresh produce, pharmacy drug items, and fuel grades. Manages SKU, UPC, GTIN, PLU codes, product hierarchies, categories, attributes, nutritional information, and regulatory compliance flags. Supports planogram design, category management, and FDA labeling requirements.' .

ind:Store rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Store' ;
    rdfs:comment 'Physical retail locations including supermarkets, pharmacies, fuel centers, and micro-fulfillment centers (MFCs). Manages store profiles, layouts, departments, gondolas, endcaps, backrooms, operating hours, formats, service capabilities, and regional hierarchy. Supports store clustering, comp sales performance tracking, and site selection.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Real-time and historical stock positions across all stores, distribution centers, and MFCs. Manages on-hand quantities, reserved stock, FIFO/LIFO rotation tracking, shrink records (theft, spoilage, damage), OOS monitoring, cycle counts, cold chain temperature compliance, and CAO replenishment signals. Integrates with WMS, SAP MM, and ERP systems.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Supply' ;
    rdfs:comment 'End-to-end supply chain from vendor sourcing through DC receiving to store replenishment. Manages purchase orders, inbound shipments, cross-dock operations, DSD workflows, transportation routing, cold chain logistics, and RFID tracking. Integrates with Blue Yonder Demand Planning, JDA TMS, and Manhattan Associates WMS.' .

ind:Pharmacy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Pharmacy' ;
    rdfs:comment 'Prescription management, drug inventory, clinical services, patient counseling, and controlled substance tracking. Manages Rx orders, fills, refills, insurance claims, prior authorizations, DEA compliance reporting, and HIPAA-compliant patient records. Integrates with McKesson pharmacy systems and State Board of Pharmacy licensing data.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Marketing campaigns, weekly ad circulars, BOGO offers, TPRs, digital coupons, personalized deals, and loyalty reward promotions. Manages promotion planning, calendars, offer eligibility rules, execution, redemption tracking, markdown optimization, and GMROI analysis. Supports slotting fee negotiations and post-promotion performance measurement.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Supplier and vendor master data including CPG manufacturers, produce growers, DSD distributors, private-label co-manufacturers, and category captain designations. Manages vendor profiles, contracts, EDI partner profiles, slotting agreements, performance scorecards (fill rate, on-time delivery), and compliance tracking.' .

ind:Loyalty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Loyalty' ;
    rdfs:comment 'Customer loyalty program management including membership enrollment, tier management, points accrual and redemption, personalized reward offers, and gamification. Tracks engagement metrics, NPS contribution, program ROI, dwell time patterns, and household purchase behavior. Integrates with CRM, promotion, and fuel reward systems.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Financial accounting, general ledger, accounts payable/receivable, cost centers, budgeting, and SOX compliance. Manages COGS, EBITDA reporting, comp sales and same-store sales metrics, shrink financial impact, and financial consolidation. Integrates with SAP FI/CO modules and supports GAAP-compliant regulatory financial disclosures and audit trails.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Physical execution of order fulfillment across DCs, MFCs, and store backrooms. Manages pick-pack-ship workflows, wave planning, WMS task management, putaway and slotting logic, carrier selection and assignment, last-mile delivery dispatch, and SLA compliance. Tracks fill rates and cold chain integrity during shipment.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'Price management across all channels including SRP, competitive pricing, zone pricing, markdown strategies, and dynamic fuel pricing. Manages price changes, promotional pricing linkages, ASP analytics, and price optimization algorithms. Supports competitive intelligence integration and ensures FTC pricing compliance.' .

ind:Assortment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Assortment' ;
    rdfs:comment 'Merchandise planning, category management, product assortment optimization, and planogram execution. Manages space allocation, facings, new item introductions, SKU rationalization, and localized assortments by store cluster. Supports seasonal planning and category captain collaboration.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Grocery ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Payment processing for all transaction types including credit/debit cards, EBT, SNAP, WIC, mobile wallets, gift cards, and fuel rewards. Manages payment authorization, settlement, chargebacks, refunds, and PCI DSS compliance. Integrates with NCR POS systems, payment gateways, and digital commerce checkout.' .

# --- Data Product Classes (Tables) ---
ind:Shopper rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Shopper' ;
    rdfs:comment 'Core master entity representing every individual grocery shopper (B2C) known to Grocery. Serves as the single source of truth for shopper identity, capturing legal name, preferred name, date of birth, gender, primary language, registration channel (in-store, app, web), account status (active, suspended, closed), SNAP/WIC/EBT eligibility flags, loyalty enrollment status, CLTV tier, NPS score, acquisition source, and opt-in/opt-out flags for marketing communications. This is the golden record for all B2C customer identity data integrated from Salesforce CRM and NCR POS loyalty enrollment.' .

ind:WholesaleAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Wholesale Account' ;
    rdfs:comment 'Master entity for B2B wholesale and institutional accounts served by Grocery (e.g., restaurants, food service operators, corporate cafeterias, school districts, hospitals). Captures legal business name, DBA name, business type (restaurant, caterer, institutional, corporate), tax ID (EIN), DUNS number, credit limit, payment terms (net-30, net-60, COD), assigned account manager, account tier (strategic, standard, small business), contract start/end dates, billing address, primary contact person, and annual revenue estimate. Distinct from the individual shopper entity — represents an organizational buyer rather than a person. Supports B2B order management, credit approval workflows, and wholesale pricing eligibility.' .

ind:Household rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Household' ;
    rdfs:comment 'Represents a household grouping of one or more shoppers sharing a residence and loyalty account. Serves as the single source of truth for household composition and member associations — no other product in this domain stores household membership data. Captures household ID, primary shopper reference, household size, estimated annual grocery spend, household income band, home ownership status, residential zip code, and household lifecycle stage (single, couple, family with children, empty nester, senior). Owns all member associations including member role (primary, secondary, dependent), join and departure dates, and primary loyalty cardholder designation. Enables household composition tracking over time, multi-member loyalty accrual rules, household-level personalization, targeted promotions, and CLTV modeling. Integrates with Salesforce CRM household object.' .

ind:ContactInfo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact Info' ;
    rdfs:comment 'Single source of truth for all contact details and physical/mailing addresses for shoppers and wholesale accounts. Owns phone numbers, email addresses, and postal addresses — no other product in this domain stores contact or address data. Supports multiple records per entity with contact type (email, mobile phone, home phone) and address type (home, billing, delivery, pickup, mailing). Captures full USPS-validated address normalization including address lines, city, state, zip code, county, country, latitude/longitude coordinates, and validation status (USPS-verified, unverified, invalid). Tracks is_primary flag, is_verified flag, verification date, opt-in status per communication channel (SMS, email, push notification), unsubscribe timestamp, is_default flag, and effective date range. Supports omnichannel communication preferences, CAN-SPAM/TCPA compliance, last-mile delivery routing, store assignment, and geographic segmentation.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Defines named market segments used to classify shoppers for targeted marketing, personalization, and assortment decisions. Captures segment name, segment code, segment type (behavioral, demographic, value-based, lifecycle, dietary preference), description, creation date, owner team, active flag, and applicable channel (digital, in-store, all). Examples include: High-CLTV Loyalists, SNAP/EBT Shoppers, Organic Enthusiasts, Pharmacy Patients, Fuel Rewards Members. Reference entity managed by the CRM and marketing analytics teams.' .

ind:SegmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment Assignment' ;
    rdfs:comment 'Transactional association linking a shopper to one or more customer segments at a point in time. Captures shopper reference, segment reference, assignment date, expiry date, assignment method (rule-based, ML model, manual override), confidence score, and the model or rule version that produced the assignment. Enables time-series segment membership tracking and supports A/B testing of segmentation strategies.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Comprehensive single source of truth for all shopper preferences and dietary profiles — both declared and inferred — across all dimensions. No other product in this domain stores dietary, lifestyle, or shopping preference data. Covers dietary restrictions (nut allergy, lactose intolerance, celiac/gluten-free), lifestyle diet types (vegan, vegetarian, keto, paleo, Mediterranean), nutritional goals (low sodium, low sugar, high protein), certification preferences (organic, non-GMO, USDA certified), shopping preferences (preferred store, preferred pickup vs. delivery, preferred shopping day/time), communication preferences (email frequency, push notification topics), and product category affinities. Captures preference source (self-declared via app, inferred from purchase history), confidence level, and last updated timestamp. Feeds the personalization engine in Salesforce Commerce Cloud and supports digital commerce product filtering for health-conscious shopping features.' .

ind:BenefitEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Benefit Enrollment' ;
    rdfs:comment 'Tracks shopper enrollment in government assistance and special benefit programs including SNAP (Supplemental Nutrition Assistance Program), WIC (Women Infants and Children), and EBT (Electronic Benefits Transfer). Captures program type, enrollment status (active, pending, expired, denied), enrollment date, expiry date, issuing agency, benefit card number (tokenized), monthly benefit amount, and verification document reference. Critical for POS tender eligibility and regulatory compliance reporting.' .

ind:PharmacyPatient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Pharmacy Patient' ;
    rdfs:comment 'Non-PHI patient profile for shoppers who use Grocery pharmacy services. Captures patient reference to the shopper master, preferred pharmacy store, primary care physician name, allergy flags (non-clinical, self-reported), preferred contact method for Rx notifications, auto-refill opt-in status, medication synchronization (MedSync) enrollment, and patient counseling preference. Intentionally excludes all HIPAA-protected health information (PHI) — clinical data resides in McKesson Pharmacy Systems. Links to the shopper master via shopper_id.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Authoritative single source of truth for all shopper consent decisions, privacy preferences, communication suppressions, and opt-out state. No other product in this domain stores consent or suppression data. Captures consent type (marketing email, SMS, push notification, data sharing with CPG partners, personalization, analytics, direct mail), consent status (granted, withdrawn, pending), consent and withdrawal dates, consent source (app, web, in-store kiosk, call center), consent version (legal text version), and device/IP context. Owns the suppression list for shoppers excluded from specific communication types due to opt-out requests, legal holds, deceased status, or fraud flags — including suppression type (global opt-out, email, SMS, direct mail, third-party sharing), suppression reason codes, effective/expiry dates, and triggering source system. Supports CCPA, CAN-SPAM, and TCPA compliance for all outbound marketing and data sharing activities.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger chart of accounts master for Grocery, aligned with SAP FI module. Defines all GL account codes, account types (P&L, balance sheet), cost element categories, and GAAP classification. Serves as the authoritative account structure for financial consolidation, COGS tracking, EBITDA reporting, and SOX audit compliance across all store banners and legal entities.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP CO cost center master representing organizational units responsible for cost accumulation — stores, distribution centers, pharmacy departments, fuel centers, and corporate functions. Tracks cost center hierarchy, responsible manager, controlling area, profit center assignment, and budget period validity. Enables departmental P&L, shrink financial impact allocation, and labor cost attribution.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP CO profit center master representing autonomous business segments for internal profitability reporting — store-level, banner-level, pharmacy, fuel, and private-label divisions. Captures profit center hierarchy, assigned controlling area, segment classification, and validity periods. Supports comp sales, same-store sales, and EBITDA reporting by business unit.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master record of all legal entities within the Grocery corporate structure — operating subsidiaries, holding companies, and banner-level legal registrations. Captures EIN, state of incorporation, fiscal year variant, functional currency, consolidation group membership, and SOX reporting scope flag. Drives financial consolidation and intercompany elimination workflows.' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Reference calendar defining Grocery\'s fiscal year structure — fiscal year, fiscal periods (4-4-5 or 13-period retail calendar), period open/close status, and posting date ranges. Aligned with SAP FI fiscal year variant. Controls period-end close sequencing, budget comparison periods, and comp sales period-over-period calculations.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core general ledger posting document capturing all financial transactions in the Grocery ledger — standard postings, accruals, reversals, intercompany entries, shrink postings, tax postings (sales tax, fuel excise, pharmacy dispensing tax), and period-end adjustments. Contains both header metadata (document number, document type, posting date, fiscal period, company code, reference, reversal indicator, approval chain, parking status) and line-item detail (line number, debit/credit indicator, GL account, cost center, profit center, WBS element, amount in transaction and local currency, tax code, tax jurisdiction, assignment field, text). The single authoritative audit trail for all financial activity, supporting COGS analysis, EBITDA reporting, SOX compliance, state/local tax remittance reporting, and trial balance generation.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable lifecycle record covering the full invoice-to-payment cycle for vendor merchandise, DSD deliveries, slotting fees, and operational expenses. Captures invoice receipt (vendor ID, invoice date, PO reference, payment terms, gross/net/tax amounts, three-way match status, EDI 810 reference, GR/IR clearing), payment block and approval workflow, and disbursement execution (payment method — ACH/check/wire, payment date, bank account, cleared amount, discount taken, payment run ID from SAP automatic payment program). Each record tracks the complete AP document lifecycle from posting through clearing. Supports cash flow forecasting, vendor payment processing, early-pay discount optimization, and 1099 reporting.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable lifecycle record covering the full invoice-to-cash cycle for B2B wholesale customers, pharmacy insurance billings (PBM claims), fuel fleet card receivables, and vendor chargebacks/deductions. Captures billing (customer account, invoice date, payment terms, gross/net/tax amounts, billing document type), aging and dunning status, and cash receipt/application (receipt date, payment method, bank deposit reference, lockbox ID, applied invoice amounts, unapplied/on-account cash, clearing document). Supports DSO analysis, receivables aging reports, cash application automation, deduction management, bad debt provisioning, and write-off processing.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Financial budget master and period-level allocation detail for Grocery, managed in SAP CO. Captures budget header (version — original/revised/forecast, budget type — operating/capital/labor, responsible cost center or profit center, GL account scope, fiscal year, approval status) and period-level line detail (fiscal period, planned amount, revised amount, committed amount, actuals-to-date, available balance). Supports variance analysis (plan vs actual vs forecast), EBITDA target tracking, store-level operating expense budgeting, category-level COGS planning, capital expenditure governance, and real-time budget consumption monitoring with threshold alerts.' .

ind:InternalOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP CO internal order master used to track costs for specific projects, capital investments, store remodels, marketing campaigns, and temporary cost collection objects. Captures order type, responsible cost center, settlement rule, budget, actual costs, and order status (created, released, technically complete, settled). Supports CAPEX tracking and project-level profitability.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master and full depreciation lifecycle record from SAP FI Asset Accounting (AA) covering store equipment, refrigeration units, fuel pumps, POS terminals, MFC automation systems, delivery vehicles, and leasehold improvements. Captures asset master data (asset class, sub-number, serial number, acquisition date/cost, vendor, PO reference, useful life, location/cost center assignment) and periodic depreciation detail (depreciation method/key, depreciation area — book/tax/group, fiscal period amounts, accumulated depreciation, net book value, impairment, disposal proceeds and gain/loss). Supports EBITDA reconciliation (depreciation add-back), CAPEX reporting, tax depreciation vs book variance tracking, asset physical inventory, and SOX fixed asset audit.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Bank account master and electronic bank statement record for all Grocery operating, payroll, concentration, and zero-balance accounts across legal entities. Captures account master data (bank name, masked account number, routing number, account type, currency, SAP house bank ID, signatory authorities) and full statement lifecycle (MT940/BAI2 imports, statement date/sequence, opening/closing balances, individual transaction lines — deposits/withdrawals/fees/lockbox items, bank transaction codes, value date, clearing status against open AR/AP items). Supports cash management, AP payment run bank selection, AR lockbox processing, daily cash position reporting, bank reconciliation, and SOX treasury controls.' .

ind:OrderHeader rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Header' ;
    rdfs:comment 'Master record for every customer purchase across all channels (in-store POS, online, click-and-collect, curbside pickup, last-mile delivery, and pharmacy Rx fills). Captures order number, channel type, register/lane (for POS), cashier (for POS), transaction type (sale, return, void, no-sale for POS), order date/time, order status lifecycle (placed, confirmed, in-fulfillment, ready, dispatched, delivered, cancelled), customer reference, store reference, total amounts, subtotal, tax, tender summary, change due (for POS), basket item count, loyalty card scanned flag, loyalty points earned, promo codes applied, special instructions, self-checkout flag, EBT/SNAP/WIC tender flag, source system (NCR POS / Salesforce Commerce Cloud / McKesson), payment method summary, and OMS order reference. Single source of truth for ALL customer purchase identity in the retail-grocery enterprise — encompasses both POS transactions and OMS-originated orders in one canonical entity. No separate POS transaction entity exists; channel-specific attributes are captured via channel type discriminator and nullable POS-specific fields.' .

ind:ProductOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Order Line' ;
    rdfs:comment 'Individual line item within a customer order representing a single SKU/UPC purchased or requested across all channels (in-store POS scan, online cart, click-and-collect). Captures line sequence number, SKU/GTIN, PLU (for produce), UPC (for POS-scanned items), item description, ordered quantity, unit of measure, unit price, extended price, discount amount, promo applied flag, substitution flag, substitution SKU, line status (active, substituted, cancelled, out-of-stock, voided, returned), weight (for variable-weight/scale items), tax code, department code, tax amount, fulfillment method per line, void flag, return flag, TPR flag, BOGO flag, coupon applied reference, and scan method (handheld, belt scanner, self-checkout, manual key). Supports both fixed-weight CPG items and variable-weight fresh/deli items. Enables basket analytics, shrink analysis, and category performance reporting at the item level across all channels.' .

ind:OrderStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Status History' ;
    rdfs:comment 'Immutable audit trail of every status transition for an order header throughout its lifecycle. Records the previous status, new status, transition timestamp, triggering system (OMS, TMS, WMS, POS), triggering event (customer action, store action, driver scan, system timeout), and operator/system actor. Enables SLA tracking, exception investigation, and omnichannel fulfillment performance reporting. Critical for customer service resolution and carrier dispute management.' .

ind:DeliveryOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Delivery Order' ;
    rdfs:comment 'Last-mile delivery order record managing the logistics leg of an online or OMS-originated order dispatched to a customer address. Captures delivery order number, linked order header, delivery address, scheduled delivery window (start/end), actual delivery timestamp, delivery status (scheduled, assigned, en-route, delivered, failed, returned), driver/carrier reference, vehicle reference, delivery zone, distance miles, delivery fee, tip amount, contactless delivery flag, delivery instructions, proof-of-delivery method (photo/signature/PIN), and TMS route reference. Integrates with JDA TMS.' .

ind:PickupAppointment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Pickup Appointment' ;
    rdfs:comment 'Curbside or in-store click-and-collect pickup appointment record. Captures appointment ID, linked order header, store ID, pickup bay/slot, scheduled pickup window (date, start time, end time), actual arrival timestamp, actual pickup completion timestamp, appointment status (scheduled, arrived, dispensed, no-show, cancelled), vehicle description, parking spot number, associate who dispensed, and customer notification timestamps (ready SMS, reminder). Manages curbside slot capacity and SLA compliance for click-and-collect fulfillment.' .

ind:OrderFulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Fulfillment' ;
    rdfs:comment 'Fulfillment execution record linking an order header to its physical pick-pack-ship workflow in the store backroom, MFC, or DC. Captures fulfillment ID, linked order header, fulfillment location type (store/MFC/DC), fulfillment location ID, assigned picker ID, pick start timestamp, pick complete timestamp, pack complete timestamp, staging area/bay, fulfillment status (queued, picking, picked, packed, staged, dispatched), total lines, total lines picked, substitution count, OOS line count, and WMS task reference. Integrates with Manhattan Associates WMS.' .

ind:OrderDiscount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Discount' ;
    rdfs:comment 'Discount and promotion application record for each discount applied to an order header or order line. Captures discount ID, linked order header, linked order line (nullable for header-level discounts), promotion reference, coupon code, discount type (TPR, BOGO, digital coupon, loyalty reward, ad circular, markdown, employee discount, EBT discount), discount amount, discount percentage, promo stack sequence (for stacked promotions), and applied timestamp. Enables promotion redemption tracking and GMROI analysis.' .

ind:OrderPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Payment' ;
    rdfs:comment 'Payment tender record for each payment instrument applied to a customer order. Captures payment ID, linked order header, tender type (credit, debit, EBT/SNAP, WIC, mobile wallet, gift card, fuel reward, cash, check), card type (Visa/MC/Amex), last four digits, authorization code, authorization timestamp, settlement status, payment amount, change given, EBT balance remaining (for EBT tenders), and payment processor reference. Supports PCI DSS compliance and SNAP/WIC regulatory reporting. References order_header as the single parent — no dual-FK pattern.' .

ind:OrderRefund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Refund' ;
    rdfs:comment 'Refund and return transaction record for orders where items are returned or credits are issued. Captures refund ID, linked original order header, refund type (full/partial/line-level), refund reason code (damaged, wrong item, OOS, customer dissatisfaction, spoilage), refund amount, refund method (original tender, store credit, gift card), refund status (requested, approved, processed, denied), approving associate ID, and refund timestamp. Supports shrink tracking and customer satisfaction management. References order_header as the single parent.' .

ind:RxOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Rx Order' ;
    rdfs:comment 'Pharmacy prescription order record representing the purchase-event view of an Rx fill within the order domain. Captures Rx order ID, linked order header (for combined grocery+pharmacy orders), prescription number, patient reference, prescriber NPI, drug NDC code, drug name, quantity dispensed, days supply, fill type (new/refill/transfer), fill status (received, in-verification, filled, ready, dispensed, on-hold, cancelled), controlled substance schedule (DEA Schedule II-V flag), insurance claim reference, copay amount, and McKesson Rx system reference. This entity owns the ORDER-SIDE view of the Rx transaction (purchase event, payment, order status); the pharmacy domain owns the CLINICAL-SIDE (drug utilization review, patient counseling, clinical verification, controlled substance DEA reporting). Integrates with McKesson Pharmacy Systems.' .

ind:OrderSubstitution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Order Substitution' ;
    rdfs:comment 'Item substitution record capturing instances where an ordered SKU was unavailable (OOS) and replaced with an alternative item during fulfillment. Captures substitution ID, linked order line, original SKU/GTIN, substitute SKU/GTIN, substitution reason (OOS, damaged, recalled), substitution type (auto-substituted by system, picker-selected, customer pre-approved), customer notification method (app/SMS/email), customer acceptance status (accepted, rejected, pending), price difference amount, and substitution timestamp. Supports OOS root cause analysis and customer experience improvement.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Category' ;
    rdfs:comment 'Master hierarchy of merchandise categories used for assortment planning and category management. Represents the full category tree from department down to sub-category level (e.g., Grocery > Dairy > Yogurt). Owned by the assortment domain as the SSOT for category structure. Includes category captain designation, GMROI targets, space allocation norms, and seasonal planning flags. Aligns with Oracle Retail Merchandising System item hierarchy.' .

ind:Planogram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Planogram' ;
    rdfs:comment 'Visual merchandise display plan defining the exact placement, facings, and shelf positions of SKUs within a store fixture or gondola section. Captures planogram version, effective dates, fixture type, total shelf capacity, and compliance status. Includes position-level detail: individual SKU slots with shelf number, bay number, facing count, capacity, and display orientation for each product placement. Source of truth for space planning and shelf execution. Derived from Oracle Retail and space planning tools (e.g., Blue Yonder, JDA).' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Merchandise assortment plan defining the approved set of SKUs for a category within a store cluster or banner for a planning period. Captures plan name, planning horizon (season/quarter/year), target SKU count, space allocation in linear feet, GMROI target, sales plan, and approval status. Created during merchandise planning cycles in Oracle Retail Merchandising System.' .

ind:AssortmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Assortment Item' ;
    rdfs:comment 'Individual SKU included in an approved assortment plan, representing both standard plan items and localized overrides at the store-cluster or individual-store level. Captures SKU/GTIN, inclusion status (active, discontinued, new, localized-add, localized-remove), merchandising role (core, seasonal, local, ethnic, private-label), minimum facings, recommended shelf position, effective date range, override justification, and localization source (demographic demand, local supplier, store format). Serves as the single line-level detail record for all assortment decisions including hyper-local merchandising strategies, SKU rationalization outputs, and new item introduction placements.' .

ind:StoreCluster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Store Cluster' ;
    rdfs:comment 'Grouping of stores with similar demographic, geographic, volume, or format characteristics used to define localized assortments and targeted planogram assignments. Captures cluster name, cluster type (demographic, volume, format, geographic, competitive), number of member stores, store membership list with effective dating, clustering methodology version, refresh frequency, and effective date range. Enables differentiated assortment strategies by market segment. Managed within Oracle Retail and Blue Yonder category management tools.' .

ind:NewItemIntro rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'New Item Intro' ;
    rdfs:comment 'New item introduction record tracking the lifecycle of a new SKU from vendor submission through category review, buyer approval, planogram slotting, and first store receipt. Captures item name, UPC/GTIN, vendor, category, slotting fee amount, target launch date, first ship date, initial order quantity, and introduction status. Supports private-label and CPG new item workflows.' .

ind:SpaceAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Space Allocation' ;
    rdfs:comment 'Space allocation record defining the approved linear footage, shelf count, square footage, and display assignments for a category or sub-category within a store or store cluster. Covers all fixture types including gondola sections, endcaps (end-of-aisle displays), coolers, freezer cases, and promotional displays. Captures allocated linear feet, number of shelves, gondola sections, endcap position assignments (featured SKU/category, assignment dates, promotional tie-in), fixture type, seasonal space adjustments, vendor-funded indicators, and effective date ranges. Drives planogram development, category space productivity (GMROI per linear foot) analysis, and high-visibility promotional display management including endcap rotation scheduling.' .

ind:Fixture rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Assortment ;
    rdfs:label 'Fixture' ;
    rdfs:comment 'Physical store fixture master record representing a gondola, endcap, cooler, freezer case, wine rack, or specialty display unit within a specific store. Captures fixture type, aisle and bay location, number of shelves, total linear footage, depth, temperature zone (ambient, refrigerated, frozen), installation date, condition status, and current planogram assignment. Serves as the physical anchor for planogram placement and space allocation records. Referenced by planogram and space_allocation to connect logical merchandise plans to physical store infrastructure.' .

ind:Membership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Membership' ;
    rdfs:comment 'Core master record for a customer\'s loyalty program enrollment. Captures membership number (card number), current tier assignment, enrollment date, program type (standard, premium, household, pharmacy rewards), enrollment channel (in-store, digital, pharmacy, fuel center), opt-in preferences (email, SMS, push, mail), referral source, current program standing (active, suspended, closed), lifetime value classification, last activity date, and digital wallet linkage status. This is the authoritative SSOT for loyalty membership identity within the loyalty domain, referencing the customer SSOT in the customer domain via FK. One membership per customer per program.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Reference master defining the loyalty program tier structure (e.g., Member, Silver, Gold, Platinum). Captures tier name, tier code, minimum points threshold, maximum points threshold, tier benefits summary, upgrade/downgrade rules, evaluation period, and tier rank order. Drives tier assignment logic and benefit eligibility across the loyalty program.' .

ind:TierHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier History' ;
    rdfs:comment 'Transactional record of every tier change event for a loyalty member. Captures previous tier, new tier, effective date, expiry date, reason code (earned upgrade, annual reset, manual adjustment, demotion), points balance at time of change, and the triggering transaction reference. Enables tier progression analytics and member lifecycle tracking.' .

ind:PointsAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Points Account' ;
    rdfs:comment 'Master ledger account tracking the current balance for each loyalty membership across all loyalty currencies (points and fuel cents-per-gallon). Captures account type (points, fuel reward), total earned, redeemed, expired, pending (not yet confirmed), available balance, lifetime earned, maximum redemption limits (e.g., max gallons for fuel), earn period windows, and last activity date. Serves as the authoritative SSOT for a members loyalty currency position, supporting real-time balance inquiries at POS, digital channels, and fuel center pumps.' .

ind:PointsTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Points Transaction' ;
    rdfs:comment 'Granular transactional ledger recording every loyalty currency movement — accrual, redemption, adjustment, expiry, transfer, or bonus — against a loyalty account. This is the single authoritative SSOT for all loyalty value exchanges including point-for-discount redemptions, free item claims, fuel cents-per-gallon usage, pharmacy reward fulfillment, and all reward redemption events. Supports both points and fuel reward currencies. Captures transaction type (earn, redeem, expire, adjust, transfer, bonus), currency type (points, fuel cents-per-gallon), amount, transaction timestamp, source channel (POS, eCommerce, pharmacy, fuel center pump), gallons dispensed (fuel redemptions), redemption method and fulfillment status (for redeem transactions), redemption type detail (points-for-discount, free item, fuel cents-per-gallon, pharmacy copay reduction), originating order or receipt reference, promotion reference, partner reference, store location, and running balance after transaction. Provides complete audit trail for financial reconciliation, SOX compliance evidence, and ASC 606 breakage analysis inputs. Integrates with NCR POS loyalty module and fuel center systems.' .

ind:RewardOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Reward Offer' ;
    rdfs:comment 'Master catalog of personalized and program-wide reward offers available to loyalty members. Captures offer name, offer type (points multiplier, free item, discount, fuel reward, pharmacy reward, sweepstakes entry), earn or redemption mechanics, minimum spend threshold, eligible SKU or category scope, offer start and end dates, maximum redemptions per member, and targeting segment criteria. Distinct from promotion domain offers — these are loyalty-program-specific rewards tied to membership status.' .

ind:MemberOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member Offer' ;
    rdfs:comment 'Association record linking a specific reward offer to a specific loyalty member, representing a personalized offer assignment. Captures assignment date, activation status (loaded, activated, redeemed, expired), activation channel, redemption date, redemption transaction reference, and offer source (targeted, self-selected, tier benefit). Enables tracking of which members have which offers loaded to their card.' .

ind:LoyaltyRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Loyalty Redemption' ;
    rdfs:comment 'Transactional record capturing each loyalty reward redemption event — when a member uses points or a reward offer at checkout. Captures redemption type (points-for-discount, free item, fuel cents-per-gallon, pharmacy copay reduction), redemption amount (points or dollar value), redemption channel (in-store POS, online, fuel center, pharmacy), store location, transaction timestamp, and fulfillment status. Integrates with NCR POS and Salesforce Commerce Cloud OMS.' .

ind:HouseholdMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Household Member' ;
    rdfs:comment 'Association record linking individual loyalty memberships to a household unit. Captures membership role within household (primary, secondary, dependent), join date, leave date, relationship type (spouse, child, parent, roommate), points pooling participation flag, pooling contribution percentage, spending authority level, communication preference override, benefit sharing tier, and household-level offer eligibility override. Enables household-level analytics, shared benefit management, and pooled points governance.' .

ind:ProgramConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Program Config' ;
    rdfs:comment 'Reference master storing the complete configuration and business rules for each loyalty program as structured rule sets. Captures program identity (name, version, launch date, status), earn rule sets (base earn rates by category, private-label multipliers, channel bonuses, tier-based rate tables, bonus stacking priority), expiry rule sets (rolling inactivity windows, fixed calendar expiry dates, tier-based extensions, grace periods, notification lead days), redemption parameters (minimum threshold, points-to-dollar conversion rates, fuel cents-per-gallon caps, maximum single-redemption limits), welcome/referral/birthday bonus definitions, tier evaluation frequency and method, and multi-program support (standard grocery, pharmacy rewards, fuel rewards club). Organized as one record per program with nested structured rule objects — not a flat attribute blob. Supports program versioning for A/B testing and phased rollouts.' .

ind:StoreLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Store Location' ;
    rdfs:comment 'Master record for every physical retail location operated by Grocery, including supermarkets, pharmacies, fuel centers, and micro-fulfillment centers (MFCs). Captures store number, banner name, format type (superstore, neighborhood market, express), ownership type (owned/leased), gross and selling square footage, opening date, remodel date, closure date, operational status, primary phone number, email, and emergency contact information. This is the SSOT for store identity across the enterprise and the anchor entity for all store-domain relationships. Every cross-domain reference to a physical store resolves to this product.' .

ind:Format rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Format' ;
    rdfs:comment 'Reference classification of store formats used across the Grocery banner portfolio (e.g., Superstore 100K+ sqft, Neighborhood Market 40-60K sqft, Express/Convenience 10-15K sqft, Warehouse Club, Fuel-Only). Defines format-level attributes such as typical square footage range, standard department count and mix, default service capability set, planogram template family, typical SKU count range, and staffing model template. Used for store clustering, comp sales grouping, assortment planning, new store capital budgeting, and format conversion analysis.' .

ind:Region rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic and organizational hierarchy node representing a regional grouping of districts and stores under a Regional Vice President. Captures region code, region name, VP assignment (employee reference), geographic boundary definition (state/metro groupings), parent division or banner, number of districts, total store count, and active/inactive status. Serves as the primary roll-up level for comp sales reporting, regional pricing zones, promotional planning, workforce organizational structure, and P&L accountability.' .

ind:District rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'District' ;
    rdfs:comment 'Organizational hierarchy node below region, grouping a set of stores (typically 8-15) under a District Manager. Captures district code, district name, district manager employee reference, parent region reference, store count, geographic coverage description, performance tier classification, and active status. Used for operational oversight, labor scheduling aggregation, shrink accountability, weekly sales performance benchmarking, and district manager performance evaluation.' .

ind:Department rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Department' ;
    rdfs:comment 'Operational department within a store such as Produce, Bakery, Deli, Pharmacy, Floral, Frozen Foods, or General Merchandise. Captures department number, name, type classification (perishable, center-store, service), assigned manager, allocated square footage, gondola count, endcap count, cooler door count, planogram family, shrink budget target, HACCP classification, and backroom storage zone configuration (capacity, cooler/freezer flags, FIFO lane count). Supports labor scheduling, category performance reporting, replenishment planning, food safety compliance, and fixture inventory tracking.' .

ind:OperatingHours rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Scheduled and actual operating hours for each store location by day of week and date, including holiday overrides. Captures open time, close time, pharmacy hours, fuel center hours, pickup window hours, and special event hours. Supports omnichannel order fulfillment slot availability, customer-facing store locator, and workforce scheduling.' .

ind:ServiceCapability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Service Capability' ;
    rdfs:comment 'Catalog of service capabilities available at a store location, such as Curbside Pickup, Home Delivery, Click-and-Collect, Pharmacy Drive-Through, Coinstar, Western Union, Starbucks Kiosk, Sushi Bar, Floral Custom Orders, EBT/SNAP/WIC acceptance, lottery sales, money orders, and bottle return. Each record defines the capability type, activation status, capacity limits (e.g., max concurrent pickup orders), staffing requirements, equipment dependencies, and effective date range. Enables omnichannel order routing, customer-facing store locator feature display, labor planning, and site selection analysis.' .

ind:MfcProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Mfc Profile' ;
    rdfs:comment 'Master profile for a Micro-Fulfillment Center (MFC) co-located with or adjacent to a store. Captures MFC ID, associated store location, MFC type (automated/manual), total tote capacity, daily order throughput capacity, temperature zone configuration (ambient, chilled, frozen), WMS system integration reference, activation date, and operational status. Supports omnichannel fulfillment routing and capacity planning.' .

ind:HealthInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Health Inspection' ;
    rdfs:comment 'Record of food safety and health department inspections conducted at a store location. Captures inspection ID, inspection date, inspecting agency (local health department, FDA, USDA), inspection type (routine, follow-up, complaint-driven), overall score, critical violation count, non-critical violation count, HACCP compliance status, corrective action plan, and re-inspection date. Supports FDA/USDA regulatory compliance and HACCP program management.' .

ind:Lease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Lease' ;
    rdfs:comment 'Real estate lease record for store locations that are leased rather than owned. Captures lease ID, store location, landlord entity name, lease commencement date, lease expiration date, renewal option terms, base rent amount, CAM (Common Area Maintenance) charges, rent escalation schedule, co-tenancy clauses, exclusivity provisions, and lease status. Supports real estate portfolio management, SOX financial disclosure, and capital vs. operating lease classification.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all vendor and supplier entities including CPG manufacturers, produce growers, DSD distributors, private-label co-manufacturers, and specialty suppliers. Captures legal entity name, DUNS number, tax ID, headquarters address, business type, ownership structure, minority/diversity certification status, EDI capability flag, GTIN prefix, GS1 GLN, payment terms, currency, lead time, vendor tier classification, and active status. This is the Single Source of Truth (SSOT) for vendor identity across the retail-grocery enterprise. Supports produce-specific attributes (growing region, GAP certification, organic acreage, seasonal availability) for agricultural suppliers.' .

ind:SupplierContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Supplier Contact' ;
    rdfs:comment 'Individual contacts associated with a supplier organization, including account managers, EDI coordinators, compliance officers, quality assurance leads, and category management representatives. Captures contact name, title, functional role type, phone, email, preferred communication channel, escalation priority, and active status. Supports multi-contact relationships per supplier across different functional roles, enabling automated routing of POs, compliance notices, and quality incident notifications to the correct counterpart.' .

ind:SupplierSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Supplier Site' ;
    rdfs:comment 'Physical locations associated with a supplier including manufacturing plants, distribution warehouses, DSD depots, and co-manufacturing facilities. Captures site name, address, site type (plant, warehouse, DSD depot, co-man facility), cold chain capability flag, HACCP certification status, FDA facility registration number, USDA inspection status, and operating hours. Enables sourcing and logistics routing decisions.' .

ind:TradeAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Trade Agreement' ;
    rdfs:comment 'Formal trade agreements between Grocery and its suppliers including master supply agreements, private-label co-manufacturing contracts, DSD distribution agreements, and category captain agreements. Captures contract number, contract type, effective date, expiration date, auto-renewal flag, payment terms, rebate structure, exclusivity clauses, minimum order quantities, SRP compliance requirements, signatory details, and amendment history. Tracks full contract lifecycle from negotiation through amendments, renewals, and expiration with version control for audit compliance.' .

ind:VendorItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Vendor Item' ;
    rdfs:comment 'Supplier-specific item catalog linking vendor part numbers, UPCs, GTINs, and case configurations to Grocery\'s internal SKU master. Captures vendor item number, GTIN/UPC, case pack quantity, inner pack quantity, unit of measure, pallet configuration (TI-HI), minimum order quantity, lead time days, country of origin, organic certification flag, and item status. This is the authoritative cross-reference between supplier item identifiers and Grocery\'s product domain, enabling PO generation, cost management, and receiving operations.' .

ind:CostSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Cost Schedule' ;
    rdfs:comment 'Vendor cost and pricing schedule defining the wholesale cost (COGS) for each vendor item over a defined effective period. Captures vendor item, cost type (base cost, promotional cost, bracket pricing tier), effective start and end dates, unit cost, case cost, allowance type, bill-back vs. off-invoice designation, and currency. Supports COGS calculation, GMROI analysis, and margin management across the merchandise planning process.' .

ind:TradeAllowance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Trade Allowance' ;
    rdfs:comment 'Vendor trade promotion allowances, rebates, and bill-back programs negotiated with CPG suppliers. Captures allowance type (off-invoice, bill-back, scan allowance, performance rebate), promotion period, qualifying SKUs or categories, allowance rate or amount, accrual method, payment trigger (scan, purchase, performance), and settlement status. Supports accounts payable deduction management and promotional funding reconciliation.' .

ind:PerformanceScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Performance Scorecard' ;
    rdfs:comment 'Periodic vendor performance scorecard capturing key supply chain KPIs for each supplier across a measurement period. Captures fill rate percentage, on-time delivery rate, order accuracy rate, invoice accuracy rate, case fill rate, OOS incidents attributed to vendor, OTIF (On-Time In-Full) score, shrink contribution, recall incidents, and overall composite score. Drives vendor tier classification and contract renegotiation decisions.' .

ind:ComplianceRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Vendor compliance requirements and certification obligations that suppliers must meet to do business with Grocery. Captures requirement type (food safety, HACCP, organic certification, USDA inspection, FDA registration, DEA Schedule II-V for pharmacy vendors, GFSI certification, insurance certificate, COA requirements), applicable vendor categories, effective date, renewal frequency, version number, supersession reference (links to prior version when regulatory changes occur), regulatory change effective date, grace period for transition, and documentation submission requirements. Supports version-controlled regulatory change management — when FDA or USDA updates requirements, a new version is created with the prior version marked superseded, enabling audit trail of which requirement version each vendor was certified against.' .

ind:ComplianceRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Compliance Record' ;
    rdfs:comment 'Vendor compliance certification and documentation records tracking whether each supplier has met required compliance obligations. Captures vendor, compliance requirement type, certification body, certificate number, issue date, expiration date, document attachment reference, verification status (submitted, verified, expired, non-compliant), and last audit date. Supports regulatory reporting for FDA, USDA, and DEA compliance programs.' .

ind:FulfillmentSlot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Fulfillment Slot' ;
    rdfs:comment 'Scheduled time windows available for click-and-collect, curbside pickup, or last-mile delivery fulfillment at a given store or MFC. Captures slot date, start/end time, fulfillment type, location, total capacity (max orders), booked count, available capacity, cutoff time for new bookings, and slot status (open, full, closed, cancelled). Also manages individual slot reservations linking a checkout session or order to a specific slot, including reservation timestamp, reservation status (held, confirmed, released, expired), hold expiry timestamp, and release reason. Drives the slot selection UI in checkout and manages capacity contention during high-demand periods such as holidays and promotional events. This is the commerce-layer view of slot availability and reservation for the digital shopping experience; physical fulfillment execution is owned by the fulfillment domain.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Master record for all purchase orders issued to vendors, encompassing both header-level details (vendor, buyer, order type, delivery window, ship-to location, payment terms, lifecycle status) and line-level detail (SKU, ordered quantity, unit cost, pack size, allowances, line status, confirmed ship date). Supports regular, DSD, cross-dock, and promotional PO types. Enables three-way match with goods receipt and vendor invoice. Sourced from SAP MM and Oracle Retail Merchandising System.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Line-item detail for each SKU/item on a purchase order. Captures ordered quantity, unit of measure, agreed cost per unit, SRP, GTIN/UPC, item description, pack size, case pack quantity, allowances, line status, and confirmed ship date. Each line maps to a single SKU and is the atomic unit for receiving reconciliation and invoice matching in SAP MM.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Tracks vendor-initiated shipments (ASN — Advance Ship Notice) from origin to DC or store, encompassing both shipment-level details (carrier, BOL, trailer, origin, destination, scheduled/actual arrival, temperature requirement, status) and line-level detail (SKU, shipped quantity, lot number, expiration date, country of origin, HACCP compliance, pallet configuration). Integrates with JDA TMS and Manhattan Associates WMS for receiving reconciliation.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Records the physical receipt of merchandise at a DC or store against a purchase order or inbound shipment, encompassing both receipt-level details (date/time, dock door, receiver, temperature, GR document number) and item-level detail (received/accepted/rejected quantities by SKU, rejection reason, lot number, expiration date, putaway assignment). Captures OS&D (overage/shortage/damage) at both aggregate and item level. Sourced from SAP MM MIGO and Manhattan Associates WMS.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Store or DC replenishment orders generated by Blue Yonder CAO/demand planning or manually by buyers, encompassing both order-level details (type, source, destination, trigger, status) and line-level detail (SKU, ordered quantity, suggested vs. override quantity, fill rate, line status). Covers auto-replenishment, manual, and emergency order types. Distinct from purchase orders — these are internal DC-to-store transfer orders.' .

ind:DcTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Dc Transfer' ;
    rdfs:comment 'Records inter-DC and DC-to-store stock transfer movements including cross-dock flow-through and store-to-store rebalancing operations. Captures transfer type (cross-dock, pick-and-ship, store-to-store, DC-to-DC), origin location, destination location, transfer date, carrier, trailer number, total pallets, total cases, transfer reason (allocation, rebalancing, emergency, recall, seasonal), priority level, and transfer status (planned, picking, loaded, in-transit, delivered, confirmed). Managed in Manhattan Associates WMS and SAP WM. Enables inventory movement visibility and network optimization.' .

ind:DirectStoreDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Direct Store Delivery' ;
    rdfs:comment 'Direct Store Delivery records for vendor-delivered merchandise bypassing the DC network. Captures DSD vendor, delivery date/time, store location, delivery route number, driver name, total SKUs, total cases, invoice number, payment method (check, EFT, credit), receiving associate, temperature compliance flag, product category (bread, snacks, beverages, dairy), and DSD status (scheduled, delivered, reconciled, disputed). Common for bread, snack, and beverage vendors. Integrates with POS for immediate inventory and cost update.' .

ind:TransportRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Transport Route' ;
    rdfs:comment 'Master record for DC-to-store and inter-DC transportation routes and their execution, encompassing route definition (origin DC, stop sequence, mileage, carrier, trailer type, capacity, frequency), individual stop details (stop location, arrival window, pallet/case count, special handling), and load plan execution (trailer assignment, departure time, load sequence, temperature zones, dispatch status). Managed in JDA TMS. Enables route optimization, freight cost allocation, and carrier performance tracking.' .

ind:VendorLeadTime rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Vendor Lead Time' ;
    rdfs:comment 'Operational lead time parameters by vendor-item-location combination used by Blue Yonder demand planning to calculate reorder points and safety stock. Captures vendor ID, item/SKU, destination DC or store, order-to-ship days, ship-to-receipt days, total lead time days, minimum order quantity, order multiple, case pack size, effective/expiration dates, lead time tier (standard, expedited, emergency), and seasonal adjustment factors. Drives automated replenishment calculations and PO timing. Distinct from vendor master (vendor domain) — this is supply-chain operational planning data.' .

ind:DemandForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Demand Forecast' ;
    rdfs:comment 'Demand and supply forecasts generated by Blue Yonder Demand Planning at the item-location-week level. Captures forecast period, item/SKU, location (store or DC), baseline forecast units, promotional lift units, total forecast units, forecast confidence score, forecast method (statistical, ML, manual override), last updated timestamp, and planner ID. Used to drive replenishment orders and DC allocation. Operational planning data — not an analytics aggregate.' .

ind:AllocationPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Allocation Plan' ;
    rdfs:comment 'DC-to-store allocation plans generated by Blue Yonder Allocation Optimization for constrained or promotional inventory, encompassing both plan-level details (item, source DC, allocation type, method, status) and store-level allocation detail (destination store, allocated quantity, min/max, store tier, override, fulfillment status). Enables equitable distribution of limited supply and store-level fill rate measurement.' .

ind:DcFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Dc Facility' ;
    rdfs:comment 'Master record for Distribution Centers and Micro-Fulfillment Centers (MFCs) in the Grocery supply network. Captures DC code, DC name, address, facility type (full-service DC, cross-dock, MFC, cold storage), total square footage, dock door count, refrigerated capacity (cubic feet), frozen capacity, ambient capacity, WMS system instance, SAP plant code, operating hours, and facility status. Distinct from store master (owned by store domain).' .

ind:SupplierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Contract' ;
    rdfs:comment 'Supply-chain-specific vendor contracts governing purchase terms, fill rate SLAs, lead times, EDI requirements, and compliance obligations. Encompasses contract terms (type, effective dates, minimum fill rate, on-time SLA, EDI compliance) and compliance enforcement including vendor chargebacks for non-compliance events (late shipments, short fills, mislabeling, EDI errors, HACCP violations). Captures chargeback amounts, dispute status, and resolution. Distinct from vendor master (vendor domain) — this is the operational supply agreement and its enforcement.' .

ind:RxPatient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Rx Patient' ;
    rdfs:comment 'HIPAA-compliant master record for pharmacy patients, distinct from the general customer profile. Captures pharmacy-specific patient identity, documented drug allergies and adverse drug reactions (allergen, reaction type, severity, onset date, active/inactive status), medication history consent flags, HIPAA authorization status, primary care physician, insurance eligibility, date of birth for controlled substance age verification, preferred language for counseling, and patient counseling preferences. Owned exclusively by the pharmacy domain as the authoritative patient record for clinical and dispensing workflows. Allergy data supports DUR (Drug Utilization Review) screening for allergy conflicts.' .

ind:Prescription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Prescription' ;
    rdfs:comment 'Core master record for each prescription order written by a prescriber for a patient. Captures Rx number, prescriber NPI, drug NDC, prescribed quantity, days supply, refills authorized, sig (directions), DAW (Dispense As Written) code, prescription origin (written, electronic, phone, fax), issue date, expiration date, and controlled substance schedule (DEA Schedule II–V). Serves as the authoritative Rx record integrating with McKesson Pharmacy Systems.' .

ind:RxFill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Rx Fill' ;
    rdfs:comment 'Transactional record capturing each individual dispensing event (fill or refill) against a prescription. Tracks fill number, fill date, dispensed NDC, dispensed quantity, days supply dispensed, dispensing pharmacist NPI (cross-domain reference to workforce pharmacist credential), fill status (filled, partial, on-hold, cancelled, transferred), copay amount, adjudication result, label printed flag, patient pickup confirmation, will-call bin assignment, DUR screening results (drug-drug interaction alerts, therapeutic duplication, allergy conflicts, override decisions, override reason codes), patient counseling documentation (counseling offered, accepted/declined, method, topics covered, REMS acknowledgment), and transfer metadata when applicable. Each fill is a distinct business event with its own lifecycle. Integrates with McKesson dispensing workflow.' .

ind:Drug rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Drug' ;
    rdfs:comment 'Pharmacy-specific drug item master capturing NDC (National Drug Code) at package level, drug name, generic name, brand name, manufacturer, dosage form, strength, route of administration, DEA schedule (II-V or unscheduled), therapeutic class, GPI (Generic Product Identifier), drug type (Rx, OTC, compound), multi-source indicator (brand, generic, single-source), storage requirements (refrigerated, controlled room temp, freezer), unit of measure, package size, AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), and DESI (Drug Efficacy Study Implementation) status. Complements the product domain\'s general item catalog with pharmacy-specific clinical and pricing attributes required for dispensing and claims adjudication.' .

ind:DrugInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Drug Inventory' ;
    rdfs:comment 'Real-time and historical drug inventory positions at the pharmacy location level, distinct from the general store inventory domain which handles grocery/GM stock. Tracks on-hand quantity by NDC and lot number, expiration date, reorder point, reorder quantity, par level, bin location within pharmacy, controlled substance vault flag, FIFO rotation status, shrink quantity, last physical count date, and perpetual inventory adjustments. Supports DEA controlled substance inventory reconciliation (biennial and perpetual), State Board of Pharmacy compliance reporting, will-call bin management, and automated reorder triggering to McKesson distribution. Pharmacy procurement orders are managed by the supply domain; this product owns position and count data only.' .

ind:InsurancePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Insurance Plan' ;
    rdfs:comment 'Master record for pharmacy benefit insurance plans, manufacturer copay assistance programs, and patient assistance program (PAP) cards accepted at the pharmacy. Captures BIN (Bank Identification Number), PCN (Processor Control Number), group number, plan name, PBM (Pharmacy Benefit Manager) name, plan type (commercial, Medicare Part D, Medicaid, TRICARE, manufacturer_coupon, PAP), formulary tier structure (Tier 1 generic through Tier 5 specialty), coverage rules (covered, non-covered, prior auth required, step therapy required, quantity limit), copay amount by tier, formulary version effective date, prior authorization requirements, step therapy rules, network participation status, and for coupon programs: maximum benefit amount, per-fill cap, eligible NDCs, and program expiration. Used for adjudication routing, eligibility verification, and real-time formulary lookup during prescription processing.' .

ind:RxClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Rx Claim' ;
    rdfs:comment 'Transactional record for each pharmacy insurance claim or claim reversal submitted to a PBM or payer for adjudication. Captures transaction type (original billing B1, reversal B2, rebill), claim submission date, NCPDP transaction code, BIN/PCN/group, patient pay amount, plan pay amount, ingredient cost, dispensing fee, adjudication response code, reject codes, COB (Coordination of Benefits) indicator, MAC (Maximum Allowable Cost) pricing applied, and for reversals: reversal reason code (patient returned, not picked up, billing error, duplicate), reversal response, amount reversed, and restocking action. Supports revenue cycle management, DIR (Direct and Indirect Remuneration) fee tracking, and complete claims lifecycle management.' .

ind:PriorAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Prior Authorization' ;
    rdfs:comment 'Tracks prior authorization (PA) requests submitted to payers for non-formulary or restricted drugs. Captures PA request date, PA number, drug NDC, diagnosis code (ICD-10), clinical criteria submitted, payer decision (approved, denied, pending), approval effective date, expiration date, approved quantity limit, and appeal status. Integrates with McKesson PA workflow and supports clinical pharmacist review processes.' .

ind:Prescriber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Prescriber' ;
    rdfs:comment 'Master record for licensed prescribers (physicians, NPs, PAs, dentists) who write prescriptions filled at Grocery pharmacies. Captures NPI (National Provider Identifier), DEA registration number, DEA schedules authorized, prescriber name, specialty, practice address, state license number, license expiration date, e-prescribing (eRx) capability flag, and preferred contact method. Used for Rx validation, DEA compliance, and prescriber relationship management.' .

ind:PatientMedicationProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Patient Medication Profile' ;
    rdfs:comment 'Consolidated medication history and adherence management record for a pharmacy patient, capturing all active and historical medications including Rx fills, OTC medications self-reported, and medication adherence metrics (PDC — Proportion of Days Covered, MPR — Medication Possession Ratio). Tracks therapy start/stop dates, prescriber, indication, and Medication Synchronization (MedSync) program enrollment including sync date (target monthly pickup day), enrolled medications, program status (active, paused, cancelled), assigned pharmacy technician, and estimated annual fill count. Supports MTM (Medication Therapy Management) services, Star Ratings compliance for Medicare Part D, patient retention through adherence programs, and pharmacy workflow planning.' .

ind:PharmacyLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Pharmacy Location' ;
    rdfs:comment 'Master record for each Grocery pharmacy location capturing pharmacy-specific regulatory credentials and operational configuration distinct from the store domain\'s general location profile. Includes pharmacy NPI, DEA registration number and expiration, State Board of Pharmacy license number and expiration, pharmacy director name and NPI, pharmacist-in-charge designation, operating hours, pharmacy type (full-service, drive-through, 24-hour, specialty), dispensing system identifier (McKesson integration endpoint), CLIA waiver number (for point-of-care testing), controlled substance vault certification status, and maximum prescription volume capacity. Supports DEA registration renewal tracking, State Board inspection readiness, and pharmacy network adequacy reporting.' .

ind:TenderType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Tender Type' ;
    rdfs:comment 'Reference master defining all accepted payment tender types at Grocery including credit card, debit card, EBT/SNAP, WIC, mobile wallet (Apple Pay, Google Pay), gift card, fuel rewards redemption, check, and cash. Captures tender code, tender name, tender category, accepted channels (POS, eCommerce, mobile app), processing network, requires_pin flag, supports_partial_tender flag, is_contactless flag, regulatory_program_code (e.g., SNAP, WIC), and active status. Used by NCR POS and Salesforce Commerce Cloud checkout to validate and route payment instruments.' .

ind:Method rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Method' ;
    rdfs:comment 'Master record of a shopper\'s stored payment instrument on file with Grocery, representing a tokenized payment credential registered for use across POS, eCommerce, and mobile channels. Distinct from tender_type (which defines accepted payment categories), this entity represents a specific customer\'s saved card, wallet, or benefit credential. Captures payment_method_token (PCI DSS tokenized PAN), tender_type_id reference, card_brand (Visa, Mastercard, Amex, Discover), last_four_digits, expiration_month, expiration_year, billing_zip, wallet_provider (Apple Pay, Google Pay, Samsung Pay), gift_card_balance, EBT_card_number_token, is_default flag, is_expired flag, tokenization_provider, and vault_reference_id. Owned by the payment domain as the SSOT for stored payment credentials; shopper identity is linked via FK to customer domain.' .

ind:Gateway rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Reference master of external payment gateway and processor configurations used by Grocery to route authorization and settlement requests. Captures gateway_code, gateway_name, processor_name (e.g., First Data, Worldpay, Stripe), supported_tender_types, gateway_endpoint_url, timeout_ms, retry_policy, settlement_currency, acquirer_bank, merchant_id, terminal_id_prefix, pci_dss_compliance_level, certification_expiry_date, and is_active flag. Supports multi-gateway routing logic for POS, eCommerce, and fuel center payment lanes.' .

ind:Authorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Authorization' ;
    rdfs:comment 'Transactional record of each payment authorization request and response processed through Grocery\'s payment gateways. Captures authorization_code, authorization_status (approved, declined, referred, timeout), tender_type, card_brand, masked_pan, authorization_amount, currency_code, response_code, avs_result_code, cvv_result_code, gateway_reference_id, acquirer_reference_number (ARN), pos_terminal_id, store_id, channel (POS, eCommerce, mobile), requested_at_timestamp, responded_at_timestamp, response_time_ms, partial_approval_flag, partial_approved_amount, and is_void flag. Core transactional entity for real-time payment decisioning sourced from NCR POS and Salesforce Commerce Cloud.' .

ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Core payment transaction record representing a completed payment event at Grocery across all channels and tender types. Captures transaction_type (sale, refund, void, force), transaction_status (completed, failed, voided, reversed), tender_type, transaction_amount, tax_amount, tip_amount, cashback_amount, currency_code, pos_terminal_id, store_id, register_number, cashier_id, channel (in-store POS, eCommerce, curbside pickup, fuel center), transaction_timestamp, batch_id, authorization_id reference, loyalty_account_reference, snap_eligible_amount, wic_eligible_amount, fuel_reward_discount_applied, and receipt_number. SSOT for all payment transactions across NCR POS and Salesforce Commerce Cloud.' .

ind:TransactionTender rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Transaction Tender' ;
    rdfs:comment 'Association entity capturing the individual tender line items applied to a single payment transaction, supporting split-tender scenarios common in grocery retail (e.g., partial EBT + debit card). Captures transaction_id reference, tender_type, tender_amount, tender_sequence_number, payment_method_reference, authorization_id reference, change_due_amount (for cash), ebt_benefit_type (SNAP food, SNAP cash, WIC), gift_card_reference, fuel_reward_points_redeemed, and tender_status. Enables accurate tender-level reconciliation and regulatory reporting for SNAP/WIC transactions.' .

ind:SettlementBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Settlement Batch' ;
    rdfs:comment 'Settlement batch record grouping completed payment transactions submitted to the acquiring bank for funding. Captures batch_number, batch_date, store_id, gateway_id, batch_status (open, submitted, accepted, rejected), total_transaction_count, total_batch_amount, submission_timestamp, settlement_timestamp, acquirer_batch_reference, funding_date, and settlement_currency. Each batch contains line-level settlement details: authorization_code, card_brand, masked_pan, transaction_amount, interchange_fee_amount, assessment_fee_amount, net_settlement_amount, settlement_status (included, excluded, disputed), and exception_reason_code. Supports daily cash reconciliation, interchange fee analysis, exception management, and financial close processes aligned with SAP FI.' .

ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Master record for payment chargebacks and disputes initiated by cardholders or issuing banks against Grocery transactions, including supporting evidence submitted during representment. Captures chargeback lifecycle (reference_number, reason_code, dispute_amount, status through received/review/representment/resolution), card and issuer details, key dates (received, response_due, representment_deadline, resolution), financial impact, and evidence records (evidence_type, file_reference, submission_timestamp, evidence_status). Supports PCI DSS compliance, chargeback win-rate optimization, and financial loss management.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Transactional record of payment refunds issued to shoppers across all channels including in-store POS returns, eCommerce order cancellations, and pharmacy prescription reversals. Captures refund_type (full, partial, exchange), refund_status (pending, approved, processed, failed), original_transaction_id reference, refund_amount, refund_tender_type, refund_reason_code, refund_reason_description, initiated_by_channel, initiated_by_associate_id, approved_by_associate_id, refund_timestamp, return_to_original_tender_flag, store_credit_issued_flag, and store_credit_amount. Sourced from NCR POS returns workflow and Salesforce Commerce Cloud order management.' .

ind:GiftCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Gift Card' ;
    rdfs:comment 'Master record for Grocery-issued gift cards and store credit instruments. Captures gift_card_number_token, gift_card_type (physical, digital, e-gift), initial_load_amount, current_balance, currency_code, issue_date, expiration_date, is_expired flag, is_active flag, is_reloadable flag, purchase_channel, activation_status, activation_timestamp, last_transaction_timestamp, and program_name (e.g., Grocery Gift Card, Holiday Gift Card). Supports gift card issuance, activation, balance inquiry, and redemption workflows across POS and eCommerce channels.' .

ind:ProductItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Item' ;
    rdfs:comment 'Core master record and single source of truth for every sellable item in the Grocery catalog — CPG products, private-label brands, fresh produce, pharmacy drug items, and fuel grades. Stores the authoritative item description, brand reference, pack size, unit of measure, item status (active/discontinued/seasonal), item type (grocery/produce/pharmacy/fuel), temperature class (ambient/refrigerated/frozen), HACCP classification, FDA labeling flag, organic certification flag, USDA grade, private-label indicator, and source system reference. Extended by sku (identification codes and sellable units), drug_item (pharmacy attributes), fuel_grade (fuel center attributes), item_attribute (extensible regulatory/compliance flags), and nutritional_info (FDA nutrition/allergen data). Sourced from Oracle Retail Item Management and SAP MM Material Master.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Retailer-assigned Stock Keeping Unit representing a unique item-pack-location combination for inventory and sales tracking. Stores SKU code, parent item reference, retailer item number, vendor item number, case pack quantity, inner pack quantity, selling unit of measure, catch-weight flag, variable-weight flag, shelf life days, and SKU status (active/inactive/discontinued). Serves as the authoritative single source of truth for all item identification codes including UPC-A, UPC-E, EAN-13, GTIN-14, GS1 DataBar barcodes (with barcode type, barcode value, GS1 company prefix, check digit, primary barcode flag, effective date range) and PLU codes (IFPS standard PLU, commodity type, variety, organic flag per 9-prefix convention, size/grade). Bridges the item master to store-level assortment, inventory positions, and POS transactions. Supports POS scanning, receiving, EDI transactions, manual PLU entry for produce and bulk items, and multi-barcode lookup for items with multiple packaging configurations. Sourced from Oracle Retail Merchandising System and IFPS.' .

ind:ItemHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Hierarchy' ;
    rdfs:comment 'Product classification hierarchy defining the multi-level taxonomy used for category management, merchandise planning, and financial reporting. Stores each node in the hierarchy (department, category, subcategory, segment, subsegment) with node code, node name, hierarchy level number, parent node reference, category captain vendor, GMROI target, and space allocation percentage. Supports planogram design, assortment optimization, ad circular planning, and COGS roll-up by category. Sourced from Oracle Retail Merchandising System.' .

ind:UpcBarcode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Upc Barcode' ;
    rdfs:comment 'Universal Product Code and barcode registry for all items. Stores UPC-A, UPC-E, EAN-13, GTIN-14, and GS1 DataBar codes associated with each SKU, including barcode type, barcode value, GS1 company prefix, check digit, primary barcode flag, and effective date range. Supports POS scanning, receiving, and EDI transactions. Enables multi-barcode lookup for items with multiple packaging configurations.' .

ind:PluCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Plu Code' ;
    rdfs:comment 'Price Look-Up code registry for fresh produce, bulk items, and variable-weight products not identified by UPC. Stores PLU code (IFPS standard), item description, commodity type, variety, organic flag (9-prefix convention), size/grade, and effective date. Used at POS for manual entry of produce and deli items. Sourced from IFPS (International Federation for Produce Standards) and store operations.' .

ind:ItemAttribute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Attribute' ;
    rdfs:comment 'Extensible attribute store and single source of truth for item-level business, regulatory, and compliance attributes that vary by item type and cannot be anticipated at schema design time. Captures attribute name, attribute value, attribute data type, attribute group (regulatory, certification, physical, marketing, sustainability), unit of measure, certifying body, certification number, source system, effective date, and expiration date. Stores all regulatory compliance flags including SNAP/WIC/EBT eligibility, FDA bioengineered food disclosure, organic certification, non-GMO verification, gluten-free certification, kosher/halal certifications, fair-trade status, USDA grade designations, country of origin, and compliance status. Enables flexible attribute extension without schema changes. Note: structured nutritional facts and allergen declarations are owned by nutritional_info; this product handles all other regulatory flags and certifications. Sourced from vendor GS1 Sync data, certifying bodies, and regulatory agencies.' .

ind:NutritionalInfo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Nutritional Info' ;
    rdfs:comment 'FDA-mandated food compliance record serving as the single source of truth for nutritional facts, allergen declarations, and ingredient data for all food and beverage items. Stores serving size, servings per container, calories, total fat, saturated fat, trans fat, cholesterol, sodium, total carbohydrates, dietary fiber, total sugars, added sugars, protein, vitamins and minerals (D, calcium, iron, potassium), percent daily values, FDA compliance status, ingredient list, allergen type (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame per FALCPA), allergen presence indicator (contains/may contain/free-from), allergen declaration source, allergen verification date, and regulatory compliance flag. Supports FDA Nutrition Facts labeling requirements, FALCPA allergen compliance, digital nutrition and allergen display on eCommerce storefronts, customer dietary filtering, recall management for allergen-related incidents, and bioengineered food disclosure. Sourced from vendor-supplied GS1 Sync data and certifying bodies.' .

ind:AllergenDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Allergen and dietary compliance declarations for food items per FDA FALCPA (Food Allergen Labeling and Consumer Protection Act) requirements. Stores the item reference, allergen type (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame), presence indicator (contains/may contain/free-from), declaration source, verification date, and regulatory compliance flag. Supports FDA labeling compliance, customer dietary filtering on digital channels, and recall management.' .

ind:PrivateLabel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Private Label' ;
    rdfs:comment 'Private-label brand registry managing Grocery\'s store-owned brand portfolio. Stores brand name, brand tier (premium/standard/value/organic), brand logo asset reference, brand launch date, brand status, co-manufacturer vendor reference, quality standard tier, target category, brand positioning statement, and packaging specification reference. Supports private-label brand development, sourcing decisions, and category management strategy. Owned by the Grocery merchandising and private-label development team.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Brand master registry and single source of truth for all brands sold across Grocery stores — including CPG manufacturer brands, regional brands, and Grocery\'s private-label store-owned brand portfolio. Stores brand name, brand owner (manufacturer or Grocery private-label), brand type (national/regional/private-label/generic), brand tier (premium/standard/value/organic), parent company, GS1 company prefix, brand status, country of origin, brand logo asset reference, brand launch date, co-manufacturer vendor reference, quality standard tier, target category, brand positioning statement, and packaging specification reference. For private-label brands, additionally tracks brand development lifecycle, sourcing decisions, and category management strategy. Serves as the authoritative brand reference for item master, assortment planning, vendor relationship management, and private-label brand portfolio management. Sourced from merchandising, vendor management, and private-label development teams.' .

ind:ItemCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Cost' ;
    rdfs:comment 'Landed cost record for each SKU-vendor combination capturing all cost components used in margin and COGS analysis. Stores base cost (unit cost from vendor), off-invoice allowances, billback allowances, scan-based trading allowances, freight cost, handling cost, slotting fee amortization, effective date range, cost type (standard/actual/contract/promotional), cost basis (case/each/weight), currency code, and cost source (EDI 832 price catalog, vendor contract, manual override). Supports gross margin calculation, GMROI analysis, promotional lift measurement, and dead net cost reporting. Sourced from SAP MM Purchasing and Oracle Retail Price Management.' .

ind:DrugItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Drug Item' ;
    rdfs:comment 'Pharmacy drug item master extending the core item record with pharmacy-specific attributes. Stores NDC (National Drug Code), drug name (brand and generic), active ingredient, strength, dosage form, route of administration, DEA schedule (I–V or non-scheduled), controlled substance flag, OTC vs Rx flag, therapeutic class, drug interaction group, storage temperature requirement, expiration tracking method, and McKesson drug database reference. Supports McKesson Pharmacy Systems drug inventory and prescription dispensing workflows.' .

ind:ItemVendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Item Vendor' ;
    rdfs:comment 'Association between items and their approved vendors/suppliers, capturing the sourcing relationship. Stores vendor reference, item reference, vendor item number, vendor UPC, primary vendor flag, vendor lead time days, minimum order quantity, order multiple, EDI transaction set supported, DSD indicator, and effective date range. Supports purchase order creation, replenishment planning, and vendor performance management. Sourced from SAP MM Purchasing Info Record and Oracle Retail.' .

ind:Wave rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Wave' ;
    rdfs:comment 'Wave planning record representing a batch of pick tasks grouped for coordinated execution within a DC, MFC, or store backroom. Captures wave number, planned start/end times, wave type (replenishment, e-commerce, DSD), facility zone, total units, total orders, wave status (planned, released, in-progress, completed, cancelled), priority tier, and WMS wave identifier. Waves are the primary unit of work orchestration in fulfillment — all picking activity flows through wave release.' .

ind:WmsTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Wms Task' ;
    rdfs:comment 'Unified warehouse management system task representing any directed work assignment within a DC, MFC, or store backroom — including picking, putaway, replenishment, and cycle count tasks. For pick tasks: tracks task type (single, batch, cluster, zone), assigned associate, pick location (aisle, bay, level, bin), target quantity, actual quantity picked, pick method (voice, RF, paper), start and completion timestamps, exception reason (OOS, damaged, substituted), and WMS task ID. For putaway tasks: tracks task type (directed, random, cross-dock), source location (dock door, staging area), target slot location, SKU/UPC, quantity, lot number, expiration date, putaway method (FIFO, LIFO, FEFO), assigned associate, and exception code (location full, damaged goods, wrong item). All task types share common attributes: task status, priority, wave reference, facility zone, and completion metrics.' .

ind:PackTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pack Task' ;
    rdfs:comment 'Pack task record capturing the packing of picked items into containers or bags for a specific order or tote. Tracks pack station ID, packer associate, container type (bag, box, tote, cooler bag), cold chain flag (ambient, refrigerated, frozen), packed item count, pack start and end timestamps, label printed flag, pack exception codes, and QC check status. Linked to the originating wave and order.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Outbound shipment record representing the complete lifecycle of a physical dispatch of goods from a DC, MFC, or store to a customer or store location. Header: shipment type (last-mile, store replenishment, inter-DC transfer), carrier SCAC, tracking number, BOL, ship/delivery dates, weight, volume, cold chain requirements, temperature range, and status. Line detail: each SKU in the shipment with GTIN/UPC, quantities (ordered vs shipped), lot number, expiration date, temperature zone, FIFO flag, unit of measure, and exception codes (short-shipped, substituted, damaged). Last-mile dispatch: driver ID, vehicle ID, delivery route reference, ETA, actual delivery timestamp, delivery attempt count, outcome (delivered, failed, returned), proof-of-delivery (signature, photo, PIN), customer signature captured flag, and LMD carrier name (Instacart, DoorDash, internal fleet). Consolidates the full shipment lifecycle from creation through line-level fulfillment and last-mile delivery completion.' .

ind:PickupStaging rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Pickup Staging' ;
    rdfs:comment 'Curbside and click-and-collect pickup staging record tracking the readiness and handoff of a customer order at a store pickup location. Captures order ready timestamp, staging bay number, tote count, cold chain tote count, customer arrival timestamp, staging associate, customer check-in method (app, text, kiosk), handoff timestamp, handoff associate, and staging exception (missing item, wrong order, late staging). Pickup staging is the final fulfillment touchpoint for BOPIS/curbside orders — staging time and handoff speed directly impact customer NPS.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Order' ;
    rdfs:comment 'Fulfillment-domain representation of an order released for physical execution, distinct from the commercial order in the order domain. Captures fulfillment order number, source order reference, fulfillment channel (DC, MFC, store backroom, DSD), fulfillment node (facility ID), fulfillment type (delivery, pickup, ship-to-store), SLA due timestamp, fulfillment status (received, waving, picking, packing, staged, dispatched, completed, cancelled), substitution count, and OMS release timestamp. Fill rate is computed from order_line picked vs ordered quantities rather than stored as a static attribute.' .

ind:FulfillmentOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Order Line' ;
    rdfs:comment 'Line-level detail of a fulfillment order representing each SKU to be picked and packed. Tracks UPC, GTIN, PLU (for produce), item description, ordered quantity, allocated quantity, picked quantity, packed quantity, unit of measure, substitution flag, substitute UPC, cold chain zone (ambient, refrigerated, frozen), line status (open, picked, substituted, cancelled, OOS), and pick location assigned.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record of carriers and delivery service providers used for outbound shipments and last-mile delivery. Captures carrier name, SCAC code, carrier type (parcel, LTL, FTL, last-mile, gig-economy), service levels offered, geographic coverage zones, EDI capability flag, API integration flag, cold chain certified flag, insurance limit, preferred carrier tier, and contract reference. Sourced from JDA TMS carrier master.' .

ind:DeliveryRoute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Delivery Route' ;
    rdfs:comment 'Planned delivery route for last-mile dispatch representing a complete sequence of delivery stops assigned to a driver or vehicle for a given shift. Route header: route date, facility origin, total stops, total miles, estimated duration, actual start/end times, route status (planned, in-progress, completed, partial), driver ID, vehicle ID, and optimization source (JDA TMS, manual). Stop detail: stop sequence number, customer address, planned arrival time, actual arrival time, dwell time (minutes), delivery outcome (delivered, failed, partial, returned), failure reason code, proof-of-delivery method (signature, photo, PIN), and stop-level SLA met flag. Enables route-level and stop-level SLA compliance tracking, driver performance analytics, and delivery density optimization.' .

ind:SlotLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Slot Location' ;
    rdfs:comment 'Physical slot or bin location within a DC, MFC, or store backroom used for putaway and pick operations. Captures facility ID, zone (ambient, refrigerated, frozen, pharmacy), aisle, bay, level, bin, slot type (bulk, pick face, reserve, endcap), slot dimensions (height, width, depth), weight capacity, RFID tag ID, current occupancy status (empty, occupied, blocked), and planogram slot reference. Sourced from Manhattan Associates WMS slotting module.' .

ind:SlaPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Sla Policy' ;
    rdfs:comment 'Unified SLA management product encompassing policy definitions and breach event tracking for all fulfillment time commitments. Policy side: SLA name, fulfillment channel (delivery, pickup, ship-to-store), order type (standard, express, same-day, next-day), customer tier, pick/pack/dispatch SLA minutes, total fulfillment SLA hours, effective date range, and active flag. Breach side: individual breach event records where fulfillment orders, tasks, or deliveries failed to meet committed service levels — capturing breach ID, breach type (pick SLA, pack SLA, dispatch SLA, delivery SLA), breach timestamp, minutes overdue, root cause category (OOS, staffing, carrier delay, system outage, weather), impacted order count, customer notification sent flag, escalation level, resolution timestamp, and corrective action. Enables SLA compliance reporting, real-time breach alerting, root cause analysis, and continuous improvement.' .

ind:Node rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Node' ;
    rdfs:comment 'Master record of physical fulfillment nodes including DCs, MFCs, and store backrooms authorized to execute order fulfillment. Captures node name, node type (DC, MFC, store backroom, dark store), address, facility square footage, fulfillment channels supported (delivery, pickup, ship-to-store), daily order capacity, cold chain capability (ambient, refrigerated, frozen), WMS system instance, operating hours, and active status. Distinct from the store master in the store domain — focused on fulfillment operational attributes.' .

ind:Tote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Tote' ;
    rdfs:comment 'Physical tote or container used to consolidate picked items for a specific order or batch during fulfillment. Captures tote barcode, tote type (ambient, refrigerated, frozen, insulated bag), tote capacity (liters), current assignment (order, wave), tote status (available, in-use, staged, dispatched, returned, damaged), last scanned location, last scanned timestamp, and tote condition (clean, soiled, damaged). Totes are the primary unit of physical custody transfer between pick, pack, stage, and dispatch — critical for cold chain segregation in grocery.' .

ind:PromoCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Campaign' ;
    rdfs:comment 'Master record for a promotional marketing campaign. Captures campaign identity, type (weekly ad circular, digital, in-store event, seasonal, vendor-sponsored), planning horizon, budget allocation, sponsoring vendor/CPG partner, campaign objectives (trial, frequency, basket size, loyalty acquisition), target channel (in-store, digital, omnichannel), approval workflow status, and lifecycle state (draft, approved, active, completed, cancelled). Top-level organizing entity for all promotional activity. Source of truth for campaign planning, budget management, and post-promotion performance measurement.' .

ind:PromoOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Offer' ;
    rdfs:comment 'Atomic unit of promotional value delivered to shoppers within a campaign. Captures offer mechanics (BOGO, TPR, percent-off, dollar-off, mix-and-match, bundle, loyalty reward, digital coupon, personalized deal), discount calculation rules, minimum purchase thresholds, maximum redemption limits, offer validity window, eligible channels (in-store, app, web, kiosk), stackability rules, funding source (vendor-funded vs. grocer-funded), activation requirements (auto-apply vs. clip-required), personalization targeting (ML model, rule-based, mass), delivery channel for targeted offers, digital coupon attributes (barcode/QR code, clip status, clip timestamp, coupon code, issuing channel, CPG manufacturer funding), personalization metadata (generation source, targeting rationale, customer/household linkage, deal acceptance/redemption outcome, behavioral signal inputs). Each campaign contains multiple offers targeting different SKUs, customer segments, or channels. Single Source of Truth for ALL promotional offer types including digital coupons, personalized deals, loyalty rewards, and mass offers — no other product in this domain models offer-level promotional value.' .

ind:PromoCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promo Calendar' ;
    rdfs:comment 'Promotional planning calendar that organizes all campaigns and offers across time. Tracks weekly ad circular cycles, promotional periods, blackout dates, holiday event windows, and overlap constraints. Supports merchandise planning and assortment management by providing a structured view of promotional cadence across store zones, categories, and channels. Enables conflict detection between simultaneous promotions and coordination with vendor slotting commitments.' .

ind:AdCircular rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Ad Circular' ;
    rdfs:comment 'Weekly or periodic printed and digital advertising circular that communicates promotional offers to shoppers. Captures circular edition number, effective date range, distribution zone, page count, item placements with page/position coordinates, endcap and gondola feature assignments, digital vs. print format flags, circulation reach, production deadline, and proof approval status. Links to specific offers featured in each circular. Core artifact for weekly promotional execution in retail-grocery — the primary vehicle for communicating TPRs and BOGO offers to price-sensitive shoppers.' .

ind:OfferItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Offer Item' ;
    rdfs:comment 'Association entity linking promotional offers to specific sellable items (SKUs, UPCs, GTINs, PLU codes) eligible for the promotion. Captures included and excluded items, required purchase quantities, qualifying item roles (buy item vs. get item in BOGO, trigger item vs. reward item in mix-and-match), item-level discount overrides, and planogram placement context. Enables precise eligibility determination at POS, self-checkout, and digital checkout. Supports complex multi-item promotions where different items play different mechanical roles.' .

ind:OfferEligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Offer Eligibility Rule' ;
    rdfs:comment 'Business rules governing customer eligibility for promotional offers. Captures rule type (loyalty member only, new customer, geographic zone, household segment, purchase history threshold, SNAP/EBT eligible, WIC eligible), rule logic expressions, customer segment targeting criteria, minimum loyalty tier requirements, and exclusion conditions. Supports personalized deal targeting and compliance with program-specific restrictions such as WIC and SNAP regulations.' .

ind:DigitalCoupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Digital Coupon' ;
    rdfs:comment 'Digital coupon issued through the grocer\'s mobile app, website, or loyalty platform. Captures coupon code, barcode/QR code, face value, discount type, issuing channel (app clip, email, web), clip status, clip timestamp, expiration date, maximum redemption count, CPG manufacturer funding flag, and personalization source (targeted vs. mass). Distinct from paper coupons and in-store TPRs — digital coupons require explicit customer clip/activation before redemption.' .

ind:PromotionRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Promotion Redemption' ;
    rdfs:comment 'Transactional record of a promotional offer being redeemed at POS, self-checkout, or digital checkout. Captures redemption timestamp, transaction/order reference, store or fulfillment channel, offer redeemed (including digital coupon clips and personalized deal acceptances), discount amount applied, customer loyalty account, payment method used (including EBT/SNAP/WIC), item-level redemption detail, and redemption validation status (approved, rejected, partially applied). Core transactional entity for post-promotion performance measurement, vendor funding reconciliation, and coupon clearing house settlement.' .

ind:TprEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Tpr Event' ;
    rdfs:comment 'Temporary Price Reduction (TPR) event record capturing a time-bound price reduction applied to specific SKUs at store or zone level. Tracks TPR start and end dates, original SRP, TPR price, discount depth percentage, store zone applicability, category, vendor funding flag, and whether the TPR is featured in the ad circular or endcap display. Distinct from digital coupons and loyalty offers — TPRs are shelf-level price changes applied automatically at POS without customer action.' .

ind:VendorFunding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Vendor Funding' ;
    rdfs:comment 'Vendor promotional funding record tracking all financial contributions from CPG manufacturers and DSD distributors, including slotting fees for shelf space allocation, endcap placement, new item introductions, and other trade promotion funding arrangements.' .

ind:FundingClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Funding Claim' ;
    rdfs:comment 'Transactional claim submitted to a vendor for reimbursement of promotional funding. Captures claim reference number, vendor identifier, funding agreement reference, claim period, claimed units sold, claimed discount amount, supporting redemption evidence, submission date, vendor acknowledgment status, and payment received date. Supports EDI-based vendor claim processing and accounts receivable reconciliation for promotional funding.' .

ind:PersonalizedDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Personalized Deal' ;
    rdfs:comment 'Personalized promotional deal generated for a specific customer or household based on purchase history, loyalty tier, segment, and behavioral signals. Captures deal generation source (ML model, rule-based, CRM campaign), offer details, targeting rationale, customer or household identifier, deal delivery channel (app push, email, in-store kiosk), deal validity window, and acceptance/redemption outcome. Supports Customer Loyalty and Promotions Management with 1:1 personalization at scale.' .

ind:RetailPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Retail Price' ;
    rdfs:comment 'Authoritative master record of the current shelf price (SRP) for every SKU within a specific price zone and channel. Captures base retail price, effective and expiration dates, price zone assignment, unit of measure, price tier, and price-ending convention. Serves as the single source of truth for item-level retail pricing and the foundation for all price change, markdown, TPR, and promotional pricing workflows.' .

ind:PriceZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Defines geographic or competitive pricing zones used to differentiate retail prices across store clusters. Each zone groups stores with similar competitive environments, cost structures, or market demographics. Supports zone-based pricing strategies where the same SKU carries different shelf prices in different zones. Referenced by retail_price, price_change, and competitive_price records as the geographic pricing boundary.' .

ind:PriceChange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Change' ;
    rdfs:comment 'Transactional record of every approved retail price change event for a SKU in a given price zone. Captures old price, new price, effective date, expiration date, change reason code (cost increase, competitive response, seasonal, vendor-funded), initiating buyer, approval status, and batch reference. Supports FTC pricing compliance audit trails, comp-sales impact analysis, and price change velocity reporting.' .

ind:Markdown rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Markdown' ;
    rdfs:comment 'Records planned and executed markdown events for clearance, seasonal rotation, or perishable shrink reduction. Captures markdown type (permanent, temporary, clearance), markdown percentage or absolute amount, start and end dates, triggering condition (e.g., days-on-shelf threshold, sell-through rate), and store or zone scope. Distinct from TPR promotional pricing — markdowns are inventory-driven price reductions managed by category managers.' .

ind:Tpr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Tpr' ;
    rdfs:comment 'Temporary Price Reduction (TPR) record linking a SKU to a short-term shelf price reduction that is NOT tied to a formal promotion campaign. Captures the TPR price, regular price, discount amount, start and end dates, store or zone scope, and vendor funding flag (indicating whether a CPG vendor is subsidizing the reduction via a trade deal). Distinct from markdown (clearance) and from promotion-driven pricing.' .

ind:CompetitivePrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Competitive Price' ;
    rdfs:comment 'Stores competitive intelligence price observations for key SKUs and PLUs captured from competitor stores, third-party price intelligence feeds (e.g., Numerator, Datasembly), or manual audits. Captures competitor store identifier, competitor chain name, observed price, observed date, data source, and price gap versus Grocery\'s current shelf price. Feeds competitive pricing response workflows and price optimization algorithms.' .

ind:PriceRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Rule' ;
    rdfs:comment 'Business-managed pricing rules and guardrails that govern automated and manual price-setting decisions. Captures rule type (margin floor, competitive index cap, EDLP vs. Hi-Lo strategy flag, price-ending convention), applicable category or department, minimum and maximum price bounds, GMROI threshold, and rule priority. Used by price optimization algorithms and CAO systems to constrain price recommendations within acceptable business parameters.' .

ind:CostPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'Authoritative record of the vendor invoice cost (COGS basis) for each SKU, including base cost, allowances, deal costs, freight, and landed cost components. Captures effective date, expiration date, vendor agreement reference, cost type (standard, actual, replacement, forward-buy), and currency code supporting multi-currency operations. Includes vendor-initiated cost change tracking with old cost, new cost, change effective date, vendor justification (commodity index, freight surcharge, tariff, packaging), buyer acknowledgment status, and resulting retail price action flag. Serves as the cost basis for margin calculation, GMROI analysis, price change justification, and gross profit reporting. Temporal versioning maintains full cost history for audit and trend analysis.' .

ind:ChannelPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Channel Price' ;
    rdfs:comment 'Defines channel-specific price overrides for SKUs sold through digital commerce, delivery, or pickup channels where pricing may differ from in-store shelf price. Captures channel type (in-store, eCommerce, curbside pickup, third-party delivery marketplace), channel price, currency code for multi-currency support, price differential versus shelf price, effective dates, and business justification (delivery surcharge, marketplace fee pass-through, competitive digital pricing). Supports omnichannel pricing consistency governance and regulatory compliance for price representation across channels.' .

ind:PriceOverride rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Override' ;
    rdfs:comment 'Records point-of-sale price overrides where a cashier, store manager, or self-checkout system applied a price different from the registered shelf price. Captures override type (manager override, price match, damaged goods, customer dispute, rain check), original price, override price, reason code, authorizing associate, store location, and POS transaction reference. Critical for FTC scanner accuracy compliance, shrink analysis, and cashier accountability.' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Real-time and near-real-time on-hand stock position for every SKU at every location (store, DC, MFC). Captures on-hand quantity, reserved quantity, available-to-sell quantity, in-transit quantity, on-order quantity, and comprehensive OOS tracking: OOS status flag, OOS start timestamp, OOS end timestamp (when restocked), OOS duration in hours, root cause category (supplier OOS, DC OOS, store receiving delay, shrink, demand spike), estimated lost sales value, and OOS detection method (POS scan failure, CAO signal, manual audit). This is the authoritative SSOT for current inventory levels and out-of-stock events across the enterprise, fed by SAP MM goods movements and Manhattan WMS inventory control. Supports OOS monitoring and alerting, CAO replenishment signal generation, omnichannel availability checks, and store operations performance measurement.' .

ind:GoodsMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Goods Movement' ;
    rdfs:comment 'Transactional record of every inventory movement event — receipts, issues, transfers, adjustments (including cycle-count corrections, damage write-offs, donation dispositions, and recall removals), returns, and write-offs — across all locations. Each record captures movement type (GR, GI, transfer, adjustment, cycle-count-correction), quantity, unit of measure, originating document reference, posting timestamp, and for adjustments: reason code, approving manager, adjustment value at cost, and supporting documentation reference. Sourced from SAP MM material documents and Manhattan WMS transactions. Provides the full audit trail for stock position changes, supports FIFO/LIFO rotation tracking, and serves as the controlled, auditable record for all inventory quantity changes including authorized corrections. This is the single source of truth for all inventory quantity change events.' .

ind:ShrinkRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Shrink Record' ;
    rdfs:comment 'Operational record of inventory shrink events and loss-mitigation dispositions. Captures shrink cause (theft known/unknown, spoilage, damage, administrative error, vendor short-ship), quantity lost, estimated cost of shrink, shrink category, responsible department, and disposition method and outcome — including markdowns (clearance, near-expiry, seasonal, damage markdowns with original price, markdown price, markdown percentage, effective/expiry dates), donations, and disposal. For markdown dispositions: tracks quantity marked down, sell-through outcome, and recovered value. Supports GMROI analysis, loss prevention programs, HACCP compliance for perishable spoilage, shrink reduction programs, and perishable inventory management. Sourced from store shrink entry workflows in SAP MM and Oracle Retail.' .

ind:CycleCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Scheduled and ad-hoc physical inventory count events at the SKU-location level. Captures count date, count method (full, cycle, spot), counted quantity, system quantity at time of count, variance quantity, variance value, count status (scheduled, in-progress, completed, approved), and the associate who performed the count. Drives inventory accuracy KPIs and triggers adjustment postings when variances exceed tolerance thresholds. Sourced from Manhattan WMS cycle count module and SAP MM physical inventory.' .

ind:ReplenishmentSignal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Signal' ;
    rdfs:comment 'CAO (Computer-Assisted Ordering) replenishment signals generated for each SKU-location combination when on-hand stock falls below reorder point or safety stock threshold. Captures signal type (auto-generated, manual override), suggested order quantity, reorder point at time of signal, safety stock level, lead time days, signal status (pending, converted-to-PO, cancelled), and the demand forecast that triggered the signal. Integrates Blue Yonder Demand Planning output with Oracle Retail Replenishment.' .

ind:OosEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Oos Event' ;
    rdfs:comment 'Out-of-Stock (OOS) event records capturing when a SKU at a specific location transitions to zero available-to-sell quantity. Tracks OOS start timestamp, OOS end timestamp (when restocked), OOS duration in hours, root cause category (supplier OOS, DC OOS, store receiving delay, shrink, demand spike), estimated lost sales value, and whether the OOS was detected via POS scan failure, CAO signal, or manual audit. Critical for store operations performance and vendor fill-rate accountability.' .

ind:LotBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Lot Batch' ;
    rdfs:comment 'Lot and batch master records for perishable, regulated, and traceable inventory items. Captures lot number, batch number, production date, expiration date, best-by date, FIFO/FEFO sequence number, country of origin, USDA/FDA certification flags, cold chain entry temperature, current lot status (active, quarantined, recalled, expired, consumed), and comprehensive rotation compliance tracking: rotation method (FIFO, FEFO — First Expired First Out), current rotation sequence at each location, days-to-expiry at time of check, rotation compliance flag (whether stock was rotated per policy), rotation check date, and checking associate. Essential for FIFO/LIFO/FEFO rotation enforcement, HACCP compliance, fresh produce quality management, spoilage reduction, perishable rotation audit, and FDA/USDA food safety traceability. Sourced from SAP MM batch management.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Master record of all physical storage locations within stores, DCs, and MFCs where inventory is held. Captures location type (sales floor, backroom, cooler, freezer, pharmacy vault, fuel tank, MFC bin), aisle, bay, shelf, bin coordinates, planogram slot reference, maximum capacity (units and weight), temperature zone classification, and active status. This is the SSOT for inventory location topology used by WMS putaway, picking, and replenishment workflows.' .

ind:TransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Transfer Order' ;
    rdfs:comment 'Inter-location inventory transfer orders authorizing movement of stock between stores, from DC to store, from DC to MFC, or between DCs. Captures source location, destination location, requested quantity, approved quantity, shipped quantity, received quantity, transfer reason (replenishment, rebalancing, recall, seasonal), transfer status (created, approved, in-transit, received, closed), and expected delivery date. Sourced from Manhattan WMS transfer order management and SAP MM stock transport orders.' .

ind:ReorderPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Reorder Policy' ;
    rdfs:comment 'SKU-location level replenishment policy parameters governing CAO and manual reorder behavior. Captures reorder point (units), safety stock quantity, maximum stock level, economic order quantity (EOQ), order multiple (case pack), lead time days, review cycle (daily, weekly), replenishment method (min-max, demand-driven, vendor-managed), demand forecast reference, and policy effective/expiry dates. Managed in Oracle Retail Replenishment and Blue Yonder Demand Planning. Drives replenishment signal generation and integrates demand forecast inputs for dynamic threshold calculation.' .

ind:PerishableRotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Perishable Rotation' ;
    rdfs:comment 'FIFO/LIFO rotation tracking records for perishable and short-shelf-life inventory. Captures rotation method (FIFO, FEFO — First Expired First Out), current rotation sequence for each lot at each location, days-to-expiry at time of record, rotation compliance flag (whether stock was rotated per policy), rotation check date, and associate who performed the rotation check. Supports HACCP compliance, fresh produce quality management, and reduction of spoilage shrink.' .

ind:ReceivingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Receiving Record' ;
    rdfs:comment 'Inbound inventory receiving records for all goods arriving at stores and DCs — including DC-sourced replenishment, Direct Store Delivery (DSD) from vendor-managed distributors, and inter-location transfers. Captures receiving type (DC-sourced, DSD, transfer), PO or invoice reference, vendor/carrier, DSD vendor identifier, scheduled and actual delivery dates, expected/received/accepted/rejected quantities with rejection reasons, refused quantities with reason for DSD, temperature at receipt for cold chain items, backdoor receiver sign-off, payment terms reference, and receiving status (scheduled, partial, complete, discrepant). Sourced from Manhattan WMS receiving module and SAP MM goods receipt (MIGO). Supports DSD vendor reconciliation, accounts payable three-way match, store-level inventory updates, and DSD-specific audit workflows. This is the single source of truth for all inbound inventory receipts regardless of delivery channel.' .

ind:Banner rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Banner' ;
    rdfs:comment 'Master reference table for banner. Referenced by banner_id.' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
    rdfs:comment 'Master reference table for payment_run. Referenced by payment_run_id.' .

ind:Vehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Vehicle' ;
    rdfs:comment 'Master reference table for vehicle. Referenced by vehicle_id.' .

ind:TemperatureZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Master reference table for temperature_zone. Referenced by zone_id.' .

ind:Payer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Payer' ;
    rdfs:comment 'Master reference table for payer. Referenced by payer_id.' .

ind:Division rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Store ;
    rdfs:label 'Division' ;
    rdfs:comment 'Master reference table for division. Referenced by division_id.' .

ind:TradeAllowanceItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Trade Allowance Item' ;
    rdfs:comment 'This association product represents the Contract between a trade_allowance program and a specific vendor_item that qualifies under that program. It captures the item-level terms of a trade allowance agreement — including item-specific rates, qualifying quantities, accrual amounts, and effective dates — that exist only in the context of a specific allowance-item pairing. Each record links one trade_allowance to one vendor_item and is the authoritative source for deduction management, EDI 844/849 line-item processing, and trade promotion ROI analysis at the SKU level.. Existence Justification: In grocery retail trade promotion management, a single trade allowance program (e.g., a scan allowance or bill-back) routinely covers dozens or hundreds of specific vendor items (SKUs), and a single vendor item can simultaneously participate in multiple active trade allowance programs (e.g., an off-invoice allowance AND a performance rebate from the same supplier). The business actively manages this coverage list — adding or removing qualifying items, setting item-level rates, and tracking accruals per item — making this a genuine operational M:N relationship, not an analytical correlation. The detection phase correctly identified the \'qualifying_sku_list STRING\' anti-pattern on trade_allowance as direct evidence that this M:N is currently unresolved.' .

ind:CircularOfferPlacement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Promotion ;
    rdfs:label 'Circular Offer Placement' ;
    rdfs:comment 'This association product represents the Placement event between a promo_offer and an ad_circular. It captures the operational decision by merchandisers to feature a specific promotional offer at a specific position within a specific circular edition, including the negotiated slotting fee, page location, feature type, and feature size. Each record links one promo_offer to one ad_circular and carries attributes that exist only in the context of that specific placement — they belong neither to the offer alone nor to the circular alone.. Existence Justification: In grocery retail, merchandisers actively manage which promotional offers are placed in which ad circulars — a single offer (e.g., a BOGO on cereal) can appear in multiple circulars (weekly standard, loyalty-exclusive, digital-only), and a single circular contains dozens to hundreds of distinct offers. The placement itself is a managed business artifact: merchandisers negotiate page position, feature size, and slotting fees for each offer-circular combination, making the relationship a first-class operational entity called \'circular offer placement\' that carries its own attributes independent of either the offer or the circular.' .

ind:InboundShipmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment Line' ;
    rdfs:comment 'This association product represents the ASN Line Item — the operational record linking one inbound shipment to one purchase order line. It captures the line-level fulfillment detail for each SKU within an ASN, including quantities shipped, quantities received, variance, and per-line compliance status. Each record is created during ASN processing in Manhattan Associates WMS and reconciled against SAP MM goods receipts during receiving. This entity is the atomic unit for three-way matching (PO line → ASN line → invoice line) and cannot be derived from either the shipment header or the PO line alone.. Existence Justification: In grocery supply chain operations, a single PO line can be fulfilled across multiple inbound shipments (partial shipments, split deliveries across ASNs), and a single inbound shipment (ASN) routinely covers multiple PO lines from one or more purchase orders. This is a genuine operational M:N: the business actively creates, tracks, and reconciles ASN-to-PO-line linkages in Manhattan Associates WMS and SAP MM as part of the receiving and invoice-matching process. The relationship itself carries operational data (shipped quantity per line, received quantity per line, variance, line-level shipment status) that belongs to neither the shipment header nor the PO line alone.' .

# --- Attribute Properties ---
ind:shopperId rdf:type rdf:Property ;
    rdfs:label 'Shopper Id' ;
    rdfs:comment 'Unique surrogate identifier for each grocery shopper record in the Databricks Silver Layer. Serves as the primary key and golden record identifier for all B2C customer identity data integrated from Salesforce CRM and NCR POS loyalty enrollment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:formatId rdf:type rdf:Property ;
    rdfs:label 'Format Id' ;
    rdfs:comment 'Foreign key linking to store.store_format. Business justification: MARKETING: Preferred store format drives targeted campaigns and inventory allocation; shoppers often indicate format preference in loyalty app.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Format .

ind:householdId rdf:type rdf:Property ;
    rdfs:label 'Household Id' ;
    rdfs:comment 'Identifier linking this shopper to a household grouping entity. Multiple shoppers sharing a household are linked via this identifier for household-level analytics, shared loyalty benefits, and targeted household promotions. Resolved through identity matching in Salesforce CRM.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:preferredCategoryId rdf:type rdf:Property ;
    rdfs:label 'Preferred Category Id' ;
    rdfs:comment 'Foreign key linking to assortment.category. Business justification: Category Preference Marketing Report needs each shopper\'s preferred category to target promotions; shoppers naturally have a preferred category, so a FK preferred_category_id → category.category_id is' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:preferredPharmacyLocationId rdf:type rdf:Property ;
    rdfs:label 'Preferred Pharmacy Location Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pharmacy_location. Business justification: Supports loyalty program\'s preferred pharmacy assignment for auto-refill and targeted marketing.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyLocation .

ind:slaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.sla_policy. Business justification: Apply a shopper-tier-based SLA policy for order fulfillment guarantees; used in SLA compliance and compensation reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:storeLocationId rdf:type rdf:Property ;
    rdfs:label 'Store Location Id' ;
    rdfs:comment 'Identifier of the shopper\'s most frequently visited or self-designated home store location. Used for store-level personalization, local ad circular targeting, pickup order routing, and store-level comp sales attribution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreLocation .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date on which the shopper account was permanently closed or deactivated. Populated only when account_status = \'closed\'. Used for GDPR right-to-erasure compliance tracking, retention policy enforcement, and churn analysis.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the shopper account. \'active\' indicates a fully enrolled shopper; \'suspended\' indicates a temporarily restricted account; \'closed\' indicates a permanently deactivated account; \'pending_verification\' indicates registration awaiting email or identity confirmation; \'merged\' indicates the record was consolidated into another golden record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionSource rdf:type rdf:Property ;
    rdfs:label 'Acquisition Source' ;
    rdfs:comment 'Marketing or operational source that drove the shopper\'s initial registration (e.g., \'weekly_ad_circular\', \'referral\', \'loyalty_kiosk\', \'digital_coupon\', \'fuel_center_promo\'). Used for marketing attribution, campaign ROI analysis, and Customer Lifetime Value (CLTV) modeling. [ENUM-REF-CANDIDATE: weekly_ad_circular|referral|loyalty_kiosk|digital_coupon|fuel_center_promo|organic_web|paid_search|social_media — promote to reference product]' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the shopper\'s primary residential address (street number and street name). Used for direct mail delivery, last-mile delivery (LMD) routing, and geographic segmentation analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the shopper\'s primary residential address (apartment, suite, unit number). Supplements address_line1 for complete delivery address resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Date of birth of the shopper in yyyy-MM-dd format. Used for age verification (alcohol, tobacco, pharmacy), birthday loyalty rewards, WIC (Women, Infants, and Children) program eligibility, and demographic segmentation analytics.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the shopper\'s primary residential address. Used for geographic market segmentation, delivery zone assignment, and local promotional targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cltvTier rdf:type rdf:Property ;
    rdfs:label 'Cltv Tier' ;
    rdfs:comment 'Segmentation tier assigned to the shopper based on their Customer Lifetime Value (CLTV) score. Drives differentiated marketing investment, personalized offer depth, and service prioritization. Tiers are recalculated periodically by the analytics platform.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the shopper\'s primary residential address (e.g., \'USA\'). Supports international shopper identification and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the shopper record was first created in the Databricks Silver Layer golden record store, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Represents the RECORD_AUDIT_CREATED category for the MASTER_PARTY role. Used for data lineage, audit trails, and SOX compliance reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier assigned to this shopper in Salesforce CRM (Customer Relationship Management). Used to reconcile the golden record with the CRM source system for B2C identity resolution and personalization workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Direct Mail Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive physical direct mail communications such as weekly Ad Circulars, personalized coupons, and promotional mailers. True = opted in. Drives mailing list inclusion for print marketing campaigns.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ebtCardOnFile rdf:type rdf:Property ;
    rdfs:label 'Ebt Card On File' ;
    rdfs:comment 'Indicates whether the shopper has an EBT (Electronic Benefits Transfer) card registered to their account for online SNAP ordering. True = EBT card on file, enabling SNAP-eligible online checkout per USDA online purchasing pilot requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for the shopper account. Used as the principal digital contact channel for order confirmations, promotional communications, loyalty program updates, and account recovery. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive marketing communications via email. True = opted in. Must be honored in all outbound email campaigns. Consent state is tracked per CAN-SPAM Act and GDPR Article 7 requirements.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the shopper as captured at registration. Used for identity verification, personalized communications, and loyalty program correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-reported gender identity of the shopper. Used for demographic segmentation, personalized product recommendations, and diversity analytics. Collected with explicit consent per GDPR and CCPA requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerified rdf:type rdf:Property ;
    rdfs:label 'Identity Verified' ;
    rdfs:comment 'Indicates whether the shopper\'s identity has been verified through an identity confirmation process (e.g., email verification, phone OTP, or in-store ID check). True = identity confirmed. Used for fraud prevention, age-restricted purchase eligibility, and pharmacy patient linking.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name of the shopper as captured at registration. Combined with first_name to form the full legal identity used in account management and regulatory compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEnrolled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrolled' ;
    rdfs:comment 'Indicates whether the shopper is currently enrolled in Grocery\'s loyalty rewards program. True = enrolled and eligible for points accrual, personalized offers, and loyalty pricing. False = not enrolled. Sourced from NCR POS loyalty integration.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the shopper enrolled in the loyalty rewards program. Used to calculate loyalty tenure, tier progression timelines, and anniversary benefit triggers.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) provided by the shopper, ranging from 0 to 10. Indicates likelihood to recommend Grocery to others. Used for customer satisfaction tracking, churn risk modeling, and service recovery prioritization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent NPS (Net Promoter Score) survey response was captured. Used to assess recency of satisfaction data and determine eligibility for re-survey.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pharmacyPatient rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Patient' ;
    rdfs:comment 'Indicates whether the shopper is also a registered pharmacy patient at a Grocery pharmacy location. True = pharmacy patient record exists (non-PHI flag only; clinical data is managed exclusively in McKesson Pharmacy Systems under HIPAA). Used for cross-domain identity linking without exposing protected health information.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for the shopper, stored in E.164 international format. Used for SMS marketing opt-ins, order pickup notifications, delivery alerts, and two-factor authentication.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posLoyaltyCode rdf:type rdf:Property ;
    rdfs:label 'Pos Loyalty Code' ;
    rdfs:comment 'Loyalty card or account identifier assigned by the NCR POS (Point of Sale) system at the time of in-store loyalty enrollment. Used to link POS transaction history to the shopper golden record.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code of the shopper\'s primary residential address. Used for delivery zone mapping, trade area analysis, demographic append, and targeted ad circular distribution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the shopper prefers to be addressed by in communications and personalized experiences (e.g., nickname or chosen name). May differ from legal first name. Supports personalization in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'Preferred language of the shopper expressed as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-TW\'). Drives localization of digital communications, app content, and in-store signage preferences for omnichannel personalization.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the shopper has enabled push notifications on the Grocery mobile app. True = push notifications enabled. Used for real-time order status updates, personalized offers, and pickup-ready alerts via Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'The channel through which the shopper originally registered their account. Supports acquisition source analytics, channel attribution, and omnichannel engagement strategy. Values align with Grocery\'s omnichannel touchpoints including NCR POS in-store enrollment and Salesforce Commerce Cloud digital channels.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Calendar date on which the shopper account was first created. Used for tenure calculations, cohort analysis, anniversary loyalty rewards, and CLTV (Customer Lifetime Value) segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Marketing and analytics segment assigned to the shopper based on behavioral, demographic, and transactional data (e.g., \'health_conscious\', \'value_seeker\', \'organic_buyer\', \'family_household\', \'convenience_shopper\'). Drives personalized offer targeting and assortment planning. [ENUM-REF-CANDIDATE: health_conscious|value_seeker|organic_buyer|family_household|convenience_shopper|premium_shopper|deal_hunter — promote to reference product]' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the shopper has opted in to receive marketing and transactional communications via SMS text message. True = opted in. Consent is required under TCPA (Telephone Consumer Protection Act) prior to any commercial SMS transmission.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:snapEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Eligible' ;
    rdfs:comment 'Indicates whether the shopper has been identified as eligible to use SNAP (Supplemental Nutrition Assistance Program) / EBT (Electronic Benefits Transfer) for qualifying purchases. True = SNAP-eligible. Used for EBT tender routing at POS and SNAP-compliant product filtering in digital commerce.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state or territory code of the shopper\'s primary residential address (e.g., \'CA\', \'TX\'). Used for state-level regulatory compliance (e.g., state WIC agency reporting, state pharmacy board jurisdiction), tax jurisdiction assignment, and regional marketing segmentation.' ;
    rdfs:domain ind:Shopper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the shopper record in the Databricks Silver Layer, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Used for change data capture (CDC), incremental ETL processing, and audit trail compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wicEligible rdf:type rdf:Property ;
    rdfs:label 'Wic Eligible' ;
    rdfs:comment 'Indicates whether the shopper is enrolled in or eligible for the WIC (Women, Infants, and Children) federal nutrition program. True = WIC-eligible. Enables WIC-approved product filtering, WIC tender acceptance at POS, and compliance reporting to state WIC agencies.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wholesaleAccountId rdf:type rdf:Property ;
    rdfs:label 'Wholesale Account Id' ;
    rdfs:comment 'Primary key for wholesale_account' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WholesaleAccount .

ind:accountOwnerShopperId rdf:type rdf:Property ;
    rdfs:label 'Account Owner Shopper Id' ;
    rdfs:comment 'Foreign key linking to customer.shopper. Business justification: Wholesale_account needs an in-domain relationship to identify the owning shopper (account owner). Adding account_owner_shopper_id creates this link without affecting existing structure.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shopper .

ind:dcFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dc Facility Id' ;
    rdfs:comment 'Foreign key linking to supply.dc_facility. Business justification: Wholesale order fulfillment routing: the DC facility that services a wholesale account determines order routing, delivery scheduling, and freight cost allocation. Grocery wholesale operations assign a' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DcFacility .

ind:dedicatedCarrierId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Carrier Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier. Business justification: Wholesale accounts often have dedicated carrier contracts; needed for carrier billing, SLA compliance, and contract reporting.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:deliveryRouteId rdf:type rdf:Property ;
    rdfs:label 'Delivery Route Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.delivery_route. Business justification: Specific delivery routes are assigned to bulk-shipment wholesale accounts; required for route scheduling and capacity planning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryRoute .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Wholesale B2B accounts (food service, institutional buyers) must be bound to a specific legal entity for contract enforcement, tax-exempt certificate validation, AR invoicing jurisdiction, and EIN/DUN' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:membershipId rdf:type rdf:Property ;
    rdfs:label 'Membership Id' ;
    rdfs:comment 'Foreign key linking to loyalty.membership. Business justification: B2B loyalty programs in grocery wholesale track volume-based rewards at the account level. A direct FK from wholesale_account to membership enables account managers to view loyalty standing, apply who' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:priceRuleId rdf:type rdf:Property ;
    rdfs:label 'Price Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_rule. Business justification: Wholesale contract pricing: wholesale accounts operate under negotiated price rules governing volume tiers, contract rates, and minimum order pricing. A retail-grocery domain expert expects wholesale ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceRule .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Enables profitability analysis per wholesale account; profit_center links sales to internal profit reporting structures.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: Contract management: Supplier contracts are negotiated per wholesale account; linking enables contract compliance, SLA tracking, and account-specific pricing.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Segmentation tier assigned to the wholesale account based on revenue potential, purchase volume, and strategic importance. Determines service levels, dedicated account management, pricing tiers, and promotional eligibility. Values: strategic (top-tier, high-volume), standard (mid-market), small_business (emerging or low-volume).' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the wholesale account by business type, indicating the nature of the organizational buyer. Drives pricing eligibility, product assortment access, and compliance requirements. Satisfies CLASSIFICATION_OR_TYPE category for MASTER_PARTY role. [ENUM-REF-CANDIDATE: restaurant|caterer|institutional|corporate|food_service|school_district|hospital|hotel — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Estimate' ;
    rdfs:comment 'Estimated annual gross revenue (in USD) of the wholesale account\'s business, sourced from credit applications, Dun & Bradstreet data, or account manager input. Used for account tier assignment, credit limit setting, and strategic segmentation.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and accounts receivable correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary street address line for the wholesale account\'s billing address (suite, floor, unit number, etc.). Supplements billing_address_line1 for complete address representation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the wholesale account\'s billing address. Used for invoice generation, tax jurisdiction determination, and geographic segmentation of B2B accounts.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the wholesale account\'s billing address (e.g., USA, CAN). Supports international wholesale accounts and cross-border tax compliance.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code for the wholesale account\'s billing address. Used for tax jurisdiction mapping, delivery zone assignment, and geographic analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateCode rdf:type rdf:Property ;
    rdfs:label 'Billing State Code' ;
    rdfs:comment 'Two-letter US state or territory code for the wholesale account\'s billing address (e.g., CA, TX, NY). Used for state tax compliance, sales tax nexus determination, and regional reporting.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The date on which the wholesale supply agreement or master service contract expires or is scheduled to terminate. Null indicates an open-ended or evergreen contract. Used for renewal alerts, pricing expiry, and account review workflows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'The date on which the wholesale supply agreement or master service contract between Grocery and the wholesale account becomes effective. Used for contract lifecycle management, pricing eligibility, and compliance tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is currently on credit hold, blocking new order processing until outstanding balances are resolved or credit terms are renegotiated. Managed by the accounts receivable team in SAP FI.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'The maximum outstanding accounts receivable balance (in USD) approved for the wholesale account by the credit department. Orders that would cause the balance to exceed this limit are blocked pending credit review. Managed in SAP FI credit management.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal credit risk rating assigned to the wholesale account based on payment history, Dun & Bradstreet data, and financial review. Informs credit limit decisions and payment term negotiations.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or \'Doing Business As\' (DBA) name under which the wholesale account operates, if different from the legal business name. Used for operational communications, order labels, and account management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The preferred or contracted method by which wholesale orders are fulfilled and delivered to the account. DC delivery uses Grocery\'s Distribution Center (DC) fleet; DSD (Direct Store Delivery) uses vendor-direct routes; pickup indicates the account collects from a Grocery facility; third_party_carrier uses an external logistics provider.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'The nine-digit Dun & Bradstreet Data Universal Numbering System (DUNS) number uniquely identifying the wholesale account\'s business entity globally. Used for credit risk assessment, supplier onboarding, and B2B identity verification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Edi Capable Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is set up to exchange orders, invoices, and advance ship notices via Electronic Data Interchange (EDI). EDI-capable accounts use automated order processing workflows, reducing manual entry.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'The federal Employer Identification Number (EIN) / Tax Identification Number (TIN) assigned by the IRS to the wholesale account. Required for tax reporting (1099 issuance), credit applications, and regulatory compliance. Format: XX-XXXXXXX.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The date of the most recent order placed by the wholesale account. Used for account activity monitoring, dormancy detection, and retention analytics. Updated by the order management system upon each new order.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalBusinessName rdf:type rdf:Property ;
    rdfs:label 'Legal Business Name' ;
    rdfs:comment 'The full legal registered name of the wholesale account as it appears on official business registration documents, contracts, and tax filings. Used for invoicing, credit agreements, and regulatory compliance. Satisfies IDENTITY_LABEL category for MASTER_PARTY role.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Amount' ;
    rdfs:comment 'The minimum order value (in USD) required for the wholesale account to place a valid order. Orders below this threshold are flagged or blocked. Used to ensure order profitability and logistics efficiency.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for account managers to record operational notes, special handling instructions, relationship context, or escalation history relevant to the wholesale account. Not used for structured analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'The date on which the wholesale account was formally onboarded and approved to begin placing orders with Grocery. Distinct from created_timestamp (system record creation); this reflects business approval completion.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The agreed payment terms governing when invoices are due for the wholesale account. Drives accounts receivable aging, cash flow forecasting, and order release decisions. Common values: net_30 (payment due 30 days from invoice), net_60, net_90, cod (Cash on Delivery), prepaid.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Day' ;
    rdfs:comment 'The preferred day of the week for wholesale order deliveries to the account, as agreed during onboarding or account setup. Used by the Transportation Management System (TMS) for route optimization and scheduling.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The primary email address for the main business contact at the wholesale account. Used for order confirmations, invoices, promotional communications, and account management. Satisfies PRIMARY_CONTACT category for MASTER_PARTY role.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the wholesale account. Used for account communications, order confirmations, and relationship management. This is a business contact, not a personal consumer.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct phone number for the primary business contact at the wholesale account. Used for order inquiries, delivery coordination, and account management communications.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary business contact at the wholesale account (e.g., Purchasing Manager, Executive Chef, Director of Operations). Used for targeted communications and account segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Code' ;
    rdfs:comment 'Code identifying the geographic or organizational sales territory to which this wholesale account is assigned. Used for territory-based reporting, quota allocation, and account manager assignment.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapWicEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Eligible Flag' ;
    rdfs:comment 'Indicates whether the wholesale account is authorized to purchase SNAP/WIC-eligible products for resale or institutional use under applicable federal program guidelines. Relevant for school districts, food banks, and institutional buyers.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'The state-issued tax exemption or resale certificate number for the wholesale account. Required when tax_exempt_flag is True. Used for sales tax audit compliance and exemption documentation.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the wholesale account holds a valid tax exemption certificate (e.g., resale certificate, government entity, non-profit). When True, applicable sales taxes are suppressed on invoices. Requires a valid tax_exempt_certificate_number.' ;
    rdfs:domain ind:WholesaleAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mergedIntoHouseholdId rdf:type rdf:Property ;
    rdfs:label 'Merged Into Household Id' ;
    rdfs:comment 'When a household record is consolidated (status = \'merged\'), this field references the surviving household ID into which this record was merged. Enables data lineage tracking and prevents orphaned loyalty history. Null when the household has not been merged.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Household .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Foreign key linking to store.region. Business justification: REGIONAL LOYALTY: Household region is used for regional loyalty program eligibility and sales reporting per region.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The channel through which the household was first acquired as a loyalty member. Used for marketing attribution, channel ROI analysis, and acquisition cost modeling. Supports optimization of loyalty enrollment investment across channels. [ENUM-REF-CANDIDATE: in_store|digital|direct_mail|referral|pharmacy|fuel_center|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationOptInEmail rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Email' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing and promotional communications via email. Must be respected for all outbound email campaigns per CAN-SPAM Act and CCPA opt-out requirements.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInMail rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Mail' ;
    rdfs:comment 'Indicates whether the household has opted in to receive physical direct mail communications, including weekly ad circulars and promotional mailers. Used for print campaign targeting and postal budget allocation.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInSms rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Sms' ;
    rdfs:comment 'Indicates whether the household has opted in to receive marketing and promotional communications via SMS/text message. Must be respected per TCPA (Telephone Consumer Protection Act) consent requirements for automated text messaging.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmHouseholdCode rdf:type rdf:Property ;
    rdfs:label 'Crm Household Code' ;
    rdfs:comment 'External household identifier assigned by Salesforce CRM. Used to correlate the lakehouse household record with the corresponding Salesforce CRM household object for bi-directional integration and data lineage.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the originating system or channel through which this household record was first created. Used for data lineage, quality scoring, and source-system reconciliation. Values reflect the operational systems of record integrated into the lakehouse.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryPreferenceFlags rdf:type rdf:Property ;
    rdfs:label 'Dietary Preference Flags' ;
    rdfs:comment 'Comma-delimited list of self-reported or inferred dietary preferences for the household (e.g., \'organic,gluten_free,kosher,vegan\'). Used for personalized product recommendations, digital storefront filtering, and targeted promotions. [ENUM-REF-CANDIDATE: organic|gluten_free|kosher|halal|vegan|vegetarian|dairy_free|nut_free|low_sodium — promote to reference product]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAccountLinked rdf:type rdf:Property ;
    rdfs:label 'Digital Account Linked' ;
    rdfs:comment 'Indicates whether the household\'s loyalty account is linked to a digital account on the Salesforce Commerce Cloud eCommerce platform, enabling online ordering, digital coupons, and personalized web/app experiences.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualGrocerySpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Grocery Spend' ;
    rdfs:comment 'Estimated total annual grocery expenditure for the household across all channels (in-store, pickup, delivery), expressed in USD. Derived from loyalty transaction history and third-party spend data. Used as a key input for CLTV modeling, tier assignment, and promotional investment prioritization. Not a calculated aggregate — represents a modeled estimate stored as a business attribute.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRewardsEnrolled rdf:type rdf:Property ;
    rdfs:label 'Fuel Rewards Enrolled' ;
    rdfs:comment 'Indicates whether the household is enrolled in the fuel rewards program, enabling per-gallon discount accrual at Grocery fuel centers. Used for fuel center promotional targeting and cross-category basket-building incentives.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeOwnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Home Ownership Status' ;
    rdfs:comment 'Indicates whether the household owns or rents their primary residence. Used as a demographic segmentation variable for targeted promotions (e.g., home improvement, cleaning supplies) and CLTV modeling. Sourced from third-party demographic append or loyalty enrollment data.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdName rdf:type rdf:Property ;
    rdfs:label 'Household Name' ;
    rdfs:comment 'Human-readable label for the household, typically derived from the primary shopper\'s surname (e.g., \'Smith Household\'). Used in CRM displays, loyalty communications, and household-level reporting. Serves as the IDENTITY_LABEL for this MASTER_PARTY entity.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdStatus rdf:type rdf:Property ;
    rdfs:label 'Household Status' ;
    rdfs:comment 'Current lifecycle status of the household record. \'active\' indicates an engaged household with recent loyalty activity. \'inactive\' indicates no transactions within the defined inactivity window. \'suspended\' indicates a temporary hold (e.g., fraud review). \'merged\' indicates the household was consolidated into another. \'deceased\' indicates all primary members are deceased.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:householdType rdf:type rdf:Property ;
    rdfs:label 'Household Type' ;
    rdfs:comment 'Classification of the household by its primary relationship with the grocery business. Distinguishes B2C retail shoppers, B2B wholesale accounts, SNAP/WIC/EBT program participants, pharmacy patient households, and employee households. Drives eligibility rules, pricing tiers, and program enrollment. [ENUM-REF-CANDIDATE: b2c_shopper|b2b_wholesale|snap_wic_participant|pharmacy_patient|employee — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeBand rdf:type rdf:Property ;
    rdfs:label 'Income Band' ;
    rdfs:comment 'Estimated annual household income range, derived from third-party demographic data or self-reported during loyalty enrollment. Used for private-label brand targeting, SNAP/WIC eligibility modeling, and CLTV segmentation. Stored as a band rather than exact income to reduce sensitivity.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestHousehold rdf:type rdf:Property ;
    rdfs:label 'Is Test Household' ;
    rdfs:comment 'Indicates whether this household record is a test or synthetic record created for QA, UAT, or system integration testing purposes. Test households must be excluded from all production analytics, reporting, and marketing campaign execution.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase transaction recorded for any member of this household across all channels (in-store, pickup, delivery). Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis, lapsed-shopper identification, and win-back campaign targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Categorical classification of the household\'s current life stage based on composition and demographics. Drives assortment recommendations, promotional targeting, and personalization strategies. Values: single (one adult), couple (two adults, no children), family_with_children, empty_nester (adults, children departed), senior (primary shopper 65+).' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Loyalty Account Number' ;
    rdfs:comment 'The externally-known loyalty program account number associated with this household. Serves as the primary business identifier printed on loyalty cards and referenced at NCR POS during transaction processing. Links household to loyalty accrual and redemption activity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Expiry Date' ;
    rdfs:comment 'Date on which the household\'s loyalty program membership expires or is scheduled for review. Nullable for open-ended memberships. Serves as the EFFECTIVE_UNTIL for the loyalty relationship. Used for renewal campaigns and lapsed-member win-back programs.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberCountAdult rdf:type rdf:Property ;
    rdfs:label 'Member Count Adult' ;
    rdfs:comment 'Number of adult members (age 18+) currently associated with this household. Used to differentiate adult-targeted promotions, alcohol/tobacco eligibility, and per-adult spend benchmarking from total household size.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberCountChild rdf:type rdf:Property ;
    rdfs:label 'Member Count Child' ;
    rdfs:comment 'Number of minor members (age under 18) currently associated with this household. Drives targeting for baby/toddler, school-age, and family product categories, as well as WIC program eligibility assessment.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyHousehold rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Household' ;
    rdfs:comment 'Indicates whether one or more members of this household are active pharmacy patients at a Grocery-operated pharmacy location. Non-PHI flag used for household-level pharmacy service targeting and cross-sell of health/wellness products. No prescription or clinical data is stored in this product.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredFulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Fulfillment Channel' ;
    rdfs:comment 'The household\'s predominant order fulfillment preference based on historical transaction patterns. Values: in_store (traditional shopping), pickup (click-and-collect / curbside), delivery (last-mile delivery), mixed (no dominant channel). Used for omnichannel personalization and capacity planning.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryShopperCode rdf:type rdf:Property ;
    rdfs:label 'Primary Shopper Code' ;
    rdfs:comment 'Reference to the customer record designated as the primary loyalty cardholder and decision-maker for this household. Used for personalization, targeted promotions, and CLTV modeling. The primary shopper holds the loyalty account in their name.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateLabelAffinity rdf:type rdf:Property ;
    rdfs:label 'Private Label Affinity' ;
    rdfs:comment 'Household-level affinity classification for Grocery\'s private-label brand products, based on the share of private-label SKUs in the household\'s purchase history. Used for private-label brand development targeting, promotional investment, and category management insights.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialZipCode rdf:type rdf:Property ;
    rdfs:label 'Residential Zip Code' ;
    rdfs:comment 'Five-digit (or ZIP+4) US postal code of the household\'s primary residence. Used for geographic segmentation, store trade area analysis, last-mile delivery (LMD) zone assignment, and targeted ad circular distribution. Not a full address — ZIP-level granularity balances utility with privacy.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Total number of individuals currently associated with this household, including primary, secondary, and dependent members. Used for basket size benchmarking, per-capita spend analysis, and product assortment planning. Updated dynamically as members join or depart.' ;
    rdfs:domain ind:Household ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactInfoId rdf:type rdf:Property ;
    rdfs:label 'Contact Info Id' ;
    rdfs:comment 'Unique surrogate identifier for each contact information record in the Grocery customer domain. Serves as the primary key for the contact_info data product.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContactInfo .

ind:addressResidentialIndicator rdf:type rdf:Property ;
    rdfs:label 'Address Residential Indicator' ;
    rdfs:comment 'USPS-derived classification indicating whether the address is a residential or commercial location. Impacts last-mile delivery (LMD) carrier surcharge calculations, delivery time window eligibility, and cold chain logistics planning.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the purpose of the physical or mailing address captured in this record (e.g., home, billing, delivery, pickup, mailing). Null when the record represents a non-address contact type such as email or phone.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. \'active\' indicates the contact is valid and in use; \'bounced\' indicates email hard-bounce or phone disconnection; \'suppressed\' indicates the contact is on a suppression list for compliance reasons; \'pending_verification\' indicates awaiting confirmation.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classifies the nature of the contact channel captured in this record (e.g., email, mobile phone, home phone, work phone, fax). Drives channel-specific communication routing and CAN-SPAM/TCPA compliance enforcement.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactValue rdf:type rdf:Property ;
    rdfs:label 'Contact Value' ;
    rdfs:comment 'The actual contact detail for non-address contact types: email address, mobile phone number, home phone number, work phone number, or fax number. Null when the record represents a physical address. Contains PII and must be handled per GDPR/CCPA requirements.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish name associated with the address. Used for local tax jurisdiction mapping, regulatory reporting, and geographic segmentation analytics.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryZoneCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Code' ;
    rdfs:comment 'Internal delivery zone identifier assigned to this address based on geographic proximity to fulfillment centers, micro-fulfillment centers (MFC), or store locations. Used by the Order Management System (OMS) and last-mile delivery (LMD) routing to determine delivery eligibility, time windows, and carrier assignment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dncRegistryCheckedDate rdf:type rdf:Property ;
    rdfs:label 'Dnc Registry Checked Date' ;
    rdfs:comment 'Most recent date on which this phone contact record was checked against the FTC National Do Not Call (DNC) Registry. Required for TCPA compliance; phone numbers must be scrubbed against the DNC registry at least every 31 days before telemarketing calls.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether all outbound communications to this contact record are suppressed regardless of opt-in status. Set when an entity is on a national Do Not Call (DNC) registry, has filed a legal complaint, or has requested complete communication cessation. Overrides all opt-in flags.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this contact record is no longer active or valid. Null for currently active records. Supports bi-temporal modeling, address history retention, and regulatory data retention requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this contact record is considered active and valid for use in communications and fulfillment operations. Supports bi-temporal modeling and historical contact data management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityRef rdf:type rdf:Property ;
    rdfs:label 'Entity Ref' ;
    rdfs:comment 'Identifier of the parent entity (shopper, wholesale account, or pharmacy patient) to whom this contact record belongs. Supports multiple contact records per entity.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Discriminator indicating the type of entity this contact record belongs to, enabling the contact_info product to serve B2C shoppers, B2B wholesale accounts, and pharmacy patients (non-PHI) within the customer domain.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultAddress rdf:type rdf:Property ;
    rdfs:label 'Is Default Address' ;
    rdfs:comment 'Indicates whether this address record is the default address for the entity. Used by the Order Management System (OMS) and omnichannel fulfillment to pre-populate delivery and billing addresses at checkout.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this contact record is the primary contact of its type for the entity. Only one record per entity per contact_type should have is_primary = true. Used to determine the default channel for outbound communications.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the contact value (email or phone) or address has been verified through an active confirmation process (e.g., email click-through, SMS OTP, USPS validation). Drives communication eligibility and fraud risk scoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees, WGS84) derived from USPS address normalization and geocoding. Supports last-mile delivery (LMD) route optimization, store assignment, and geographic segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees, WGS84) derived from USPS address normalization and geocoding. Supports last-mile delivery (LMD) route optimization, store assignment, and geographic segmentation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the entity has provided explicit opt-in consent to receive marketing email communications on this email contact record. Required for CAN-SPAM and GDPR compliance. Null or false for non-email contact types.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPush rdf:type rdf:Property ;
    rdfs:label 'Opt In Push' ;
    rdfs:comment 'Indicates whether the entity has opted in to receive push notifications through the Grocery mobile application or digital commerce platform. Supports omnichannel personalization and promotional targeting via Salesforce Commerce Cloud.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the entity has provided explicit opt-in consent to receive SMS/text message communications on this mobile phone contact record. Required for TCPA compliance. Null or false for non-mobile-phone contact types.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag indicating the entity\'s preferred language for communications delivered to this contact (e.g., en-US, es-MX, zh-CN). Supports multilingual marketing, ad circular distribution, and omnichannel personalization.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this contact record originated (e.g., Salesforce Commerce Cloud for digital registrations, NCR POS for in-store capture, SAP Retail for wholesale accounts, McKesson for pharmacy patients). Supports data lineage and master data management reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContactCode rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Code' ;
    rdfs:comment 'The native identifier of this contact record in the originating operational system of record (e.g., Salesforce Contact Point ID, SAP partner address number). Supports cross-system reconciliation and master data management (MDM) deduplication.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone offset) when the entity unsubscribed or withdrew consent for communications on this contact record. Null if the entity has not unsubscribed. Required for CAN-SPAM 10-business-day honor period and GDPR right-to-withdraw-consent tracking.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uspsDeliveryPointCode rdf:type rdf:Property ;
    rdfs:label 'Usps Delivery Point Code' ;
    rdfs:comment 'Two-digit USPS Delivery Point Code appended to the ZIP+4 to form the full 11-digit delivery point barcode. Confirms precise deliverability and supports carrier route optimization for last-mile delivery (LMD).' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uspsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Usps Validation Status' ;
    rdfs:comment 'Result of USPS address normalization and validation process. \'verified\' indicates the address was confirmed deliverable by USPS; \'unverified\' indicates validation has not been performed or was inconclusive; \'invalid\' indicates the address failed USPS validation and is not deliverable.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Calendar date on which the contact value or address was last successfully verified. Used to assess verification currency and trigger re-verification workflows when verification has lapsed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment 'USPS ZIP or ZIP+4 postal code for the address record. Supports delivery zone routing, geographic segmentation, store assignment, and SNAP/WIC/EBT program eligibility determination.' ;
    rdfs:domain ind:ContactInfo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for a customer segment record in the Grocery CRM and marketing analytics platform. Primary key for the customer_segment reference entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:bannerId rdf:type rdf:Property ;
    rdfs:label 'Banner Id' ;
    rdfs:comment 'Foreign key linking to store.banner. Business justification: In retail-grocery, customer segments are scoped per banner (e.g., Kroger vs. Ralphs vs. Fred Meyer) to drive banner-specific loyalty programs, circular ad campaigns, and CRM differentiation. A domain ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Banner .

ind:adCircularResponsive rdf:type rdf:Property ;
    rdfs:label 'Ad Circular Responsive' ;
    rdfs:comment 'Indicates whether shoppers in this segment are known to respond to weekly promotional ad circulars (print or digital). Used to prioritize segment inclusion in weekly ad circular targeting and Temporary Price Reduction (TPR) campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableChannel rdf:type rdf:Property ;
    rdfs:label 'Applicable Channel' ;
    rdfs:comment 'The shopping channel(s) to which this segment applies for targeting and personalization. \'digital\' applies to Salesforce Commerce Cloud eCommerce and app experiences; \'in_store\' applies to NCR POS loyalty and in-store promotions; \'all\' applies across omnichannel touchpoints.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or username of the individual who formally approved this segment for activation. Supports governance audit trails and accountability for marketing targeting decisions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which this segment definition was formally approved by the owning team or governance committee for use in live marketing and personalization activities. Null if the segment has not yet been approved.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avgBasketSizeBand rdf:type rdf:Property ;
    rdfs:label 'Avg Basket Size Band' ;
    rdfs:comment 'Categorical band representing the typical transaction basket size (number of items or spend level) for shoppers in this segment. Used for assortment planning, endcap and gondola placement decisions, and targeted upsell promotions.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPriority rdf:type rdf:Property ;
    rdfs:label 'Campaign Priority' ;
    rdfs:comment 'Numeric priority ranking used to resolve conflicts when a customer qualifies for multiple segments simultaneously. Lower values indicate higher priority. Used by the CRM and Salesforce Commerce Cloud personalization engine to determine which segment\'s offer or experience takes precedence.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalEngagementScoreBand rdf:type rdf:Property ;
    rdfs:label 'Digital Engagement Score Band' ;
    rdfs:comment 'Categorical band representing the digital engagement level of shoppers in this segment, derived from app usage, click-and-collect frequency, and eCommerce activity on Salesforce Commerce Cloud. Used to tailor digital vs. in-store communication strategies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSegmentCode rdf:type rdf:Property ;
    rdfs:label 'External Segment Code' ;
    rdfs:comment 'The identifier for this segment as known in the originating external system (e.g., Salesforce CRM segment ID, NCR loyalty group code). Used for cross-system reconciliation and integration mapping during ETL and API synchronization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelRewardsEligible rdf:type rdf:Property ;
    rdfs:label 'Fuel Rewards Eligible' ;
    rdfs:comment 'Indicates whether members of this segment are eligible for Fuel Rewards program benefits, including per-gallon discounts at Grocery fuel centers. Used to target fuel-related promotions and cross-sell fuel center offers.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic scope at which this segment is defined and applied. National segments apply across all Grocery markets; regional segments apply to specific trade areas; local and store_cluster segments apply to specific store groups for hyper-local targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPharmacySegment rdf:type rdf:Property ;
    rdfs:label 'Is Pharmacy Segment' ;
    rdfs:comment 'Indicates whether this segment targets pharmacy patients or customers with pharmacy-related behaviors (e.g., prescription refill frequency, OTC purchase patterns). Pharmacy segments must be handled in compliance with HIPAA privacy requirements for non-PHI customer data.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Program' ;
    rdfs:comment 'Indicates whether this segment is associated with a government-regulated assistance program such as SNAP (Supplemental Nutrition Assistance Program), WIC (Women, Infants, and Children), or EBT (Electronic Benefits Transfer). Regulatory program segments require special handling for compliance and reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuppressionSegment rdf:type rdf:Property ;
    rdfs:label 'Is Suppression Segment' ;
    rdfs:comment 'Indicates whether this segment is used as a suppression list to exclude customers from specific campaigns or communications (e.g., opt-out customers, recently converted customers, do-not-contact lists). Suppression segments are applied as exclusion filters in campaign execution.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The date and time when this segment record was most recently updated. Used for change tracking, cache invalidation in personalization engines, and audit compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyProgramLinked rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Linked' ;
    rdfs:comment 'Indicates whether this segment is linked to the Grocery loyalty program for targeted rewards, personalized offers, and NCR POS loyalty integration. Loyalty-linked segments receive differentiated promotional treatment at checkout.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxMemberCount rdf:type rdf:Property ;
    rdfs:label 'Max Member Count' ;
    rdfs:comment 'The configured upper limit on the number of customers that can be assigned to this segment at any given time. Used for capacity-constrained segments such as exclusive loyalty tiers or pilot program cohorts. Null indicates no cap.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsBand rdf:type rdf:Property ;
    rdfs:label 'Nps Band' ;
    rdfs:comment 'Net Promoter Score (NPS) classification band associated with this segment, indicating the general advocacy level of shoppers in the segment. Promoters are highly satisfied advocates; detractors are at-risk shoppers. Used to prioritize retention and win-back campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicAffinity rdf:type rdf:Property ;
    rdfs:label 'Organic Affinity' ;
    rdfs:comment 'Indicates whether shoppers in this segment show a preference for USDA-certified organic products. Used to drive organic assortment decisions, planogram placement, and targeted promotions for organic categories.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Email address of the primary business owner or data steward responsible for this segment. Used for governance notifications, approval workflows, and segment lifecycle management communications.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Name of the internal business team responsible for defining, maintaining, and governing this segment (e.g., \'CRM Analytics\', \'Marketing Strategy\', \'Loyalty Programs\', \'Pharmacy Marketing\'). Used for accountability and data stewardship.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Fulfillment Method' ;
    rdfs:comment 'The order fulfillment method most commonly used by shoppers in this segment. Pickup = curbside or click-and-collect; delivery = last-mile delivery (LMD); in_store = traditional in-store shopping. Used to optimize omnichannel campaign targeting and OMS routing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency Band' ;
    rdfs:comment 'Categorical band representing the typical purchase frequency of shoppers in this segment. Used for lifecycle marketing, replenishment-driven promotions, and churn risk identification. Lapsed indicates shoppers who have not purchased within a defined recency window.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How frequently the membership of this segment is recalculated and refreshed based on updated customer behavior and transaction data. Real-time segments are updated via streaming; manual segments require explicit re-run by the owning team.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Code' ;
    rdfs:comment 'Identifies the specific government assistance program associated with this segment when is_regulatory_program is true. SNAP = Supplemental Nutrition Assistance Program; WIC = Women, Infants, and Children; EBT = Electronic Benefits Transfer. NONE if not a regulatory program segment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short, externally-known alphanumeric code uniquely identifying the segment across systems (e.g., HCL-001, SNAP-EBT, ORG-ENT). Used as the business key in CRM integrations, Salesforce Commerce Cloud personalization rules, and NCR POS loyalty targeting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the segment\'s defining criteria, business purpose, and intended use cases. Authored by the owning marketing or CRM analytics team for documentation and governance purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the market segment as displayed in CRM dashboards, marketing campaign tools, and personalization engines (e.g., \'High-CLTV Loyalists\', \'SNAP/EBT Shoppers\', \'Organic Enthusiasts\', \'Fuel Rewards Members\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment. Active segments are used in live campaigns and personalization. Draft segments are being defined. Under_review segments are pending approval. Archived segments are retained for historical analysis but no longer applied.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology used to define this segment. Behavioral segments are based on purchase patterns; demographic on age/income/household; value-based on Customer Lifetime Value (CLTV) tiers; lifecycle on shopper journey stage; dietary_preference on food choices (organic, gluten-free, etc.).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version number for this segment definition. Incremented each time the segment criteria, name, or configuration is materially changed. Supports segment versioning for A/B testing, campaign attribution, and audit history.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each shopper-to-segment assignment record in the Databricks Silver Layer. Serves as the primary key for this transactional association entity.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Segment Id' ;
    rdfs:comment 'Reference to the customer segment definition to which the shopper is being assigned. Links to the segment master in the Customer domain.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:programConfigId rdf:type rdf:Property ;
    rdfs:label 'Program Config Id' ;
    rdfs:comment 'Reference to the loyalty program under which this segment assignment was created. Segments may be scoped to specific loyalty programs (e.g., standard rewards, premium tier, fuel rewards). Null if the assignment is not tied to a specific loyalty program.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramConfig .

ind:promoCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promo Campaign Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_campaign. Business justification: Campaign-triggered segmentation is a named CRM process in grocery retail: a promo campaign execution triggers re-segmentation of shoppers (e.g., lapsed-buyer win-back campaign moves shoppers into a ne' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoCampaign .

ind:storeClusterId rdf:type rdf:Property ;
    rdfs:label 'Store Cluster Id' ;
    rdfs:comment 'Foreign key linking to assortment.store_cluster. Business justification: Cluster-specific segment execution: retail-grocery personalization and targeted promotion systems apply segment assignments at the store cluster level to match cluster assortment. Drives cluster-scope' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreCluster .

ind:abTestGroup rdf:type rdf:Property ;
    rdfs:label 'Ab Test Group' ;
    rdfs:comment 'Designates the experimental group to which this shopper-segment assignment belongs when the assignment is part of an A/B or multivariate segmentation test. \'control\' is the baseline group; \'treatment_a\' and \'treatment_b\' are variant groups; \'holdout\' is excluded from all treatments for measurement purposes. Null if the assignment is not part of an active test.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the shopper was formally assigned to the segment. Used for time-series segment membership tracking and cohort analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The mechanism by which the shopper was assigned to this segment. \'rule_based\' indicates a deterministic business rule engine; \'ml_model\' indicates a machine learning model prediction; \'manual_override\' indicates a CRM analyst or marketer directly assigned the shopper; \'batch_import\' indicates a bulk load from an external system; \'api_push\' indicates a real-time API-driven assignment from an integrated platform such as Salesforce Commerce Cloud.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The operational system of record that originated this segment assignment. Supports data lineage tracking and reconciliation across integrated platforms. Values correspond to known operational systems: Salesforce Commerce Cloud CRM, NCR POS loyalty integration, Blue Yonder demand planning, internal ML platform, manual CRM tooling, or batch ETL processes.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of this shopper-to-segment assignment. \'active\' means the shopper currently belongs to the segment; \'expired\' means the assignment passed its expiry date; \'revoked\' means it was manually removed; \'pending\' means awaiting activation; \'superseded\' means replaced by a newer assignment for the same segment.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the assignment event was recorded in the system. Supports real-time segmentation pipelines and audit trails. Distinct from assignment_date which captures the business date.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchRunCode rdf:type rdf:Property ;
    rdfs:label 'Batch Run Code' ;
    rdfs:comment 'The identifier of the batch processing run (e.g., Blue Yonder or internal ML platform job execution) that generated this segment assignment. Enables traceability of bulk assignment events back to a specific pipeline execution for debugging, reprocessing, and data lineage auditing. Null for real-time API-driven or manual assignments.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Defines the omnichannel shopping context in which this segment assignment is applicable. \'all_channels\' applies across all touchpoints; \'in_store\' applies only to physical store interactions; \'digital\' applies to eCommerce and app; \'pickup\' applies to Click-and-Collect (curbside or in-store order collection); \'delivery\' applies to last-mile delivery orders; \'pharmacy\' applies to pharmacy-specific interactions. Supports Grocery\'s omnichannel personalization strategy.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'A numeric probability score between 0.0000 and 1.0000 representing the model\'s or rule engine\'s confidence that the shopper belongs to this segment. Populated for ml_model and rule_based assignment methods. Used to filter high-confidence assignments for precision targeting and to support A/B testing of segmentation strategies.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Consent Flag' ;
    rdfs:comment 'Indicates whether the shopper has provided consent for their data to be used in segmentation and targeted marketing activities at the time of this assignment. True means consent is on record. Supports CCPA and GDPR-aligned data privacy compliance for customer data usage in the Customer domain.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which the shopper\'s membership in this segment is considered active and eligible for targeted promotions, personalization, and loyalty offers. May differ from assignment_date if the assignment is scheduled for a future activation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the shopper\'s membership in this segment expires and is no longer valid for targeting. Null indicates an open-ended assignment with no scheduled expiry. Supports time-bounded segmentation strategies such as seasonal or promotional cohorts.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Indicates whether this segment assignment represents the shopper\'s primary or dominant segment when a shopper belongs to multiple segments simultaneously. True means this is the primary segment used for default personalization and offer targeting. Supports single-segment fallback logic in downstream marketing and POS systems.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'The version identifier of the ML model or rule engine that produced this segment assignment. Enables reproducibility, model performance tracking, and rollback analysis. Format follows semantic versioning (e.g., \'v2.3.1\') or a named model run identifier. Null for manual_override and batch_import methods.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Nps Score At Assignment' ;
    rdfs:comment 'The shopper\'s most recent Net Promoter Score (NPS) at the time of segment assignment, on a scale of 0 to 10. Captured as a point-in-time snapshot to contextualize the segmentation decision. Supports analysis of whether segment membership correlates with shopper satisfaction and advocacy.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the shopper has opted out of marketing communications associated with this segment. True means the shopper should not receive outbound marketing for this segment even if the assignment is active. Distinct from data_consent_flag which governs data processing consent.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation provided by the CRM analyst or marketing manager when assignment_method is \'manual_override\'. Documents the business justification for bypassing the automated segmentation engine. Required for audit compliance when overriding ML or rule-based assignments.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible Flag' ;
    rdfs:comment 'Indicates whether the shopper\'s segment assignment qualifies them for personalized digital experiences including eCommerce storefront personalization, app recommendations, and targeted email campaigns via Salesforce Commerce Cloud. Distinct from promotion_eligibility_flag which governs price-based offers.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligibility Flag' ;
    rdfs:comment 'Indicates whether the shopper is eligible to receive targeted promotions, TPR (Temporary Price Reduction) offers, or ad circular inclusions based on this segment assignment. True means the shopper qualifies for segment-specific promotional targeting. Supports the Promotions Management domain and FTC advertising compliance.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleSetCode rdf:type rdf:Property ;
    rdfs:label 'Rule Set Code' ;
    rdfs:comment 'Reference to the specific business rule set definition that triggered this assignment when assignment_method is \'rule_based\'. Enables traceability of which rule configuration produced the membership. Null for ml_model, manual_override, and batch_import methods.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'The high-level category of the segment to which the shopper is assigned. \'behavioral\' segments are based on shopping behavior patterns; \'demographic\' on age, income, or household composition; \'psychographic\' on lifestyle and values; \'transactional\' on purchase history and spend patterns; \'lifecycle\' on shopper journey stage (new, active, lapsed, churned); \'program_based\' on enrollment in specific programs such as SNAP, WIC, or pharmacy.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentRank rdf:type rdf:Property ;
    rdfs:label 'Segment Rank' ;
    rdfs:comment 'Numeric rank (1 = highest priority) indicating the relative priority of this segment assignment among all active segments for the shopper. Used to resolve conflicts when multiple segments offer competing promotions or personalization rules. Lower values indicate higher priority.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapWicEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Eligible' ;
    rdfs:comment 'Indicates whether this segment assignment is specifically associated with a SNAP (Supplemental Nutrition Assistance Program) or WIC (Women, Infants, and Children) program participant segment. True flags the shopper as a government assistance program participant for targeted compliance reporting and eligible product promotions. Supports USDA and FTC regulatory requirements.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionTrigger rdf:type rdf:Property ;
    rdfs:label 'Transition Trigger' ;
    rdfs:comment 'The business event or condition that triggered the shopper\'s transition into this segment. \'purchase_event\' indicates a qualifying transaction; \'loyalty_milestone\' indicates reaching a loyalty tier threshold; \'model_refresh\' indicates a scheduled ML model re-scoring run; \'manual_review\' indicates a CRM analyst-initiated change; \'program_enrollment\' indicates enrollment in SNAP, WIC, or pharmacy program; \'inactivity\' indicates a lapse-based re-segmentation.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each shopper preference record in the Grocery customer preference data product. Serves as the primary key for all preference-related joins and lineage tracking.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to assortment.category. Business justification: Category-level shopper preference drives personalization engines, targeted promotions, and assortment decisions in retail-grocery (e.g., organic Produce preference, Dairy avoidance). product_category_' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Foreign key linking to store.department. Business justification: PROMOTION: Department-level preference allows personalized promotions and shelf-stock decisions per department.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:productItemId rdf:type rdf:Property ;
    rdfs:label 'Product Item Id' ;
    rdfs:comment 'Foreign key linking to product.product_item. Business justification: Personalized marketing uses shopper product preferences; linking preferences to product items enables recommendation engines and targeted promotions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductItem .

ind:certificationPreference rdf:type rdf:Property ;
    rdfs:label 'Certification Preference' ;
    rdfs:comment 'Specifies a product certification standard that the shopper prefers when purchasing. Used to filter product catalog results in digital commerce and to drive assortment recommendations. Aligns with USDA organic certification and GS1 product attribute standards. Null for non-certification preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGiven rdf:type rdf:Property ;
    rdfs:label 'Consent Given' ;
    rdfs:comment 'Indicates whether the shopper has provided explicit consent for Grocery to collect, store, and use their preference data for personalization and targeted marketing purposes. Required for GDPR and CCPA compliance. When FALSE, preference data must not be used for marketing purposes.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The date and time when the shopper provided or last renewed consent for preference data collection and use. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the privacy policy or consent notice under which the shopper\'s preference consent was collected (e.g., \'v2.1\'). Enables compliance teams to identify shoppers who consented under older policy versions and trigger re-consent workflows when policies are updated.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Dietary Restriction Type' ;
    rdfs:comment 'Classifies the nature of a dietary restriction preference. \'allergy\' indicates a medically significant food allergy. \'intolerance\' indicates a food sensitivity. \'medical\' indicates a clinically prescribed dietary requirement. \'religious\' indicates a faith-based dietary rule (e.g., kosher, halal). \'ethical\' indicates a values-based choice (e.g., vegan). \'lifestyle\' indicates a personal wellness choice (e.g., keto). Null for non-dietary preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebtEligibleFilter rdf:type rdf:Property ;
    rdfs:label 'Ebt Eligible Filter' ;
    rdfs:comment 'Indicates whether the shopper has enabled the EBT (Electronic Benefits Transfer) eligible product filter in their digital commerce experience. When TRUE, product search and browse results are filtered to show only EBT-eligible items. Supports SNAP/WIC program compliance in the digital channel.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailFrequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Email Frequency Preference' ;
    rdfs:comment 'The shopper\'s declared preference for how often they wish to receive promotional email communications, including ad circulars and personalized offers. Governs email suppression logic in the CRM platform. Null for non-communication preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Inference Model Version' ;
    rdfs:comment 'The version identifier of the machine learning model used to infer this preference from purchase history or behavioral data (e.g., \'v1.3.2\'). Null for self-declared preferences. Enables model governance, A/B testing of inference models, and rollback of preferences generated by deprecated model versions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this preference record is currently active and should be applied in personalization, product filtering, and marketing targeting. Set to FALSE when a shopper removes or overrides a preference.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAllergy rdf:type rdf:Property ;
    rdfs:label 'Is Allergy' ;
    rdfs:comment 'Indicates whether this preference represents a food allergy or intolerance (e.g., nut allergy, lactose intolerance, celiac/gluten-free). When TRUE, this preference is treated with elevated priority in product filtering and warning displays to protect shopper safety. Aligns with FDA food allergen labeling requirements.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when this preference record was most recently modified, either by the shopper or by the inference engine. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used to identify stale inferred preferences that may need re-evaluation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifestyleDietType rdf:type rdf:Property ;
    rdfs:label 'Lifestyle Diet Type' ;
    rdfs:comment 'Identifies the shopper\'s declared or inferred lifestyle diet pattern. Used to curate personalized product recommendations, recipe suggestions, and category affinities in the digital commerce experience. Null for non-lifestyle preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalGoalType rdf:type rdf:Property ;
    rdfs:label 'Nutritional Goal Type' ;
    rdfs:comment 'Specifies the primary nutritional goal the shopper is pursuing. Used to filter product catalog results and surface nutritionally aligned products in digital commerce. Aligns with FDA nutrition labeling standards. Null for non-nutritional preference categories.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether this preference record is currently eligible to be consumed by the Salesforce Commerce Cloud personalization engine for product recommendations, digital commerce filtering, and targeted marketing. May be FALSE if consent is withdrawn, the preference is expired, or the confidence score is below the minimum threshold.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'High-level grouping that classifies the type of preference being recorded. Drives routing to the correct personalization engine module in Salesforce Commerce Cloud. [ENUM-REF-CANDIDATE: dietary|lifestyle|nutritional_goal|certification|shopping|communication|product_affinity — promote to reference product if additional categories are added]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Indicates how this preference was captured. \'self_declared\' means the shopper explicitly set it via the app or web profile. \'purchase_inferred\' means it was derived from POS transaction history. \'loyalty_inferred\' means it was derived from loyalty program behavior. \'app_behavior\' means it was inferred from digital browsing or filtering actions in Salesforce Commerce Cloud.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the preference record. \'active\' means the preference is in use by the personalization engine. \'inactive\' means the shopper has disabled it. \'pending_review\' means the inferred preference awaits confidence threshold validation. \'overridden\' means a self-declared preference has superseded an inferred one. \'expired\' means the preference has passed its validity window.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Specific preference dimension within the category (e.g., \'nut_allergy\', \'gluten_free\', \'vegan\', \'keto\', \'low_sodium\', \'organic\', \'preferred_store\', \'email_frequency\', \'produce_affinity\'). Granular discriminator used by the personalization engine for product filtering and targeted marketing. [ENUM-REF-CANDIDATE: nut_allergy|lactose_intolerance|gluten_free|vegan|vegetarian|keto|paleo|mediterranean|low_sodium|low_sugar|high_protein|organic|non_gmo|usda_certified|preferred_store|preferred_fulfillment|preferred_day|preferred_time|email_frequency|push_notification|category_affinity — promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The declared or inferred value for this preference dimension. For boolean preferences (e.g., nut allergy) this is \'true\' or \'false\'; for enumerated preferences (e.g., preferred fulfillment) this is the selected option (e.g., \'pickup\', \'delivery\'); for affinity scores this is a numeric string. Flexible string to accommodate all preference types.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredShoppingDay rdf:type rdf:Property ;
    rdfs:label 'Preferred Shopping Day' ;
    rdfs:comment 'The day of the week the shopper most prefers to shop, either declared via app profile or inferred from POS transaction history. Used to time promotional communications (ad circulars, push notifications) and to optimize pickup/delivery slot recommendations. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShoppingTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Shopping Time' ;
    rdfs:comment 'The time-of-day window the shopper most prefers to shop, either declared or inferred from purchase history. Used to schedule push notifications and delivery/pickup slot suggestions. Complements preferred_shopping_day for precise timing of personalized outreach.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privateLabelPreference rdf:type rdf:Property ;
    rdfs:label 'Private Label Preference' ;
    rdfs:comment 'Indicates whether the shopper has a declared or inferred preference for Grocery\'s private-label (store-owned brand) products over national CPG (Consumer Packaged Goods) brands. Used to surface private-label alternatives in product recommendations and to support private-label brand development analytics.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushNotificationTopics rdf:type rdf:Property ;
    rdfs:label 'Push Notification Topics' ;
    rdfs:comment 'Comma-separated list of push notification topic categories the shopper has opted into (e.g., \'promotions,order_updates,loyalty_rewards,weekly_ad\'). Allows granular control over notification content beyond the binary opt-in flag. Managed via the Salesforce Commerce Cloud personalization module.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapWicParticipant rdf:type rdf:Property ;
    rdfs:label 'Snap Wic Participant' ;
    rdfs:comment 'Indicates whether the shopper participates in SNAP (Supplemental Nutrition Assistance Program) or WIC (Women Infants and Children) federal benefit programs. When TRUE, the personalization engine surfaces SNAP/WIC-eligible products and EBT (Electronic Benefits Transfer) payment options. Treated as confidential due to program participation sensitivity.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The digital or physical channel through which this preference was captured or inferred. Distinguishes between mobile app self-declaration, web profile updates, in-store kiosk entry, POS transaction inference, and loyalty portal updates. Used for channel attribution in preference data quality reporting. [ENUM-REF-CANDIDATE: mobile_app|web|in_store_kiosk|associate_entry|pos|loyalty_portal|survey — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'The date after which this preference record is no longer valid and should be excluded from personalization logic. Null indicates an open-ended preference with no expiry. Supports temporary dietary restrictions, seasonal preferences, and time-limited program participation.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date from which this preference record is considered valid and should be applied in personalization and product filtering. Supports time-bounded preferences such as seasonal dietary goals or temporary dietary restrictions.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for each benefit program enrollment record. Primary key for the benefit_enrollment data product in the customer domain.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: SNAP/WIC government reimbursement accounting requires each benefit enrollment type to post to a specific GL account. Grocery retailers must reconcile benefit redemptions against GL accounts for USDA/F' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:tenderTypeId rdf:type rdf:Property ;
    rdfs:label 'Tender Type Id' ;
    rdfs:comment 'Foreign key linking to payment.tender_type. Business justification: EBT/SNAP/WIC benefit enrollments map directly to specific POS tender types in grocery retail. The POS system must resolve which tender_type corresponds to a benefit enrollment to authorize transaction' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TenderType .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Date by which the shopper must file a formal appeal with the issuing agency if the enrollment was denied or suspended. Populated when enrollment_status is denied or suspended. Supports shopper advocacy and regulatory fair hearing compliance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedRetailerNumber rdf:type rdf:Property ;
    rdfs:label 'Authorized Retailer Number' ;
    rdfs:comment 'USDA FNS-assigned retailer authorization number for the grocery store location where the benefit is redeemable. Required for SNAP and WIC regulatory compliance reporting and EBT transaction settlement with the state processor.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the shopper has consented to automatic recertification or renewal processing for this benefit enrollment where permitted by the issuing agency. Supports streamlined recertification workflows and reduces benefit lapse rates.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent synchronization of the benefit_balance field with the state EBT processor or WIC management information system. Indicates data freshness for POS eligibility decisions.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:benefitBalance rdf:type rdf:Property ;
    rdfs:label 'Benefit Balance' ;
    rdfs:comment 'Current remaining benefit balance available on the shopper\'s EBT or WIC benefit account as of the last synchronization with the state EBT processor. Used for POS tender limit enforcement and shopper balance inquiry support.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCardLast4 rdf:type rdf:Property ;
    rdfs:label 'Benefit Card Last4' ;
    rdfs:comment 'Last four digits of the EBT or WIC benefit card number, retained for customer service identification and POS receipt display purposes. Not sufficient to reconstruct the full card number.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCardToken rdf:type rdf:Property ;
    rdfs:label 'Benefit Card Token' ;
    rdfs:comment 'Tokenized representation of the shopper\'s EBT or WIC benefit card number. The actual card number is never stored; only the secure token is retained for POS tender matching and transaction reconciliation. Tokenization complies with PCI DSS and state EBT security requirements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the benefit amount (typically USD for US government programs). Supports multi-currency readiness for future program expansions.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoricalEligibility rdf:type rdf:Property ;
    rdfs:label 'Categorical Eligibility' ;
    rdfs:comment 'Indicates whether the shopper qualifies for the benefit program through categorical eligibility (i.e., automatic eligibility based on participation in another qualifying program such as TANF or SSI) rather than through standard income and resource testing. Simplifies eligibility determination and reduces documentation burden.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized agency-issued code indicating the reason an enrollment application was denied or an active enrollment was suspended. Populated only when enrollment_status is denied or suspended. Used for regulatory reporting and shopper appeals support. [ENUM-REF-CANDIDATE: income_exceeds_limit|residency_not_verified|identity_not_verified|incomplete_application|duplicate_enrollment|ineligible_category|other — promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the shopper completed the benefit program enrollment process. Supports omnichannel analytics and process optimization for enrollment workflows.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the shopper was officially enrolled and approved into the benefit program by the issuing agency. Represents the effective start of benefit eligibility.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known enrollment reference number assigned by the issuing government agency or program administrator. Used for cross-referencing with agency records and POS tender eligibility lookups.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the benefit program enrollment. Active indicates the shopper is currently eligible; pending indicates application submitted but not yet approved; expired indicates the benefit period has lapsed; denied indicates the application was rejected by the issuing agency; suspended indicates temporary hold by the agency.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomeEligibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Income Eligibility Level' ;
    rdfs:comment 'Federal Poverty Level (FPL) income bracket certified by the issuing agency at the time of enrollment. Determines benefit amount tiers and program eligibility thresholds. Expressed as a percentage range of the Federal Poverty Level per USDA FNS guidelines.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Code' ;
    rdfs:comment 'Standardized code identifying the government agency that issued the benefit enrollment. Aligns with USDA FNS state agency codes and enables automated agency-level regulatory reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyName rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Name' ;
    rdfs:comment 'Name of the government agency or authorized body that issued and administers the benefit enrollment (e.g., state Department of Social Services, county health department, USDA FNS regional office). Used for regulatory reporting and agency reconciliation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateCode rdf:type rdf:Property ;
    rdfs:label 'Issuing State Code' ;
    rdfs:comment 'Two-letter ISO 3166-2 US state code of the government agency that issued the benefit enrollment. Supports state-level regulatory compliance reporting and cross-state benefit portability tracking.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Benefit Amount' ;
    rdfs:comment 'Dollar value of government assistance benefits allocated to the shopper per calendar month. Used for POS tender limit enforcement, financial reconciliation with USDA FNS, and regulatory reporting on benefit utilization.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationConsent rdf:type rdf:Property ;
    rdfs:label 'Notification Consent' ;
    rdfs:comment 'Indicates whether the shopper has consented to receive benefit-related notifications (e.g., expiry reminders, recertification alerts, balance updates) via their preferred communication channel. Supports CRM-driven benefit engagement campaigns.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTenderEligible rdf:type rdf:Property ;
    rdfs:label 'Pos Tender Eligible' ;
    rdfs:comment 'Indicates whether this enrollment record currently qualifies the shopper to use the associated benefit card as a valid tender type at the NCR POS system. Derived from enrollment_status and expiry_date but stored as an operational flag for real-time POS eligibility checks.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the government assistance or special benefit program in which the shopper is enrolled. SNAP (Supplemental Nutrition Assistance Program), WIC (Women, Infants, and Children), EBT (Electronic Benefits Transfer), TANF (Temporary Assistance for Needy Families), MEDICAID. Drives POS tender eligibility rules at checkout.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationDate rdf:type rdf:Property ;
    rdfs:label 'Recertification Date' ;
    rdfs:comment 'Date by which the shopper must complete recertification with the issuing agency to maintain uninterrupted benefit eligibility. Used to trigger proactive outreach and prevent benefit lapses.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapHouseholdSize rdf:type rdf:Property ;
    rdfs:label 'Snap Household Size' ;
    rdfs:comment 'Number of individuals in the shopper\'s household as certified by the issuing agency for SNAP benefit calculation purposes. Directly determines the monthly SNAP allotment amount. Applicable only when program_type is SNAP.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this benefit enrollment record was ingested into the Databricks Silver Layer. Supports data lineage tracking and reconciliation across NCR POS, Salesforce CRM, agency portal feeds, and EBT processor interfaces.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocReference rdf:type rdf:Property ;
    rdfs:label 'Verification Doc Reference' ;
    rdfs:comment 'Reference identifier pointing to the document management system record containing the eligibility verification documents submitted by the shopper (e.g., income verification, residency proof, identity documents). Supports audit trails for regulatory compliance without storing document content in the data lakehouse.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDocType rdf:type rdf:Property ;
    rdfs:label 'Verification Doc Type' ;
    rdfs:comment 'Classification of the primary eligibility verification document type submitted by the shopper during enrollment. Used for compliance audit reporting and document completeness checks.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicFoodPackageCode rdf:type rdf:Property ;
    rdfs:label 'Wic Food Package Code' ;
    rdfs:comment 'USDA-assigned food package code designating the specific WIC food package category the shopper qualifies for (e.g., Package A for infants, Package D for women). Determines which product SKUs are WIC-eligible at POS. Applicable only when program_type is WIC.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicParticipantCategory rdf:type rdf:Property ;
    rdfs:label 'Wic Participant Category' ;
    rdfs:comment 'USDA WIC participant category classifying the shopper\'s eligibility basis within the WIC program. Determines food package entitlements and benefit amounts. Applicable only when program_type is WIC.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyPatientId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Patient Id' ;
    rdfs:comment 'Unique surrogate identifier for the pharmacy patient profile record in the Grocery lakehouse Silver layer. Primary key for this entity. Entity role: MASTER_AGREEMENT — represents a long-running enrollment/registration relationship between a shopper and Grocery pharmacy services.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyPatient .

ind:insurancePlanId rdf:type rdf:Property ;
    rdfs:label 'Insurance Plan Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.insurance_plan. Business justification: Insurance verification and adjudication: pharmacy_patient stores insurance_bin_number, insurance_group_number, insurance_pcn, insurance_plan_name as denormalized plain attributes. Normalizing to a pro' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsurancePlan .

ind:pharmacyLocationId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Location Id' ;
    rdfs:comment 'Identifier of the Grocery store location where the patient prefers to fill prescriptions. Used for routing Rx notifications, staffing, and inventory planning at the pharmacy counter.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyLocation .

ind:primaryCarePrescriberId rdf:type rdf:Property ;
    rdfs:label 'Primary Care Prescriber Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.prescriber. Business justification: Care coordination and e-prescribing: pharmacy_patient stores primary_care_physician_name and primary_care_physician_phone as denormalized plain attributes. Linking to prescriber via primary_care_presc' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prescriber .

ind:rxPatientId rdf:type rdf:Property ;
    rdfs:label 'Rx Patient Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.rx_patient. Business justification: Patient identity reconciliation: the grocery CRM\'s pharmacy_patient record must link to the pharmacy system\'s rx_patient to synchronize HIPAA consent, allergy flags, counseling preferences, and MedSyn' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RxPatient .

ind:allergyDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Allergy Disclosure Date' ;
    rdfs:comment 'Date on which the patient most recently disclosed or updated their self-reported allergy information with pharmacy staff. Nullable when allergy_flag is False. Used to prompt periodic allergy review during counseling.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergyFlag rdf:type rdf:Property ;
    rdfs:label 'Allergy Flag' ;
    rdfs:comment 'Non-clinical, self-reported indicator that the patient has disclosed one or more drug or food allergies to pharmacy staff. This is a flag only — clinical allergy details reside in McKesson Pharmacy Systems and are excluded from this non-PHI profile per HIPAA compliance requirements.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRefillConsentDate rdf:type rdf:Property ;
    rdfs:label 'Auto Refill Consent Date' ;
    rdfs:comment 'Date on which the patient provided or last updated consent for the auto-refill program. Required for audit trail and regulatory compliance. Nullable when auto_refill_opt_in is False.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoRefillOptIn rdf:type rdf:Property ;
    rdfs:label 'Auto Refill Opt In' ;
    rdfs:comment 'Indicates whether the patient has opted into the automatic prescription refill program. When True, eligible maintenance medications are automatically queued for refill before the supply runs out. Drives CAO (Computer-Assisted Ordering) logic for pharmacy inventory.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counselingPreference rdf:type rdf:Property ;
    rdfs:label 'Counseling Preference' ;
    rdfs:comment 'Patient\'s preferred method for receiving pharmacist counseling when picking up a new or changed prescription. \'waived\' indicates the patient has formally declined counseling. Required by OBRA-90 regulations for Medicaid patients; captured for all patients as best practice.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counselingWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Counseling Waiver Date' ;
    rdfs:comment 'Date on which the patient most recently waived pharmacist counseling. Nullable when counseling_preference is not \'waived\'. Supports compliance audit trail for OBRA-90 and State Board of Pharmacy inspections.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for prescription home delivery. Captured separately from the shopper\'s primary address to support patients who require delivery to a different location (e.g., workplace, caregiver address). Used by LMD (Last Mile Delivery) routing.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for prescription home delivery (apartment, suite, unit number). Nullable. Complements delivery_address_line1 for complete delivery address specification.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City component of the prescription home delivery address. Used for LMD (Last Mile Delivery) zone assignment and carrier routing.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the prescription home delivery address. Used for delivery zone mapping, carrier selection, and geographic analytics.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateCode rdf:type rdf:Property ;
    rdfs:label 'Delivery State Code' ;
    rdfs:comment 'Two-letter US state code for the prescription home delivery address. Used for carrier zone assignment and state-level pharmacy licensing compliance verification.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disenrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Date' ;
    rdfs:comment 'Date on which the pharmacy patient profile was deactivated or the patient relationship ended. Nullable for currently active patients. Used for record retention scheduling and compliance reporting.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Full name of the legally authorized representative or guardian for patients who cannot consent on their own behalf (e.g., pediatric patients, patients with power of attorney arrangements). Non-PHI reference field. Nullable for adult patients without a designated representative.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRelationship rdf:type rdf:Property ;
    rdfs:label 'Guardian Relationship' ;
    rdfs:comment 'Relationship of the authorized representative or guardian to the pharmacy patient. Used to validate authorization for prescription pickup and counseling consent. Nullable when no guardian is on file.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAcknowledgmentChannel rdf:type rdf:Property ;
    rdfs:label 'Hipaa Acknowledgment Channel' ;
    rdfs:comment 'Method by which the patient acknowledged the HIPAA Notice of Privacy Practices. Supports audit trail for HIPAA compliance. \'verbal_noted\' is used when the patient verbally acknowledged but declined to sign, per HIPAA good-faith effort documentation requirements.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Acknowledgment Date' ;
    rdfs:comment 'Date on which the patient acknowledged receipt of the HIPAA Notice of Privacy Practices. Nullable when hipaa_notice_acknowledged is False. Required for HIPAA compliance audit trail.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaNoticeAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Hipaa Notice Acknowledged' ;
    rdfs:comment 'Indicates whether the patient has acknowledged receipt of the pharmacy\'s HIPAA Notice of Privacy Practices (NPP). Required by HIPAA Privacy Rule for all new pharmacy patients. Pharmacies must make a good-faith effort to obtain written acknowledgment.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Patient\'s preferred language for pharmacy communications, prescription labels, and counseling materials. Stored as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-TW\'). Used to route multilingual pharmacy staff and generate translated prescription materials per FDA labeling guidance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRxFillDate rdf:type rdf:Property ;
    rdfs:label 'Last Rx Fill Date' ;
    rdfs:comment 'Date of the patient\'s most recent prescription fill at any Grocery pharmacy location. Non-PHI operational field used for patient activity monitoring, inactive patient identification, and MedSync scheduling. Sourced from McKesson Pharmacy Systems.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyRxPointsEligible rdf:type rdf:Property ;
    rdfs:label 'Loyalty Rx Points Eligible' ;
    rdfs:comment 'Indicates whether the patient is eligible to earn loyalty program points for qualifying prescription fills. Integrates pharmacy activity with the Grocery loyalty program managed via NCR POS Systems and CRM. Certain prescription categories (e.g., controlled substances) may be ineligible per program rules.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mckessonPatientCode rdf:type rdf:Property ;
    rdfs:label 'Mckesson Patient Code' ;
    rdfs:comment 'External patient identifier assigned by McKesson Pharmacy Systems (the operational system of record for prescription management). Used to cross-reference non-PHI profile data in the lakehouse with clinical records in McKesson. Required for operational reconciliation.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medsyncEnrolled rdf:type rdf:Property ;
    rdfs:label 'Medsync Enrolled' ;
    rdfs:comment 'Indicates whether the patient is enrolled in the Medication Synchronization (MedSync) program, which aligns all of the patient\'s maintenance prescriptions to a single monthly pickup date. Improves adherence and reduces pharmacy counter traffic variability.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medsyncEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Medsync Enrollment Date' ;
    rdfs:comment 'Date on which the patient was enrolled in the MedSync program. Used for program tenure tracking and cohort analysis. Nullable when medsync_enrolled is False.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medsyncSyncDate rdf:type rdf:Property ;
    rdfs:label 'Medsync Sync Date' ;
    rdfs:comment 'The designated monthly calendar date on which all synchronized prescriptions for this patient are scheduled for pickup or delivery. Nullable when medsync_enrolled is False. Used for pharmacy workload planning and inventory pre-positioning.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:n340bEligible rdf:type rdf:Property ;
    rdfs:label 'N340b Eligible' ;
    rdfs:comment 'Indicates whether the patient is eligible for the 340B Drug Pricing Program, which provides discounted outpatient drugs to qualifying patients of covered entities. Non-PHI eligibility flag used for claims routing and pricing.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Status' ;
    rdfs:comment 'Current lifecycle status of the pharmacy patient profile. \'active\' indicates the patient is actively using Grocery pharmacy services. \'inactive\' indicates no recent activity. \'on_hold\' indicates a temporary suspension of services. \'transferred\' indicates the patient has moved to another pharmacy. \'deceased\' is set upon notification of patient death for record retention compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientType rdf:type rdf:Property ;
    rdfs:label 'Patient Type' ;
    rdfs:comment 'Classification of the pharmacy patient by service type. \'retail\' is the standard in-store patient. \'mail_order\' indicates the patient primarily uses mail-order fulfillment. \'specialty\' indicates enrollment in specialty pharmacy programs for high-cost or complex medications. \'long_term_care\' indicates a patient in a care facility. \'pediatric\' indicates a minor patient with a guardian on file.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxNotificationChannel rdf:type rdf:Property ;
    rdfs:label 'Rx Notification Channel' ;
    rdfs:comment 'Patient\'s preferred communication channel for prescription-related notifications, including ready-for-pickup alerts, refill reminders, and drug interaction notices. Drives outbound messaging routing in McKesson and NCR POS Systems.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rxReadyPickupPreference rdf:type rdf:Property ;
    rdfs:label 'Rx Ready Pickup Preference' ;
    rdfs:comment 'Patient\'s preferred method for collecting ready prescriptions. Supports omnichannel fulfillment including in-store counter, curbside pickup (Click-and-Collect), drive-through pharmacy window, and home delivery. Drives OMS (Order Management System) routing for pharmacy fulfillment.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapBenefitEligible rdf:type rdf:Property ;
    rdfs:label 'Snap Benefit Eligible' ;
    rdfs:comment 'Indicates whether the patient has been identified as eligible for SNAP (Supplemental Nutrition Assistance Program) benefits, which may affect OTC product eligibility at the pharmacy counter. Non-PHI flag aligned with the shopper master SNAP eligibility field.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wicBenefitEligible rdf:type rdf:Property ;
    rdfs:label 'Wic Benefit Eligible' ;
    rdfs:comment 'Indicates whether the patient has been identified as eligible for WIC (Women, Infants, and Children) program benefits, which may affect eligible OTC and formula purchases at the pharmacy counter. Non-PHI flag.' ;
    rdfs:domain ind:PharmacyPatient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent record. Primary key for the consent_record data product in the customer domain.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Previous Consent Record Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior consent record that this record supersedes or replaces. Enables consent history chain reconstruction for audit and regulatory investigation purposes. Null for the initial consent record.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentRecord .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'The business reason explaining why this consent record was created or modified. Supports audit trails and compliance investigations. [ENUM-REF-CANDIDATE: shopper_request|legal_text_update|regulatory_mandate|system_migration|fraud_investigation|deceased_notification|other — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The exact date and time when the shopper granted consent for the specified consent type. Serves as the authoritative timestamp for consent activation and regulatory audit trails.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which this consent record is scheduled to expire and require renewal. Null for indefinite consents. Supports re-consent campaign triggers and ensures consent currency for regulatory compliance.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'The IETF BCP 47 language code representing the language in which the consent notice was presented to the shopper (e.g., \'en\', \'es\', \'zh-TW\'). Supports multilingual compliance and ensures consent was presented in the shopper\'s preferred language.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint through which the shopper provided or withdrew consent. Used for compliance auditing and channel attribution. Includes digital (app, web), physical (in-store kiosk, POS), and assisted (call center, paper form) channels.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of this consent record. Indicates whether the shopper has actively granted, withdrawn, or is pending confirmation of consent for the specified consent type.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent being captured. Defines the specific communication channel or data-use purpose for which the shopper has provided or withdrawn consent. [ENUM-REF-CANDIDATE: marketing_email|sms|push_notification|direct_mail|data_sharing_cpg|personalization|analytics — promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Partner Code' ;
    rdfs:comment 'Identifies the specific Consumer Packaged Goods (CPG) partner or third-party organization with whom shopper data may be shared under this consent record. Applicable only when consent_type is \'data_sharing_cpg\'. Null for all other consent types.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the shopper when providing or withdrawing consent. Captured for regulatory audit context and digital channel analytics. Null for non-digital consent sources. [ENUM-REF-CANDIDATE: mobile_ios|mobile_android|desktop|tablet|kiosk|pos_terminal|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the shopper completed a double opt-in confirmation step (e.g., clicked a confirmation link in a verification email or SMS) for this consent record. Relevant for email and SMS marketing consent under CAN-SPAM and TCPA best practices.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Date' ;
    rdfs:comment 'The date and time when the shopper completed the double opt-in confirmation step. Null if double_opt_in_confirmed is false or not applicable for the consent type.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address of the device from which the shopper submitted their consent decision. Captured for regulatory proof-of-consent and fraud detection. Null for non-digital consent sources. May be considered PII under CCPA.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSuppressed rdf:type rdf:Property ;
    rdfs:label 'Is Suppressed' ;
    rdfs:comment 'Indicates whether this shopper is currently on the suppression list for the associated consent type. When true, the shopper must be excluded from all outbound communications of the corresponding type regardless of other consent flags.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction under which this consent record is governed. Determines which privacy regulations apply (e.g., CCPA for California residents, state-level privacy laws for other states). Drives jurisdiction-specific consent logic and reporting. [ENUM-REF-CANDIDATE: US-CA|US-VA|US-CO|US-CT|US-UT|US-FED|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramConsent rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Consent' ;
    rdfs:comment 'Indicates whether the shopper has consented to the use of their loyalty program transaction data (purchase history, points activity) for personalization and targeted marketing purposes. Distinct from general analytics consent.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorGuardianConsent rdf:type rdf:Property ;
    rdfs:label 'Minor Guardian Consent' ;
    rdfs:comment 'Indicates whether consent was provided by a parent or legal guardian on behalf of a minor shopper. Relevant for COPPA compliance when the shopper is under 13 years of age.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfConsentReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Consent Reference' ;
    rdfs:comment 'An external reference identifier (e.g., document ID, screenshot hash, call recording ID, or form submission ID) that serves as auditable proof of the consent event. Supports regulatory investigations and legal hold processes.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Re Consent Requested Date' ;
    rdfs:comment 'The date on which a re-consent request was sent to the shopper. Null if no re-consent request has been issued. Used to track re-consent campaign outreach and measure response rates.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required' ;
    rdfs:comment 'Indicates whether this consent record requires re-confirmation from the shopper, typically triggered by a legal text version change, consent expiry, or regulatory update. Drives re-consent campaign targeting in CRM.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The primary regulatory framework governing this consent record. Enables framework-specific compliance reporting and audit queries. A single consent record may be governed by one primary framework even if multiple apply.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Suppression Effective Date' ;
    rdfs:comment 'The date on which the suppression became active for this shopper and consent type. Used to determine when outbound communications must cease. Null when is_suppressed is false.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Suppression Expiry Date' ;
    rdfs:comment 'The date on which the suppression is scheduled to expire, if applicable. Null for permanent suppressions (e.g., deceased, fraud flag). Enables automated re-activation of communication eligibility after temporary suppression periods.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the shopper was added to the suppression list. Supports compliance reporting and operational triage. Null when is_suppressed is false.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Suppression Source System' ;
    rdfs:comment 'The operational system of record that triggered or originated the suppression event. Supports data lineage, audit trails, and cross-system reconciliation for compliance investigations. [ENUM-REF-CANDIDATE: salesforce_crm|ncr_pos|mckesson|sfcc|call_center|manual|legal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionType rdf:type rdf:Property ;
    rdfs:label 'Suppression Type' ;
    rdfs:comment 'The specific communication channel or data-use category for which the shopper is suppressed. Null when is_suppressed is false. Drives suppression list filtering in outbound marketing execution systems.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The exact date and time when the shopper withdrew or revoked consent for the specified consent type. Null if consent has not been withdrawn. Required for CCPA opt-out audit trails.' ;
    rdfs:domain ind:ConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The externally-known alphanumeric GL account number as defined in the SAP FI Chart of Accounts (SKA1 table). This is the primary business identifier used across all financial postings, journal entries, and regulatory disclosures. Typically a 6–10 digit numeric code aligned with the company\'s chart of accounts structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'SAP FI account group (KTOKS) that controls the number range and field status for the GL account. Groups accounts by functional category such as balance sheet accounts, P&L accounts, cost accounts, or reconciliation accounts. Used for mass maintenance and reporting segmentation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Level' ;
    rdfs:comment 'Numeric level within the GL account hierarchy structure (e.g., 1=top-level group, 5=detail posting account). Supports financial statement rollup, management reporting hierarchies, and drill-down analytics in EBITDA and comp sales dashboards.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name for the GL account providing additional context beyond the short name. Used in detailed financial disclosures, SOX audit documentation, and ERP configuration reports.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The human-readable short description or title of the GL account as maintained in SAP FI (SKAT table). Used in financial reports, trial balances, and audit documentation. Example: \'Cost of Goods Sold – Grocery\', \'Accounts Payable – Trade\'.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountCode rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Code' ;
    rdfs:comment 'Country-specific or group-level alternative account number used for statutory reporting or financial consolidation mapping. Corresponds to SAP FI ALTKT field. Used when Grocery must report under multiple chart of accounts structures (e.g., local GAAP vs. group GAAP).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account Indicator' ;
    rdfs:comment 'Indicates whether this is a balance sheet account (True) or a profit and loss (P&L) income statement account (False). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Corresponds to SAP FI XBILK field in SKA1.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'The SAP chart of accounts key (e.g., \'GROC\') that this GL account belongs to. Grocery may maintain multiple charts of accounts for different legal entities or country-specific GAAP requirements. Corresponds to the KTOPL field in SAP FI SKA1.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cogs Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is classified as a Cost of Goods Sold (COGS) account. COGS accounts are used in gross margin and GMROI calculations, merchandise planning analysis, and EBITDA reporting. Supports Oracle Retail Merchandising System and SAP FI/CO integration for cost flow tracking.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Commitment Management Indicator' ;
    rdfs:comment 'Indicates whether this GL account participates in SAP CO commitment management, tracking purchase order commitments and budget reservations before actual expenditure. Relevant for capital expenditure accounts, store renovation budgets, and DC equipment procurement.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'SAP Controlling (CO) cost element category indicating whether this GL account is a primary cost element (direct costs posted from FI, e.g., COGS, labor), a secondary cost element (internal allocations, overhead), or not applicable (balance sheet accounts). Drives cost center accounting, EBITDA reporting, and shrink financial impact analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementType rdf:type rdf:Property ;
    rdfs:label 'Cost Element Type' ;
    rdfs:comment 'Granular classification of the cost element within SAP CO, such as \'material costs\', \'personnel costs\', \'depreciation\', \'overhead allocation\', \'revenue\'. Supports detailed cost center reporting and profitability analysis (CO-PA) across store banners. [ENUM-REF-CANDIDATE: material_costs|personnel_costs|depreciation|overhead_allocation|revenue|settlement|assessment|distribution — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which this GL account is maintained (e.g., \'USD\'). Grocery operates primarily in USD but may maintain foreign currency accounts for international vendor transactions or cross-border operations. Corresponds to SAP FI WAERS field.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date after which this GL account is no longer valid for new financial postings. Null indicates the account has no defined end date and remains open-ended. Supports account lifecycle management and year-end close procedures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP FI field status group (FSTAG) assigned to this GL account, controlling which fields are required, optional, or suppressed during document entry. Ensures data completeness for cost center, profit center, and business area assignments on postings. Critical for CO integration and reporting accuracy.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementSection rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Section' ;
    rdfs:comment 'The primary financial statement section where this GL account is reported. Drives financial consolidation mapping and GAAP-compliant disclosure preparation. Used in EBITDA reporting, comp sales analysis, and SOX financial reporting controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP FI/CO functional area classification used for cost-of-sales accounting and segment reporting. Segments expenses by business function such as \'manufacturing\', \'sales\', \'administration\', \'research_development\'. Supports GAAP income statement by function presentation and SEC segment disclosures. [ENUM-REF-CANDIDATE: store_operations|supply_chain|merchandising|pharmacy|administration|marketing|finance|it|fuel_operations — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'Detailed GAAP line-item classification for the account, such as \'Current Assets\', \'Long-Term Liabilities\', \'Cost of Goods Sold (COGS)\', \'Selling General and Administrative (SG&A)\', \'Depreciation and Amortization\'. Supports EBITDA calculation, COGS tracking, and SEC financial disclosure. [ENUM-REF-CANDIDATE: current_assets|non_current_assets|current_liabilities|non_current_liabilities|equity|net_revenue|cogs|gross_profit|sga|depreciation_amortization|interest_expense|income_tax|other_income_expense — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'House Bank Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is a bank account (house bank) used for cash management and treasury operations. Bank accounts require special reconciliation procedures and are subject to PCI DSS controls for payment processing. Supports daily cash position reporting and bank reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsMappingCode rdf:type rdf:Property ;
    rdfs:label 'Ifrs Mapping Code' ;
    rdfs:comment 'IFRS account mapping code for international financial reporting or cross-border consolidation purposes. Used when Grocery operates entities in jurisdictions requiring IFRS reporting alongside US GAAP. Supports dual-ledger accounting in SAP FI parallel ledger configuration.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used for intercompany transactions between Grocery\'s legal entities (e.g., store banners, distribution centers, pharmacy subsidiaries). Intercompany accounts require elimination during financial consolidation. Supports SOX-compliant consolidation and GAAP ASC 810 requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Posting Allowed' ;
    rdfs:comment 'Indicates whether direct financial postings are permitted to this GL account. False for summary/header accounts that only aggregate child accounts, or for accounts blocked for posting. Corresponds to SAP FI XLOEV (account blocked for posting) flag.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account for a subledger (Accounts Payable, Accounts Receivable, or Asset Accounting). Reconciliation accounts cannot receive direct manual postings; they are updated automatically from subledger transactions. Critical for AP/AR balance integrity and SOX controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Tax Relevant' ;
    rdfs:comment 'Indicates whether this GL account is subject to tax reporting obligations. True for accounts involving taxable sales, purchases, or excise duties (e.g., fuel center, alcohol, tobacco). Supports tax compliance reporting and FTC regulatory filings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this GL account in SAP FI. When True, auditors and finance analysts can drill down to individual posting details. Required for SOX audit trails and GAAP disclosure support. Corresponds to SAP FI XKRES field.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account. When True, individual line items remain open until cleared by a matching offsetting entry (e.g., GR/IR clearing accounts, bank clearing accounts). Essential for AP/AR reconciliation and month-end close processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the parent/summary account in the GL hierarchy. Enables hierarchical rollup of financial balances for management reporting, financial consolidation, and EBITDA calculation. Null for top-level accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Planning Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is used in SAP CO budgeting and planning processes. Planning accounts are included in annual budget cycles, labor budget planning (Kronos integration), and Blue Yonder demand planning financial inputs. Supports comp sales and same-store sales budget vs. actual analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossStatementAccountType rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Statement Account Type' ;
    rdfs:comment 'Classifies P&L accounts into their income statement reporting category for EBITDA calculation, comp sales analysis, and same-store sales reporting. \'cogs\' accounts feed COGS tracking; \'ebitda_component\' accounts are used in EBITDA reporting. Not applicable for balance sheet accounts. [ENUM-REF-CANDIDATE: net_revenue|cogs|gross_profit|operating_expense|ebitda_component|interest|tax|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Specifies the subledger type this reconciliation account is linked to. Applicable only when is_reconciliation_account is True. Drives AP/AR aging reports, vendor payment reconciliation, and fixed asset depreciation schedules.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Shrink Account Indicator' ;
    rdfs:comment 'Indicates whether this GL account is designated for recording shrink (inventory loss from theft, spoilage, or damage). Shrink accounts are critical for fresh produce and perishable inventory financial impact tracking, GMROI analysis, and loss prevention reporting across store banners.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP FI sort key (ZUAWA) that determines the assignment field populated in line items posted to this account. Controls how line items are sorted and displayed in account statements. Common values: \'001\' (posting date), \'003\' (document number), \'031\' (vendor invoice number). Supports efficient account reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevantIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Indicator' ;
    rdfs:comment 'Indicates whether this GL account is in scope for SOX Section 302/404 internal controls testing and audit. SOX-relevant accounts require documented controls, segregation of duties, and periodic reconciliation sign-off. Critical for Grocery\'s external audit and SEC financial reporting compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'SAP FI tax category assigned to the GL account, controlling whether tax codes are required, optional, or not allowed during posting. Relevant for sales tax on grocery transactions, fuel excise tax, and pharmacy prescription tax exemptions. Corresponds to SAP FI MWSKZ field. [ENUM-REF-CANDIDATE: input_tax_required|output_tax_required|tax_optional|no_tax|exempt — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Primary key for cost_center' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code associated with this cost center, representing the primary type of work or service output produced (e.g., \'LABOR_HRS\', \'MACHINE_HRS\', \'DELIVERY_UNITS\'). Used for activity-based costing, internal order settlements, and COGS allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center for the current budget period, expressed in the cost center\'s operating currency. Used for budget vs. actual variance analysis, EBITDA reporting, and financial planning. Sourced from SAP CO cost center planning (KP06).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The fiscal year for which the current budget plan is active for this cost center (e.g., \'2025\'). Used to scope budget vs. actual variance analysis, EBITDA reporting, and departmental P&L reviews.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area assigned to this cost center, representing a distinct area of operations for internal balance sheet and P&L reporting (e.g., Grocery Retail, Pharmacy, Fuel). Supports segment-level financial disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same chart of accounts and fiscal year variant.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP CO cost center category code (single or two-character) that controls which activity types and statistical key figures can be posted to this cost center. Common values include \'A\' (General), \'B\' (Administration), \'F\' (Production), \'H\' (Auxiliary). Governs posting rules and planning behavior in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code assigned to the cost center in SAP CO, used across financial reporting, budgeting, and interoperability with ERP systems. Serves as the business-facing identifier (e.g., \'CC-STORE-0042\', \'CC-DC-WEST-01\').' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable descriptive name of the cost center as maintained in SAP CO (e.g., \'Store 042 - Produce Department\', \'Distribution Center West - Receiving\', \'Pharmacy - Store 101\'). Used in financial reports, P&L statements, and budget dashboards.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' — open for cost postings and budget planning; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings (SAP CO lock indicator); \'pending_activation\' — created but not yet effective; \'closed\' — permanently decommissioned after validity end date.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Categorical classification of the cost center indicating the type of organizational unit it represents within Grocery\'s operations. Drives departmental P&L segmentation, shrink financial impact allocation, and labor cost attribution. [ENUM-REF-CANDIDATE: store|distribution_center|pharmacy|fuel_center|corporate|administrative|manufacturing|logistics — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Internal department code associated with this cost center, used for departmental P&L reporting and labor cost attribution. Aligns with Grocery\'s organizational structure (e.g., Produce, Bakery, Deli, Pharmacy, Fuel, Receiving, Corporate Finance).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Organizational division code to which this cost center belongs (e.g., \'GROCERY_RETAIL\', \'PHARMACY\', \'FUEL_OPERATIONS\', \'ECOMMERCE\'). Supports divisional P&L reporting, EBITDA segmentation, and same-store sales analysis by business division.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP FI fiscal year variant code that defines the fiscal year structure (number of periods, start/end months) applicable to this cost center. Grocery typically uses a 52/53-week fiscal year. Drives period-based budget and actual cost comparisons.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP CO functional area classification used to differentiate cost by business function (e.g., Cost of Goods Sold, Selling, General & Administrative, Research & Development). Enables COGS vs. SG&A split in income statement reporting per GAAP.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'The node within the SAP CO standard cost center hierarchy to which this cost center is assigned. Enables roll-up reporting across organizational levels (e.g., region, division, banner). Used for enterprise-wide P&L consolidation, EBITDA reporting, and comp sales analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLockedForActual rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Actual' ;
    rdfs:comment 'Indicates whether this cost center is locked for actual cost postings (True). When locked, no actual costs can be posted to this cost center in SAP CO. Used during period-end close, audit periods, or when a cost center is being decommissioned.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLockedForPlan rdf:type rdf:Property ;
    rdfs:label 'Is Locked For Plan' ;
    rdfs:comment 'Indicates whether this cost center is locked for plan (budget) postings (True). When locked, no budget updates can be made to this cost center in SAP CO. Used to freeze budgets after approval for SOX compliance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this cost center is a statistical cost center (True) used only for informational/reporting purposes without actual cost postings, or a real cost center (False) that accumulates actual costs. Statistical cost centers are used in SAP CO for parallel reporting structures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Amount' ;
    rdfs:comment 'Portion of the annual budget specifically allocated to labor costs (wages, salaries, benefits) for this cost center. Enables labor cost attribution analysis, workforce planning integration with Kronos/Workday HCM, and COGS labor component reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center master record. Required for SOX compliance audit trails to establish accountability for master data changes. Corresponds to SAP CO change document user field.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cost center master record in SAP CO. Used for change tracking, SOX audit trails, and incremental data load processing in the Databricks Silver Layer.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Physical location type associated with this cost center. Distinguishes between store-level, DC (Distribution Center), MFC (Micro-Fulfillment Center), corporate office, fuel center, and pharmacy cost centers for geographic and operational segmentation in financial reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadRate rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate' ;
    rdfs:comment 'The overhead allocation rate applied to this cost center, expressed as a decimal percentage (e.g., 0.1250 = 12.50%). Used in SAP CO overhead costing sheets to allocate indirect costs (e.g., corporate overhead, DC overhead) to store or department cost centers for full-absorption costing and COGS calculation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code to which this cost center belongs (e.g., \'NORTHEAST\', \'SOUTHEAST\', \'WEST\'). Used for regional P&L roll-up, comp sales analysis by region, and regional budget variance reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Code' ;
    rdfs:comment 'SAP CO settlement rule code that defines how costs accumulated on this cost center are settled (allocated) to other cost objects (e.g., other cost centers, internal orders, profitability segments). Drives period-end cost allocation and COGS calculation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name of the cost center used in condensed financial reports, POS system displays, and space-constrained UI contexts. Corresponds to the SAP CO short text field (up to 20 characters).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Shrink Allocation Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in shrink (inventory loss from theft, spoilage, or damage) financial impact allocation (True). When enabled, shrink costs calculated from inventory management systems are allocated to this cost center for departmental P&L and COGS reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'The date through which this cost center is active and valid for cost postings. Corresponds to the SAP CO validity period end date. A value of 9999-12-31 indicates an open-ended (indefinite) validity. Cost postings after this date are blocked.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'The date from which this cost center is active and valid for cost postings and budget planning. Corresponds to the SAP CO validity period start date. Cost postings before this date are not permitted.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bannerCode rdf:type rdf:Property ;
    rdfs:label 'Banner Code' ;
    rdfs:comment 'The retail banner or brand under which this profit center operates (e.g., \'KROGER\', \'RALPHS\', \'FREDS\', \'HARRIS\'). Used for banner-level comp sales and same-store sales reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date this profit center was permanently closed. Null for active profit centers. Used for historical analysis and asset impairment calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compSalesEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is eligible for comp sales (comparable store sales) reporting. True if the location has been open for at least 12 months and meets comp sales criteria.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCount rdf:type rdf:Property ;
    rdfs:label 'Department Count' ;
    rdfs:comment 'The number of distinct departments or categories within this profit center (e.g., produce, meat, dairy, bakery, pharmacy, fuel). Used for assortment complexity analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'The district code within a region, representing a cluster of stores managed by a district manager. Used for district-level P&L roll-up.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The current number of full-time equivalent (FTE) employees assigned to this profit center. Used for labor productivity and EBITDA per employee calculations.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The hierarchical level of this profit center in the organizational structure (1=top-level, 2=division, 3=region, 4=store, etc.). Used for roll-up reporting and consolidation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The SAP user ID of the person who last modified this profit center master record. Required for SOX audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this profit center is locked for new postings. True when locked (no new transactions allowed), False when open for posting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'The market or metropolitan area code (e.g., \'NYC\', \'LAX\', \'CHI\'). Used for market-level competitive analysis and same-store sales comparisons.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date this profit center (store, pharmacy, fuel center) first opened for business. Used to calculate comp sales eligibility and age-based performance metrics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'The code of the parent profit center in the hierarchy. Null for top-level profit centers. Enables roll-up of comp sales, same-store sales, and EBITDA by region or division.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'The externally-known alphanumeric code identifying the profit center in SAP CO. Used in financial reports, general ledger postings, and management accounting documents.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Extended text description providing additional context about the profit center\'s purpose, scope, and business model (e.g., \'High-volume urban supermarket with full-service pharmacy and fuel center\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'The full business name of the profit center (e.g., \'Store 1234 - Downtown Seattle\', \'Pharmacy Division - West Region\', \'Private Label Bakery\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center: active (operational and posting transactions), inactive (temporarily suspended), planned (future opening), closed (permanently shut down).' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterType rdf:type rdf:Property ;
    rdfs:label 'Profit Center Type' ;
    rdfs:comment 'Classification of the profit center by business function: store-level P&L, banner-level aggregation, pharmacy operations, fuel center operations, distribution center, private-label brand division, or corporate overhead. [ENUM-REF-CANDIDATE: store|banner|pharmacy|fuel_center|distribution_center|private_label|corporate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remodelDate rdf:type rdf:Property ;
    rdfs:label 'Remodel Date' ;
    rdfs:comment 'The date of the most recent major remodel or renovation. Significant remodels may reset comp sales eligibility timers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sameStoreSalesEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Same Store Sales Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this profit center qualifies for same-store sales reporting (revenue comparison for existing locations year-over-year). Typically requires 13+ months of operation without major remodels.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'The total retail square footage of the store or facility. Used to calculate sales per square foot and GMROI (Gross Margin Return on Investment) metrics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this profit center is valid and can accept financial postings. Used for time-dependent master data and historical reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this profit center is valid. Null for open-ended validity. Used to track store closures, division consolidations, and organizational changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Reference to the parent legal entity in the corporate hierarchy. Null for the ultimate parent holding company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate structure. Used for ultimate consolidation and group-level reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:auditFirmName rdf:type rdf:Property ;
    rdfs:label 'Audit Firm Name' ;
    rdfs:comment 'Name of the external audit firm responsible for auditing this legal entity\'s financial statements. Required for SOX-scoped and public entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group or reporting unit to which this legal entity belongs. Used for financial consolidation and intercompany elimination.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the legal entity was officially dissolved or ceased operations. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or DBA name under which the legal entity operates. May differ from the legal name for customer-facing operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational status of the legal entity. Active entities are operational and filing; inactive or dissolved entities are no longer conducting business.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'The month (1-12) in which the legal entity\'s fiscal year ends. Used for annual financial statement preparation and tax filing deadlines.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which the legal entity conducts business and maintains its books.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Standard' ;
    rdfs:comment 'The accounting standard framework used by this legal entity for financial reporting (US GAAP, IFRS, or local GAAP).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was officially incorporated or registered with the state. Used to calculate entity age and anniversary dates.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date on which the most recent external financial audit was completed for this legal entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the legal entity in financial systems and reporting. Typically used in SAP FI company code configuration.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the entity as registered with the state or jurisdiction of incorporation. Used for all legal documents, contracts, and regulatory filings.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit code classifying the primary business activity of the legal entity. Used for industry benchmarking and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Public Company Flag' ;
    rdfs:comment 'Indicates whether this legal entity is publicly traded on a stock exchange. Determines SEC reporting requirements and audit obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal entity\'s registered address on file with the state. Used for official correspondence and legal service of process.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the registered address (suite, floor, building). Optional field for additional address details.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City of the legal entity\'s registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'ZIP code of the registered address. Supports 5-digit or 9-digit ZIP+4 format.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredState rdf:type rdf:Property ;
    rdfs:label 'Registered State' ;
    rdfs:comment 'Two-letter US state code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for consolidated financial reporting. May differ from functional currency for foreign subsidiaries.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit code classifying the primary business activity. Legacy classification system still used by SEC and some regulatory bodies.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Flag' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of SOX compliance and internal control testing. True for publicly traded entities and material subsidiaries.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'State Of Incorporation' ;
    rdfs:comment 'Two-letter US state code where the legal entity is incorporated or registered. Determines governing law and annual filing requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchangeCode rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange Code' ;
    rdfs:comment 'Code identifying the primary stock exchange where the entity\'s shares are traded (e.g., NYSE, NASDAQ). Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTickerSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker Symbol' ;
    rdfs:comment 'The ticker symbol under which the entity\'s shares are traded. Null for private entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary tax jurisdiction for the legal entity. Determines applicable tax rates and filing requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or sales tax registration number for entities operating in jurisdictions requiring VAT registration. Null for US-only entities without VAT obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Unique identifier for the fiscal period. Primary key.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:priorYearPeriodFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Fiscal Period Id' ;
    rdfs:comment 'Reference to the corresponding fiscal period in the prior fiscal year. Enables year-over-year comp sales and same-store sales calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Identifier for the budget version applicable to this fiscal period (e.g., \'Original\', \'Revised_Q2\', \'Forecast\'). Supports budget vs actual variance analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDayCount rdf:type rdf:Property ;
    rdfs:label 'Business Day Count' ;
    rdfs:comment 'Number of business operating days (excluding weekends and holidays) in this fiscal period. Used for labor budgeting and productivity metrics.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month number (1-12) in which the fiscal period primarily falls. Supports calendar-based reporting and seasonality analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year (Gregorian) in which the majority of this fiscal period falls. Used for calendar-year reporting and external benchmarking.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'The actual calendar date when the fiscal period was closed and locked for posting. Null if period is still open. Critical for SOX compliance and audit trail.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Precise timestamp when the fiscal period close process was completed. Used for audit trail and SOX compliance documentation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayCount rdf:type rdf:Property ;
    rdfs:label 'Day Count' ;
    rdfs:comment 'Total number of calendar days in this fiscal period. Used for daily rate calculations and pro-rata adjustments.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date used for currency exchange rate determination for this fiscal period. Typically period-end date or average rate date for multi-currency consolidation.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditRequired rdf:type rdf:Property ;
    rdfs:label 'External Audit Required' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal period is subject to external audit review. Typically true for year-end and quarterly periods for publicly traded companies.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year (1-13 for 13-period retail calendar or 1-12 for standard calendar). Used for period-over-period comparisons and comp sales calculations.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter number (1-4) to which this period belongs. Supports quarterly financial reporting and EBITDA analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this period belongs (e.g., 2024, 2025). Aligns with Grocery\'s fiscal calendar and SAP FI fiscal year variant.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gaapCompliant rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliant' ;
    rdfs:comment 'Boolean flag indicating whether financial reporting for this period follows GAAP standards. True for US-based public company reporting.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active fiscal period for transaction posting. True if current, false otherwise.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Boolean flag indicating whether the fiscal year containing this period is a leap year. Affects day count calculations and year-over-year comparisons.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last calendar date of the fiscal period. Defines the end of the posting date range for transactions and triggers period-end close processes.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the fiscal period (e.g., \'FY2024-P01\', \'January 2024\', \'Q1-2024\'). Used in financial reports and dashboards.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first calendar date of the fiscal period. Defines the beginning of the posting date range for transactions.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the fiscal period. Controls whether transactions can be posted. Open allows posting, closed prevents new postings, locked is permanently closed, pending_close indicates close process is underway.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the fiscal period. Regular periods are standard operating periods, adjustment periods are for accruals and corrections, special periods are for extraordinary events, year_end is the final closing period.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Date' ;
    rdfs:comment 'Date when SOX certification and management attestation were completed for this fiscal period. Required for publicly traded companies.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Certification Required' ;
    rdfs:comment 'Boolean flag indicating whether this fiscal period requires SOX certification and management attestation. True for publicly traded company reporting periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekCount rdf:type rdf:Property ;
    rdfs:label 'Week Count' ;
    rdfs:comment 'Number of weeks in this fiscal period. Typically 4 or 5 weeks for 4-4-5 retail calendar. Critical for normalizing comp sales and same-store sales metrics.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry document. Primary key for the journal entry product.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ap_invoice. Business justification: AP invoices in SAP FI generate accounting documents (journal entries) upon posting. Adding ap_invoice_id to journal_entry establishes the source document reference from the GL posting back to the orig' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: AR invoices in SAP FI generate accounting documents (journal entries) upon billing. Adding ar_invoice_id to journal_entry establishes the source document reference from the GL posting back to the orig' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Foreign key linking to finance.payment_run. Business justification: Payment runs in SAP FI generate journal entries (clearing postings). Adding payment_run_id to journal_entry establishes the source document linkage from the accounting document back to the payment run' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:settlementBatchId rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Id' ;
    rdfs:comment 'Foreign key linking to payment.settlement_batch. Business justification: Daily cash close journal entries: grocery finance posts a journal entry per settlement batch for daily cash clearing. This link provides the audit trail from GL posting back to the originating settlem' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementBatch .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: Cash receipt journal entries: grocery finance posts journal entries directly for cash receipts from POS transactions. This link enables cash receipt reconciliation, audit trail from GL entry back to o' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was approved for posting. Null if not yet approved or approval not required. Used for approval workflow tracking and SOX compliance monitoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date used for payment term calculation in accounts payable processing. Typically the invoice date or goods receipt date. Used for payment due date calculation and cash flow forecasting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'The batch input session name if this journal entry was created via batch processing. Null for online entries. Used for batch processing tracking and error resolution.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this journal entry was cleared or settled. Null if not yet cleared. Used for aging analysis and cash flow forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number of the clearing entry that settled this journal entry. Null if not yet cleared. Used for accounts payable/receivable reconciliation and open item management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date printed on the source document (invoice date, receipt date, contract date). May differ from posting date due to processing delays. Used for aging analysis and vendor/customer reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned by the financial system (SAP FI document number). This is the business identifier used in audit trails and financial reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the journal entry document type. SA=General Ledger Document, KR=Vendor Invoice, DR=Customer Invoice, AB=Accounting Document, KG=Vendor Credit Memo, DZ=Payment Document. Determines posting rules and account determination logic.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The date when the journal entry was first created or entered into the system by the user. Audit trail timestamp for SOX compliance and internal control monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate used to convert transaction currency amounts to local currency amounts. Null if transaction currency equals local currency. Used for foreign exchange gain/loss calculation and multi-currency consolidation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form text description at the document header level providing context or explanation for the journal entry. Used for audit trail documentation and user communication.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry represents an intercompany transaction between two company codes within the Grocery enterprise. True if intercompany, False otherwise. Used for intercompany reconciliation and elimination entries in consolidated financial statements.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'The ledger or ledger group to which this journal entry is posted. 0L=Leading Ledger (GAAP), 2L=IFRS Ledger, 9Z=Management Reporting Ledger. Supports parallel accounting for multiple accounting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'The local (company code) currency in which amounts are also stored for statutory reporting. Three-letter ISO 4217 currency code. Typically USD for US-based grocery operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was last modified. Null if never modified after creation. Audit trail timestamp for SOX compliance and change tracking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parkingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Parking Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was parked. Null if entry was never parked. Used for workflow tracking and aging analysis of parked documents.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating a payment block preventing automatic payment processing. Null if no block exists. Used for payment exception management and vendor dispute resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'Code indicating the payment method for this journal entry. C=Check, T=Wire Transfer, W=ACH, Z=Other. Used for payment processing and cash management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The payment terms code defining the due date calculation and discount terms for this journal entry. Used for accounts payable aging, cash flow forecasting, and early payment discount analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was posted to the general ledger. Null if entry is parked but not yet posted. Used for posting workflow tracking and audit trail analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry is posted to the general ledger. This is the principal business event date that determines which fiscal period the transaction affects. Used for period-end close, trial balance, and financial statement generation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the journal entry. Posted=finalized and affecting GL balances, Parked=saved but not yet posted, Cleared=settled against another document, Reversed=negated by reversal entry, Cancelled=voided before posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (vendor invoice number, customer order number, check number, wire transfer reference). Used for reconciliation and audit trail linkage to source documents.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a prior entry. True if this document reverses another document, False otherwise. Used for accrual reversal processing and error correction tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversal. 01=Accrual Reversal, 02=Error Correction, 03=Period-End Adjustment, 04=Reclassification, 05=Duplicate Entry, 06=Other. Used for internal control monitoring and audit trail analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Null if this is not a reversal entry. Used to maintain audit trail linkage between original and reversing entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date used for tax reporting purposes. May differ from posting date due to tax jurisdiction rules. Used for sales tax remittance reporting, fuel excise tax reporting, and pharmacy dispensing tax compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'The company code of the intercompany trading partner if this is an intercompany transaction. Null for non-intercompany entries. Used for intercompany reconciliation and automated elimination entry generation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Identifier of the company bank account from which payment was disbursed. Supports multi-bank operations and cash management reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.carrier. Business justification: Freight invoices from carriers are a major AP category in retail-grocery. Direct carrier_id on ap_invoice enables carrier spend analysis, contract compliance auditing, and freight accrual reporting wi' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:costPriceId rdf:type rdf:Property ;
    rdfs:label 'Cost Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.cost_price. Business justification: AP invoice-to-cost-price matching is a critical retail-grocery process: invoiced supplier cost is validated against the agreed cost price record for cost variance analysis, deal compliance, and allowa' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostPrice .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the warehouse or store goods receipt document used in three-way match. Confirms physical receipt of merchandise or materials before invoice approval.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:newItemIntroId rdf:type rdf:Property ;
    rdfs:label 'New Item Intro Id' ;
    rdfs:comment 'Foreign key linking to assortment.new_item_intro. Business justification: Slotting fees for new item introductions are invoiced by suppliers and processed as AP invoices. Grocery retailers must match slotting fee AP invoices to specific new item intro records for vendor dea' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NewItemIntro .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order for three-way match validation (PO, goods receipt, invoice). Null for non-PO invoices such as utility bills, rent, or service agreements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.shipment. Business justification: Freight Invoice Reconciliation: AP Invoice for carrier freight must reference the Shipment it settles, enabling the Freight Cost Reconciliation report.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Identifier of the vendor or supplier who issued this invoice. Links to the vendor master record for merchandise suppliers, DSD (Direct Store Delivery) vendors, service providers, and operational expense vendors.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date the invoice was approved for payment. Used to measure approval cycle time and identify bottlenecks in the AP workflow.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current state of the invoice in the approval workflow. Tracks manager or finance approval for invoices requiring authorization before payment, supporting SOX internal control requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedAmount rdf:type rdf:Property ;
    rdfs:label 'Cleared Amount' ;
    rdfs:comment 'The actual amount paid to the vendor after applying any last-minute adjustments, discounts taken, or partial payments. May differ from net_amount if early payment discount was exercised.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The discount amount available if payment is made within the early payment discount period (e.g., 2% if paid within 10 days). Supports cash flow optimization and vendor relationship management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'The actual early payment discount amount deducted at payment time. Tracks discount capture performance and vendor payment optimization.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor per the agreed payment terms. Calculated from invoice date plus payment term days (e.g., Net 30, Net 60).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:edi810Reference rdf:type rdf:Property ;
    rdfs:label 'Edi 810 Reference' ;
    rdfs:comment 'Reference number for the EDI 810 electronic invoice transaction received from the vendor. Supports automated invoice processing and vendor integration via EDI (Electronic Data Interchange).' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, including merchandise cost, freight, slotting fees, or service charges. Represents the vendor\'s billed amount before tax.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. Used to calculate payment due dates based on payment terms and to determine early payment discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The external invoice number assigned by the vendor. This is the business identifier printed on the vendor\'s invoice document and referenced in payment correspondence.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current state of the invoice in the accounts payable workflow. Tracks progression from receipt through three-way match, approval, payment scheduling, disbursement, and clearing in the GR/IR (Goods Receipt/Invoice Receipt) account. [ENUM-REF-CANDIDATE: received|pending_match|matched|approved|payment_blocked|scheduled|paid|cleared|cancelled|disputed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document. Standard invoices are typical vendor bills; credit memos reduce liability; debit memos increase liability; prepayments cover advance payments; recurring invoices are for subscription services.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is1099Reportable rdf:type rdf:Property ;
    rdfs:label 'Is 1099 Reportable' ;
    rdfs:comment 'Indicates whether this invoice payment must be reported to the IRS on Form 1099-MISC or 1099-NEC for vendor tax reporting. True for payments to non-corporate vendors exceeding the annual threshold.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Indicates whether the invoice has been successfully matched against the purchase order and goods receipt. Three-way match validates quantity, price, and terms alignment before payment approval.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The final payable amount after applying discounts and adding taxes. This is the amount that will be disbursed to the vendor (gross + tax - discount).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Detailed explanation of why the invoice payment is blocked. Provides context for AP analysts and vendor inquiry resolution.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date the payment was executed and funds were disbursed to the vendor. Null for unpaid invoices. Used for cash flow reporting and vendor payment tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The disbursement method used or planned for vendor payment. ACH (Automated Clearing House) and EFT (Electronic Funds Transfer) are preferred for cost efficiency and speed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number for the payment transaction (check number, ACH trace number, wire confirmation). Used for bank reconciliation and vendor inquiry resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax charged on the invoice, including sales tax, use tax, VAT, or GST depending on jurisdiction. Used for tax reporting and reconciliation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderId rdf:type rdf:Property ;
    rdfs:label 'Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Order-to-Invoice Matching: AR Invoice is generated from a Fulfillment Order; linking them supports the Customer Billing & Revenue Recognition process.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Order .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of invoice age based on days past due date. Used for Days Sales Outstanding (DSO) analysis and bad debt provisioning. Current = not yet due; other buckets represent days overdue.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankDepositReference rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Reference' ;
    rdfs:comment 'Bank deposit batch or transaction reference number linking the payment to the bank statement. Used for bank reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the invoice is denominated (e.g., USD, CAD, MXN).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this invoice. Used for revenue recognition period matching and accrual accounting.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this invoice. Relevant for subscription-based or periodic billing (e.g., fuel fleet monthly billing, pharmacy monthly claims).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'Number of days since the invoice date. Used to calculate Days Sales Outstanding (DSO) metrics and identify slow-paying accounts.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the invoice is overdue beyond the payment due date. Null or zero if invoice is not yet due. Used for dunning level determination.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the customer formally disputed the invoice. Used to track dispute resolution cycle time.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the customer has disputed this invoice. True if customer has raised a billing dispute, pricing disagreement, or quality claim that blocks payment.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the customer dispute reason (e.g., pricing error, quantity discrepancy, damaged goods, service issue). Populated when dispute_flag is true.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current escalation level in the collections dunning process (0=no dunning, 1=first reminder, 2=second reminder, 3=final notice, 4=legal action). Increments based on days past due and payment history.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Shipping and freight charges included in the invoice for delivery of goods to the customer location.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date the invoice was posted to the general ledger for financial reporting. May differ from invoice date due to period-end cutoffs or batch processing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice or collection reminder was sent to the customer for this invoice.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Number' ;
    rdfs:comment 'Identifier of the bank lockbox service used for automated payment processing. Relevant for high-volume check and remittance processing.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on the invoice after applying all cash receipts, credit memos, and adjustments. Zero when invoice is fully paid.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount received and applied against this invoice across all payment transactions. Sum of all cash receipts allocated to this invoice.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer purchase order number provided for this invoice. Used for customer reconciliation and three-way matching in customer accounts payable systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating sales order or delivery document that generated this invoice. Links AR invoice back to the order fulfillment transaction.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount of the invoice written off as uncollectible bad debt. Recorded when collection efforts are exhausted and the receivable is deemed unrecoverable.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'Date the invoice (or portion thereof) was written off as bad debt. Triggers bad debt expense recognition in the general ledger.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReasonCode rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason Code' ;
    rdfs:comment 'Reason code for the write-off: customer bankruptcy, deemed uncollectible after collection efforts, small balance not worth pursuing, dispute settlement, goodwill adjustment, or other.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Primary key for budget' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:fulfillmentNodeId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Node Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.node. Business justification: Fulfillment nodes have dedicated operational budgets (labor, supplies, utilities, equipment). Direct node-level budget tracking enables budget vs. actual variance reporting for DC and MFC operations —' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Node .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual amount spent or incurred to date for this budget line, as recorded in the general ledger. Used for variance analysis (actual vs plan).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this budget record to the audit trail or change log for compliance and SOX reporting. Tracks all modifications to budget amounts and approvals.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableBalance rdf:type rdf:Property ;
    rdfs:label 'Available Balance' ;
    rdfs:comment 'The remaining budget balance available for spending, calculated as revised_amount minus (committed_amount plus actual_amount). Used for budget consumption monitoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'Hierarchical category or grouping for the budget line (e.g., Store Operations, Supply Chain, Marketing, IT Infrastructure). Used for rollup reporting and variance analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known unique business identifier for the budget, typically formatted as BUD-YYYYNNNN where YYYY is fiscal year and NNNN is sequence number.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget: draft (in preparation), submitted (awaiting approval), approved (authorized), active (in use), frozen (locked for changes), closed (period ended), or rejected (not approved). [ENUM-REF-CANDIDATE: draft|submitted|approved|active|frozen|closed|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by functional category: operating expenses, capital expenditures (CapEx), labor costs, marketing spend, administrative overhead, or Cost of Goods Sold (COGS).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'The amount of budget that has been committed through purchase orders, contracts, or other obligations but not yet expensed. Used for encumbrance accounting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the individual or role responsible for managing and monitoring this budget (e.g., Store Manager, Regional VP, CFO).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The original planned budget amount for the fiscal period, as approved during the annual budgeting process. Represents the baseline target.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The revised budget amount after adjustments, reforecasts, or supplemental allocations. Reflects the current authorized budget target.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is subject to SOX internal control requirements and audit trails (True = SOX-controlled, False = not SOX-controlled).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdCriticalPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Critical Percentage' ;
    rdfs:comment 'The percentage of budget consumption at which a critical alert is triggered and spending may be blocked (e.g., 95.00 means critical alert when 95% of budget is consumed).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdWarningPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Warning Percentage' ;
    rdfs:comment 'The percentage of budget consumption at which a warning alert is triggered (e.g., 80.00 means alert when 80% of budget is consumed). Used for proactive budget monitoring.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The variance between planned and actual amounts (actual_amount minus planned_amount). Positive values indicate overspend; negative values indicate underspend.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance expressed as a percentage of the planned amount ((actual_amount - planned_amount) / planned_amount * 100). Used for threshold alerts and performance scorecards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version type of the budget indicating whether it is the original plan, a revised plan, a forecast, reforecast, supplemental allocation, or final approved version.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Unique identifier for the SAP CO internal order. Primary key for the internal order master data.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs posted to this internal order to date, in the company code currency. Includes direct costs, allocations, and internal activity charges. Updated in real-time as costs are posted.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the project or activity was completed and the order was set to technically complete status. Triggers settlement eligibility.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when work began on this internal order, typically when the first cost was posted or the order status changed to released.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the individual who approved the internal order budget. Required for SOX compliance and audit trail documentation.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'SAP FI asset class code if this internal order will be settled to a fixed asset. Determines depreciation rules, useful life, and GL account assignments for the resulting asset.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'SAP FI fixed asset master number to which this internal order will be settled upon completion. Populated for CAPEX orders that create or enhance fixed assets.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget for this internal order in the company code currency. Used for budget control and variance reporting. Budget may be original, supplemental, or revised.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amount. Typically matches the company code currency but may differ for multi-currency projects.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Flag' ;
    rdfs:comment 'Boolean indicator whether costs on this internal order are capitalized (True) or expensed (False). True for capital investments that will be settled to fixed assets; False for operating expenses settled to cost centers or GL accounts.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs (purchase requisitions and purchase orders) against this internal order. Used for funds availability checking and budget consumption reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character SAP FI company code representing the legal entity to which this internal order belongs. Used for financial consolidation and legal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Four-character SAP CO controlling area code. Represents the organizational unit for cost accounting and internal management reporting. Multiple company codes may share a controlling area.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Boolean indicator whether this internal order has been marked for deletion. True indicates the order is logically deleted but retained for audit purposes; False indicates an active or closed order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'SAP user ID of the individual who last modified this internal order master record. Used for change tracking and audit trail.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDescription rdf:type rdf:Property ;
    rdfs:label 'Order Description' ;
    rdfs:comment 'Free-text description of the internal order purpose, scope, and business justification. Provides context for financial analysts and auditors reviewing project costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the internal order, externally visible and used in financial reporting and project tracking. Typically a 10-12 character alphanumeric code assigned by SAP CO.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the internal order. Controls whether costs can be posted, whether the order can be settled, and whether it appears in active project reports. Status progression: created → released → technically_complete → settled → closed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the internal order by business purpose. Determines cost collection rules, settlement targets, and reporting hierarchy. Common types include capital investments, store remodels, marketing campaigns, maintenance projects, and IT initiatives.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned completion date for the project or activity. Used to determine when the order should be technically complete and ready for settlement.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned start date for the project or activity tracked by this internal order. Used for project scheduling and resource planning.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Project Manager Email' ;
    rdfs:comment 'Email address of the project manager for communication and escalation purposes. Used for automated budget alerts and approval workflows.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Full name of the individual responsible for managing this internal order project. Accountable for budget adherence, timeline, and deliverables.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name or code of the business department that requested this internal order. Used for chargeback and accountability reporting.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date when costs accumulated on this internal order were settled to the final receiver cost object. Marks the financial close of the order.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReceiverCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Code' ;
    rdfs:comment 'Identifier of the specific cost object (asset number, cost center code, GL account number) to which costs will be settled. Format varies by receiver type.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReceiverType rdf:type rdf:Property ;
    rdfs:label 'Settlement Receiver Type' ;
    rdfs:comment 'Type of cost object to which this internal order will be settled upon completion. Common receivers include fixed assets (for CAPEX), cost centers (for OPEX), or GL accounts (for period costs).' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Profile' ;
    rdfs:comment 'Configuration key defining how costs accumulated on this internal order are settled to final cost objects (e.g., asset under construction, cost center, GL account). Determines settlement percentage, receiver type, and settlement period rules.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'Identifier of the WBS element if this internal order is part of a larger project structure. Links the order to a project hierarchy for integrated project and cost management.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'SAP user ID of the individual who created this internal order master record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Unique identifier for the fixed asset record. Primary key for the fixed asset entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.vehicle. Business justification: Delivery vehicles are capitalized fixed assets tracked for acquisition cost, depreciation, and disposal. Linking fixed_asset to vehicle enables fleet asset lifecycle management, depreciation schedulin' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since acquisition. This is the cumulative contra-asset amount reducing the net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or capitalized cost of the asset in USD. This is the gross base amount for depreciation calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'The date the asset was acquired or placed in service. This is the principal business event timestamp for the asset lifecycle and determines when depreciation begins.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed textual description of the fixed asset, including make, model, and specific characteristics.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Active assets are in service and depreciating; under construction assets are capitalized but not yet depreciating; retired/disposed assets are no longer in use.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-number for assets that are part of a larger asset group or complex asset. Used when a main asset has multiple components tracked separately for depreciation purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Physical tag or barcode identifier affixed to the asset for inventory tracking and physical verification during SOX audits.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'The date the asset was capitalized in the general ledger. For assets under construction, this may differ from the acquisition date.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPeriodDepreciation rdf:type rdf:Property ;
    rdfs:label 'Current Period Depreciation' ;
    rdfs:comment 'Depreciation expense recognized in the current fiscal period (month or quarter). Used for EBITDA reconciliation and P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'The valuation view for depreciation calculation: book (GAAP financial reporting), tax (IRS tax depreciation), group (consolidated reporting), or IFRS (international standards).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'SAP-specific depreciation key that defines the calculation rules, useful life, and period control for depreciation posting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'The method used to calculate periodic depreciation expense (e.g., straight-line, declining balance). Aligns with GAAP and tax regulations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'The date the asset was retired, sold, or otherwise disposed of, marking the end of its service life.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalGainLoss rdf:type rdf:Property ;
    rdfs:label 'Disposal Gain Loss' ;
    rdfs:comment 'Gain or loss recognized on disposal, calculated as disposal proceeds minus net book value at disposal date. Positive values indicate gain; negative values indicate loss.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Total impairment loss recognized when the asset\'s recoverable amount falls below its net book value, per GAAP impairment testing requirements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentDate rdf:type rdf:Property ;
    rdfs:label 'Impairment Date' ;
    rdfs:comment 'The date on which an impairment loss was recognized for the asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isLeasedAsset rdf:type rdf:Property ;
    rdfs:label 'Is Leased Asset' ;
    rdfs:comment 'Flag indicating whether the asset is leased rather than owned. Leased assets follow ASC 842 lease accounting rules.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'The date of the most recent physical inventory verification of the asset, required for SOX compliance and audit trails.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Reference to the lease agreement contract number if the asset is leased. Links to lease liability and right-of-use asset records.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset, calculated as acquisition cost minus accumulated depreciation. Represents the remaining capitalized value on the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique equipment identifier for physical tracking and warranty management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAccumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Tax Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation recognized for tax purposes to date. Used to track book-tax differences for deferred tax calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'The IRS-approved depreciation method used for tax reporting, which may differ from book depreciation (e.g., MACRS, Section 179 expensing, bonus depreciation).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years, used to calculate depreciation rates. Determined by asset class and IRS guidelines.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'The date on which the manufacturer or vendor warranty expires, used for maintenance planning and cost forecasting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concentrationAccountId rdf:type rdf:Property ;
    rdfs:label 'Concentration Account Id' ;
    rdfs:comment 'Foreign key to the master concentration account if this is a zero-balance account. Null for non-ZBA accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Must match legal entity name for corporate accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Full bank account number. Stored in encrypted form for PCI compliance.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Business purpose of the account: operating (AP/AR), payroll (employee payments), tax (remittances), investment (short-term cash), debt_service (loan payments), escrow (restricted funds).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier. In US: ABA routing number (9 digits). In EU: Bank Identifier Code (BIC/SWIFT). Maps to SAP bank key (BNKA-BANKL).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Full street address of the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCity rdf:type rdf:Property ;
    rdfs:label 'Branch City' ;
    rdfs:comment 'City where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Branch Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the bank branch where the account is domiciled.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchPostalCode rdf:type rdf:Property ;
    rdfs:label 'Branch Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the bank branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchState rdf:type rdf:Property ;
    rdfs:label 'Branch State' ;
    rdfs:comment 'Two-letter state or province code for the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date the bank account was closed. Null for active accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Most recent closing balance from the last processed bank statement. Used for daily cash position reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'SAP-assigned identifier for the house bank configuration. Links to SAP FI bank master (T012).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for SEPA and cross-border payments in Europe and other IBAN-participating countries.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate earned on positive balances or charged on overdrafts, expressed as a decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'Date of the most recent completed bank reconciliation. Used for SOX compliance monitoring.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recent bank statement received and processed for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockboxIndicator rdf:type rdf:Property ;
    rdfs:label 'Lockbox Indicator' ;
    rdfs:comment 'True if this account is a lockbox account used for automated AR collection processing. False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Account Number' ;
    rdfs:comment 'Masked account number showing only last 4 digits for display purposes (e.g., XXXXXX1234).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum negative balance allowed by the bank under overdraft protection agreement. Zero if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing transit number for US domestic wire and ACH transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority1 rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority 1' ;
    rdfs:comment 'Name of the primary authorized signatory for the account. Required for SOX treasury controls and audit trail.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority2 rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority 2' ;
    rdfs:comment 'Name of the secondary authorized signatory. Used for dual-control requirements on high-value transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Signatory Threshold Amount' ;
    rdfs:comment 'Maximum transaction amount that can be authorized by a single signatory. Amounts above this require dual approval.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'Electronic format in which bank statements are received: MT940 (SWIFT standard), BAI2 (US cash management), CAMT053 (ISO 20022 XML), PDF, CSV.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'How often bank statements are issued: daily (for high-volume accounts), weekly, monthly.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'Bank Identifier Code (BIC) for international wire transfers. 8 or 11 character ISO 9362 code.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroBalanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Zero Balance Indicator' ;
    rdfs:comment 'True if this is a zero-balance account that is automatically swept to/from a concentration account daily. False otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Order Header Id' ;
    rdfs:comment 'Unique surrogate identifier for every customer purchase record across all channels (POS, online, click-and-collect, curbside pickup, last-mile delivery, pharmacy Rx fills). Primary key of the order_header entity and the single canonical identity for all customer transactions in the enterprise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:adCircularId rdf:type rdf:Property ;
    rdfs:label 'Ad Circular Id' ;
    rdfs:comment 'Foreign key linking to promotion.ad_circular. Business justification: Grocery retailers measure ad circular ROI by attributing transactions to the specific circular that drove the visit. order_header.ad_circular_week is a denormalized reference; a proper FK to ad_circul' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdCircular .

ind:methodId rdf:type rdf:Property ;
    rdfs:label 'Method Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_method. Business justification: Order-level reference to the tokenized payment method allows reporting of payment method usage per order and supports refunds to the original method.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:primaryOrderFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Links each order to its fiscal period, enabling period-based financial statements and variance analysis.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:ageVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Age Verification Required' ;
    rdfs:comment 'Indicates whether the order contains age-restricted items (alcohol, tobacco, lottery tickets, certain medications) requiring cashier or delivery driver age verification at point of sale or delivery. Triggers age-check workflow in NCR POS or last-mile delivery confirmation.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bagFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Bag Fee Amount' ;
    rdfs:comment 'Total fee charged for single-use plastic or paper bags per applicable state and local bag fee ordinances. Required for regulatory compliance reporting in jurisdictions with mandatory bag fee laws (e.g., California, Illinois). Zero in jurisdictions without bag fee requirements.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basketItemCount rdf:type rdf:Property ;
    rdfs:label 'Basket Item Count' ;
    rdfs:comment 'Total number of distinct line items (SKUs) in the order basket. Used for basket size analytics, express lane eligibility (e.g., 15 items or fewer), and customer segmentation. Distinct from total unit quantity which counts individual units across all line items.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code explaining why the order was cancelled. Populated only when order_status = \'cancelled\'. Used for cancellation root-cause analysis, OOS (Out of Stock) reporting, and fraud detection. Values: customer_request, out_of_stock, payment_failure, fraud_hold, store_closure, system_error.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDueAmount rdf:type rdf:Property ;
    rdfs:label 'Change Due Amount' ;
    rdfs:comment 'Amount of cash change to be returned to the customer when cash tender exceeds the order total. Applicable only for in-store POS and self-checkout cash transactions. Null for non-cash or digital orders. Sourced from NCR POS cash management module.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for last-mile delivery service. Applicable for online_delivery channel orders. May be zero for fee-waived orders (e.g., loyalty member benefit, promotional free delivery). Null for in-store POS, click-and-collect, and curbside pickup orders.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebtSnapWicUsed rdf:type rdf:Property ;
    rdfs:label 'Ebt Snap Wic Used' ;
    rdfs:comment 'Indicates whether any government assistance program tender (EBT — Electronic Benefits Transfer, SNAP — Supplemental Nutrition Assistance Program, or WIC — Women Infants and Children) was used in this transaction. Required for USDA SNAP/WIC program compliance reporting and retailer authorization audits.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Scheduled or actual date on which the order is to be fulfilled — delivered to the customer, made available for pickup, or dispensed (for pharmacy Rx). Used for delivery slot management, SLA tracking, and fulfillment capacity planning. Null for immediate in-store POS transactions.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Precise timestamp when the order was actually fulfilled — delivered, picked up by the customer, or dispensed. Used for on-time delivery rate (OTD) measurement, last-mile delivery (LMD) SLA compliance, and customer experience analytics. Null until fulfillment is confirmed.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyCardScanned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Card Scanned' ;
    rdfs:comment 'Indicates whether a customer loyalty card or loyalty account was identified and scanned/linked at the time of the transaction. True enables loyalty points accrual and personalized offer redemption. False indicates an anonymous transaction with no loyalty attribution.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty reward points earned by the customer on this transaction based on the applicable loyalty program earning rules. Zero for anonymous transactions (loyalty_card_scanned = false) or transactions where no points were awarded (e.g., fuel-only purchases).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:omsOrderReference rdf:type rdf:Property ;
    rdfs:label 'Oms Order Reference' ;
    rdfs:comment 'External order reference number assigned by the OMS (Order Management System — Salesforce Commerce Cloud) for omnichannel orders. Enables cross-system order tracing between the Silver layer canonical model and the OMS source system. Null for pure in-store POS transactions not routed through OMS.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Calendar date on which the order was placed or the POS transaction was initiated. Used for daily sales reporting, comp sales (comparable store sales), same-store sales analysis, and fiscal period alignment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Precise date and time at which the order was placed or the POS transaction was opened. The principal real-world business event timestamp. Used for intraday sales analytics, peak-hour staffing analysis, and order SLA measurement. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pharmacyRxFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Rx Flag' ;
    rdfs:comment 'Indicates whether this order contains one or more pharmacy prescription (Rx) line items. When true, the order is subject to HIPAA privacy requirements, DEA controlled substance regulations, and State Board of Pharmacy dispensing rules. Drives downstream routing to McKesson Pharmacy Systems.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registerNumber rdf:type rdf:Property ;
    rdfs:label 'Register Number' ;
    rdfs:comment 'POS register or checkout lane identifier within the store where the transaction was processed. Applicable only for in_store_pos and self_checkout channel types. Used for lane-level performance reporting, cashier assignment, and cash reconciliation. Null for OMS-originated orders.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfCheckout rdf:type rdf:Property ;
    rdfs:label 'Self Checkout' ;
    rdfs:comment 'Indicates whether the transaction was processed through a self-checkout (SCO) lane where the customer scanned and bagged their own items without cashier assistance. Used for self-checkout adoption analytics, shrink attribution, and labor efficiency reporting.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field capturing customer-provided delivery, pickup, or preparation instructions (e.g., \'Leave at front door\', \'No substitutions\', \'Call upon arrival\'). Applicable for online delivery, click-and-collect, and curbside pickup orders. Null for in-store POS transactions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Customer preference indicating whether out-of-stock (OOS) items in the order may be substituted with comparable alternatives by the picker or fulfillment associate. Applicable for online delivery, click-and-collect, and curbside pickup orders. Null for in-store POS transactions.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item extended prices before tax, discounts, and fees are applied. Represents the gross merchandise value (GMV) of the basket prior to adjustments. Used in COGS (Cost of Goods Sold) and GMROI (Gross Margin Return on Investment) calculations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderSummary rdf:type rdf:Property ;
    rdfs:label 'Tender Summary' ;
    rdfs:comment 'Human-readable summary of payment tender types used in this transaction (e.g., \'Credit $45.20, Loyalty Points $5.00\'). Provides a quick overview of how the order was paid without exposing sensitive payment details. Sourced from NCR POS tender records or Salesforce Commerce Cloud payment summary.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final net amount due from the customer after applying subtotal, discounts, fees, and tax. Equals subtotal_amount minus discount_amount plus tax_amount plus any applicable fees (delivery, service). This is the amount tendered by the customer. Core metric for revenue reporting and EBITDA calculations.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Unit Quantity' ;
    rdfs:comment 'Total number of individual units (items) purchased across all line items in the order. Differs from basket_item_count which counts distinct SKUs. Used for average units per transaction (UPT) analytics and shrink analysis.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the POS or OMS transaction by its business purpose. Primarily relevant for in-store POS and self-checkout channels. Values: sale (standard purchase), return (merchandise returned for refund), void (transaction cancelled before tender completion), no_sale (cash drawer opened without a sale), exchange (item swap without net monetary change).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Product Order Line Id' ;
    rdfs:comment 'Unique identifier for the order line item. Primary key for the order line product.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductOrderLine .

ind:assortmentItemId rdf:type rdf:Property ;
    rdfs:label 'Assortment Item Id' ;
    rdfs:comment 'Foreign key linking to assortment.assortment_item. Business justification: Needed for planogram compliance analysis; linking each sold line to the specific assortment item enables tracking of plan execution vs actual sales.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssortmentItem .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to product.brand. Business justification: Enables brand performance analytics and promotional budgeting by linking each order line to its brand master.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:drugItemId rdf:type rdf:Property ;
    rdfs:label 'Drug Item Id' ;
    rdfs:comment 'Foreign key linking to product.drug_item. Business justification: Necessary for pharmacy order compliance, controlled-substance tracking, and drug-specific reporting.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugItem .

ind:itemHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Item Hierarchy Id' ;
    rdfs:comment 'Foreign key linking to product.item_hierarchy. Business justification: Supports hierarchical assortment planning and category-level sales reporting via the item hierarchy reference.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItemHierarchy .

ind:pluCodeId rdf:type rdf:Property ;
    rdfs:label 'Plu Code Id' ;
    rdfs:comment 'Foreign key linking to product.plu_code. Business justification: product_order_line stores plu as a denormalized string for fresh produce and variable-weight items. plu_code is the authoritative PLU registry with commodity type, organic flag, size grade, and price-' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PluCode .

ind:prescriptionId rdf:type rdf:Property ;
    rdfs:label 'Prescription Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.prescription. Business justification: Line-level tracking of prescription items enables accurate inventory deduction, claim submission, and return processing in pharmacy operations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prescription .

ind:priceChangeId rdf:type rdf:Property ;
    rdfs:label 'Price Change Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_change. Business justification: Price-change impact analysis tracks which price_change event affected a line, supporting margin and revenue impact reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceChange .

ind:promoOfferId rdf:type rdf:Property ;
    rdfs:label 'Promo Offer Id' ;
    rdfs:comment 'Foreign key linking to promotion.promo_offer. Business justification: When a coupon or promo code is applied, the order line should reference the specific promo offer for audit and effectiveness analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromoOffer .

ind:retailPriceId rdf:type rdf:Property ;
    rdfs:label 'Retail Price Id' ;
    rdfs:comment 'Foreign key linking to pricing.retail_price. Business justification: Price audit report requires linking each order line to the exact retail_price record applied, enabling compliance checks of sold price versus current price.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailPrice .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Required for SKU-level sales reporting and inventory allocation; order lines must reference the SKU master record.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:upcBarcodeId rdf:type rdf:Property ;
    rdfs:label 'Upc Barcode Id' ;
    rdfs:comment 'Foreign key linking to product.upc_barcode. Business justification: product_order_line stores upc as a denormalized string. upc_barcode is the authoritative UPC/barcode registry with scan metadata, packaging level, and GS1 company prefix. Adding upc_barcode_id normali' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpcBarcode .

ind:ageRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restricted Flag' ;
    rdfs:comment 'Indicates whether this item requires age verification at point of sale. Includes alcohol, tobacco, and certain over-the-counter medications.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bogoFlag rdf:type rdf:Property ;
    rdfs:label 'Bogo Flag' ;
    rdfs:comment 'Indicates whether this line item was part of a Buy One Get One promotion. Used for basket analysis and promotional effectiveness reporting.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:couponCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Code' ;
    rdfs:comment 'Manufacturer or store coupon code applied to this line item. Links to coupon campaign for redemption tracking and vendor chargeback.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedPrice rdf:type rdf:Property ;
    rdfs:label 'Extended Price' ;
    rdfs:comment 'Total price for the line item calculated as quantity multiplied by unit price, before discounts and taxes. Gross line amount.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'Method by which this specific line item will be fulfilled. Supports mixed-cart scenarios where different items in the same order have different fulfillment methods.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'Global Trade Item Number for international product identification. Encompasses UPC, EAN, and other GS1 identifiers.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Human-readable description of the product as it appears on the receipt and in order details. Includes brand, size, and variant information.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this line item within the parent order. Used for ordering and display purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the order line item. Tracks the line through fulfillment stages from active order to final disposition. [ENUM-REF-CANDIDATE: active|substituted|cancelled|out_of_stock|voided|returned|picked|packed|delivered — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Flag' ;
    rdfs:comment 'Indicates whether this item is certified organic by USDA or equivalent certification body. Used for organic category reporting and compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalSku rdf:type rdf:Property ;
    rdfs:label 'Original Sku' ;
    rdfs:comment 'Original SKU that was requested by the customer before substitution occurred. Null if no substitution was made.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether this item is a perishable product requiring cold chain management and FIFO inventory rotation. Includes fresh produce, meat, dairy, deli, bakery, and frozen items.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privateLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Private Label Flag' ;
    rdfs:comment 'Indicates whether this item is a store-owned private label brand product. Used for private label performance analysis and margin reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promoAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Promo Applied Flag' ;
    rdfs:comment 'Indicates whether a promotional discount was applied to this line item. True if any promotion, coupon, or loyalty discount was used.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Quantity of the item ordered by the customer. Supports fractional quantities for variable-weight items such as produce, meat, and deli products.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnFlag rdf:type rdf:Property ;
    rdfs:label 'Return Flag' ;
    rdfs:comment 'Indicates whether this line item represents a product return. Used for return rate analysis and inventory restocking.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Reason code explaining why the item was returned. Examples include defective, expired, customer dissatisfaction, or wrong item delivered.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanMethod rdf:type rdf:Property ;
    rdfs:label 'Scan Method' ;
    rdfs:comment 'Method used to capture the item at point of sale or during order picking. Indicates whether the item was scanned via handheld device, belt scanner, self-checkout, manually keyed, or captured via mobile app.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Snap Eligible Flag' ;
    rdfs:comment 'Indicates whether this item is eligible for purchase using SNAP Electronic Benefits Transfer (EBT). Required for government program compliance and reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether this line item is a substitution for an originally requested item that was out of stock or unavailable. Common in online and click-and-collect orders.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax classification code for the item determining applicable sales tax rates. Differentiates taxable, non-taxable, and reduced-rate items such as groceries, prepared foods, and SNAP-eligible products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tprFlag rdf:type rdf:Property ;
    rdfs:label 'Tpr Flag' ;
    rdfs:comment 'Indicates whether this line item was sold at a temporary price reduction. Used for promotional markdown analysis and ad circular tracking.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity ordered. Indicates whether the item is sold by each, weight, volume, or pack. [ENUM-REF-CANDIDATE: each|lb|kg|oz|g|case|pack|dozen|gallon|liter|ml — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of measure before any discounts or promotions are applied. Base selling price for the item.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidFlag rdf:type rdf:Property ;
    rdfs:label 'Void Flag' ;
    rdfs:comment 'Indicates whether this line item was voided during the transaction. Used for shrink analysis and cashier performance monitoring.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Reason code explaining why the line item was voided. Examples include customer changed mind, pricing error, damaged item, or cashier error.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightActual rdf:type rdf:Property ;
    rdfs:label 'Weight Actual' ;
    rdfs:comment 'Actual weight of the item for variable-weight products such as fresh produce, meat, deli, and seafood. Captured from scale at POS or during fulfillment picking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for the actual weight field. Typically pounds or kilograms depending on regional standards.' ;
    rdfs:domain ind:ProductOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Wic Eligible Flag' ;
    rdfs:comment 'Indicates whether this item is eligible for purchase using WIC benefits. Required for government program compliance and reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Order Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition record in the order lifecycle. Primary key for the immutable audit trail.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'The category of actor (person or system) that triggered the status transition. Examples: customer, store_associate, warehouse_picker, delivery_driver, system_automation, customer_service_rep, pharmacy_technician. [ENUM-REF-CANDIDATE: customer|store_associate|warehouse_picker|delivery_driver|system_automation|customer_service_rep|pharmacy_technician — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'The unique identifier of the device (mobile scanner, POS terminal, handheld picker device) used to record this status transition. Used for device audit trails and operational troubleshooting.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dwellTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Dwell Time Minutes' ;
    rdfs:comment 'The number of minutes the order spent in the previous status before this transition. Calculated as the difference between this transition_timestamp and the prior transition_timestamp. Used for cycle time analysis and bottleneck identification.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Timestamp' ;
    rdfs:comment 'The estimated date and time when the order is expected to reach final completion (delivered or ready for pickup), calculated at the time of this status transition. Updated with each transition to reflect current estimates.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code identifying any exception or issue that occurred during this status transition. Examples: OUT_OF_STOCK, PAYMENT_DECLINED, ADDRESS_INVALID, WEATHER_DELAY, CUSTOMER_NOT_HOME. Null for normal transitions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Free-text description providing additional context about the exception or issue. Used for customer service investigation and root cause analysis. Null for normal transitions.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The omnichannel fulfillment method for this order. Examples: in_store (traditional POS), curbside_pickup (click-and-collect), home_delivery (last-mile delivery), ship_to_home (parcel shipment), pharmacy_pickup, locker_pickup.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate where the status transition occurred, captured from mobile device or delivery scanner. Used for delivery verification and route optimization analysis. Null if geolocation not captured.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate where the status transition occurred, captured from mobile device or delivery scanner. Used for delivery verification and route optimization analysis. Null if geolocation not captured.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status the order transitioned to. Captures the to-state in the status change event. This is the current status after the transition. [ENUM-REF-CANDIDATE: pending|confirmed|allocated|picking|picked|packed|ready_for_pickup|out_for_delivery|delivered|cancelled|refunded — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status transition. Examples: email, sms, push (mobile push notification), none (no notification sent).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification (email, SMS, push notification) was sent for this status transition. True if notification was triggered, False otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status the order was in immediately before this transition. Captures the from-state in the status change event. [ENUM-REF-CANDIDATE: pending|confirmed|allocated|picking|picked|packed|ready_for_pickup|out_for_delivery|delivered|cancelled|refunded — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the status transition occurred within the SLA target window. True if transition_timestamp <= sla_target_timestamp, False otherwise. Critical for performance reporting and customer service.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The target date and time by which this status transition was expected to occur, based on the order\'s service level agreement. Used for SLA compliance tracking and exception reporting.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Ref' ;
    rdfs:comment 'The unique transaction or event identifier from the source system (OMS, TMS, WMS, POS) that generated this status transition. Used for cross-system reconciliation and technical troubleshooting.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'The carrier-provided tracking number or shipment identifier associated with this status transition. Used for carrier dispute management and delivery verification. Null for non-delivery transitions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the status transition occurred. This is the business event timestamp for the status change, distinct from record creation time.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'The specific business event or action that caused this status transition. Examples: customer_placed_order, payment_authorized, inventory_allocated, pick_started, pick_completed, pack_completed, customer_arrived (for pickup), driver_dispatched, driver_scanned, delivery_confirmed, customer_cancelled, system_timeout, exception_raised, refund_processed. [ENUM-REF-CANDIDATE: customer_placed_order|payment_authorized|inventory_allocated|pick_started|pick_completed|pack_completed|customer_arrived|driver_dispatched|driver_scanned|delivery_confirmed|customer_cancelled|system_timeout|exception_raised|refund_processed — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringSystem rdf:type rdf:Property ;
    rdfs:label 'Triggering System' ;
    rdfs:comment 'The source system that initiated or recorded this status transition. Examples: OMS (Order Management System), TMS (Transportation Management System), WMS (Warehouse Management System), POS (Point of Sale), ECOM (eCommerce platform), MOBILE (mobile app), PHARMACY (pharmacy system), MANUAL (manual override). [ENUM-REF-CANDIDATE: OMS|TMS|WMS|POS|ECOM|MOBILE|PHARMACY|MANUAL — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Unique identifier for the delivery order record. Primary key for the delivery order entity representing the last-mile logistics leg of an online or OMS-originated order.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentSlotId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Slot Id' ;
    rdfs:comment 'Foreign key linking to product.fulfillment_slot. Business justification: A delivery_order represents last-mile delivery which is scheduled within a fulfillment_slot time window (scheduled_window_start_time, scheduled_window_end_time on delivery_order correspond to slot win' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentSlot .

ind:orderFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Order Fulfillment Id' ;
    rdfs:comment 'Foreign key linking to product.order_fulfillment. Business justification: A delivery_order is the last-mile logistics leg that follows the pick-pack-ship fulfillment execution in order_fulfillment. Linking delivery_order to order_fulfillment enables end-to-end order trackin' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderFulfillment .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'The precise timestamp when the delivery was completed and goods were handed off to the customer or left at the delivery location. Null if delivery not yet completed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactlessDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Delivery Flag' ;
    rdfs:comment 'Indicates whether the customer requested contactless delivery. When true, driver should leave items at the door and minimize direct contact.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes recorded by the driver at delivery time. May include delivery condition observations, customer interactions, or exception details.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Number' ;
    rdfs:comment 'Human-readable business identifier for the delivery order, used for tracking and customer communication. Typically formatted as DO- prefix followed by 10-digit sequence.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order. Tracks progression from scheduling through final delivery or failure. Values: scheduled (delivery window assigned), assigned (driver allocated), en_route (in transit), out_for_delivery (final leg), delivered (completed successfully), failed (delivery attempt unsuccessful), returned (sent back to origin), cancelled (order cancelled before delivery). [ENUM-REF-CANDIDATE: scheduled|assigned|en_route|out_for_delivery|delivered|failed|returned|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of delivery service level. Defines the speed and method of delivery fulfillment.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Total distance in miles from the fulfillment origin (store, MFC, or DC) to the delivery destination. Used for delivery fee calculation and route analytics.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code indicating why a delivery attempt failed. Populated only when delivery_status is failed or returned. Used for root cause analysis and redelivery planning. [ENUM-REF-CANDIDATE: customer_not_home|address_not_found|access_denied|weather|vehicle_issue|refused|damaged|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Method' ;
    rdfs:comment 'The method used to capture proof that the delivery was completed. Values: signature (customer signed on device), photo (driver captured delivery photo), pin (customer provided PIN code), none (no proof captured for contactless).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference identifier or URL to the stored proof of delivery artifact (signature image, photo, or PIN verification record). Used for dispute resolution.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reattemptCount rdf:type rdf:Property ;
    rdfs:label 'Reattempt Count' ;
    rdfs:comment 'Number of delivery attempts made for this order. Increments with each failed delivery attempt. Used to trigger customer contact or return-to-sender workflows.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Name of the person who received the delivery. May differ from the order customer if delivery was accepted by household member or designee.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'The date on which the delivery is scheduled to occur. Used for day-level delivery planning and customer communication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Window End Time' ;
    rdfs:comment 'The ending timestamp of the scheduled delivery window communicated to the customer. Defines the latest time within the promised delivery window.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Window Start Time' ;
    rdfs:comment 'The beginning timestamp of the scheduled delivery window communicated to the customer. Defines the earliest time the customer should expect delivery.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'The position of this delivery within the drivers route sequence. Used for route optimization and estimated time of arrival calculation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this delivery requires cold chain temperature control for perishable or frozen items. When true, vehicle must have refrigeration capability.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tipAmount rdf:type rdf:Property ;
    rdfs:label 'Tip Amount' ;
    rdfs:comment 'Gratuity amount provided by the customer for the delivery driver. May be pre-tip at order time or post-delivery adjustment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickupAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Pickup Appointment Id' ;
    rdfs:comment 'Unique identifier for the pickup appointment record. Primary key for curbside and click-and-collect appointment tracking.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCapabilityId rdf:type rdf:Property ;
    rdfs:label 'Service Capability Id' ;
    rdfs:comment 'Foreign key linking to store.service_capability. Business justification: Pickup appointments are governed by the store\'s curbside or in-store pickup service_capability record, which defines bay count, SLA targets, and capacity limits. Linking appointments to service_capabi' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCapability .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Human-readable business identifier for the pickup appointment. Used for customer communication and associate reference during fulfillment.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of the pickup appointment. Tracks progression from scheduling through completion or cancellation. Critical for SLA (Service Level Agreement) monitoring and operational workflow management. [ENUM-REF-CANDIDATE: scheduled|confirmed|ready|arrived|in_progress|dispensed|completed|no_show|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Classification of pickup method. Distinguishes between curbside delivery to vehicle, in-store pickup counter collection, or automated locker retrieval.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Notification Sent Timestamp' ;
    rdfs:comment 'The timestamp when the customer sent an I\'m here notification via mobile app or SMS. Alerts store associates that customer has arrived.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notes' ;
    rdfs:comment 'Free-text notes explaining the cancellation circumstances. Provides additional context beyond the reason code for customer service and operational review.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The timestamp when the appointment was cancelled by customer or system. Used for slot release and cancellation rate analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'The phone number to reach the customer upon arrival or for appointment coordination. Used for real-time communication during pickup process.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Arrival Timestamp' ;
    rdfs:comment 'The actual timestamp when the customer arrived at the pickup location. Captured via mobile app check-in or associate entry. Critical for SLA (Service Level Agreement) measurement.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the customer about their pickup experience. Captures qualitative insights for service improvement.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRating rdf:type rdf:Property ;
    rdfs:label 'Customer Rating' ;
    rdfs:comment 'The customer satisfaction rating provided after pickup completion, typically on a 1-5 scale. Used for service quality measurement and associate performance evaluation.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispensing Completion Timestamp' ;
    rdfs:comment 'The timestamp when the order was fully dispensed to the customer and the transaction completed. Used for calculating total service time and SLA compliance.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispensingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispensing Start Timestamp' ;
    rdfs:comment 'The timestamp when the associate began loading items into the customer\'s vehicle or handed over the order. Marks the beginning of the dispensing process.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderReadyTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Ready Timestamp' ;
    rdfs:comment 'The timestamp when the order was fully picked, staged, and ready for customer pickup. Triggers customer notification that order is available.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parkingSpotNumber rdf:type rdf:Property ;
    rdfs:label 'Parking Spot Number' ;
    rdfs:comment 'The specific parking spot identifier where the customer parks for curbside pickup. May differ from bay number in stores with multiple spot configurations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupBayNumber rdf:type rdf:Property ;
    rdfs:label 'Pickup Bay Number' ;
    rdfs:comment 'The designated curbside bay or parking spot number assigned to this appointment. Used for directing customers to the correct location and managing bay capacity.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready Notification Sent Timestamp' ;
    rdfs:comment 'The timestamp when the order-ready notification (SMS, email, or app push) was sent to the customer. Used for communication audit trail.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reminderNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reminder Notification Sent Timestamp' ;
    rdfs:comment 'The timestamp when a reminder notification was sent to the customer about their upcoming appointment. Used for proactive customer engagement tracking.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The calendar date on which the pickup appointment is scheduled. Used for day-level capacity planning and customer communication.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The ending timestamp of the scheduled pickup window. Defines the latest time within the appointment slot for customer arrival.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'The beginning timestamp of the scheduled pickup window. Defines when the customer can arrive for their appointment.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'The target service time in minutes for this appointment type. Used for measuring performance against service commitments.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotCapacityUsed rdf:type rdf:Property ;
    rdfs:label 'Slot Capacity Used' ;
    rdfs:comment 'The capacity units consumed by this appointment within the time slot. Used for managing concurrent appointment limits and preventing overbooking.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionPreference rdf:type rdf:Property ;
    rdfs:label 'Substitution Preference' ;
    rdfs:comment 'Customer preference for handling out-of-stock items. Determines whether substitutions are allowed and if customer approval is required.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'The temperature control requirement for this order. Determines staging location and handling procedures to maintain cold chain integrity for perishables.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBagCount rdf:type rdf:Property ;
    rdfs:label 'Total Bag Count' ;
    rdfs:comment 'The total number of bags or containers prepared for this pickup. Helps associates verify complete order transfer to customer.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Item Count' ;
    rdfs:comment 'The total number of items in the order for this pickup appointment. Used for workload estimation and associate staffing decisions.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleDescription rdf:type rdf:Property ;
    rdfs:label 'Vehicle Description' ;
    rdfs:comment 'Description of the customer\'s vehicle including make, model, and color. Helps associates identify the correct vehicle during curbside fulfillment.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Vehicle License Plate' ;
    rdfs:comment 'The license plate number of the customer\'s vehicle. Used for positive identification during curbside pickup. Business-confidential customer information.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Time Minutes' ;
    rdfs:comment 'The calculated wait time in minutes from customer arrival to dispensing completion. Key performance indicator for curbside service quality and SLA compliance.' ;
    rdfs:domain ind:PickupAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchWaveId rdf:type rdf:Property ;
    rdfs:label 'Batch Wave Id' ;
    rdfs:comment 'Identifier for the batch wave if this fulfillment was part of a multi-order picking wave. Used in WMS optimization for efficient picking routes.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:mfcProfileId rdf:type rdf:Property ;
    rdfs:label 'Mfc Profile Id' ;
    rdfs:comment 'Foreign key linking to store.mfc_profile. Business justification: MFC-fulfilled orders must reference the specific mfc_profile to support robotics throughput reporting, pick-time SLA tracking, and MFC-level order accuracy KPIs. Grocery omnichannel operations teams r' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MfcProfile .

ind:actualFulfillmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Fulfillment Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from pick start to dispatch. Used to measure picker productivity and SLA compliance.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatched Timestamp' ;
    rdfs:comment 'Timestamp when the order was handed to the customer (curbside/in-store pickup) or to the delivery carrier for last-mile delivery.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentLocationType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Location Type' ;
    rdfs:comment 'Type of facility executing the fulfillment. Store = retail store backroom, MFC = Micro-Fulfillment Center, DC = Distribution Center, Pharmacy = pharmacy dispensing area.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Number' ;
    rdfs:comment 'Business-readable identifier for this fulfillment execution, used for tracking and communication with pickers and customers.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current state of the fulfillment workflow. Queued = awaiting assignment, Assigned = picker assigned but not started, Picking = actively picking items, Picked = all items picked, Packing = items being packed, Packed = packing complete, Staged = ready for customer pickup or delivery dispatch, Dispatched = handed to carrier or customer, Cancelled = fulfillment aborted. [ENUM-REF-CANDIDATE: queued|assigned|picking|picked|packing|packed|staged|dispatched|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosLineCount rdf:type rdf:Property ;
    rdfs:label 'Oos Line Count' ;
    rdfs:comment 'Number of order lines that could not be fulfilled due to out-of-stock conditions and no acceptable substitution. Impacts customer satisfaction and fill rate metrics.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Complete Timestamp' ;
    rdfs:comment 'Timestamp when packing was completed and order is ready for staging or dispatch.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Timestamp when packing of picked items began. Used for labor tracking and process efficiency analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of packages or bags this fulfillment was packed into. Used for customer communication and carrier handoff verification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Complete Timestamp' ;
    rdfs:comment 'Timestamp when all items were picked (or picking was completed with substitutions/OOS). Marks transition to packing stage.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'Timestamp when the picker began picking items for this order. Used for labor productivity tracking and SLA monitoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickerNotes rdf:type rdf:Property ;
    rdfs:label 'Picker Notes' ;
    rdfs:comment 'Free-text notes entered by the picker during fulfillment, such as item condition observations, substitution reasons, or customer communication notes.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Flag' ;
    rdfs:comment 'Indicates whether this fulfillment underwent a quality inspection before staging. True = quality check performed, False = no quality check. Used for high-value orders or training purposes.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stagedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Staged Timestamp' ;
    rdfs:comment 'Timestamp when the packed order was placed in the staging area or pickup bay, ready for customer collection or carrier pickup.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stagingArea rdf:type rdf:Property ;
    rdfs:label 'Staging Area' ;
    rdfs:comment 'Physical staging location identifier within the fulfillment facility (e.g., bay number, zone, cooler section) where the packed order is held for pickup or dispatch.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionCount rdf:type rdf:Property ;
    rdfs:label 'Substitution Count' ;
    rdfs:comment 'Number of order lines where a substitute item was picked due to the original item being out of stock or unavailable.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLines rdf:type rdf:Property ;
    rdfs:label 'Total Lines' ;
    rdfs:comment 'Total number of order line items in the original order that this fulfillment is responsible for picking.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLinesPicked rdf:type rdf:Property ;
    rdfs:label 'Total Lines Picked' ;
    rdfs:comment 'Number of order lines successfully picked (including substitutions). Used to calculate fill rate and picker productivity.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsPicked rdf:type rdf:Property ;
    rdfs:label 'Total Units Picked' ;
    rdfs:comment 'Total quantity of units picked across all lines, including substitutions. Used for labor productivity measurement (units per hour).' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Liters' ;
    rdfs:comment 'Total volume of the packed order in liters. Used for vehicle capacity planning and staging area space management.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total weight of the picked and packed order in kilograms. Used for shipping cost calculation and load planning for delivery vehicles.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTaskReference rdf:type rdf:Property ;
    rdfs:label 'Wms Task Reference' ;
    rdfs:comment 'External task or wave identifier from Manhattan Associates WMS that orchestrated this fulfillment execution. Used for integration and audit trail.' ;
    rdfs:domain ind:OrderFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDiscountId rdf:type rdf:Property ;
    rdfs:label 'Order Discount Id' ;
    rdfs:comment 'Unique identifier for the order discount record. Primary key.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rewardOfferId rdf:type rdf:Property ;
    rdfs:label 'Reward Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.reward_offer. Business justification: Loyalty-funded discount reconciliation requires distinguishing discounts funded by loyalty reward offers from trade-promotion discounts. Finance and loyalty teams separately account for loyalty redemp' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RewardOffer .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'The date and time when this discount was applied to the order during the transaction or order processing workflow.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this discount required manager or supervisor approval before being applied. True if approval was required, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when this discount was approved by a manager or supervisor. Nullable if no approval was required.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The sales channel through which this discount was applied. In-store for POS (Point of Sale) transactions, online for eCommerce, mobile app for app-based orders, curbside pickup for click-and-collect, delivery for last-mile delivery orders, pharmacy for prescription fills.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'The percentage rate of discount applied, expressed as a decimal (e.g., 15.00 for 15% off). Nullable if discount is a fixed amount rather than percentage-based.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discount Reason Code' ;
    rdfs:comment 'Internal code indicating the business reason or authorization basis for the discount. Used for audit and compliance tracking.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountScope rdf:type rdf:Property ;
    rdfs:label 'Discount Scope' ;
    rdfs:comment 'The level at which this discount is applied. Order header applies to entire order, order line applies to specific line item, category applies to product category, SKU (Stock Keeping Unit) applies to specific product, basket applies to qualifying basket combinations.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountStatus rdf:type rdf:Property ;
    rdfs:label 'Discount Status' ;
    rdfs:comment 'Current lifecycle status of the discount. Applied indicates successfully applied, reversed indicates discount was removed or refunded, pending indicates awaiting validation, expired indicates promotion period ended, invalid indicates discount failed validation rules.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism applied. TPR (Temporary Price Reduction), BOGO (Buy One Get One), digital coupon, loyalty reward, ad circular promotion, markdown clearance, employee discount, EBT (Electronic Benefits Transfer) discount, vendor-funded promotion, or store-funded promotion. [ENUM-REF-CANDIDATE: tpr|bogo|digital_coupon|loyalty_reward|ad_circular|markdown|employee_discount|ebt_discount|vendor_funded|store_funded — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPrice rdf:type rdf:Property ;
    rdfs:label 'Final Price' ;
    rdfs:comment 'The final price after this discount was applied. Represents the net amount charged to the customer for this discount application.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Entity responsible for funding or absorbing the cost of this discount. Vendor-funded promotions are reimbursed by suppliers, store-funded are absorbed by the retailer.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty program points redeemed by the customer to obtain this discount. Nullable if discount is not loyalty-based.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDiscountAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Discount Allowed' ;
    rdfs:comment 'The maximum discount amount permitted by the promotion rules or system configuration. Used to enforce discount caps and prevent over-discounting.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurchaseRequired rdf:type rdf:Property ;
    rdfs:label 'Min Purchase Required' ;
    rdfs:comment 'The minimum purchase amount required to qualify for this discount. Nullable if no minimum threshold applies.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'The original price of the item or order total before this discount was applied. Used for calculating discount impact and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Code' ;
    rdfs:comment 'Identifier of the point-of-sale terminal or register where this discount was processed. Nullable for digital commerce transactions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoStackSequence rdf:type rdf:Property ;
    rdfs:label 'Promo Stack Sequence' ;
    rdfs:comment 'The order in which this discount was applied when multiple promotions are stacked on the same order or line. Lower numbers indicate earlier application in the discount calculation sequence.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'The effective end date of the promotion period after which this discount is no longer valid.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'The effective start date of the promotion period during which this discount is valid.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityThreshold rdf:type rdf:Property ;
    rdfs:label 'Quantity Threshold' ;
    rdfs:comment 'The minimum quantity of items required to qualify for this discount (e.g., buy 3 get 1 free). Nullable if discount is not quantity-based.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation or code indicating why this discount was reversed or removed from the order. Nullable if discount was not reversed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'The date and time when this discount was reversed or removed. Nullable if discount was not reversed.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Indicates whether this discount is applied before tax calculation (pre-tax), after tax calculation (post-tax), or if the discounted amount is tax-exempt.' ;
    rdfs:domain ind:OrderDiscount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Order Payment Id' ;
    rdfs:comment 'Unique identifier for the payment tender record. Primary key.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'Foreign key linking to payment.authorization. Business justification: Grocery order payments must link to the authorization record for chargeback response, settlement reconciliation, and dispute resolution. The plain-text \'authorization_code\' and \'authorization_timestam' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:giftCardId rdf:type rdf:Property ;
    rdfs:label 'Gift Card Id' ;
    rdfs:comment 'Foreign key linking to payment.gift_card. Business justification: When a grocery order is paid with a gift card, the order_payment record must link to the specific gift card for balance management, fraud detection, and state escheatment law compliance. Plain-text \'g' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Response code returned by the Address Verification Service (AVS) indicating the match result between billing address provided and address on file with card issuer. Used for fraud detection and risk management.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four Digits' ;
    rdfs:comment 'Last four digits of the bank account number from the check. Applicable only when tender_type is check. Stored for reference while maintaining compliance with financial data protection standards.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Nine-digit American Bankers Association (ABA) routing number from the check. Applicable only when tender_type is check. Used for electronic check verification and processing.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Card Last Four Digits' ;
    rdfs:comment 'Last four digits of the payment card number. Used for customer reference and dispute resolution while maintaining Payment Card Industry Data Security Standard (PCI DSS) compliance by not storing full card number.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Card network brand for credit and debit card tenders. Applicable only when tender_type is credit_card or debit_card.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card. Used for fraud detection and dispute resolution. Applicable to credit and debit card tenders.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeGivenAmount rdf:type rdf:Property ;
    rdfs:label 'Change Given Amount' ;
    rdfs:comment 'Amount of change returned to the customer when payment_amount exceeds the order balance. Applicable primarily to cash tenders. Null for non-cash tenders or when exact payment is tendered.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Check number from the paper check tendered. Applicable only when tender_type is check. Used for reconciliation and fraud detection.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Response Code' ;
    rdfs:comment 'Response code indicating whether the Card Verification Value (CVV) provided matched the value on file with the card issuer. Used for fraud detection. Applicable to card-not-present transactions.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Code returned by the payment processor indicating why the payment was declined. Examples include insufficient_funds, invalid_card, expired_card, fraud_suspected. Applicable when settlement_status is declined.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebtBalanceRemaining rdf:type rdf:Property ;
    rdfs:label 'Ebt Balance Remaining' ;
    rdfs:comment 'Remaining balance on the Electronic Benefits Transfer (EBT) card after this transaction. Applicable only when tender_type is ebt_snap. Supports customer service inquiries and Supplemental Nutrition Assistance Program (SNAP) regulatory reporting requirements.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRewardDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Reward Discount Amount' ;
    rdfs:comment 'Monetary value of fuel reward points applied as discount. Applicable only when tender_type is fuel_reward.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRewardPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Fuel Reward Points Redeemed' ;
    rdfs:comment 'Number of fuel reward loyalty points redeemed as payment toward this order. Applicable only when tender_type is fuel_reward. Supports fuel center operations and loyalty program reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileWalletType rdf:type rdf:Property ;
    rdfs:label 'Mobile Wallet Type' ;
    rdfs:comment 'Type of mobile wallet used for payment. Applicable only when tender_type is mobile_wallet.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Monetary amount applied from this payment tender toward the order total. For split-tender transactions, this represents the portion paid by this specific instrument. Expressed in the transaction currency.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Channel or interface through which the payment was captured. Point of Sale (POS) for in-store register transactions; ecommerce for web storefront; mobile_app for native app checkout; kiosk for self-service terminals; phone for call center orders; curbside_terminal for pickup payment devices.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentGateway rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway' ;
    rdfs:comment 'Name or identifier of the payment gateway or processor that handled this transaction. Examples include First Data, Worldpay, Stripe, or internal processor identifiers.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorReference rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the external payment processor or gateway. Used for reconciliation, dispute resolution, and cross-system traceability.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Sequence Number' ;
    rdfs:comment 'Sequential number of this payment tender within the order. Supports split-tender transactions where multiple payment instruments are applied to a single order.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Code indicating the reason for refund when settlement_status is refunded. Examples include customer_request, damaged_goods, pricing_error, order_cancellation. Used for refund analytics and fraud detection.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed. Applicable only when settlement_status is refunded.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:snapEligibleAmount rdf:type rdf:Property ;
    rdfs:label 'Snap Eligible Amount' ;
    rdfs:comment 'Portion of the order total that qualifies for Supplemental Nutrition Assistance Program (SNAP) Electronic Benefits Transfer (EBT) payment. Applicable when tender_type is ebt_snap. Required for SNAP regulatory reporting and compliance audits.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tokenizedPaymentInstrument rdf:type rdf:Property ;
    rdfs:label 'Tokenized Payment Instrument' ;
    rdfs:comment 'Payment Card Industry Data Security Standard (PCI DSS) compliant token representing the payment instrument. Used for recurring payments and stored payment methods without retaining sensitive card data.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wicEligibleAmount rdf:type rdf:Property ;
    rdfs:label 'Wic Eligible Amount' ;
    rdfs:comment 'Portion of the order total that qualifies for Women Infants and Children (WIC) program payment. Applicable when tender_type is wic. Required for WIC program reporting.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wicVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Wic Voucher Number' ;
    rdfs:comment 'Unique voucher or authorization number for Women Infants and Children (WIC) program payment. Applicable only when tender_type is wic. Required for WIC program reconciliation and state reporting.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderRefundId rdf:type rdf:Property ;
    rdfs:label 'Order Refund Id' ;
    rdfs:comment 'Unique identifier for the refund transaction record. Primary key for the order_refund product.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chargebackId rdf:type rdf:Property ;
    rdfs:label 'Chargeback Id' ;
    rdfs:comment 'Foreign key linking to payment.chargeback. Business justification: In grocery retail, chargebacks frequently trigger refund issuance. Linking order_refund to the originating chargeback record enables chargeback-driven refund tracking, financial impact reporting, and ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Chargeback .

ind:primaryOrderPaymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Payment Transaction Id' ;
    rdfs:comment 'External payment processor transaction identifier from the original order. Used to link refund back to original payment for reconciliation and chargeback prevention.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:refundGiftCardId rdf:type rdf:Property ;
    rdfs:label 'Refund Gift Card Id' ;
    rdfs:comment 'Foreign key linking to payment.gift_card. Business justification: When grocery refunds are issued as store credit/gift cards, the order_refund must link to the specific gift card issued for balance tracking, fraud prevention, and state escheatment law compliance. Ro' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftCard .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Foreign key linking to payment.refund. Business justification: Grocery refund operations require linking the business-level order_refund (customer reason, policy exception, loyalty reversal) to the payment-level refund record (processor transaction, settlement) f' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:refundTenderTypeId rdf:type rdf:Property ;
    rdfs:label 'Refund Tender Type Id' ;
    rdfs:comment 'Foreign key linking to payment.tender_type. Business justification: Grocery refund policy mandates tender-type-specific rules: EBT refunds must return to EBT, gift card refunds to store credit. Linking order_refund to tender_type via role-prefixed \'refund_tender_type_' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TenderType .

ind:refundedProductOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Refunded Product Order Line Id' ;
    rdfs:comment 'Foreign key linking to product.product_order_line. Business justification: A refund/return is typically tied to a specific order line item (the SKU being returned). order_refund already has order_header_id for the header-level link, but lacks a line-level reference. Adding r' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductOrderLine .

ind:rxClaimId rdf:type rdf:Property ;
    rdfs:label 'Rx Claim Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.rx_claim. Business justification: When a pharmacy order is refunded, the associated rx_claim must be reversed for PBM/insurance adjudication. CMS and PBM contracts require claim reversals to match refund records within the reversal wi' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RxClaim .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Optional post-refund satisfaction rating provided by customer, typically on a scale of 1-5. Used to measure refund experience quality. Null if not collected.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Free-text explanation for why the refund request was denied. Null if refund was approved. Used for customer communication and policy compliance.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Level' ;
    rdfs:comment 'Authorization level required to approve this refund if it was a policy exception. Null if no exception was needed.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numerical fraud risk score assigned by fraud detection system, typically 0-100 where higher values indicate greater fraud likelihood. Null if fraud scoring not applied.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryDisposition rdf:type rdf:Property ;
    rdfs:label 'Inventory Disposition' ;
    rdfs:comment 'Action taken with the returned inventory. Restock returns item to sellable inventory, damage_out records shrink, donate sends to charity, dispose discards, vendor_return sends back to supplier.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'Boolean indicator whether this refund was flagged as potentially fraudulent by fraud detection systems or manual review. Used for loss prevention analysis.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsReversed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Reversed' ;
    rdfs:comment 'Number of loyalty program points deducted from customer account due to this refund. Zero if no loyalty points were earned on original purchase or if points not reversed.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Policy Exception Flag' ;
    rdfs:comment 'Boolean indicator whether this refund required an exception to standard return policy (e.g., outside return window, no receipt, final sale item). Requires manager approval.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Original receipt number provided by customer to validate the purchase. Used for no-receipt return policy enforcement and fraud prevention.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total monetary value being refunded to the customer, including product cost and applicable taxes. Expressed in the transaction currency.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Approved Timestamp' ;
    rdfs:comment 'Date and time when the refund was approved by an authorized associate or automated system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundChannel rdf:type rdf:Property ;
    rdfs:label 'Refund Channel' ;
    rdfs:comment 'Business channel through which the refund was initiated. POS = Point of Sale for in-store refunds.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDeniedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Denied Timestamp' ;
    rdfs:comment 'Date and time when the refund request was denied. Null if refund was approved. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundNotes rdf:type rdf:Property ;
    rdfs:label 'Refund Notes' ;
    rdfs:comment 'Free-text notes captured by the associate processing the refund. May include additional context, customer comments, or special handling instructions.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund payment was successfully processed and funds were returned to the customer. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundRequestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Requested Timestamp' ;
    rdfs:comment 'Date and time when the customer initiated the refund request. Represents the start of the refund lifecycle. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle state of the refund transaction. Tracks progression from initial request through final settlement or denial.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundSubtotal rdf:type rdf:Property ;
    rdfs:label 'Refund Subtotal' ;
    rdfs:comment 'Refund amount before taxes. Represents the product cost portion of the refund.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Tax Amount' ;
    rdfs:comment 'Portion of the refund amount representing sales tax or other applicable taxes being returned to the customer.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund scope. Full refund returns entire order value, partial refund returns a portion of order value, line-level refund returns specific line items only.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Fee charged to customer for processing the return, if applicable per store policy. Deducted from the refund amount. Zero if no restocking fee applies.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of shipping the returned items back to the retailer for online/delivery orders. May be absorbed by retailer or charged to customer depending on policy.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days between original order date and refund request date. Used to enforce return policy time limits and analyze return patterns.' ;
    rdfs:domain ind:OrderRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shrinkFlag rdf:type rdf:Property ;
    rdfs:label 'Shrink Flag' ;
    rdfs:comment 'Boolean indicator whether this refund contributes to inventory shrink (loss from theft, spoilage, or damage). True if item cannot be restocked.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rxOrderId rdf:type rdf:Property ;
    rdfs:label 'Rx Order Id' ;
    rdfs:comment 'Unique identifier for the pharmacy prescription order record. Primary key representing the purchase-event view of an Rx fill within the order domain.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RxOrder .

ind:drugId rdf:type rdf:Property ;
    rdfs:label 'Drug Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.drug. Business justification: rx_order requires pharmacy.drug for insurance adjudication (AWP, WAC), formulary tier determination, REMS compliance, and DEA schedule verification at dispensing time. drug_item is the retail catalog ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drug .

ind:priorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.prior_authorization. Business justification: Controlled substances and specialty drugs require an approved prior authorization before dispensing. rx_order must reference pharmacy.prior_authorization to confirm PA status, approved quantity, and e' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:controlledSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Flag' ;
    rdfs:comment 'Indicates whether the medication is a controlled substance requiring DEA reporting and special handling.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Patient copayment amount in USD for this prescription fill after insurance adjudication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'Number of days the dispensed medication is intended to last based on prescribed dosing instructions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deaSchedule rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule' ;
    rdfs:comment 'DEA classification schedule for controlled substances (II through V). Non-controlled medications are marked as Non_Controlled.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispensed Timestamp' ;
    rdfs:comment 'Date and time the prescription was picked up or delivered to the patient.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispensingFee rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee' ;
    rdfs:comment 'Professional fee charged by the pharmacy for dispensing services in USD.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillNumber rdf:type rdf:Property ;
    rdfs:label 'Fill Number' ;
    rdfs:comment 'Sequential number indicating which fill this is for the prescription (1 for initial fill, 2+ for refills).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillStatus rdf:type rdf:Property ;
    rdfs:label 'Fill Status' ;
    rdfs:comment 'Current status of the prescription fill in the pharmacy workflow: received, in clinical verification, ready for patient pickup, dispensed to patient, on hold, cancelled, or returned. [ENUM-REF-CANDIDATE: received|in_verification|ready_for_pickup|dispensed|on_hold|cancelled|returned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fill Timestamp' ;
    rdfs:comment 'Date and time the prescription was filled and verified by the pharmacist.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fillType rdf:type rdf:Property ;
    rdfs:label 'Fill Type' ;
    rdfs:comment 'Classification of the prescription fill event: new prescription, refill of existing prescription, transfer from another pharmacy, transfer to another pharmacy, or partial fill.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Paid Amount' ;
    rdfs:comment 'Amount paid by insurance in USD for this prescription fill after adjudication.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mckessonRxSystemRef rdf:type rdf:Property ;
    rdfs:label 'Mckesson Rx System Ref' ;
    rdfs:comment 'Source system identifier from McKesson Pharmacy Systems for this prescription order record.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Prescription Expiration Date' ;
    rdfs:comment 'Date after which the prescription is no longer valid for filling or refilling.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prescriptionReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Prescription Received Timestamp' ;
    rdfs:comment 'Date and time the prescription was received by the pharmacy (electronically, by phone, or in person).' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:prescriptionWrittenDate rdf:type rdf:Property ;
    rdfs:label 'Prescription Written Date' ;
    rdfs:comment 'Date the prescription was originally written by the prescriber.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Number of units of medication dispensed to the patient (e.g., number of tablets, milliliters of liquid).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refillsRemaining rdf:type rdf:Property ;
    rdfs:label 'Refills Remaining' ;
    rdfs:comment 'Number of authorized refills remaining on the prescription after this fill.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sigCode rdf:type rdf:Property ;
    rdfs:label 'Sig Code' ;
    rdfs:comment 'Prescription directions for use (Sig) provided to the patient. Instructions on how to take the medication.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed Flag' ;
    rdfs:comment 'Indicates whether generic substitution was permitted by the prescriber for this prescription.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Occurred Flag' ;
    rdfs:comment 'Indicates whether a generic substitution was actually made when filling this prescription.' ;
    rdfs:domain ind:RxOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Total price charged for the prescription fill in USD before insurance coverage.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderSubstitutionId rdf:type rdf:Property ;
    rdfs:label 'Order Substitution Id' ;
    rdfs:comment 'Unique identifier for the order substitution record. Primary key.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substituteProductItemId rdf:type rdf:Property ;
    rdfs:label 'Substitute Product Item Id' ;
    rdfs:comment 'Foreign key linking to product.product_item. Business justification: order_substitution captures the substitute item via substitute_sku (string) and substitute_product_name (string). Adding substitute_product_item_id normalizes the substitute item reference to the prod' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductItem .

ind:substituteSkuId rdf:type rdf:Property ;
    rdfs:label 'Substitute Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: order_substitution stores substitute_sku and substitute_gtin as denormalized strings. Adding substitute_sku_id as a FK to the sku table normalizes the substitute item\'s SKU reference, enabling proper ' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:waveId rdf:type rdf:Property ;
    rdfs:label 'Wave Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.wave. Business justification: Substitutions occur during picking waves. Linking order_substitution to the wave enables wave-level substitution rate analysis — a key fulfillment quality KPI in grocery operations. Wave managers use ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wave .

ind:brandMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item is from the same brand as the original item.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Category Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item is from the same product category as the original item, supporting substitution quality analysis.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Status' ;
    rdfs:comment 'The customers response to the substitution offer. ACCEPTED=Customer explicitly accepted, REJECTED=Customer declined substitute, PENDING=Awaiting customer response, AUTO_ACCEPTED=Accepted per customer preferences, NOT_REQUIRED=No acceptance needed per business rules.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedbackComments rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Comments' ;
    rdfs:comment 'Free-text comments provided by the customer regarding the substitution experience.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'The channel used to notify the customer about the substitution. APP=Mobile app notification, SMS=Text message, EMAIL=Email notification, PHONE=Phone call, NONE=No notification sent.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'The date and time when the customer was notified about the substitution. Null if no notification was sent.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Response Timestamp' ;
    rdfs:comment 'The date and time when the customer provided their acceptance or rejection response. Null if no response received or not required.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer-provided rating (1-5 scale) of their satisfaction with the substitution. Null if customer has not provided feedback.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorySnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Snapshot Timestamp' ;
    rdfs:comment 'The timestamp when inventory levels were checked for the original item, capturing the point-in-time inventory state that led to the OOS condition.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalGtin rdf:type rdf:Property ;
    rdfs:label 'Original Gtin' ;
    rdfs:comment 'The GTIN (UPC/EAN) of the originally ordered product that was unavailable. Supports 8, 12, 13, or 14 digit formats.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalItemStockLevel rdf:type rdf:Property ;
    rdfs:label 'Original Item Stock Level' ;
    rdfs:comment 'The on-hand inventory quantity of the original item at the fulfillment location at the time of substitution decision.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalProductName rdf:type rdf:Property ;
    rdfs:label 'Original Product Name' ;
    rdfs:comment 'The display name of the originally ordered product for customer communication and reporting.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Quantity' ;
    rdfs:comment 'The quantity of the original item that was ordered before substitution.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Original Unit Price' ;
    rdfs:comment 'The unit price of the originally ordered item at the time of order placement.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Difference Amount' ;
    rdfs:comment 'The monetary difference between the original item and substitute item (substitute price minus original price). Negative values indicate customer savings, positive values indicate upcharge.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceProtectionAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Price Protection Applied Flag' ;
    rdfs:comment 'Indicates whether price protection was applied to ensure the customer was not charged more than the original item price, even if the substitute was more expensive.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Issued Flag' ;
    rdfs:comment 'Indicates whether a refund was issued to the customer due to substitution rejection or price difference.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sizeMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Size Match Flag' ;
    rdfs:comment 'Indicates whether the substitute item has the same or comparable size/quantity as the original item.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substituteItemStockLevel rdf:type rdf:Property ;
    rdfs:label 'Substitute Item Stock Level' ;
    rdfs:comment 'The on-hand inventory quantity of the substitute item at the fulfillment location at the time of substitution.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substituteQuantity rdf:type rdf:Property ;
    rdfs:label 'Substitute Quantity' ;
    rdfs:comment 'The quantity of the substitute item provided to fulfill the order.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substituteUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Substitute Unit Price' ;
    rdfs:comment 'The unit price of the substitute item at the time of substitution.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Approval Required Flag' ;
    rdfs:comment 'Indicates whether customer approval was required before proceeding with the substitution based on business rules and customer preferences.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionNumber rdf:type rdf:Property ;
    rdfs:label 'Substitution Number' ;
    rdfs:comment 'Business-facing identifier for the substitution event, used for customer service and tracking purposes.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionQualityScore rdf:type rdf:Property ;
    rdfs:label 'Substitution Quality Score' ;
    rdfs:comment 'A system-calculated score (0.00 to 5.00) representing the quality of the substitution match based on product attributes, category similarity, and customer preferences.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:substitutionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason Code' ;
    rdfs:comment 'The primary reason the original item required substitution. OOS=Out of Stock, DAMAGED=Product damaged, RECALLED=Product recalled, EXPIRED=Product expired or near expiration, QUALITY=Quality issue identified, DISCONTINUED=Product discontinued.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Substitution Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the substitution was necessary, providing additional context beyond the reason code.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Substitution Timestamp' ;
    rdfs:comment 'The date and time when the substitution decision was made and recorded in the system.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substitutionType rdf:type rdf:Property ;
    rdfs:label 'Substitution Type' ;
    rdfs:comment 'The method by which the substitution was determined. AUTO_SYSTEM=Automatically selected by system algorithm, PICKER_SELECTED=Chosen by store associate or picker during fulfillment, CUSTOMER_PREAPPROVED=Customer pre-authorized substitutions in preferences, CUSTOMER_REQUESTED=Customer specifically requested this substitute.' ;
    rdfs:domain ind:OrderSubstitution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category in the hierarchy. Null for top-level departments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:averageShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Average Shelf Life Days' ;
    rdfs:comment 'Average shelf life in days for products in this category. Used for inventory planning and shrink management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Business identifier code for the category used across systems and reporting. Typically alphanumeric code assigned by merchandising team.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the category scope, including product types, brands, and assortment guidelines.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full business name of the merchandise category (e.g., Yogurt, Fresh Produce, Bakery).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryStatus rdf:type rdf:Property ;
    rdfs:label 'Category Status' ;
    rdfs:comment 'Current lifecycle status of the category. Active categories are available for assortment planning and SKU assignment.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification of the category node type within the merchandise hierarchy.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dsd Eligible Flag' ;
    rdfs:comment 'Indicates whether this category is eligible for direct store delivery from vendors, bypassing the distribution center.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endcapEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Endcap Eligible Flag' ;
    rdfs:comment 'Indicates whether products in this category are eligible for end-of-aisle endcap promotional displays.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmroiTarget rdf:type rdf:Property ;
    rdfs:label 'Gmroi Target' ;
    rdfs:comment 'Target GMROI ratio for this category. Measures gross margin dollars returned for every dollar invested in inventory. Used for category performance evaluation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Required Flag' ;
    rdfs:comment 'Indicates whether this category requires HACCP food safety protocols for handling and storage.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full path from root to this category (e.g., Grocery > Dairy > Yogurt). Used for navigation and rollup reporting.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localizedAssortmentFlag rdf:type rdf:Property ;
    rdfs:label 'Localized Assortment Flag' ;
    rdfs:comment 'Indicates whether this category supports localized assortment variations by store cluster based on demographics and regional preferences.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markdownStrategy rdf:type rdf:Property ;
    rdfs:label 'Markdown Strategy' ;
    rdfs:comment 'Pricing markdown strategy for clearance and slow-moving items in this category.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFacings rdf:type rdf:Property ;
    rdfs:label 'Minimum Facings' ;
    rdfs:comment 'Minimum number of product facings (front-facing units on shelf) required for this category to maintain visual merchandising standards.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Organic Certified Flag' ;
    rdfs:comment 'Indicates whether this category requires USDA organic certification for included products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planogramRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Planogram Required Flag' ;
    rdfs:comment 'Indicates whether this category requires formal planogram execution for visual merchandising and space allocation.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'Primary replenishment method for this category: CAO (Computer-Assisted Ordering), manual ordering, vendor-managed inventory, or cross-dock.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Flag' ;
    rdfs:comment 'Indicates whether this category has seasonal assortment variations (e.g., holiday baking, summer grilling, back-to-school).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shrinkRatePercent rdf:type rdf:Property ;
    rdfs:label 'Shrink Rate Percent' ;
    rdfs:comment 'Expected inventory shrink rate percentage for this category due to theft, spoilage, or damage. Used for financial planning and loss prevention.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceAllocationSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Square Feet' ;
    rdfs:comment 'Standard space allocation norm for this category in square feet. Used for planogram planning and store layout design.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planogramId rdf:type rdf:Property ;
    rdfs:label 'Planogram Id' ;
    rdfs:comment 'Unique identifier for the planogram. Primary key for the planogram data product.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Planogram .

ind:primaryPlanogramCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Planogram Category Id' ;
    rdfs:comment 'Reference to the merchandise category this planogram represents. Links to the product category hierarchy for assortment planning and category management.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:complianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Required Flag' ;
    rdfs:comment 'Indicates whether strict compliance to this planogram is mandatory. True for corporate-mandated sets, false for suggested guidelines. Drives store execution accountability.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Compliance Tolerance Pct' ;
    rdfs:comment 'Acceptable variance percentage from the planogram specification before a store is considered non-compliant. Used for compliance scoring and audit thresholds.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeeklySalesAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Weekly Sales Amount' ;
    rdfs:comment 'Projected weekly sales revenue in dollars for all SKUs (Stock Keeping Units) in this planogram. Supports space-to-sales ratio analysis and fixture ROI evaluation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeeklySalesUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Weekly Sales Units' ;
    rdfs:comment 'Projected weekly sales volume in units for all SKUs (Stock Keeping Units) in this planogram. Used for space productivity forecasting and GMROI (Gross Margin Return on Investment) analysis.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixtureDepthInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Depth Inches' ;
    rdfs:comment 'Total depth of the fixture in inches. Constrains product depth and facing orientation for shelf placement.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureHeightInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Height Inches' ;
    rdfs:comment 'Total height of the fixture in inches. Determines vertical space available for product placement and shelf allocation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixtureType rdf:type rdf:Property ;
    rdfs:label 'Fixture Type' ;
    rdfs:comment 'Type of physical store fixture or display unit this planogram is designed for. Gondola for standard aisle shelving units, cooler for refrigerated cases, freezer for frozen food cases, pallet for floor stacks, display rack for specialty merchandisers, pegboard for hanging items, shelf for general shelving. [ENUM-REF-CANDIDATE: gondola|endcap|cooler|freezer|pallet|display_rack|pegboard|shelf — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureWidthInches rdf:type rdf:Property ;
    rdfs:label 'Fixture Width Inches' ;
    rdfs:comment 'Total width of the fixture in inches. Critical dimension for space planning and ensuring planogram fits physical store layout.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL (Uniform Resource Locator) or file path to the visual rendering or photograph of the planogram. Provides reference image for store teams during reset execution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutOrientation rdf:type rdf:Property ;
    rdfs:label 'Layout Orientation' ;
    rdfs:comment 'Primary orientation of product placement within the planogram. Horizontal for side-by-side shelf arrangements, vertical for top-to-bottom brand blocking, mixed for combination layouts.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingStrategy rdf:type rdf:Property ;
    rdfs:label 'Merchandising Strategy' ;
    rdfs:comment 'Primary merchandising strategy applied in this planogram. Brand blocking groups products by manufacturer, price point arranges by cost tiers, size progression orders by package size, color blocking groups by visual appeal, cross merchandising combines complementary categories.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramName rdf:type rdf:Property ;
    rdfs:label 'Planogram Name' ;
    rdfs:comment 'Human-readable name or title of the planogram, typically describing the category, fixture, or section it represents (e.g., \'Cereal Aisle Endcap Q1 2024\').' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramNumber rdf:type rdf:Property ;
    rdfs:label 'Planogram Number' ;
    rdfs:comment 'Business identifier for the planogram, typically used in space planning systems and store communications. Externally-known unique code for this visual merchandise display plan.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramStatus rdf:type rdf:Property ;
    rdfs:label 'Planogram Status' ;
    rdfs:comment 'Current lifecycle status of the planogram. Draft indicates work-in-progress, approved indicates ready for deployment, active indicates currently in use in stores, inactive indicates temporarily suspended, archived indicates historical record.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramType rdf:type rdf:Property ;
    rdfs:label 'Planogram Type' ;
    rdfs:comment 'Classification of the planogram by merchandising purpose. Standard for regular shelf sets, promotional for temporary displays, seasonal for holiday or seasonal merchandise, endcap for end-of-aisle displays, power aisle for high-traffic promotional zones, checkout for point-of-sale impulse areas.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelFacingPct rdf:type rdf:Property ;
    rdfs:label 'Private Label Facing Pct' ;
    rdfs:comment 'Percentage of total facings allocated to private label or store-owned brand products. Key metric for private label penetration and margin optimization strategy.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spacePlanningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Space Planning System Code' ;
    rdfs:comment 'Identifier or code from the source space planning system (e.g., Blue Yonder, JDA, Oracle Retail) where this planogram was designed. Supports system integration and data lineage.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Units' ;
    rdfs:comment 'Total product capacity of the fixture in units, summing all SKU (Stock Keeping Unit) positions and depths. Represents maximum inventory that can be displayed on the fixture at full stock.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacingCount rdf:type rdf:Property ;
    rdfs:label 'Total Facing Count' ;
    rdfs:comment 'Total number of product facings (product fronts visible to shoppers) across all shelves in this planogram. Key metric for space productivity and SKU (Stock Keeping Unit) representation.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalShelfCount rdf:type rdf:Property ;
    rdfs:label 'Total Shelf Count' ;
    rdfs:comment 'Total number of shelves or levels within the fixture. Used for vertical space allocation and capacity planning.' ;
    rdfs:domain ind:Planogram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total number of unique SKUs (Stock Keeping Units) included in this planogram. Measures assortment breadth and variety for the fixture.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Unique identifier for the merchandise assortment plan. Primary key for the assortment plan entity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:actualSkuCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sku Count' ;
    rdfs:comment 'Actual number of unique SKUs approved and included in the final assortment plan after merchandise planning review.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assortmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Strategy' ;
    rdfs:comment 'Strategic approach for this assortment plan: broad (wide variety), focused (narrow depth), premium (high-end), value (price-focused), seasonal (time-limited), or promotional (event-driven).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Plan Amount' ;
    rdfs:comment 'Planned cost of goods sold (COGS) for this assortment plan during the planning period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuedItemCount rdf:type rdf:Property ;
    rdfs:label 'Discontinued Item Count' ;
    rdfs:comment 'Number of SKUs being discontinued or removed from the assortment compared to the previous planning period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryInvestmentPlan rdf:type rdf:Property ;
    rdfs:label 'Inventory Investment Plan' ;
    rdfs:comment 'Planned average inventory investment at cost required to support this assortment plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localizationLevel rdf:type rdf:Property ;
    rdfs:label 'Localization Level' ;
    rdfs:comment 'Geographic granularity of this assortment plan: national (all stores), regional (multi-state), cluster (store groups), or store (individual location).' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Margin Plan Amount' ;
    rdfs:comment 'Planned gross margin (sales minus cost) for this assortment plan during the planning period.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPlanPercent rdf:type rdf:Property ;
    rdfs:label 'Margin Plan Percent' ;
    rdfs:comment 'Planned gross margin percentage (margin divided by sales) target for this assortment plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newItemCount rdf:type rdf:Property ;
    rdfs:label 'New Item Count' ;
    rdfs:comment 'Number of new SKUs being introduced in this assortment plan that were not in the previous period\'s assortment.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Unique business identifier code for the assortment plan used for external reference and reporting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Business-friendly name for the assortment plan, typically including category and season identifiers (e.g., \'Spring 2024 Fresh Produce Assortment\').' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the assortment plan: draft (being created), in_review (under merchandise planning review), approved (ready for execution), active (currently in effect), completed (planning period ended), or cancelled (plan abandoned).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Type of planning horizon for this assortment plan (season, quarter, year, promotional event, or ad circular cycle).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningSeason rdf:type rdf:Property ;
    rdfs:label 'Planning Season' ;
    rdfs:comment 'Season identifier for seasonal assortment plans (e.g., \'Spring 2024\', \'Holiday 2024\', \'Back to School 2024\').' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelSalesPlanPercent rdf:type rdf:Property ;
    rdfs:label 'Private Label Sales Plan Percent' ;
    rdfs:comment 'Target percentage of total sales plan that should come from private label products in this assortment.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:privateLabelSkuCount rdf:type rdf:Property ;
    rdfs:label 'Private Label Sku Count' ;
    rdfs:comment 'Number of private label (store-owned brand) SKUs included in this assortment plan. Used for private label penetration tracking.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesPlanAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Plan Amount' ;
    rdfs:comment 'Planned sales revenue target for this assortment plan during the planning period. Used for financial planning and GMROI (Gross Margin Return on Investment) calculation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceAllocationLinearFeet rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Linear Feet' ;
    rdfs:comment 'Total shelf space allocated to this assortment plan measured in linear feet. Used for planogram execution and space productivity analysis.' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSkuCount rdf:type rdf:Property ;
    rdfs:label 'Target Sku Count' ;
    rdfs:comment 'Planned number of unique SKUs (Stock Keeping Units) to be carried in this assortment plan. Used for SKU rationalization and space planning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFacings rdf:type rdf:Property ;
    rdfs:label 'Total Facings' ;
    rdfs:comment 'Total number of product facings (product fronts visible on shelf) allocated across all SKUs in this assortment plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnRateTarget rdf:type rdf:Property ;
    rdfs:label 'Turn Rate Target' ;
    rdfs:comment 'Target inventory turn rate (number of times inventory is sold and replaced during the planning period) for this assortment plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assortmentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Assortment Category Id' ;
    rdfs:comment 'Reference to the merchandise subcategory for finer-grained assortment segmentation. Enables detailed space allocation and assortment breadth analysis within categories.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:primaryAssortmentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Assortment Category Id' ;
    rdfs:comment 'Reference to the merchandise category this item belongs to. Links assortment decisions to category management strategies and category captain collaboration.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:vendorItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor_item. Business justification: An authorized assortment item must link to the vendor_item record to enable replenishment order generation, cost-based margin reporting, and vendor compliance checks. Category managers and replenishme' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorItem .

ind:assortmentTier rdf:type rdf:Property ;
    rdfs:label 'Assortment Tier' ;
    rdfs:comment 'Strategic importance tier of this SKU within the assortment. Defines priority for space allocation, inventory investment, and promotional support.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Inclusion Status' ;
    rdfs:comment 'Current lifecycle status of this SKU within the assortment plan. Indicates whether the item is actively carried, newly introduced, discontinued, or represents a localized override decision. [ENUM-REF-CANDIDATE: active|discontinued|new|localized_add|localized_remove|pending|seasonal_inactive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when this SKU was first introduced into the assortment. Enables new item maturity analysis and time-to-productivity measurement.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this assortment item was last reviewed for performance and continued inclusion. Supports ongoing assortment optimization and ensures regular evaluation cycles.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localizationSource rdf:type rdf:Property ;
    rdfs:label 'Localization Source' ;
    rdfs:comment 'Primary driver for localized assortment decision. Identifies the business factor that triggered inclusion or exclusion of this SKU at the local level. [ENUM-REF-CANDIDATE: demographic_demand|local_supplier|store_format|competitive_response|customer_request|test_market|ethnic_community — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingRole rdf:type rdf:Property ;
    rdfs:label 'Merchandising Role' ;
    rdfs:comment 'Strategic role this SKU plays in the assortment. Defines whether the item is a core year-round offering, seasonal rotation, localized for demographic demand, ethnic specialty, private-label brand, promotional driver, or test item. [ENUM-REF-CANDIDATE: core|seasonal|local|ethnic|private_label|promotional|test — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newItemFlag rdf:type rdf:Property ;
    rdfs:label 'New Item Flag' ;
    rdfs:comment 'Indicates whether this is a new item introduction within the current planning cycle. Supports new item performance tracking and innovation pipeline management.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this assortment item represents a localized override to the standard cluster plan. True when a store or sub-cluster has deviated from the base assortment strategy.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Business rationale for localized assortment override. Captures the reason for deviation from standard plan such as demographic demand, competitive response, local supplier availability, or store format requirements.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationalizationCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Rationalization Candidate Flag' ;
    rdfs:comment 'Indicates whether this SKU has been identified as a candidate for removal during SKU rationalization analysis. Flags underperforming items for review and potential discontinuation.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rationalizationReason rdf:type rdf:Property ;
    rdfs:label 'Rationalization Reason' ;
    rdfs:comment 'Primary reason this SKU is flagged for rationalization. Captures the business driver for potential discontinuation such as poor sales velocity, margin erosion, or assortment duplication. [ENUM-REF-CANDIDATE: low_sales|low_margin|duplication|supplier_exit|quality_issues|regulatory|space_optimization — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedFacings rdf:type rdf:Property ;
    rdfs:label 'Recommended Facings' ;
    rdfs:comment 'Optimal number of facings recommended by space planning algorithms based on sales velocity, margin, and shelf capacity. Guides planogram design and space allocation decisions.' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Seasonal period or event this SKU is associated with. Enables seasonal assortment transitions, promotional calendar alignment, and year-over-year seasonal performance comparison. [ENUM-REF-CANDIDATE: spring|summer|fall|winter|holiday|back_to_school|easter|fourth_of_july — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Assortment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfPositionCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Position Code' ;
    rdfs:comment 'Recommended shelf position or merchandising location for this SKU. Indicates optimal vertical and horizontal placement to maximize visibility, accessibility, and sales performance. [ENUM-REF-CANDIDATE: eye_level|reach_level|stoop_level|endcap|gondola_end|power_aisle|checkout — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssortmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal stock keeping unit identifier for the product included in this assortment. The unique item-level identifier used across merchandising, inventory, and POS systems.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assortmentDepthStrategy rdf:type rdf:Property ;
    rdfs:label 'Assortment Depth Strategy' ;
    rdfs:comment 'Strategic approach to SKU (Stock Keeping Unit) selection and variety within categories for this cluster. Narrow-deep offers fewer brands with more sizes/flavors; broad-shallow offers many brands with limited variety per brand.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageStoreSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Average Store Size Sqft' ;
    rdfs:comment 'Mean selling square footage of stores in this cluster. Used for space planning and planogram capacity estimation.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageWeeklySales rdf:type rdf:Property ;
    rdfs:label 'Average Weekly Sales' ;
    rdfs:comment 'Mean weekly sales volume across stores in this cluster. Used for volume-based assortment planning and inventory allocation. Business-sensitive financial metric.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateZone rdf:type rdf:Property ;
    rdfs:label 'Climate Zone' ;
    rdfs:comment 'Predominant climate classification for the cluster geography. Influences seasonal assortment planning for weather-dependent categories such as beverages, apparel, and outdoor products.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterCode rdf:type rdf:Property ;
    rdfs:label 'Cluster Code' ;
    rdfs:comment 'Business identifier code for the store cluster used in merchandising and planning systems. Externally visible identifier used in Oracle Retail and Blue Yonder systems.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Email' ;
    rdfs:comment 'Business email address of the cluster manager for operational communication and escalation. Business-confidential contact information.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterManagerName rdf:type rdf:Property ;
    rdfs:label 'Cluster Manager Name' ;
    rdfs:comment 'Name of the category manager or merchandising leader responsible for assortment strategy and performance for this cluster.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterName rdf:type rdf:Property ;
    rdfs:label 'Cluster Name' ;
    rdfs:comment 'Descriptive name of the store cluster for business user identification and reporting purposes.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterStatus rdf:type rdf:Property ;
    rdfs:label 'Cluster Status' ;
    rdfs:comment 'Current lifecycle status of the store cluster. Active clusters are in use for assortment planning, inactive clusters are temporarily disabled, pending clusters are under review, and archived clusters are historical.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterType rdf:type rdf:Property ;
    rdfs:label 'Cluster Type' ;
    rdfs:comment 'Classification of the clustering methodology used to group stores. Demographic clusters group by customer profile, volume clusters by sales tier, format clusters by store size/layout, geographic clusters by region, competitive clusters by market dynamics, and hybrid clusters use multiple factors.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusteringMethodology rdf:type rdf:Property ;
    rdfs:label 'Clustering Methodology' ;
    rdfs:comment 'Description of the analytical approach and business rules used to define cluster membership. May reference statistical models, business criteria, or hybrid approaches.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure in the markets served by this cluster. High-intensity clusters may require more aggressive promotional assortments and pricing strategies.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Date' ;
    rdfs:comment 'Date when the cluster definition and membership were last recalculated or reviewed. Used to track data freshness and trigger next refresh cycle.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberStoreCount rdf:type rdf:Property ;
    rdfs:label 'Member Store Count' ;
    rdfs:comment 'Total number of stores currently assigned to this cluster. Used for assortment scale planning and distribution allocation.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:methodologyVersion rdf:type rdf:Property ;
    rdfs:label 'Methodology Version' ;
    rdfs:comment 'Version identifier for the clustering algorithm or business rules applied. Enables tracking of methodology changes over time and impact analysis.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newItemIntroductionPriority rdf:type rdf:Property ;
    rdfs:label 'New Item Introduction Priority' ;
    rdfs:comment 'Sequencing priority for rolling out new SKUs (Stock Keeping Units) to stores in this cluster. First-wave clusters receive new items earliest; test-only clusters are used for market testing before broader rollout.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Date' ;
    rdfs:comment 'Planned date for the next cluster review and update cycle. Supports proactive planning and resource allocation for cluster maintenance.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Performance classification based on sales productivity, profitability, and strategic importance. Platinum and gold tiers receive priority for new item introductions and promotional support.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramTemplateSet rdf:type rdf:Property ;
    rdfs:label 'Planogram Template Set' ;
    rdfs:comment 'Reference to the collection of planogram (visual merchandise display plan) templates assigned to this cluster. Links cluster to specific shelf layout and facing strategies.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCategoryFocus rdf:type rdf:Property ;
    rdfs:label 'Primary Category Focus' ;
    rdfs:comment 'Dominant merchandise categories or departments emphasized in this cluster\'s assortment strategy, such as fresh produce, organic, ethnic foods, or premium selections.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDemographicProfile rdf:type rdf:Property ;
    rdfs:label 'Primary Demographic Profile' ;
    rdfs:comment 'Dominant customer demographic characteristics of stores in this cluster, such as income level, household composition, age distribution, or ethnicity mix. Used for targeted assortment selection.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelPenetrationTarget rdf:type rdf:Property ;
    rdfs:label 'Private Label Penetration Target' ;
    rdfs:comment 'Target percentage of sales from private-label (store-owned brand) products for this cluster. Used to guide assortment mix and shelf space allocation decisions.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalResetSchedule rdf:type rdf:Property ;
    rdfs:label 'Seasonal Reset Schedule' ;
    rdfs:comment 'Timing and frequency of major seasonal assortment resets and planogram changes for this cluster. Aligns with holiday periods, weather transitions, and promotional calendars.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuRationalizationScore rdf:type rdf:Property ;
    rdfs:label 'Sku Rationalization Score' ;
    rdfs:comment 'Metric indicating the degree of SKU optimization and elimination of low-performing items in this cluster. Higher scores indicate more streamlined, efficient assortments.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeFormatMix rdf:type rdf:Property ;
    rdfs:label 'Store Format Mix' ;
    rdfs:comment 'Distribution of store formats within the cluster, such as supermarket, hypermarket, convenience, or specialty formats. Informs format-specific assortment strategies.' ;
    rdfs:domain ind:StoreCluster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costScheduleId rdf:type rdf:Property ;
    rdfs:label 'Cost Schedule Id' ;
    rdfs:comment 'Foreign key linking to vendor.cost_schedule. Business justification: Before authorizing a new item into the assortment, buyers must confirm an approved cost schedule exists. This link enables margin validation during new item review by pulling unit_cost, allowances, an' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostSchedule .

ind:primaryNewCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary New Category Id' ;
    rdfs:comment 'Identifier of the merchandise category to which the new item belongs.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:tradeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Trade Agreement Id' ;
    rdfs:comment 'Foreign key linking to vendor.trade_agreement. Business justification: New item introductions are frequently governed by a trade agreement specifying slotting fees, promotional commitments, and exclusivity terms. Finance and category teams require this link to reconcile ' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAgreement .

ind:casePackQuantity rdf:type rdf:Property ;
    rdfs:label 'Case Pack Quantity' ;
    rdfs:comment 'Number of individual units contained in one case for distribution center handling.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'The wholesale cost per unit that the retailer will pay to the vendor for the new item.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAnnualSalesUnits rdf:type rdf:Property ;
    rdfs:label 'Expected Annual Sales Units' ;
    rdfs:comment 'Forecasted number of units expected to be sold annually for the new item, used for planning and performance tracking.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedGrossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Gross Margin Percent' ;
    rdfs:comment 'Projected gross margin percentage for the new item, calculated as (retail price - cost) / retail price * 100.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstReceiptDate rdf:type rdf:Property ;
    rdfs:label 'First Receipt Date' ;
    rdfs:comment 'Actual date when the first shipment of the new item was received at a store or distribution center.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstShipDate rdf:type rdf:Property ;
    rdfs:label 'First Ship Date' ;
    rdfs:comment 'Actual date when the first shipment of the new item was sent from the vendor or distribution center.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Initial Order Quantity' ;
    rdfs:comment 'The quantity of units ordered for the initial stocking of the new item across the distribution network.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:introductionStatus rdf:type rdf:Property ;
    rdfs:label 'Introduction Status' ;
    rdfs:comment 'Current lifecycle status of the new item introduction process from vendor submission through store activation. [ENUM-REF-CANDIDATE: submitted|under_review|approved|rejected|planogram_assigned|in_transit|received|active — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrganicCertified rdf:type rdf:Property ;
    rdfs:label 'Is Organic Certified' ;
    rdfs:comment 'Indicates whether the new item has USDA organic certification (True) or not (False).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivateLabel rdf:type rdf:Property ;
    rdfs:label 'Is Private Label' ;
    rdfs:comment 'Indicates whether the new item is a store-owned private label brand (True) or a national/CPG brand (False).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonal rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal' ;
    rdfs:comment 'Indicates whether the new item is a seasonal product (True) or a year-round item (False).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'The marketing name or product title of the new item being introduced.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFacings rdf:type rdf:Property ;
    rdfs:label 'Number Of Facings' ;
    rdfs:comment 'The number of product fronts allocated to the new item on the shelf for visibility and inventory capacity.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'The size or quantity of the item package (e.g., 16 oz, 500 ml, 12 count).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided when a new item introduction is rejected, including business rationale.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRefrigeration rdf:type rdf:Property ;
    rdfs:label 'Requires Refrigeration' ;
    rdfs:comment 'Indicates whether the new item requires cold chain temperature-controlled storage and handling (True) or not (False).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the category review process was completed and a decision was made on the new item.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the category review process began for the new item introduction.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Specific shelf location assigned to the new item within the planogram (e.g., aisle, shelf level, position).' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Slotting Fee Amount' ;
    rdfs:comment 'One-time fee paid by the vendor to secure shelf space and distribution for the new item.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the vendor submitted the new item introduction request to the retailer for review.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suggestedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Suggested Retail Price' ;
    rdfs:comment 'Vendor-recommended retail price for the new item at point of sale.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Target Launch Date' ;
    rdfs:comment 'Planned date when the new item should be available for sale in stores.' ;
    rdfs:domain ind:NewItemIntro ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit Universal Product Code assigned to the new item for point-of-sale scanning.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spaceAllocationId rdf:type rdf:Property ;
    rdfs:label 'Space Allocation Id' ;
    rdfs:comment 'Unique identifier for the space allocation record. Primary key.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixtureId rdf:type rdf:Property ;
    rdfs:label 'Fixture Id' ;
    rdfs:comment 'Foreign key linking to assortment.fixture. Business justification: Space allocation defines approved linear footage, shelf count, and display positions — all of which are physically assigned to a specific store fixture (gondola, endcap, cooler, etc.). Adding fixture_' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primarySpaceCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Space Category Id' ;
    rdfs:comment 'Identifier of the product category for which space is allocated. Links to the product category hierarchy.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'Aisle number within the store where the space allocation is located. Used for store navigation, planogram execution, and space mapping.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Business identifier code for the space allocation record. Used for external reference and reporting.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPriority rdf:type rdf:Property ;
    rdfs:label 'Allocation Priority' ;
    rdfs:comment 'Priority level of the space allocation. High-priority allocations receive preferential space and visibility (e.g., high-margin categories, promotional items). Used for space optimization and conflict resolution.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle status of the space allocation. Indicates whether the allocation is in planning, approved for execution, actively in use, temporarily suspended, expired, or cancelled.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bayNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Number' ;
    rdfs:comment 'Bay or section number within the aisle where the space allocation is located. Provides precise fixture location for planogram execution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endcapPosition rdf:type rdf:Property ;
    rdfs:label 'Endcap Position' ;
    rdfs:comment 'Physical position of the endcap display within the store. Endcaps are high-visibility promotional displays at the end of aisles. Position affects traffic flow and sales lift. [ENUM-REF-CANDIDATE: front_left|front_right|mid_left|mid_right|back_left|back_right|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facingCount rdf:type rdf:Property ;
    rdfs:label 'Facing Count' ;
    rdfs:comment 'Total number of product facings (product fronts visible on shelf) allocated to the category or sub-category. Determines SKU (Stock Keeping Unit) capacity and visual merchandising impact.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredSku rdf:type rdf:Property ;
    rdfs:label 'Featured Sku' ;
    rdfs:comment 'Primary SKU (Stock Keeping Unit) featured in the endcap or promotional display. Used for endcap rotation scheduling and promotional tie-in tracking.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gondolaSectionCount rdf:type rdf:Property ;
    rdfs:label 'Gondola Section Count' ;
    rdfs:comment 'Number of gondola sections (standard 4-foot shelving units) allocated to the category or sub-category. Used for planogram development and space planning.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linearFeetAllocated rdf:type rdf:Property ;
    rdfs:label 'Linear Feet Allocated' ;
    rdfs:comment 'Total linear footage allocated to the category or sub-category. Measured horizontally across shelves and fixtures. Key metric for space productivity analysis.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalTieInFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Tie In Flag' ;
    rdfs:comment 'Indicates whether the space allocation is tied to a specific promotional campaign or ad circular (weekly promotional flyer). True if promotional, false otherwise.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Name of the season for seasonal space allocations (e.g., Holiday 2024, Back-to-School 2024, Summer 2024). Applicable when seasonal_flag is true.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfCount rdf:type rdf:Property ;
    rdfs:label 'Shelf Count' ;
    rdfs:comment 'Number of shelves allocated to the category or sub-category within the fixture. Determines vertical space capacity.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfHeightInches rdf:type rdf:Property ;
    rdfs:label 'Shelf Height Inches' ;
    rdfs:comment 'Total vertical height in inches of the shelving allocated to the category or sub-category. Used for vertical space planning and fixture capacity calculation.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:squareFootageAllocated rdf:type rdf:Property ;
    rdfs:label 'Square Footage Allocated' ;
    rdfs:comment 'Total square footage allocated to the category or sub-category. Used for floor space planning and productivity measurement.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGmroiPerLinearFoot rdf:type rdf:Property ;
    rdfs:label 'Target Gmroi Per Linear Foot' ;
    rdfs:comment 'Target Gross Margin Return on Investment (GMROI) per linear foot for the space allocation. Used for category space productivity analysis and performance benchmarking. Measures profitability per unit of space.' ;
    rdfs:domain ind:SpaceAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Funded Flag' ;
    rdfs:comment 'Indicates whether the space allocation is funded by a vendor through slotting fees (vendor payment for shelf space) or promotional allowances. True if vendor-funded, false otherwise.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentPlanogramId rdf:type rdf:Property ;
    rdfs:label 'Current Planogram Id' ;
    rdfs:comment 'Identifier of the planogram (visual merchandise display plan) currently assigned to this fixture. Links logical merchandise plans to physical store infrastructure.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Planogram .

ind:adaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Flag' ;
    rdfs:comment 'Indicates whether the fixture meets ADA (Americans with Disabilities Act) accessibility requirements for height and reach ranges.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current physical condition of the fixture: excellent, good, fair, poor, needs repair, or out of service. Used for maintenance prioritization and capital planning.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the fixture was permanently removed from service or decommissioned.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Reason for decommissioning the fixture, such as end of life, store remodel, equipment failure, or format change.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyStarCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Energy Star Certified Flag' ;
    rdfs:comment 'Indicates whether the fixture (particularly refrigerated or frozen units) is Energy Star certified for energy efficiency.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireSafetyCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Safety Compliant Flag' ;
    rdfs:comment 'Indicates whether the fixture meets fire safety code requirements for materials and placement.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixtureCode rdf:type rdf:Property ;
    rdfs:label 'Fixture Code' ;
    rdfs:comment 'Business identifier or code assigned to the fixture for operational reference and planogram assignment.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureName rdf:type rdf:Property ;
    rdfs:label 'Fixture Name' ;
    rdfs:comment 'Descriptive name or label for the fixture, often used for store associate reference and planogram communication.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightInches rdf:type rdf:Property ;
    rdfs:label 'Height Inches' ;
    rdfs:comment 'Total height of the fixture in inches from floor to top shelf.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the fixture was installed in the store, used for asset lifecycle tracking and maintenance scheduling.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent maintenance or inspection performed on the fixture, particularly important for refrigerated and frozen units.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPlanogramResetDate rdf:type rdf:Property ;
    rdfs:label 'Last Planogram Reset Date' ;
    rdfs:comment 'Date when the fixture was last reset or re-merchandised according to a planogram.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or vendor who produced the fixture.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model number or SKU (Stock Keeping Unit) of the fixture, used for parts ordering and warranty management.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next maintenance or inspection of the fixture.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfShelves rdf:type rdf:Property ;
    rdfs:label 'Number Of Shelves' ;
    rdfs:comment 'Total count of shelves or levels available on the fixture for product placement.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational status of the fixture: active (in use), inactive (temporarily not in use), under maintenance, or decommissioned (permanently removed).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Planogram Compliance Status' ;
    rdfs:comment 'Indicates whether the fixture is currently set according to the assigned planogram: compliant, non-compliant, pending reset, or not applicable.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planogramEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Planogram Effective Date' ;
    rdfs:comment 'Date when the current planogram assignment became effective on this fixture.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseCost rdf:type rdf:Property ;
    rdfs:label 'Purchase Cost' ;
    rdfs:comment 'Original purchase cost of the fixture in USD (United States Dollars), used for capital asset tracking and depreciation calculations.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date when the fixture was purchased by the company.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refrigerantType rdf:type rdf:Property ;
    rdfs:label 'Refrigerant Type' ;
    rdfs:comment 'Type of refrigerant used in refrigerated or frozen fixtures, required for EPA (Environmental Protection Agency) compliance and environmental reporting.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfDepthInches rdf:type rdf:Property ;
    rdfs:label 'Shelf Depth Inches' ;
    rdfs:comment 'Depth of shelves in inches, determining the size of products that can be accommodated and the number of facings per SKU (Stock Keeping Unit).' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMaxFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Fahrenheit' ;
    rdfs:comment 'Maximum temperature in Fahrenheit that the fixture maintains, applicable to refrigerated and frozen fixtures for food safety compliance.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Fahrenheit' ;
    rdfs:comment 'Minimum temperature in Fahrenheit that the fixture maintains, applicable to refrigerated and frozen fixtures for food safety compliance.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLinearFeet rdf:type rdf:Property ;
    rdfs:label 'Total Linear Feet' ;
    rdfs:comment 'Total linear footage of shelf space available on the fixture, calculated across all shelves. Critical metric for space allocation and planogram capacity planning.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthInches rdf:type rdf:Property ;
    rdfs:label 'Width Inches' ;
    rdfs:comment 'Total width of the fixture in inches, representing the horizontal span of the unit.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipPreferredStoreStoreLocationId rdf:type rdf:Property ;
    rdfs:label 'Membership Preferred Store Store Location Id' ;
    rdfs:comment 'The store location the member shops at most frequently, determined by transaction history. Used for localized offers and store-specific promotions.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreLocation .

ind:membershipStoreLocationId rdf:type rdf:Property ;
    rdfs:label 'Membership Store Location Id' ;
    rdfs:comment 'The store location where the customer enrolled, if enrollment occurred in-store. Null for digital enrollments. Used for store-level enrollment performance tracking.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StoreLocation .

ind:referringMemberMembershipId rdf:type rdf:Property ;
    rdfs:label 'Referring Member Membership Id' ;
    rdfs:comment 'The membership ID of the existing member who referred this customer, if enrollment came through the member referral program. Null for non-referred enrollments. Used for referral reward attribution.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: Membership belongs to a tier; replace string tier with foreign key for referential integrity.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:annualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Amount' ;
    rdfs:comment 'Total purchase amount by the member in the current calendar or program year. Used for tier qualification thresholds and high-value member identification. Resets annually.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualVisitCount rdf:type rdf:Property ;
    rdfs:label 'Annual Visit Count' ;
    rdfs:comment 'Total number of shopping trips or transactions by the member in the current calendar or program year. Used for frequency-based tier qualification and engagement scoring. Resets annually.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cltvClassification rdf:type rdf:Property ;
    rdfs:label 'Cltv Classification' ;
    rdfs:comment 'Segmentation of the member based on their predicted or actual customer lifetime value. High value members receive premium treatment and exclusive offers. At-risk members are targeted for retention campaigns.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletLinkedFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Linked Flag' ;
    rdfs:comment 'Indicates whether the membership card has been added to a digital wallet (Apple Wallet, Google Pay) for contactless loyalty identification at POS.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directMailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Mail Opt In Flag' ;
    rdfs:comment 'Indicates whether the member has opted in to receive physical mail communications including ad circulars and exclusive member offers.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Indicates whether the member has opted in to receive promotional emails and loyalty program communications via email.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gamificationLevel rdf:type rdf:Property ;
    rdfs:label 'Gamification Level' ;
    rdfs:comment 'The current level or rank the member has achieved in the loyalty program gamification system through completing challenges, missions, or milestones. Higher levels unlock exclusive badges and rewards.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'The most recent date the member earned or redeemed points through any transaction. Used for churn prediction and reactivation targeting.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'The most recent date the member made a purchase that earned loyalty points. Used for recency-based segmentation and lapsed member identification.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all loyalty points earned since enrollment, including redeemed and expired points. Used for tier qualification and lifetime value analysis.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Cumulative total of all loyalty points redeemed since enrollment. Used for redemption rate analysis and program liability calculation.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'The externally-known loyalty card number or membership identifier presented at POS and used for points accrual and redemption. This is the business identifier for the membership.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the membership. Active memberships can earn and redeem points. Inactive memberships have no recent activity. Suspended memberships are temporarily blocked due to policy violations. Closed memberships are permanently terminated. Pending activation memberships are enrolled but not yet verified.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiration Date' ;
    rdfs:comment 'The date of the next scheduled points expiration event. Null if no points are scheduled to expire. Used for proactive member communication.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsBalance rdf:type rdf:Property ;
    rdfs:label 'Points Balance' ;
    rdfs:comment 'Current available loyalty points balance that can be redeemed for rewards, discounts, or merchandise. Updated in real-time with each transaction and redemption.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiringSoon rdf:type rdf:Property ;
    rdfs:label 'Points Expiring Soon' ;
    rdfs:comment 'Number of points scheduled to expire within the next 30 days. Used for expiration reminder campaigns and breakage forecasting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryHouseholdMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Household Member Flag' ;
    rdfs:comment 'Indicates whether this member is the primary account holder for a household loyalty membership. Primary members have administrative privileges to add or remove household members.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushNotificationOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In Flag' ;
    rdfs:comment 'Indicates whether the member has opted in to receive push notifications through the mobile app for personalized offers and program updates.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'The source or campaign that led to the member enrollment. Examples: member referral program, social media campaign, in-store promotion, partner co-marketing. Used for acquisition cost analysis and campaign ROI measurement.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In Flag' ;
    rdfs:comment 'Indicates whether the member has opted in to receive promotional text messages and loyalty alerts via SMS.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Status Effective Date' ;
    rdfs:comment 'The date the current status became effective. Used for status history tracking and reactivation eligibility determination.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Detailed reason or code explaining the current membership status. Examples: voluntary closure, fraud suspension, inactivity timeout, duplicate account merge, deceased member.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'The date the customer achieved their current tier level. Used for tier anniversary calculations and tier retention analysis.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiration Date' ;
    rdfs:comment 'The date the current tier expires if tier qualification thresholds are not maintained. Null for lifetime tiers. Used for tier retention campaigns and downgrade warnings.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual membership fee in USD required to maintain this tier. Zero for free tiers; positive amount for premium tiers. Used in billing and revenue recognition.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Comprehensive text description of all benefits and privileges associated with this tier. Used in customer communications, marketing materials, and mobile app displays.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdayBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Birthday Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to members of this tier on their birthday. Used for gamification and customer engagement.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric order in which this tier should be displayed in user interfaces and reports. Used for consistent presentation across channels.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Rule Description' ;
    rdfs:comment 'Business rule description explaining conditions under which customers are downgraded from this tier to a lower tier. Includes minimum points requirements and grace periods.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Days' ;
    rdfs:comment 'Number of days over which points are accumulated and evaluated for tier qualification (e.g., 365 for annual evaluation, 90 for quarterly). Defines the rolling window for tier assignment calculations.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusiveOffersFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Offers Flag' ;
    rdfs:comment 'Indicates whether members of this tier receive exclusive promotional offers and early access to sales. True if exclusive offers are a tier benefit; false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeDeliveryEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Free Delivery Eligible Flag' ;
    rdfs:comment 'Indicates whether members of this tier are eligible for free delivery on online orders. True if free delivery is a tier benefit; false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelDiscountCentsPerGallon rdf:type rdf:Property ;
    rdfs:label 'Fuel Discount Cents Per Gallon' ;
    rdfs:comment 'Fuel discount in cents per gallon offered to members of this tier at participating fuel centers. Integrates with fuel operations pricing systems.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days customers retain this tier status after falling below the minimum points threshold before being downgraded. Provides buffer period for customers to re-qualify.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL path to the tier icon image used in digital channels (mobile app, website, email). Supports visual tier recognition in customer-facing applications.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingColorCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Color Code' ;
    rdfs:comment 'Hexadecimal color code used to represent this tier in marketing materials, mobile apps, and customer communications (e.g., #FFD700 for Gold). Ensures consistent brand presentation.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Threshold' ;
    rdfs:comment 'Maximum number of loyalty points for this tier. Customers earning more than this threshold during the evaluation period qualify for the next higher tier. Null for the highest tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPointsThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Points Threshold' ;
    rdfs:comment 'Minimum number of loyalty points required to qualify for this tier. Customers must earn at least this many points during the evaluation period to achieve or maintain this tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this tier record. Supports audit trail and accountability for tier configuration changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'Multiplier applied to base points earned by members of this tier (e.g., 1.0 for base tier, 1.5 for Silver, 2.0 for Gold). Used to calculate accelerated points accrual for higher tiers.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityCustomerServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Customer Service Flag' ;
    rdfs:comment 'Indicates whether members of this tier receive priority customer service (e.g., dedicated phone line, faster response times). True if priority service is a tier benefit; false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier (e.g., MEMBER, SILVER, GOLD, PLATINUM). Used as business identifier in external systems and customer communications.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable display name of the loyalty tier (e.g., Member, Silver, Gold, Platinum). Used in customer-facing applications and marketing materials.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Numeric rank order of the tier within the loyalty program hierarchy. Lower numbers indicate higher status (e.g., 1=Platinum, 2=Gold, 3=Silver, 4=Member). Used for tier comparison and upgrade/downgrade logic.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier. Active tiers are available for customer assignment; inactive tiers are no longer offered but may have existing members; deprecated tiers are being phased out; pending tiers are scheduled for future launch.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Upgrade Rule Description' ;
    rdfs:comment 'Business rule description explaining how customers qualify for upgrade to this tier from a lower tier. Includes points thresholds, evaluation periods, and any additional criteria.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:welcomeBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Welcome Bonus Points' ;
    rdfs:comment 'Number of bonus loyalty points awarded to customers when they first achieve this tier. Used to incentivize tier upgrades.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierHistoryId rdf:type rdf:Property ;
    rdfs:label 'Tier History Id' ;
    rdfs:comment 'Unique identifier for each tier change event in the loyalty program. Primary key for the tier history transactional record.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newTierId rdf:type rdf:Property ;
    rdfs:label 'New Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: tier_history currently stores new_tier_code and new_tier_name as denormalized STRING columns. Adding new_tier_id as a FK to loyalty.tier.tier_id normalizes this relationship, allowing a JOIN to retrie' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:pointsTransactionId rdf:type rdf:Property ;
    rdfs:label 'Points Transaction Id' ;
    rdfs:comment 'Reference to the specific Point of Sale (POS) transaction that triggered this tier change event, if applicable. Null for system-initiated or manual tier changes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsTransaction .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date when the new tier status became active and the member began receiving benefits associated with the new tier level.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Precise timestamp when the tier change was applied in the loyalty system, used for real-time benefit activation and audit purposes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the qualification period used to evaluate tier eligibility for this change event.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the qualification period used to evaluate tier eligibility for this change event (e.g., program year start, rolling 12-month window start).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isManualAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Manual Adjustment' ;
    rdfs:comment 'Boolean flag indicating whether this tier change was manually adjusted by customer service or loyalty program administrators rather than automatically triggered by system rules.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manualAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Manual Adjustment Reason' ;
    rdfs:comment 'Detailed explanation for manual tier adjustments, including customer service case reference, goodwill gesture context, or system error correction details. Null for automated tier changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when the tier change notification was sent to the member through Customer Relationship Management (CRM) or loyalty communication channels.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pointsBalanceAtChange rdf:type rdf:Property ;
    rdfs:label 'Points Balance At Change' ;
    rdfs:comment 'The total loyalty points balance the member held at the exact moment of the tier change event, used for tier progression analytics and member lifecycle tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTierCode rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Code' ;
    rdfs:comment 'The loyalty tier code the member held immediately before this change event (e.g., BRONZE, SILVER, GOLD, PLATINUM).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTierName rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Name' ;
    rdfs:comment 'Human-readable name of the previous loyalty tier for reporting and customer communication.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The loyalty program year during which this tier change occurred, used for annual tier reset and year-over-year progression analytics.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'The cumulative spend amount that qualified the member for this tier change, measured over the qualification period. Null for non-spend-based tier changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Transaction Count' ;
    rdfs:comment 'The number of qualifying transactions completed during the evaluation period that contributed to this tier change. Null for non-transaction-based tier changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this tier history record was first created in the lakehouse silver layer, used for data lineage and audit trail purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this tier history record was last modified in the lakehouse silver layer, used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this tier change record in the source operational system, used for data lineage and reconciliation.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierBenefitsActivatedFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Benefits Activated Flag' ;
    rdfs:comment 'Boolean flag indicating whether all tier-specific benefits (discounts, free delivery, exclusive offers) have been successfully activated in the members profile.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Change Number' ;
    rdfs:comment 'Business-facing unique identifier for this tier change event, used for customer service inquiries and audit trails.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason Code' ;
    rdfs:comment 'Standardized code indicating why the tier change occurred (e.g., EARNED_UPGRADE for qualifying spend threshold, ANNUAL_RESET for program year rollover, MANUAL_ADJ for customer service adjustment, DEMOTION for inactivity, PROMO_BOOST for promotional tier grant).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason Description' ;
    rdfs:comment 'Detailed explanation of the business reason for the tier change, including any special circumstances or promotional context.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Change Status' ;
    rdfs:comment 'Current lifecycle status of this tier change record: active (currently in effect), expired (tier period ended), reversed (change was rolled back), or pending (scheduled but not yet effective).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeType rdf:type rdf:Property ;
    rdfs:label 'Tier Change Type' ;
    rdfs:comment 'Classification of the tier movement direction: upgrade (tier improvement), downgrade (tier reduction), lateral (same tier level but different program), initial_enrollment (first tier assignment), or reset (annual program reset).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAccountId rdf:type rdf:Property ;
    rdfs:label 'Points Account Id' ;
    rdfs:comment 'Unique identifier for the loyalty points account. Primary key for the points account ledger.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsAccount .

ind:loyaltyMembershipId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Membership Id' ;
    rdfs:comment 'Reference to the loyalty membership that owns this points account. Each membership may have multiple accounts (points, fuel rewards).' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the points account was activated and became eligible for earning and redemption. May differ from creation date if account required verification or approval.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason code for account closure. Used for churn analysis, compliance reporting, and member service quality tracking. Null for active accounts.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Multiplier' ;
    rdfs:comment 'Current earning rate multiplier applied to this account. Base rate is 1.0; tier upgrades or promotions may increase to 1.5x, 2.0x, etc. Applied to all qualifying purchases.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Earn Period End Date' ;
    rdfs:comment 'End date of the current earning period window. Points earned during this period may have specific expiration rules or tier qualification impact.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Earn Period Start Date' ;
    rdfs:comment 'Start date of the current earning period window. Used for time-bound promotions, seasonal campaigns, and rolling expiration calculations.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Expiration Policy Code' ;
    rdfs:comment 'Code identifying the expiration policy applied to this account. References program rules for time-based expiration, rolling windows, or activity-based extension. Used for automated expiration processing.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAccountCode rdf:type rdf:Property ;
    rdfs:label 'External Account Code' ;
    rdfs:comment 'Account identifier from the source operational system. Used for cross-system reconciliation, data integration, and troubleshooting. May differ from the lakehouse primary key.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudHoldDate rdf:type rdf:Property ;
    rdfs:label 'Fraud Hold Date' ;
    rdfs:comment 'Timestamp when the fraud hold was placed on the account. Used for hold duration tracking and compliance with fraud investigation timelines. Null if no hold is active.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Hold Flag' ;
    rdfs:comment 'Indicates whether the account is under fraud review hold. When true, all earn and redemption transactions are blocked pending investigation. Set by fraud detection systems.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Indicates whether loyalty currency from this account can be combined with other payment methods or loyalty currencies in a single transaction. Used for POS redemption logic.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether loyalty currency in this account can be transferred to another member or household account. Typically false for standard points, may be true for family pooling programs.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date of the most recent loyalty currency earning transaction. Used for inactivity tracking, dormancy detection, and member re-engagement campaigns.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent loyalty currency redemption transaction. Used for engagement analysis, redemption velocity tracking, and member behavior segmentation.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeAdjusted rdf:type rdf:Property ;
    rdfs:label 'Lifetime Adjusted' ;
    rdfs:comment 'Total cumulative amount of loyalty currency adjusted due to corrections, reversals, goodwill credits, or fraud chargebacks. Can be positive or negative. Used for audit and reconciliation.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Earned' ;
    rdfs:comment 'Total cumulative amount of loyalty currency earned since account inception. Never decreases. Used for tier qualification, member recognition, and lifetime value analytics.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Expired' ;
    rdfs:comment 'Total cumulative amount of loyalty currency that has expired due to inactivity or time-based expiration policies. Used for breakage analysis and program liability management.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Redeemed' ;
    rdfs:comment 'Total cumulative amount of loyalty currency redeemed since account inception. Never decreases. Used for program ROI analysis and member engagement metrics.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxRedemptionPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Redemption Per Day' ;
    rdfs:comment 'Maximum amount of loyalty currency that can be redeemed within a 24-hour period. Used for fraud prevention and program liability management.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxRedemptionPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Redemption Per Transaction' ;
    rdfs:comment 'Maximum amount of loyalty currency that can be redeemed in a single transaction. For fuel rewards, this typically represents maximum gallons eligible for discount (e.g., 20 gallons). Enforced at POS and fuel pump.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextExpirationAmount rdf:type rdf:Property ;
    rdfs:label 'Next Expiration Amount' ;
    rdfs:comment 'Amount of loyalty currency scheduled to expire on the next expiration date. Used for proactive member engagement campaigns to encourage redemption before expiration.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingBalance rdf:type rdf:Property ;
    rdfs:label 'Pending Balance' ;
    rdfs:comment 'Balance of loyalty currency earned but not yet confirmed or posted to available balance. Typically represents transactions awaiting settlement, return windows, or fraud review periods.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateEarned rdf:type rdf:Property ;
    rdfs:label 'Year To Date Earned' ;
    rdfs:comment 'Total loyalty currency earned in the current calendar year. Resets to zero on January 1. Used for annual tier qualification and member performance tracking.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateRedeemed rdf:type rdf:Property ;
    rdfs:label 'Year To Date Redeemed' ;
    rdfs:comment 'Total loyalty currency redeemed in the current calendar year. Resets to zero on January 1. Used for redemption velocity analysis and program engagement metrics.' ;
    rdfs:domain ind:PointsAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalCouponId rdf:type rdf:Property ;
    rdfs:label 'Digital Coupon Id' ;
    rdfs:comment 'Foreign key linking to promotion.digital_coupon. Business justification: When a digital coupon is redeemed, bonus loyalty points may be awarded. points_transaction already has promo_offer_id but digital coupon-specific points attribution (e.g., manufacturer-funded coupon b' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalCoupon .

ind:tradeAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Trade Allowance Id' ;
    rdfs:comment 'Foreign key linking to vendor.trade_allowance. Business justification: Bonus points transactions funded by supplier trade allowances (e.g., double-points weekends, category-specific earn events) must be attributed to the specific trade allowance for co-op settlement, all' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeAllowance .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Quantity of loyalty currency moved in this transaction. Positive for accruals (earn, bonus, transfer-in), negative for deductions (redeem, expire, adjust-down, transfer-out). For points currency this is the point count; for fuel currency this is cents-per-gallon discount value.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchCode rdf:type rdf:Property ;
    rdfs:label 'Batch Code' ;
    rdfs:comment 'Identifier of the batch processing job that created this transaction record. Used for bulk operations such as nightly expiration processing, monthly tier bonus awards, and partner point transfers. Null for real-time individual transactions. Supports operational troubleshooting and reprocessing scenarios.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakageEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Breakage Eligible Flag' ;
    rdfs:comment 'Indicates whether this transaction is eligible for breakage revenue recognition under ASC 606. True for earned points that may expire unused, allowing the company to recognize a portion of deferred revenue as breakage. False for redeemed, expired, or adjusted points. Used in financial reporting and actuarial breakage analysis.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Type of loyalty currency involved in this transaction. Points are the primary loyalty currency; fuel cents-per-gallon represents fuel discount rewards earned through the loyalty program.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the loyalty currency from this transaction will expire if not used. Populated for earn and bonus transactions based on program expiration policy (e.g., points expire 12 months from earn date). Used to calculate points-expiring-soon alerts and ASC 606 breakage analysis. Null for redeem, expire, and adjust transactions. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Discount Amount' ;
    rdfs:comment 'Total dollar value of fuel discount applied at the pump, calculated as gallons dispensed multiplied by cents-per-gallon reward rate. Used for financial reconciliation and revenue recognition. Populated only for fuel redemptions. Null for all other transaction types.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gallonsDispensed rdf:type rdf:Property ;
    rdfs:label 'Gallons Dispensed' ;
    rdfs:comment 'Number of gallons of fuel dispensed for fuel redemption transactions. Used to calculate the total dollar discount applied (gallons × cents-per-gallon). Populated only for fuel center redemptions. Null for all other transaction types.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining why this transaction occurred. Used primarily for adjust, expire, reversal, and bonus transactions. Examples: ADJ-001 (customer service goodwill), EXP-POLICY (standard expiration), REV-RETURN (order return), BONUS-TIER (tier anniversary bonus). Supports audit trail and customer service inquiry.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text explanation of the transaction reason, providing additional context beyond the reason code. Used for customer service notes, adjustment justifications, and audit documentation. Particularly important for manual adjustments and reversals.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionMethod rdf:type rdf:Property ;
    rdfs:label 'Redemption Method' ;
    rdfs:comment 'How the redemption was triggered. Automatic redemptions apply rewards without customer action (e.g., auto-apply fuel discount), manual redemptions require cashier or customer service intervention, customer-initiated redemptions are explicitly requested by the member (e.g., selecting reward in mobile app), system-initiated redemptions are triggered by business rules (e.g., expiring points converted to charity donation). Populated only for redeem transactions.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Specific method of reward redemption for redeem transactions. Points-for-discount applies points as basket discount at checkout, free item claims a specific product reward, fuel cents-per-gallon applies fuel discount at pump, pharmacy copay reduction lowers prescription cost, charity donation converts points to charitable contribution, partner transfer moves points to external program. Null for non-redemption transactions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this transaction is a reversal of a previous transaction. True for reversal transactions that cancel or correct prior points movements (e.g., order return, redemption cancellation). False for all original transactions. Used to filter reversals from financial reporting and customer lifetime value calculations.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runningBalance rdf:type rdf:Property ;
    rdfs:label 'Running Balance' ;
    rdfs:comment 'Cumulative balance of loyalty currency in the membership account after this transaction is applied. Provides point-in-time snapshot for audit trail and customer service inquiry. Calculated as prior balance plus/minus transaction amount.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique identifier of this transaction in the originating source system. Used for end-to-end traceability, reconciliation with source systems, and troubleshooting data quality issues. Enables lookup of original transaction details in NCR POS, Salesforce Commerce Cloud, or other source systems.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Impact Amount' ;
    rdfs:comment 'Dollar value of tax impact associated with this loyalty transaction. Used for financial accounting when loyalty redemptions affect taxable sales (e.g., fuel discount reduces taxable fuel revenue). Supports ASC 606 revenue recognition and tax compliance reporting. Null for transactions with no tax impact.' ;
    rdfs:domain ind:PointsTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the loyalty currency movement occurred in the source system. This is the business event time, not the ETL load time. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether offer is automatically applied at checkout when conditions are met (True) or requires manual activation (False).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Current Redemption Count' ;
    rdfs:comment 'Running total of redemptions that have occurred for this offer across all members.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount (percentage or dollar amount depending on discount_type). Null if not applicable.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleChannelList rdf:type rdf:Property ;
    rdfs:label 'Eligible Channel List' ;
    rdfs:comment 'Comma-separated list of purchase channels where offer can be redeemed (e.g., in-store, online, mobile app, pickup, delivery).' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleSkuList rdf:type rdf:Property ;
    rdfs:label 'Eligible Sku List' ;
    rdfs:comment 'Comma-separated list of specific SKU codes eligible for this offer. Null if offer applies to categories or all products.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleTierList rdf:type rdf:Property ;
    rdfs:label 'Eligible Tier List' ;
    rdfs:comment 'Comma-separated list of loyalty membership tiers eligible for this offer (e.g., Silver, Gold, Platinum). Null if available to all tiers.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the reward offer expires and is no longer available for activation or redemption.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCostPerRedemption rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Redemption' ;
    rdfs:comment 'Projected financial cost to the business for each redemption of this offer including discounts, points liability, and operational costs.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedSkuList rdf:type rdf:Property ;
    rdfs:label 'Excluded Sku List' ;
    rdfs:comment 'Comma-separated list of SKU codes explicitly excluded from this offer even if they fall within eligible categories.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelRewardCentsPerGallon rdf:type rdf:Property ;
    rdfs:label 'Fuel Reward Cents Per Gallon' ;
    rdfs:comment 'Discount amount in cents per gallon applied at fuel centers when offer is redeemed. Null if not a fuel reward offer.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamificationBadgeName rdf:type rdf:Property ;
    rdfs:label 'Gamification Badge Name' ;
    rdfs:comment 'Name of digital badge or achievement unlocked when offer is completed. Null if not part of gamification program.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRedemptionsPerMember rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions Per Member' ;
    rdfs:comment 'Maximum number of times a single member can redeem this offer during its validity period. Null for unlimited.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRedemptionsTotal rdf:type rdf:Property ;
    rdfs:label 'Max Redemptions Total' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all members for this offer. Null for unlimited.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mechanicsType rdf:type rdf:Property ;
    rdfs:label 'Mechanics Type' ;
    rdfs:comment 'Defines whether the offer is for earning points, redeeming points, or a combination of both.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of qualifying items that must be purchased to activate the offer. Null if no quantity requirement.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Spend Amount' ;
    rdfs:comment 'Minimum purchase amount required to qualify for the reward offer. Null if no minimum required.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the reward offer for tracking and redemption purposes.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the reward offer including terms, conditions, and member benefits.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name of the reward offer displayed to loyalty members.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the reward offer indicating availability to members.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Category of reward offer defining the benefit mechanism provided to the member.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'Indicates whether this offer was generated through personalized recommendation engine (True) or is a program-wide offer (False).' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyRewardDescription rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Reward Description' ;
    rdfs:comment 'Description of pharmacy-specific reward benefit (e.g., discount on prescriptions, health screening credit). Null if not a pharmacy offer.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Points Award Amount' ;
    rdfs:comment 'Fixed number of bonus points awarded when offer conditions are met. Null if offer uses multiplier instead.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Redemption End Date' ;
    rdfs:comment 'Final date by which activated offers must be redeemed. May extend beyond offer end_date.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Start Date' ;
    rdfs:comment 'Date when members can begin redeeming this offer. May differ from activation date for earn-then-redeem mechanics.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this offer can be combined with other offers or promotions (True) or is mutually exclusive (False).' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the reward offer becomes active and available to qualifying members.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sweepstakesEntryCount rdf:type rdf:Property ;
    rdfs:label 'Sweepstakes Entry Count' ;
    rdfs:comment 'Number of sweepstakes entries awarded when offer conditions are met. Null if not a sweepstakes offer.' ;
    rdfs:domain ind:RewardOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRoiPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Roi Percentage' ;
    rdfs:comment 'Target return on investment percentage for this offer based on incremental revenue and customer lifetime value impact.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions governing the reward offer including restrictions, exclusions, and member obligations.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberOfferId rdf:type rdf:Property ;
    rdfs:label 'Member Offer Id' ;
    rdfs:comment 'Unique identifier for the member offer assignment record. Primary key for this association entity linking a loyalty member to a specific reward offer.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberOffer .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'Channel through which the member activated the offer. Tracks which touchpoint the member used to clip or engage with the offer.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Precise timestamp when the member activated the offer. Used for detailed engagement tracking and time-to-activation analytics.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentChannel rdf:type rdf:Property ;
    rdfs:label 'Assignment Channel' ;
    rdfs:comment 'Channel through which the offer was assigned to the member. Indicates the touchpoint where the offer was delivered or made available.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Source or method by which the offer was assigned. Distinguishes between targeted offers pushed by the system, offers selected by the member, tier-based automatic benefits, and other assignment mechanisms.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstViewTimestamp rdf:type rdf:Property ;
    rdfs:label 'First View Timestamp' ;
    rdfs:comment 'Timestamp when the member first viewed this offer. Null if the member has not viewed the offer. Used to calculate time-to-activation and engagement velocity.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastViewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last View Timestamp' ;
    rdfs:comment 'Timestamp when the member most recently viewed this offer. Tracks ongoing member interest and re-engagement patterns.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberOfferStatus rdf:type rdf:Property ;
    rdfs:label 'Member Offer Status' ;
    rdfs:comment 'Current lifecycle status of the member offer assignment. Tracks progression from loaded to card, through activation, redemption, or expiration.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationScore rdf:type rdf:Property ;
    rdfs:label 'Personalization Score' ;
    rdfs:comment 'Algorithmic score representing how well this offer matches the member\'s predicted preferences and purchase behavior. Higher scores indicate better personalization. Used for offer targeting optimization.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Points Awarded' ;
    rdfs:comment 'Number of loyalty points awarded to the member upon redemption of this offer. Null if the offer has not been redeemed or if the offer does not award points.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking of this offer relative to other offers assigned to the same member. Lower numbers indicate higher priority. Used for offer display ordering and conflict resolution.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionDate rdf:type rdf:Property ;
    rdfs:label 'Redemption Date' ;
    rdfs:comment 'Date when the member redeemed the offer through a qualifying purchase. Null if the offer has not been redeemed yet.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Precise timestamp when the offer was redeemed. Matches the transaction timestamp for the qualifying purchase.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the offer was revoked or removed from the member\'s account. Null if the offer has not been revoked. Used for fraud prevention or policy violations.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation for why the offer was revoked from the member. Null if not revoked. Supports compliance and customer service inquiries.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingSegment rdf:type rdf:Property ;
    rdfs:label 'Targeting Segment' ;
    rdfs:comment 'Customer segment or cohort used to target this offer to the member. Identifies the segmentation strategy that resulted in this assignment.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Number of times the member viewed this offer in digital channels. Used to measure offer visibility and member interest before activation.' ;
    rdfs:domain ind:MemberOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Redemption Id' ;
    rdfs:comment 'Unique identifier for the loyalty reward redemption transaction. Primary key.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyRedemption .

ind:basketTotalAfterRedemption rdf:type rdf:Property ;
    rdfs:label 'Basket Total After Redemption' ;
    rdfs:comment 'Total transaction amount after the loyalty redemption discount was applied.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basketTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Basket Total Amount' ;
    rdfs:comment 'Total transaction amount before the loyalty redemption discount was applied. Provides context for redemption impact.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Explanation of why the redemption failed or was reversed. Null for successful redemptions.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelDiscountPerGallon rdf:type rdf:Property ;
    rdfs:label 'Fuel Discount Per Gallon' ;
    rdfs:comment 'Cents-per-gallon discount applied to fuel purchase. Null for non-fuel redemptions.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelGallonsPurchased rdf:type rdf:Property ;
    rdfs:label 'Fuel Gallons Purchased' ;
    rdfs:comment 'Number of gallons of fuel purchased when fuel discount was applied. Null for non-fuel redemptions.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamificationEventFlag rdf:type rdf:Property ;
    rdfs:label 'Gamification Event Flag' ;
    rdfs:comment 'Indicates whether this redemption was part of a gamification event or challenge (True) or a standard redemption (False).' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Eligible Flag' ;
    rdfs:comment 'Indicates whether this redemption event qualifies the member for a Net Promoter Score (NPS) survey (True/False).' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'Member\'s loyalty points balance immediately after this redemption was processed.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Member\'s loyalty points balance immediately before this redemption was processed.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Points Redeemed' ;
    rdfs:comment 'Number of loyalty points deducted from the member\'s balance for this redemption. Zero if redemption was a non-points reward (e.g., free item offer).' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionSource rdf:type rdf:Property ;
    rdfs:label 'Redemption Source' ;
    rdfs:comment 'How the redemption was initiated: member-initiated (customer selected), auto-applied (system automatically applied best offer), cashier-applied (store associate applied), or system-triggered (rule-based application).' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierAtRedemption rdf:type rdf:Property ;
    rdfs:label 'Tier At Redemption' ;
    rdfs:comment 'Loyalty tier code of the member at the time of redemption. Captured for historical analysis of tier-based redemption behavior.' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Monetary value of the redemption in local currency (dollar discount applied, fuel savings, copay reduction, or retail value of free item).' ;
    rdfs:domain ind:LoyaltyRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:householdMemberId rdf:type rdf:Property ;
    rdfs:label 'Household Member Id' ;
    rdfs:comment 'Unique identifier for the household member association record. Primary key.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHouseholdMembershipId rdf:type rdf:Property ;
    rdfs:label 'Primary Household Membership Id' ;
    rdfs:comment 'Reference to the individual loyalty membership record associated with this household member.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:benefitSharingTier rdf:type rdf:Property ;
    rdfs:label 'Benefit Sharing Tier' ;
    rdfs:comment 'Level of household benefits this member is eligible to receive. Full tier receives all household benefits, partial receives select benefits, restricted has limited access, and none receives no shared benefits.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNumber rdf:type rdf:Property ;
    rdfs:label 'Card Number' ;
    rdfs:comment 'Physical or virtual loyalty card number assigned to this household member for POS (Point of Sale) identification. May be shared across household or unique per member depending on program rules.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreferenceOverride rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Override' ;
    rdfs:comment 'Indicates whether this member inherits household communication preferences, has custom individual preferences, or suppresses all household communications. Enables personalized communication strategies within households.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelRewardsSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Rewards Sharing Flag' ;
    rdfs:comment 'Indicates whether this member can access and redeem household fuel rewards at fuel centers. Enables household-level fuel discount pooling and redemption tracking.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdMemberStatus rdf:type rdf:Property ;
    rdfs:label 'Household Member Status' ;
    rdfs:comment 'Current status of this household member association. Active members participate in household benefits, inactive members have left, suspended members are temporarily blocked, and pending members await approval.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Accepted Date' ;
    rdfs:comment 'Date when this member accepted the household invitation. Null if invitation is pending or was declined.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invitationCode rdf:type rdf:Property ;
    rdfs:label 'Invitation Code' ;
    rdfs:comment 'Unique code used to invite this member to join the household. Tracks invitation source and enables secure household joining workflows.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationSentDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Sent Date' ;
    rdfs:comment 'Date when the household invitation was sent to this member. Used to track invitation response time and follow-up campaigns.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'Date when this member was added to the household. Used to track household growth and member tenure.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaveDate rdf:type rdf:Property ;
    rdfs:label 'Leave Date' ;
    rdfs:comment 'Date when this member left or was removed from the household. Null if the member is currently active in the household.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsContributed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Contributed' ;
    rdfs:comment 'Total loyalty points this member has contributed to the household pool since joining. Used for household contribution analytics and member value assessment.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'Role of this member within the household loyalty structure. Primary members have full administrative rights, secondary members have shared benefits, dependents have limited access, and authorized users can transact on behalf of the household.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerEligibilityOverride rdf:type rdf:Property ;
    rdfs:label 'Offer Eligibility Override' ;
    rdfs:comment 'Override flag for household-level offer eligibility. Inherit uses household rules, eligible forces inclusion in household offers, ineligible excludes this member from household offers. Used for compliance or member preference scenarios.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyBenefitsSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Benefits Sharing Flag' ;
    rdfs:comment 'Indicates whether this member can access household pharmacy loyalty benefits such as prescription discounts or health rewards. Subject to HIPAA privacy rules and state pharmacy regulations.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsPoolingFlag rdf:type rdf:Property ;
    rdfs:label 'Points Pooling Flag' ;
    rdfs:comment 'Indicates whether this member participates in household-level points pooling. When true, points earned by this member contribute to the shared household balance.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poolingContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Pooling Contribution Percentage' ;
    rdfs:comment 'Percentage of points earned by this member that are contributed to the household pool. Range 0.00 to 100.00. Enables partial pooling scenarios where members retain some individual points.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Type of relationship this member has to the primary household member. Used for household composition analytics and targeted family offers. [ENUM-REF-CANDIDATE: spouse|partner|child|parent|sibling|roommate|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Spending Authority Level' ;
    rdfs:comment 'Level of authority this member has to redeem household points or use household benefits. Full authority allows unrestricted redemption, limited requires approval thresholds, view-only can see but not transact, and none has no access.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Spending Limit Amount' ;
    rdfs:comment 'Maximum dollar value or points this member can redeem per transaction or per period without additional approval. Null indicates no limit. Used for dependent and secondary member governance.' ;
    rdfs:domain ind:HouseholdMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseEarnRate rdf:type rdf:Property ;
    rdfs:label 'Base Earn Rate' ;
    rdfs:comment 'Default points earned per dollar spent across all categories before any multipliers or bonuses are applied.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusStackingPriority rdf:type rdf:Property ;
    rdfs:label 'Bonus Stacking Priority' ;
    rdfs:comment 'Rule defining how multiple earn bonuses (category, channel, tier) are combined when a transaction qualifies for more than one.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannelBonusRate rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel Bonus Rate' ;
    rdfs:comment 'Additional points bonus rate applied to last mile delivery orders.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryFixedMonthDay rdf:type rdf:Property ;
    rdfs:label 'Expiry Fixed Month Day' ;
    rdfs:comment 'Month and day (MM-DD format) when points expire annually if using fixed calendar expiry method. Null if not applicable.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Grace Period Days' ;
    rdfs:comment 'Number of days after expiry date during which points can still be redeemed before permanent forfeiture.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryInactivityDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Inactivity Days' ;
    rdfs:comment 'Number of days of member inactivity after which points expire when using rolling inactivity expiry method. Null if not applicable.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryNotificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Expiry Notification Lead Days' ;
    rdfs:comment 'Number of days before points expiry when the system sends notification alerts to members.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelRedemptionCentsPerGallonCap rdf:type rdf:Property ;
    rdfs:label 'Fuel Redemption Cents Per Gallon Cap' ;
    rdfs:comment 'Maximum discount in cents per gallon that can be applied to a single fuel transaction when redeeming points at fuel centers.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRedemptionGallonLimit rdf:type rdf:Property ;
    rdfs:label 'Fuel Redemption Gallon Limit' ;
    rdfs:comment 'Maximum number of gallons eligible for discount in a single fuel transaction when redeeming loyalty points.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gamificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gamification Enabled Flag' ;
    rdfs:comment 'Indicates whether gamification features (badges, levels, challenges, leaderboards) are active for this program configuration.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when this loyalty program configuration was first made available to customers.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxSingleRedemptionPoints rdf:type rdf:Property ;
    rdfs:label 'Max Single Redemption Points' ;
    rdfs:comment 'Maximum number of points that can be redeemed in a single transaction to prevent excessive value extraction.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiProgramSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Program Support Flag' ;
    rdfs:comment 'Indicates whether this configuration supports members participating in multiple loyalty programs simultaneously (e.g., grocery + pharmacy + fuel).' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineChannelBonusRate rdf:type rdf:Property ;
    rdfs:label 'Online Channel Bonus Rate' ;
    rdfs:comment 'Additional points bonus rate applied to purchases made through digital commerce channels (web, mobile app).' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether AI-driven personalized reward offers and recommendations are enabled for members in this program.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupChannelBonusRate rdf:type rdf:Property ;
    rdfs:label 'Pickup Channel Bonus Rate' ;
    rdfs:comment 'Additional points bonus rate applied to click-and-collect or curbside pickup orders.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryMethod rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Method' ;
    rdfs:comment 'Strategy used to determine when loyalty points expire (rolling window from last activity, fixed annual date, tier-dependent rules, or never).' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateLabelMultiplier rdf:type rdf:Property ;
    rdfs:label 'Private Label Multiplier' ;
    rdfs:comment 'Points multiplier applied to purchases of store-owned brand products to incentivize private label sales.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed business description of the loyalty program purpose, target audience, and key benefits for internal reference.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty program configuration.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionMinimumThreshold rdf:type rdf:Property ;
    rdfs:label 'Redemption Minimum Threshold' ;
    rdfs:comment 'Minimum number of points a member must accumulate before they are eligible to redeem for rewards.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionPointsToDollarRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Points To Dollar Rate' ;
    rdfs:comment 'Conversion rate defining how many points equal one dollar of redemption value (e.g., 100 points = $1.00).' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralBonusPointsReferee rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points Referee' ;
    rdfs:comment 'Number of points awarded to the new member who joins the program through a referral link or code.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralBonusPointsReferrer rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points Referrer' ;
    rdfs:comment 'Number of points awarded to the existing member who successfully refers a new member to the program.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web address where the complete legal terms and conditions for this loyalty program version are published.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEvaluationFrequency rdf:type rdf:Property ;
    rdfs:label 'Tier Evaluation Frequency' ;
    rdfs:comment 'Cadence at which member tier status is recalculated based on points earned or spend thresholds.' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEvaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Tier Evaluation Method' ;
    rdfs:comment 'Metric used to determine member tier qualification (current points balance, points earned in period, spend in period, or visit frequency).' ;
    rdfs:domain ind:ProgramConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Foreign key linking to store.district. Business justification: Each store belongs to a district; adding district_id creates the hierarchical link without redundancy.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:gatewayId rdf:type rdf:Property ;
    rdfs:label 'Gateway Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_gateway. Business justification: Required for POS settlement reporting: each store is assigned a payment gateway that processes its transactions, needed for daily settlement batch generation and compliance audits.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gateway .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: Pricing zone assignment per store drives zone-specific price strategies; required for Price Zone Performance Report and zone-based price optimization.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:acceptsSnapEbt rdf:type rdf:Property ;
    rdfs:label 'Accepts Snap Ebt' ;
    rdfs:comment 'Indicates whether this store is authorized to accept SNAP (Supplemental Nutrition Assistance Program) benefits via EBT (Electronic Benefits Transfer). Impacts payment processing, regulatory compliance, and customer accessibility.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsWic rdf:type rdf:Property ;
    rdfs:label 'Accepts Wic' ;
    rdfs:comment 'Indicates whether this store is authorized to accept WIC (Women, Infants, and Children) program benefits. Impacts product assortment, POS configuration, and regulatory compliance.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backroomSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Backroom Square Footage' ;
    rdfs:comment 'Square footage of storage and receiving areas behind the sales floor. Used for inventory capacity planning, replenishment strategy, and operational efficiency analysis.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for store-level communication. Used for customer inquiries, vendor coordination, and internal communications. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24/7 emergency contact number for the store location. Used for after-hours incidents, security alerts, and facility emergencies. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Gross Square Footage' ;
    rdfs:comment 'Total building square footage including sales floor, backroom, offices, restrooms, and mechanical spaces. Used for facility management, lease agreements, and property tax calculations.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasBakery rdf:type rdf:Property ;
    rdfs:label 'Has Bakery' ;
    rdfs:comment 'Indicates whether this store includes an in-store bakery. Impacts food safety compliance, production scheduling, and fresh product assortment.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDeli rdf:type rdf:Property ;
    rdfs:label 'Has Deli' ;
    rdfs:comment 'Indicates whether this store includes a deli department with prepared foods. Impacts food safety compliance (HACCP), staffing, and merchandising strategy.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasFloral rdf:type rdf:Property ;
    rdfs:label 'Has Floral' ;
    rdfs:comment 'Indicates whether this store includes a floral department. Impacts perishable inventory management, vendor relationships, and seasonal merchandising.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasFuelCenter rdf:type rdf:Property ;
    rdfs:label 'Has Fuel Center' ;
    rdfs:comment 'Indicates whether this store location includes a fuel center. Impacts environmental compliance (EPA), pricing strategy, and loyalty program integration.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMeatDepartment rdf:type rdf:Property ;
    rdfs:label 'Has Meat Department' ;
    rdfs:comment 'Indicates whether this store includes a full-service meat department with butchers. Impacts USDA compliance, cold chain management, and staffing.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasOrganicSection rdf:type rdf:Property ;
    rdfs:label 'Has Organic Section' ;
    rdfs:comment 'Indicates whether this store includes a dedicated organic and natural foods section. Impacts merchandising strategy, vendor relationships, and customer segmentation.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPharmacy rdf:type rdf:Property ;
    rdfs:label 'Has Pharmacy' ;
    rdfs:comment 'Indicates whether this store location includes a licensed pharmacy department. Impacts regulatory compliance (DEA, State Boards of Pharmacy, HIPAA), staffing requirements, and service offerings.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSeafood rdf:type rdf:Property ;
    rdfs:label 'Has Seafood' ;
    rdfs:comment 'Indicates whether this store includes a fresh seafood department. Impacts cold chain management, HACCP compliance, and specialized staffing requirements.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRemodelDate rdf:type rdf:Property ;
    rdfs:label 'Last Remodel Date' ;
    rdfs:comment 'The date of the most recent major remodel or renovation. Used to track capital investment cycles, assess store modernization status, and plan future remodel schedules.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the store location. Impacts financial reporting, capital expenditure planning, and operational control.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpacesCount rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces Count' ;
    rdfs:comment 'Total number of customer parking spaces available at this location. Impacts site selection, customer convenience, and omnichannel pickup capacity.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary customer-facing phone number for the store. Used for customer inquiries, order status, and pharmacy consultations. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Selling Square Footage' ;
    rdfs:comment 'Square footage of customer-accessible sales floor area. Excludes backroom, offices, and non-selling spaces. Used for sales productivity metrics (sales per square foot), space planning, and merchandising allocation.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter state or province code (e.g., CA, TX, ON). Used for tax jurisdiction determination, regulatory compliance, and regional reporting.' ;
    rdfs:domain ind:Store ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeName rdf:type rdf:Property ;
    rdfs:label 'Store Name' ;
    rdfs:comment 'Human-readable name of the store location, often including neighborhood or landmark identifiers (e.g., \'Downtown Main Street\', \'Riverside Plaza\'). Used for customer communication and internal reference.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeNumber rdf:type rdf:Property ;
    rdfs:label 'Store Number' ;
    rdfs:comment 'Externally-known business identifier for the store location. Used in all customer-facing communications, signage, and operational systems. Typically a 4-6 digit numeric code assigned sequentially or by region.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsCurbsidePickup rdf:type rdf:Property ;
    rdfs:label 'Supports Curbside Pickup' ;
    rdfs:comment 'Indicates whether this store offers curbside pickup service for online orders (click-and-collect). Impacts omnichannel fulfillment strategy, parking allocation, and staffing.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsHomeDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Home Delivery' ;
    rdfs:comment 'Indicates whether this store serves as a fulfillment center for home delivery orders. Impacts last mile delivery (LMD) operations, inventory allocation, and order management system (OMS) integration.' ;
    rdfs:domain ind:StoreLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the store location (e.g., America/New_York, America/Chicago). Used for scheduling, reporting, and operational coordination across regions.' ;
    rdfs:domain ind:Grocery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueTargetMax rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target Max' ;
    rdfs:comment 'Maximum annual revenue target for stores of this format, in USD. Used for comp sales performance tracking and store clustering.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTargetMin rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target Min' ;
    rdfs:comment 'Minimum annual revenue target for stores of this format, in USD. Used for comp sales performance tracking and store clustering.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bakeryIncluded rdf:type rdf:Property ;
    rdfs:label 'Bakery Included' ;
    rdfs:comment 'Indicates whether stores of this format include an in-store bakery department.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalInvestmentTypical rdf:type rdf:Property ;
