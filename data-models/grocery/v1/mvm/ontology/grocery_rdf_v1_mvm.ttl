ind:daysToExpiryAtCheck rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry At Check' ;
    rdfs:comment 'Number of calendar days remaining until the lot expires at the moment of the check.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
    rdfs:comment 'JSON-encoded snapshot of key fields captured at the time of the rotation check for downstream processing.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorizes the event; fixed value \'rotation_check\' for this product.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rotation Check Timestamp' ;
    rdfs:comment 'Date and time when the rotation check was performed.' ;
    rdfs:domain ind:PerishableRotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptedQuantity rdf:type rdf:Property ;
    rdfs:label 'Accepted Quantity' ;
    rdfs:comment 'Units approved for inventory after quality and compliance checks.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsdVendorIdentifier rdf:type rdf:Property ;
    rdfs:label 'Dsd Vendor Identifier' ;
    rdfs:comment 'Identifier used for Direct Store Delivery vendors that may differ from the master vendor ID.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'Quantity of units expected on the purchase order or transfer.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Receiving Record Status' ;
    rdfs:comment 'Current processing status of the receiving record.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingType rdf:type rdf:Property ;
    rdfs:label 'Receiving Type' ;
    rdfs:comment 'Indicates how the goods arrived: distribution center sourced, direct store delivery, or inter-location transfer.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refusedQuantity rdf:type rdf:Property ;
    rdfs:label 'Refused Quantity' ;
    rdfs:comment 'Quantity the DSD vendor refused to accept back (e.g., for damaged pallets).' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
