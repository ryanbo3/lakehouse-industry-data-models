    rdfs:range xsd:string .

ind:economicOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Economic Order Quantity' ;
    rdfs:comment 'Calculated optimal order size that minimizes total holding and ordering costs.' ;
