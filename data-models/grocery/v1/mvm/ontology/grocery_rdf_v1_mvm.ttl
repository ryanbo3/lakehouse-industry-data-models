ind:geographicBoundaryDefinition rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Definition' ;
    rdfs:comment 'Textual description of the geographic coverage of the region, typically listing states, metro areas, or counties included (e.g., \'NY, NJ, CT, PA eastern counties\').' ;
    rdfs:domain ind:Region ;
