    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bogoOffersCount rdf:type rdf:Property ;
    rdfs:label 'Bogo Offers Count' ;
    rdfs:comment 'Number of Buy One Get One (BOGO) promotional offers included in this circular. [Moved from ad_circular: This is a derived aggregate count of BOGO offer placements within the circular. It is derivable by querying circular_offer_placement records joined to promo_offer where discount_type = \'BOGO\'. Storing it on ad_circular creates a denormalized redundancy that will drift out of sync as placements are added or removed. It should be removed from ad_circular and computed on demand.]' ;
    rdfs:domain ind:CircularOfferPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featureSize rdf:type rdf:Property ;
    rdfs:label 'Feature Size' ;
    rdfs:comment 'Physical or digital dimensions of the offer placement within the circular (e.g., \'4x6 inches\', \'300x250px\'). Specific to each offer-circular placement combination.' ;
    rdfs:domain ind:CircularOfferPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Classification of the feature format for this offer placement within the circular (e.g., full-page feature, half-page, thumbnail). Determined per placement, not per offer or per circular.' ;
    rdfs:domain ind:CircularOfferPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageNumber rdf:type rdf:Property ;
    rdfs:label 'Page Number' ;
    rdfs:comment 'The page number within the circular on which this offer placement appears. Belongs to the placement, not to the offer or the circular independently.' ;
    rdfs:domain ind:CircularOfferPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementPosition rdf:type rdf:Property ;
