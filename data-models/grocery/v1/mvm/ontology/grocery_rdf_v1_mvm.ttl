    rdfs:range xsd:string .

ind:primaryStateCode rdf:type rdf:Property ;
    rdfs:label 'Primary State Code' ;
    rdfs:comment 'Two-letter US state code representing the primary or largest state within the region\'s geographic boundary (e.g., NY, CA, TX).' ;
