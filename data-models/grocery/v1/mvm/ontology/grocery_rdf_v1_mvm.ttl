    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerName rdf:type rdf:Property ;
    rdfs:label 'Banner Name' ;
    rdfs:comment 'Human-readable name of the banner as displayed to customers and internal users.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerStatus rdf:type rdf:Property ;
    rdfs:label 'Banner Status' ;
    rdfs:comment 'Current lifecycle status of the banner.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bannerType rdf:type rdf:Property ;
    rdfs:label 'Banner Type' ;
    rdfs:comment 'Classification of the banner based on its market positioning and ownership model.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseFeePercent rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Percent' ;
    rdfs:comment 'Standard percentage of gross sales paid as franchise fee for stores under this banner.' ;
    rdfs:domain ind:Banner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFranchise rdf:type rdf:Property ;
    rdfs:label 'Is Franchise' ;
    rdfs:comment 'True if the banner operates primarily through franchise agreements.' ;
