ind:selfCheckoutEnabled rdf:type rdf:Property ;
    rdfs:label 'Self Checkout Enabled' ;
    rdfs:comment 'Indicates whether stores of this format typically include self-checkout capabilities.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellingAreaPercentage rdf:type rdf:Property ;
    rdfs:label 'Selling Area Percentage' ;
    rdfs:comment 'Percentage of total square footage allocated to customer-facing selling area (excluding backroom, receiving, offices). Used for space productivity analysis.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuCountMax rdf:type rdf:Property ;
    rdfs:label 'Sku Count Max' ;
    rdfs:comment 'Maximum number of unique SKUs (Stock Keeping Units) typically carried in stores of this format. Used for assortment planning and inventory management.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
