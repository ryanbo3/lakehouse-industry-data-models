ind:refusedReason rdf:type rdf:Property ;
    rdfs:label 'Refused Reason' ;
    rdfs:comment 'Explanation for the DSD vendor\'s refusal.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Units rejected due to damage, spoilage, or non-conformance.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffName rdf:type rdf:Property ;
    rdfs:label 'Sign Off Name' ;
    rdfs:comment 'Name of the employee who signed off on the receipt.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Measured temperature of the product at receipt for cold-chain compliance.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Total Gross Amount' ;
    rdfs:comment 'Gross monetary value of the received goods before discounts or adjustments.' ;
