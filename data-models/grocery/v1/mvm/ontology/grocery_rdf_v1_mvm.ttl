    rdfs:range xsd:integer .

ind:departmentCountMin rdf:type rdf:Property ;
    rdfs:label 'Department Count Min' ;
    rdfs:comment 'Minimum number of merchandise departments typically found in stores of this format.' ;
    rdfs:domain ind:Format ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endcapCountTypical rdf:type rdf:Property ;
    rdfs:label 'Endcap Count Typical' ;
    rdfs:comment 'Typical number of endcap display locations in stores of this format. Endcaps are high-visibility end-of-aisle promotional displays.' ;
    rdfs:domain ind:Format ;
