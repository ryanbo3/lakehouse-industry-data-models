ind:clinicalValidity rdf:type rdf:Property ;
    rdfs:label 'Clinical Validity' ;
    rdfs:comment 'Evidence level supporting the clinical relevance of the assay results.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method used to detect variants (e.g., hybrid capture, amplicon, SNP array).' ;
