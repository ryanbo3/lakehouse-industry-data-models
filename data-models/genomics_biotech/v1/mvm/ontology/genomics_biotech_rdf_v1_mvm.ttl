ind:segmentChangeReason rdf:type rdf:Property ;
    rdfs:label 'Segment Change Reason' ;
    rdfs:comment 'Business reason for the most recent market segment classification change. Examples: product portfolio shift, regulatory status change, acquisition, business model pivot.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Segment Effective Date' ;
    rdfs:comment 'Date when the current market segment classification became effective. Used for tracking segment transitions and historical analysis.' ;
    rdfs:domain ind:Account ;
