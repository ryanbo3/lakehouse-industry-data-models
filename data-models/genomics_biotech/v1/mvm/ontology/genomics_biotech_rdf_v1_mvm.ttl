    rdfs:comment 'Standard list price for the assay before discounts.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleRequirements rdf:type rdf:Property ;
    rdfs:label 'Sample Requirements' ;
    rdfs:comment 'Specific collection, volume, or preservation requirements for the specimen.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRequirements rdf:type rdf:Property ;
