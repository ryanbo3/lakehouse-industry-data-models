    rdfs:range xsd:string .

ind:applicableJobRoles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Roles' ;
    rdfs:comment 'Comma-separated list or description of job roles, titles, or functions to which this curriculum applies (e.g., \'Manufacturing Operator\', \'Quality Control Analyst\', \'Laboratory Technician\').' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Role or individual authorized to approve this training curriculum (e.g., \'Quality Assurance Manager\', \'Training Director\').' ;
