ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional job title or role of the contact within their organization (e.g., Principal Investigator, Lab Director, Procurement Officer, Clinical Genomics Specialist).' ;
    rdfs:domain ind:Contact ;
