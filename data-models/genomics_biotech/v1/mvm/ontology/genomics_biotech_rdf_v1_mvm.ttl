    rdfs:comment 'Indicates whether samples are de-identified for privacy.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diseaseFocus rdf:type rdf:Property ;
    rdfs:label 'Disease Focus' ;
    rdfs:comment 'Primary disease or condition the cohort targets.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityInclusion rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Inclusion' ;
    rdfs:comment 'Ethnicity groups included in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
