    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this segment is currently active and in use for customer classification (True) or has been retired/deprecated (False).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Requirement Flag' ;
    rdfs:comment 'Indicates whether accounts in this segment require explicit consent management for data processing and marketing communications (True) or operate under standard terms (False). Relevant for GDPR and HIPAA compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Standard contract duration in months for accounts in this segment (e.g., 12 for annual contracts, 36 for multi-year agreements). Null if no standard term applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Standard credit limit assigned to accounts in this segment for credit risk management. Expressed in USD. Null if no standard limit applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Primary geographic scope or region where this segment operates (e.g., GLOBAL for worldwide segments, USA for US-only, EMEA for Europe/Middle East/Africa). [ENUM-REF-CANDIDATE: GLOBAL|NORTH_AMERICA|EMEA|APAC|LATAM|USA|MULTI_REGION — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
