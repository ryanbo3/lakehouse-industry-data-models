    rdfs:comment 'Family name or surname of the contact person.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Original source through which this contact was acquired (web, referral, conference, trade_show, partner, direct_sales, advertisement, other). [ENUM-REF-CANDIDATE: web|referral|conference|trade_show|partner|direct_sales|advertisement|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
