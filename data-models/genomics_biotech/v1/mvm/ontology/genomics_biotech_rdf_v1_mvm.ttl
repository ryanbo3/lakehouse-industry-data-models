ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training event indicating the business driver or trigger for the training requirement. [ENUM-REF-CANDIDATE: initial|refresher|requalification|change_control|capa_driven|role_based|regulatory_mandated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDepartments rdf:type rdf:Property ;
