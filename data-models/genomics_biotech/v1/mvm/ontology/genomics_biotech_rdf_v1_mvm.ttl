# RDFS Schema for Business: Genomics Biotech

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/genomics_biotech#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Genomics Biotech ---
ind:GenomicsBiotech rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Genomics Biotech' ;
    rdfs:comment 'Genomics and Biotechnology is a rapidly evolving industry developing sequencing, array-based, and gene-editing solutions for genetic analysis, enabling advances in precision medicine, drug development, agricultural genomics, and diagnostics.' .

# --- Domain Classes ---
ind:Sequencing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Sequencing' ;
    rdfs:comment 'Core NGS operations including WGS, WES, targeted sequencing, library preparation, flow cell management, multiplexing, demultiplexing, and raw data generation. Manages sequencing runs, read quality (Phred scores), coverage depth, read length, and FASTQ output. Central to genomic data production workflows integrated with Illumina BaseSpace Sequence Hub.' .

ind:Sample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Sample' ;
    rdfs:comment 'Authoritative SSOT for biological sample identity, chain-of-custody, and lifecycle tracking across accessioning, aliquoting, storage, and disposal. Manages sample metadata, IRB consent linkage, PHI de-identification flags, specimen types, collection metadata, and LIMS-driven workflow assignments in LabVantage. Underpins traceability for clinical, research, and QC specimens.' .

ind:Instrument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Instrument' ;
    rdfs:comment 'Manages the full lifecycle of sequencing instruments, array scanners, PCR/qPCR platforms, liquid handlers, and gene-editing equipment — covering engineering specifications, installation qualification (IQ/OQ/PQ), calibration records, preventive maintenance schedules, performance telemetry, and field service events. Integrates with ServiceNow for field service dispatch and SAP PM for asset accounting.' .

ind:Reagent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Reagent' ;
    rdfs:comment 'Governs the lifecycle of reagents, consumables, and biochemical inputs — including library preparation kits, flow cells, CRISPR reagents, PCR/qPCR master mixes, enzymes, buffers, and array hybridization chips. Owns LOT traceability, COA records, SDS documentation, expiry management, storage requirements, usage tracking, and GMP-compliant release status.' .

ind:Bioinformatics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Bioinformatics' ;
    rdfs:comment 'Owns the computational pipeline ecosystem for genomic data processing — alignment (BAM), variant calling (VCF), annotation pipelines, CNV/SNP analysis, MAF calculations, and HPC/cloud (AWS) job orchestration. Manages pipeline versions, algorithm parameters, run parameters, compute resource consumption, reference genome linkages, and data lineage from raw FASTQ to interpreted genomic results.' .

ind:Clinical rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Clinical' ;
    rdfs:comment 'SSOT for clinical genomics assay management — IVD and LDT test catalog, CLIA/CAP-accredited test orders, clinical validity and analytical performance (LOD, sensitivity, specificity), patient-level genomic results, clinical report generation, variant interpretation records, and PHI-compliant clinical workflows. Bridges clinical laboratory operations with regulatory submissions and precision medicine applications.' .

ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identities — research institutions, clinical laboratories, biopharma partners, agricultural genomics clients, OEM accounts, and individual researchers. Owns customer profiles, account hierarchies, contacts, segmentation (RUO vs. IVD/clinical), consent records, technical requirements, service agreements, and relationship history. Master data managed via Salesforce CRM.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Order' ;
    rdfs:comment 'Manages the complete commercial order lifecycle — quotes, sales orders, fulfillment instructions, shipment tracking, returns, and customer acceptance — for instruments, reagents, consumables, sequencing services, and software. Integrates SAP SD for order-to-cash processing and Salesforce CRM for opportunity-to-order handoff. SSOT for order status, SLA-driven TAT commitments, and delivery records.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative catalog of all commercial offerings — sequencing platforms, array products, gene-editing tools (CRISPR), reagent kits, consumables, bioinformatics software licenses, and services. Owns SKU definitions, BOM linkages, product specifications, regulatory classifications (RUO/IVD/CE-IVD), ASP, and product lifecycle stages from R&D through commercialization and end-of-life.' .

ind:Research rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Research' ;
    rdfs:comment 'Manages R&D project portfolios, experimental designs, molecular biology protocols, gene-editing (CRISPR) development programs, custom assay development, and IP-generating discoveries. Integrates Benchling for electronic lab notebook (ELN) records and molecular design. Tracks R&D spend, milestone achievement, collaboration agreements, IRB approvals, publications, and technology readiness levels.' .

ind:Manufacturing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Manufacturing' ;
    rdfs:comment 'GMP-compliant production of instruments, reagent kits, arrays, flow cells, and consumables — encompassing work orders, MES-driven production steps, BOM execution, batch records, in-process QC checkpoints, yield tracking, equipment qualification, and process validation. Integrates SAP PP/QM and MES for shop-floor execution. Ensures traceability from raw material receipt through finished goods release.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Manages the end-to-end supply chain for raw materials, components, and finished goods — including supplier master data, procurement, purchase orders, inbound logistics, warehouse inventory, demand planning, cold-chain handling, and distribution. Integrates SAP MM for procurement and inventory management. Supports COGS visibility and ensures uninterrupted supply of critical genomics inputs.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Quality' ;
    rdfs:comment 'Enterprise-wide quality management system encompassing QC testing, QA oversight, CAPA, deviation management, audit trails, SOP management, document control, training qualification tracking, and regulatory inspection readiness. Integrates Veeva Vault and MasterControl for controlled document management. Ensures compliance with GxP, ISO 13485, FDA 21 CFR Part 11, CLIA, and CAP requirements.' .

ind:Regulatory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Regulatory' ;
    rdfs:comment 'Manages regulatory submissions, approvals, and post-market surveillance across global jurisdictions — including FDA 510(k)/PMA filings, CE-IVD/IVDR technical files, EMA submissions, ICH dossiers, adverse event reporting, regulatory intelligence, and labeling compliance. Tracks submission status, agency correspondence, and IVD registration lifecycles. Integrates Veeva Vault for controlled regulatory document management.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:GenomicsBiotech ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Owns enterprise financial management — general ledger, cost centers, accounts payable/receivable, revenue recognition, budgeting, R&D capitalization, COGS allocation, financial consolidation, and SOX-compliant reporting. Manages EBITDA tracking, ROI analysis, multi-entity P&L, and capital expenditures. Integrates SAP FI/CO as the primary ERP financial system of record.' .

# --- Data Product Classes (Tables) ---
ind:Pipeline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline' ;
    rdfs:comment 'Master registry of all bioinformatics computational pipelines used at Genomics Biotech — including NGS alignment pipelines (BWA, STAR), variant calling pipelines (GATK, DeepVariant), CNV/SNP analysis pipelines, annotation pipelines (VEP, ANNOVAR), and MAF calculation workflows. Captures pipeline name, version, algorithm parameters, supported assay types (WGS, WES, targeted), reference genome compatibility, GxP validation status, and pipeline owner. This is the authoritative catalog of all pipeline definitions.' .

ind:PipelineVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline Version' ;
    rdfs:comment 'Authoritative master registry and versioned lifecycle record of all bioinformatics computational pipelines at Genomics Biotech. Each record represents a specific version of a pipeline — capturing pipeline identity (name, owner, category: alignment/variant-calling/annotation/CNV/MAF), supported assay types (WGS, WES, targeted panel, array), semantic version number, algorithm parameter configurations (name, type, default, allowed range, GxP-controlled flag), container image references (Docker/Singularity), reference genome compatibility (GRCh38, T2T), changelog, validation status (RUO vs IVD-validated), deprecation flag, and effective date range. Serves as the single source of truth for pipeline identity and the reproducibility-enabling version history from FASTQ to final output. All pipeline_run records reference this entity.' .

ind:PipelineRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline Run' ;
    rdfs:comment 'Transactional record of each individual execution of a bioinformatics pipeline — capturing pipeline_version reference, triggering sample or batch identifier, compute environment (HPC cluster/AWS/GCP), job submission and completion timestamps, wall-clock duration, CPU/memory peak consumption, run status (queued, running, completed, failed, cancelled), exit code, error message summary, output artifact locations, batch grouping reference, and initiating user/system. Central operational log for all pipeline executions supporting SLA tracking, failure triage, batch-level monitoring, cost attribution, and cohort-level result delivery.' .

ind:PipelineRunStep rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline Run Step' ;
    rdfs:comment 'Granular step-level execution records within a pipeline run — capturing individual tool invocations (e.g., BWA-MEM alignment, GATK HaplotypeCaller, Picard MarkDuplicates, VEP annotation), step order, input/output file paths, tool version, parameters applied, step status, duration, and resource consumption. Enables fine-grained debugging, performance profiling, and data lineage tracing at the tool level.' .

ind:ComputeJob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Compute Job' ;
    rdfs:comment 'Tracks individual HPC cluster and cloud compute jobs spawned by pipeline runs — including job scheduler ID (SLURM/LSF/PBS/AWS Batch), compute environment details (HPC node, EC2/GCE instance type, spot vs on-demand), requested and actual resources (CPU cores, memory GB, GPU, storage IOPS), job queue name and priority tier, timing (submission, start, end, wall-clock), exit status and error output, cost estimate (USD), and resource quota consumption against team/project allocations. Supports resource optimization, capacity planning, cloud cost governance, budget tracking, and chargeback reporting.' .

ind:AlignmentResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Alignment Result' ;
    rdfs:comment 'Stores the output metadata and QC metrics for each BAM/CRAM alignment produced by a pipeline run — including aligned BAM/CRAM file path, reference genome used (GRCh38/hg38, T2T), aligner tool and version, total reads, mapped reads percentage, duplicate rate, mean coverage depth, uniformity of coverage, insert size distribution, Phred score distribution, and alignment QC pass/fail status. Core output artifact of the alignment stage.' .

ind:VariantCallResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Variant Call Result' ;
    rdfs:comment 'Unified output record for all variant detection and genotyping results per sample per pipeline run — covering NGS variant calling (WGS/WES/targeted), array-based SNP genotyping, and targeted genotyping panels. Captures VCF/genotype file path, caller tool and version, call method discriminator (NGS variant calling, array genotyping, targeted panel), total variants/genotypes called, SNP/INDEL counts, individual genotype calls (rsID, chromosome, position, REF/ALT, zygosity, quality score, array probe ID where applicable), Ti/Tv ratio, dbSNP concordance, call rate, coverage at locus, QC pass/fail status, and filtering criteria applied. Supports GWAS, pharmacogenomics, oncology, clinical interpretation, ancestry, and agricultural genomics workflows.' .

ind:VariantAnnotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Variant Annotation' ;
    rdfs:comment 'Captures per-variant annotation records produced by annotation pipelines (VEP, ANNOVAR, SnpEff) — including chromosome, position, REF/ALT alleles, gene symbol, transcript ID, consequence type (missense, frameshift, splice-site), HGVS notation, ClinVar classification, gnomAD MAF, SIFT/PolyPhen scores, OncoKB tier, and annotation pipeline version. Provides the interpreted genomic context for each called variant.' .

ind:PipelineQcMetric rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline Qc Metric' ;
    rdfs:comment 'Stores structured QC metric records generated at each pipeline stage — including metric name (mean_coverage, pct_q30_bases, duplication_rate, on_target_rate, uniformity), metric value, unit, pass/fail threshold, QC tool (FastQC, Picard, MultiQC), pipeline run and step reference, evaluation timestamp, and failure flag with remediation notes when thresholds are breached. Enables automated QC gating, longitudinal QC trending, and systematic quality failure pattern analysis.' .

ind:GenomicArtifact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Genomic Artifact' ;
    rdfs:comment 'Master registry of all genomic data artifacts produced or consumed by bioinformatics pipelines — including FASTQ, BAM, CRAM, VCF, gVCF, BED, and annotation output files. Captures artifact type, file path (S3/HDFS/NFS), file size, checksum (MD5/SHA256), compression format, creation timestamp, pipeline run provenance, upstream sequencing run reference (flow cell, lane, barcode, demux batch), retention policy, and data classification (PHI, de-identified, research). Serves as the data asset inventory and input lineage anchor linking raw sequencing outputs to the bioinformatics processing layer.' .

ind:DataLineageEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Data Lineage Event' ;
    rdfs:comment 'Transactional record capturing each data transformation event in the bioinformatics processing chain — from raw FASTQ ingestion through alignment (BAM/CRAM), variant calling (VCF/gVCF), annotation, QC filtering, and clinical report generation. Records source artifact(s), target artifact(s), transformation tool and version, pipeline run step reference, timestamp, lineage event type (ingest, transform, filter, merge, split, annotate, export, archive), operator/system identity, and error/failure context when transformations fail. Supports GxP audit trails, HIPAA data traceability, 21 CFR Part 11 compliance, reproducibility requirements, and failure root-cause analysis.' .

ind:PipelineValidationStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bioinformatics ;
    rdfs:label 'Pipeline Validation Study' ;
    rdfs:comment 'Master record of formal analytical validation studies conducted on bioinformatics pipelines for IVD/LDT regulatory compliance — including study name, pipeline version validated, assay type, validation type (analytical sensitivity, specificity, reproducibility, accuracy), study protocol reference, validation status (in-progress, passed, failed), LOD established, regulatory submission reference (FDA, CE-IVD), and validation completion date. Required for CLIA/CAP and FDA IVD pipeline qualification.' .

ind:SequencingRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Sequencing Run' ;
    rdfs:comment 'Core master record for each NGS sequencing run executed on an instrument. Captures run identity, instrument assignment, flow cell, run mode (WGS, WES, targeted), read length, paired-end configuration, run status (queued, in-progress, completed, failed), start/end timestamps, operator, reagent kit lot, BaseSpace run ID, total cycles, and run-level QC pass/fail outcome. This is the central operational entity of the sequencing domain — every downstream FASTQ, QC metric, and library result traces back to a sequencing run.' .

ind:FlowCell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Flow Cell' ;
    rdfs:comment 'Master record for each physical flow cell consumable loaded onto a sequencing instrument. Tracks flow cell serial number, part number, lot number, flow cell type (e.g., S1, S2, S4, SP for NovaSeq; MID, HIGH for NextSeq), number of lanes, cluster density specification, maximum output (Gb), expiry date, storage conditions, receipt date, and current status (in-stock, loaded, consumed, failed). Links to reagent domain for procurement lineage and to sequencing_run for usage tracking.' .

ind:Library rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Library' ;
    rdfs:comment 'Master record representing a prepared sequencing library — the biochemically processed form of a biological sample ready for loading onto a flow cell. Captures library identity, source sample reference (FK to sample domain), preparation protocol and kit, insert size (bp), concentration (nM), quantification method (qPCR, Bioanalyzer, Qubit), library type (WGS, WES, amplicon, RNA-seq, ChIP-seq, targeted panel, methylation), adapter sequences, unique dual index (UDI) assignment, strand specificity, preparation date, operator, QC status (pass/fail/pending), volume remaining (µL), and storage location (plate/well). SSOT for library identity within the sequencing domain — the central entity linking sample preparation to sequencing output and the primary unit of work for coverage tracking.' .

ind:LibraryPrepRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Library Prep Run' ;
    rdfs:comment 'Transactional record capturing the execution of a library preparation workflow batch. Tracks prep run ID, protocol version, kit lot number, number of samples processed, start/end timestamps, operator, instrument used (e.g., liquid handler), fragmentation method (enzymatic, mechanical), end-repair and adapter ligation steps, PCR amplification cycles, final pooling volume, batch QC outcome, and any deviations from SOP. Enables traceability from raw sample to sequencing-ready library and supports GxP audit requirements.' .

ind:Pool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Pool' ;
    rdfs:comment 'Master record for a multiplexed pool of indexed libraries combined for co-sequencing on a single flow cell lane or entire flow cell. Captures pool identity, pooling strategy (equimolar, custom ratio, normalized), number of constituent libraries, total volume (µL), final concentration (nM), loading concentration for the target instrument and flow cell type, pooling date, operator, pool QC status (concentration verification via Qubit/qPCR, fragment size distribution via Bioanalyzer/TapeStation), expected per-library read depth targets, and pool expiry/stability window. Central to multiplexing operations — the pool is what physically gets loaded onto the sequencer and determines per-sample yield allocation.' .

ind:PoolLibrary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Pool Library' ;
    rdfs:comment 'Association entity linking libraries to pools, capturing the multiplexing relationship with its own business data. Records the library-to-pool assignment, index sequence (i7/i5), expected molar fraction (%), actual volume contributed (µL), loading ratio, and any index collision flags. Essential for demultiplexing traceability — enables reconstruction of which library contributed which reads in a pooled run.' .

ind:RunLane rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Run Lane' ;
    rdfs:comment 'Operational record representing a single lane within a sequencing run on a multi-lane flow cell. Captures lane number, assigned pool or library, loading concentration, cluster density (K/mm²), clusters passing filter (%), PhiX spike-in percentage, lane-level QC status, and lane yield (Gb). Enables per-lane performance monitoring and troubleshooting of lane-specific failures on instruments such as NovaSeq 6000 with S-series flow cells.' .

ind:RunQcMetric rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Run Qc Metric' ;
    rdfs:comment 'Transactional record storing quantitative quality metrics for sequencing runs at multiple granularity levels: run-level, lane-level, and per-library. Instrument-level metrics include Q30%, mean Phred score, error rate, cluster density, clusters passing filter, yield (Gb), PhiX alignment and error rate, and undetermined index rate. Per-library coverage metrics include mean/median coverage depth (X), coverage uniformity (%), fraction of bases at ≥10X/≥20X/≥30X/≥100X thresholds, on-target rate (% for WES/targeted), duplication rate (%), insert size statistics, and GC bias. Each metric row is attributed to a run, optionally a lane, and optionally a library — enabling both run-level pass/fail determination and per-library coverage adequacy assessment. Sourced from Illumina InterOp files, BaseSpace, bcl2fastq stats, and alignment tools (Picard, samtools). Supports instrument performance trending, assay-specific coverage thresholds, and GxP compliance reporting.' .

ind:DemuxResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Demux Result' ;
    rdfs:comment 'Transactional record capturing the output of the demultiplexing process (bcl2fastq / DRAGEN BCL Convert) for each library within a pooled sequencing run. Records library ID, run ID, lane, index sequence matched, read count assigned, percentage of reads assigned, undetermined read count, mismatch tolerance used, demux software version, demux completion timestamp, and demux QC pass/fail status. Provides the authoritative link between a sequencing run and the resulting per-sample FASTQ files.' .

ind:FastqFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Fastq File' ;
    rdfs:comment 'Master record representing a FASTQ output file generated from demultiplexing. Captures file name, file path (cloud storage URI on BaseSpace/S3), file size (bytes), read number (R1/R2/I1/I2), total read count, mean read length (bp), compression format (gzip), MD5 checksum, generation timestamp, associated library and run, BaseSpace dataset ID, retention policy, and data classification (PHI/non-PHI). SSOT for raw sequencing data file inventory — the primary output artifact of the sequencing domain.' .

ind:CoverageStat rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Coverage Stat' ;
    rdfs:comment 'Transactional record storing per-library sequencing coverage statistics computed post-demultiplexing. Captures mean coverage depth (X), median coverage depth, coverage uniformity (%), fraction of bases at ≥10X, ≥20X, ≥30X, ≥100X thresholds, on-target rate (% for targeted/WES), duplication rate (%), insert size mean and standard deviation, GC bias metric, and coverage QC pass/fail against assay-specific thresholds. Enables assessment of whether a library meets minimum coverage requirements for downstream bioinformatics analysis.' .

ind:IndexSet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Index Set' ;
    rdfs:comment 'Controlled reference master for sequencing index (barcode) sets used in library multiplexing. Captures index set name, manufacturer, index type (single/dual/UDI/combinatorial), i7 and i5 sequences, index length (bp), compatible library prep kits and instruments, Hamming distance from nearest neighbor in the set, color balance properties, and approval status. Managed by sequencing operations to prevent index collisions during pool design and ensure reliable demultiplexing. Updated when new index chemistries are validated.' .

ind:SequencingProtocol rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Sequencing Protocol' ;
    rdfs:comment 'Reference master for approved sequencing protocols and run configurations. Captures protocol name, version, sequencing application type (WGS, WES, targeted panel, RNA-seq, amplicon, methylation), instrument compatibility, read configuration (single-end/paired-end), read lengths (R1/R2 cycles), index read cycles, recommended coverage target, minimum Q30 threshold, approved library prep kits, SOP document reference, effective date, and approval status. Governs which run parameters are permissible for each assay type and supports GxP compliance.' .

ind:RunSampleSheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sequencing ;
    rdfs:label 'Run Sample Sheet' ;
    rdfs:comment 'Transactional record representing the sample sheet submitted to configure a sequencing run on an Illumina instrument. Captures sample sheet format version (v1/v2), associated run and instrument, flow cell type, operator, submission timestamp, sample manifest (sample IDs, index assignments, project groupings), override cycles string, adapter sequences, application settings, and validation status. The sample sheet is the authoritative GxP-controlled input document that drives both instrument run setup and downstream demultiplexing configuration.' .

ind:SampleSpecimen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Sample Specimen' ;
    rdfs:comment 'Core master entity representing a biological specimen collected from a subject (human, animal, or environmental source). Captures specimen identity, type classification (blood, tissue, saliva, FFPE, cfDNA, etc.), collection site, collection date/time, collection method, volume/mass, matrix type, PHI de-identification flag and tier, IRB protocol linkage, consent status, current lifecycle status (accessioned, in-processing, extracted, archived, depleted, disposed), and LIMS accession number from LabVantage. This is the SSOT for all biological material entering the genomics workflow and the anchor entity for chain-of-custody traceability.' .

ind:Aliquot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Aliquot' ;
    rdfs:comment 'Represents a physical sub-division of a parent specimen created during aliquoting workflows, including the container holding it. Tracks aliquot volume, concentration, unit of measure, container identity (barcode, type, manufacturer, lot number, material, volume capacity), position in storage rack/plate/well, aliquot purpose (sequencing, QC, archive, backup), current lifecycle status, and container status (in-use, empty, discarded). Maintains parent-child lineage back to the originating specimen and supports multi-level aliquot hierarchies (aliquot-of-aliquot). Also serves as the master record for empty container inventory when pre-registered in LabVantage. Managed with barcode-driven tracking.' .

ind:Accession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Accession' ;
    rdfs:comment 'Transactional record capturing the formal intake and registration of a specimen into the laboratory information management system (LabVantage). Records accession number (LIMS-generated), receipt date/time, receiving lab site, courier/shipment reference, condition on arrival (acceptable, compromised, rejected), accessioning technician, priority level (STAT, routine), and linkage to the originating clinical order (FK to order domain). Represents the chain-of-custody entry point — the moment a specimen transitions from external custody to laboratory custody.' .

ind:BiobankLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Biobank Location' ;
    rdfs:comment 'Master data entity representing a physical storage location within the biorepository hierarchy — freezer, shelf, rack, box, and well/position. Captures location code, storage unit type, temperature setpoint (e.g., -80°C, -196°C LN2, 4°C, RT), facility site, capacity (total positions, occupied positions), and current operational status. Enables precise chain-of-custody tracking and retrieval of specimens and aliquots.' .

ind:StorageEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Storage Event' ;
    rdfs:comment 'Transactional record of every storage state change and custody transfer for a specimen or aliquot — initial placement, relocation, retrieval, return, and inter-section transfers. Captures event type, source location, destination location, event timestamp, operator ID, custodian identity, reason code (routine storage, retrieval for assay, transfer to external site, quarantine), temperature excursion flag, and electronic acknowledgment. Provides the full chain-of-custody audit trail required for GxP, CLIA, and forensic genomics compliance. Serves as the immutable custody log for all in-facility specimen movements.' .

ind:SampleConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Sample Consent Record' ;
    rdfs:comment 'Authoritative record of IRB-approved informed consent obtained from a research subject or patient for specimen collection and use. Captures consent form version, IRB protocol number, consent date, consent type (broad, specific, re-consent), scope of permitted use (research, clinical, commercial, data sharing), withdrawal date if applicable, and PHI handling authorization. Links specimen to the governing ethical and regulatory framework. Supports HIPAA, GDPR, and NIH Genomic Data Sharing Policy compliance.' .

ind:Subject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Subject' ;
    rdfs:comment 'De-identified or pseudonymized master record of the biological source individual (research participant, patient, donor, or animal model) from whom specimens are collected. Stores subject code, species, biological sex, year of birth (not full DOB for de-identification), ethnicity/ancestry group (for population genomics), disease indication, de-identification method applied (HIPAA Safe Harbor or Expert Determination), de-identification tier (fully de-identified, pseudonymized, limited dataset), and re-identification risk level. Does NOT store direct PHI — PHI linkage is managed via consent_record and access-controlled separately per HIPAA Safe Harbor. Supports cohort membership tracking via external study enrollment references.' .

ind:CollectionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Collection Event' ;
    rdfs:comment 'Transactional record of the physical specimen collection activity. Captures collection date/time, collection site (anatomical location or environmental site), collection method (venipuncture, biopsy, swab, saliva kit, liquid biopsy), collector ID, collection kit lot number, pre-analytical conditions (fasting status, time from collection to processing), and any collection deviations. Provides the pre-analytical metadata critical for NGS data quality interpretation.' .

ind:Extraction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Extraction' ;
    rdfs:comment 'Records the nucleic acid extraction process applied to a specimen or aliquot — producing DNA, RNA, cfDNA, gDNA, or total nucleic acid. Captures extraction method (column-based, magnetic bead, manual, automated), instrument used, extraction kit lot number, input material type and volume, elution volume, yield (ng/µL), purity ratios (A260/A280, A260/A230), extraction date, operator, and pass/fail QC determination. Critical pre-analytical step linking specimen to library preparation in the NGS workflow.' .

ind:QcMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Qc Measurement' ;
    rdfs:comment 'Captures quantitative and qualitative QC measurements performed on specimens, aliquots, or extracted nucleic acids at any stage of the sample lifecycle. Records measurement type (Qubit fluorometry, NanoDrop spectrophotometry, Bioanalyzer/TapeStation electrophoresis, DIN score, RIN score, fragment size distribution), instrument ID, reagent lot, measured value, unit, reference range, pass/fail flag, and measurement timestamp. Supports LOD tracking and pre-analytical QC gating decisions.' .

ind:Container rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Container' ;
    rdfs:comment 'Master entity representing a physical container (tube, plate, vial, cryovial, microplate well) used to hold a specimen or aliquot. Captures container barcode, container type, manufacturer, lot number, material (polypropylene, glass), volume capacity, current contents reference, and container status (empty, in-use, discarded). Enables barcode-driven sample tracking and container inventory management within LabVantage.' .

ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Project' ;
    rdfs:comment 'Master record for R&D projects and programs within the research domain — covering CRISPR gene-editing development programs, custom assay development initiatives, novel sequencing chemistry research, and platform innovation projects. Tracks project title, type (discovery, development, validation), technology readiness level (TRL), strategic priority, target indication or application area, project phase, start/end dates, budget allocation, principal investigator, sponsoring business unit, IP classification, and current status. Serves as the authoritative SSOT for all R&D project identity and lifecycle management.' .

ind:Milestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Milestone' ;
    rdfs:comment 'Tracks discrete, measurable milestones and formal technology readiness assessments within R&D projects — including go/no-go decision gates, IND-enabling study completions, proof-of-concept readouts, TRL advancement evaluations (TRL 1-9 scale), and regulatory pre-submission milestones. Captures milestone name, type (decision_gate, deliverable, trl_assessment, regulatory_checkpoint), planned date, actual completion date, success criteria, outcome (met/missed/deferred), TRL score (for TRL-type milestones), assessment rationale, evidence artifacts, advancement criteria for next level, accountable owner, and associated deliverable. Enables milestone-based R&D spend recognition, portfolio stage-gating from basic research through product development readiness, and structured progress reporting.' .

ind:Experiment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Experiment' ;
    rdfs:comment 'Core entity representing individual scientific experiments and their associated electronic lab notebook (ELN) records — including CRISPR editing efficiency assays, library preparation optimization runs, sequencing chemistry validation experiments, and reagent formulation trials. Captures experiment title, hypothesis, experimental design type (controlled, factorial, dose-response), associated protocol reference, Benchling ELN entry ID, assigned scientist, lab location, start/end dates, status (planned, in-progress, completed, failed), outcome summary, ELN entry type (observation, result, protocol execution, data analysis), review status (unreviewed, peer-reviewed, supervisor-approved), and data integrity signature. Serves as the unified scientific record integrating experimental design with auditable notebook documentation required for IP prosecution and GxP compliance.' .

ind:ResearchProtocol rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Research Protocol' ;
    rdfs:comment 'Master catalog of molecular biology and laboratory protocols used in R&D — including CRISPR guide RNA design protocols, library preparation SOPs, PCR/qPCR assay protocols, cell transfection procedures, and sequencing run setup protocols. Tracks protocol name, version, type (SOP, method, assay protocol), author, approval status, effective date, superseded version, associated Benchling protocol ID, applicable instrument platforms, and regulatory classification (GLP, RUO). Serves as the authoritative protocol library for the research domain.' .

ind:CrisprConstruct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Crispr Construct' ;
    rdfs:comment 'Master registry for molecular biology constructs and design artifacts developed within R&D programs — including CRISPR guide RNA (gRNA) sequences, Cas protein variants (Cas9, Cas12, Cas13), base editors, prime editors, delivery vector configurations, plasmid maps, oligo/primer designs, gene synthesis constructs, and expression vector configurations. Captures construct name, type (crispr_grna, cas_variant, plasmid, oligo, gene_fragment, expression_vector), target gene or locus, genomic coordinates (GRCh38/hg38), sequence data reference (Benchling entity ID), editing modality (knockout, knock-in, base edit — for CRISPR types), delivery format (plasmid, RNP, LNP, AAV), design tool/algorithm used, Benchling molecular design reference, design status (draft, reviewed, approved, deprecated), IP status, and development stage. Serves as the unified molecular construct registry bridging Benchling ELN with the broader research data model and IP portfolio management.' .

ind:AssayDevelopment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Assay Development' ;
    rdfs:comment 'Tracks custom assay development projects from feasibility through analytical validation — including NGS-based panel assays, qPCR diagnostic assays, SNP genotyping arrays, CNV detection assays, methylation assays, and CRISPR editing efficiency readouts. Captures assay name, type (IVD, RUO, LDT), target analyte/biomarker, intended use, development phase (feasibility, optimization, pre-validation, analytical validation, clinical validation), performance characteristics (LOD, LOQ, analytical sensitivity/specificity, precision, reproducibility), target TAT, regulatory pathway (FDA 510(k), CE-IVD, CLIA LDT), and parent R&D project. Bridges R&D discovery with clinical/commercial assay deployment.' .

ind:Spend rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Spend' ;
    rdfs:comment 'Transactional record of R&D expenditure at the project and cost-center level — capturing actual spend events including personnel costs (FTE allocation), external CRO/CMO service fees, reagent and consumable purchases, instrument depreciation allocations, and HPC/cloud compute costs. Tracks spend date, cost category, cost center, GL account reference, amount, currency, capitalization eligibility (ASC 730 / IFRS IAS 38), and approval status. Enables R&D capitalization decisions, budget vs. actuals tracking, and EBITDA impact reporting. Complements the finance domain\'s general ledger without duplicating it.' .

ind:CollaborationAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Collaboration Agreement' ;
    rdfs:comment 'Master record for external R&D collaboration agreements — including academic partnerships (MIT, Broad Institute, Sanger), biopharma co-development deals, CRO/CDMO service agreements, government grants (NIH, BARDA, DARPA), and industry consortium memberships (GA4GH, ASHG). Captures agreement title, partner organization, agreement type (sponsored research, co-development, licensing-in, material transfer, data sharing), effective/expiration dates, financial terms, IP ownership and licensing provisions, publication rights and embargo periods, exclusivity scope, data sharing obligations, IRB requirements, and status. Distinct from commercial contracts — these are research-specific partnerships.' .

ind:IrbSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Irb Submission' ;
    rdfs:comment 'Tracks Institutional Review Board (IRB) submissions and approvals for human subjects research conducted or sponsored by Genomics Biotech — including genomic data studies, clinical sample collection protocols, and precision medicine research programs. Captures submission date, IRB board name, protocol title, study type, risk classification, approval status, approval date, expiration date, amendment history count, HIPAA waiver status, PHI handling classification, and associated R&D project. Ensures compliance with NIH Genomic Data Sharing Policy, HIPAA, and GDPR for human genomic research.' .

ind:IpDisclosure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Ip Disclosure' ;
    rdfs:comment 'Master record for intellectual property disclosures generated from R&D activities — including novel sequencing chemistries, CRISPR construct innovations, bioinformatics algorithm inventions, and assay method discoveries. Captures disclosure title, disclosure date, inventors, invention type (composition of matter, method, software), associated R&D project, technology area, novelty assessment status, prior art search status, patent filing decision (file/abandon/trade secret), and assigned IP counsel. Serves as the SSOT for IP-generating discoveries originating in the research domain.' .

ind:Publication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Publication' ;
    rdfs:comment 'Tracks scientific publications, conference presentations, and preprints authored or co-authored by Genomics Biotech R&D staff — including peer-reviewed journal articles, Nature/Science/Cell publications, conference abstracts (ASHG, AGBT, AACR), and bioRxiv/medRxiv preprints. Captures title, authors, publication type, journal/conference name, submission date, acceptance date, publication date, DOI, associated R&D project, IP clearance status, embargo flag, and open-access classification. Supports publication strategy, IP protection timing, and scientific reputation management.' .

ind:Grant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Grant' ;
    rdfs:comment 'Master record for external research grants awarded to or applied for by Genomics Biotech — including NIH R01/R21/SBIR grants, BARDA contracts, NSF awards, EU Horizon grants, and philanthropic research funding. Captures grant title, funding agency, grant number, program officer, award type, application submission date, award date, total award amount, indirect cost rate, project period start/end, reporting requirements (RPPR schedule, final report deadlines), compliance obligations (NIH Genomic Data Sharing Policy), report submission tracking (type, period, due date, submission status, key findings), and associated R&D projects. Enables grant portfolio management, compliance tracking, and audit readiness for federally funded research.' .

ind:MolecularDesign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Molecular Design' ;
    rdfs:comment 'Master entity for molecular biology design artifacts created in Benchling — including plasmid maps, oligo sequences, primer designs, gRNA designs, gene synthesis constructs, and expression vector configurations. Captures design name, design type (plasmid, oligo, gRNA, gene fragment), sequence data reference (Benchling entity ID), target gene or locus, design tool/algorithm used, design status (draft, reviewed, approved, deprecated), associated experiment or CRISPR construct, and IP flag. Serves as the molecular design registry bridging Benchling ELN with the broader research data model.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Header' ;
    rdfs:comment 'Core commercial order record representing a confirmed customer purchase of instruments, reagent kits, consumables, sequencing services, or software licenses. Integrates with ERP order-to-cash processing and CRM opportunity-to-order handoff. Captures order number, order type (instrument, reagent, service, software), order date, requested delivery date, confirmed ship date, order status (open, in-fulfillment, shipped, delivered, cancelled), ERP sales document number, CRM opportunity ID, customer account ID, ship-to and bill-to party references, incoterms, payment terms, currency, total net value, total tax amount, total order value, SLA tier, TAT commitment date, order source channel (direct, distributor, OEM, e-commerce), RUO/IVD classification, export control flag, and GxP-relevant order flag.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Line' ;
    rdfs:comment 'Individual line item within a sales order representing a specific SKU, product catalog entry, or sequencing service. Captures line item number, SAP item category, product SKU, product description, ordered quantity, unit of measure, confirmed quantity, open quantity, net unit price, line discount amount, line net value, tax code, tax amount, requested delivery date per line, confirmed delivery date, line status (open, partially-shipped, fully-shipped, cancelled), lot number reference, batch number, RUO/IVD designation, reagent kit configuration, instrument model reference, and sequencing service type (WGS, WES, targeted panel).' .

ind:Quotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Quotation' ;
    rdfs:comment 'Pre-order commercial quotation generated for a customer opportunity, representing a formal price offer for instruments, reagent kits, consumables, sequencing services, or software. Sourced from ERP quotation processing with upstream linkage to CRM opportunity management. Captures quotation number, ERP quotation document number, CRM opportunity ID, quotation date, valid-from date, valid-to date, quotation status (draft, submitted, accepted, rejected, expired), customer account ID, total quoted value, currency, discount tier, pricing conditions applied, special pricing justification, RUO/IVD classification, and conversion-to-order flag.' .

ind:QuotationLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Quotation Line' ;
    rdfs:comment 'Individual line item within a commercial quotation specifying a product SKU, service offering, or instrument configuration with associated pricing. Captures quotation line number, product SKU, product description, quoted quantity, unit of measure, list price, quoted unit price, discount percentage, line net value, pricing condition type, reagent kit configuration details, instrument model, sequencing service specification (read length, coverage depth, flow cell type), and line-level RUO/IVD designation.' .

ind:Delivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery' ;
    rdfs:comment 'Outbound delivery document representing the physical fulfillment instruction for one or more order lines — covering instruments, reagent kits, consumables, and flow cells. Sourced from ERP outbound delivery processing. Captures delivery document number, delivery type, delivery date, goods issue date, goods issue status, warehouse number, shipping point, carrier name, carrier SCAC code, tracking number, shipment method (ground, air, cold-chain), cold-chain requirement flag, temperature range requirement, packaging type, total gross weight, total net weight, number of packages, incoterms, export declaration number, dangerous goods flag, and SDS reference.' .

ind:DeliveryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Line' ;
    rdfs:comment 'Individual line item within an outbound delivery document specifying the exact product, lot, batch, and quantity being shipped. Captures delivery line number, product SKU, product description, delivery quantity, unit of measure, lot number (LOT), batch number, serial number (for instruments), storage location, pick status, pack status, goods issue quantity, COA reference number, expiry date for reagents/consumables, cold-chain handling instruction, and hazardous material classification.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical shipment record tracking the movement of one or more deliveries from Genomics Biotech warehouse to the customer site. Captures shipment number, carrier name, carrier tracking number, shipment status (booked, in-transit, out-for-delivery, delivered, exception), ship date, estimated delivery date, actual delivery date, origin facility, destination address, shipment method, cold-chain monitoring flag, temperature excursion flag, temperature log reference, proof-of-delivery reference, carrier SLA breach flag, and TAT compliance status.' .

ind:ReturnAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Return Authorization' ;
    rdfs:comment 'Customer return authorization and processing record for instruments, reagent kits, consumables, or flow cells that are defective, expired, or incorrectly shipped. Sourced from ERP returns processing. Captures return order number, original sales order reference, return reason code (defective, wrong-item, expired, over-shipment, customer-cancellation), return authorization number (RMA), return status (requested, authorized, in-transit, received, inspected, credited), customer account ID, return quantity, return value, credit memo reference, QC inspection result upon receipt, disposition code (restock, quarantine, destroy), and GMP deviation flag.' .

ind:StatusEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status Event' ;
    rdfs:comment 'Immutable event log capturing every status transition in the lifecycle of a sales order — from order creation through fulfillment, shipment, delivery, and closure. Enables SLA-driven TAT tracking and order lifecycle audit. Captures event timestamp, order ID, previous status, new status, status change reason, triggered-by system (SAP SD, Salesforce, manual), triggered-by user ID, SLA milestone flag (e.g., order-confirmed, shipped-on-time, delivered-on-time), TAT elapsed hours at transition, and SLA breach indicator.' .

ind:FulfillmentInstruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fulfillment Instruction' ;
    rdfs:comment 'Operational directive translating a confirmed sales order into specific warehouse, logistics, or field service execution tasks. Covers standard pick-pack-ship, cold-chain logistics coordination (dry ice, controlled-rate shipping for enzymes/reagents), instrument installation scheduling with field service engineers, sequencing service sample-kit dispatch, and software license activation. Captures instruction type (ship, install, service-dispatch, activate), execution status, assigned facility or field team, priority level, special handling codes, scheduled execution date, TAT deadline, and completion confirmation. Serves as the orchestration layer between commercial order management and physical/digital fulfillment.' .

ind:CreditMemo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Credit Memo' ;
    rdfs:comment 'Credit memo record issued to customers following approved returns, billing corrections, pricing disputes, or service failures — linked to the originating sales order and return order. Sourced from ERP billing/credit processing. Captures credit memo number, ERP billing document number, linked return order ID, linked original sales order ID, credit memo type (return-credit, price-correction, goodwill, service-failure), credit amount, currency, tax amount, credit reason code, approval status, approver ID, issue date, customer account ID, and accounting document reference. Triggers revenue reversal for milestone-based recognition on sequencing service orders.' .

ind:CustomerPo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Customer Po' ;
    rdfs:comment 'Customer purchase order record capturing the formal procurement document issued by the customer authorizing Genomics Biotech to fulfill a sales order. Serves as the contractual reference linking customer procurement systems to SAP SD. Captures customer PO number, customer account ID, PO issue date, PO value, currency, PO type (standard, blanket, framework, government), linked sales order ID, PO validity start date, PO validity end date, remaining PO balance, PO status (open, partially-consumed, fully-consumed, cancelled), customer ERP system reference, and special terms noted on PO.' .

ind:Capa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Capa' ;
    rdfs:comment 'Corrective and Preventive Action (CAPA) master record tracking the full lifecycle of quality issues requiring systematic investigation and remediation. Captures CAPA initiation trigger (deviation, audit finding, complaint, OOS result), root cause analysis methodology (5-Why, Fishbone, FTA), effectiveness check criteria, GxP classification, regulatory impact assessment, and closure approval chain. Integrates with Veeva Vault for controlled document linkage and MasterControl for associated SOP updates. Supports FDA 21 CFR Part 820, ISO 13485 Clause 8.5.2, and ICH Q10 CAPA system requirements.' .

ind:Deviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Deviation' ;
    rdfs:comment 'GxP deviation record capturing any unplanned departure from an approved procedure, specification, or regulatory requirement during manufacturing, laboratory, or clinical operations. Tracks deviation type (process, equipment, material, environmental), GMP/GLP/GCP classification, severity grading, immediate containment actions, affected batch/lot numbers, product impact assessment, and disposition decision. Feeds into CAPA workflow when systemic root cause is identified. Supports FDA 21 CFR Part 211, ISO 13485, and GxP deviation management requirements.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Quality audit master record for internal, supplier, and regulatory inspection audits. Captures audit type (internal GMP, ISO 13485, CLIA/CAP, supplier qualification, regulatory inspection readiness), audit scope, lead auditor, audit team, scheduled and actual dates, facility/department scope, applicable regulatory standards, and overall audit outcome (conforming, nonconforming, needs improvement). SSOT for audit identity and scheduling — individual observations are tracked in audit_finding. Supports FDA 21 CFR Part 820, ISO 13485 Clause 9.2, and CAP/CLIA inspection readiness.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual observation or nonconformance identified during a quality audit. Captures finding classification (critical, major, minor, observation), regulatory citation, affected process or procedure, finding description, objective evidence, required response type (CAPA, correction, observation acknowledgment), response due date, and closure verification status. Links to parent audit record and may trigger CAPA initiation. Supports FDA Warning Letter response tracking, ISO 13485 nonconformance management, and CAP/CLIA deficiency resolution.' .

ind:ControlledDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Controlled Document' ;
    rdfs:comment 'Master record for all GxP-controlled documents managed through Veeva Vault and MasterControl — including SOPs, work instructions, specifications, validation protocols, batch records, and forms. Tracks document number, version, effective date, review cycle, document owner, approval workflow status, training requirement flag, superseded version linkage, and regulatory submission association. Enforces FDA 21 CFR Part 11 electronic signature requirements and ISO 13485 Clause 7.5 document control requirements. SSOT for document identity and version lifecycle across the quality management system.' .

ind:TrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Training Record' ;
    rdfs:comment 'Individual employee training qualification record tracking completion of GxP-required training assignments against controlled documents, SOPs, and regulatory curricula. Captures trainee identity, training assignment source (document revision, role-based curriculum, CAPA-driven retraining), training method (read-and-understand, classroom, OJT, e-learning), completion date, assessment score, trainer/assessor identity, qualification status, and retraining due date. Integrates with MasterControl training management module and Oracle Cloud HCM for workforce linkage. Supports FDA 21 CFR Part 211.68, ISO 13485 Clause 6.2, and CLIA personnel qualification requirements.' .

ind:TrainingCurriculum rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Training Curriculum' ;
    rdfs:comment 'Role-based GxP training curriculum definition specifying required training assignments for each job function, department, or regulatory qualification level. Captures curriculum name, applicable job roles, required controlled document list, training frequency (initial, annual, event-driven), assessment requirements, and regulatory basis (FDA 21 CFR Part 211.68, CLIA personnel standards). SSOT for training requirements by role — serves as the authoritative template from which individual training_record assignments are generated. Triggers automatic retraining upon linked controlled_document revision.' .

ind:Nonconformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Nonconformance' ;
    rdfs:comment 'Nonconforming material or product record (NCR) capturing instances where a product, reagent, instrument component, or raw material fails to meet defined specifications or acceptance criteria. Tracks nonconformance source (incoming inspection, in-process QC, final release, customer complaint), affected material/lot/batch, failure mode, quantity affected, disposition decision (use-as-is, rework, reject/scrap, return to supplier), and regulatory reportability assessment. Distinct from deviation (process departure) — NCR is material/product-focused. Supports SAP QM module integration and ISO 13485 Clause 8.3 nonconforming product control.' .

ind:QcResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Qc Result' ;
    rdfs:comment 'Quality control test result record capturing individual QC measurements and inspection outcomes for reagents, consumables, instruments, and in-process materials — including inspection lot context, test method, measured value, acceptance criteria, and pass/fail disposition' .

ind:OosInvestigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Oos Investigation' ;
    rdfs:comment 'Out-of-Specification (OOS) investigation record initiated when a QC result falls outside established acceptance criteria. Captures Phase I (laboratory investigation — analyst error, instrument malfunction, calculation error) and Phase II (full investigation — process failure, raw material failure, method failure) findings, invalidation justification if applicable, retesting authorization, assignable cause determination, and regulatory reportability assessment. Supports FDA OOS guidance (2006) compliance, CLIA proficiency testing failure investigation, and CAP accreditation requirements for laboratory investigations.' .

ind:Complaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Complaint' ;
    rdfs:comment 'Customer complaint record for quality-related issues reported by research institutions, clinical laboratories, biopharma partners, and agricultural genomics clients. Captures complaint source, product/lot implicated, complaint category (reagent performance, instrument malfunction, sequencing quality, bioinformatics pipeline error, labeling/packaging), patient safety or diagnostic impact assessment, MDR/vigilance reportability determination, investigation findings, and customer response. Integrates with Salesforce CRM case management and Veeva Vault for regulatory reporting. Supports FDA 21 CFR Part 820.198, EU IVDR Article 87, and ISO 13485 Clause 8.2.2 complaint handling requirements.' .

ind:ValidationStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Validation Study' ;
    rdfs:comment 'Analytical and process validation study master record covering method validation, assay validation, software validation (CSV), equipment qualification (IQ/OQ/PQ), and process validation for GxP-regulated activities. Captures validation type, applicable regulatory standard (FDA 21 CFR Part 11, ICH Q2(R1), CLSI EP guidelines), validation protocol document reference, acceptance criteria, study execution dates, statistical analysis approach, validation conclusion, and approval chain. Supports clinical assay analytical validation for CLIA/CAP LDT submissions and IVD performance studies for FDA/CE-IVD submissions.' .

ind:ChangeControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Change Control' ;
    rdfs:comment 'Unified quality change control record governing all GxP-impactful changes — including manufacturing processes, equipment, materials, software, facilities, analytical methods, and controlled document revisions. Manages the complete change lifecycle: initiation, impact assessment (regulatory, validation, training, document), cross-functional approval routing, implementation authorization, and post-change effectiveness verification. Encompasses both document-level changes (SOP revisions, specification updates) and broader operational changes requiring regulatory submission (PAS, CBE-30, CBE-0). Integrates with Veeva Vault for change control workflow, MasterControl for document revision routing, and SAP for ERP-side change implementation. Supports FDA 21 CFR Part 820.40, ICH Q10, and ISO 13485 Clause 7.3.9.' .

ind:Submission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission' ;
    rdfs:comment 'Master record for every regulatory submission made to a health authority — FDA 510(k), PMA, De Novo, CE-IVD technical file, EMA dossier, ICH CTD, IVDR registration, and country-specific IVD filings. Captures submission type, target agency, target jurisdiction (country/region/trading bloc), submission date, dossier reference, regulatory pathway classification, product scope, predicate device (for 510(k)), lead regulatory affairs owner, and current lifecycle status. Includes jurisdiction-level metadata: applicable regulatory framework, competent authority, IVD classification system, language requirements, and local representative requirement. SSOT for all regulatory filing identities across global jurisdictions.' .

ind:SubmissionEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission Event' ;
    rdfs:comment 'Transactional record capturing each discrete regulatory submission action — initial filing, amendment, supplement, response to deficiency letter, withdrawal, or resubmission. Tracks submission date, submission method (eCTD gateway, paper, eSTAR), agency receipt confirmation, submission version, and associated dossier package reference. Enables full audit trail of all submission activities per dossier.' .

ind:Approval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Approval' ;
    rdfs:comment 'Master record of regulatory approvals, clearances, and registrations granted by health authorities — FDA 510(k) clearance, PMA approval, CE-IVD certificate, IVDR certificate of conformity, EMA marketing authorization, and country-specific IVD registrations. Captures approval date, approval number, notified body or agency, approved indications, conditions of approval, expiry date, and renewal obligations. SSOT for all granted regulatory authorizations.' .

ind:AgencyCorrespondence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Agency Correspondence' ;
    rdfs:comment 'Transactional record of all formal communications and interactions with regulatory agencies — including pre-submission engagements (FDA Q-Sub/Pre-Sub meetings, EMA scientific advice, notified body pre-application consultations, CLIA/CAP consultation interactions), FDA deficiency letters, additional information requests (AIRs), interactive review meetings, EMA questions, notified body queries, and agency responses. Captures correspondence type, interaction subtype (pre-submission, during-review, post-approval), direction (inbound/outbound), agency contact, meeting date, agenda topics, key questions posed, agency feedback received, impact on submission strategy, due date for response, response status, and linked submission. SSOT for all regulatory agency dialogue — from proactive pre-submission engagement through post-approval interactions.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Document' ;
    rdfs:comment 'Master record for controlled regulatory documents managed in Veeva Vault — technical files, clinical evaluation reports (CER), performance evaluation reports (PER), risk management files (ISO 14971), instructions for use (IFU), labeling artwork, and regulatory SOPs. Captures document type, Veeva Vault document ID, version, effective date, document owner, approval status, and applicable submission references. Integrates with Veeva Vault as the system of record for document control.' .

ind:Labeling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Labeling' ;
    rdfs:comment 'Master record for all product labeling and IFU (Instructions for Use) assets subject to regulatory control, including their change history. Covers instrument labels, reagent kit inserts, IFU documents, carton artwork, and digital labeling. Captures labeling version, applicable markets/jurisdictions, language variants, regulatory approval status, effective date, linked product SKU, and full change history — including change reason, change classification (major/minor), impacted markets, regulatory notification requirements, change control reference, and implementation date. Tracks labeling lifecycle and compliance with FDA 21 CFR Part 801, EU IVDR Annex I, and global jurisdiction-specific labeling requirements.' .

ind:AdverseEventReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Adverse Event Report' ;
    rdfs:comment 'Transactional record for the complete post-market vigilance and field safety workflow — adverse event reports, serious incident reports, field safety corrective actions (FSCA), and field safety notices (FSN). Covers FDA MDR filings, EU IVDR serious incident reports, product recalls, market withdrawals, hazard alerts, and corrective field actions. Captures event date, event description, device involved, patient/user impact, reportability determination, report submission date, agency acknowledgment, follow-up status, action type, affected lot numbers, affected markets, root cause, corrective action description, regulatory notification dates, customer notification status, and closure date. Integrates with quality CAPA and supply chain recall management. SSOT for all post-market safety signals from detection through corrective action closure.' .

ind:PostMarketSurveillance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Post Market Surveillance' ;
    rdfs:comment 'Master record for post-market surveillance (PMS) plans and reports per product — IVDR PMS plans, periodic safety update reports (PSUR), post-market performance follow-up (PMPF) plans, and FDA post-approval study commitments. Captures PMS plan version, reporting frequency, data sources (complaint data, literature, registry), next due date, responsible owner, and regulatory submission linkage. SSOT for ongoing post-market regulatory obligations per product.' .

ind:FieldSafetyAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Field Safety Action' ;
    rdfs:comment 'Transactional record for field safety corrective actions (FSCA) and field safety notices (FSN) — product recalls, market withdrawals, hazard alerts, and corrective field actions initiated in response to safety signals or regulatory requirements. Captures action type, affected lot numbers, affected markets, root cause, corrective action description, regulatory notification dates, customer notification status, and closure date. Integrates with quality CAPA and supply chain recall management.' .

ind:IvdRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Ivd Registration' ;
    rdfs:comment 'Master record for all regulatory registrations — product-level IVD registrations, facility/establishment registrations, and manufacturer/importer registrations with global health authorities. Covers Health Canada, TGA (Australia), ANVISA (Brazil), NMPA (China), PMDA (Japan), CDSCO (India), FDA establishment registration (21 CFR Part 807), EU authorized representative registrations, and other national competent authority filings. Captures registration type (product, facility, manufacturer, importer, distributor), registration number, country, facility address, registration date, expiry date, renewal status, local authorized representative, applicable product or facility scope, device types listed, and annual renewal obligations. SSOT for global regulatory registration, establishment compliance, and market access status across all registration types.' .

ind:DeviceIdentifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Master record for Unique Device Identifier (UDI) assignments and device database registrations — UDI-DI (device identifier), UDI-PI (production identifier), GUDID submissions (FDA), and EUDAMED device registrations (EU IVDR). Captures UDI-DI code, UDI-PI format, Basic UDI-DI, issuing agency (GS1, HIBCC, ICCBBA), product reference, EUDAMED device identifier, EUDAMED registration status, economic operator registrations, and UDI-DI/UDI-PI linkage to labeling. Supports FDA GUDID, EU EUDAMED Article 26/Annex VI, and global UDI compliance for IVD and genomic instrument products.' .

ind:EstablishmentRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Establishment Registration' ;
    rdfs:comment 'Master record for facility and establishment registrations with regulatory authorities — FDA establishment registration (21 CFR Part 807), EU authorized representative registrations, and country-specific manufacturer/importer registrations. Captures establishment name, registration number, facility address, registration type (manufacturer, importer, distributor), applicable device types, registration expiry, and annual renewal status. SSOT for regulatory facility compliance across global markets.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for every customer account served by Genomics Biotech — research institutions, clinical laboratories, biopharma partners, agricultural genomics clients, OEM accounts, and individual researchers. Sourced from Salesforce CRM Account object. Stores legal entity name, account type (RUO, IVD/clinical, OEM, agricultural, biopharma), industry vertical, tier classification, account status, primary address, tax/VAT identifiers, DUNS number, parent account reference for hierarchy, assigned territory, CRM account ID, ERP customer number (SAP SD), credit limit, currency, preferred language, data privacy consent flags (GDPR, HIPAA), market segment classification (RUO, IVD/clinical, biopharma, agricultural, OEM, academic/government), strategic tier (key account, growth, standard), pricing tier, SLA tier, segment effective date, and segment change reason. Segment classification is the authoritative source — no separate segment entity exists.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual person associated with a customer account — principal investigators, lab directors, procurement officers, clinical genomics specialists, field application scientists, and purchasing contacts. Sourced from Salesforce CRM Contact object. Captures full name, job title, department, email, phone, preferred communication channel, contact role (technical, commercial, billing, regulatory), opt-in/opt-out marketing flags, GDPR consent status, PHI handling authorization, and active/inactive status.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Market segmentation classification applied to customer accounts for commercial targeting, pricing strategy, and service tiering. Segments include RUO (Research Use Only), IVD/clinical, biopharma drug development, agricultural genomics, OEM/reseller, and academic/government. Stores segment code, segment name, regulatory use classification (RUO vs. IVD), market vertical, sub-vertical, strategic tier (key account, growth, standard), assigned pricing tier, SLA tier, and segment owner. Drives downstream product eligibility, promotional eligibility, and support prioritization.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with customer accounts and contacts — shipping destinations for instruments and reagent kits, billing addresses, laboratory site addresses, and registered legal addresses. Captures address type (shipping, billing, legal, lab site), street lines, city, state/province, postal code, country (ISO 3166), geocoordinates, validated flag, validation source, biosafety level of the receiving lab (BSL-1 through BSL-4), cold-chain eligibility flag, and hazmat receiving authorization.' .

ind:TechnicalRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Technical Requirement' ;
    rdfs:comment 'Documents customer-specific technical and application requirements captured during pre-sales, onboarding, or support engagements. Covers sequencing application type (WGS, WES, targeted panel, single-cell), required read length, coverage depth targets, preferred library preparation method, multiplexing requirements, bioinformatics pipeline preferences (FASTQ delivery, BAM/VCF output), instrument platform preference, throughput requirements, turnaround time (TAT) expectations, and regulatory use classification (RUO vs. IVD/LDT). Enables field application scientists and commercial teams to configure appropriate product and service offerings.' .

ind:ServiceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Agreement' ;
    rdfs:comment 'Records service-level agreements, support contracts, and product evaluation/beta-testing engagements established with customer accounts — instrument service contracts, reagent supply agreements, bioinformatics support SLAs, field application scientist engagement terms, instrument beta placements, early-access reagent kit evaluations, clinical assay validation pilots, CRISPR tool assessments, and demo placements. Captures agreement type (instrument warranty, preventive maintenance, reagent supply SLA, FAS support, beta evaluation, early access, clinical evaluation, demo placement), program name, start date, end date, SLA tier (standard, premium, enterprise), response time commitments, uptime guarantees, covered instruments/products, annual contract value (ACV), renewal terms, agreement status, evaluation status, products under evaluation, success criteria, customer feedback summary, commercial conversion outcome, and internal scientific lead. Serves as the unified contractual and evaluation engagement record — no separate evaluation program entity exists.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Captures all recorded touchpoints and engagement activities between Genomics Biotech personnel and customer accounts or contacts — sales calls, field application scientist (FAS) site visits, technical support calls, webinar attendance, trade show meetings, product demonstrations, training sessions, and scientific advisory board meetings. Stores interaction type, interaction date, channel (in-person, phone, email, video, portal), subject, outcome/notes, next action, associated opportunity or case reference, duration, and the internal employee who conducted the interaction. Provides the relationship history timeline for each account and supports customer engagement scoring.' .

ind:Accreditation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Accreditation' ;
    rdfs:comment 'Tracks laboratory accreditations, certifications, and regulatory authorizations held by clinical laboratory and diagnostic customer accounts — CLIA certification, CAP accreditation, ISO 15189 certification, CE-IVD authorization, GxP compliance status, and IRB registration. Captures accreditation type, issuing body, certificate number, accreditation scope, issue date, expiry date, renewal status, and associated laboratory site address. Critical for determining product eligibility (IVD vs. RUO) and regulatory compliance of customer-facing activities.' .

ind:InstalledInstrument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Installed Instrument' ;
    rdfs:comment 'Customer-facing registry of sequencing instruments, array scanners, PCR/qPCR platforms, and gene-editing equipment installed at customer sites. Captures instrument model, serial number, installation date, site address, warranty expiry, current firmware version, service contract reference, instrument status (active, decommissioned, under repair), utilization tier, and the customer account and contact responsible for the instrument. Enables field service dispatch, proactive maintenance scheduling, reagent/consumable consumption forecasting, and upgrade targeting. Note: this is the customer-relationship view of installed base; the instrument domain owns the engineering asset master.' .

ind:SupportCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Support Case' ;
    rdfs:comment 'Records customer-reported technical support cases, instrument issues, reagent complaints, bioinformatics pipeline questions, and field application requests. Sourced from ServiceNow and Salesforce CRM Case objects. Captures case number, case type (instrument fault, reagent QC complaint, software/pipeline issue, application support, billing inquiry), priority, severity, status (open, in-progress, resolved, closed), reported date, resolution date, TAT, root cause category, resolution summary, and escalation flag. Distinct from internal CAPA records owned by the quality domain.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers and vendors providing raw materials, reagents, components, and services to Genomics Biotech. Captures supplier identity, classification (GMP-qualified, preferred, approved, conditional), regulatory certifications (ISO 13485, GMP), contact hierarchy, geographic footprint, payment terms, lead time profiles, and risk tier. SSOT for supplier identity across procurement and supply chain operations. Sourced from SAP MM vendor master.' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Material' ;
    rdfs:comment 'Master record for all materials managed within the supply chain — including raw chemicals, biological reagents, flow cell components, array substrates, packaging materials, and finished goods SKUs. Captures material number, description, material type (ROH, HALB, FERT), base unit of measure, storage conditions (cold-chain temperature range, hazard class), shelf life, GMP classification, BOM relevance, and regulatory status (RUO, IVD). Sourced from SAP MM Material Master (MARA/MARC).' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Transactional record of a formal procurement commitment issued to a supplier for materials or services. Header captures PO number, PO type (standard, blanket, consignment, subcontracting), supplier reference, plant/storage location, requested delivery date, incoterms, payment terms, total net value, currency, GMP-relevant flags, and approval workflow status. Line items (after po_line merge) capture material reference, ordered quantity, confirmed quantity, unit price, delivery schedule, storage location assignment, over/under-delivery tolerances, and goods receipt/invoice receipt indicators. The line item is the grain of this product. Each PO is the authoritative procurement document linking demand signals to supplier fulfillment. Sourced from SAP MM (EKKO/EKPO/EKET).' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line item within a purchase order representing a specific material, quantity, unit price, delivery schedule, and storage location assignment. Captures line number, material reference, ordered quantity, confirmed quantity, unit of measure, net price, delivery date, goods receipt indicator, invoice receipt indicator, and over/under-delivery tolerances. Enables granular tracking of multi-material procurement events. Sourced from SAP MM (EKPO/EKET).' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Transactional ledger of all material movements within the Genomics Biotech supply chain — including goods receipts against POs (mvt 101), goods issues to production (mvt 261), stock transfers between plants/locations (mvt 301/311), returns to supplier (mvt 122), and scrapping events (mvt 551). Captures movement type, posting date, material, plant, storage location, batch, quantity, movement value, reference document (PO, production order, delivery), cold-chain temperature log reference, COA reference, and movement reason code. Provides the single authoritative material ledger for GMP audit trails, COGS calculation, and full lot traceability. Sourced from SAP MM (MSEG/MKPF).' .

ind:InventoryStock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inventory Stock' ;
    rdfs:comment 'Current and historical stock position for each material at each plant and storage location. Captures unrestricted stock, quality inspection stock, blocked stock, consignment stock, and in-transit stock quantities. Includes batch-level granularity for GMP-controlled materials, expiry date tracking, cold-chain storage zone assignment, and reorder point/safety stock parameters. Supports COGS visibility and uninterrupted supply assurance for critical genomics inputs. Sourced from SAP MM (MARD/MCHB/MBEW).' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional log of every material movement within the supply chain — including goods receipts, goods issues, stock transfers, returns, and scrapping events. Captures movement type, posting date, material, plant, storage location, batch, quantity, value, reference document (PO, production order, delivery), and movement reason. Provides full material ledger traceability required for GMP audit trails and COGS calculation. Sourced from SAP MM (MSEG/MKPF).' .

ind:Batch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Batch' ;
    rdfs:comment 'Master record for a specific production or procurement batch of a material, enabling full lot traceability from supplier through manufacturing to customer delivery. Captures batch number, material reference, manufacturing date, expiry date, COA number, QC release status, storage conditions, cold-chain compliance flag, GMP classification, and batch origin (internal production vs. external procurement). Critical for GxP compliance, recall management, and reagent/consumable quality assurance. Sourced from SAP MM/QM (MCH1/MCHA).' .

ind:InboundDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Delivery' ;
    rdfs:comment 'Logistics document tracking the physical inbound shipment of materials from a supplier to a Genomics Biotech receiving location. Captures delivery number, carrier, tracking number, expected arrival date, actual arrival date, incoterms, cold-chain monitoring device ID, temperature excursion flag, number of packages, total weight, and customs clearance status for international shipments. Links to purchase orders and triggers goods receipt processing. Sourced from SAP MM/LE (LIKP/LIPS).' .

ind:SupplierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Contract' ;
    rdfs:comment 'Master procurement contract or scheduling agreement with a supplier defining agreed pricing, volume commitments, delivery cadence, quality requirements, and SLA terms for materials critical to genomics operations. Captures contract number, contract type (value contract, quantity contract, scheduling agreement), validity period, target value, release order strategy, price conditions, and GMP/quality clauses. Enables blanket order releases and long-term supply security. Sourced from SAP MM (EKKO with contract document types).' .

ind:WarehouseLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Master record for physical storage locations within Genomics Biotech warehouses and distribution centers — including ambient, refrigerated (2–8°C), frozen (−20°C, −80°C), and ultra-cold (liquid nitrogen) zones required for biological reagents, flow cells, and CRISPR components. Captures warehouse number, storage type, storage section, bin location, temperature zone, capacity (weight/volume), hazardous material classification (UN number, hazard class, storage incompatibilities), GMP zone classification, and current utilization. Supports cold-chain zone management and regulatory compliance for transport/storage of hazardous genomics inputs. Sourced from SAP WM/EWM.' .

ind:SupplierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Qualification' ;
    rdfs:comment 'Record of the formal qualification and approval status of a supplier for specific material categories or GMP-controlled supply. Captures qualification type (initial, re-qualification, audit-based), qualification date, expiry date, approved material scope, audit findings summary, corrective action requirements, qualification status (approved, conditional, suspended, disqualified), and regulatory body alignment (FDA, EMA, ISO 13485). Ensures only qualified suppliers provide critical genomics inputs. Sourced from Veeva Vault / SAP QM.' .

ind:Catalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Catalog' ;
    rdfs:comment 'Master catalog of all reagents, consumables, and biochemical inputs managed by Genomics Biotech — including library preparation kits, flow cells, CRISPR reagents, PCR/qPCR master mixes, enzymes, buffers, and array hybridization chips. Captures product identity, reagent type classification (enzyme, buffer, kit, flow cell, CRISPR component, consumable), category hierarchy, classification (RUO vs IVD), intended application (NGS, WGS, WES, CRISPR, qPCR, array), storage requirements (temperature range, humidity limits, light sensitivity, freeze-thaw limits, special handling), hazard classification, regulatory status, and lifecycle stage. This is the SSOT for reagent product definitions and their storage condition profiles.' .

ind:Lot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Lot' ;
    rdfs:comment 'GMP-compliant lot (batch) master record for every manufactured or received reagent lot. Captures lot number, manufacturing date, expiry date, quantity produced, GMP release status, quarantine flags, retest date, originating work order or supplier shipment, supplier lot number, supplier COA reference, country of origin, and supplier quality grade. Includes immutable status audit trail recording all lifecycle transitions (quarantine → QC testing → released → restricted → disposed) with triggering event, operator ID, timestamp, and supporting document reference. SSOT for lot traceability across the reagent lifecycle. Supports FDA 21 CFR Part 211, ISO 13485, and GxP requirements.' .

ind:Coa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Coa' ;
    rdfs:comment 'Certificate of Analysis (COA) record for each reagent lot, documenting QC test results, acceptance criteria, pass/fail determinations, analytical method references, and authorized release signatures. Captures COA document number, issuing laboratory, test date, specification version, and GMP release authorization. Supports regulatory submission packages, customer-facing COA delivery, and ISO 13485 / GxP documentation requirements. Linked to the lot master and QC test results.' .

ind:StorageLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or logical storage location master for reagent inventory — capturing facility, building, room, freezer/refrigerator unit, shelf, and rack/position identifiers. Records monitored temperature zone, humidity range, capacity limits, current occupancy, environmental monitoring device linkage, access control level, and GMP qualification status. Supports LIMS-driven storage assignment, FIFO/FEFO management, cold-chain compliance tracking, and capacity planning.' .

ind:InventoryBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Inventory Balance' ;
    rdfs:comment 'Real-time reagent inventory balance record tracking on-hand quantity, reserved quantity, available-to-use quantity, and unit of measure for each reagent lot at each storage location. Captures reorder point, minimum stock level, maximum stock level, and last physical count date. Supports FEFO (First Expired First Out) dispensing logic, low-stock alerts, and GMP inventory reconciliation. Updated by goods receipts, dispensing events, and inventory adjustments.' .

ind:DispensingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Dispensing Event' ;
    rdfs:comment 'Transactional record of each reagent material movement — including dispensing to experiments/assays, consumption by instruments, internal transfers between storage locations or facilities, and returns to stock. Captures event timestamp, movement type (dispense, transfer, return, inter-site shipment), operator ID, lot number, quantity moved, unit of measure, source location, destination (experiment, assay run, production work order, instrument, or storage location), transfer reason (lab request, cold-chain relocation, quarantine move), remaining lot quantity post-event, cold-chain compliance flag, and chain-of-custody confirmation. Supports full LOT traceability from receipt through consumption or relocation, GMP usage logs, inter-site transfer documentation, and LIMS-driven reagent tracking.' .

ind:QcSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Qc Specification' ;
    rdfs:comment 'Reference master defining QC acceptance specifications for each reagent catalog item — including test method name, analytical parameter, specification type (identity, purity, potency, sterility, endotoxin, functional), acceptance criteria (numeric limits, pass/fail criteria), unit of measure, applicable regulatory standard, and specification version. Drives automated pass/fail evaluation of QC test results and supports method validation documentation.' .

ind:KitComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Kit Component' ;
    rdfs:comment 'Association entity defining the bill-of-materials (BOM) composition of multi-component reagent kits — capturing the parent kit catalog item, each component reagent catalog item, component quantity, unit of measure, component role (e.g., enzyme, buffer, adapter, index plate), and component version. Supports kit assembly work orders, component substitution management, and traceability of individual component lots within assembled kits. Enables downstream LOT-level traceability for each kit component.' .

ind:TestCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Test Catalog' ;
    rdfs:comment 'Authoritative master catalog of all IVD (In Vitro Diagnostic) and LDT (Laboratory Developed Test) clinical assays offered by Genomics Biotech, including versioned assay configurations. Captures test code, test name, assay type (WGS, WES, targeted panel, SNP array, CRISPR-based), intended use (RUO vs IVD), regulatory clearance status (FDA 510(k)/PMA, CE-IVD), CLIA/CAP accreditation scope, specimen types accepted, TAT commitments, CPT billing codes, assay version history (version number, effective/retired dates, reference genome build, panel gene list version, pipeline version, validation status, change rationale), and reflex testing rules. SSOT for the clinical test menu and assay version traceability.' .

ind:AssayVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Assay Version' ;
    rdfs:comment 'Tracks versioned configurations of each clinical assay in the IVD test catalog — capturing assay version number, effective date, retired date, reference genome build (GRCh38/hg38, T2T), panel gene list version, bioinformatics pipeline version, analytical validation status, and change rationale. Enables traceability of which assay version was used for any given patient result. Supports regulatory audit and post-market surveillance requirements.' .

ind:TestOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Test Order' ;
    rdfs:comment 'Core transactional record representing a CLIA/CAP-accredited clinical test order placed for a patient specimen. Captures ordering physician, ordering institution, patient demographics (PHI-compliant), test(s) ordered, clinical indication (ICD-10 codes), specimen accession number, priority (STAT vs routine), order date, required TAT, insurance/billing authorization, consent status, and IRB protocol reference where applicable. SSOT for clinical test order lifecycle.' .

ind:Patient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Patient' ;
    rdfs:comment 'PHI-compliant master record for patients whose specimens are submitted for clinical genomic testing. Stores de-identified and identified patient demographics (name, DOB, sex, race/ethnicity, MRN), consent records, HIPAA authorization status, GDPR data subject rights flags, guardian/proxy relationships, and patient communication preferences. Governed under HIPAA/GDPR data handling policies. SSOT for patient identity within the clinical domain.' .

ind:ClinicalSpecimen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Clinical Specimen' ;
    rdfs:comment 'Clinical-domain representation of a patient specimen submitted for IVD/LDT testing. Captures specimen accession number, specimen type (blood, saliva, FFPE, cfDNA, buccal swab), collection date, collection site, volume/quantity, pre-analytical QC status (Phred Score thresholds, DIN, RIN), chain-of-custody events, storage conditions, and linkage to the patient and test order. Complements the sample domain SSOT with clinical-specific pre-analytical metadata.' .

ind:AnalyticalValidation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Analytical Validation' ;
    rdfs:comment 'Records the analytical performance validation data for each clinical assay version — including LOD (Limit of Detection), analytical sensitivity, analytical specificity, precision (repeatability/reproducibility), accuracy, linearity, interference studies, and reference range establishment. Captures validation study design, number of replicates, acceptance criteria, pass/fail determination, validation date, and approving scientist. Required for CLIA/CAP accreditation and FDA/EMA regulatory submissions.' .

ind:GenomicResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Genomic Result' ;
    rdfs:comment 'Patient-level genomic result record generated from a completed clinical assay run. Stores result type (SNP genotype, CNV call, somatic variant, germline variant, pharmacogenomic result), result value, zygosity, chromosomal coordinates (GRCh38), gene symbol, transcript ID, HGVS nomenclature, ClinVar accession, MAF from gnomAD, coverage depth at locus, Phred quality score, result status (preliminary/final/amended/corrected), and reporting date. Core clinical output entity.' .

ind:VariantInterpretation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Variant Interpretation' ;
    rdfs:comment 'Clinical variant interpretation record capturing the classification of a genomic variant per ACMG/AMP guidelines (Pathogenic, Likely Pathogenic, VUS, Likely Benign, Benign), evidence codes applied (PVS1, PS1-4, PM1-6, PP1-5, BA1, BS1-4, BP1-7), interpretation rationale, disease association (OMIM/MONDO), inheritance pattern, clinical significance narrative, interpreting molecular pathologist, review date, and classification version. SSOT for variant-level clinical interpretation.' .

ind:Report rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Report' ;
    rdfs:comment 'Finalized clinical genomics report delivered to the ordering physician and patient, including full amendment lifecycle. Captures report ID, associated test order, patient demographics summary, assay name and version, result summary (positive/negative/inconclusive/VUS), variant findings included, clinical interpretation narrative, recommendations (genetic counseling, confirmatory testing, treatment implications), report format (PDF/HL7 FHIR), delivery method, delivery timestamp, report status (draft/final/amended/corrected/retracted), electronic signature of authorizing pathologist, amendment history (amendment type, reason, amended content, amendment date, notification status to ordering physician). Supports CLIA/CAP amendment tracking requirements and patient safety audit trails.' .

ind:VariantKnowledgeBase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Variant Knowledge Base' ;
    rdfs:comment 'Curated internal knowledge base of clinically significant variants observed in Genomics Biotech\'s patient population — capturing variant identifier (HGVS), gene, disease association, ACMG classification history, internal observation frequency, supporting literature (PubMed IDs), ClinVar submission status, expert panel review status (ClinGen), last review date, and curator identity. Distinct from the reference domain\'s public variant databases — this is the proprietary clinical interpretation repository.' .

ind:CliaAccreditation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Clia Accreditation' ;
    rdfs:comment 'Master record of CLIA and CAP accreditation credentials and associated proficiency testing compliance for the clinical laboratory. Captures certificate type (CLIA Certificate of Compliance, CAP accreditation), certificate number, issuing body, accreditation scope (test categories, specialty areas), effective date, expiration date, inspection date, deficiencies cited, corrective action status, renewal workflow status, proficiency testing enrollment (PT program name, analyte/test system evaluated, enrollment period, sample sets, results submitted, graded outcomes, corrective action references, submission deadline compliance). SSOT for laboratory accreditation standing and PT compliance tracking.' .

ind:ClinicalConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Clinical Consent Record' ;
    rdfs:comment 'PHI-compliant record of patient informed consent for clinical genomic testing — capturing consent type (germline testing, somatic testing, research use, biobanking, return of incidental findings), consent version, consent date, method of consent (written/electronic), patient or guardian signature reference, IRB protocol number, withdrawal status, and withdrawal date. Required for HIPAA compliance, GDPR data subject rights, and NIH Genomic Data Sharing Policy adherence.' .

ind:AssayQcRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Assay Qc Run' ;
    rdfs:comment 'Quality control run record for a clinical assay batch or sequencing run — capturing QC run ID, assay version, run date, instrument ID, reagent lot numbers, control sample results (positive, negative, no-template), QC metrics (coverage uniformity, on-target rate, duplicate rate, mean coverage depth, contamination check), Westgard rule evaluation, pass/fail determination per acceptance criteria, and reviewing scientist sign-off. Supports CLIA QC documentation, Westgard multi-rule monitoring, and lot release decisions. Links failed QC runs to CAPA workflows.' .

ind:AuthorizedOrderer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Authorized Orderer' ;
    rdfs:comment 'Master registry of physicians, genetic counselors, and clinical institutions authorized to order clinical genomic tests — capturing provider NPI, name, credentials, specialty, institutional affiliation, CLIA ordering privileges, state licensure verification, preferred report delivery method (EHR/fax/portal), active/inactive status, and credentialing verification date. Required for CLIA compliance (only authorized providers may order high-complexity tests) and report delivery routing. Distinct from customer domain accounts — this is the clinical credentialing and ordering authority registry.' .

ind:CatalogItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Catalog Item' ;
    rdfs:comment 'Authoritative master record for every commercial offering in the Genomics Biotech portfolio — sequencing platforms (NovaSeq/NextSeq-class instruments), array products, CRISPR gene-editing tools, reagent kits, consumables, bioinformatics software licenses, professional services, and commercial bundles. Owns the canonical SKU, product name, product family, product line, product category (instrument/reagent/software/service/consumable/bundle), regulatory use classification (RUO/IVD/CE-IVD/LDT), product description, short description, marketing tagline, product URL, launch date, end-of-life date, current lifecycle stage (concept/development/launch/growth/maturity/EOL), lifecycle stage history, and bundle-specific attributes (discount percentage, eligibility rules) where applicable. This is the SSOT for all product identity across the enterprise.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit definition record that maps each orderable, shippable, or licensable variant of a catalog item to a unique SKU code. Captures SKU code, SKU description, unit of measure (UOM), pack size, configuration (e.g., 8-plex flow cell, 96-sample kit), country availability, sales channel eligibility (direct/distributor/OEM/ecommerce), active/inactive status, introduction date, discontinuation date, and whether the SKU is a standalone item or a bundle component. Enables order management, inventory, and supply chain to reference precise orderable units.' .

ind:Family rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Family' ;
    rdfs:comment 'Hierarchical grouping entity that organizes catalog items into product families and product lines (e.g., \'Short-Read Sequencing\', \'Long-Read Sequencing\', \'Microarray\', \'CRISPR Editing\', \'Liquid Biopsy\'). Stores family name, family code, parent family reference for multi-level hierarchy, owning business unit, strategic priority tier, and associated go-to-market segment. Enables portfolio-level reporting, roadmap planning, and cross-sell/upsell analysis without duplicating catalog item records.' .

ind:Specification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Technical and performance specification sheet for a catalog item or SKU. Captures instrument/reagent/software specifications including read length (bp), throughput (Gb/run), flow cell type, cluster density, Q30 score threshold, library compatibility, storage temperature, shelf life (days), hazard classification, CE marking status, ISO 13485 compliance flag, CLIA applicability, and software version compatibility matrix. Serves as the authoritative technical datasheet referenced by field application scientists, regulatory submissions, and quality teams.' .

ind:ProductBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Bom' ;
    rdfs:comment 'Bill of Materials header record linking a finished-goods catalog item, SKU, or commercial bundle to its component materials, sub-assemblies, reagents, packaging, or bundled SKUs. Stores BOM number, BOM type (production/engineering/costing/commercial-bundle), component item reference, component quantity, unit of measure, lead time offset, scrap factor, effective date range, discount percentage (for commercial bundles), eligibility rules, and BOM status (active/superseded/draft). Critical for manufacturing cost rollup, supply planning, regulatory traceability of component lots, and commercial bundle definition with solution-selling go-to-market strategies.' .

ind:BomLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bom Line' ;
    rdfs:comment 'Individual component line within a Bill of Materials, representing one raw material, sub-assembly, packaging item, or commercial bundle component required to produce or compose the parent finished good or bundle. Captures component SKU reference, required quantity, unit of measure, item category (raw material/semi-finished/packaging/phantom/bundle-component), component role (primary instrument/reagent/software/service for bundles), alternative item group, substitution eligibility flag, mandatory/optional flag, supply type (in-house/external), and validity dates. Enables granular cost analysis, component substitution management, lot traceability from raw material to finished product, and commercial bundle composition with revenue allocation.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'Commercial pricing record defining the list price, ASP (Average Selling Price), transfer price, and tiered volume pricing for each SKU by currency, region, and sales channel. Stores price type (list/contract/distributor/OEM/government), currency code, unit price, minimum order quantity, volume break thresholds, effective start and end dates, approval status, and the pricing owner (commercial ops team). Supports revenue recognition, deal desk quoting, and margin analysis. Distinct from customer-specific contract pricing which lives in the order/agreement domain.' .

ind:RegulatoryClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory use and market authorization classification for each catalog item by jurisdiction. Captures intended use classification (RUO/IVD/CE-IVD/LDT/ASR), device class (Class I/II/III per FDA 21 CFR), IVDR risk class (A/B/C/D per EU 2017/746), GMDN code, product code (FDA), CE-IVD certificate number, authorization status (authorized/pending/withdrawn), jurisdiction (US/EU/APAC/ROW), authorization date, expiry date, and labeling language requirements. Serves as the SSOT for regulatory status consumed by regulatory submissions, quality, and commercial teams.' .

ind:SoftwareRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Software Release' ;
    rdfs:comment 'Version and release record for bioinformatics software products, instrument firmware, and analysis pipeline software offered commercially by Genomics Biotech. Captures software product reference, version number (semantic versioning), release type (major/minor/patch/hotfix), release date, end-of-support date, supported OS and cloud platforms (AWS/on-premise/HPC), release notes summary, known issues log reference, validated instrument compatibility, and license model (perpetual/subscription/SaaS). Enables software lifecycle management and customer entitlement tracking.' .

ind:LicenseEntitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'License Entitlement' ;
    rdfs:comment 'Product-level license entitlement template defining the usage rights and technical constraints granted when a customer purchases a specific software SKU. Captures license type (node-locked/floating/site/cloud/SaaS subscription), maximum concurrent users, maximum compute nodes, licensed feature set (e.g., DRAGEN alignment, variant calling, tumor-normal analysis), license key generation method, activation mechanism (online/offline/token-based), entitlement duration (perpetual/annual/multi-year), renewal terms, upgrade eligibility, geographic usage restrictions, and compliance audit requirements. Serves as the canonical template from which customer-specific license assignments (in the order/agreement domain) are instantiated. Critical for software revenue recognition, entitlement verification, and license compliance auditing.' .

ind:ServiceOffering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Service Offering' ;
    rdfs:comment 'Extended detail record for professional and technical services offered commercially — including instrument installation, IQ/OQ/PQ qualification, preventive maintenance contracts, field application scientist (FAS) support, custom assay development, bioinformatics consulting, sequencing-as-a-service, and training programs. Captures service-specific attributes beyond what catalog_item holds: service code, service category (installation/qualification/maintenance/FAS/training/consulting/sequencing-service), delivery mode (on-site/remote/hybrid), standard duration (hours/days), deliverables description, SLA tier, pricing model (fixed-fee/time-and-materials/subscription), required certifications for delivery staff, prerequisite services, and geographic availability. Each service_offering references a parent catalog_item of category=service; this entity extends the catalog with service-specific operational detail that does not apply to physical products.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'GMP-compliant production work order representing a discrete manufacturing execution unit for instruments, reagent kits, arrays, flow cells, or consumables. Captures SAP PP production order details including order number, product/material being produced, planned vs actual quantities, scheduled start/finish dates, actual start/finish dates, production plant, work center, BOM version, routing version, order type (e.g., process order, production order), order status (created, released, confirmed, technically complete), priority, batch number assigned, MES integration reference, and GxP-relevant fields such as GMP flag and electronic batch record reference.' .

ind:ProductionBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Batch' ;
    rdfs:comment 'Master record for a discrete manufactured batch (LOT) of a genomics/biotech product — reagent kit, flow cell, array, consumable, or instrument sub-assembly. Serves as the single source of truth for batch identity, batch documentation (Electronic Batch Record / EBR), and batch release readiness. Captures batch number, material, batch size, manufacturing/expiry/retest dates, batch status and disposition, GMP classification, manufacturing site, production line, and COA reference. Owns the complete EBR lifecycle: batch record status (draft, in-review, approved, rejected), review/approval workflow with electronic signatures (21 CFR Part 11 / Annex 11), reviewer/approver identities, deviation and exception counts, material consumption records, and MES/Veeva Vault document references. Integrates with SAP PP batch master and QM usage decision.' .

ind:ManufacturingBom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Manufacturing Bom' ;
    rdfs:comment 'Bill of Materials defining the complete assembly structure for a manufactured product (instrument, reagent kit, array, flow cell, consumable) — including both the header definition and all component line items. Header captures: material number, BOM usage (production, engineering, costing), BOM status (active, inactive), valid-from/valid-to dates, base quantity, unit of measure, plant, BOM alternative number, change number, and ECM reference. Components capture: component material number, item category (stock, non-stock, document, text), required quantity, unit of measure, scrap factor, valid-from/valid-to dates, operation assignment, storage location, batch classification requirement, controlled substance flag, and cold-chain requirement. Serves as the authoritative BOM definition for production execution, MRP explosion, and cost rollup. Integrates with SAP PP BOM (CS01/CS02).' .

ind:BomComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Bom Component' ;
    rdfs:comment 'Individual component line item within a Bill of Materials, representing a raw material, sub-assembly, reagent, or consumable required to manufacture the parent assembly. Captures component material number, item category (stock item, non-stock, document, text), required quantity, unit of measure, scrap factor, valid-from/valid-to dates, operation assignment, storage location, batch classification requirement, and GMP-relevant fields such as controlled substance flag and cold-chain requirement. Enables BOM explosion for production planning and material requirements planning (MRP).' .

ind:ProductionOperation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Operation' ;
    rdfs:comment 'Individual manufacturing operation executed on the shop floor as part of a work order, representing a discrete production step (e.g., reagent dispensing, mixing, fill-finish, optical alignment, PCR amplification). Captures operation number, short text, work center, control key, standard values (setup/machine/labor time), actual times, operation status (not started, in progress, confirmed, skipped), yield and scrap quantities, operator ID, equipment used, in-process QC checkpoint flag, electronic signature (21 CFR Part 11), and MES transaction reference. Supports GMP batch record completeness and shop-floor traceability.' .

ind:InprocessQcResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Inprocess Qc Result' ;
    rdfs:comment 'In-process quality control inspection result recorded at a defined checkpoint during manufacturing execution. Captures inspection lot number (SAP QM), inspection characteristic, measured value, unit of measure, specification lower/upper limits, pass/fail result, inspection method, operator ID, inspection date/time, equipment used for measurement, deviation flag, and disposition (accept, reject, conditional release). Supports GMP compliance, real-time yield monitoring, and out-of-specification (OOS) investigation triggers. Integrates with SAP QM inspection lots and MES QC checkpoints.' .

ind:BatchRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Batch Record' ;
    rdfs:comment 'Electronic Batch Record (EBR) — the GMP-mandated comprehensive record of all activities, materials, equipment, and results associated with the manufacture of a specific production batch. Captures batch record number, associated batch and work order, product name and code, manufacturing site, batch record status (draft, in-review, approved, rejected), review/approval workflow steps, reviewer and approver identities with electronic signatures (21 CFR Part 11 / Annex 11 compliant), review date, approval date, deviation count, exception count, and MES/Veeva Vault document reference. Serves as the primary GMP compliance artifact for batch release.' .

ind:EquipmentQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment Qualification' ;
    rdfs:comment 'Records the qualification and validation status of manufacturing equipment used in GMP production — covering Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ) activities. Captures equipment ID, equipment name, equipment type, qualification type (IQ/OQ/PQ), qualification status (pending, in-progress, qualified, expired, failed), qualification date, next requalification due date, qualification protocol reference, qualification report reference (Veeva Vault), responsible engineer, and regulatory standard applied (ISO 13485, GMP Annex 15). Ensures only qualified equipment is used in GMP manufacturing.' .

ind:ProcessValidation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Process Validation' ;
    rdfs:comment 'Master record for process validation studies conducted to demonstrate that a manufacturing process consistently produces a product meeting its predetermined specifications and quality attributes. Captures validation protocol number, product/process being validated, validation type (prospective, concurrent, retrospective, revalidation), validation stage (protocol approved, execution in progress, report approved, validated, revalidation required), number of validation runs, acceptance criteria, validation outcome, regulatory submission reference (FDA, EMA), validation report reference (Veeva Vault), and process validation expiry date. Critical for IVD/GMP regulatory compliance.' .

ind:WorkCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Work Center' ;
    rdfs:comment 'Master data for manufacturing work centers — production lines, assembly stations, clean rooms, fill-finish suites, and packaging lines — where production operations are executed. Captures work center ID, name, category (machine, labor, production line), plant, cost center, capacity (shifts, hours), efficiency factor, utilization rate, GMP classification (ISO class 5/7/8, EU GMP grade A/B/C/D), associated equipment list, and qualification status. Used for production scheduling, capacity planning, and GMP environmental monitoring zone assignment. Integrates with SAP PP work center master (CR01/CR02).' .

ind:FinishedGoodsRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Finished Goods Release' ;
    rdfs:comment 'Records the formal quality release decision for a finished goods batch, authorizing it for commercial distribution or internal use. Captures release record number, batch number, product code, product name, manufacturing site, release type (full release, conditional release, reject), release decision date, quality reviewer ID, quality approver ID (QP/QA), electronic signature reference (21 CFR Part 11), COA number, COA issue date, release criteria checklist completion status, outstanding deviation count, regulatory hold flag, and distribution authorization date. Integrates with SAP QM usage decision and Veeva Vault batch release workflow.' .

ind:ProductionRouting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Production Routing' ;
    rdfs:comment 'Master data defining the sequence of manufacturing operations (routing) required to produce a specific product, including standard times, work center assignments, and control keys. Captures routing number, routing group, material/product, plant, routing status (active, inactive), valid-from/valid-to dates, total standard lead time, operation sequence with operation numbers, work center per operation, standard setup/machine/labor times, GMP-critical operation flags, electronic signature requirement per operation, and MES integration reference. Serves as the manufacturing process template for work order generation and shop-floor execution. Integrates with SAP PP routing (CA01/CA02).' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Master record for every physical instrument asset owned or managed by Genomics Biotech — sequencing platforms (NGS, WGS), array scanners, PCR/qPCR systems, liquid handlers, and gene-editing equipment. Captures serial number, model, firmware version, asset tag, acquisition date, warranty expiry, GxP classification (RUO/IVD), site location, and current operational status. This is the SSOT for instrument identity and lifecycle within the instrument domain.' .

ind:Model rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Model' ;
    rdfs:comment 'Reference catalog of instrument model definitions — sequencing platforms, array scanners, PCR/qPCR analyzers, liquid handlers, and CRISPR delivery systems. Stores manufacturer, model number, platform generation, read length capability, throughput specifications, supported chemistries, regulatory clearance class (IVD/RUO), and compatible reagent families. Serves as the template from which individual instrument assets are instantiated.' .

ind:InstallationQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Installation Qualification' ;
    rdfs:comment 'Records the IQ/OQ/PQ (Installation Qualification, Operational Qualification, Performance Qualification) lifecycle for each instrument asset at a customer or internal site. Captures qualification type (IQ/OQ/PQ), execution date, performed-by engineer, pass/fail outcome, deviations noted, approval signatures, and GxP compliance attestation. Required for FDA 21 CFR Part 11, ISO 13485, and GxP-regulated environments.' .

ind:CalibrationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Calibration Record' ;
    rdfs:comment 'Tracks all calibration events performed on instrument assets — optical, thermal, fluidic, and electrical calibration. Stores calibration date, due date, calibration standard used, tolerance limits, measured values, pass/fail status, calibration certificate reference, and technician ID. Supports CLIA, CAP, ISO 15189, and ISO 13485 compliance requirements for instrument traceability.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Defines the preventive maintenance (PM) schedule for each instrument model or individual asset — specifying maintenance task type, frequency (daily, weekly, quarterly, annual), estimated duration, required parts/consumables, and applicable SOP reference. Drives automated PM work order generation and field service dispatch via ServiceNow integration. Supports SAP PM maintenance plans.' .

ind:MaintenanceEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Maintenance Event' ;
    rdfs:comment 'Captures every executed maintenance activity on an instrument asset — preventive, corrective, and emergency maintenance — along with associated parts consumption, downtime impact, and post-maintenance verification. Records event type, trigger (scheduled/unscheduled), start and end datetime, downtime duration, technician, parts replaced (part number, quantity, lot, unit cost), labor hours, root cause category, impact assessment (runs affected, samples impacted), resolution notes, customer sign-off, follow-up actions, and post-maintenance verification status. Integrates with ServiceNow field service work orders and SAP PM notifications. Supports SLA compliance tracking, uptime KPI reporting, and parts consumption analytics.' .

ind:FieldServiceRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Field Service Request' ;
    rdfs:comment 'Manages field service dispatch requests for instrument assets at customer or internal sites — covering breakdown calls, installation requests, upgrade visits, and application support. Stores request type, priority, SLA tier, customer site, assigned field service engineer (FSE), scheduled visit date, travel details, and resolution status. Sourced from ServiceNow ITSM and linked to SAP SD service orders.' .

ind:InstrumentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Instrument Run' ;
    rdfs:comment 'Records each instrument run executed on a sequencing platform, array scanner, or PCR/qPCR system — capturing run ID, run type (WGS/WES/targeted/array/qPCR), start and end datetime, operator, flow cell or array cartridge used, reagent lot numbers, run parameters (read length, cycle count, multiplexing index), run status (in-progress/completed/failed/aborted), and output data location (FASTQ/BAM path in BaseSpace or cloud storage). Central transactional record linking instrument operations to sequencing and bioinformatics domains.' .

ind:ServiceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Service Contract' ;
    rdfs:comment 'Manages all instrument coverage entitlements — including manufacturer standard warranties (included with purchase), extended warranties, and separately purchased service contracts (comprehensive, parts-only, time-and-materials). Captures entitlement type, acquisition method (bundled-with-purchase vs separately-sold), coverage scope, SLA tier (response time, uptime guarantee), start and end dates, annual value, renewal terms, included PM visits, provider (manufacturer/third-party), and claim eligibility rules. Sourced from SAP SD service contracts and Salesforce CRM. SSOT for answering \'what coverage does this instrument have?\' for field service entitlement checking, warranty claims, and SLA compliance.' .

ind:Configuration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Instrument ;
    rdfs:label 'Configuration' ;
    rdfs:comment 'Captures the approved operational configuration state of each instrument asset at a point in time — including run parameter defaults, network configuration, enabled modules, software feature flags, GxP-validated configuration baseline, and configuration change history. Supports 21 CFR Part 11 configuration management and ISO 13485 change control. Distinct from firmware_deployment in that it captures the full configuration profile, not just the firmware version.' .

ind:InventoryTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reagent ;
    rdfs:label 'Inventory Transaction' ;
    rdfs:comment 'Unified transactional record of all reagent inventory movements — goods receipts from suppliers or manufacturing, internal transfers between storage locations, and consumption events. Captures transaction type, source/destination, quantity, lot reference, and timestamp.' .

ind:RunSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Run Sample' ;
    rdfs:comment 'This association product represents the operational assignment of a biological specimen to a specific instrument sequencing run. In genomics operations, multiple specimens are routinely multiplexed into a single sequencing run (8-96+ specimens per run), and individual specimens may be re-sequenced across multiple runs for additional coverage, validation, or QC failure recovery. Each record captures the lane assignment, index sequences for demultiplexing, loading concentration, per-specimen read counts, quality metrics, and QC status for each specimen-run pairing. This is the core operational entity that enables multiplexed sequencing workflows and per-specimen quality tracking across the sequencing lifecycle.. Existence Justification: In genomics sequencing operations, specimens and instrument runs have a genuine many-to-many relationship. Multiple specimens (8-96+) are routinely multiplexed into a single sequencing run to maximize instrument utilization and reduce per-specimen cost. Individual specimens are frequently re-sequenced across multiple runs when initial runs fail QC, when additional coverage is needed, or for validation purposes. The business actively manages these specimen-run assignments as operational entities with specific lane assignments, index sequences, loading concentrations, and per-specimen quality metrics.' .

ind:Cohort rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Cohort' ;
    rdfs:comment 'Master reference table for cohort. Referenced by cohort_id.' .

ind:Assay rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Assay' ;
    rdfs:comment 'Master reference table for clinical_assay. Referenced by clinical_assay_id.' .

ind:PerformingLaboratory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Performing Laboratory' ;
    rdfs:comment 'Master reference table for performing_laboratory. Referenced by performing_laboratory_id.' .

ind:Bundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle' ;
    rdfs:comment 'Master reference table for bundle. Referenced by bundle_id.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Master reference table for risk_assessment. Referenced by risk_assessment_id.' .

ind:TestMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Master reference table for test_method. Referenced by test_method_id.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Site' ;
    rdfs:comment 'Master reference table for manufacturing_site. Referenced by manufacturing_site_id.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Master reference table for equipment. Referenced by equipment_id.' .

ind:LabSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sample ;
    rdfs:label 'Lab Site' ;
    rdfs:comment 'Master reference table for lab_site. Referenced by lab_site_id.' .

ind:Plant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Master reference table for plant. Referenced by plant_id.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master reference table for warehouse. Referenced by warehouse_id.' .

ind:Study rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Study' ;
    rdfs:comment 'Master reference table for study. Referenced by study_id.' .

ind:BundleComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle Component' ;
    rdfs:comment 'This association product represents the Component role between bundle and sku. It captures the explicit composition of a product bundle — which SKUs are included, in what quantities, in what sequence, whether each is mandatory, and at what component-level discount. Each record links one bundle to one SKU and carries attributes that exist only in the context of that specific bundle-SKU pairing. Product and commercial teams actively create, update, and retire these records as bundle definitions evolve.. Existence Justification: In genomics biotech commercial operations, bundles are explicitly composed of multiple SKUs (e.g., a sequencing bundle may include a flow cell SKU, a reagent kit SKU, and a software license SKU), and a single SKU can participate in multiple bundles simultaneously (e.g., a 96-sample prep kit SKU may appear in both a research bundle and a clinical bundle). Product managers actively define, update, and retire these bundle-SKU compositions as a named business process called bundle component management. The `is_bundle_component` flag on the SKU table and the detection-phase relationship data (quantity_per_bundle, component_sequence, is_mandatory_component, bundle_component_discount_percent) confirm this is an operationally managed relationship with its own attributes.' .

ind:ValidationRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Manufacturing ;
    rdfs:label 'Validation Run' ;
    rdfs:comment 'This association product represents the formal designation of a production batch as an executed run within a process validation study. It captures the operational and regulatory evidence generated when a specific production batch is used to demonstrate process consistency for a validation study. Each record links one process_validation study to one production_batch and carries run-specific attributes — sequence number, outcome, acceptance status, run date, and deviation count — that exist only in the context of this specific batch-within-study execution. Governed by ICH Q7, FDA Process Validation Guidance (2011), and EMA guidelines.. Existence Justification: In GMP biotech/genomics manufacturing, process validation studies formally designate specific production batches as \'validation runs\' — this is a regulated, actively managed business activity governed by ICH Q7 and FDA Process Validation Guidance (2011). One validation study requires multiple batches (typically 3 consecutive runs minimum per regulatory guidance), and one production batch can legitimately serve as a validation run for multiple concurrent studies (e.g., a batch validating both a new process parameter and a site transfer simultaneously). The \'Validation Run\' is a recognized regulatory and operational concept with its own data (run sequence, outcome, acceptance status) that belongs to neither the validation study nor the batch record alone.' .

ind:ConstructAssayEvaluation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Research ;
    rdfs:label 'Construct Assay Evaluation' ;
    rdfs:comment 'This association product represents the Evaluation event between a CRISPR construct and an assay development program. It captures the operational record of a specific construct being tested within a specific assay development project — including the role the construct played, the concentration used, the validation outcome for that pairing, and the scientific rationale for inclusion. Each record links one crispr_construct to one assay_development with attributes that exist only in the context of this evaluation relationship. Required for regulatory submissions (FDA 510(k), CE-IVD) that mandate documentation of all constructs evaluated during assay development.. Existence Justification: In genomics biotech R&D, a single CRISPR construct (e.g., a Cas9-gRNA targeting BRCA1) is routinely evaluated across multiple assay development programs (e.g., an NGS editing efficiency assay, a qPCR readout assay, and a CNV detection assay). Conversely, a single assay development program evaluates multiple CRISPR constructs to compare editing efficiency, specificity, and performance characteristics. This is an actively managed operational relationship — assay scientists explicitly track which constructs were tested in which assay programs, at what concentration, in what role, and with what validation outcome, particularly for regulatory submissions (FDA 510(k), CE-IVD) that require documented evidence of all constructs evaluated.' .

ind:TestSiteAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Clinical ;
    rdfs:label 'Test Site Authorization' ;
    rdfs:comment 'This association product represents the Contract between test_catalog and performing_laboratory. It captures the governed authorization of a specific clinical assay version at a specific CLIA/CAP-certified laboratory site. Each record defines one test-lab authorization with its own lifecycle, accreditation scope, turnaround time commitment, and menu access level — attributes that exist only in the context of this specific test-site pairing and cannot reside on either the test catalog or the laboratory master alone.. Existence Justification: In clinical genomics operations, a single test (e.g., WGS, targeted panel) can be authorized and performed at multiple CLIA-certified laboratory sites, and each laboratory site is authorized to perform multiple tests. This is not a derived analytical correlation — genomics companies with multi-site operations actively govern which tests are authorized at which sites, with distinct effective dates, turnaround time commitments, and accreditation scope per site-test combination. The business explicitly manages this as a \'laboratory test offering\' or \'test site authorization\' — a recognized operational concept with its own lifecycle.' .

# --- Attribute Properties ---
ind:pipelineId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Id' ;
    rdfs:comment 'Unique surrogate identifier for each bioinformatics pipeline definition record in the master registry. Primary key for the pipeline data product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pipeline .

ind:assayId rdf:type rdf:Property ;
    rdfs:label 'Assay Id' ;
    rdfs:comment 'Foreign key linking to clinical.clinical_assay. Business justification: Bioinformatics pipelines are designed and validated for specific clinical assays — driving pipeline design scope, validation requirements, and regulatory submissions. A domain expert expects pipelines' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assay .

ind:catalogItemId rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Validated bioinformatics pipelines are commercialized as catalog products (e.g., Illumina DRAGEN, 10x Genomics Cell Ranger). Business need: product catalog management, revenue recognition, regulatory ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:controlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Controlled Document Id' ;
    rdfs:comment 'Reference identifier for the GxP validation documentation package stored in Veeva Vault (e.g., IQ/OQ/PQ validation report document ID). Links the pipeline definition to its formal validation evidence for regulatory audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_model. Business justification: Bioinformatics pipelines are validated for specific sequencer platforms (e.g., NovaSeq 6000 vs MiSeq). This link enforces platform-specific pipeline qualification requirements, ensures correct algorit' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to quality.risk_assessment. Business justification: IVD and clinical diagnostic pipelines require a formal risk assessment (IEC 62304 software risk classification, FMEA). Linking pipeline to quality.risk_assessment enables risk-based oversight of pipel' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:softwareReleaseId rdf:type rdf:Property ;
    rdfs:label 'Software Release Id' ;
    rdfs:comment 'Foreign key linking to product.software_release. Business justification: Bioinformatics pipelines are distributed as versioned software releases for product lifecycle management, FDA/CE regulatory submissions, and customer entitlement enforcement. A genomics product manage' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareRelease .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Clinical/diagnostic pipelines are locked to specific regulatory submissions (510k, CE-IVD) for version control and post-market surveillance. New attribute needed to track which submission authorized e' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:algorithmName rdf:type rdf:Property ;
    rdfs:label 'Algorithm Name' ;
    rdfs:comment 'Name of the primary algorithm or tool used by the pipeline (e.g., \'BWA-MEM\', \'STAR\', \'GATK HaplotypeCaller\', \'DeepVariant\', \'VEP\', \'ANNOVAR\'). Identifies the computational engine for reproducibility and regulatory documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmParameters rdf:type rdf:Property ;
    rdfs:label 'Algorithm Parameters' ;
    rdfs:comment 'JSON-serialized string of key algorithm configuration parameters used by the pipeline (e.g., GATK HaplotypeCaller ploidy, BWA-MEM seed length, DeepVariant model type). Stored as a structured string for auditability and reproducibility. Required for GxP validation documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version of the underlying algorithm or tool (e.g., \'BWA 0.7.17\', \'GATK 4.3.0.0\', \'DeepVariant 1.5\'). Distinct from the pipeline version — the same pipeline version may reference a specific algorithm version. Required for GxP validation and regulatory submissions.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationDatabase rdf:type rdf:Property ;
    rdfs:label 'Annotation Database' ;
    rdfs:comment 'Name and version of the variant annotation database(s) used by the pipeline (e.g., \'ClinVar 2024-01\', \'gnomAD v3.1.2\', \'dbSNP 156\', \'COSMIC v97\'). Determines the clinical and population-level context applied to called variants.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayType rdf:type rdf:Property ;
    rdfs:label 'Assay Type' ;
    rdfs:comment 'Supported sequencing assay type(s) for which this pipeline is designed (e.g., WGS — Whole Genome Sequencing, WES — Whole Exome Sequencing, targeted panel, amplicon, RNA-seq). Determines pipeline applicability to incoming sample runs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Documented reason for the creation of this pipeline version (e.g., \'Updated reference genome to GRCh38\', \'Algorithm parameter tuning for improved sensitivity\', \'Bug fix in CNV caller\'). Required for GxP change control and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvDetectionSupported rdf:type rdf:Property ;
    rdfs:label 'Cnv Detection Supported' ;
    rdfs:comment 'Indicates whether the pipeline includes Copy Number Variation (CNV) detection capability. CNV analysis identifies genomic regions with abnormal copy numbers, relevant for oncology and rare disease diagnostics.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerImage rdf:type rdf:Property ;
    rdfs:label 'Container Image' ;
    rdfs:comment 'Docker or Singularity container image reference (repository:tag) used to package and execute the pipeline (e.g., \'genomics-biotech/bwa-pipeline:1.0.0\'). Ensures reproducibility and environment consistency across HPC and cloud runs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this pipeline record was first created in the master registry. Supports audit trail requirements under GxP 21 CFR Part 11 and data lineage tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this pipeline version is approved and available for production use. Pipelines should not be used in production runs before this date. Supports GxP change control and regulatory traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Runtime Hours' ;
    rdfs:comment 'Estimated wall-clock runtime in hours for a standard pipeline execution on a typical input dataset. Used for TAT (Turnaround Time) planning, SLA commitments, and HPC/cloud job scheduling.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Execution Environment' ;
    rdfs:comment 'Compute environment where the pipeline is designed to execute (HPC — High-Performance Computing cluster, AWS cloud, on-premise servers, hybrid, or Databricks). Drives infrastructure provisioning and cost allocation.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Gxp Validation Status' ;
    rdfs:comment 'GxP validation status of the pipeline indicating whether it has been formally validated for use in regulated (GMP/GLP/GCP) environments. Pipelines used in IVD or clinical assay workflows must be validated per FDA 21 CFR Part 11 and ISO 13485 requirements.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDataFormat rdf:type rdf:Property ;
    rdfs:label 'Input Data Format' ;
    rdfs:comment 'Primary input file format accepted by the pipeline (e.g., FASTQ for raw sequencing reads, BAM — Binary Alignment Map for aligned reads, CRAM, VCF — Variant Call Format). Defines upstream data dependencies and ingestion requirements.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Regulatory intended use classification of the pipeline: RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), research, clinical, or manufacturing QC. Determines applicable regulatory framework and validation requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isParallelizable rdf:type rdf:Property ;
    rdfs:label 'Is Parallelizable' ;
    rdfs:comment 'Indicates whether the pipeline supports parallel execution across multiple compute nodes or shards (e.g., scatter-gather parallelism in WDL). Parallelizable pipelines can be scaled horizontally on HPC or AWS for reduced TAT.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafThreshold rdf:type rdf:Property ;
    rdfs:label 'Maf Threshold' ;
    rdfs:comment 'Minor Allele Frequency (MAF) threshold used by the pipeline to filter common variants from rare variant analysis. Variants with MAF above this threshold may be excluded from clinical reporting. Expressed as a decimal (e.g., 0.01 = 1%).' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCpuCores rdf:type rdf:Property ;
    rdfs:label 'Max Cpu Cores' ;
    rdfs:comment 'Maximum number of CPU cores allocated per pipeline execution job. Used for HPC/AWS resource planning, cost estimation, and job scheduling configuration.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Max Memory Gb' ;
    rdfs:comment 'Maximum RAM memory in gigabytes (GB) required per pipeline execution job. Critical for HPC cluster and AWS instance type selection and cost management.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Min Coverage Depth' ;
    rdfs:comment 'Minimum sequencing coverage depth (read depth, expressed as integer fold-coverage, e.g., 30x) required for the pipeline to produce reliable results. Used in QC gating and assay validation documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPhredScore rdf:type rdf:Property ;
    rdfs:label 'Min Phred Score' ;
    rdfs:comment 'Minimum Phred quality score threshold applied during pipeline execution for base quality filtering. Phred scores represent the probability of an incorrect base call; higher values indicate higher quality. Typical threshold is Q20 or Q30.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minReadLength rdf:type rdf:Property ;
    rdfs:label 'Min Read Length' ;
    rdfs:comment 'Minimum sequencing read length in base pairs (bp) required for this pipeline to function correctly. Ensures compatibility with sequencing instrument output and library preparation protocols.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplexingSupported rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Supported' ;
    rdfs:comment 'Indicates whether the pipeline supports multiplexed sample processing (multiple samples pooled on a single flow cell and demultiplexed during processing). True if multiplexing/demultiplexing is handled within the pipeline.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outputDataFormat rdf:type rdf:Property ;
    rdfs:label 'Output Data Format' ;
    rdfs:comment 'Primary output file format produced by the pipeline (e.g., BAM/CRAM for alignment, VCF/gVCF — Genomic VCF for variant calls, BED, TSV). Defines downstream data consumption and annotation pipeline compatibility. [ENUM-REF-CANDIDATE: BAM|CRAM|VCF|gVCF|BED|TSV|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the bioinformatics team or organizational unit responsible for this pipeline (e.g., \'Clinical Bioinformatics\', \'Research Genomics\', \'NGS Platform Engineering\'). Supports organizational accountability and resource planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the pipeline (e.g., \'NGS-ALIGN-BWA-001\', \'VC-GATK-WGS-002\'). Used in SOPs, regulatory submissions, and cross-system references.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineDescription rdf:type rdf:Property ;
    rdfs:label 'Pipeline Description' ;
    rdfs:comment 'Free-text narrative description of the pipeline\'s purpose, methodology, and key capabilities. Provides context for bioinformaticians, clinical scientists, and regulatory reviewers who need to understand the pipeline\'s function without reading the source code.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Name' ;
    rdfs:comment 'Human-readable name of the bioinformatics pipeline (e.g., \'BWA-MEM Alignment Pipeline\', \'GATK Variant Calling Pipeline\', \'VEP Annotation Pipeline\'). Used in reporting, dashboards, and user interfaces.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline definition (draft, active, deprecated, retired, under_validation). Controls whether the pipeline is available for production runs. Active pipelines are cleared for use; deprecated/retired pipelines are preserved for historical traceability.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineType rdf:type rdf:Property ;
    rdfs:label 'Pipeline Type' ;
    rdfs:comment 'Categorical classification of the pipeline by its primary computational function (e.g., alignment, variant calling, annotation, CNV/SNP analysis, MAF calculation, QC). Drives workflow routing and reporting segmentation. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|snp_analysis|maf_calculation|qc|other — promote to reference product]' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceGenomeAssembly rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Assembly' ;
    rdfs:comment 'Name and version of the reference genome assembly used by this pipeline (e.g., \'GRCh38\', \'GRCh37/hg19\', \'GRCm39\'). Critical for variant calling accuracy, annotation consistency, and regulatory traceability. Links to the Reference Genomics data domain.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which this pipeline version was retired or deprecated and is no longer available for new production runs. Historical runs executed under this version remain traceable. Nullable for active pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snpDetectionSupported rdf:type rdf:Property ;
    rdfs:label 'Snp Detection Supported' ;
    rdfs:comment 'Indicates whether the pipeline includes Single Nucleotide Polymorphism (SNP) detection and genotyping capability. SNP analysis is foundational for population genomics, pharmacogenomics, and GWAS studies.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Document number or identifier of the Standard Operating Procedure (SOP) governing the use and execution of this pipeline (e.g., \'SOP-BIO-0042-v3\'). Required for GxP compliance and CLIA/CAP laboratory accreditation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Source Repository Url' ;
    rdfs:comment 'URL of the version-controlled source code repository for this pipeline (e.g., GitHub, GitLab, Bitbucket repository URL). Enables code traceability, change history review, and CI/CD integration for GxP-compliant software development.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this pipeline record. Required for GxP audit trail compliance and change management tracking in the Databricks Silver Layer.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:variantCallingLod rdf:type rdf:Property ;
    rdfs:label 'Variant Calling Lod' ;
    rdfs:comment 'Limit of Detection (LOD) for variant calling expressed as the minimum variant allele frequency (VAF) detectable by this pipeline. Critical for somatic variant calling pipelines and clinical assay validation documentation.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Semantic version number of the pipeline (e.g., \'1.0.0\', \'2.3.1\'). Tracks iterative changes to algorithms, parameters, or reference genome compatibility. Critical for GxP validation traceability and reproducibility of genomic results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowLanguage rdf:type rdf:Property ;
    rdfs:label 'Workflow Language' ;
    rdfs:comment 'Workflow definition language used to implement the pipeline (e.g., WDL — Workflow Description Language, Nextflow, Snakemake, CWL — Common Workflow Language). Determines tooling requirements for execution and portability. [ENUM-REF-CANDIDATE: WDL|Nextflow|Snakemake|CWL|Bash|Python|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineVersionId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version Id' ;
    rdfs:comment 'Unique surrogate identifier for each versioned record of a bioinformatics pipeline in the authoritative master registry. Primary key for the pipeline_version entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineVersion .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.approval. Business justification: A specific pipeline version is cleared under a specific regulatory approval (e.g., software version v2.1.0 cleared under 510(k) K231234). IVD software lifecycle management requires knowing which appro' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Foreign key linking to quality.capa. Business justification: A pipeline version with systemic validation failures or repeated production deviations may be subject to a CAPA requiring version remediation or retirement. Linking pipeline_version to quality.capa en' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:changeControlId rdf:type rdf:Property ;
    rdfs:label 'Change Control Id' ;
    rdfs:comment 'Reference identifier of the formal change control record in MasterControl or Veeva Vault that authorized the creation or modification of this pipeline version (e.g., \'CC-2024-00456\'). Mandatory for GxP-controlled pipelines to maintain a complete audit trail of version changes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeControl .

ind:deviationId rdf:type rdf:Property ;
    rdfs:label 'Deviation Id' ;
    rdfs:comment 'Foreign key linking to quality.deviation. Business justification: A pipeline version deployed with known deviations from its validation protocol (e.g., emergency deployment before full validation) must be linked to the formal deviation record. This is a GxP requirem' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deviation .

ind:deviceIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Device Identifier Id' ;
    rdfs:comment 'Foreign key linking to regulatory.device_identifier. Business justification: Under FDA UDI rules and EUDAMED, each software version of an IVD pipeline (Software as a Medical Device) must be associated with a specific device identifier (UDI-DI). Direct FK from pipeline_version ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceIdentifier .

ind:predecessorVersionPipelineVersionId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Version Pipeline Version Id' ;
    rdfs:comment 'Reference to the pipeline_version_id of the immediately preceding version of this pipeline. Enables traversal of the full version lineage chain from the earliest to the current version, supporting data lineage tracking and regulatory audit trails.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineVersion .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to product.specification. Business justification: Pipeline versions must be validated against product specifications (sensitivity, specificity, LOD, Q30 thresholds). QA and regulatory teams require this link to confirm which product specification a p' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:validatedInstrumentModelId rdf:type rdf:Property ;
    rdfs:label 'Validated Instrument Model Id' ;
    rdfs:comment 'Foreign key linking to instrument.model. Business justification: A specific pipeline version is validated against a specific instrument model generation (e.g., pipeline v2.1 validated only on NovaSeq X, not NovaSeq 6000). Role-prefix \'validated_instrument_\' used be' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:validatedReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Validated Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Pipeline validation studies qualify specific reagent SKUs (e.g., "validated with Illumina TruSeq DNA PCR-Free kit catalog #20015963"). Change control process requires revalidation when reagent formula' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:validationDocumentId rdf:type rdf:Property ;
    rdfs:label 'Validation Document Id' ;
    rdfs:comment 'Reference identifier of the formal validation report or protocol document stored in Veeva Vault (e.g., \'VV-VAL-2024-00123\'). Links this pipeline version to its regulatory validation evidence package for audit and regulatory submission purposes.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:validationStudyId rdf:type rdf:Property ;
    rdfs:label 'Validation Study Id' ;
    rdfs:comment 'Foreign key linking to quality.validation_study. Business justification: Each pipeline version must be formally validated and linked to the QMS validation study record. GxP traceability requires knowing which quality.validation_study validated a given pipeline_version. Exi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValidationStudy .

ind:algorithmConfigJson rdf:type rdf:Property ;
    rdfs:label 'Algorithm Config Json' ;
    rdfs:comment 'JSON-serialized configuration document capturing all algorithm parameter definitions for this pipeline version, including parameter name, data type, default value, allowed range, and GxP-controlled flag for each parameter (e.g., minimum Phred Score threshold, minimum coverage depth, MAF cutoff, LOD threshold). Stored as a STRING to avoid complex types per schema rules. Enables full parameter reproducibility and change-control auditing.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignerTool rdf:type rdf:Property ;
    rdfs:label 'Aligner Tool' ;
    rdfs:comment 'Name and version of the read alignment tool used to produce BAM files in this pipeline version (e.g., \'BWA-MEM2 2.2.1\', \'STAR 2.7.10\', \'Bowtie2 2.5.1\'). Determines alignment accuracy, BAM format characteristics, and downstream variant calling performance.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when this pipeline version received formal approval for production use. Distinct from validation_date (which records scientific validation completion) — this records the organizational authorization event. Required for GxP electronic signature audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the authorized signatory (e.g., Head of Bioinformatics, Quality Assurance Manager) who formally approved this pipeline version for production use. Required for GxP electronic signature compliance under 21 CFR Part 11.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchlingEntryReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Entry Reference' ;
    rdfs:comment 'Reference identifier of the Benchling R&D Notebook entry documenting the scientific design, development rationale, and experimental validation data for this pipeline version. Provides traceability from the computational pipeline back to the laboratory science.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changelogSummary rdf:type rdf:Property ;
    rdfs:label 'Changelog Summary' ;
    rdfs:comment 'Human-readable summary of changes introduced in this pipeline version compared to the immediately preceding version. Documents algorithm updates, parameter changes, bug fixes, new assay support, or reference genome updates. Essential for regulatory submissions and scientific reproducibility.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImageDigest rdf:type rdf:Property ;
    rdfs:label 'Container Image Digest' ;
    rdfs:comment 'Cryptographic SHA-256 digest of the container image, providing immutable integrity verification of the pipeline\'s computational environment. Ensures that the exact same software stack is used across all runs referencing this version, supporting GxP audit trail requirements.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImageUri rdf:type rdf:Property ;
    rdfs:label 'Container Image Uri' ;
    rdfs:comment 'Fully-qualified URI of the Docker or Singularity container image encapsulating this pipeline version\'s runtime environment (e.g., \'registry.genomicsbiotech.com/pipelines/wgs-gvc:3.2.1\'). Ensures computational reproducibility by pinning all software dependencies. Required for GxP-compliant pipeline execution.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this pipeline version is approved and authorized for production use. Defines the start of the version\'s active period in the pipeline lifecycle. Required for regulatory traceability and change control documentation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this pipeline version\'s authorization expires or is superseded. Null indicates the version remains active with no planned end date. Used for lifecycle management, regulatory compliance, and preventing use of expired pipeline versions in clinical workflows.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gitCommitHash rdf:type rdf:Property ;
    rdfs:label 'Git Commit Hash' ;
    rdfs:comment 'Full 40-character SHA-1 Git commit hash uniquely identifying the exact source code state for this pipeline version. Provides immutable, cryptographically verifiable traceability to the precise codebase used, supporting GxP audit trail and reproducibility requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpControlled rdf:type rdf:Property ;
    rdfs:label 'Gxp Controlled' ;
    rdfs:comment 'Indicates whether this pipeline version is subject to Good Practice (GxP) regulations (GMP, GLP, GCP), requiring formal change control, validation documentation, and audit trail maintenance. True = GxP-controlled pipeline requiring full validation lifecycle; False = non-GxP pipeline (e.g., exploratory R&D).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hpcComputeProfile rdf:type rdf:Property ;
    rdfs:label 'Hpc Compute Profile' ;
    rdfs:comment 'Designated High-Performance Computing (HPC) or cloud compute execution profile for this pipeline version. Specifies the orchestration environment: AWS Batch, AWS EC2, HPC SLURM cluster, HPC LSF cluster, local execution, or hybrid. Drives resource allocation and job scheduling configurations.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Boolean flag indicating whether this pipeline version has been formally deprecated and superseded by a newer version. True = deprecated (new pipeline runs should not use this version); False = not deprecated. Distinct from \'retired\' status — deprecated versions may still be used for legacy run reproduction.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this pipeline version record. Required for change control auditing and data lineage tracking in GxP-regulated environments. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lodSensitivity rdf:type rdf:Property ;
    rdfs:label 'Lod Sensitivity' ;
    rdfs:comment 'Analytical Limit of Detection (LOD) expressed as the minimum variant allele fraction detectable by this pipeline version at a defined confidence level. A key analytical performance characteristic for clinical and IVD-validated pipelines, reported in regulatory submissions and validation documentation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCpuCores rdf:type rdf:Property ;
    rdfs:label 'Min Cpu Cores' ;
    rdfs:comment 'Minimum number of CPU cores required to execute this pipeline version. Used for compute resource planning, job scheduling, and cost estimation on HPC/AWS infrastructure.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Min Memory Gb' ;
    rdfs:comment 'Minimum RAM in gigabytes required to execute this pipeline version. Critical for HPC/AWS job scheduling, instance type selection, and preventing out-of-memory failures during large WGS runs.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Primary file format produced as the final output of this pipeline version. VCF = Variant Call Format; BAM = Binary Alignment Map; FASTQ = raw sequence data; CRAM = compressed BAM; GVCF = Genomic VCF for joint genotyping. Determines downstream compatibility with analysis tools and data consumers. [ENUM-REF-CANDIDATE: VCF|BAM|FASTQ|CRAM|BED|TSV|GVCF — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineCategory rdf:type rdf:Property ;
    rdfs:label 'Pipeline Category' ;
    rdfs:comment 'Functional classification of the pipeline by its primary computational purpose. Drives routing logic, validation requirements, and reporting groupings. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|maf_calculation|array_processing|demultiplexing|other — promote to reference product]' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineOwner rdf:type rdf:Property ;
    rdfs:label 'Pipeline Owner' ;
    rdfs:comment 'Name or employee identifier of the bioinformatics scientist or team lead who is the designated owner and accountable party for this pipeline version. Responsible for validation, change control, and scientific integrity of the pipeline.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceGenomeBuild rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Build' ;
    rdfs:comment 'Primary reference genome assembly version this pipeline version is configured to align against (e.g., GRCh38, T2T-CHM13). Critical for reproducibility, variant calling accuracy, and cross-study comparability. Determines coordinate system for BAM/VCF outputs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionIds rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ids' ;
    rdfs:comment 'Comma-separated list of regulatory submission identifiers (FDA 510(k), PMA, De Novo, EMA IVDR submission numbers) in which this pipeline version is referenced or cited (e.g., \'K240001,DEN230045\'). Enables traceability between pipeline versions and regulatory filings.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semanticVersion rdf:type rdf:Property ;
    rdfs:label 'Semantic Version' ;
    rdfs:comment 'Semantic versioning string (MAJOR.MINOR.PATCH) for this pipeline release, following SemVer 2.0 conventions (e.g., \'3.2.1\'). MAJOR increments indicate breaking algorithm changes; MINOR indicate new features; PATCH indicate bug fixes. Enables reproducibility tracking from FASTQ to final genomic output.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedAssayTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Assay Types' ;
    rdfs:comment 'Comma-separated list of genomic assay types this pipeline version is designed and validated to process (e.g., \'WGS,WES,targeted_panel\'). Assay types include WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), targeted panel, array-based, amplicon, RNA-Seq, single-cell. Drives compatibility checks at pipeline run initiation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:useClassification rdf:type rdf:Property ;
    rdfs:label 'Use Classification' ;
    rdfs:comment 'Regulatory use classification governing how this pipeline version may be deployed. RUO = Research Use Only; IVD = In Vitro Diagnostic (FDA-cleared/approved); LDT = Laboratory Developed Test; CE-IVD = Conformité Européenne In Vitro Diagnostic (EU market). Determines permissible clinical and commercial applications.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which formal validation of this pipeline version was completed and documented. Required for IVD, LDT, and GxP-controlled pipelines. Supports regulatory submission timelines and audit readiness.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Regulatory validation classification of this pipeline version. \'unvalidated\' = no formal validation performed; \'ruo_validated\' = validated for Research Use Only (RUO) applications; \'ivd_validated\' = validated as an In Vitro Diagnostic (IVD) per FDA/IVDR requirements; \'clinical_validated\' = validated for clinical reporting under CLIA/CAP standards.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCallerTool rdf:type rdf:Property ;
    rdfs:label 'Variant Caller Tool' ;
    rdfs:comment 'Name and version of the primary variant calling algorithm/tool used in this pipeline version (e.g., \'GATK HaplotypeCaller 4.4.0\', \'DeepVariant 1.5\', \'Strelka2 2.9.10\'). Directly determines the VCF output format and variant calling characteristics. Essential for reproducibility and regulatory documentation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual pipeline execution record in the bioinformatics domain. Primary key for the pipeline_run data product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRun .

ind:accessionId rdf:type rdf:Property ;
    rdfs:label 'Accession Id' ;
    rdfs:comment 'Foreign key linking to sample.accession. Business justification: Clinical genomics pipeline runs are initiated from accession records. TAT compliance reporting, result delivery workflows, and clinical order fulfillment require linking pipeline runs directly to the ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accession .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Clinical and commercial sequencing runs are performed for customer accounts (pharma partners, clinical labs, research institutions). Essential for revenue recognition, SLA compliance tracking, regulat' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:aliquotId rdf:type rdf:Property ;
    rdfs:label 'Aliquot Id' ;
    rdfs:comment 'Foreign key linking to sample.aliquot. Business justification: Pipeline runs are triggered from a specific aliquot\'s sequencing data. LIMS-to-bioinformatics handoff traceability, QC failure root-cause analysis, and GxP audit trails require identifying the exact a' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aliquot .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_asset. Business justification: Track which physical sequencer generated analyzed data. Critical for instrument-specific bias correction algorithms, troubleshooting systematic quality issues, regulatory audit trails, and correlating' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.audit. Business justification: Regulatory audits (FDA, CAP, CLIA) review specific pipeline runs for GxP compliance, data integrity, electronic signature adherence, and audit trail completeness. Auditors sample pipeline runs to veri' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Reference to the batch grouping under which this pipeline run was submitted. Supports cohort-level monitoring, batch-level result delivery, and aggregate SLA reporting across multiple samples processed together.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:catalogId rdf:type rdf:Property ;
    rdfs:label 'Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Pipeline runs consume specific sequencing reagents (library prep kits, flow cell reagents). Critical for QC root cause analysis when variant calling failures correlate to reagent lot quality issues. R' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:demuxResultId rdf:type rdf:Property ;
    rdfs:label 'Demux Result Id' ;
    rdfs:comment 'Foreign key linking to sequencing.demux_result. Business justification: Pipelines consume demultiplexed FASTQ files as input, fundamental data flow relationship. This link enables tracking from demultiplexing through analysis, required for troubleshooting index hopping, u' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemuxResult .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Foreign key linking to research.experiment. Business justification: A pipeline run is directly triggered by a research experiment — sequencing experiment data flows into a pipeline run for analysis. This operational link enables experiment-level reporting of compute c' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Experiment .

ind:extractionId rdf:type rdf:Property ;
    rdfs:label 'Extraction Id' ;
    rdfs:comment 'Foreign key linking to sample.extraction. Business justification: Pipeline run quality is directly influenced by extraction parameters (RIN score, purity ratios, yield). Bioinformatics QC investigations and regulatory submissions require tracing pipeline runs to the' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Extraction .

ind:installedInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Installed Instrument Id' ;
    rdfs:comment 'Foreign key linking to customer.installed_instrument. Business justification: Sequencing runs executed on customer-installed instruments (at customer sites or in service labs) must be tracked to the specific instrument for utilization analytics, warranty/service contract valida' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstalledInstrument .

ind:instrumentRunId rdf:type rdf:Property ;
    rdfs:label 'Instrument Run Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_run. Business justification: Every bioinformatics pipeline processes sequencing data from a specific instrument run. This link is essential for data provenance, quality troubleshooting, regulatory traceability (21 CFR Part 11), a' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentRun .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Extends reagent traceability to lot level. Clinical genomics labs must document exact reagent lot used in each sequencing run for CLIA compliance and FDA submissions. Enables batch-level investigation' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: A pipeline run producing out-of-specification results (QC failure, coverage below validated threshold) triggers a nonconformance record in the QMS. This direct link enables GxP disposition decisions (' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:oosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Oos Investigation Id' ;
    rdfs:comment 'Foreign key linking to quality.oos_investigation. Business justification: Pipeline runs with QC metrics outside validated specification ranges (e.g., percent_bases_above_q30 below threshold) directly trigger OOS investigations in GxP genomics labs. This link is required for' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.line. Business justification: In genomics sequencing-as-a-service, each pipeline run fulfills a specific order line (e.g., WGS variant calling service). This link enables service fulfillment tracking, TAT reporting, and customer i' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Foreign key linking to supply.plant. Business justification: GxP-regulated clinical pipeline runs must be traceable to the executing site/plant for CLIA/CAP accreditation and FDA site-specific clearances. Multi-site genomics operations require site attribution ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:productionBatchId rdf:type rdf:Property ;
    rdfs:label 'Production Batch Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_batch. Business justification: GMP lot traceability: each pipeline run must be traceable to the manufactured kit/reagent production batch used. Distinct from supply.batch — production_batch captures the GMP manufacturing record. Re' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:runSampleId rdf:type rdf:Property ;
    rdfs:label 'Run Sample Id' ;
    rdfs:comment 'Foreign key linking to sample.run_sample. Business justification: The run_sample record is the LIMS-side record of a specific aliquot loaded on a sequencer lane. Pipeline runs are triggered per run_sample. This link enables direct LIMS-to-bioinformatics result recon' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RunSample .

ind:sampleSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Sample Specimen Id' ;
    rdfs:comment 'Reference to the biological sample or sample batch that triggered this pipeline execution. Links the computational run back to the physical specimen tracked in LabVantage LIMS for end-to-end traceability from wet lab to genomic result.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSpecimen .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_order. Business justification: In GMP genomics manufacturing, bioinformatics pipeline runs are executed as part of manufacturing work orders for kit release testing or in-process QC. Linking pipeline runs to work orders enables MES' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:cloudJobReference rdf:type rdf:Property ;
    rdfs:label 'Cloud Job Reference' ;
    rdfs:comment 'The native job identifier assigned by the compute platform (e.g., AWS Batch Job ID, HPC SLURM Job ID) for this pipeline execution. Used for cross-referencing with infrastructure cost billing records and compute platform logs.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The date and time when the pipeline run reached a terminal state (completed, failed, or cancelled). Used to calculate wall-clock duration, TAT (Turnaround Time), and SLA compliance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:computeEnvironment rdf:type rdf:Property ;
    rdfs:label 'Compute Environment' ;
    rdfs:comment 'The infrastructure platform on which this pipeline run was executed (e.g., HPC cluster, AWS cloud, GCP). Used for cost attribution, performance benchmarking across environments, and capacity planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuCoreHours rdf:type rdf:Property ;
    rdfs:label 'Cpu Core Hours' ;
    rdfs:comment 'Total CPU core-hours consumed by this pipeline run across all compute nodes. Primary metric for cloud/HPC cost attribution, capacity planning, and per-sample computational cost reporting.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCategory rdf:type rdf:Property ;
    rdfs:label 'Error Category' ;
    rdfs:comment 'Standardized classification of the failure type when a pipeline run does not complete successfully. Enables systematic failure triage, root cause analysis, and trend reporting on pipeline reliability.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessageSummary rdf:type rdf:Property ;
    rdfs:label 'Error Message Summary' ;
    rdfs:comment 'Truncated human-readable summary of the error message or exception captured at pipeline failure. Supports first-level failure triage without requiring access to full log files. Maximum 2000 characters.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComputeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Compute Cost Usd' ;
    rdfs:comment 'Estimated monetary cost in US Dollars for the compute resources consumed by this pipeline run, derived from CPU core-hours, memory, and storage metrics against cloud/HPC pricing. Used for per-sample cost attribution, project budget tracking, and COGS reporting.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitCode rdf:type rdf:Property ;
    rdfs:label 'Exit Code' ;
    rdfs:comment 'Numeric exit code returned by the pipeline process upon termination. Exit code 0 indicates successful completion; non-zero codes indicate specific failure modes. Used for automated failure classification and triage routing.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputFastqPath rdf:type rdf:Property ;
    rdfs:label 'Input Fastq Path' ;
    rdfs:comment 'Cloud or HPC storage path to the input FASTQ file(s) consumed by this pipeline run. FASTQ is the raw sequencing data format produced by NGS instruments. Required for data lineage tracking, reprocessing, and audit trail from raw data to result.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Mean Coverage Depth' ;
    rdfs:comment 'Average number of sequencing reads aligned to each base position in the target region or genome. A key QC metric indicating sequencing depth adequacy. Minimum thresholds vary by assay type (e.g., 30x for WGS, 100x for targeted panels).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputBamPath rdf:type rdf:Property ;
    rdfs:label 'Output Bam Path' ;
    rdfs:comment 'Cloud or HPC storage path to the output BAM (Binary Alignment Map) file produced by alignment pipeline runs. BAM is the standard compressed binary format for aligned sequencing reads. Used for downstream variant calling and data lineage.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputReportPath rdf:type rdf:Property ;
    rdfs:label 'Output Report Path' ;
    rdfs:comment 'Cloud or HPC storage path to the final analytical report or summary output artifact (e.g., QC report, annotation summary, CNV report) generated by this pipeline run. Used for result delivery to downstream consumers and regulatory documentation.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputVcfPath rdf:type rdf:Property ;
    rdfs:label 'Output Vcf Path' ;
    rdfs:comment 'Cloud or HPC storage path to the output VCF (Variant Call Format) file produced by variant calling pipeline runs. VCF is the standard format for representing SNPs, indels, and structural variants. Central artifact for clinical and research genomic interpretation.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Peak Memory Gb' ;
    rdfs:comment 'Maximum RAM (in gigabytes) consumed at any point during this pipeline run. Used for resource right-sizing, out-of-memory failure diagnosis, and HPC/cloud instance type optimization.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentBasesAboveQ30 rdf:type rdf:Property ;
    rdfs:label 'Percent Bases Above Q30' ;
    rdfs:comment 'Percentage of sequencing bases with a Phred quality score of 30 or higher, indicating 99.9% base call accuracy. A primary sequencing QC metric used to assess run quality before downstream analysis. Industry standard threshold is ≥80%.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentReadsMapped rdf:type rdf:Property ;
    rdfs:label 'Percent Reads Mapped' ;
    rdfs:comment 'Percentage of total sequencing reads that successfully aligned to the reference genome. A key alignment QC metric; low mapping rates indicate sample quality issues, contamination, or reference genome mismatch.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcFailureReason rdf:type rdf:Property ;
    rdfs:label 'Qc Failure Reason' ;
    rdfs:comment 'Human-readable description of the specific QC metric(s) that caused this pipeline run to fail QC assessment (e.g., \'Mean coverage depth 18x below 30x threshold\', \'Mapping rate 62% below 80% threshold\'). Populated only when qc_pass_flag is False.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Boolean indicator of whether this pipeline run passed all defined QC thresholds (coverage depth, mapping rate, Phred score, variant count sanity checks). Drives automated downstream routing — only QC-passed runs proceed to clinical or research reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryUseClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Use Classification' ;
    rdfs:comment 'Regulatory classification of the intended use of this pipeline run\'s outputs. IVD (In Vitro Diagnostic) runs are subject to FDA/IVDR validation requirements; RUO (Research Use Only) runs have different compliance obligations. Drives audit trail depth and result release controls.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprocessingFlag rdf:type rdf:Property ;
    rdfs:label 'Reprocessing Flag' ;
    rdfs:comment 'Indicates whether this pipeline run is a reprocessing of a previously executed run (e.g., triggered by QC failure, pipeline version upgrade, or parameter correction). When True, data_lineage_run_id should reference the original run.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Run Accession Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to this pipeline execution at submission time. Used for cross-system traceability, SLA tracking, and audit references across LIMS, BaseSpace, and downstream reporting systems.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline execution. Drives operational dashboards, SLA breach alerting, failure triage workflows, and batch-level completion monitoring. Transitions: queued → running → completed | failed | cancelled.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingAssayType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Assay Type' ;
    rdfs:comment 'The type of genomic sequencing assay whose data is being processed in this pipeline run (e.g., WGS — Whole Genome Sequencing, WES — Whole Exome Sequencing, targeted panel). Determines applicable pipeline parameters, QC thresholds, and regulatory classification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this pipeline run exceeded its defined SLA target TAT. Populated upon run completion. Drives SLA breach alerting, escalation workflows in ServiceNow, and operational performance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTatHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Tat Hours' ;
    rdfs:comment 'The contracted or internally defined SLA target for Turnaround Time (TAT) in hours for this pipeline run, based on assay type and regulatory classification. Used to assess SLA compliance by comparing against actual wall-clock duration.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The date and time when the pipeline run transitioned from queued to actively executing on the compute environment. Used to calculate queue wait time (start_timestamp minus submission_timestamp) and actual wall-clock execution duration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageConsumedGb rdf:type rdf:Property ;
    rdfs:label 'Storage Consumed Gb' ;
    rdfs:comment 'Total intermediate and output storage consumed by this pipeline run in gigabytes. Includes FASTQ inputs, BAM alignment files, VCF outputs, and annotation artifacts. Used for storage cost attribution and capacity planning.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when this pipeline run was submitted to the compute queue. Serves as the principal business event timestamp for SLA measurement start, TAT (Turnaround Time) calculation, and queue wait-time analytics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalReadsCount rdf:type rdf:Property ;
    rdfs:label 'Total Reads Count' ;
    rdfs:comment 'Total number of sequencing reads processed by this pipeline run. Used as a primary input volume metric for QC assessment, cost normalization, and performance benchmarking across pipeline runs.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variantCount rdf:type rdf:Property ;
    rdfs:label 'Variant Count' ;
    rdfs:comment 'Total number of genomic variants (SNPs, indels, CNVs) identified and reported in the VCF output of this pipeline run. Used for QC sanity checks, result completeness validation, and cohort-level variant burden analytics.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wallClockDurationSec rdf:type rdf:Property ;
    rdfs:label 'Wall Clock Duration Sec' ;
    rdfs:comment 'Total elapsed real-world time in seconds from pipeline start to completion. Used for performance benchmarking, SLA compliance verification, and identifying pipeline runs that exceed expected execution time thresholds.' ;
    rdfs:domain ind:PipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowEngine rdf:type rdf:Property ;
    rdfs:label 'Workflow Engine' ;
    rdfs:comment 'The bioinformatics workflow orchestration engine used to execute this pipeline run (e.g., Nextflow, Snakemake, CWL, WDL/Cromwell). Relevant for reproducibility documentation, debugging, and regulatory submission of computational methods.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRunStepId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Step Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular step-level execution record within a bioinformatics pipeline run. Primary key for this entity.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRunStep .

ind:computeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Compute Cost Usd' ;
    rdfs:comment 'Estimated or actual cloud/HPC compute cost in US dollars attributed to this step execution, based on instance type, duration, and resource consumption. Supports COGS allocation, R&D cost tracking, and pipeline ROI analysis.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpuCoresRequested rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Requested' ;
    rdfs:comment 'Number of CPU cores requested for this step from the HPC/cloud compute scheduler. Used for resource planning, cost attribution, and pipeline optimization.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpuCoresUsed rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Used' ;
    rdfs:comment 'Actual number of CPU cores consumed by this step during execution, as reported by the compute scheduler. Enables resource efficiency analysis and right-sizing of future pipeline runs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLineageHash rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the step\'s input files, parameters, and tool version, enabling deterministic reproducibility verification and tamper detection for GxP and regulatory audit purposes.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diskIoReadGb rdf:type rdf:Property ;
    rdfs:label 'Disk Io Read Gb' ;
    rdfs:comment 'Total data read from storage in gigabytes during this step\'s execution. Used for storage cost attribution, I/O bottleneck analysis, and pipeline performance optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diskIoWriteGb rdf:type rdf:Property ;
    rdfs:label 'Disk Io Write Gb' ;
    rdfs:comment 'Total data written to storage in gigabytes during this step\'s execution. Used for storage cost attribution, output size estimation, and pipeline performance optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Wall-clock execution time of this pipeline step in seconds, as recorded by the job scheduler. Used for HPC/cloud cost attribution, performance profiling, and pipeline optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Captured error or exception message from the tool\'s standard error output when the step fails. Enables rapid root cause analysis and debugging without requiring access to raw compute logs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFileFormat rdf:type rdf:Property ;
    rdfs:label 'Input File Format' ;
    rdfs:comment 'Standard genomic file format of the primary input consumed by this step (e.g., FASTQ for raw reads, BAM for aligned reads, VCF for variants). Supports data lineage classification and format validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|GVCF|BED|TSV|FASTA|BCF — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFilePaths rdf:type rdf:Property ;
    rdfs:label 'Input File Paths' ;
    rdfs:comment 'Semicolon-delimited list of input file URIs consumed by this step (e.g., S3 paths to FASTQ, BAM, or VCF files). Enables data lineage tracing from raw sequencing data through each transformation step.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instanceType rdf:type rdf:Property ;
    rdfs:label 'Instance Type' ;
    rdfs:comment 'Cloud or HPC instance/node type used to execute this step (e.g., \'r5.4xlarge\', \'c5.2xlarge\' for AWS EC2). Enables cost attribution, performance benchmarking, and optimal instance selection for future runs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGxpCritical rdf:type rdf:Property ;
    rdfs:label 'Is Gxp Critical' ;
    rdfs:comment 'Indicates whether this step is classified as GxP-critical (True), meaning it falls within the validated computational workflow for clinical or regulatory submissions and requires enhanced audit trail and change control.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logFilePath rdf:type rdf:Property ;
    rdfs:label 'Log File Path' ;
    rdfs:comment 'URI path to the full execution log file for this step (e.g., S3 path to CloudWatch log export or SLURM job log). Enables detailed debugging and GxP audit trail access.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryRequestedGb rdf:type rdf:Property ;
    rdfs:label 'Memory Requested Gb' ;
    rdfs:comment 'Amount of RAM in gigabytes requested for this step from the compute scheduler. Used for resource planning and cost attribution in HPC/AWS environments.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryUsedGb rdf:type rdf:Property ;
    rdfs:label 'Memory Used Gb' ;
    rdfs:comment 'Peak RAM consumption in gigabytes recorded during this step\'s execution. Enables memory efficiency analysis, out-of-memory failure diagnosis, and right-sizing recommendations.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputFileFormat rdf:type rdf:Property ;
    rdfs:label 'Output File Format' ;
    rdfs:comment 'Standard genomic file format of the primary output produced by this step (e.g., BAM for alignment, VCF/GVCF for variant calling, annotated TSV for annotation steps). Enables format-aware downstream processing. [ENUM-REF-CANDIDATE: BAM|CRAM|VCF|GVCF|BED|TSV|FASTA|BCF|HTML — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFilePaths rdf:type rdf:Property ;
    rdfs:label 'Output File Paths' ;
    rdfs:comment 'Semicolon-delimited list of output file URIs produced by this step (e.g., S3 paths to aligned BAM, called VCF, or annotated TSV files). Supports downstream step input resolution and data lineage documentation.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametersJson rdf:type rdf:Property ;
    rdfs:label 'Parameters Json' ;
    rdfs:comment 'JSON-serialized string of all command-line parameters and configuration settings applied to the tool during this step execution (e.g., minimum base quality, ploidy, emit-ref-confidence mode). Required for GxP reproducibility and regulatory submission.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMetricsJson rdf:type rdf:Property ;
    rdfs:label 'Qc Metrics Json' ;
    rdfs:comment 'JSON-serialized string of key QC metrics produced by this step (e.g., Phred score distribution, coverage depth, duplication rate, alignment rate, transition/transversion ratio). Enables automated QC gating and quality reporting.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this step has been retried following a failure. Tracks transient infrastructure failures (e.g., AWS spot instance preemption) and informs pipeline reliability metrics.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spotInstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Spot Instance Flag' ;
    rdfs:comment 'Indicates whether this step was executed on a cloud spot/preemptible instance (True) or an on-demand instance (False). Spot instances reduce cost but increase retry risk; used for cost-reliability trade-off analysis.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step End Timestamp' ;
    rdfs:comment 'Date and time when this pipeline step completed or terminated execution. Combined with step_start_timestamp to derive step duration for performance benchmarking and TAT reporting.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepExecutionReference rdf:type rdf:Property ;
    rdfs:label 'Step Execution Reference' ;
    rdfs:comment 'Externally-known unique identifier for this step execution as assigned by the HPC/cloud job scheduler (e.g., AWS Batch job ID, SLURM job ID, or Nextflow process hash). Used for cross-referencing with compute infrastructure logs.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the pipeline step (e.g., \'BWA-MEM Alignment\', \'GATK HaplotypeCaller\', \'Picard MarkDuplicates\', \'VEP Annotation\', \'Trimmomatic QC\'). Used for display, reporting, and debugging.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepOrder rdf:type rdf:Property ;
    rdfs:label 'Step Order' ;
    rdfs:comment 'Sequential position of this step within the parent pipeline run, defining the execution order and enabling reconstruction of the full data lineage chain from raw FASTQ input to final genomic result.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when this pipeline step began execution on the compute infrastructure. Used for duration calculation, performance profiling, and TAT (Turnaround Time) analysis.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline step execution. Drives monitoring dashboards, alerting workflows, and SLA tracking for bioinformatics pipeline operations.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Functional classification of the pipeline step indicating the category of genomic processing performed. Enables performance profiling and resource benchmarking by step category. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|qc|trimming|demultiplexing|cnv_analysis|snp_genotyping|library_prep_qc|indexing|phasing|imputation — promote to reference product]' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolName rdf:type rdf:Property ;
    rdfs:label 'Tool Name' ;
    rdfs:comment 'Name of the bioinformatics software tool invoked during this step (e.g., BWA-MEM, GATK, Picard, STAR, Samtools, VEP, DeepVariant, Strelka2). Critical for reproducibility, audit, and regulatory submission documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolVersion rdf:type rdf:Property ;
    rdfs:label 'Tool Version' ;
    rdfs:comment 'Semantic version string of the bioinformatics tool used in this step (e.g., \'4.2.6.1\' for GATK, \'0.7.17\' for BWA). Required for GxP compliance, reproducibility, and regulatory submission traceability.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeJobId rdf:type rdf:Property ;
    rdfs:label 'Compute Job Id' ;
    rdfs:comment 'Unique surrogate identifier for each compute job record in the bioinformatics pipeline ecosystem. Primary key for the compute_job data product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComputeJob .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the research or clinical project under which this compute job is executed. Used for chargeback reporting, budget tracking, and resource quota allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:awsRegion rdf:type rdf:Property ;
    rdfs:label 'Aws Region' ;
    rdfs:comment 'The AWS geographic region where this cloud compute job was executed (e.g., us-east-1, eu-west-1). Used for data residency compliance, latency analysis, and regional cost optimization.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuCoresActual rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Actual' ;
    rdfs:comment 'The actual number of CPU cores consumed by the job during execution as reported by the scheduler or cloud monitoring service. Used for resource utilization analysis and right-sizing recommendations.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time when the compute job completed, failed, or was terminated. Used to calculate wall-clock duration and measure pipeline turnaround time (TAT).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'The estimated monetary cost in US dollars for this compute job, calculated based on instance type, pricing model, and wall-clock duration. Used for cloud cost governance, chargeback reporting, and budget tracking against project allocations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpuCountRequested rdf:type rdf:Property ;
    rdfs:label 'Gpu Count Requested' ;
    rdfs:comment 'The number of GPU accelerators requested by the job at submission time. Relevant for deep learning-based variant calling, structural variant analysis, and AI/ML genomics workloads.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hpcNodeName rdf:type rdf:Property ;
    rdfs:label 'Hpc Node Name' ;
    rdfs:comment 'The hostname or identifier of the HPC compute node on which this job executed. Used for hardware failure correlation, node performance analysis, and infrastructure capacity planning.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDataPath rdf:type rdf:Property ;
    rdfs:label 'Input Data Path' ;
    rdfs:comment 'The storage path or URI of the primary input data consumed by this job (e.g., S3 bucket path to FASTQ files, BAM files). Used for data lineage tracking from raw FASTQ to interpreted genomic results.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSpotPreempted rdf:type rdf:Property ;
    rdfs:label 'Is Spot Preempted' ;
    rdfs:comment 'Indicates whether this job was interrupted due to spot instance reclamation by the cloud provider. Used to measure spot preemption rates, assess cost-reliability trade-offs, and inform spot usage policies.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobName rdf:type rdf:Property ;
    rdfs:label 'Job Name' ;
    rdfs:comment 'Human-readable name assigned to the compute job, typically reflecting the pipeline step or algorithm being executed (e.g., bwa_alignment, gatk_variant_calling, cnv_analysis).' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle state of the compute job within the scheduler or cloud batch system. Drives operational monitoring, SLA tracking, and pipeline retry logic. [ENUM-REF-CANDIDATE: pending|queued|running|completed|failed|cancelled|timeout|preempted — promote to reference product]' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the bioinformatics workload executed by this job. Drives resource profiling and cost allocation by workload category. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|qc|demultiplexing|assembly|other — promote to reference product]' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryActualGb rdf:type rdf:Property ;
    rdfs:label 'Memory Actual Gb' ;
    rdfs:comment 'The peak RAM consumption in gigabytes recorded during job execution. Used for right-sizing analysis, out-of-memory root cause investigation, and capacity planning.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputDataPath rdf:type rdf:Property ;
    rdfs:label 'Output Data Path' ;
    rdfs:comment 'The storage path or URI where this job\'s primary output data was written (e.g., S3 path to BAM, VCF, or annotation files). Used for downstream pipeline step chaining and data lineage documentation.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'The pricing or allocation model under which the compute instance was provisioned. Spot instances offer cost savings but risk preemption; on-demand and reserved instances provide reliability. Drives cloud cost governance and budget forecasting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'The business priority tier assigned to this compute job, governing scheduling precedence within the queue. Clinical and regulatory jobs typically receive critical or high priority; exploratory R&D jobs receive standard or low.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'The name of the HPC job queue or cloud batch queue to which this job was submitted (e.g., high_priority, standard, low_priority, gpu_queue). Used for capacity planning and queue performance analysis.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCpuCoreHoursConsumed rdf:type rdf:Property ;
    rdfs:label 'Quota Cpu Core Hours Consumed' ;
    rdfs:comment 'The number of CPU core-hours consumed by this job, counted against the team or project\'s allocated compute quota. Used for quota enforcement, capacity planning, and fair-share scheduling.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulerJobReference rdf:type rdf:Property ;
    rdfs:label 'Scheduler Job Reference' ;
    rdfs:comment 'The native job identifier assigned by the HPC job scheduler or cloud batch service (e.g., SLURM job ID, LSF job ID, PBS job ID, AWS Batch job ID). Used to cross-reference with scheduler logs and cloud billing records.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageIopsRequested rdf:type rdf:Property ;
    rdfs:label 'Storage Iops Requested' ;
    rdfs:comment 'The number of storage input/output operations per second (IOPS) requested by the job. Critical for I/O-intensive genomics workloads such as BAM sorting, FASTQ processing, and large VCF annotation.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageReadGb rdf:type rdf:Property ;
    rdfs:label 'Storage Read Gb' ;
    rdfs:comment 'Total data volume in gigabytes read from storage during job execution. Used for data egress cost estimation, storage performance analysis, and pipeline I/O profiling.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageWriteGb rdf:type rdf:Property ;
    rdfs:label 'Storage Write Gb' ;
    rdfs:comment 'Total data volume in gigabytes written to storage during job execution. Used for storage capacity planning, data lifecycle management, and pipeline output sizing.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wallClockSeconds rdf:type rdf:Property ;
    rdfs:label 'Wall Clock Seconds' ;
    rdfs:comment 'The actual elapsed real-world time in seconds from job start to job end. Distinct from CPU time; used for SLA compliance, pipeline TAT reporting, and resource efficiency analysis.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alignmentResultId rdf:type rdf:Property ;
    rdfs:label 'Alignment Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each BAM/CRAM alignment result record produced by a bioinformatics pipeline run. Primary key for this entity. Role: TRANSACTION_HEADER — this entity represents a discrete computational event (alignment job output) with its own lifecycle, QC status, and lineage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlignmentResult .

ind:flowCellId rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Id' ;
    rdfs:comment 'Identifier of the sequencing Flow Cell used to generate the raw reads for this alignment. The Flow Cell is the consumable cartridge on which sequencing chemistry occurs. Traceability to the flow cell enables investigation of batch-level sequencing failures, reagent lot issues, and instrument performance trends.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlowCell .

ind:genomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Genomic Artifact Id' ;
    rdfs:comment 'Foreign key linking to bioinformatics.genomic_artifact. Business justification: alignment_result is METADATA about an alignment (QC metrics, statistics). The actual BAM/CRAM file is a genomic_artifact. alignment_result currently has output_file_path, output_file_format, output_fi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:libraryId rdf:type rdf:Property ;
    rdfs:label 'Library Id' ;
    rdfs:comment 'Foreign key linking to sequencing.library. Business justification: Alignment results are library-specific outputs required for library QC, coverage analysis, and prep troubleshooting. Labs use this to identify failed libraries, optimize prep protocols, and determine ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Library .

ind:libraryPrepReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Library Prep Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Alignment QC metrics (duplicate rate, insert size distribution, GC bias) are library prep chemistry-dependent. Troubleshooting workflow: when coverage uniformity degrades, correlate to library prep re' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:qcResultId rdf:type rdf:Property ;
    rdfs:label 'Qc Result Id' ;
    rdfs:comment 'Foreign key linking to quality.qc_result. Business justification: Alignment results depend on upstream sample QC (DNA integrity, concentration, purity) performed in laboratory. Poor alignment metrics often trace to failed sample QC. Enables integrated quality invest' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcResult .

ind:sequencingRunId rdf:type rdf:Property ;
    rdfs:label 'Sequencing Run Id' ;
    rdfs:comment 'Foreign key linking to sequencing.sequencing_run. Business justification: Alignment results must trace to originating sequencing run for quality control, coverage analysis, and reprocessing decisions. Essential for clinical laboratories to validate alignment quality against' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SequencingRun .

ind:alignerVersion rdf:type rdf:Property ;
    rdfs:label 'Aligner Version' ;
    rdfs:comment 'Semantic version string of the aligner tool used (e.g., 0.7.17, 2.2.1). Version tracking is mandatory for bioinformatics method validation, regulatory submissions (FDA, EMA), and reproducibility of clinical genomic results. A version change may require re-validation under ISO 15189 and CLIA.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alignment Timestamp' ;
    rdfs:comment 'The date and time at which the alignment job completed and the BAM/CRAM output file was finalized. Represents the principal real-world business event time for this record. Used for Turnaround Time (TAT) calculations, SLA monitoring, and pipeline performance analytics. Satisfies BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chimericReadRatePct rdf:type rdf:Property ;
    rdfs:label 'Chimeric Read Rate Pct' ;
    rdfs:comment 'Percentage of reads flagged as chimeric (reads where the two ends map to different chromosomes or distant genomic locations). Elevated chimeric rates indicate library preparation artifacts, structural variant signals, or sequencing errors. Monitored as a QC metric in clinical WGS and structural variant detection workflows.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computePlatform rdf:type rdf:Property ;
    rdfs:label 'Compute Platform' ;
    rdfs:comment 'Compute infrastructure platform on which the alignment job was executed: AWS (Amazon Web Services), on-premise High-Performance Computing (HPC) cluster, Azure, GCP, or Illumina DRAGEN server. Required for cost allocation, performance benchmarking, and infrastructure capacity planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeRuntimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Compute Runtime Seconds' ;
    rdfs:comment 'Wall-clock time in seconds taken to complete the alignment job from job start to job completion. Used for pipeline performance monitoring, SLA compliance tracking, HPC/cloud resource optimization, and cost modeling. Enables identification of performance regressions across aligner versions or reference genome builds.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageUniformityPct rdf:type rdf:Property ;
    rdfs:label 'Coverage Uniformity Pct' ;
    rdfs:comment 'Percentage of target bases covered at ≥20% of the mean coverage depth, measuring the uniformity of sequencing coverage across the target region. High uniformity indicates consistent library preparation and sequencing performance. Low uniformity may indicate GC bias or capture inefficiency in WES/panel assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateRatePct rdf:type rdf:Property ;
    rdfs:label 'Duplicate Rate Pct' ;
    rdfs:comment 'Percentage of mapped reads flagged as PCR or optical duplicates (duplicate_reads / mapped_reads × 100). High duplicate rates reduce effective coverage depth and can introduce variant calling bias. Typically assessed using Picard MarkDuplicates or equivalent. Threshold violations trigger QC warning or failure.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcContentPct rdf:type rdf:Property ;
    rdfs:label 'Gc Content Pct' ;
    rdfs:comment 'Percentage of guanine (G) and cytosine (C) bases in the aligned reads. GC content deviating significantly from the expected genomic average (~41% for human) indicates GC bias in library preparation or PCR amplification, which can cause uneven coverage and affect Copy Number Variation (CNV) analysis accuracy.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertSizeStdDevBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Std Dev Bp' ;
    rdfs:comment 'Standard deviation of the insert size distribution in base pairs. A narrow distribution indicates consistent library preparation; a wide distribution may indicate mixed fragment populations or library quality issues. Used alongside median_insert_size_bp for comprehensive library QC assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReanalysis rdf:type rdf:Property ;
    rdfs:label 'Is Reanalysis' ;
    rdfs:comment 'Boolean flag indicating whether this alignment result is a reanalysis of a previously aligned sample (True) or an original first-pass alignment (False). Reanalyses may be triggered by reference genome updates, aligner version upgrades, QC failures, or clinical reinterpretation requests. Supports data lineage and version management.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappedReads rdf:type rdf:Property ;
    rdfs:label 'Mapped Reads' ;
    rdfs:comment 'Number of sequencing reads that successfully mapped to the reference genome. Together with total_reads, this is used to compute the mapping rate. Low mapped read counts may indicate sample contamination, library preparation failure, or reference genome mismatch.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mappingRatePct rdf:type rdf:Property ;
    rdfs:label 'Mapping Rate Pct' ;
    rdfs:comment 'Percentage of total reads that successfully mapped to the reference genome (mapped_reads / total_reads × 100). A primary alignment QC metric; typical acceptable thresholds are ≥90% for human WGS. Values below threshold trigger QC failure and potential re-sequencing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanBaseQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Base Quality Score' ;
    rdfs:comment 'Mean Phred Score across all bases in the aligned reads. The Phred Score is a logarithmic measure of base call accuracy (Q30 = 99.9% accuracy). A key sequencing run quality metric; Q30 ≥ 80% is a standard threshold for clinical-grade sequencing. Directly impacts variant calling sensitivity and specificity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Median Insert Size Bp' ;
    rdfs:comment 'Median length of the DNA fragment insert in base pairs (bp) as measured from the aligned paired-end reads. Insert size distribution is a key library preparation QC metric; unexpected values indicate library degradation, adapter contamination, or incorrect size selection. Affects read overlap and variant calling accuracy.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctBasesAbove10x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 10x' ;
    rdfs:comment 'Percentage of target bases covered at a minimum depth of 10× reads. A standard coverage adequacy metric used in clinical genomics reporting to confirm that the majority of the target region has sufficient depth for reliable variant calling. Commonly reported in clinical assay validation and CAP/CLIA compliance.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAbove30x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 30x' ;
    rdfs:comment 'Percentage of target bases covered at a minimum depth of 30× reads. The 30× threshold is the standard minimum for clinical Whole Genome Sequencing (WGS) and is required by many regulatory and accreditation bodies. Distinct from pct_bases_above_10x as it represents a higher stringency clinical threshold.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctQ30Bases rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 Bases' ;
    rdfs:comment 'Percentage of sequenced bases with a Phred Score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. The Q30 percentage is the primary sequencing run quality KPI reported by Illumina instruments and BaseSpace. Minimum thresholds (typically ≥75–80%) are defined in clinical assay SOPs and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:properlyPairedRatePct rdf:type rdf:Property ;
    rdfs:label 'Properly Paired Rate Pct' ;
    rdfs:comment 'Percentage of read pairs where both reads mapped to the reference genome in the expected orientation and within the expected insert size range. Low properly paired rates indicate library preparation issues, adapter contamination, or reference genome incompatibility. A standard SAMtools flagstat metric.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Review Notes' ;
    rdfs:comment 'Free-text notes entered by a bioinformatics scientist or QC reviewer during manual review of this alignment result. Captures the rationale for QC status overrides, observations about anomalous metrics, or instructions for downstream processing. Required for GxP audit trail and CLIA/CAP documentation.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Overall Quality Control (QC) pass/fail/warning determination for this alignment result based on evaluation of all QC metrics against defined thresholds. Drives downstream workflow routing: pass results proceed to variant calling; fail results trigger re-sequencing or sample rejection. Satisfies LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLengthBp rdf:type rdf:Property ;
    rdfs:label 'Read Length Bp' ;
    rdfs:comment 'Length of sequencing reads in base pairs (e.g., 150 bp for standard Illumina short-read, 10,000+ bp for long-read platforms). Read length affects alignment accuracy, variant detection capability (especially for structural variants and repeat regions), and computational resource requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Result Identifier' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for this alignment result (e.g., ALN-2024-00123456). Used in LIMS reports, bioinformatics dashboards, and regulatory submissions to uniquely identify an alignment output without exposing surrogate keys. Satisfies BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingPlatform rdf:type rdf:Property ;
    rdfs:label 'Sequencing Platform' ;
    rdfs:comment 'Sequencing instrument platform used to generate the raw reads (e.g., Illumina NovaSeq, PacBio Revio, Oxford Nanopore PromethION). Platform determines read characteristics (length, error profile), applicable alignment tools, and QC thresholds. Required for method validation documentation and regulatory submissions.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Type' ;
    rdfs:comment 'Classification of the sequencing assay type for which this alignment was performed: Whole Genome Sequencing (WGS), Whole Exome Sequencing (WES), targeted panel, RNA-seq, amplicon, or metagenomics. Determines applicable QC thresholds, coverage requirements, and downstream analysis workflows. Satisfies CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandBalanceRatio rdf:type rdf:Property ;
    rdfs:label 'Strand Balance Ratio' ;
    rdfs:comment 'Ratio of reads mapping to the forward strand versus the reverse strand (forward_reads / total_mapped_reads). Expected value is approximately 0.5 for unstranded libraries. Significant deviation indicates strand bias, which can introduce systematic variant calling errors, particularly for SNP and indel detection.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReads rdf:type rdf:Property ;
    rdfs:label 'Total Reads' ;
    rdfs:comment 'Total number of sequencing reads in the input FASTQ file(s) submitted for alignment. Reflects sequencing depth and library complexity. Used to assess whether sufficient input data was provided for the intended application (e.g., WGS, WES, targeted panel). Key QC input metric.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variantCallResultId rdf:type rdf:Property ;
    rdfs:label 'Variant Call Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each variant call result record in the Databricks Silver Layer. Entity role: TRANSACTION_HEADER — represents a discrete genomic analysis event (variant detection/genotyping run output) with a clear lifecycle from raw FASTQ to interpreted result.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantCallResult .

ind:priorResultVariantCallResultId rdf:type rdf:Property ;
    rdfs:label 'Prior Result Variant Call Result Id' ;
    rdfs:comment 'Reference to the previous variant call result record that this result supersedes or is a reanalysis of. Enables data lineage chain tracking from original to reanalyzed results. Null for original (non-reanalysis) results.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantCallResult .

ind:annotationPipelineVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Pipeline Version' ;
    rdfs:comment 'Version of the variant annotation pipeline applied to this call set (e.g., VEP, ANNOVAR, SnpEff). Tracks which annotation databases and logic were used, critical for clinical interpretation reproducibility and regulatory audit.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrayProbeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Array Probe Identifier' ;
    rdfs:comment 'Unique identifier of the array probe used to genotype this locus (applicable to array-based SNP genotyping only, e.g., Illumina Infinium probe ID). Null for NGS-based variant calls. Enables probe-level QC and array manifest cross-referencing.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callMethod rdf:type rdf:Property ;
    rdfs:label 'Call Method' ;
    rdfs:comment 'Discriminator indicating the technology and analytical approach used to generate this result: NGS variant calling (WGS/WES), array-based SNP genotyping, targeted panel sequencing, or targeted genotyping. Drives downstream interpretation logic and QC thresholds.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callRate rdf:type rdf:Property ;
    rdfs:label 'Call Rate' ;
    rdfs:comment 'Proportion of loci or probes that received a valid genotype call (range 0.0000–1.0000). A key QC metric for array genotyping; samples below threshold (typically <0.97) are flagged for reanalysis. Also applicable to targeted panel completeness.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Timestamp' ;
    rdfs:comment 'The real-world timestamp when the variant calling or genotyping pipeline completed and this result was generated. Principal business event time for this transaction. Used for turnaround time (TAT) calculations and SLA monitoring.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:callerToolName rdf:type rdf:Property ;
    rdfs:label 'Caller Tool Name' ;
    rdfs:comment 'Name of the variant calling or genotyping software tool used (e.g., GATK HaplotypeCaller, DeepVariant, Strelka2, GenomeStudio, Illumina DRAGEN). Essential for reproducibility, audit, and regulatory submission documentation.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callerToolVersion rdf:type rdf:Property ;
    rdfs:label 'Caller Tool Version' ;
    rdfs:comment 'Software version of the variant calling or genotyping tool (e.g., 4.2.6.1 for GATK). Required for regulatory submissions, audit trails, and ensuring reproducibility of results across pipeline versions.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromosome rdf:type rdf:Property ;
    rdfs:label 'Chromosome' ;
    rdfs:comment 'Chromosome identifier for the primary or representative variant locus in this result record (e.g., chr1, chrX, chrMT). For multi-variant result summaries, this field captures the primary locus; individual variant details are in the VCF file.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvCount rdf:type rdf:Property ;
    rdfs:label 'Cnv Count' ;
    rdfs:comment 'Number of copy number variation (CNV) events detected in this result. Applicable to WGS, WES, and array-based CNV analysis workflows. Null for targeted SNP-only panels.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dbsnpConcordanceRate rdf:type rdf:Property ;
    rdfs:label 'Dbsnp Concordance Rate' ;
    rdfs:comment 'Proportion of called variants that are present in the dbSNP database (range 0.0000–1.0000). A QC benchmark for variant calling accuracy; high concordance (>0.95 for WGS) indicates reliable calling performance.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterCriteriaApplied rdf:type rdf:Property ;
    rdfs:label 'Filter Criteria Applied' ;
    rdfs:comment 'Description or identifier of the variant filtering criteria applied to this call set (e.g., VQSR, hard-filter thresholds, panel-specific filters). Documents the post-calling filtering logic for audit, reproducibility, and regulatory submission.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicPosition rdf:type rdf:Property ;
    rdfs:label 'Genomic Position' ;
    rdfs:comment '1-based genomic coordinate of the primary or representative variant locus on the reference genome. Used for locus-level QC reporting, targeted panel coverage verification, and clinical variant lookup.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genotypeQualityScore rdf:type rdf:Property ;
    rdfs:label 'Genotype Quality Score' ;
    rdfs:comment 'Phred-scaled genotype quality score (GQ) for the primary variant call, representing confidence in the assigned genotype. Follows VCF FORMAT/GQ field conventions. Used for variant-level QC filtering and clinical reporting thresholds.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indelCount rdf:type rdf:Property ;
    rdfs:label 'Indel Count' ;
    rdfs:comment 'Number of small insertion and deletion (INDEL) variants called in this result. INDELs are a distinct variant class from SNPs and require separate QC thresholds and clinical interpretation rules.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClinicalReportable rdf:type rdf:Property ;
    rdfs:label 'Is Clinical Reportable' ;
    rdfs:comment 'Indicates whether this variant call result has passed all QC gates and regulatory checks and is eligible for inclusion in a clinical genomics report. True = reportable; False = not reportable (failed QC, RUO designation, or pending review).' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafThresholdApplied rdf:type rdf:Property ;
    rdfs:label 'Maf Threshold Applied' ;
    rdfs:comment 'The minor allele frequency (MAF) cutoff applied during variant filtering or GWAS QC for this result (e.g., 0.01 = 1%). Variants below this threshold may be excluded from population-level analyses. Null if no MAF filter was applied.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAbove20x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 20x' ;
    rdfs:comment 'Proportion of target bases achieving at least 20x sequencing coverage depth (range 0.0000–1.0000). A standard NGS QC threshold metric used to assess adequacy of coverage for reliable variant detection.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reanalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Flag' ;
    rdfs:comment 'Indicates whether this result was generated as a reanalysis of a previously processed sample (e.g., due to updated pipeline version, reference genome, or QC failure). True = reanalysis; False = original analysis. Supports data lineage and version tracking.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryUseDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Use Designation' ;
    rdfs:comment 'Regulatory designation governing the intended use of this result: In Vitro Diagnostic (IVD), Research Use Only (RUO), Laboratory Developed Test (LDT), or CE-IVD (EU conformity). Determines applicable regulatory reporting obligations and data handling requirements.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current lifecycle state of this variant call result record. Controls whether the result is available for clinical reporting, downstream analytics, or has been superseded by a reanalysis. Distinct from QC status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsNumber rdf:type rdf:Property ;
    rdfs:label 'Rs Number' ;
    rdfs:comment 'dbSNP reference SNP identifier (rsID) for the primary or representative variant in this result (e.g., rs334 for the sickle cell HbS variant). Enables cross-study variant lookup, pharmacogenomics mapping, and clinical database concordance checks.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snpCount rdf:type rdf:Property ;
    rdfs:label 'Snp Count' ;
    rdfs:comment 'Number of single nucleotide polymorphism (SNP) variants called in this result. Used for QC benchmarking, GWAS analysis, and pharmacogenomics reporting.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tiTvRatio rdf:type rdf:Property ;
    rdfs:label 'Ti Tv Ratio' ;
    rdfs:comment 'Ratio of transition (Ti) to transversion (Tv) SNP variants in this call set. A critical QC metric for NGS variant calling: expected ~2.0–2.1 for WGS, ~3.0–3.3 for WES coding regions. Deviations indicate potential calling errors or contamination.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGenotypesCalled rdf:type rdf:Property ;
    rdfs:label 'Total Genotypes Called' ;
    rdfs:comment 'Total number of individual genotype calls made in this result. Primarily applicable to array-based SNP genotyping where each probe position yields a discrete genotype call. Distinct from variant count in NGS workflows.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVariantsCalled rdf:type rdf:Property ;
    rdfs:label 'Total Variants Called' ;
    rdfs:comment 'Total count of all variant sites (SNPs, INDELs, CNVs, structural variants) called in this result before any filtering. Primary quantitative output metric for NGS variant calling runs.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useCaseClassification rdf:type rdf:Property ;
    rdfs:label 'Use Case Classification' ;
    rdfs:comment 'Classification of the intended use case for this variant call result. Determines applicable regulatory framework (IVD/RUO/LDT), data access controls, and downstream workflow routing. [ENUM-REF-CANDIDATE: clinical|research|agricultural|pharmacogenomics|oncology|ancestry|gwas|ruo — promote to reference product]' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantsPassFilterCount rdf:type rdf:Property ;
    rdfs:label 'Variants Pass Filter Count' ;
    rdfs:comment 'Number of variants that passed all applied quality filters and are included in the final reportable call set. Distinct from total_variants_called which includes pre-filter counts.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zygosity rdf:type rdf:Property ;
    rdfs:label 'Zygosity' ;
    rdfs:comment 'Zygosity classification of the primary variant call: homozygous reference, heterozygous, homozygous alternate, hemizygous (X-linked in males), or no-call. Critical for clinical interpretation, inheritance pattern analysis, and pharmacogenomics dosing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAnnotationId rdf:type rdf:Property ;
    rdfs:label 'Variant Annotation Id' ;
    rdfs:comment 'Unique surrogate identifier for each variant annotation record in the Silver Layer lakehouse. Primary key for this data product. Entity role: MASTER_RESOURCE — represents a genomic variant annotation artifact with its own identity, lifecycle, and rich set of interpreted attributes derived from annotation pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantAnnotation .

ind:variantKnowledgeBaseId rdf:type rdf:Property ;
    rdfs:label 'Variant Knowledge Base Id' ;
    rdfs:comment 'Foreign key linking to clinical.variant_knowledge_base. Business justification: Variant annotations are enriched from the clinical variant knowledge base — the authoritative source for ACMG classifications and ClinVar accessions. Tracing which knowledge base entry informed an ann' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantKnowledgeBase .

ind:acmgClassification rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification' ;
    rdfs:comment 'Variant classification assigned per ACMG/AMP 2015 guidelines for germline variants (Pathogenic, Likely Pathogenic, Variant of Uncertain Significance (VUS), Likely Benign, Benign). The authoritative classification for clinical genetic testing reports and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acmgCriteriaCodes rdf:type rdf:Property ;
    rdfs:label 'Acmg Criteria Codes' ;
    rdfs:comment 'Pipe-delimited list of ACMG/AMP evidence criteria codes applied to support the variant classification (e.g., PVS1|PS3|PM2|PP3). Provides the evidence basis for the classification decision and supports audit and regulatory review.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationDbVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Db Version' ;
    rdfs:comment 'Version of the annotation database(s) used during annotation (e.g., ClinVar 2024-01, gnomAD v3.1.2, dbSNP b156). Required for regulatory submissions and reproducibility of clinical-grade annotations.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationStatus rdf:type rdf:Property ;
    rdfs:label 'Annotation Status' ;
    rdfs:comment 'Current lifecycle status of the annotation record: pending (awaiting annotation), completed (annotation finalized), failed (annotation pipeline error), review_required (flagged for manual curation), superseded (replaced by a newer annotation run).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Annotation Timestamp' ;
    rdfs:comment 'Timestamp when the annotation pipeline completed and this annotation record was generated. Serves as the principal business event timestamp for the annotation lifecycle. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:annotationTool rdf:type rdf:Property ;
    rdfs:label 'Annotation Tool' ;
    rdfs:comment 'Name of the annotation pipeline tool used to generate this annotation record (VEP=Ensembl Variant Effect Predictor, ANNOVAR, SnpEff). Enables tool-specific interpretation and reproducibility tracking.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationToolVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Tool Version' ;
    rdfs:comment 'Version string of the annotation tool used (e.g., VEP 108.0, ANNOVAR 2023-01-12). Critical for reproducibility, regulatory submissions, and audit trails per GxP and CLIA requirements.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caddPhredScore rdf:type rdf:Property ;
    rdfs:label 'Cadd Phred Score' ;
    rdfs:comment 'Combined Annotation Dependent Depletion (CADD) Phred-scaled score integrating multiple functional annotations to predict variant deleteriousness. Scores ≥20 indicate top 1% most deleterious variants. Used for variant prioritization in research and clinical pipelines.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinvarAccession rdf:type rdf:Property ;
    rdfs:label 'Clinvar Accession' ;
    rdfs:comment 'ClinVar Reference Variant (RCV) accession number uniquely identifying the variant-condition record in the ClinVar database. Enables direct cross-referencing to the authoritative clinical variant database for regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinvarClassification rdf:type rdf:Property ;
    rdfs:label 'Clinvar Classification' ;
    rdfs:comment 'Clinical significance classification of the variant as curated in the NCBI ClinVar database (Pathogenic, Likely Pathogenic, Uncertain Significance (VUS), Likely Benign, Benign). Central to clinical reporting and IVD/LDT assay interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceType rdf:type rdf:Property ;
    rdfs:label 'Consequence Type' ;
    rdfs:comment 'Sequence Ontology (SO) term describing the predicted molecular consequence of the variant on the transcript (e.g., missense_variant, frameshift_variant, stop_gained, splice_site_variant). Primary driver of clinical significance classification. [ENUM-REF-CANDIDATE: missense_variant|frameshift_variant|stop_gained|stop_lost|splice_donor_variant|splice_acceptor_variant|splice_site_variant|synonymous_variant|intron_variant|5_prime_UTR_variant|3_prime_UTR_variant|upstream_gene_variant|downstream_gene_variant|intergenic_variant — promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosmicAccession rdf:type rdf:Property ;
    rdfs:label 'Cosmic Accession' ;
    rdfs:comment 'Catalogue of Somatic Mutations in Cancer (COSMIC) identifier for the variant (e.g., COSM476). Relevant for oncology applications, somatic variant interpretation, and OncoKB tier assignment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbsnpAccession rdf:type rdf:Property ;
    rdfs:label 'Dbsnp Accession' ;
    rdfs:comment 'NCBI dbSNP reference SNP identifier (rsID) for the variant (e.g., rs80357906). Standard cross-reference identifier used in clinical reports, publications, and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exonNumber rdf:type rdf:Property ;
    rdfs:label 'Exon Number' ;
    rdfs:comment 'Exon number within the canonical transcript where the variant is located (e.g., \'14/23\' indicating exon 14 of 23). Reported as a string to accommodate fractional or range notation. Used in clinical reports and splice-site analysis.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneSymbol rdf:type rdf:Property ;
    rdfs:label 'Gene Symbol' ;
    rdfs:comment 'Official HGNC (HUGO Gene Nomenclature Committee) gene symbol for the gene in which the variant is located (e.g., BRCA1, TP53, EGFR). Primary human-readable identifier for gene-level reporting and clinical interpretation.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gnomadMaf rdf:type rdf:Property ;
    rdfs:label 'Gnomad Maf' ;
    rdfs:comment 'Minor Allele Frequency (MAF) of the variant in the Genome Aggregation Database (gnomAD) global population. Used to assess variant rarity and support pathogenicity classification per ACMG/AMP criteria (BA1, BS1, PM2).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gnomadPopulation rdf:type rdf:Property ;
    rdfs:label 'Gnomad Population' ;
    rdfs:comment 'gnomAD population subgroup for which the MAF is reported (e.g., AFR=African, AMR=Latino/Admixed American, EAS=East Asian, NFE=Non-Finnish European). Required for population-stratified allele frequency interpretation. [ENUM-REF-CANDIDATE: AFR|AMR|ASJ|EAS|FIN|NFE|OTH|SAS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hgvsCoding rdf:type rdf:Property ;
    rdfs:label 'Hgvs Coding' ;
    rdfs:comment 'Human Genome Variation Society (HGVS) notation describing the variant at the coding DNA sequence level (e.g., NM_007294.4:c.5266dupC). Standard notation for clinical reporting, regulatory submissions, and variant database submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hgvsProtein rdf:type rdf:Property ;
    rdfs:label 'Hgvs Protein' ;
    rdfs:comment 'HGVS notation describing the predicted amino acid change at the protein level (e.g., NP_009225.1:p.Gln1756Profs). Required for clinical variant reporting and interpretation of functional impact.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Predicted functional impact severity of the variant as classified by the annotation tool (HIGH, MODERATE, LOW, MODIFIER per SnpEff/VEP convention). Used for variant prioritization in clinical and research workflows.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intronNumber rdf:type rdf:Property ;
    rdfs:label 'Intron Number' ;
    rdfs:comment 'Intron number within the canonical transcript where the variant is located (e.g., \'5/22\'). Populated for intronic and splice-site variants. Used in clinical reports and splicing impact assessment.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCanonicalTranscript rdf:type rdf:Property ;
    rdfs:label 'Is Canonical Transcript' ;
    rdfs:comment 'Indicates whether this annotation record is based on the canonical (primary) transcript for the gene as defined by Ensembl or MANE Select. Canonical transcript annotations are used for primary clinical reporting; non-canonical records are retained for completeness.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSomatic rdf:type rdf:Property ;
    rdfs:label 'Is Somatic' ;
    rdfs:comment 'Indicates whether the variant is classified as somatic (True) or germline (False). Drives routing to oncology vs. hereditary disease interpretation workflows, and determines applicable regulatory and reporting frameworks.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oncokbMutationEffect rdf:type rdf:Property ;
    rdfs:label 'Oncokb Mutation Effect' ;
    rdfs:comment 'OncoKB-curated functional effect of the somatic mutation on the gene product (Gain-of-function, Loss-of-function, Neutral, Switch-of-function, Unknown). Supports oncology biomarker reporting and therapeutic decision support.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oncokbTier rdf:type rdf:Property ;
    rdfs:label 'Oncokb Tier' ;
    rdfs:comment 'OncoKB evidence-based therapeutic actionability tier for the somatic variant (Level 1=FDA-approved biomarker, Level 2=Standard care, Level 3A/3B=Investigational, Level 4=Biological evidence, R1/R2=Resistance). Critical for oncology precision medicine and clinical trial matching. [ENUM-REF-CANDIDATE: 1|2|3A|3B|4|R1|R2 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyphen2Prediction rdf:type rdf:Property ;
    rdfs:label 'Polyphen2 Prediction' ;
    rdfs:comment 'Categorical PolyPhen-2 prediction for the amino acid substitution (probably damaging, possibly damaging, benign, unknown). Provides human-readable interpretation of the PolyPhen-2 score for clinical reporting.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyphen2Score rdf:type rdf:Property ;
    rdfs:label 'Polyphen2 Score' ;
    rdfs:comment 'Polymorphism Phenotyping v2 (PolyPhen-2) score predicting the impact of an amino acid substitution on protein structure and function (0=benign, 1=probably damaging). Used as evidence for ACMG/AMP pathogenicity criteria (PP3, BP4).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment '1-based genomic coordinate (POS) on the chromosome where the variant is located, as defined in the VCF specification. Used for precise variant localization and cross-database lookups.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Level of expert review applied to the variant classification (e.g., not_reviewed, single_submitter, expert_panel, practice_guideline). Mirrors ClinVar review status levels and indicates confidence in the reported classification for clinical use.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siftPrediction rdf:type rdf:Property ;
    rdfs:label 'Sift Prediction' ;
    rdfs:comment 'Categorical SIFT prediction for the amino acid substitution (deleterious or tolerated, with confidence qualifier). Provides human-readable interpretation of the SIFT score for clinical reporting.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siftScore rdf:type rdf:Property ;
    rdfs:label 'Sift Score' ;
    rdfs:comment 'Sorting Intolerant From Tolerant (SIFT) score predicting whether an amino acid substitution affects protein function (0=deleterious, 1=tolerated). Used as evidence for ACMG/AMP pathogenicity criteria (PP3, BP4).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strand rdf:type rdf:Property ;
    rdfs:label 'Strand' ;
    rdfs:comment 'DNA strand orientation of the gene/transcript relative to the reference genome (+ for forward/sense strand, - for reverse/antisense strand). Required for correct HGVS notation and splice-site interpretation.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantType rdf:type rdf:Property ;
    rdfs:label 'Variant Type' ;
    rdfs:comment 'Classification of the variant by its molecular nature: Single Nucleotide Polymorphism (SNP), Insertion/Deletion (INDEL), Multi-Nucleotide Polymorphism (MNP), Copy Number Variation (CNV), Structural Variant (SV), or gene Fusion. Drives downstream clinical and research interpretation workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineQcMetricId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Qc Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each pipeline QC metric record generated during genomic data processing. Primary key for this entity.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Qc Specification Id' ;
    rdfs:comment 'Foreign key linking to reagent.qc_specification. Business justification: GxP regulatory traceability requires linking bioinformatics pipeline QC thresholds to the reagent QC specification that defined them. Auditors and regulatory submissions (FDA 21 CFR Part 11, CE-IVD) m' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcSpecification .

ind:evaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluation Timestamp' ;
    rdfs:comment 'Date and time when this QC metric was evaluated against its threshold. This is the principal business event timestamp for the metric record, used for longitudinal QC trending and SLA compliance tracking.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Structured description of why this metric failed its threshold (e.g., \'mean_coverage below 30x minimum\', \'duplication_rate exceeds 20% threshold\'). Populated only when qc_status is \'fail\' or \'warn\'. Enables systematic failure pattern analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPairedEnd rdf:type rdf:Property ;
    rdfs:label 'Is Paired End' ;
    rdfs:comment 'Indicates whether the sequencing data evaluated by this QC metric was generated using paired-end (True) or single-end (False) sequencing chemistry. Affects interpretation of insert size and duplication rate metrics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQcGateBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Qc Gate Blocking' ;
    rdfs:comment 'Indicates whether a failure on this metric blocks downstream pipeline progression (True) or is advisory only (False). Critical for automated QC gating decisions in the bioinformatics pipeline.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'Lane number on the sequencing flow cell from which the data for this QC metric was derived. Enables per-lane QC analysis to detect lane-specific quality issues.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Functional category grouping the QC metric for reporting and trend analysis. Enables domain-specific QC dashboards (e.g., coverage metrics vs. base quality metrics vs. alignment metrics). [ENUM-REF-CANDIDATE: coverage|base_quality|duplication|alignment|contamination|library_complexity|variant_calling — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricComputationDurationSec rdf:type rdf:Property ;
    rdfs:label 'Metric Computation Duration Sec' ;
    rdfs:comment 'Wall-clock time in seconds taken by the QC tool to compute this metric. Supports HPC/cloud compute resource optimization and pipeline performance benchmarking.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Standardized name of the QC metric being recorded (e.g., mean_coverage, pct_q30_bases, duplication_rate, on_target_rate, uniformity, insert_size_median, gc_bias_score). [ENUM-REF-CANDIDATE: mean_coverage|pct_q30_bases|duplication_rate|on_target_rate|uniformity|insert_size_median|gc_bias_score|chimeric_read_rate|adapter_contamination_rate|phred_score_mean — promote to reference product]' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit of measurement for the metric value (e.g., \'x\' for coverage depth, \'%\' for percentage-based metrics, \'bp\' for base-pair measurements, \'reads\' for read counts). Enables correct interpretation and cross-metric comparison.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'Numeric value of the QC metric as computed by the QC tool for this pipeline step and sample. This is the principal quantitative observation (e.g., 45.3 for mean_coverage, 0.92 for pct_q30_bases).' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold' ;
    rdfs:comment 'Minimum (or maximum, per threshold_direction) acceptable value for this metric to be considered passing. Defines the QC gate boundary used for automated pass/fail evaluation.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Logical stage of the bioinformatics pipeline at which this QC metric was evaluated. Enables stage-specific QC dashboards and failure pattern analysis across the FASTQ-to-VCF data lineage.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name of the bioinformatics QC tool that computed this metric (e.g., FastQC, Picard, MultiQC, Samtools). Enables tool-specific metric interpretation and version-controlled reproducibility tracking. [ENUM-REF-CANDIDATE: FastQC|Picard|MultiQC|GATK|Trimmomatic|Samtools|Qualimap|Fastp|Mosdepth|VerifyBamID — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolVersion rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Version' ;
    rdfs:comment 'Version string of the QC tool used to compute this metric (e.g., \'0.11.9\' for FastQC, \'2.27.5\' for Picard). Essential for reproducibility, audit trails, and identifying metric drift caused by tool upgrades.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Documented corrective or remediation action taken or recommended in response to a QC failure (e.g., \'re-sequence sample\', \'increase library input\', \'repeat library preparation\'). Supports CAPA workflows and GxP compliance.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation workflow for a failed QC metric. \'not_required\' for passing metrics; \'pending\', \'in_progress\', \'resolved\', or \'escalated\' for failing metrics requiring corrective action.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Formal outcome of the QA/QC reviewer\'s assessment of this metric result. \'waived\' indicates a documented exception approval for a failing metric. Required for GxP and clinical laboratory compliance.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when a QA/QC reviewer formally reviewed this metric result. Supports GxP electronic record requirements and TAT (Turnaround Time) tracking for clinical workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceFilePath rdf:type rdf:Property ;
    rdfs:label 'Source File Path' ;
    rdfs:comment 'File system or object storage path to the QC tool output file (e.g., FastQC HTML report, Picard metrics file, MultiQC JSON) from which this metric was extracted. Supports data lineage and audit traceability.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegionBedFile rdf:type rdf:Property ;
    rdfs:label 'Target Region Bed File' ;
    rdfs:comment 'File path or identifier of the BED file defining the genomic target regions used for on-target rate and coverage uniformity calculations. Applicable for WES and targeted panel assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Indicates whether the pass_threshold is a minimum bound (metric must be >= threshold), maximum bound (metric must be <= threshold), or a range (metric must fall within defined bounds). Required for correct automated QC gating logic.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLowerBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Bound' ;
    rdfs:comment 'Lower boundary of an acceptable range for this metric when threshold_direction is \'range\'. Null when threshold_direction is \'min\' or \'max\'.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Bound' ;
    rdfs:comment 'Upper boundary of an acceptable range for this metric when threshold_direction is \'range\'. Null when threshold_direction is \'min\' or \'max\'.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdVersion rdf:type rdf:Property ;
    rdfs:label 'Threshold Version' ;
    rdfs:comment 'Version identifier of the QC threshold specification applied during evaluation (e.g., \'v1.2.0\'). Enables audit traceability when thresholds are updated over time and supports longitudinal comparability of QC results.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented scientific or clinical justification for waiving a QC failure and allowing downstream processing to proceed. Populated only when review_outcome is \'waived\'. Required for regulatory audit trails.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Id' ;
    rdfs:comment 'Foreign key linking to order.delivery_line. Business justification: Genomic artifacts (VCF, BAM, reports) are the digital deliverables fulfilled against delivery line items. Linking artifact to delivery_line enables proof-of-delivery tracking for digital genomics outp' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryLine .

ind:parentArtifactGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Parent Artifact Genomic Artifact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate upstream artifact from which this artifact was derived (e.g., a BAM artifact\'s parent is the FASTQ artifact; a VCF artifact\'s parent is the BAM artifact). Enables reconstruction of the full data lineage chain from raw to interpreted results.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this artifact was moved to archival storage (e.g., AWS S3 Glacier), in ISO 8601 format with timezone offset. Null if the artifact has not been archived. Used for storage cost tracking, retrieval SLA management, and compliance with data lifecycle policies.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:artifactExternalReference rdf:type rdf:Property ;
    rdfs:label 'Artifact External Reference' ;
    rdfs:comment 'Externally-known unique identifier for the artifact as assigned by the originating system of record (e.g., Illumina BaseSpace file ID, LabVantage LIMS artifact accession number, or cloud storage object key). Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactName rdf:type rdf:Property ;
    rdfs:label 'Artifact Name' ;
    rdfs:comment 'Human-readable name or label assigned to the genomic artifact, typically derived from the sample identifier, run identifier, and artifact type (e.g., \'SampleA_WGS_R1.fastq.gz\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactStatus rdf:type rdf:Property ;
    rdfs:label 'Artifact Status' ;
    rdfs:comment 'Current lifecycle state of the genomic artifact within the bioinformatics pipeline ecosystem. \'pending\' indicates awaiting generation; \'available\' indicates ready for downstream consumption; \'processing\' indicates actively being transformed; \'failed\' indicates a pipeline error; \'archived\' indicates moved to cold storage; \'deleted\' indicates purged per retention policy. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactType rdf:type rdf:Property ;
    rdfs:label 'Artifact Type' ;
    rdfs:comment 'Classification of the genomic data artifact by its file format and biological content type. Drives downstream pipeline routing, storage tier assignment, and retention policy application. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|ANNOTATION|REPORT|INDEX|QC_METRICS — promote to reference product]' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeSequence rdf:type rdf:Property ;
    rdfs:label 'Barcode Sequence' ;
    rdfs:comment 'Index/barcode nucleotide sequence used to identify this sample within a multiplexed sequencing pool during demultiplexing. Enables traceability of the artifact to its specific library preparation and sample assignment in a pooled run.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash digest of the artifact file content used for data integrity verification during transfer, storage, and retrieval. Enables detection of file corruption or unauthorized modification. Widely used in genomics data exchange protocols.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash of the artifact file content providing stronger integrity assurance than MD5. Required for regulatory-grade data integrity verification under GxP and HIPAA security rule compliance. Preferred checksum for clinical and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionFormat rdf:type rdf:Property ;
    rdfs:label 'Compression Format' ;
    rdfs:comment 'Compression algorithm applied to the artifact file. BGZF (Blocked GNU Zip Format) is standard for BAM/CRAM/VCF files enabling random access; GZIP is standard for FASTQ files. Determines decompression requirements for downstream pipeline steps and storage cost calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsPhi rdf:type rdf:Property ;
    rdfs:label 'Contains Phi' ;
    rdfs:comment 'Boolean flag indicating whether this artifact contains Protected Health Information (PHI) as defined under HIPAA. Drives access control enforcement, audit logging requirements, and data handling procedures. Must be set to True for any artifact linked to an identified clinical sample.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Privacy and regulatory classification of the genomic data contained in this artifact. \'PHI\' (Protected Health Information) indicates data subject to HIPAA; \'de_identified\' indicates PHI has been removed per HIPAA Safe Harbor or Expert Determination; \'research\' indicates IRB-governed research data; \'restricted\' indicates controlled-access data (e.g., dbGaP); \'public\' indicates open-access data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Generation Timestamp' ;
    rdfs:comment 'Timestamp when the physical artifact file was generated by the pipeline or instrument, in ISO 8601 format with timezone offset. Distinct from the registry record creation timestamp — represents the actual file creation time as reported by the pipeline or storage system. Used for data freshness assessment and TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Physical size of the genomic artifact file in bytes at the time of creation or last verification. Used for storage capacity planning, cost allocation, and data transfer monitoring. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomeBuild rdf:type rdf:Property ;
    rdfs:label 'Genome Build' ;
    rdfs:comment 'Specific reference genome assembly build used during alignment or variant calling (e.g., GRCh38, GRCh37/hg19). Stored directly on the artifact for rapid querying without joining to the reference genome table. Critical for variant interpretation and cross-cohort comparability.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStorageUri rdf:type rdf:Property ;
    rdfs:label 'Index Storage Uri' ;
    rdfs:comment 'Full URI path to the index file associated with this artifact (e.g., \'.bai\' for BAM, \'.tbi\' for VCF). Stored alongside the artifact URI to enable direct access by pipeline tools without requiring a separate lookup.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIndexed rdf:type rdf:Property ;
    rdfs:label 'Is Indexed' ;
    rdfs:comment 'Boolean flag indicating whether a corresponding index file exists for this artifact (e.g., BAI index for BAM, TBI/CSI index for VCF). Indexed artifacts support random-access queries by genomic coordinate, which is required for most downstream analysis tools.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanPhredQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Quality Score' ;
    rdfs:comment 'Mean Phred base quality score across all reads in the artifact. Phred score (Q) represents the probability of an incorrect base call (Q30 = 99.9% accuracy). A primary QC metric for sequencing run quality assessment per CLIA and CAP standards.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentQ30 rdf:type rdf:Property ;
    rdfs:label 'Percent Q30' ;
    rdfs:comment 'Percentage of bases in the artifact with a Phred quality score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. Industry-standard QC threshold metric for NGS data quality acceptance. Typically required to be ≥80% for clinical-grade sequencing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date on which this artifact becomes eligible for archival or deletion per the assigned retention policy. Calculated from the artifact creation date and the applicable retention period. Used by automated data lifecycle management processes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Retention policy classification governing how long this artifact must be retained before it is eligible for archival or deletion. \'short_term\' (e.g., 90 days for intermediate files); \'standard\' (e.g., 2 years); \'long_term\' (e.g., 7 years for clinical); \'permanent\' (e.g., reference datasets); \'regulatory_hold\' (litigation or regulatory investigation hold).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePlatform rdf:type rdf:Property ;
    rdfs:label 'Storage Platform' ;
    rdfs:comment 'Cloud or on-premises storage platform where the artifact is physically stored. Drives data access patterns, cost allocation, and egress fee tracking. Supports multi-cloud and hybrid storage architecture management.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full URI path to the artifact file in the storage backend (e.g., S3 bucket path \'s3://genomics-biotech-prod/artifacts/sample123/output.bam\', HDFS path, or NFS mount path). Used by pipeline orchestration and data access layers to locate and retrieve the file.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReadCount rdf:type rdf:Property ;
    rdfs:label 'Total Read Count' ;
    rdfs:comment 'Total number of sequencing reads contained in this artifact. For FASTQ files, represents raw read count; for BAM/CRAM files, represents total aligned and unaligned reads. Used for QC assessment, yield reporting, and billing calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLineageEventId rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each data lineage event record in the bioinformatics processing chain. Primary key for this table. Entity role: EVENT_LOG — captures immutable transformation events across the genomic data processing pipeline from raw FASTQ ingestion to clinical report generation.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLineageEventDataLineageEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Lineage Event Data Lineage Event Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding lineage event in the processing chain. Enables construction of a directed acyclic graph (DAG) of transformation events for end-to-end data lineage traversal from raw FASTQ to clinical report.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataLineageEvent .

ind:primaryDataGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Primary Data Genomic Artifact Id' ;
    rdfs:comment 'Reference to the genomic data artifact (e.g., FASTQ, BAM, VCF, gVCF, annotation file) that served as the input to this transformation event. Supports forward and backward data lineage tracing.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:targetArtifactGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Genomic Artifact Id' ;
    rdfs:comment 'Reference to the genomic data artifact produced as the output of this transformation event (e.g., aligned BAM, called VCF, annotated VCF, clinical report). Enables downstream lineage traversal.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Structured error or exception code returned by the bioinformatics tool or pipeline orchestrator when a transformation event fails (e.g., TOOL_EXIT_NONZERO, INSUFFICIENT_COVERAGE, CHECKSUM_MISMATCH, TIMEOUT). Used for failure root-cause analysis and automated alerting.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Externally-known business identifier for this lineage event, formatted as LIN- followed by an alphanumeric code. Used for cross-system referencing, audit log correlation, and regulatory submission traceability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the data transformation event. Indicates whether the transformation is pending execution, actively running, successfully completed, failed with error, skipped due to conditional logic, or retried after a prior failure. Used for pipeline monitoring and failure root-cause analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the data transformation event occurred in the bioinformatics pipeline. This is the principal real-world event time, distinct from record audit timestamps. Critical for GxP audit trails and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorical discriminator identifying the kind of data transformation that occurred in the bioinformatics pipeline. Values: ingest (raw FASTQ ingestion), transform (alignment/variant calling), filter (QC filtering), merge (combining artifacts), split (demultiplexing), annotate (variant annotation), export (clinical report generation), archive (long-term storage). [ENUM-REF-CANDIDATE: ingest|transform|filter|merge|split|annotate|export|archive — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Wall-clock elapsed time in seconds for the transformation event to complete, from job start to job end. Used for pipeline performance benchmarking, Turnaround Time (TAT) analysis, and SLA monitoring.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Gxp Audit Required' ;
    rdfs:comment 'Indicates whether this transformation event is subject to GxP (Good Practice Regulations including GMP, GLP, GCP) audit trail requirements (True = GxP-regulated event, False = non-regulated event). Used to filter events for regulatory audit reporting and inspection readiness.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaPhiInvolved rdf:type rdf:Property ;
    rdfs:label 'Hipaa Phi Involved' ;
    rdfs:comment 'Indicates whether this transformation event processed or produced data containing Protected Health Information (PHI) as defined under HIPAA (True = PHI involved, False = no PHI). Used for HIPAA compliance reporting, data access controls, and breach risk assessment.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputRecordCount rdf:type rdf:Property ;
    rdfs:label 'Input Record Count' ;
    rdfs:comment 'Number of input records, reads, or variants consumed by this transformation event (e.g., number of FASTQ reads ingested, number of variants in input VCF). Used for data volume tracking, QC validation, and pipeline performance analysis.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorIdentity rdf:type rdf:Property ;
    rdfs:label 'Operator Identity' ;
    rdfs:comment 'Username, service account name, or system identity (human user or automated pipeline agent) that initiated or executed this transformation event. Required for GxP audit trails, 21 CFR Part 11 electronic signature traceability, and HIPAA access accountability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Categorizes whether the transformation event was initiated by a human user, an automated bioinformatics pipeline, a system service account, or a scheduled job. Supports audit trail differentiation and compliance reporting under 21 CFR Part 11.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputRecordCount rdf:type rdf:Property ;
    rdfs:label 'Output Record Count' ;
    rdfs:comment 'Number of output records, reads, or variants produced by this transformation event (e.g., number of aligned reads in output BAM, number of variants in output VCF). Used for data volume tracking, QC validation, and yield analysis.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcMetricName rdf:type rdf:Property ;
    rdfs:label 'Qc Metric Name' ;
    rdfs:comment 'Name of the primary Quality Control (QC) metric evaluated at this transformation step (e.g., mean_coverage_depth, percent_mapped_reads, phred_score_q30_percent, ts_tv_ratio, variant_call_rate). Provides context for the QC pass/fail determination.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMetricValue rdf:type rdf:Property ;
    rdfs:label 'Qc Metric Value' ;
    rdfs:comment 'Numeric value of the primary Quality Control (QC) metric evaluated at this transformation step (e.g., 45.7 for mean coverage depth, 98.3 for percent mapped reads). Used for QC trending, threshold monitoring, and regulatory compliance reporting.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceArtifactChecksum rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the input genomic data artifact at the time of consumption. Used to verify data integrity, detect corruption, and confirm that the correct artifact version was used. Required for 21 CFR Part 11 and GxP data integrity compliance.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceArtifactFormat rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Format' ;
    rdfs:comment 'File format of the input genomic data artifact consumed by this transformation event (e.g., FASTQ for raw reads, BAM/CRAM for aligned reads, VCF/gVCF for variant calls). Enables format-aware lineage queries and pipeline validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|FASTA|TSV|CSV|JSON|HTML|PDF — promote to reference product]' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Path' ;
    rdfs:comment 'Cloud or network storage path (e.g., S3 URI, ADLS path) of the input genomic data artifact consumed by this transformation event. Confidential as it may reveal internal infrastructure topology and data organization. Required for data recovery, re-processing, and audit traceability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactChecksum rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the output genomic data artifact produced by this transformation event. Used to verify data integrity, detect corruption, and confirm artifact authenticity for downstream steps. Required for 21 CFR Part 11 and GxP data integrity compliance.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactFormat rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Format' ;
    rdfs:comment 'File format of the output genomic data artifact produced by this transformation event (e.g., BAM for alignment output, VCF for variant calling output, annotated VCF for annotation output). Enables format-aware lineage queries and downstream pipeline validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|FASTA|TSV|CSV|JSON|HTML|PDF — promote to reference product]' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Path' ;
    rdfs:comment 'Cloud or network storage path (e.g., S3 URI, ADLS path) of the output genomic data artifact produced by this transformation event. Confidential as it may reveal internal infrastructure topology. Required for downstream pipeline steps, data recovery, and audit traceability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolContainerImage rdf:type rdf:Property ;
    rdfs:label 'Tool Container Image' ;
    rdfs:comment 'Docker or container image URI (including registry, repository, and digest/tag) used to execute the bioinformatics tool, ensuring exact computational environment reproducibility. Example: docker.io/broadinstitute/gatk:4.2.6.1. Supports GxP validation and 21 CFR Part 11 audit requirements.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Validation Study Id' ;
    rdfs:comment 'Unique surrogate identifier for the pipeline validation study record. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete formal analytical validation event with a defined lifecycle (in-progress, passed, failed) tied to regulatory compliance for IVD/LDT pipeline qualification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineValidationStudy .

ind:accreditationId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Id' ;
    rdfs:comment 'Foreign key linking to customer.accreditation. Business justification: Pipeline validation studies are conducted to satisfy CLIA/CAP accreditation requirements at customer labs. Regulators and auditors require traceability from a validation study to the specific accredit' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Accreditation .

ind:assayVersionId rdf:type rdf:Property ;
    rdfs:label 'Assay Version Id' ;
    rdfs:comment 'Foreign key linking to clinical.assay_version. Business justification: Pipeline validation studies validate a pipeline version for a specific assay version — the validated combination is the unit of CAP/CLIA and regulatory documentation. This FK completes the traceabilit' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayVersion .

ind:cliaAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Clia Accreditation Id' ;
    rdfs:comment 'CLIA certificate number of the laboratory in which the validation study was conducted. Required for LDT validation records to demonstrate the study was performed in a CLIA-certified facility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CliaAccreditation .

ind:cohortId rdf:type rdf:Property ;
    rdfs:label 'Cohort Id' ;
    rdfs:comment 'Foreign key linking to sample.cohort. Business justification: Pipeline validation studies are performed on defined sample cohorts with specific population characteristics (disease indication, demographics, specimen types). Regulatory submissions (FDA, CLIA) requ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cohort .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Foreign key linking to order.header. Business justification: Pipeline validation studies are often commercially procured services (customers pay for custom validation of a pipeline for their use case). Linking to the order header enables revenue recognition for' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:labSiteId rdf:type rdf:Property ;
    rdfs:label 'Lab Site Id' ;
    rdfs:comment 'Foreign key linking to sample.lab_site. Business justification: Pipeline validation studies are conducted at specific CLIA/CAP-accredited lab sites. Regulatory submissions and accreditation audits require identifying the lab site where validation was performed. Si' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSite .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_bom. Business justification: A pipeline validation study is validated against a specific manufacturing BOM version of the kit/assay. Regulatory submissions (510(k), PMA) require documenting which BOM configuration the pipeline wa' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Validation studies test pipeline performance with specific reagent lots and materials to establish validated material specifications and acceptable ranges. Regulatory submissions (FDA 510k, CAP/CLIA v' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:performingLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Performing Laboratory Id' ;
    rdfs:comment 'Foreign key linking to clinical.performing_laboratory. Business justification: Pipeline validation studies are conducted at specific CLIA-certified performing laboratories. CAP/CLIA accreditation requires documenting which lab performed each validation. No existing FK covers thi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformingLaboratory .

ind:primaryPipelineProtocolDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Pipeline Protocol Document Id' ;
    rdfs:comment 'Reference identifier for the formal validation protocol document as registered in Veeva Vault or MasterControl document control system. Provides traceability from the study record to the approved study design document.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:priorStudyPipelineValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Prior Study Pipeline Validation Study Id' ;
    rdfs:comment 'Reference to the preceding validation study that this study supersedes or extends. Populated when is_revalidation is True. Enables lineage tracing across successive pipeline validation generations.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineValidationStudy .

ind:rdProjectId rdf:type rdf:Property ;
    rdfs:label 'Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Pipeline validation studies are conducted within R&D projects to establish analytical performance (LOD, sensitivity, specificity) before regulatory submission or clinical deployment. Required for IVD ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:studyId rdf:type rdf:Property ;
    rdfs:label 'Study Id' ;
    rdfs:comment 'Foreign key linking to research.study. Business justification: Pipeline validation studies are formally conducted under a registered research study for regulatory traceability (FDA, CAP/CLIA). Linking validation study to research.study enables audit trail from pi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: GxP validation studies must reference the specific supplier contract governing reagent supply to ensure validated materials were procured under approved terms. FDA 21 CFR Part 820 and ISO 13485 requir' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_qualification. Business justification: Regulatory requirement (ISO 13485, FDA 21 CFR 820.50): pipeline validation studies must document that the reagent supplier was formally qualified at time of study. Links validation evidence to supplie' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualification .

ind:testCatalogId rdf:type rdf:Property ;
    rdfs:label 'Test Catalog Id' ;
    rdfs:comment 'Foreign key linking to clinical.test_catalog. Business justification: Pipeline validation studies are conducted to qualify a pipeline for a specific test catalog entry — a CAP/CLIA and FDA IVD requirement. Linking validation studies to the test they support enables test' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCatalog .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:comment 'Overall accuracy of the pipeline measured as concordance with a reference standard method, expressed as a percentage. Calculated as (TP + TN) / (TP + TN + FP + FN) × 100. Required for CLIA/CAP and FDA IVD qualification.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the validation study report was formally reviewed and approved by the designated approver. Marks the transition from completed execution to approved regulatory evidence.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Accreditation Number' ;
    rdfs:comment 'CAP laboratory accreditation number for the facility conducting the validation. CAP accreditation is a recognized alternative to CLIA inspection and is required for many clinical genomics laboratory operations.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The date on which the validation study was formally completed and all results were finalized. Null if the study is still in-progress. Required for regulatory submission timelines and CLIA/CAP audit records.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Privacy classification of the genomic data used in the validation study. De-identified: PHI removed per HIPAA Safe Harbor. Pseudonymized: indirect identifiers replaced. Synthetic: computationally generated data. Identifiable: requires IRB approval and full PHI controls.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpcEnvironment rdf:type rdf:Property ;
    rdfs:label 'Hpc Environment' ;
    rdfs:comment 'Compute environment in which the validation study pipeline runs were executed (e.g., AWS cloud HPC, on-premise HPC cluster, hybrid). Documents the infrastructure context for reproducibility and regulatory traceability.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Number' ;
    rdfs:comment 'IRB protocol approval number when the validation study uses identifiable human genomic samples. Required for studies involving human subjects data to demonstrate ethical oversight compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevalidation rdf:type rdf:Property ;
    rdfs:label 'Is Revalidation' ;
    rdfs:comment 'Indicates whether this study is a revalidation triggered by a pipeline change, algorithm update, or prior validation failure (True), or an initial validation (False). Revalidations require documentation of the change that triggered them.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodEstablished rdf:type rdf:Property ;
    rdfs:label 'Lod Established' ;
    rdfs:comment 'The analytically established Limit of Detection (LOD) for the pipeline, expressed as variant allele frequency (VAF) or copies per milliliter depending on assay type. Represents the lowest detectable signal with 95% confidence. Core regulatory performance claim for IVD/LDT qualification.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lodUnit rdf:type rdf:Property ;
    rdfs:label 'Lod Unit' ;
    rdfs:comment 'Unit of measure for the established LOD value (e.g., VAF — Variant Allele Frequency as a decimal, copies per mL for ctDNA, percent for mosaic variants). Required to correctly interpret the lod_established value.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Minimum Coverage Depth' ;
    rdfs:comment 'Minimum sequencing coverage depth (read depth, expressed as ×) required and validated for the pipeline to meet performance specifications (e.g., 100× for somatic variant calling). Defines the analytical boundary conditions of the validated pipeline.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPhredScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Phred Score' ;
    rdfs:comment 'Minimum base quality Phred score threshold applied during the validation study (e.g., Q20, Q30). Defines the quality filtering boundary conditions under which the pipeline performance metrics were established.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineVersionTag rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version Tag' ;
    rdfs:comment 'Semantic version label of the bioinformatics pipeline validated (e.g., v3.2.1, v4.0.0-rc1). Captured directly on this record to preserve the validated version string even if the pipeline registry is updated.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionCvPercent rdf:type rdf:Property ;
    rdfs:label 'Precision Cv Percent' ;
    rdfs:comment 'Coefficient of Variation (CV%) measuring pipeline precision (reproducibility of quantitative outputs) across replicate runs. Lower CV indicates higher precision. Applicable for quantitative assays such as CNV ratio or VAF estimation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the study protocol document used to execute this validation (e.g., v1.0, v2.3). Captured to ensure the executed study is traceable to the exact approved protocol version, supporting GxP compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceStandard rdf:type rdf:Property ;
    rdfs:label 'Reference Standard' ;
    rdfs:comment 'Name or identifier of the reference standard, truth set, or orthogonal method used to establish ground truth for the validation (e.g., NIST Genome in a Bottle NA12878, Sanger sequencing, ddPCR, Platinum Genomes). Required for accuracy and concordance claims.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ref' ;
    rdfs:comment 'External regulatory submission identifier associated with this validation study (e.g., FDA 510(k) number K231234, PMA number P200001, CE-IVD Technical File reference, EMA EPAR reference). Links the validation evidence to the formal regulatory dossier.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory submission pathway for which this validation study provides supporting evidence. 510(k): FDA premarket notification. PMA: FDA premarket approval. De Novo: FDA novel device classification. CE-IVD: EU conformity assessment. EUA: Emergency Use Authorization. IVDR: EU In Vitro Diagnostic Regulation 2017/746. [ENUM-REF-CANDIDATE: 510k|PMA|De_Novo|CE-IVD|EUA|IVDR|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Total number of samples (or synthetic datasets) processed during the validation study. Determines statistical power of the validation and is reviewed by regulatory bodies to assess adequacy of the study design.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sensitivityPercent rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Percent' ;
    rdfs:comment 'Measured analytical sensitivity (true positive rate) of the pipeline expressed as a percentage (0–100). Calculated as TP / (TP + FN) × 100 across the validation sample set. Key regulatory performance metric for IVD/LDT claims.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificityPercent rdf:type rdf:Property ;
    rdfs:label 'Specificity Percent' ;
    rdfs:comment 'Measured analytical specificity (true negative rate) of the pipeline expressed as a percentage (0–100). Calculated as TN / (TN + FP) × 100 across the validation sample set. Key regulatory performance metric for IVD/LDT claims.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'The date on which formal execution of the validation study commenced (first sample or dataset processed per the study protocol). Distinct from the protocol authoring date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationType rdf:type rdf:Property ;
    rdfs:label 'Validation Type' ;
    rdfs:comment 'Category of analytical validation being performed. Analytical sensitivity measures LOD; analytical specificity measures cross-reactivity; reproducibility measures inter-run/inter-site consistency; accuracy measures concordance with reference method; precision measures intra-run variability; interference measures matrix effects. [ENUM-REF-CANDIDATE: analytical_sensitivity|analytical_specificity|reproducibility|accuracy|precision|interference|repeatability|comparability — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantTypesEvaluated rdf:type rdf:Property ;
    rdfs:label 'Variant Types Evaluated' ;
    rdfs:comment 'Comma-separated list of genomic variant classes evaluated in this validation study (e.g., SNP, Indel, CNV, SV, fusion). Defines the analytical scope of the validation and maps to regulatory performance claims.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultStudyReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Study Reference' ;
    rdfs:comment 'System identifier for the validation study record as registered in Veeva Vault Quality Management System. Enables direct cross-system traceability between the analytics lakehouse record and the regulated document management system.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayDevelopmentId rdf:type rdf:Property ;
    rdfs:label 'Assay Development Id' ;
    rdfs:comment 'Foreign key linking to research.assay_development. Business justification: Sequencing runs executed as assay development validation runs must be traceable to the assay_development record. Assay development teams track run performance against target coverage_depth and technol' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayDevelopment .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Technical contact for run-specific communications: QC notifications, result delivery, troubleshooting. Critical for customer-facing service operations and regulatory traceability of data delivery.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:licenseEntitlementId rdf:type rdf:Property ;
    rdfs:label 'License Entitlement Id' ;
    rdfs:comment 'Foreign key linking to product.license_entitlement. Business justification: Each sequencing run consumes software license entitlements (BaseSpace compute, DRAGEN analysis, data_processing_limit_gb). License compliance reporting and usage-based billing require runs to referenc' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseEntitlement .

ind:manufacturingProductionBatchId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Production Batch Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_batch. Business justification: Direct traceability from sequencing run to manufactured reagent batch enables rapid quality investigations. When Q30 scores drop or error rates spike, QC teams must immediately identify affected manuf' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:manufacturingWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Work Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_order. Business justification: Vertically-integrated genomics companies manufacture custom reagent kits in-house. Sequencing runs must trace to manufacturing work orders for regulatory compliance (21 CFR Part 11, ISO 13485), qualit' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primarySequencingAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Sequencing Asset Id' ;
    rdfs:comment 'Reference to the sequencing instrument (e.g., NovaSeq, NextSeq, HiSeq) on which this run was executed. Used to trace run performance back to a specific physical instrument asset.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Sequencing runs consume reagent kits purchased via PO. Link enables cost accounting per run, supplier performance tracking, and GMP traceability required for regulated assays. Critical for COGS calcul' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:reagentKitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.catalog. Business justification: Reagent kit compatibility validation and recall management require linking each sequencing run to the reagent.catalog entry to access storage requirements, GMP compliance status, and shelf-life specs.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:reagentKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Sequencing runs consume specific reagent kit catalog items. Essential for cost-per-run analysis, inventory management, regulatory lot traceability, and procurement planning. Labs must track which comm' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:reagentKitLotId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Lot Id' ;
    rdfs:comment 'Reference to the reagent kit lot (LOT number) consumed during this sequencing run. Enables traceability from run output back to reagent manufacturing lot for quality investigations and COA verification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:reagentKitSkuId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Inventory depletion and COGS reporting require the specific SKU (pack size, regional config) consumed per run, not just the catalog item. Procurement reorder triggers and run-level cost accounting in ' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:regulatoryClassificationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Id' ;
    rdfs:comment 'Foreign key linking to product.regulatory_classification. Business justification: IVD vs RUO classification of a sequencing run determines GxP requirements, data handling, and regulatory reporting obligations. The plain column regulatory_use_classification is denormalized from prod' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryClassification .

ind:salesOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Header Id' ;
    rdfs:comment 'Foreign key linking to order.header. Business justification: A sequencing run executed as a service must reference the sales order that commissioned it. This is fundamental traceability in genomics service labs — linking lab execution to commercial order for bi' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:sequencingProtocolId rdf:type rdf:Property ;
    rdfs:label 'Sequencing Protocol Id' ;
    rdfs:comment 'Foreign key linking to sequencing.sequencing_protocol. Business justification: Sequencing runs must follow approved, validated sequencing protocols that define run configuration, QC thresholds, and regulatory compliance requirements. sequencing_run currently has run_mode, run_ty' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SequencingProtocol .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.service_agreement. Business justification: Runs performed under specific service agreements defining SLA terms, turnaround time, pricing tier, regulatory classification. Essential for contract compliance verification and billing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAgreement .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Foreign key linking to product.service_offering. Business justification: Sequencing-as-a-service runs must reference the service offering for billing, SLA compliance, and deliverables tracking. Contract research organizations and genomics service labs link each run to the ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceOffering .

ind:technicalRequirementId rdf:type rdf:Property ;
    rdfs:label 'Technical Requirement Id' ;
    rdfs:comment 'Foreign key linking to customer.technical_requirement. Business justification: Runs executed to fulfill customer-specified technical requirements (coverage depth, read length, platform). Links run parameters to customer engagement specifications for QC validation and acceptance ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalRequirement .

ind:actualSampleCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Count' ;
    rdfs:comment 'Actual number of samples successfully demultiplexed and yielding usable FASTQ data from this run. May differ from planned_sample_count due to index mismatches, low-quality libraries, or run failures. Key metric for run efficiency and yield reporting.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basespaceRunCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Run Code' ;
    rdfs:comment 'The unique run identifier assigned by Illumina BaseSpace Sequence Hub for this sequencing run. Used to link the internal enterprise record to the BaseSpace cloud platform for FASTQ retrieval, run monitoring, and bioinformatics pipeline initiation.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDensity rdf:type rdf:Property ;
    rdfs:label 'Cluster Density' ;
    rdfs:comment 'The density of sequencing clusters generated on the flow cell surface, measured in thousands of clusters per mm². A critical run quality parameter — too low indicates under-loading, too high causes cluster overlap and quality degradation. Reported by the instrument and BaseSpace.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clusterPfPct rdf:type rdf:Property ;
    rdfs:label 'Cluster Pf Pct' ;
    rdfs:comment 'Percentage of clusters that pass the Illumina chastity filter (PF = Passing Filter), indicating the proportion of reads with sufficient signal purity for reliable base calling. A key run-level QC metric; typically expected to be >75-80% for a passing run.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRetentionCategory rdf:type rdf:Property ;
    rdfs:label 'Data Retention Category' ;
    rdfs:comment 'Data retention classification for this sequencing run record and its associated FASTQ/BAM/VCF outputs, determining the minimum retention period per applicable regulations. \'standard\' = 2 years (RUO); \'extended\' = 10+ years (clinical/GxP); \'permanent\' = indefinite (regulatory submission data); \'restricted_deletion\' = deletion requires regulatory approval.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demultiplexingStatus rdf:type rdf:Property ;
    rdfs:label 'Demultiplexing Status' ;
    rdfs:comment 'Current status of the FASTQ demultiplexing process for this run, which separates pooled (multiplexed) sample reads by their index barcodes into individual sample FASTQ files. Tracks the post-run data processing step that precedes bioinformatics pipeline execution.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorRatePct rdf:type rdf:Property ;
    rdfs:label 'Error Rate Pct' ;
    rdfs:comment 'The base-level sequencing error rate for this run expressed as a percentage, calculated using PhiX control spike-in alignment. Lower values indicate higher sequencing accuracy. Used for run QC acceptance/rejection decisions and instrument performance trending.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fastqOutputPath rdf:type rdf:Property ;
    rdfs:label 'Fastq Output Path' ;
    rdfs:comment 'The storage path or URI (e.g., S3 bucket path, BaseSpace project URL, or HPC filesystem path) where the FASTQ output files for this run are stored. Confidential as it reveals internal data infrastructure topology. Used by bioinformatics pipelines to locate raw sequencing data.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCellType rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Type' ;
    rdfs:comment 'The type/format of flow cell used in this run (e.g., SP, S1, S2, S4 for NovaSeq; P1, P2, P3 for NovaSeq X; nano, micro for MiSeq). Determines lane count, cluster capacity, and maximum output yield. Critical for run planning and cost accounting. [ENUM-REF-CANDIDATE: SP|S1|S2|S4|P1|P2|P3|nano|micro|high|mid — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folderName rdf:type rdf:Property ;
    rdfs:label 'Folder Name' ;
    rdfs:comment 'The instrument-generated run folder name following Illumina naming convention (e.g., \'240115_A00001_0001_AHXXXXXX\'). Contains date, instrument serial, run number, and flow cell ID. Used for data traceability between instrument output and enterprise data systems.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReadLength rdf:type rdf:Property ;
    rdfs:label 'Index Read Length' ;
    rdfs:comment 'Number of base pairs sequenced for the index (barcode) reads used in multiplexing/demultiplexing. Typically 6, 8, or 10 bp per index. Determines the number of samples that can be multiplexed on a single flow cell and the accuracy of demultiplexing.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneCount rdf:type rdf:Property ;
    rdfs:label 'Lane Count' ;
    rdfs:comment 'Number of lanes on the flow cell used in this sequencing run (e.g., 1 for MiSeq, 2 for NextSeq, 4 for NovaSeq SP/S1/S2, 8 for NovaSeq S4). Used for per-lane QC analysis, sample distribution planning, and run capacity calculations.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:libraryPrepKit rdf:type rdf:Property ;
    rdfs:label 'Library Prep Kit' ;
    rdfs:comment 'Name or catalog identifier of the library preparation kit used to prepare samples for this sequencing run (e.g., \'Illumina DNA Prep\', \'TruSeq Stranded mRNA\', \'Nextera DNA Flex\'). Affects sequencing performance, adapter trimming parameters, and bioinformatics pipeline configuration.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for operator or QC reviewer notes about this sequencing run, including observations about run performance, deviations from SOP, troubleshooting actions taken, or contextual information relevant to data interpretation. Supports GxP deviation documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputYieldGb rdf:type rdf:Property ;
    rdfs:label 'Output Yield Gb' ;
    rdfs:comment 'Total sequencing data output generated by this run measured in gigabases (Gb). Represents the QUANTITATIVE_RESULT for this non-monetary TRANSACTION_HEADER. Used for run performance benchmarking, storage capacity planning, and comparison against instrument specifications.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phixSpikeInPct rdf:type rdf:Property ;
    rdfs:label 'Phix Spike In Pct' ;
    rdfs:comment 'Percentage of PhiX bacteriophage control library spiked into the sequencing run for real-time quality monitoring and error rate calibration. Typically 1-5% for standard runs. Used to calculate error_rate_pct and validate instrument performance.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSampleCount rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Count' ;
    rdfs:comment 'Number of samples planned to be multiplexed and sequenced in this run as defined in the sample sheet at run setup. Used for capacity planning, reagent consumption estimation, and comparison against actual demultiplexed sample count.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:q30Pct rdf:type rdf:Property ;
    rdfs:label 'Q30 Pct' ;
    rdfs:comment 'Percentage of bases with a Phred quality score of 30 or higher (Q30), indicating ≥99.9% base call accuracy. The primary industry-standard run quality metric. Typically required to be >75-80% for a run to pass QC. Directly impacts variant calling accuracy and clinical reporting confidence.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the QC review of this sequencing run was completed and the run_qc_status was formally assigned. Part of the GxP electronic audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readLength rdf:type rdf:Property ;
    rdfs:label 'Read Length' ;
    rdfs:comment 'The number of base pairs sequenced per read in this run (e.g., 75, 100, 150, 250 bp). A key sequencing parameter that determines data quality, coverage, and application suitability. Configured at run setup and recorded for QC and reproducibility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runMode rdf:type rdf:Property ;
    rdfs:label 'Run Mode' ;
    rdfs:comment 'The NGS application type or sequencing strategy for this run. Determines the library preparation approach, bioinformatics pipeline, and downstream analysis. WGS = Whole Genome Sequencing; WES = Whole Exome Sequencing; targeted = targeted panel sequencing; amplicon = amplicon-based sequencing; RNA-seq = transcriptome sequencing; metagenomics = environmental/microbial sequencing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Human-readable name assigned to the sequencing run, typically following a lab naming convention (e.g., \'RUN-2024-001-NovaSeq\'). Used for identification in LIMS, BaseSpace, and operational dashboards. Maps to the Run Name field in Illumina BaseSpace Sequence Hub.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Externally-known business identifier for the sequencing run, assigned by the LIMS or laboratory operations system. Used for cross-system referencing, customer reporting, and regulatory traceability. Serves as the BUSINESS_IDENTIFIER for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the run by its intended use context. \'clinical\' = IVD/LDT clinical diagnostic run subject to CLIA/CAP; \'research\' = RUO research run; \'validation\' = assay validation run; \'QC\' = quality control run; \'development\' = R&D development run. Determines applicable regulatory framework and data handling requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetVersion rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Version' ;
    rdfs:comment 'Version identifier of the Illumina sample sheet file used to configure this sequencing run, specifying sample IDs, index sequences, and demultiplexing parameters. Used for run reproducibility, troubleshooting, and audit trail. Maps to Illumina SampleSheet.csv versioning.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Target Coverage Depth' ;
    rdfs:comment 'The intended mean sequencing coverage depth (number of times each base is sequenced) specified at run design time (e.g., 30x for WGS, 100x for WES, 500x for targeted panels). Used to validate whether the run met its coverage objectives and for clinical reporting thresholds.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCycles rdf:type rdf:Property ;
    rdfs:label 'Total Cycles' ;
    rdfs:comment 'Total number of sequencing chemistry cycles executed in this run. For paired-end runs, this includes both read 1, index reads, and read 2 cycles (e.g., 2×150 bp = 300 cycles + index cycles). Used for run cost accounting, reagent consumption tracking, and run configuration validation.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coaId rdf:type rdf:Property ;
    rdfs:label 'Coa Id' ;
    rdfs:comment 'Foreign key linking to reagent.coa. Business justification: Flow cells require Certificate of Analysis verification for GxP-compliant sequencing runs, quality control, and regulatory audits. supplier_lot_certificate_number is a reference string, not a denormal' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Flow cell inventory management requires SKU-level tracking (lane count variant, read length configuration). Procurement reorder points and lot-level COGS accounting depend on the specific SKU consumed' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:basespaceFlowCellCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Flow Cell Code' ;
    rdfs:comment 'External identifier assigned to this flow cell within the Illumina BaseSpace Sequence Hub system. Enables cross-system reconciliation between the internal lakehouse record and the BaseSpace sequencing data management platform. Used for data lineage and run data retrieval.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Breach Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion or cold chain breach was detected during shipping or storage of this flow cell (True = breach detected). Triggers quarantine workflow and quality investigation in LabVantage LIMS and Veeva Vault. A breached flow cell must not be used until cleared by QA.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumed Timestamp' ;
    rdfs:comment 'Date and time when the sequencing run was completed and the flow cell was fully consumed or removed from the instrument. Marks the end of the flow cell\'s active lifecycle. Used for TAT reporting, instrument utilization metrics, and inventory depletion tracking.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the unit_cost field (e.g., USD, EUR, GBP). Enables multi-currency financial reporting and cost normalization across global procurement activities.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the consumed, failed, or expired flow cell was disposed of per the applicable disposal method. Required for environmental compliance records and GMP documentation of consumable lifecycle closure.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used for disposal of the consumed or failed flow cell. Governs environmental health and safety (EHS) compliance for waste management. Options include standard laboratory waste, biohazardous waste, chemical waste, or return to supplier for failed/defective units.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Manufacturer-specified expiration date after which the flow cell must not be used for sequencing. Critical for GMP compliance, inventory management, and preventing use of expired consumables that could compromise sequencing quality. Monitored in SAP S/4HANA QM and LabVantage LIMS for automated expiry alerts.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Identifier of the Genomics Biotech facility (laboratory or sequencing center) where this flow cell is stored and used. Supports multi-site inventory management, site-level capacity planning, and regulatory site-specific compliance reporting.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flowCellStatus rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Status' ;
    rdfs:comment 'Current lifecycle status of the physical flow cell consumable. Tracks the operational state from receipt through consumption or disposal. \'in_stock\' = received and available; \'reserved\' = allocated to a planned run; \'loaded\' = currently on instrument; \'consumed\' = run completed; \'failed\' = quality failure; \'expired\' = past expiry date; \'quarantined\' = held for investigation. [ENUM-REF-CANDIDATE: in_stock|reserved|loaded|consumed|failed|expired|quarantined — promote to reference product]' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentPlatform rdf:type rdf:Property ;
    rdfs:label 'Instrument Platform' ;
    rdfs:comment 'The sequencing instrument platform for which this flow cell is designed and compatible (e.g., NovaSeq 6000, NovaSeq X, NextSeq 2000, MiSeq). Governs compatibility rules for loading, reagent kits, and run parameters. [ENUM-REF-CANDIDATE: NovaSeq 6000|NovaSeq X|NextSeq 550|NextSeq 2000|MiSeq|HiSeq 4000|iSeq 100 — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedApplication rdf:type rdf:Property ;
    rdfs:label 'Intended Application' ;
    rdfs:comment 'Primary sequencing application for which this flow cell is designated (e.g., WGS — Whole Genome Sequencing, WES — Whole Exome Sequencing, targeted sequencing, RNA-seq, single-cell). Drives run parameter configuration and quality acceptance criteria. Also distinguishes Research Use Only (RUO) from In Vitro Diagnostic (IVD) use contexts for regulatory compliance. [ENUM-REF-CANDIDATE: WGS|WES|targeted_sequencing|amplicon|RNA_seq|single_cell|RUO|IVD — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSingleUse rdf:type rdf:Property ;
    rdfs:label 'Is Single Use' ;
    rdfs:comment 'Indicates whether the flow cell is designed for single use only (True) or supports multiple sequencing runs (False). Governs reuse policies, disposal procedures, and run scheduling logic. Most modern Illumina flow cells are single-use; this flag supports future platform compatibility.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsBarcode rdf:type rdf:Property ;
    rdfs:label 'Lims Barcode' ;
    rdfs:comment 'Barcode label scanned into LabVantage LIMS at receipt to register the flow cell in the laboratory inventory system. Used for physical tracking, chain-of-custody documentation, and automated workflow triggering in the LIMS. May differ from the manufacturer serial number.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when the flow cell was physically loaded onto the sequencing instrument, marking the transition from \'reserved\' to \'loaded\' status. Recorded in Illumina BaseSpace Sequence Hub and LabVantage LIMS. Used for run scheduling, instrument utilization analysis, and TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date the flow cell was manufactured by the supplier, as printed on the product label or Certificate of Analysis (COA). Used for shelf-life calculations, lot traceability, and quality investigations. Sourced from the COA accompanying the shipment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP S/4HANA purchase order number under which this flow cell was procured. Provides procurement lineage linking the physical consumable to the financial transaction, supplier contract, and goods receipt documentation. Supports COGS tracking and financial reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Date' ;
    rdfs:comment 'Date on which the incoming QC inspection was performed for this flow cell. Used for compliance audit trails, SOP adherence tracking, and calculating time-from-receipt-to-clearance metrics.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Result of the incoming quality control inspection performed upon receipt of the flow cell. \'pending\' = inspection not yet completed; \'passed\' = meets acceptance criteria; \'failed\' = does not meet criteria, quarantined; \'waived\' = inspection waived per approved SOP (e.g., for pre-qualified lots). Managed in SAP S/4HANA QM and LabVantage LIMS.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentKitLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Lot Number' ;
    rdfs:comment 'Lot number of the sequencing reagent kit used in conjunction with this flow cell. Enables paired traceability between the flow cell consumable and its associated reagent kit for quality investigations, recall management, and GMP compliance. Sourced from LabVantage LIMS run setup records.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the flow cell was physically received at the Genomics Biotech facility and logged into inventory. Recorded in SAP S/4HANA MM Goods Receipt and LabVantage LIMS. Used to calculate storage duration, validate shelf life, and support FIFO inventory management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number printed on the physical flow cell cartridge. Used as the primary external identifier for traceability across LabVantage LIMS, Illumina BaseSpace Sequence Hub, and SAP S/4HANA inventory management. Enables one-to-one mapping between the physical consumable and its digital record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the physical storage location (e.g., freezer unit, shelf, rack position) where the flow cell is currently stored within the facility. Managed in SAP S/4HANA MM Warehouse Management and LabVantage LIMS. Enables rapid physical retrieval and inventory audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius as specified by the manufacturer. Paired with storage_temperature_min_c to define the acceptable cold chain range. Monitored against environmental monitoring system data to ensure GMP-compliant storage conditions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum required storage temperature in degrees Celsius as specified by the manufacturer. Used to validate cold chain compliance during receipt inspection and ongoing storage monitoring. Deviations from this range trigger quarantine and quality investigation workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierLotCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Certificate Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (COA) issued by the supplier for this specific lot. The COA documents manufacturer QC test results confirming the flow cell meets specification. Stored in Veeva Vault for regulatory document management and GMP compliance.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the external supplier or manufacturer who supplied this flow cell (e.g., Illumina, Inc.). Used for procurement lineage, supplier qualification tracking, and quality management. Linked to the reagent and consumable domain for full procurement traceability.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Actual procurement cost per flow cell unit in the operating currency (USD). Sourced from SAP S/4HANA MM invoice verification. Used for Cost of Goods Sold (COGS) allocation, run cost accounting, and financial reporting. Classified as confidential due to commercial sensitivity of supplier pricing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerId rdf:type rdf:Property ;
    rdfs:label 'Container Id' ;
    rdfs:comment 'Identifier of the physical plate or rack in which the library is stored. Used for laboratory inventory management, retrieval workflows, and storage location tracking within the LIMS.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Container .

ind:indexSetId rdf:type rdf:Property ;
    rdfs:label 'Index Set Id' ;
    rdfs:comment 'Foreign key linking to sequencing.index_set. Business justification: Libraries are assigned index adapters from controlled index sets for multiplexing. library currently has adapter_sequence_i7, adapter_sequence_i5, and udi_plate_id but no FK to index_set. Adding index' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndexSet .

ind:libraryPrepRunId rdf:type rdf:Property ;
    rdfs:label 'Library Prep Run Id' ;
    rdfs:comment 'Foreign key linking to sequencing.library_prep_run. Business justification: Each library is produced by a specific library preparation run. This is a standard parent-child relationship where library_prep_run is the batch execution entity and library is the output product. Cur' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LibraryPrepRun .

ind:molecularDesignId rdf:type rdf:Property ;
    rdfs:label 'Molecular Design Id' ;
    rdfs:comment 'Foreign key linking to research.molecular_design. Business justification: Targeted sequencing libraries (capture panels, amplicon libraries) are built from specific molecular designs defining target loci and probe sequences. Linking library to molecular_design enables trace' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MolecularDesign .

ind:multiplexingPoolId rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Pool Id' ;
    rdfs:comment 'Identifier of the multiplexing pool to which this library has been assigned for co-loading onto a flow cell. Enables tracking of pooled libraries, demultiplexing yield analysis, and per-library coverage attribution within a pooled run.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:originalLibraryId rdf:type rdf:Property ;
    rdfs:label 'Original Library Id' ;
    rdfs:comment 'Reference to the original library record when this library is a resequencing attempt (resequencing_flag = True). Enables lineage tracking across preparation attempts and supports failure analysis workflows. Null for original preparations.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Library .

ind:prepKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Prep Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Library prep kits are commercial catalog items. Labs track which kit SKU was used for cost allocation, protocol validation, regulatory compliance, and troubleshooting quality issues. Essential for GxP' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:prepKitSkuId rdf:type rdf:Property ;
    rdfs:label 'Prep Kit Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Library prep kit SKU traceability is required for lot-level COGS accounting and inventory depletion. In regulated genomics labs, the specific kit SKU (pack size, configuration) used per library must b' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:testOrderId rdf:type rdf:Property ;
    rdfs:label 'Test Order Id' ;
    rdfs:comment 'Foreign key linking to clinical.test_order. Business justification: A library is prepared to fulfill a specific clinical test order. CLIA audit trails require direct traceability from library preparation to the clinical test order, enabling consent verification, TAT t' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestOrder .

ind:basespaceLibraryCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Library Code' ;
    rdfs:comment 'External identifier assigned to this library within Illumina BaseSpace Sequence Hub. Enables cross-system traceability between the internal LIMS record and the BaseSpace sequencing data management platform for FASTQ retrieval and run association.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationNm rdf:type rdf:Property ;
    rdfs:label 'Concentration Nm' ;
    rdfs:comment 'Measured molar concentration of the library in nanomolar (nM) units. Used for accurate loading onto flow cells and pooling calculations during multiplexing. Sourced from quantification instrument output.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether valid informed consent has been obtained for the use of the source sample in sequencing and data sharing (True = consent confirmed; False = consent not confirmed or withdrawn). Required for HIPAA, GDPR, and NIH Genomic Data Sharing Policy compliance.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingRestricted rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Restricted' ;
    rdfs:comment 'Indicates whether genomic data derived from this library is subject to data sharing restrictions (True = restricted; False = unrestricted). Restrictions may arise from consent limitations, IRB conditions, contractual obligations, or GDPR/HIPAA data subject rights. Governs downstream data product access controls.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputDnaMassNg rdf:type rdf:Property ;
    rdfs:label 'Input Dna Mass Ng' ;
    rdfs:comment 'Mass of input nucleic acid (DNA or RNA) used for library preparation, measured in nanograms (ng). A key QC parameter — insufficient input mass is a leading cause of library preparation failure and low complexity.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Bp' ;
    rdfs:comment 'Target or measured average insert size of the library fragments in base pairs (bp). A key MEASUREMENT_OR_VALUE (MASTER_RESOURCE category) for library quality assessment. Impacts read alignment efficiency, coverage uniformity, and variant calling accuracy. Typically 150–500 bp for WGS/WES.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPcrFree rdf:type rdf:Property ;
    rdfs:label 'Is Pcr Free' ;
    rdfs:comment 'Indicates whether the library was prepared using a PCR-free protocol (True) or a PCR-amplified protocol (False). PCR-free libraries have lower duplicate rates and reduced GC bias, preferred for high-accuracy WGS applications.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libraryCode rdf:type rdf:Property ;
    rdfs:label 'Library Code' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the sequencing library, used in LIMS, BaseSpace, and laboratory documentation. Follows the internal naming convention LIB-{alphanumeric}. This is the BUSINESS_IDENTIFIER (MASTER_RESOURCE category) used across operational systems.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryName rdf:type rdf:Property ;
    rdfs:label 'Library Name' ;
    rdfs:comment 'Human-readable descriptive name assigned to the sequencing library, typically incorporating sample identifier, preparation date, and assay type. Used as the IDENTITY_LABEL (MASTER_RESOURCE category) for display in LIMS dashboards, BaseSpace projects, and laboratory reports.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryType rdf:type rdf:Property ;
    rdfs:label 'Library Type' ;
    rdfs:comment 'Classification of the sequencing library by assay strategy. Drives downstream bioinformatics pipeline selection, coverage expectations, and reporting templates. CLASSIFICATION_OR_TYPE (MASTER_RESOURCE category). [ENUM-REF-CANDIDATE: WGS|WES|amplicon|RNA-seq|targeted_panel|methylation|ChIP-seq|ATAC-seq|single_cell — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsLibraryCode rdf:type rdf:Property ;
    rdfs:label 'Lims Library Code' ;
    rdfs:comment 'Native identifier for this library record within LabVantage LIMS. Supports bidirectional reconciliation between the Silver Layer data product and the operational LIMS system of record for audit and data lineage purposes.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nucleicAcidType rdf:type rdf:Property ;
    rdfs:label 'Nucleic Acid Type' ;
    rdfs:comment 'Type of nucleic acid used as input for library preparation. Drives protocol selection, QC thresholds, and bioinformatics pipeline configuration. Values: gDNA — genomic DNA; cfDNA — cell-free DNA (liquid biopsy); RNA — total or mRNA; cDNA — complementary DNA; FFPE_DNA — formalin-fixed paraffin-embedded DNA; amplicon_DNA — pre-amplified target DNA.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrCycleCount rdf:type rdf:Property ;
    rdfs:label 'Pcr Cycle Count' ;
    rdfs:comment 'Number of PCR amplification cycles applied during library preparation. Impacts PCR duplicate rate, GC bias, and library complexity. PCR-free libraries have a value of 0. Tracked for QC benchmarking and protocol optimization.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolingProportionPct rdf:type rdf:Property ;
    rdfs:label 'Pooling Proportion Pct' ;
    rdfs:comment 'Percentage contribution of this library to the total multiplexing pool by molar concentration. Used to balance per-library coverage in multiplexed sequencing runs and to investigate coverage imbalance post-sequencing.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepDate rdf:type rdf:Property ;
    rdfs:label 'Prep Date' ;
    rdfs:comment 'Calendar date on which the library preparation protocol was completed. Used for lot traceability, reagent expiry correlation, and turnaround time (TAT) calculations. Aligns with GxP batch record requirements.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantificationMethod rdf:type rdf:Property ;
    rdfs:label 'Quantification Method' ;
    rdfs:comment 'Analytical method used to measure library concentration and/or size distribution. Affects confidence in concentration accuracy and downstream loading calculations. Common methods: qPCR (most accurate for sequenceable molecules), Bioanalyzer/TapeStation (size + concentration), Qubit (fluorometric mass concentration).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resequencingFlag rdf:type rdf:Property ;
    rdfs:label 'Resequencing Flag' ;
    rdfs:comment 'Indicates whether this library was prepared as a resequencing attempt for a previously failed or insufficient-coverage library (True = resequencing; False = original preparation). Supports TAT tracking, cost analysis, and failure rate reporting.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Required or actual storage temperature for the library in degrees Celsius (e.g., -20°C for long-term, 4°C for short-term). Supports cold chain compliance, stability monitoring, and deviation investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageWellPosition rdf:type rdf:Property ;
    rdfs:label 'Storage Well Position' ;
    rdfs:comment 'Well position (e.g., A01, H12) within the storage plate where the library aliquot is located. Combined with storage_plate_id, provides precise physical location for laboratory retrieval and inventory audits.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandSpecificity rdf:type rdf:Property ;
    rdfs:label 'Strand Specificity' ;
    rdfs:comment 'Indicates whether the library preserves strand-of-origin information for RNA-seq or other strand-aware assays. Values: unstranded — no strand information retained; forward — read 1 maps to sense strand; reverse — read 1 maps to antisense strand. Required for correct transcript quantification in RNA-seq pipelines.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReadLength rdf:type rdf:Property ;
    rdfs:label 'Target Read Length' ;
    rdfs:comment 'Intended sequencing read length in base pairs (e.g., 150 bp for paired-end short-read WGS). Determines sequencing run configuration, instrument chemistry selection, and bioinformatics pipeline parameters.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:udiPlateCode rdf:type rdf:Property ;
    rdfs:label 'Udi Plate Code' ;
    rdfs:comment 'Identifier of the unique dual index (UDI) plate from which the index pair was assigned. Enables traceability of index assignments across batches and supports investigation of index hopping or cross-contamination events.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiWellPosition rdf:type rdf:Property ;
    rdfs:label 'Udi Well Position' ;
    rdfs:comment 'Well position (e.g., A01, B12) on the UDI plate from which the index pair was drawn. Together with udi_plate_id, uniquely identifies the index assignment for demultiplexing and audit purposes.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRemainingUl rdf:type rdf:Property ;
    rdfs:label 'Volume Remaining Ul' ;
    rdfs:comment 'Current volume of library material remaining in storage, measured in microliters (µL). Tracks consumable inventory for re-sequencing eligibility and storage management. Updated after each aliquot event.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Kit Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.catalog. Business justification: Library prep kit specification lookups (storage conditions, hazard classification, GMP compliance) require linking library_prep_run to reagent.catalog. The existing kit_catalog_item_id targets product' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:kitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Library prep runs consume specific kit catalog items. Essential for batch cost tracking, lot-to-lot performance analysis, regulatory traceability, and quality investigations when prep runs fail QC.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:kitLotId rdf:type rdf:Property ;
    rdfs:label 'Kit Lot Id' ;
    rdfs:comment 'Identifier of the reagent kit lot used in this library preparation run. Enables reagent lot traceability, recall management, and correlation of kit lot performance with QC outcomes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:kitSkuId rdf:type rdf:Property ;
    rdfs:label 'Kit Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Library prep run COGS and inventory management require the specific kit SKU consumed. Procurement reorder triggers and manufacturing cost rollups depend on SKU-level consumption tracking per prep run.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:researchProtocolId rdf:type rdf:Property ;
    rdfs:label 'Research Protocol Id' ;
    rdfs:comment 'Identifier of the standard operating procedure (SOP) or library preparation protocol document used for this run. Links to the document control system (MasterControl/Veeva Vault) for version-controlled protocol traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchProtocol .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Library prep kit supplier tracking. Enables supplier performance evaluation based on prep run outcomes (QC failures, adapter dimer rates), quality investigations, and supplier scorecarding for procure' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:adapterDimerPct rdf:type rdf:Property ;
    rdfs:label 'Adapter Dimer Pct' ;
    rdfs:comment 'Percentage of adapter dimer contamination detected in the final library by electrophoresis (Bioanalyzer/TapeStation). High adapter dimer content reduces effective sequencing yield and is a key QC failure indicator. Typically must be below 5% for pass disposition.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adapterLigationMethod rdf:type rdf:Property ;
    rdfs:label 'Adapter Ligation Method' ;
    rdfs:comment 'Method used to ligate sequencing adapters to the end-repaired DNA fragments. Tagmentation (Nextera) combines fragmentation and adapter ligation in a single step. Affects ligation efficiency, adapter dimer formation rate, and overall library yield.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchQcOutcome rdf:type rdf:Property ;
    rdfs:label 'Batch Qc Outcome' ;
    rdfs:comment 'Overall quality control disposition for the library preparation run batch. Determines whether the batch is approved for sequencing submission. A conditional pass may require additional review or re-quantification before proceeding.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Free-text description of any deviation from the approved SOP observed during this library preparation run. Populated only when sop_deviation_flag is True. Supports GxP deviation management, CAPA (Corrective and Preventive Action) initiation, and regulatory audit readiness.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endRepairPerformed rdf:type rdf:Property ;
    rdfs:label 'End Repair Performed' ;
    rdfs:comment 'Indicates whether an end-repair and A-tailing step was performed on the fragmented DNA prior to adapter ligation. End repair is required for blunt-end ligation protocols but may be skipped in tagmentation-based workflows.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalLibraryConcentrationNm rdf:type rdf:Property ;
    rdfs:label 'Final Library Concentration Nm' ;
    rdfs:comment 'Measured concentration of the final pooled library in nanomolar (nM), typically quantified by qPCR or fluorometric assay (e.g., Qubit). Used to calculate the dilution factor for optimal flow cell loading and to assess library yield.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPoolingVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Final Pooling Volume Ul' ;
    rdfs:comment 'Total volume in microliters (µL) of the final pooled library submitted for sequencing. Used to calculate loading concentration for the flow cell and to assess library yield sufficiency for sequencing.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentationMethod rdf:type rdf:Property ;
    rdfs:label 'Fragmentation Method' ;
    rdfs:comment 'DNA/RNA fragmentation approach applied during library preparation. Enzymatic fragmentation uses restriction enzymes or transposases (e.g., Nextera); mechanical fragmentation uses sonication or acoustic shearing (e.g., Covaris). Affects insert size distribution and library quality metrics.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCollisionCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Index Collision Check Passed' ;
    rdfs:comment 'Indicates whether the selected multiplexing index combinations were verified to have sufficient Hamming distance to prevent index hopping or misassignment during demultiplexing. A failed check requires index reassignment before sequencing.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputDnaAmountNg rdf:type rdf:Property ;
    rdfs:label 'Input Dna Amount Ng' ;
    rdfs:comment 'Total mass of input DNA or RNA (in nanograms) used per sample in this library preparation run. Critical QC parameter — insufficient input material is a leading cause of library preparation failure and low-complexity libraries.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputMaterialType rdf:type rdf:Property ;
    rdfs:label 'Input Material Type' ;
    rdfs:comment 'Type of nucleic acid input material used for library preparation (e.g., genomic DNA (gDNA), cell-free DNA (cfDNA), RNA, formalin-fixed paraffin-embedded (FFPE) DNA). Determines applicable protocol, QC acceptance criteria, and downstream analytical interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRunCode rdf:type rdf:Property ;
    rdfs:label 'Lims Run Code' ;
    rdfs:comment 'Native run identifier assigned by the source LabVantage LIMS system. Preserved as a cross-reference key to enable bidirectional traceability between the Databricks Silver Layer and the operational LIMS without relying solely on the surrogate primary key.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanFragmentSizeBp rdf:type rdf:Property ;
    rdfs:label 'Mean Fragment Size Bp' ;
    rdfs:comment 'Measured mean fragment size in base pairs (bp) of the final library as determined by Bioanalyzer, TapeStation, or equivalent electrophoresis instrument. Compared against target_insert_size_bp to assess size selection success and protocol adherence.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplexingIndexSet rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Index Set' ;
    rdfs:comment 'Name or identifier of the index/barcode set used for sample multiplexing in this library preparation run (e.g., Illumina TruSeq CD Index Set A, IDT for Illumina 10 bp UDI). Enables demultiplexing of pooled samples post-sequencing and prevents index collision errors.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrAmplificationCycles rdf:type rdf:Property ;
    rdfs:label 'Pcr Amplification Cycles' ;
    rdfs:comment 'Number of PCR amplification cycles applied during library preparation. Excessive PCR cycles introduce duplicate reads and GC bias, reducing library complexity. Zero cycles indicates a PCR-free protocol. Key parameter for library quality assessment and protocol compliance.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcMethod rdf:type rdf:Property ;
    rdfs:label 'Qc Method' ;
    rdfs:comment 'Analytical method used to quantify and assess library quality (e.g., qPCR for accurate molar quantification, Qubit fluorometry for mass concentration, Bioanalyzer/TapeStation for fragment size distribution). Affects the reliability of concentration measurements and QC pass/fail decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the library preparation run, typically generated by the LIMS (e.g., LP-NGSA-240315). Used for cross-system traceability, SOP deviation tracking, and GxP audit references. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for operator observations, troubleshooting notes, or contextual comments recorded during or after the library preparation run. Supplements structured deviation documentation and supports root cause analysis.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeSelectionMethod rdf:type rdf:Property ;
    rdfs:label 'Size Selection Method' ;
    rdfs:comment 'Method used to select the target insert size range from the library pool (e.g., SPRI bead-based cleanup, gel excision, Pippin Prep automated electrophoresis). Size selection removes adapter dimers and off-target fragments, improving sequencing efficiency.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Deviation Flag' ;
    rdfs:comment 'Indicates whether any deviation from the approved standard operating procedure (SOP) was recorded during this library preparation run. A True value triggers mandatory deviation documentation and review per GxP requirements.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Target Insert Size Bp' ;
    rdfs:comment 'Intended DNA insert size in base pairs (bp) for the prepared library, as specified by the protocol. Insert size directly impacts sequencing read overlap, coverage uniformity, and variant calling accuracy. Typical ranges: 150–400 bp for short-read NGS.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useType rdf:type rdf:Property ;
    rdfs:label 'Use Type' ;
    rdfs:comment 'Regulatory use classification of the library preparation run. Research Use Only (RUO) runs are not subject to IVD regulatory controls; In Vitro Diagnostic (IVD) and Laboratory Developed Test (LDT) runs require CLIA/CAP compliance and stricter QC documentation. Drives applicable regulatory requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workgroupCode rdf:type rdf:Property ;
    rdfs:label 'Workgroup Code' ;
    rdfs:comment 'Identifier of the laboratory workgroup or team responsible for executing this library preparation run. Supports capacity planning, workload balancing, and team-level performance reporting.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolId rdf:type rdf:Property ;
    rdfs:label 'Pool Id' ;
    rdfs:comment 'Unique system-generated identifier for the multiplexed library pool record. Primary key for the pool entity in the sequencing domain.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:parentPoolId rdf:type rdf:Property ;
    rdfs:label 'Parent Pool Id' ;
    rdfs:comment 'Reference to the original pool from which this re-pool was derived, when is_repool is True. Enables lineage tracking and root cause analysis for failed pools.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:reagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.catalog. Business justification: Pooling reagent specification lookups (storage temperature, hazard classification, GMP compliance) require linking pool to reagent.catalog. The existing reagent_catalog_item_id targets product.catalog' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:reagentCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Reagent Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Pooling operations use reagents/normalization kits that are catalog items. Needed for cost accounting, protocol compliance, and tracking which commercial products were used for library normalization a' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:basespacePoolCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Pool Code' ;
    rdfs:comment 'External identifier assigned to this pool within Illumina BaseSpace Sequence Hub. Used for cross-system traceability between the internal LIMS and the BaseSpace sequencing data management platform.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMethod rdf:type rdf:Property ;
    rdfs:label 'Concentration Method' ;
    rdfs:comment 'Analytical method used to measure the pool concentration. Qubit and qPCR are preferred for accurate molar quantification; Bioanalyzer and TapeStation provide both concentration and fragment size data.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConcentrationNm rdf:type rdf:Property ;
    rdfs:label 'Final Concentration Nm' ;
    rdfs:comment 'Measured molar concentration of the pool in nanomolar (nM) after pooling, as determined by Qubit fluorometry or qPCR quantification. Used to calculate dilution for loading concentration.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowCellLane rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Lane' ;
    rdfs:comment 'Specific lane(s) on the flow cell to which this pool is assigned for loading. A pool may occupy a single lane or the entire flow cell depending on the instrument type and run design.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragmentSizeLowerBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Lower Bp' ;
    rdfs:comment 'Lower bound of the acceptable fragment size distribution range in base pairs (bp) for this pool, as defined by the QC specification. Fragments below this threshold indicate adapter contamination or over-fragmentation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fragmentSizeMethod rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Method' ;
    rdfs:comment 'Instrument or method used to assess the fragment size distribution of the pool (e.g., Agilent Bioanalyzer, Agilent TapeStation, Advanced Analytical Fragment Analyzer, or gel electrophoresis).' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragmentSizeUpperBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Upper Bp' ;
    rdfs:comment 'Upper bound of the acceptable fragment size distribution range in base pairs (bp) for this pool. Fragments above this threshold may indicate incomplete fragmentation or genomic DNA contamination.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexCollisionRisk rdf:type rdf:Property ;
    rdfs:label 'Index Collision Risk' ;
    rdfs:comment 'Assessed risk level of index sequence collision (cross-contamination between demultiplexed samples) within this pool, based on Hamming distance analysis of the index set. Low risk indicates sufficient edit distance between all index pairs.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepool rdf:type rdf:Property ;
    rdfs:label 'Is Repool' ;
    rdfs:comment 'Indicates whether this pool is a re-pool created to replace or supplement a previously failed or underperforming pool (True = re-pool, False = original pool). Used for tracking remediation events.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libraryCount rdf:type rdf:Property ;
    rdfs:label 'Library Count' ;
    rdfs:comment 'Total number of individually indexed libraries combined into this pool. Determines the degree of multiplexing and directly impacts per-library read depth allocation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limsPoolCode rdf:type rdf:Property ;
    rdfs:label 'Lims Pool Code' ;
    rdfs:comment 'Native pool identifier from LabVantage LIMS, used for cross-system reconciliation between the enterprise data lakehouse and the operational LIMS source system.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingConcentrationPm rdf:type rdf:Property ;
    rdfs:label 'Loading Concentration Pm' ;
    rdfs:comment 'Target loading concentration of the diluted pool in picomolar (pM) for the specific instrument and flow cell type. Directly impacts cluster density and sequencing quality.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Human-readable, externally-known unique alphanumeric code assigned to the pool for tracking across LIMS, BaseSpace, and laboratory worksheets. Used as the business identifier on COAs and run manifests.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Descriptive human-readable name assigned to the pool, typically encoding project, date, and cohort information for easy identification in run planning and reporting.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the pool. Tracks progression from initial creation through QC verification, loading onto the sequencer, sequencing completion, or expiry. [ENUM-REF-CANDIDATE: pending|qc_in_progress|qc_passed|qc_failed|loaded|sequenced|expired — promote to reference product]' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolingDate rdf:type rdf:Property ;
    rdfs:label 'Pooling Date' ;
    rdfs:comment 'Calendar date on which the individual libraries were combined to form this pool. Used for traceability, stability window calculation, and laboratory scheduling.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poolingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pooling Strategy' ;
    rdfs:comment 'Method used to combine individual indexed libraries into the pool. Equimolar pools combine equal molar quantities; custom ratio pools use user-defined proportions; normalized pools use concentration normalization prior to combining; volume-based pools combine equal volumes.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcConcentrationPassed rdf:type rdf:Property ;
    rdfs:label 'Qc Concentration Passed' ;
    rdfs:comment 'Indicates whether the pool passed the concentration QC threshold check (True = passed, False = failed). A pool must pass concentration QC before it is eligible for loading onto the sequencer.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcDate rdf:type rdf:Property ;
    rdfs:label 'Qc Date' ;
    rdfs:comment 'Date on which QC measurements (concentration and fragment size) were performed on the pool. May differ from pooling date if QC is conducted on a subsequent day.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcFragmentSizePassed rdf:type rdf:Property ;
    rdfs:label 'Qc Fragment Size Passed' ;
    rdfs:comment 'Indicates whether the pool passed the fragment size distribution QC check (True = passed, False = failed). Ensures the pool\'s insert size profile is within acceptable bounds for the target sequencing application.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcOverallPassed rdf:type rdf:Property ;
    rdfs:label 'Qc Overall Passed' ;
    rdfs:comment 'Composite QC pass/fail flag indicating whether the pool has passed all required QC checks (concentration and fragment size) and is approved for sequencer loading. True = all QC checks passed.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequencingApplication rdf:type rdf:Property ;
    rdfs:label 'Sequencing Application' ;
    rdfs:comment 'Genomic sequencing application type for which this pool was prepared. Determines bioinformatics pipeline routing, QC thresholds, and coverage requirements. [ENUM-REF-CANDIDATE: wgs|wes|targeted_panel|amplicon|rna_seq|chip_seq|atac_seq|methyl_seq — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage location identifier (freezer, rack, box, position) where the pool is stored in the laboratory. Used for sample retrieval and inventory management within LIMS.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReadDepth rdf:type rdf:Property ;
    rdfs:label 'Target Read Depth' ;
    rdfs:comment 'Expected average sequencing read depth (coverage depth) per library within the pool, expressed as number of reads. Used for run planning, yield allocation, and per-sample coverage estimation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Total Volume Ul' ;
    rdfs:comment 'Total volume of the combined pool in microlitres (µL) after all libraries have been pooled. Used to assess whether sufficient material exists for loading and archival.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolLibraryId rdf:type rdf:Property ;
    rdfs:label 'Pool Library Id' ;
    rdfs:comment 'Unique surrogate identifier for the pool-library association record. Primary key for this junction entity linking a sequencing library to a pool.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualMolarFractionPct rdf:type rdf:Property ;
    rdfs:label 'Actual Molar Fraction Pct' ;
    rdfs:comment 'The measured proportion (%) of this library\'s molar contribution in the final pool, determined by qPCR or fluorometric quantification. Deviations from expected fraction indicate pipetting or quantification errors.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedReadCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Count' ;
    rdfs:comment 'Total number of sequencing reads successfully demultiplexed and assigned to this library from the pool run. Populated post-sequencing from demultiplexing output (e.g., bcl2fastq/BCL Convert reports). Used to assess yield per library.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedReadFractionPct rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Fraction Pct' ;
    rdfs:comment 'Percentage of total pool reads assigned to this library after demultiplexing. Compared against expected molar fraction to assess pooling balance and identify over- or under-represented libraries.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone) when this library was assigned to the pool in the LIMS or BaseSpace Sequence Hub. Serves as the primary business event timestamp for this junction record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the library-to-pool assignment. Tracks whether the library is pending confirmation, actively loaded, failed QC, or removed from the pool.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceDatasetCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Dataset Code' ;
    rdfs:comment 'Identifier of the FASTQ dataset generated for this library in Illumina BaseSpace Sequence Hub following demultiplexing. Links the pool-library assignment to the resulting sequencing data artifact for downstream bioinformatics pipeline ingestion.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demultiplexMismatchAllowed rdf:type rdf:Property ;
    rdfs:label 'Demultiplex Mismatch Allowed' ;
    rdfs:comment 'Number of base mismatches permitted during demultiplexing for this library\'s index sequence. Typically 0 or 1. Higher values increase sensitivity but risk misassignment between similar indexes.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedMolarFractionPct rdf:type rdf:Property ;
    rdfs:label 'Expected Molar Fraction Pct' ;
    rdfs:comment 'The theoretical proportion (%) of this library\'s molar contribution relative to the total pool. Used to balance sequencing depth across libraries in a multiplexed run. Sum across all libraries in a pool should equal 100%.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:i5IndexSequence rdf:type rdf:Property ;
    rdfs:label 'I5 Index Sequence' ;
    rdfs:comment 'The i5 (read 2 side) barcode index nucleotide sequence assigned to this library for dual-index multiplexing. Required for dual-indexed library pools to prevent index hopping. Typically 6–10 bases.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i7IndexSequence rdf:type rdf:Property ;
    rdfs:label 'I7 Index Sequence' ;
    rdfs:comment 'The i7 (read 1 side) barcode index nucleotide sequence assigned to this library for multiplexing identification. Used during demultiplexing to assign reads back to the originating library. Typically 6–10 bases.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCollisionFlag rdf:type rdf:Property ;
    rdfs:label 'Index Collision Flag' ;
    rdfs:comment 'Indicates whether this library\'s index sequence conflicts (collides) with another library\'s index in the same pool, which would impair demultiplexing accuracy. True = collision detected; False = no collision. Populated by index compatibility checking tools.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indexDistance rdf:type rdf:Property ;
    rdfs:label 'Index Distance' ;
    rdfs:comment 'Minimum Hamming distance between this library\'s index sequence and all other index sequences in the same pool. A distance of ≥2 is typically required for reliable demultiplexing with 1 mismatch tolerance. Low values indicate collision risk.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Human-readable name or catalog designation of the index pair (e.g., \'IDT-10nt-UDI-0001\', \'TruSeq-D701-D501\'). Corresponds to the index kit nomenclature used during library preparation.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneAssignment rdf:type rdf:Property ;
    rdfs:label 'Lane Assignment' ;
    rdfs:comment 'The specific flow cell lane(s) to which this library-pool combination is assigned for sequencing (e.g., \'1\', \'1,2\', \'all\'). Relevant for patterned flow cells with lane-level loading (e.g., Illumina NovaSeq S4 flow cell).' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsPoolLibraryRef rdf:type rdf:Property ;
    rdfs:label 'Lims Pool Library Ref' ;
    rdfs:comment 'External reference identifier for this pool-library association record as recorded in LabVantage LIMS. Enables cross-system traceability between the lakehouse silver layer and the operational LIMS source of record.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingRatio rdf:type rdf:Property ;
    rdfs:label 'Loading Ratio' ;
    rdfs:comment 'The ratio of this library\'s contribution relative to the total pool volume or molar amount at the time of flow cell loading. Used to normalize read depth expectations and assess pooling balance post-sequencing.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Quality Score' ;
    rdfs:comment 'Average Phred quality score across all bases in reads assigned to this library. Provides a summary measure of base call accuracy for this library\'s contribution to the pool run.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalizationTool rdf:type rdf:Property ;
    rdfs:label 'Normalization Tool' ;
    rdfs:comment 'Name of the instrument or software tool used to quantify and normalize this library prior to pooling (e.g., \'Qubit 4 Fluorometer\', \'Agilent Bioanalyzer 2100\', \'Agilent TapeStation 4200\', \'KAPA Library Quantification qPCR\'). Supports reagent and instrument traceability.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phredQ30Pct rdf:type rdf:Property ;
    rdfs:label 'Phred Q30 Pct' ;
    rdfs:comment 'Percentage of bases in reads assigned to this library that meet or exceed Phred quality score Q30 (≥99.9% base call accuracy). Key NGS quality metric; typically ≥80% Q30 is required for clinical-grade sequencing.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolingMethod rdf:type rdf:Property ;
    rdfs:label 'Pooling Method' ;
    rdfs:comment 'Method used to determine the volume of this library added to the pool. Options include equimolar normalization, volume-based, mass-based, qPCR-normalized, or fluorometric quantification-based pooling.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason code explaining why this library was removed from the pool. Populated only when assignment_status is \'removed\' or \'failed\'. Supports root cause analysis and CAPA (Corrective and Preventive Action) workflows.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed Timestamp' ;
    rdfs:comment 'Date and time when this library was removed or disqualified from the pool, if applicable. Null if the library remains active in the pool. Supports lifecycle tracking and investigation of failed runs.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleSheetPosition rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Position' ;
    rdfs:comment 'Row position of this library entry in the Illumina sample sheet (SampleSheet.csv) used to configure the sequencing run and demultiplexing. Ensures correct index-to-sample mapping during BCL conversion.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spikeInFlag rdf:type rdf:Property ;
    rdfs:label 'Spike In Flag' ;
    rdfs:comment 'Indicates whether this library entry represents a spike-in control (e.g., PhiX, synthetic spike-in) rather than a biological sample library. True = spike-in control; False = biological sample. Spike-ins are used for sequencing quality calibration and are excluded from biological analysis.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undeterminedReadFlag rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Flag' ;
    rdfs:comment 'Indicates whether this library contributed a disproportionate number of reads to the undetermined (unassigned) category during demultiplexing, suggesting index sequence issues or contamination. True = flagged; False = within acceptable threshold.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeAddedUl rdf:type rdf:Property ;
    rdfs:label 'Volume Added Ul' ;
    rdfs:comment 'Actual volume in microliters (µL) of this library pipetted into the pool. Critical for molar balance calculations and audit of physical pooling operations.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runLaneId rdf:type rdf:Property ;
    rdfs:label 'Run Lane Id' ;
    rdfs:comment 'Unique surrogate identifier for a single lane record within a sequencing run on a multi-lane flow cell. Primary key for the run_lane entity. Entity role: TRANSACTION_LINE — represents one lane/line of a sequencing run (TRANSACTION_HEADER), carrying its own QC metrics, yield, and operational state.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RunLane .

ind:libraryPoolId rdf:type rdf:Property ;
    rdfs:label 'Library Pool Id' ;
    rdfs:comment 'Reference to the multiplexed library pool or individual library loaded onto this lane. Enables traceability from lane-level sequencing output back to the sample preparation and library construction records in the LIMS.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:basecallingSoftware rdf:type rdf:Property ;
    rdfs:label 'Basecalling Software' ;
    rdfs:comment 'Name and version of the base calling software used to convert raw intensity signals to nucleotide sequences (FASTQ) for this lane (e.g., Illumina RTA 3.4.4, DRAGEN). Critical for data provenance, reproducibility, and regulatory traceability of genomic data.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basecallingSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Basecalling Software Version' ;
    rdfs:comment 'Version identifier of the base calling software used for this lane. Required for GxP audit trails and bioinformatics reproducibility; version changes may affect base quality scores and downstream variant calling results.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceLaneCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Lane Code' ;
    rdfs:comment 'Unique identifier for this lane as recorded in Illumina BaseSpace Sequence Hub, the primary system of record for sequencing data management. Enables direct linkage between the enterprise data lakehouse and the BaseSpace platform for data retrieval and audit.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDensityKPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Cluster Density K Per Mm2' ;
    rdfs:comment 'Number of clusters generated per square millimeter on this lane, expressed in thousands (K/mm²). A key sequencing performance metric; values outside the instrument-specific acceptable range indicate over- or under-clustering, leading to reduced data quality or yield.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clustersPassingFilterPct rdf:type rdf:Property ;
    rdfs:label 'Clusters Passing Filter Pct' ;
    rdfs:comment 'Percentage of clusters on this lane that pass the Illumina chastity filter, indicating the proportion of high-quality reads retained for downstream analysis. Industry benchmark is typically ≥75–80%. Low values indicate poor library quality, phasing issues, or flow cell defects.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexReadLengthI1 rdf:type rdf:Property ;
    rdfs:label 'Index Read Length I1' ;
    rdfs:comment 'Length of Index Read 1 (i7 index) in base pairs used for demultiplexing samples on this lane. Defines the barcode length for sample identification in multiplexed sequencing runs.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexReadLengthI2 rdf:type rdf:Property ;
    rdfs:label 'Index Read Length I2' ;
    rdfs:comment 'Length of Index Read 2 (i5 index) in base pairs used for dual-index demultiplexing on this lane. Null for single-index runs. Dual indexing reduces index hopping and improves sample assignment accuracy in high-multiplex runs.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lane End Timestamp' ;
    rdfs:comment 'Date and time when sequencing completed on this lane. Together with lane_start_timestamp, enables calculation of lane-level sequencing duration and instrument cycle time for operational efficiency reporting.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laneFailureReason rdf:type rdf:Property ;
    rdfs:label 'Lane Failure Reason' ;
    rdfs:comment 'Free-text or coded description of the root cause when a lane fails QC (lane_qc_status = \'fail\'). Captures failure categories such as low cluster density, high error rate, low Q30, PhiX misalignment, or reagent lot issues. Used for root cause analysis, CAPA, and instrument troubleshooting.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneQcStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Qc Status' ;
    rdfs:comment 'Overall Quality Control (QC) disposition for this lane based on cluster density, clusters passing filter, PhiX alignment, and yield thresholds. Drives downstream bioinformatics pipeline gating and sample release decisions. Satisfies TRANSACTION_LINE category: LINE_VALUE_OR_RESULT. [ENUM-REF-CANDIDATE: pass|fail|warning|pending|under_review|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lane Start Timestamp' ;
    rdfs:comment 'Date and time when sequencing commenced on this lane. Used for Turnaround Time (TAT) calculation, instrument utilization reporting, and scheduling of downstream bioinformatics processing. Satisfies TRANSACTION_LINE category: BUSINESS_EVENT_TIMESTAMP.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laneYieldGb rdf:type rdf:Property ;
    rdfs:label 'Lane Yield Gb' ;
    rdfs:comment 'Total sequencing output (data yield) generated from this lane, expressed in gigabases (Gb). Primary throughput metric for lane-level performance assessment and SLA compliance. Satisfies TRANSACTION_LINE category: LINE_QUANTITY.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsLaneReference rdf:type rdf:Property ;
    rdfs:label 'Lims Lane Reference' ;
    rdfs:comment 'External identifier for this lane record as assigned by the Laboratory Information Management System (LIMS), such as LabVantage. Enables cross-system traceability between the Databricks Silver Layer analytical record and the operational LIMS source of record.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanPhredQ30Pct rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Q30 Pct' ;
    rdfs:comment 'Percentage of bases on this lane with a Phred quality score ≥30 (Q30), indicating a base call accuracy of 99.9% or higher. Industry-standard quality threshold for NGS data; Illumina specifies Q30 ≥75–80% as a minimum acceptance criterion for most applications.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanPhredScore rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score' ;
    rdfs:comment 'Average Phred base quality score across all bases sequenced on this lane. Provides a single summary quality metric complementing the Q30 percentage for lane-level quality trending and instrument performance monitoring.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numSamplesMultiplexed rdf:type rdf:Property ;
    rdfs:label 'Num Samples Multiplexed' ;
    rdfs:comment 'Count of individual samples multiplexed (pooled) and loaded onto this lane. Determines the expected per-sample read depth after demultiplexing and is a key parameter for capacity planning and SLA compliance per sample.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phixAlignmentPct rdf:type rdf:Property ;
    rdfs:label 'Phix Alignment Pct' ;
    rdfs:comment 'Percentage of reads on this lane that aligned to the PhiX reference genome. Used to validate the PhiX spike-in and assess lane-level sequencing error rate. Significant deviation from the expected PhiX spike-in percentage indicates a lane-level quality issue.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Review Timestamp' ;
    rdfs:comment 'Date and time when the QC review of this lane was completed and the QC disposition (pass/fail/warning) was recorded. Required for GxP audit trail and regulatory submission traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewed By' ;
    rdfs:comment 'Reference to the Quality Control (QC) scientist or analyst who reviewed and approved or rejected the lane QC results. Required for GxP electronic signature compliance and audit trail integrity under FDA 21 CFR Part 11.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLengthR1 rdf:type rdf:Property ;
    rdfs:label 'Read Length R1' ;
    rdfs:comment 'Length of Read 1 in base pairs (bp) for this lane, as configured in the sequencing run setup. Determines the sequencing mode (e.g., 150 bp paired-end) and directly impacts the genomic applications supported (WGS, WES, targeted panels).' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readLengthR2 rdf:type rdf:Property ;
    rdfs:label 'Read Length R2' ;
    rdfs:comment 'Length of Read 2 in base pairs (bp) for paired-end sequencing on this lane. Null for single-read runs. Together with read_length_r1, defines the paired-end read configuration (e.g., 2×150 bp) used for library insert size estimation and alignment accuracy.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readsPassingFilter rdf:type rdf:Property ;
    rdfs:label 'Reads Passing Filter' ;
    rdfs:comment 'Number of reads on this lane that passed the Illumina chastity filter and are available for downstream bioinformatics processing. Directly determines the effective sequencing depth available for variant calling and genomic analysis.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requeueCount rdf:type rdf:Property ;
    rdfs:label 'Requeue Count' ;
    rdfs:comment 'Number of times this lane has been requeued for resequencing due to QC failure or insufficient yield. Tracks repeat failure patterns for root cause analysis and supports escalation decisions when a lane repeatedly fails.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requeueRequired rdf:type rdf:Property ;
    rdfs:label 'Requeue Required' ;
    rdfs:comment 'Indicates whether this lane requires resequencing (requeue) due to QC failure or insufficient yield. Triggers downstream sample management and scheduling workflows in the LIMS to prioritize reruns and maintain customer SLA commitments.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undeterminedReadsPct rdf:type rdf:Property ;
    rdfs:label 'Undetermined Reads Pct' ;
    rdfs:comment 'Percentage of reads on this lane that could not be assigned to a sample index during demultiplexing. High undetermined read rates indicate index contamination, index hopping, or sample sheet errors. Typically acceptable threshold is <5–10%.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runQcMetricId rdf:type rdf:Property ;
    rdfs:label 'Run Qc Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each run QC metric record. Serves as the primary key for this transactional entity capturing quantitative quality measurements at run, lane, or library granularity. Entity role: TRANSACTION_HEADER — stores discrete QC measurement events with a clear lifecycle and multiple metric dimensions sourced from Illumina InterOp, BaseSpace, bcl2fastq, Picard, and samtools.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postMarketSurveillanceId rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Id' ;
    rdfs:comment 'Foreign key linking to regulatory.post_market_surveillance. Business justification: Sequencing run QC metrics (error rates, yield, Q30) are a primary data source for post-market surveillance reports on IVD sequencing products, as required by EU MDR Article 83 and FDA PMS guidance. Do' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PostMarketSurveillance .

ind:supportCaseId rdf:type rdf:Property ;
    rdfs:label 'Support Case Id' ;
    rdfs:comment 'Foreign key linking to customer.support_case. Business justification: QC failures trigger customer support cases. Links metrics to cases for root cause analysis, resolution tracking, and customer communication. Critical for service lab incident management and SLA compli' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportCase .

ind:alignmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Alignment Rate Percent' ;
    rdfs:comment 'Percentage of reads that successfully aligned to the reference genome. Low alignment rates may indicate sample contamination, wrong species, or library preparation failures. Sourced from samtools flagstat or DRAGEN alignment metrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clustersPassingFilterPercent rdf:type rdf:Property ;
    rdfs:label 'Clusters Passing Filter Percent' ;
    rdfs:comment 'Percentage of clusters that pass Illumina\'s chastity filter, indicating the proportion of high-quality reads retained after filtering. A key run-level QC metric; typically ≥75–85% is expected for acceptable run quality. Sourced from Illumina InterOp.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageUniformityPercent rdf:type rdf:Property ;
    rdfs:label 'Coverage Uniformity Percent' ;
    rdfs:comment 'Percentage of target bases covered at ≥20% of the mean coverage depth, measuring how evenly reads are distributed across the target region. High uniformity indicates consistent library preparation and sequencing performance. Sourced from Picard or samtools.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duplication Rate Percent' ;
    rdfs:comment 'Percentage of reads identified as PCR or optical duplicates, which are removed prior to variant calling. High duplication rates reduce effective coverage and indicate over-amplification during library preparation. Sourced from Picard MarkDuplicates.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Error Rate Percent' ;
    rdfs:comment 'Percentage of base calls that do not match the reference sequence, typically measured using PhiX control spike-in. Reflects sequencing chemistry and instrument performance. Lower values indicate higher accuracy. Sourced from Illumina InterOp.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcBiasIndex rdf:type rdf:Property ;
    rdfs:label 'Gc Bias Index' ;
    rdfs:comment 'Quantitative measure of GC content bias in sequencing coverage, indicating the degree to which GC-rich or GC-poor regions are over- or under-represented relative to expected coverage. Values near 0 indicate minimal bias. Sourced from Picard CollectGcBiasMetrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Mean Insert Size Bp' ;
    rdfs:comment 'Average size of the DNA fragment inserted between sequencing adapters, in base pairs. Reflects library preparation quality; deviations from expected insert size indicate degradation, over-fragmentation, or adapter contamination. Sourced from Picard CollectInsertSizeMetrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Median Coverage Depth' ;
    rdfs:comment 'Median fold-coverage across the target region, less sensitive to outliers than mean coverage. Used alongside mean_coverage_depth to assess coverage uniformity and detect regions of extreme over- or under-representation. Sourced from Picard or samtools.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricGranularityLevel rdf:type rdf:Property ;
    rdfs:label 'Metric Granularity Level' ;
    rdfs:comment 'Indicates the level of aggregation at which this QC metric record applies: \'run\' for instrument-wide metrics, \'lane\' for per-lane flow cell metrics, or \'library\' for per-library/per-sample coverage metrics. Determines which metric fields are populated and how the record is used in QC workflows.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Metric Source System' ;
    rdfs:comment 'Identifies the upstream tool or system from which this QC metric record was derived: Illumina InterOp files, BaseSpace, bcl2fastq demultiplexing stats, Picard alignment tools, samtools, DRAGEN, or other. Supports data lineage tracking and metric reproducibility audits. [ENUM-REF-CANDIDATE: InterOp|BaseSpace|bcl2fastq|Picard|samtools|DRAGEN|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTargetRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Target Rate Percent' ;
    rdfs:comment 'Percentage of aligned reads that map to the intended target region (exome capture or targeted panel). Applicable for WES and targeted sequencing assays. Low on-target rates indicate poor library enrichment or capture efficiency. Sourced from Picard CollectHsMetrics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt100x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 100x' ;
    rdfs:comment 'Fraction of target bases covered at a minimum depth of 100X, expressed as a percentage. Used for high-depth targeted sequencing panels, somatic variant calling, and liquid biopsy applications requiring high sensitivity at low allele frequencies. Sourced from Picard or samtools.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt10x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 10x' ;
    rdfs:comment 'Fraction of target bases covered at a minimum depth of 10X, expressed as a percentage. Used as a coverage adequacy threshold for low-depth applications and as a QC gate for variant calling sensitivity. Sourced from Picard CollectHsMetrics or samtools depth.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt20x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 20x' ;
    rdfs:comment 'Fraction of target bases covered at a minimum depth of 20X, expressed as a percentage. Standard coverage threshold for WES clinical assays; used to assess whether sufficient depth was achieved for reliable heterozygous variant detection. Sourced from Picard or samtools.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt30x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 30x' ;
    rdfs:comment 'Fraction of target bases covered at a minimum depth of 30X, expressed as a percentage. Common coverage threshold for WGS clinical applications; used to confirm adequate depth for high-confidence variant calling across the genome. Sourced from Picard or samtools.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pfReads rdf:type rdf:Property ;
    rdfs:label 'Pf Reads' ;
    rdfs:comment 'Number of reads passing Illumina\'s chastity filter (PF reads), representing high-quality reads used in downstream alignment and variant calling. Distinct from total_reads which includes all raw clusters. Sourced from Illumina InterOp or bcl2fastq.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phixAlignmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Phix Alignment Rate Percent' ;
    rdfs:comment 'Percentage of reads that align to the PhiX bacteriophage control genome, which is spiked into sequencing runs as an internal quality control standard. Used to validate sequencing chemistry performance and calibrate error rate measurements.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phixErrorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Phix Error Rate Percent' ;
    rdfs:comment 'Sequencing error rate calculated from PhiX control reads, providing an unbiased measure of instrument and chemistry accuracy independent of sample biology. Sourced from Illumina InterOp. Used for instrument performance trending and GxP compliance.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:q30Percent rdf:type rdf:Property ;
    rdfs:label 'Q30 Percent' ;
    rdfs:comment 'Percentage of bases with a Phred quality score of 30 or higher (Q30), indicating ≥99.9% base call accuracy. Industry-standard instrument performance metric; Illumina typically requires ≥75–80% Q30 for run acceptance. Sourced from Illumina InterOp or BaseSpace.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readType rdf:type rdf:Property ;
    rdfs:label 'Read Type' ;
    rdfs:comment 'Indicates whether the sequencing run used single-end or paired-end read chemistry. Paired-end reads provide improved alignment accuracy and structural variant detection. Affects coverage calculation and bioinformatics pipeline configuration.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'Calendar date on which the sequencing run was initiated. Used as the principal business event date for instrument performance trending, throughput reporting, and time-series QC analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:undeterminedIndexRatePercent rdf:type rdf:Property ;
    rdfs:label 'Undetermined Index Rate Percent' ;
    rdfs:comment 'Percentage of reads that could not be assigned to a sample index during demultiplexing, indicating index hopping, contamination, or library preparation issues. High undetermined rates may trigger run failure or sample reprocessing. Sourced from bcl2fastq demultiplexing stats.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldGb rdf:type rdf:Property ;
    rdfs:label 'Yield Gb' ;
    rdfs:comment 'Total sequencing output in gigabases (Gb) for the run, lane, or library. Represents the volume of sequence data generated and is used to assess whether sufficient data was produced to meet coverage requirements for the assay type. Sourced from Illumina BaseSpace or bcl2fastq.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Clinical Specimen Id' ;
    rdfs:comment 'Foreign key linking to clinical.clinical_specimen. Business justification: Demux results are produced for a specific clinical specimen. While demux_result links to sample_specimen_id, the clinical_specimen carries accession number and chain of custody. Direct link enables CL' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalSpecimen .

ind:originalDemuxResultId rdf:type rdf:Property ;
    rdfs:label 'Original Demux Result Id' ;
    rdfs:comment 'Reference to the original demux_result record when this record represents a reprocessing event (reprocessing_flag = True). Enables full lineage tracing from reprocessed results back to the original demultiplexing output. Null when reprocessing_flag = False.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemuxResult .

ind:assignedReadPct rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Pct' ;
    rdfs:comment 'Percentage of total reads in the lane assigned to this library (assigned_read_count / total lane reads × 100). Indicates library balance within the pool. Values significantly deviating from expected multiplexing ratio trigger QC review.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Data Release Flag' ;
    rdfs:comment 'Indicates whether the FASTQ files produced by this demux result have been formally released for downstream bioinformatics processing or delivery to the customer/requester. True = released; False = held (pending QC review or approval). Supports data governance and release management workflows.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demuxCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Demux Completion Timestamp' ;
    rdfs:comment 'The date and time at which the demultiplexing process completed for this library within the sequencing run. Principal business event timestamp. Used for turnaround time (TAT) calculation and SLA monitoring.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demuxRunIdentifier rdf:type rdf:Property ;
    rdfs:label 'Demux Run Identifier' ;
    rdfs:comment 'Externally-known business identifier for the demultiplexing execution job, as assigned by the demux software (e.g., bcl2fastq job ID or DRAGEN BCL Convert run name). Used for cross-referencing with Illumina BaseSpace Sequence Hub and bioinformatics pipeline logs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demuxStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Demux Start Timestamp' ;
    rdfs:comment 'The date and time at which the demultiplexing process was initiated for this run. Used in conjunction with demux_completion_timestamp to calculate demux processing duration for performance monitoring.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demuxStatus rdf:type rdf:Property ;
    rdfs:label 'Demux Status' ;
    rdfs:comment 'Current lifecycle status of the demultiplexing job for this library-run combination. \'completed\' indicates successful assignment; \'partial\' indicates some reads assigned but below threshold; \'failed\' indicates job error or no reads assigned.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqI1Path rdf:type rdf:Property ;
    rdfs:label 'Fastq I1 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Index Read 1 (i7 index) sequences. Generated when index reads are retained in FASTQ format. Used for index QC validation and troubleshooting demultiplexing failures.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqR1Path rdf:type rdf:Property ;
    rdfs:label 'Fastq R1 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Read 1 (forward reads) generated for this library after demultiplexing. Provides the authoritative link between the demux result and the resulting FASTQ output file for downstream bioinformatics pipeline ingestion.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqR2Path rdf:type rdf:Property ;
    rdfs:label 'Fastq R2 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Read 2 (reverse reads) generated for this library after demultiplexing. Populated only for paired-end sequencing runs. Null for single-end runs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMismatchCount rdf:type rdf:Property ;
    rdfs:label 'Index Mismatch Count' ;
    rdfs:comment 'Number of reads assigned to this library that contained one or more base mismatches in the index sequence relative to the expected index, within the allowed mismatch tolerance. Elevated counts may indicate index synthesis errors or library contamination.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexSequence rdf:type rdf:Property ;
    rdfs:label 'Index Sequence' ;
    rdfs:comment 'The nucleotide index sequence (i7 and optionally i5 dual-index) matched to assign reads to this library during demultiplexing. Supports single-index (e.g., ACGTACGT) and dual-index (e.g., ACGTACGT+TTGGCCAA) formats. Critical for multiplexing validation and index collision analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanPhredScoreR1 rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score R1' ;
    rdfs:comment 'Mean Phred quality score across all bases in Read 1 for this library. Phred score (Q score) represents base call accuracy (Q30 = 99.9% accuracy). A key NGS QC metric; values below Q30 threshold may trigger QC failure.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanPhredScoreR2 rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score R2' ;
    rdfs:comment 'Mean Phred quality score across all bases in Read 2 for this library. Typically lower than R1 due to signal degradation in paired-end sequencing. Null for single-end runs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minReadCountThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Read Count Threshold' ;
    rdfs:comment 'The minimum number of assigned reads required for this library to pass QC, as defined by the applicable assay protocol or SOP. Stored at the record level to capture the threshold in effect at the time of demultiplexing, supporting historical QC audits.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mismatchTolerance rdf:type rdf:Property ;
    rdfs:label 'Mismatch Tolerance' ;
    rdfs:comment 'Number of allowable base mismatches permitted when matching a read\'s index sequence to the expected library index during demultiplexing. Typically 0 or 1. Higher values increase assignment rate but risk index cross-contamination between libraries.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctQ30R1 rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 R1' ;
    rdfs:comment 'Percentage of Read 1 bases with a Phred quality score of 30 or higher (≥Q30). Industry-standard NGS QC threshold; Illumina specifies ≥75–80% Q30 as passing for most platforms. Used in run-level and library-level QC reporting.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctQ30R2 rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 R2' ;
    rdfs:comment 'Percentage of Read 2 bases with a Phred quality score of 30 or higher (≥Q30). Null for single-end runs. Compared against run-specific QC thresholds for paired-end quality assessment.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runUseType rdf:type rdf:Property ;
    rdfs:label 'Run Use Type' ;
    rdfs:comment 'Intended use classification of the sequencing run from which this demux result originates. RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), clinical_validation, or research. Governs applicable regulatory requirements and data handling obligations.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaneReadCount rdf:type rdf:Property ;
    rdfs:label 'Total Lane Read Count' ;
    rdfs:comment 'Total number of reads generated in the flow cell lane from which this library was demultiplexed. Used as the denominator for calculating assigned_read_pct and undetermined_read_pct. Enables per-lane yield assessment.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undeterminedReadCount rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Count' ;
    rdfs:comment 'Number of reads in the lane that could not be assigned to any library due to index mismatch or ambiguity. High undetermined counts indicate index contamination, library preparation issues, or incorrect sample sheet configuration.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undeterminedReadPct rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Pct' ;
    rdfs:comment 'Percentage of total lane reads that were unassigned (undetermined_read_count / total lane reads × 100). A key QC metric; values exceeding the defined threshold (typically >5%) trigger run-level QC failure investigation.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fastqFileId rdf:type rdf:Property ;
    rdfs:label 'Fastq File Id' ;
    rdfs:comment 'Unique surrogate identifier for the FASTQ file record in the sequencing data inventory. Primary key for this master resource entity representing a raw sequencing output file.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FastqFile .

ind:adapterTrimmingFlag rdf:type rdf:Property ;
    rdfs:label 'Adapter Trimming Flag' ;
    rdfs:comment 'Indicates whether adapter sequences were trimmed from reads during or after demultiplexing. Adapter trimming affects downstream alignment and variant calling accuracy. Relevant for pipeline configuration validation.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basespaceFileCode rdf:type rdf:Property ;
    rdfs:label 'Basespace File Code' ;
    rdfs:comment 'The unique file-level identifier assigned by Illumina BaseSpace Sequence Hub to this specific FASTQ file object. Enables direct file-level API operations and provenance tracking within BaseSpace.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'The informed consent status of the subject associated with this FASTQ file\'s sample. Governs permissible uses of the genomic data (research, clinical, secondary use). Withdrawn consent triggers data deletion or de-identification workflows per GDPR and HIPAA.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStatus rdf:type rdf:Property ;
    rdfs:label 'Encryption Status' ;
    rdfs:comment 'Indicates whether this FASTQ file is encrypted at rest in cloud storage. Encryption is mandatory for PHI-containing files under HIPAA Security Rule and for GxP-regulated data. Supports security compliance auditing.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The full file name of the FASTQ output file including extension (e.g., SampleA_S1_L001_R1_001.fastq.gz). Follows Illumina naming conventions encoding sample, lane, read number, and index.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Cloud storage URI indicating the full path to the FASTQ file on BaseSpace or Amazon S3 (e.g., s3://genomics-biotech-seq/runs/RUN001/SampleA_R1.fastq.gz). Serves as the authoritative location reference for downstream bioinformatics pipeline access.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current lifecycle status of the FASTQ file in the sequencing data inventory. Pending = demultiplexing in progress, Available = ready for pipeline consumption, Archived = moved to cold storage, Deleted = purged per retention policy, Failed = generation error, Quarantined = held for QC investigation.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'The date and time when this FASTQ file was generated by the demultiplexing process. Represents the principal business event timestamp — the moment raw sequencing data became available as a FASTQ artifact. Used for TAT (Turnaround Time) calculations and data lineage.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:md5Checksum rdf:type rdf:Property ;
    rdfs:label 'Md5 Checksum' ;
    rdfs:comment 'The MD5 cryptographic hash of the FASTQ file used to verify file integrity during transfer, storage, and archival. Mandatory for data integrity validation in GxP-regulated environments and regulatory submissions.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanReadLengthBp rdf:type rdf:Property ;
    rdfs:label 'Mean Read Length Bp' ;
    rdfs:comment 'The mean length of sequencing reads in this FASTQ file measured in base pairs (bp). Reflects the sequencing chemistry and run configuration. Relevant for alignment pipeline parameter selection and quality benchmarking.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctBasesQ30 rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Q30' ;
    rdfs:comment 'The percentage of bases in this FASTQ file with a Phred quality score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. Industry-standard QC threshold for NGS data quality; typically ≥80% Q30 is required for clinical-grade sequencing.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctReadsPassingFilter rdf:type rdf:Property ;
    rdfs:label 'Pct Reads Passing Filter' ;
    rdfs:comment 'The percentage of reads in this FASTQ file that passed the Illumina chastity filter (PF reads). Reads failing the filter are excluded from analysis. A key indicator of cluster quality and flow cell performance.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phiFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Flag' ;
    rdfs:comment 'Indicates whether this FASTQ file is associated with Protected Health Information (PHI) as defined under HIPAA. When True, the file is subject to HIPAA Privacy and Security Rule requirements, access restrictions, and audit logging obligations. Drives data governance and access control enforcement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Pipeline Ready Flag' ;
    rdfs:comment 'Indicates whether this FASTQ file has passed all QC checks and is cleared for ingestion into bioinformatics analysis pipelines. When True, the file is eligible for alignment, variant calling, and downstream processing. Prevents failed or quarantined files from entering production pipelines.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readNumber rdf:type rdf:Property ;
    rdfs:label 'Read Number' ;
    rdfs:comment 'Designates the read type of this FASTQ file within a paired-end or indexed sequencing run. R1 = forward read, R2 = reverse read, I1 = index 1 (i7), I2 = index 2 (i5). Critical for demultiplexing validation and downstream alignment pipeline configuration.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'The cloud storage tier in which this FASTQ file currently resides. Hot = frequently accessed (active analysis), Warm = infrequent access, Cold = rare access, Archive = long-term retention (e.g., AWS Glacier). Drives storage cost management and retrieval SLA expectations.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when this FASTQ file was successfully uploaded to cloud storage (BaseSpace or S3). Distinct from generation_timestamp; captures the transfer completion event for data availability tracking and SLA monitoring.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverageStatId rdf:type rdf:Property ;
    rdfs:label 'Coverage Stat Id' ;
    rdfs:comment 'Unique surrogate identifier for each coverage statistic record computed post-demultiplexing for a sequencing library. Primary key for the coverage_stat data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForAnalysis rdf:type rdf:Property ;
    rdfs:label 'Approved For Analysis' ;
    rdfs:comment 'Indicates whether this library\'s coverage statistics have been reviewed and approved for downstream bioinformatics analysis (variant calling, annotation). Set to True only when qc_status is Pass and any required manual review has been completed.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computed Timestamp' ;
    rdfs:comment 'Date and time when the coverage statistics were computed by the bioinformatics pipeline post-demultiplexing. Represents the principal business event timestamp for this record. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:duplicationRatePct rdf:type rdf:Property ;
    rdfs:label 'Duplication Rate Pct' ;
    rdfs:comment 'Percentage of mapped reads identified as PCR or optical duplicates. High duplication rates reduce effective coverage depth and can introduce variant calling artifacts. Computed by duplicate-marking tools (e.g., Picard MarkDuplicates) during bioinformatics processing.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcBiasMetric rdf:type rdf:Property ;
    rdfs:label 'Gc Bias Metric' ;
    rdfs:comment 'Quantitative measure of GC content bias in coverage distribution, typically expressed as the normalized coverage deviation across GC content bins. Values near zero indicate minimal GC bias; large deviations indicate systematic under- or over-representation of GC-rich or GC-poor regions.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertSizeMeanBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Mean Bp' ;
    rdfs:comment 'Mean insert size of the sequencing library in base pairs (bp). Reflects the average length of the DNA fragment between adapter sequences. Deviations from expected insert size indicate library preparation issues affecting coverage uniformity and read alignment.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTargetRatePct rdf:type rdf:Property ;
    rdfs:label 'On Target Rate Pct' ;
    rdfs:comment 'Percentage of aligned reads that map to the intended target region (capture panel or amplicon targets). Applicable for WES and targeted sequencing assays. Low on-target rate indicates poor hybridization capture efficiency or library quality issues.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceGenomeVersion rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Version' ;
    rdfs:comment 'Version of the reference genome used for read alignment and coverage computation (e.g., GRCh38, GRCh37/hg19, GRCm39). Critical for reproducibility and cross-sample comparability of coverage statistics. Must match the reference used in downstream variant calling pipelines.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resequencingRequired rdf:type rdf:Property ;
    rdfs:label 'Resequencing Required' ;
    rdfs:comment 'Indicates whether this library has been flagged for resequencing due to insufficient coverage or QC failure. When True, the library must be re-run on the sequencer before downstream bioinformatics analysis can proceed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the laboratory scientist or bioinformatician who performed the manual QC review of this coverage statistic record. Required for clinical assays under CLIA and CAP accreditation to maintain an auditable review trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this coverage statistic record originated. Supports data lineage and provenance tracking in the Databricks Silver Layer. Typically Illumina BaseSpace Sequence Hub for automated pipeline outputs or LabVantage LIMS for manually entered records.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statIdentifier rdf:type rdf:Property ;
    rdfs:label 'Stat Identifier' ;
    rdfs:comment 'Human-readable business identifier for this coverage statistic record, following the COVSTAT-{alphanumeric} naming convention. Used for cross-system referencing and audit trail purposes in LIMS and BaseSpace.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegionSizeBp rdf:type rdf:Property ;
    rdfs:label 'Target Region Size Bp' ;
    rdfs:comment 'Total size of the target genomic region in base pairs as defined by the BED file. Used as the denominator for coverage depth calculations. For WGS, this represents the effective genome size used in analysis.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adapterSequenceRead1 rdf:type rdf:Property ;
    rdfs:label 'Adapter Sequence Read1' ;
    rdfs:comment 'Full adapter sequence flanking the i7 index on the Read 1 side, used for adapter trimming in bioinformatics preprocessing pipelines. Stored in 5\'→3\' orientation per IUPAC convention.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adapterSequenceRead2 rdf:type rdf:Property ;
    rdfs:label 'Adapter Sequence Read2' ;
    rdfs:comment 'Full adapter sequence flanking the i5 index on the Read 2 side, used for adapter trimming in paired-end bioinformatics preprocessing pipelines. Null for single-end or single-index configurations.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle and approval status of the index set within Genomics Biotech sequencing operations. \'pending_validation\' = under internal validation; \'validated\' = technically validated but not yet formally approved; \'approved\' = approved for production use; \'deprecated\' = superseded by a newer set, no new runs; \'retired\' = fully decommissioned.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceIndexSetCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Index Set Code' ;
    rdfs:comment 'The unique identifier assigned to this index set within Illumina BaseSpace Sequence Hub. Enables direct cross-reference between the Genomics Biotech lakehouse master record and the operational sequencing data management platform for run configuration and demultiplexing.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorBalanceStatus rdf:type rdf:Property ;
    rdfs:label 'Color Balance Status' ;
    rdfs:comment 'Indicates whether the index set provides adequate color (fluorescence channel) balance across all sequencing cycles on two-channel or four-channel chemistry instruments. \'balanced\' = no spike-in required; \'unbalanced\' = color imbalance detected; \'requires_spike_in\' = PhiX or other spike-in control is mandatory. Prevents base-calling failures on patterned flow cells.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleInstruments rdf:type rdf:Property ;
    rdfs:label 'Compatible Instruments' ;
    rdfs:comment 'Comma-separated list of sequencing instrument models validated for use with this index set (e.g., \'NovaSeq 6000, NextSeq 550, MiSeq\'). Ensures that run configuration and read cycle parameters are compatible with the index chemistry.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleLibraryPrepKits rdf:type rdf:Property ;
    rdfs:label 'Compatible Library Prep Kits' ;
    rdfs:comment 'Comma-separated list of library preparation kit names or catalogue numbers validated for use with this index set (e.g., \'TruSeq DNA PCR-Free, TruSeq Stranded mRNA, Nextera DNA Flex\'). Managed by sequencing operations to prevent incompatible kit-index pairings during run setup.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'Date on which the index set was deprecated or retired from active use. Null if still active. Used to enforce that no new sequencing runs are configured with deprecated index sets and to support historical traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether the index set was manufactured under Good Manufacturing Practice (GMP) conditions as required for IVD or clinical use. True = GMP-manufactured; False = non-GMP (RUO grade). Drives quality management and supplier qualification requirements.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:i5Sequence rdf:type rdf:Property ;
    rdfs:label 'I5 Sequence' ;
    rdfs:comment 'Nucleotide sequence of the i5 (read 2 side) index used in dual-index configurations. Null or empty for single-index sets. Stored as a representative or consensus sequence; individual per-sample i5 sequences are tracked at the library level.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i7Sequence rdf:type rdf:Property ;
    rdfs:label 'I7 Sequence' ;
    rdfs:comment 'Nucleotide sequence of the i7 (read 1 side) index used for sample identification during demultiplexing. Stored as a representative or consensus sequence for the set; individual per-sample i7 sequences are tracked at the library level. Validated against IUPAC nucleotide codes.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCount rdf:type rdf:Property ;
    rdfs:label 'Index Count' ;
    rdfs:comment 'Total number of unique index sequences (barcodes) available in the set. Determines the maximum multiplexing capacity — i.e., the maximum number of samples that can be pooled in a single sequencing run using this index set.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'Classification of the indexing strategy used in the set. \'single\' = single-end index (i7 only); \'dual\' = dual-index (i7 + i5, may be combinatorial); \'UDI\' = Unique Dual Index (each sample has a unique i7+i5 pair, preventing index hopping); \'combinatorial\' = combinatorial dual index (i7 and i5 drawn from independent pools). Critical for demultiplexing configuration and index-hopping risk assessment.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsIndexSetCode rdf:type rdf:Property ;
    rdfs:label 'Lims Index Set Code' ;
    rdfs:comment 'The unique identifier for this index set in LabVantage LIMS, the system of record for sample tracking and laboratory workflow management. Enables traceability between the lakehouse master record and LIMS-managed library preparation and pool design workflows.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readOrientation rdf:type rdf:Property ;
    rdfs:label 'Read Orientation' ;
    rdfs:comment 'Specifies the orientation in which the i5 index is read on the sequencer. Critical for correct demultiplexing on instruments with different flow cell orientations (e.g., NovaSeq v1.5 flow cells require reverse complement of i5 vs. standard orientation). [ENUM-REF-CANDIDATE: forward|reverse_complement|forward_reverse|reverse_complement_forward — promote to reference product]' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingChemistry rdf:type rdf:Property ;
    rdfs:label 'Sequencing Chemistry' ;
    rdfs:comment 'The sequencing chemistry type for which this index set is designed. Determines color balance requirements and base-calling algorithm compatibility. \'two_channel\' = Illumina two-channel SBS (e.g., NextSeq, NovaSeq); \'four_channel\' = Illumina four-channel SBS (e.g., MiSeq, HiSeq); \'ion_semiconductor\' = Ion Torrent; \'nanopore\' = Oxford Nanopore; \'other\' = other chemistry.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setCode rdf:type rdf:Property ;
    rdfs:label 'Set Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code or catalogue number assigned to the index set by the manufacturer or internally by sequencing operations. Used as the business key for cross-system lookups and BOM references in SAP S/4HANA MM.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setName rdf:type rdf:Property ;
    rdfs:label 'Set Name' ;
    rdfs:comment 'Human-readable name of the sequencing index set as defined by the manufacturer or sequencing operations team (e.g., \'Illumina TruSeq CD Index Set A\', \'IDT xGen UDI-UMI Adapters\'). Used as the primary display label in library preparation workflows and pool design tools.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Manufacturer-specified shelf life of the index set reagents in months from the date of manufacture. Used for expiry tracking, inventory management, and ensuring reagents are not used beyond their validated stability window.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededBySetCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Set Code' ;
    rdfs:comment 'Set code of the newer index set that replaces this one when it is deprecated. Enables migration guidance for sequencing operations teams transitioning from legacy to current index chemistries. Null if not superseded.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umiIncluded rdf:type rdf:Property ;
    rdfs:label 'Umi Included' ;
    rdfs:comment 'Indicates whether the index set includes Unique Molecular Identifiers (UMIs) integrated into the adapter design. UMIs enable PCR duplicate removal and error correction in downstream bioinformatics pipelines, critical for low-input and cfDNA applications.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:umiLengthBp rdf:type rdf:Property ;
    rdfs:label 'Umi Length Bp' ;
    rdfs:comment 'Length of the UMI sequence in base pairs when UMIs are included in the index set design (e.g., 8, 12 bp). Null if umi_included is False. Required for configuring UMI extraction steps in bioinformatics pipelines.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or employee identifier of the sequencing operations scientist or engineer who performed and signed off on the internal technical validation of this index set. Supports GxP audit trail requirements.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of the index set definition, following semantic versioning convention (e.g., \'v1.0\', \'v2.1\', \'v1.0.3\'). Incremented when index sequences, Hamming distance parameters, or compatibility matrices are updated. Supports change control and audit trail requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedKitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Approved Kit Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.catalog. Business justification: Sequencing protocols must reference approved reagent kit catalog entries for GMP validation and regulatory submission. The existing approved_kit_catalog_item_id targets product.catalog_item; reagent.c' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:approvedKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Approved Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Validated sequencing protocols specify approved/compatible kit catalog items. Essential for SOP compliance, regulatory submissions (FDA/IVDR), quality system requirements, and ensuring only validated ' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:approvedSoftwareReleaseId rdf:type rdf:Property ;
    rdfs:label 'Approved Software Release Id' ;
    rdfs:comment 'Foreign key linking to product.software_release. Business justification: Sequencing protocols specify the approved demultiplexing/basecalling software version for regulatory compliance (CLIA, CAP). The plain column demultiplexing_tool is a denormalized reference to product' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareRelease .

ind:sopDocumentId rdf:type rdf:Property ;
    rdfs:label 'Sop Document Id' ;
    rdfs:comment 'Document control identifier for the approved SOP governing execution of this sequencing protocol, as managed in MasterControl or Veeva Vault. Provides a direct link from the protocol record to the procedural document for GxP audit trails and training compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:approvedLibraryPrepKits rdf:type rdf:Property ;
    rdfs:label 'Approved Library Prep Kits' ;
    rdfs:comment 'Comma-separated list of approved library preparation kit names and catalog numbers validated for use with this sequencing protocol (e.g., \'Illumina DNA Prep (20018704), TruSeq DNA PCR-Free (20015963)\'). Only kits on this list may be used in GxP-regulated runs. Validated in Benchling and controlled in MasterControl.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccredited rdf:type rdf:Property ;
    rdfs:label 'Cap Accredited' ;
    rdfs:comment 'Indicates whether this protocol is covered under a CAP-accredited laboratory\'s scope of accreditation. True = included in CAP accreditation scope; False = not within CAP scope. Relevant for clinical genomics laboratories reporting patient results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaValidated rdf:type rdf:Property ;
    rdfs:label 'Clia Validated' ;
    rdfs:comment 'Indicates whether this protocol has been validated under CLIA requirements for clinical laboratory use. True = CLIA validation completed and documented; False = not CLIA validated (RUO or research only). Required for protocols used in LDT or clinical reporting contexts.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibleInstrumentModels rdf:type rdf:Property ;
    rdfs:label 'Compatible Instrument Models' ;
    rdfs:comment 'Comma-separated list of sequencing instrument models validated for use with this protocol (e.g., \'NovaSeq 6000, NovaSeq X Plus, NextSeq 2000\'). Ensures run parameters are only applied to compatible hardware. Validated against instrument qualification records in LabVantage LIMS.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:index1CycleCount rdf:type rdf:Property ;
    rdfs:label 'Index1 Cycle Count' ;
    rdfs:comment 'Number of cycles for the Index 1 (i7) read used in multiplexing to demultiplex samples on a shared flow cell. Typically 8 or 10 cycles. Required for all multiplexed library pools. Null for non-indexed single-sample runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:index2CycleCount rdf:type rdf:Property ;
    rdfs:label 'Index2 Cycle Count' ;
    rdfs:comment 'Number of cycles for the Index 2 (i5) read used in dual-index multiplexing schemes. Typically 8 or 10 cycles. Null for single-index or non-indexed protocols. Dual indexing reduces index-hopping artifacts in high-multiplex runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxClusterDensity rdf:type rdf:Property ;
    rdfs:label 'Max Cluster Density' ;
    rdfs:comment 'Maximum acceptable cluster density on the flow cell surface in K/mm². Exceeding this threshold causes cluster overlap (over-clustering), degrading base call quality and Q30 scores. Paired with min_cluster_density to define the acceptable loading range.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Max Insert Size Bp' ;
    rdfs:comment 'Maximum acceptable DNA insert size in base pairs for library fragments. Inserts exceeding this threshold may indicate insufficient fragmentation, leading to reduced cluster density and read-through artifacts. Paired with min_insert_size_bp to define the acceptable library size range.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minClusterDensity rdf:type rdf:Property ;
    rdfs:label 'Min Cluster Density' ;
    rdfs:comment 'Minimum acceptable cluster density on the flow cell surface, expressed in thousands of clusters per square millimeter (K/mm²). Below this threshold, insufficient data yield is expected. Used as a pre-run and mid-run QC gate in Illumina BaseSpace.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Min Insert Size Bp' ;
    rdfs:comment 'Minimum acceptable DNA insert size in base pairs for library fragments sequenced under this protocol. Insert sizes below this threshold indicate over-fragmentation and may degrade paired-end alignment quality. Used as a library QC acceptance criterion in LabVantage LIMS.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplexingMaxSamples rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Max Samples' ;
    rdfs:comment 'Maximum number of samples that can be pooled and multiplexed on a single flow cell lane under this protocol while maintaining the target coverage depth per sample. Governs library pooling decisions in LabVantage LIMS and run planning in BaseSpace.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or employee identifier of the scientist or team lead responsible for maintaining and updating this sequencing protocol. The protocol owner initiates change control requests and is accountable for scientific validity. Sourced from Oracle Cloud HCM.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDataGenerated rdf:type rdf:Property ;
    rdfs:label 'Phi Data Generated' ;
    rdfs:comment 'Indicates whether sequencing runs executed under this protocol generate Protected Health Information (PHI) as defined by HIPAA. True = PHI is generated (clinical patient samples); False = no PHI (research/RUO samples). Governs data handling, storage, and access control requirements for resulting FASTQ and downstream files.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolCode rdf:type rdf:Property ;
    rdfs:label 'Protocol Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this protocol and version (e.g., WGS-PCR-v2.1). Used as the business identifier across LIMS, BaseSpace, and regulatory submissions. Serves as the BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolName rdf:type rdf:Property ;
    rdfs:label 'Protocol Name' ;
    rdfs:comment 'Full descriptive name of the sequencing protocol (e.g., \'Whole Genome Sequencing PCR-Free 150bp Paired-End\'). Serves as the IDENTITY_LABEL category for MASTER_RESOURCE role. Used in reporting, SOP references, and customer-facing documentation.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:r1CycleCount rdf:type rdf:Property ;
    rdfs:label 'R1 Cycle Count' ;
    rdfs:comment 'Number of sequencing cycles for Read 1 (R1), determining the read length in base pairs for the forward read. Common values include 75, 100, 150, 250 cycles. Directly impacts data quality, coverage, and FASTQ file size. Serves as the MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:r2CycleCount rdf:type rdf:Property ;
    rdfs:label 'R2 Cycle Count' ;
    rdfs:comment 'Number of sequencing cycles for Read 2 (R2) in paired-end configurations. Null for single-end protocols. Must match R1 cycle count for symmetric paired-end runs or may differ for asymmetric configurations. Governs reverse read length in base pairs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readConfiguration rdf:type rdf:Property ;
    rdfs:label 'Read Configuration' ;
    rdfs:comment 'Specifies whether the sequencing run is configured for single-end or paired-end reads. Paired-end reads generate two reads per fragment (R1 and R2), improving alignment accuracy and variant calling. Directly governs flow cell programming and FASTQ output structure.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingApplicationType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Application Type' ;
    rdfs:comment 'Classification of the genomic sequencing application this protocol supports. Serves as the CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. Drives downstream bioinformatics pipeline selection and QC thresholds. WGS = Whole Genome Sequencing; WES = Whole Exome Sequencing; RNA-seq = RNA Sequencing.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingProtocolDescription rdf:type rdf:Property ;
    rdfs:label 'Sequencing Protocol Description' ;
    rdfs:comment 'Free-text narrative description of the sequencing protocol, including its scientific rationale, key distinguishing parameters, intended sample types, and any special handling requirements. Authored by the protocol owner and reviewed during the GxP approval process.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopVersion rdf:type rdf:Property ;
    rdfs:label 'Sop Version' ;
    rdfs:comment 'Version of the SOP document referenced by sop_document_id that is current and approved for use with this protocol version. Ensures the protocol record is always linked to the correct procedural revision, supporting GxP change control.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByProtocolCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Protocol Code' ;
    rdfs:comment 'Protocol code of the newer version that replaces this protocol upon retirement. Null for the current active version. Enables forward navigation in the protocol version chain for change control traceability and migration of active runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPanelBedFile rdf:type rdf:Property ;
    rdfs:label 'Target Panel Bed File' ;
    rdfs:comment 'File path or artifact identifier for the BED (Browser Extensible Data) file defining the genomic target regions for targeted panel or WES protocols. Null for WGS protocols. Used by bioinformatics pipelines for on-target coverage calculation and variant calling region restriction. Stored in genomic artifact repository.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runSampleSheetId rdf:type rdf:Property ;
    rdfs:label 'Run Sample Sheet Id' ;
    rdfs:comment 'Unique surrogate identifier for the run sample sheet record in the Databricks Silver Layer. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Foreign key linking to instrument.configuration. Business justification: Sample sheets must be generated to match the active instrument configuration — software version determines override cycles format, demultiplexing software version, and index adapter kit compatibility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:adapterRead1 rdf:type rdf:Property ;
    rdfs:label 'Adapter Read1' ;
    rdfs:comment 'The adapter sequence to be trimmed from the 3\' end of Read 1 during BCLConvert processing (e.g., AGATCGGAAGAGCACACGTCTGAACTCCAGTCA for TruSeq). Correct adapter specification is critical for accurate read trimming and downstream alignment quality.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adapterRead2 rdf:type rdf:Property ;
    rdfs:label 'Adapter Read2' ;
    rdfs:comment 'The adapter sequence to be trimmed from the 3\' end of Read 2 in paired-end runs (e.g., AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT for TruSeq). Null for single-end runs. Must match the library preparation kit adapter chemistry.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'The genomic sequencing application configured for this run. Drives pipeline selection, adapter trimming, and analysis settings. Examples: WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), Targeted Panel, Amplicon, RNA-Seq, Methylation, 16S rRNA. [ENUM-REF-CANDIDATE: WGS|WES|Targeted Panel|Amplicon|RNA-Seq|Methylation|16S rRNA|Custom — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the sample sheet received final approval (electronic signature) for use in a GxP-controlled sequencing run. Distinct from submission timestamp; captures the authorization event in the document lifecycle.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'The electronic signature identifier or hash of the authorized signatory who approved this sample sheet for GxP-controlled runs. Required under 21 CFR Part 11 for electronic records in regulated environments. Stored as a reference token, not the raw signature credential.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'The experiment identifier or label captured in the [Header] section of the Illumina sample sheet. Provides a human-readable label for the run experiment, used for BaseSpace project organization and LIMS cross-referencing.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:index1Cycles rdf:type rdf:Property ;
    rdfs:label 'Index1 Cycles' ;
    rdfs:comment 'Number of cycles for Index 1 (i7 index read) used in multiplexed library demultiplexing. Typically 8 or 10 cycles. Determines the length of the i7 barcode sequence read during the indexing phase.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:index2Cycles rdf:type rdf:Property ;
    rdfs:label 'Index2 Cycles' ;
    rdfs:comment 'Number of cycles for Index 2 (i5 index read) used in dual-indexed multiplexed library demultiplexing. Typically 8 or 10 cycles. Null for single-indexed runs. Required for dual-index demultiplexing workflows.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexAdapterKit rdf:type rdf:Property ;
    rdfs:label 'Index Adapter Kit' ;
    rdfs:comment 'The specific index adapter kit used for multiplexing (e.g., IDT for Illumina DNA/RNA UD Indexes, Nextera DNA CD Indexes). Defines the index sequence set and ensures correct barcode assignment during demultiplexing.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Name of the principal investigator or study lead responsible for the samples in this run. Captured in the [Header] section of the Illumina sample sheet. Used for accountability, reporting, and GxP traceability.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRequestCode rdf:type rdf:Property ;
    rdfs:label 'Lims Request Code' ;
    rdfs:comment 'The work order or sequencing request identifier from LabVantage LIMS that initiated this sample sheet. Provides bidirectional traceability between the sample sheet and the originating laboratory workflow request.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskShortReads rdf:type rdf:Property ;
    rdfs:label 'Mask Short Reads' ;
    rdfs:comment 'The MaskShortReads BCLConvert setting specifying the read length threshold below which reads are masked (replaced with Ns) rather than discarded. Complements minimum_trimmed_read_length to control short-read handling behavior in FASTQ output.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTrimmedReadLength rdf:type rdf:Property ;
    rdfs:label 'Minimum Trimmed Read Length' ;
    rdfs:comment 'The MinimumTrimmedReadLength BCLConvert setting specifying the minimum acceptable read length (in base pairs) after adapter trimming. Reads shorter than this threshold are discarded. Impacts FASTQ output quality and downstream alignment performance.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideCyclesString rdf:type rdf:Property ;
    rdfs:label 'Override Cycles String' ;
    rdfs:comment 'The OverrideCycles parameter string in Illumina sample sheet v2 format (e.g., \'Y151;I8;I8;Y151\') that explicitly defines the cycle allocation for each read and index segment. Overrides default cycle settings and is used by BCLConvert for precise demultiplexing configuration.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'The project or study name associated with the samples in this sample sheet. Used for grouping FASTQ output files by project in BaseSpace and downstream bioinformatics pipelines. Maps to the \'Sample_Project\' column in the sample manifest.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:read1Cycles rdf:type rdf:Property ;
    rdfs:label 'Read1 Cycles' ;
    rdfs:comment 'Number of sequencing cycles for Read 1 (forward read). Directly determines the read length in base pairs for the primary read. Typical values range from 50 to 300 cycles depending on application and instrument platform.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:read2Cycles rdf:type rdf:Property ;
    rdfs:label 'Read2 Cycles' ;
    rdfs:comment 'Number of sequencing cycles for Read 2 (reverse read) in paired-end runs. Null for single-end runs. Must match Read 1 cycles for symmetric paired-end configurations or may differ for asymmetric designs.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runSampleSheetDescription rdf:type rdf:Property ;
    rdfs:label 'Run Sample Sheet Description' ;
    rdfs:comment 'Free-text description field from the [Header] section of the Illumina sample sheet. May include run purpose, special instructions, or notes relevant to the sequencing configuration. Supports operational context for lab staff.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Format Version' ;
    rdfs:comment 'Version of the Illumina sample sheet format used (v1 or v2). v2 supports multi-section configuration including [Header], [Reads], [BCLConvert_Settings], and [BCLConvert_Data] sections. Determines downstream demultiplexing compatibility and parser behavior.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetName rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Name' ;
    rdfs:comment 'Human-readable name or title assigned to the sample sheet file, typically following the Illumina naming convention (e.g., SampleSheet_RunID_YYYYMMDD). Serves as the externally-known business identifier for this document. Aligns with Illumina BaseSpace Sequence Hub sample sheet naming standards.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorSummary rdf:type rdf:Property ;
    rdfs:label 'Validation Error Summary' ;
    rdfs:comment 'Free-text summary of validation errors or warnings identified during automated sample sheet validation (e.g., index collision detected, invalid cycle count, missing required fields). Populated when validation_status is \'failed_validation\'. Supports rapid troubleshooting by lab operators.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Specimens are collected using specific collection kit products. LIMS systems track kit SKU for regulatory compliance (21 CFR Part 11), lot traceability, and QC correlation. Essential for genomics oper' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:parentSpecimenSampleSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Parent Specimen Sample Specimen Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent specimen from which this specimen was derived (e.g., an aliquot derived from a primary blood draw, or an extracted DNA specimen derived from a tissue biopsy). Enables hierarchical specimen lineage and chain-of-custody traceability.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSpecimen .

ind:processingReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Processing Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Specimens are processed using specific reagent lots for nucleic acid extraction, library preparation, and quality control. Critical for batch effect analysis, regulatory traceability (21 CFR Part 11),' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:subjectId rdf:type rdf:Property ;
    rdfs:label 'Subject Id' ;
    rdfs:comment 'Reference to the biological subject (human patient, research participant, animal, or environmental source) from whom the specimen was collected. Links to the subject master record for IRB consent and PHI management. Classified as restricted due to potential re-identification risk.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:a260A280Ratio rdf:type rdf:Property ;
    rdfs:label 'A260 A280 Ratio' ;
    rdfs:comment 'Ratio of absorbance at 260 nm to 280 nm as measured by NanoDrop spectrophotometer, indicating nucleic acid purity. Acceptable range is 1.8–2.0 for DNA and ~2.0 for RNA. Values outside this range indicate protein or solvent contamination.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aliquotNumber rdf:type rdf:Property ;
    rdfs:label 'Aliquot Number' ;
    rdfs:comment 'Sequential number identifying this specimen as a specific aliquot derived from a parent specimen (e.g., aliquot 3 of 8 from a primary blood draw). Used for inventory management, depletion tracking, and ensuring equitable distribution of limited specimens across assays.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country in which the specimen was collected (e.g., USA, GBR, DEU). Required for GDPR cross-border data transfer compliance, biospecimen import/export regulatory tracking, and population genomics stratification.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Standardized method used to collect the specimen from the subject. Influences pre-analytical variability, QC acceptance criteria, and downstream genomic assay performance. [ENUM-REF-CANDIDATE: venipuncture|finger_prick|biopsy|swab|saliva_collection|urine_void|bone_marrow_aspirate|surgical_resection|liquid_biopsy|environmental_swab|other — promote to reference product]' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCode rdf:type rdf:Property ;
    rdfs:label 'Collection Site Code' ;
    rdfs:comment 'Coded identifier for the anatomical site or environmental location from which the specimen was collected (e.g., left_arm_antecubital, liver_biopsy_segment_VI, tumor_margin). Aligns with SNOMED CT body site codes. Critical for oncology and multi-site clinical studies.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Date and time at which the specimen was physically collected from the subject, recorded in ISO 8601 format with timezone offset. Critical for pre-analytical stability calculations, TAT (Turnaround Time) tracking, and time-sensitive assay validity windows (e.g., cfDNA stability). Serves as the MEASUREMENT_OR_VALUE temporal anchor for this resource.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concentrationNgUl rdf:type rdf:Property ;
    rdfs:label 'Concentration Ng Ul' ;
    rdfs:comment 'Concentration of extracted nucleic acid (DNA or RNA) in nanograms per microliter (ng/µL), measured post-extraction by fluorometric or spectrophotometric methods (e.g., Qubit, NanoDrop). Used for library preparation input normalization and QC pass/fail determination.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of physical container or tube in which the specimen is stored (e.g., EDTA tube, SST tube, PAXgene tube, cryovial, FFPE block). Affects pre-analytical processing requirements and downstream assay compatibility. [ENUM-REF-CANDIDATE: EDTA_tube|SST_tube|PAXgene_tube|cryovial|FFPE_block|microcentrifuge_tube|96_well_plate|other — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Date and time at which the specimen was permanently disposed of or destroyed, recorded in LabVantage LIMS. Populated only when lifecycle_status is \'disposed\'. Required for biorepository inventory reconciliation, regulatory audit trails, and biohazardous waste compliance documentation.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dnaIntegrityNumber rdf:type rdf:Property ;
    rdfs:label 'Dna Integrity Number' ;
    rdfs:comment 'DNA Integrity Number (DIN) score on a scale of 1-10 as measured by TapeStation, indicating genomic DNA quality and fragmentation level. Used for WGS and WES library preparation QC gating. Null for non-DNA specimens.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalSpecimenCode rdf:type rdf:Property ;
    rdfs:label 'External Specimen Code' ;
    rdfs:comment 'Specimen identifier assigned by the submitting institution, clinic, or partner laboratory prior to receipt at Genomics Biotech. Used for cross-referencing with external Laboratory Information Systems (LIS) and Electronic Medical Records (EMR). May differ from the internal LIMS accession number.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Count' ;
    rdfs:comment 'Number of freeze-thaw cycles the specimen has undergone since collection. Excessive freeze-thaw cycles degrade nucleic acid integrity and protein stability, impacting assay performance. Tracked in LabVantage LIMS for QC and specimen integrity assessment.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Biosafety Level (BSL) classification of the specimen per CDC/NIH biosafety guidelines, indicating the containment requirements for safe handling, processing, and disposal. Drives PPE requirements, laboratory access controls, and waste disposal procedures.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label printed on the specimen container or tube, typically matching the LIMS accession number or a barcode-encoded identifier. Used for physical identification during laboratory handling, storage, and retrieval. Serves as the IDENTITY_LABEL category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the specimen within the Genomics Biotech laboratory workflow lifecycle. Drives LIMS workflow routing, storage management, and chain-of-custody audit events. Serves as the LIFECYCLE_STATUS category for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: accessioned|in_processing|extracted|archived|depleted|disposed|rejected|on_hold — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Accession Number' ;
    rdfs:comment 'Externally-known unique accession number assigned by LabVantage LIMS at the point of specimen receipt. This is the primary business identifier used across laboratory workflows, requisition forms, and chain-of-custody documentation. Serves as the BUSINESS_IDENTIFIER category for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massMg rdf:type rdf:Property ;
    rdfs:label 'Mass Mg' ;
    rdfs:comment 'Mass of the specimen in milligrams (mg) at the time of accessioning or most recent measurement. Applicable to solid specimens (tissue biopsies, FFPE blocks, dried blood spots). Null for liquid specimens where volume_ul is used instead.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Physical matrix or medium in which the specimen is preserved or suspended (e.g., aqueous buffer, FFPE paraffin block, dried blood spot, frozen tissue). Determines storage temperature requirements, extraction chemistry, and analytical method compatibility. [ENUM-REF-CANDIDATE: aqueous|solid|semi-solid|dried|fixed|frozen|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passageCount rdf:type rdf:Property ;
    rdfs:label 'Passage Count' ;
    rdfs:comment 'Number of times the specimen or derived cell line has been sub-cultured or passaged. Relevant for cell-based specimens and primary cultures. Higher passage counts may indicate genomic drift and affect assay validity.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phiDeidentificationTier rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentification Tier' ;
    rdfs:comment 'Specifies the de-identification method applied to this specimen record per HIPAA standards: Safe Harbor (removal of 18 identifiers), Expert Determination (statistical certification), Pseudonymisation (GDPR Article 4(5)), or Identified (PHI present). Drives data access tier controls and downstream sharing permissions.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDeidentified rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentified' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) has been removed or de-identified from this specimen record in accordance with HIPAA Safe Harbor or Expert Determination methods. When True, the record may be used in broader research contexts without individual consent restrictions.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Processing priority assigned to the specimen, governing TAT (Turnaround Time) SLA targets and workflow queue position in LabVantage LIMS. STAT specimens require immediate processing; routine specimens follow standard scheduling.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time at which the specimen was received and accessioned into the Genomics Biotech laboratory, recorded in LabVantage LIMS. Used to calculate transit time, pre-analytical cold-chain compliance, and TAT (Turnaround Time) SLA metrics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Coded reason for specimen rejection at accessioning or QC review. Populated only when lifecycle_status is \'rejected\'. Used for pre-analytical quality monitoring, root cause analysis, and SOP improvement. [ENUM-REF-CANDIDATE: insufficient_volume|hemolyzed|lipemic|clotted|wrong_container|mislabeled|temperature_excursion|expired|contaminated|other — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinScore rdf:type rdf:Property ;
    rdfs:label 'Rin Score' ;
    rdfs:comment 'RNA Integrity Number (RIN) score on a scale of 1-10 as measured by Bioanalyzer or TapeStation, indicating RNA quality. A RIN score ≥7 is typically required for RNA-Seq library preparation. Null for non-RNA specimens.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Classification of the biological material type collected from the subject. Drives downstream workflow routing, extraction protocols, and storage conditions in LabVantage LIMS. Serves as the CLASSIFICATION_OR_TYPE category for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: blood|tissue|saliva|urine|plasma|cfDNA|FFPE|bone_marrow|buccal_swab|stool|other — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further granular classification of the specimen within its primary type (e.g., for blood: whole_blood, PBMC, serum; for tissue: fresh_frozen, FFPE_block, FFPE_section; for cfDNA: cell_free_plasma). Enables precise protocol selection and QC thresholds in bioinformatics pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tumorContentPct rdf:type rdf:Property ;
    rdfs:label 'Tumor Content Pct' ;
    rdfs:comment 'Estimated percentage of tumor cells (neoplastic cellularity) in the specimen as assessed by pathology review. Critical for somatic variant calling sensitivity, LOD (Limit of Detection) calculations, and clinical oncology reporting. Null for non-oncology specimens.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Use Restriction Code' ;
    rdfs:comment 'Coded data use restriction applicable to this specimen and its derived genomic data, aligned with GA4GH Data Use Ontology (DUO) codes (e.g., GRU: General Research Use, HMB: Health/Medical/Biomedical, DS: Disease-Specific). Governs permissible downstream research and data sharing activities.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUl rdf:type rdf:Property ;
    rdfs:label 'Volume Ul' ;
    rdfs:comment 'Volume of the specimen in microliters (µL) at the time of accessioning or most recent measurement. Used for aliquot planning, minimum volume QC checks, and assay feasibility assessment. Applicable to liquid specimens (blood, plasma, urine, saliva, cfDNA). Null for solid specimens where mass_mg is used instead.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAliquotId rdf:type rdf:Property ;
    rdfs:label 'Parent Aliquot Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent aliquot when this record represents a secondary or tertiary sub-division (aliquot-of-aliquot). Null for first-generation aliquots derived directly from the specimen. Enables multi-level aliquot hierarchy traversal.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aliquot .

ind:preparationReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Preparation Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Aliquots are prepared using specific reagent types (extraction kits, normalization buffers, stabilization reagents). Needed for protocol compliance verification, method validation studies, and ensurin' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:preparationReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Preparation Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: GMP/GLP aliquot preparation traceability: existing FK covers only the catalog entry, not the specific lot used. Lot-level traceability is required for reagent recall investigations and batch record co' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:sampleConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Sample Consent Record Id' ;
    rdfs:comment 'Reference to the Institutional Review Board (IRB) consent record governing the permissible uses of this aliquot. Ensures that downstream workflows (sequencing, research, clinical) are authorized under the applicable consent scope. Critical for HIPAA, GDPR, and NIH Genomic Data Sharing Policy compliance.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleConsentRecord .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Reference to the storage location record defining the physical storage unit (freezer, refrigerator, ambient rack) where this aliquot is currently housed. Supports chain-of-custody and cold-chain compliance tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:aliquotType rdf:type rdf:Property ;
    rdfs:label 'Aliquot Type' ;
    rdfs:comment 'Classification of the aliquot within the sub-division hierarchy. \'primary\' indicates first-generation aliquot from specimen; \'secondary\' and \'tertiary\' indicate downstream sub-divisions; \'pooled\' indicates a combined aliquot from multiple sources; \'reference\' indicates a reference material aliquot.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aliquoting Timestamp' ;
    rdfs:comment 'Date and time at which this aliquot was physically created from the parent specimen or parent aliquot. Represents the principal real-world business event timestamp for this entity. Used for pre-analytical variable tracking, stability calculations, and chain-of-custody documentation.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Unique barcode label affixed to the physical container holding this aliquot. Used for barcode-driven tracking, scanning at workstations, and chain-of-custody verification throughout laboratory workflows in LabVantage LIMS.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the original biological specimen was collected from the subject. Inherited from the parent specimen record. Critical for calculating specimen age, assessing pre-analytical variable impact, and meeting regulatory reporting timelines under CLIA and CAP.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concentration rdf:type rdf:Property ;
    rdfs:label 'Concentration' ;
    rdfs:comment 'Measured concentration of the biological analyte (e.g., DNA, RNA, protein) in the aliquot. The unit of measure is captured in concentration_unit. Critical for library preparation normalization in Next-Generation Sequencing (NGS) workflows and Quality Control (QC) acceptance criteria.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the concentration value recorded in the concentration field. Common units include ng/µL (nanograms per microliter) for DNA/RNA quantification, nM (nanomolar) for library quantification, and copies/µL for digital Polymerase Chain Reaction (PCR) applications.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStatus rdf:type rdf:Property ;
    rdfs:label 'Container Status' ;
    rdfs:comment 'Current operational status of the physical container holding the aliquot. \'in_use\' indicates container holds active aliquot material; \'empty\' indicates container has been emptied; \'discarded\' indicates container has been disposed of; \'pre_registered\' indicates container registered in LabVantage LIMS prior to receiving material (empty container inventory management).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'Reason code for the disposal or destruction of the aliquot. Supports regulatory audit trails and consent management reporting. \'consent_withdrawn\' is critical for GDPR Article 17 right-to-erasure and HIPAA consent revocation workflows.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this aliquot within the parent-child hierarchy. Level 1 indicates a direct sub-division of the primary specimen; level 2 indicates an aliquot-of-aliquot; and so on. Enables efficient hierarchy traversal queries and enforces maximum sub-division depth policies.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Initial Volume Ul' ;
    rdfs:comment 'Original volume of biological material dispensed into the aliquot container at the time of aliquoting, expressed in microliters (µL). Provides the baseline for volume consumption tracking and yield calculations.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPhiDeidentified rdf:type rdf:Property ;
    rdfs:label 'Is Phi Deidentified' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) associated with this aliquot has been de-identified in accordance with HIPAA Safe Harbor or Expert Determination methods. True indicates de-identified; False indicates PHI is present and access controls apply. Governs data sharing eligibility for research and external collaborations.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsAliquotCode rdf:type rdf:Property ;
    rdfs:label 'Lims Aliquot Code' ;
    rdfs:comment 'The native aliquot identifier assigned by LabVantage LIMS at the time of accessioning or aliquoting. Used as the operational cross-reference key between the lakehouse Silver Layer and the LIMS source system.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityRatio260230 rdf:type rdf:Property ;
    rdfs:label 'Purity Ratio 260 230' ;
    rdfs:comment 'Absorbance ratio at 260nm to 230nm measured by spectrophotometry. Indicates contamination by chaotropic salts, EDTA, or carbohydrates. Acceptable range is typically 2.0–2.2. Complements the A260/A280 ratio for comprehensive nucleic acid Quality Control (QC) assessment.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityRatio260280 rdf:type rdf:Property ;
    rdfs:label 'Purity Ratio 260 280' ;
    rdfs:comment 'Absorbance ratio at 260nm to 280nm measured by spectrophotometry (e.g., NanoDrop). Indicates nucleic acid purity; acceptable DNA purity is typically 1.8–2.0 and RNA purity 2.0–2.2. Values outside range may indicate protein or solvent contamination affecting downstream Next-Generation Sequencing (NGS) performance.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Intended downstream use of the aliquot. Drives workflow routing in LabVantage LIMS and determines which bioinformatics pipelines or Quality Control (QC) processes the aliquot will enter. Values include sequencing (Next-Generation Sequencing/NGS workflows), qc (Quality Control testing), archive (long-term storage), backup (redundancy), assay_validation (Clinical Assay Validation), and research (Research and Development).' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Free-text notes recorded by laboratory personnel during Quality Control (QC) assessment. Documents observations, deviations, conditional pass justifications, or remediation actions taken. Supports audit trail requirements under Good Practice Regulations (GxP) and CLIA.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier of the storage rack, plate, or box within the storage unit where this aliquot is positioned. Combined with well_position provides the precise physical location for robotic retrieval and manual locating in biobank operations.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume fields (volume_ul and initial_volume_ul). Standard unit is microliters (µL) for most genomics laboratory workflows; milliliters (mL) may be used for larger biobank specimens.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellPosition rdf:type rdf:Property ;
    rdfs:label 'Well Position' ;
    rdfs:comment 'Alphanumeric position identifier within the storage rack, plate, or box (e.g., A01, B12, H08 for a 96-well plate layout). Used for precise physical localization of the aliquot within its storage container for robotic liquid handling and manual retrieval.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOrdererId rdf:type rdf:Property ;
    rdfs:label 'Authorized Orderer Id' ;
    rdfs:comment 'National Provider Identifier (NPI) or internal identifier of the ordering physician or clinical provider who requisitioned the test. Used for result reporting, billing, and clinical communication. Classified as confidential.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthorizedOrderer .

ind:collectionEventId rdf:type rdf:Property ;
    rdfs:label 'Collection Event Id' ;
    rdfs:comment 'Foreign key linking to sample.collection_event. Business justification: Accession (formal laboratory intake) and collection_event (physical specimen collection) are closely coupled transactional records in the sample lifecycle. An accession record corresponds to a specifi' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionEvent .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_delivery. Business justification: Specimen accession maps to an inbound delivery record for chain-of-custody, cold-chain compliance, and logistics tracking. Genomics biotech labs receiving specimens from external sites use inbound del' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:irbSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Irb Submission Id' ;
    rdfs:comment 'Foreign key linking to research.irb_submission. Business justification: Accessions for human subjects research must be traceable to the IRB submission authorizing sample collection — a GxP regulatory requirement. accession.irb_protocol_number is a denormalized plain attri' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrbSubmission .

ind:patientId rdf:type rdf:Property ;
    rdfs:label 'Patient Id' ;
    rdfs:comment 'Reference to the de-identified or pseudonymized patient/subject record associated with this specimen. Classified as restricted PHI under HIPAA. Used for clinical traceability while maintaining PHI separation per de-identification protocols.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patient .

ind:accessionNumber rdf:type rdf:Property ;
    rdfs:label 'Accession Number' ;
    rdfs:comment 'LIMS-generated, externally-visible unique identifier assigned to the specimen at the point of intake into LabVantage. Serves as the primary chain-of-custody reference number communicated to ordering clinicians, research teams, and downstream bioinformatics pipelines. Format: ACC-{YYYY}-{8-digit sequence}.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionStatus rdf:type rdf:Property ;
    rdfs:label 'Accession Status' ;
    rdfs:comment 'Current workflow lifecycle state of the accession record within LabVantage. Drives downstream routing: \'received\' = physically in lab but not yet reviewed; \'in_review\' = condition assessment underway; \'accepted\' = cleared for processing; \'rejected\' = specimen rejected and not processed; \'on_hold\' = pending additional information or consent; \'cancelled\' = order cancelled prior to processing.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessioningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accessioning Timestamp' ;
    rdfs:comment 'Date and time the specimen was formally registered and accessioned into the LIMS by the receiving technician. May differ from receipt_timestamp if there is a delay between physical receipt and system registration. Used for TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalCondition rdf:type rdf:Property ;
    rdfs:label 'Arrival Condition' ;
    rdfs:comment 'Assessment of the physical condition of the specimen upon arrival at the laboratory. \'acceptable\' = meets pre-analytical quality criteria; \'compromised\' = degraded but may still be processable with notation; \'rejected\' = fails minimum quality criteria and cannot be processed. Triggers rejection workflows and recollection requests when set to \'rejected\'.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSite rdf:type rdf:Property ;
    rdfs:label 'Collection Site' ;
    rdfs:comment 'Name or identifier of the clinical facility, hospital, clinic, or research site where the specimen was collected from the patient. Supports multi-site clinical trial tracking, referring provider analytics, and logistics routing.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTime rdf:type rdf:Property ;
    rdfs:label 'Collection Time' ;
    rdfs:comment 'Precise date and time the specimen was collected from the patient or subject, including timezone. Used for time-sensitive pre-analytical stability calculations (e.g., RNA degradation, cell viability) and clinical result contextualization.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'Name of the phlebotomist, nurse, or clinician who collected the specimen from the patient. Required for chain-of-custody documentation and pre-analytical error investigation. Classified as confidential business data.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNotes rdf:type rdf:Property ;
    rdfs:label 'Condition Notes' ;
    rdfs:comment 'Free-text description of observed pre-analytical issues or anomalies noted at specimen receipt (e.g., hemolysis, lipemia, insufficient volume, broken container, temperature excursion, clotted sample). Supports root cause analysis and pre-analytical QC reporting.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courierName rdf:type rdf:Property ;
    rdfs:label 'Courier Name' ;
    rdfs:comment 'Name of the courier or logistics provider that transported the specimen to the laboratory (e.g., FedEx, World Courier, BioMatik, internal courier). Used for vendor performance tracking and temperature excursion investigations.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRequisitionNumber rdf:type rdf:Property ;
    rdfs:label 'External Requisition Number' ;
    rdfs:comment 'Test requisition number assigned by the ordering facility\'s own system (e.g., hospital LIS, EHR order number). Enables bidirectional reconciliation between the external ordering system and the internal LIMS accession record.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Applicable Flag' ;
    rdfs:comment 'Indicates whether this accession falls under GxP (Good Practice Regulations) requirements including GMP, GLP, or GCP. True = GxP controls apply, requiring full audit trail, electronic signature compliance per 21 CFR Part 11, and enhanced documentation in MasterControl.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiDeidentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentified Flag' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) associated with this accession has been de-identified per HIPAA Safe Harbor or Expert Determination methods. True = PHI has been de-identified and the record may be used in downstream analytics without PHI restrictions; False = PHI is present and full access controls apply.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time the specimen was physically received at the laboratory, marking the transition from external courier custody to laboratory custody. This is the principal business event timestamp for the accession transaction. Recorded in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recollectionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Recollection Requested Flag' ;
    rdfs:comment 'Indicates whether a recollection request has been issued to the ordering provider or collection site due to specimen rejection or insufficient quality. True = recollection has been requested; False = no recollection required.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this accession is associated with a regulatory submission (e.g., FDA IND/NDA clinical trial specimen, CE-IVD validation study, EMA submission). True = specimen is part of a regulated submission context requiring enhanced documentation and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason a specimen was rejected at accessioning. Populated only when arrival_condition = \'rejected\'. Used for pre-analytical QC trending, rejection rate KPI reporting, and recollection request generation. [ENUM-REF-CANDIDATE: insufficient_volume|hemolysis|lipemia|clotted|wrong_tube|unlabeled|temperature_excursion|expired_container|broken_container|mislabeled — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier from the LabVantage LIMS source system for this accession. Used for data lineage traceability between the Databricks Silver Layer and the operational system of record, supporting reconciliation and re-ingestion workflows.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatTargetHours rdf:type rdf:Property ;
    rdfs:label 'Tat Target Hours' ;
    rdfs:comment 'Target Turnaround Time (TAT) in hours from specimen receipt to result delivery, as defined by the SLA (Service Level Agreement) for the assigned priority level and assay type. Used for TAT compliance monitoring and SLA breach alerting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt C' ;
    rdfs:comment 'Measured temperature of the specimen or shipping container at the time of receipt, expressed in degrees Celsius. Used to assess cold-chain compliance and flag potential temperature excursions that may affect specimen integrity and downstream assay validity.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportTemperatureCode rdf:type rdf:Property ;
    rdfs:label 'Transport Temperature Code' ;
    rdfs:comment 'Required transport temperature condition under which the specimen was shipped to the laboratory. Used to verify compliance with specimen stability requirements and to flag potential temperature excursions during transit.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tubeLabelCode rdf:type rdf:Property ;
    rdfs:label 'Tube Label Code' ;
    rdfs:comment 'Barcode or label identifier physically affixed to the specimen container at the time of collection or receipt. Used for physical specimen tracking, label verification at accessioning, and reconciliation against the LIMS accession number.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeReceivedMl rdf:type rdf:Property ;
    rdfs:label 'Volume Received Ml' ;
    rdfs:comment 'Measured volume of the specimen received at the laboratory, expressed in millilitres. Used to assess adequacy for requested assays, trigger insufficient volume rejection flags, and support aliquoting planning. Represents the principal quantitative measurement of the accession transaction.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Biobank Location Id' ;
    rdfs:comment 'Unique surrogate identifier for a physical storage location within the biorepository hierarchy. Primary key for this master resource entity.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:parentLocationBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Biobank Location Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent location in the biorepository hierarchy (e.g., a box\'s parent is a rack, a rack\'s parent is a shelf). Enables recursive hierarchy traversal for chain-of-custody and retrieval workflows.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.manufacturing_site. Business justification: Biobank locations are physically within manufacturing sites in genomics biotech (e.g., -80C freezers in GMP facilities). Linking biobank_location to manufacturing_site enables site-level inventory man' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Physical and logical access control classification for this storage location. Governs who may retrieve specimens from this location. \'restricted\' and above require role-based authorization in LabVantage LIMS and physical access badge control. Relevant for PHI-linked specimens and BSL-classified materials.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerProtected rdf:type rdf:Property ;
    rdfs:label 'Backup Power Protected' ;
    rdfs:comment 'Indicates whether this storage unit is connected to an uninterruptible power supply (UPS) or emergency generator backup. Critical for specimen integrity risk assessment and business continuity planning for irreplaceable biobank specimens.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which this storage location was formally commissioned and made available for specimen storage following successful IQ/OQ/PQ qualification. Marks the start of the location\'s operational lifecycle.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date on which this storage location was permanently decommissioned and removed from active service. Null for locations still in service. Required for equipment lifecycle tracking and regulatory audit trails.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentManufacturer rdf:type rdf:Property ;
    rdfs:label 'Equipment Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the physical storage equipment (e.g., \'Thermo Fisher Scientific\', \'Panasonic\', \'Chart Industries\'). Required for vendor qualification records and regulatory equipment documentation.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Manufacturer model designation of the physical storage equipment at this location (e.g., \'Thermo Scientific TSX Series -80°C Freezer\'). Used for equipment qualification documentation, spare parts management, and maintenance scheduling.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number of the physical storage equipment. Required for equipment qualification (IQ/OQ/PQ) documentation, warranty tracking, and regulatory audit trails per ISO 13485 and GxP requirements.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCryogenic rdf:type rdf:Property ;
    rdfs:label 'Is Cryogenic' ;
    rdfs:comment 'Indicates whether this storage location uses cryogenic conditions (liquid nitrogen vapor or immersion, or mechanical ultra-low temperature ≤ -130°C). Drives safety protocol assignment, PPE requirements, and cryogenic handling SOP routing.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpControlled rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Controlled' ;
    rdfs:comment 'Indicates whether this storage location is subject to GMP regulations (e.g., for clinical trial specimens, IVD reagent intermediates, or GMP-grade biological materials). GMP-controlled locations require enhanced documentation, change control, and audit trail requirements.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhiSegregated rdf:type rdf:Property ;
    rdfs:label 'Is Phi Segregated' ;
    rdfs:comment 'Indicates whether specimens stored at this location are physically segregated due to PHI linkage, requiring enhanced access controls and HIPAA-compliant chain-of-custody documentation. Supports de-identification workflow management.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent temperature calibration or verification performed on this storage unit. Required for GxP compliance and ISO 15189 accreditation. Tracked in MasterControl and SAP QM.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Lims Location Code' ;
    rdfs:comment 'Native location identifier assigned by LabVantage LIMS for this storage position. Used for system-of-record cross-referencing, data lineage tracing, and integration reconciliation between the Silver Layer and the operational LIMS.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this storage location within the biorepository management system (LabVantage LIMS). Used for labeling, chain-of-custody documentation, and specimen retrieval workflows. Example: FRZ-A01-SH3-RK2-BX05.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Descriptive human-readable name for the storage location, used in operational reports and LIMS displays. Example: \'Freezer A1 – Shelf 3 – Rack 2 – Box 05\'.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSensorCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Sensor Code' ;
    rdfs:comment 'Identifier of the continuous temperature/humidity monitoring sensor assigned to this storage location. Links to the environmental monitoring system (EMS) for real-time excursion alerting and 21 CFR Part 11-compliant audit trails.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next temperature calibration or verification of this storage unit. Drives preventive maintenance work orders in SAP S/4HANA PM and compliance alerts in MasterControl.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occupiedPositions rdf:type rdf:Property ;
    rdfs:label 'Occupied Positions' ;
    rdfs:comment 'Current number of specimen positions occupied at this storage location as tracked by LabVantage LIMS. Enables real-time utilization monitoring and triggers capacity alerts when approaching full occupancy.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of this biobank storage location. \'active\' = available for specimen storage; \'maintenance\' = temporarily unavailable due to servicing; \'quarantine\' = specimens held pending investigation; \'decommissioned\' = permanently retired from service.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionColumn rdf:type rdf:Property ;
    rdfs:label 'Position Column' ;
    rdfs:comment 'Numeric column designator for a specific well or slot position within a box or rack (e.g., \'1\', \'12\'). Applicable at the position/well hierarchy level. Combined with position_row to form the full position address.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionRow rdf:type rdf:Property ;
    rdfs:label 'Position Row' ;
    rdfs:comment 'Alphanumeric row designator for a specific well or slot position within a box or rack (e.g., \'A\', \'B\', \'H\'). Applicable at the position/well hierarchy level. Combined with position_column to form the full position address.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date on which the current GxP equipment qualification (IQ/OQ/PQ) expires and requalification is required. Drives preventive maintenance scheduling and regulatory compliance alerts in MasterControl.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'GxP qualification status of the storage equipment: \'qualified\' = Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ) completed and approved; \'requalification_required\' = qualification expired or triggered by maintenance event. Mandatory for GMP/GLP-regulated specimen storage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCustodian rdf:type rdf:Property ;
    rdfs:label 'Responsible Custodian' ;
    rdfs:comment 'Name or employee identifier of the designated biorepository custodian or laboratory manager responsible for this storage location. Accountable for specimen integrity, access authorization, and regulatory compliance at this location.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier assigned to this storage unit for automated inventory scanning and real-time location tracking within the biorepository. Supports high-throughput specimen management workflows.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomIdentifier rdf:type rdf:Property ;
    rdfs:label 'Room Identifier' ;
    rdfs:comment 'Identifier of the laboratory or storage room within the facility where this location physically resides. Used for access control, environmental monitoring zone assignment, and GxP area classification.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenTypeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Specimen Type Compatibility' ;
    rdfs:comment 'Comma-delimited list of specimen types approved for storage at this location (e.g., \'whole_blood,plasma,FFPE,DNA,RNA,cell_line\'). Enforced during specimen accessioning in LabVantage LIMS to prevent storage condition mismatches. [ENUM-REF-CANDIDATE: whole_blood|plasma|serum|FFPE|DNA|RNA|cell_line|tissue|urine|saliva — promote to reference product]' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageMedium rdf:type rdf:Property ;
    rdfs:label 'Storage Medium' ;
    rdfs:comment 'Physical medium used for cryogenic or ambient storage at this location. Distinguishes mechanical freezer cooling from liquid nitrogen (LN2) vapor-phase or immersion-phase storage, which affects specimen viability protocols and safety requirements.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUnitType rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Type' ;
    rdfs:comment 'Classification of the physical storage unit at this location level (e.g., freezer, refrigerator, liquid nitrogen tank, ambient cabinet). Drives temperature monitoring SOP assignment and equipment maintenance scheduling.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Upper acceptable temperature limit in degrees Celsius for this storage location. Excursions above this threshold trigger alarms and non-conformance events per SOP.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Lower acceptable temperature limit in degrees Celsius for this storage location. Excursions below this threshold trigger alarms and non-conformance events per SOP.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Nominal target storage temperature in degrees Celsius for this location (e.g., -80.00 for ultra-low freezer, -196.00 for liquid nitrogen, 4.00 for refrigerator, 22.00 for room temperature). Critical for specimen integrity and regulatory compliance.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityPositions rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Positions' ;
    rdfs:comment 'Maximum number of specimen positions (wells, slots, or tubes) this storage location can physically accommodate. Used for capacity planning, utilization reporting, and biorepository space management.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageEventId rdf:type rdf:Property ;
    rdfs:label 'Storage Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each storage state change or custody transfer event record in the chain-of-custody audit trail. Primary key of the storage_event product.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cryoprotectantLotId rdf:type rdf:Property ;
    rdfs:label 'Cryoprotectant Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: GMP biobanking traceability: cryopreservation storage events consume specific reagent lots (e.g., DMSO, glycerol). Regulatory and GMP chain-of-custody requirements mandate recording which cryoprotecta' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:destinationLocationBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Biobank Location Id' ;
    rdfs:comment 'Reference to the storage location (freezer, rack, shelf, box, or position) to which the specimen or aliquot was moved or placed. Null for disposal or external transfer events where no internal destination exists.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:primaryStorageBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Biobank Location Id' ;
    rdfs:comment 'Reference to the storage location (freezer, rack, shelf, box, or position) from which the specimen or aliquot was retrieved or transferred. Null for initial placement events where no prior location exists.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time at which the electronic acknowledgment or e-signature was applied to this storage event record. Distinct from the event_timestamp (when the physical action occurred). Required for FDA 21 CFR Part 11 audit trail completeness.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodySequence rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Sequence' ;
    rdfs:comment 'Monotonically increasing integer representing the ordinal position of this storage event within the complete chain-of-custody history for the specimen or aliquot. Enables ordered reconstruction of the full custody timeline for forensic genomics, legal, and regulatory audit purposes.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether this storage event involved a deviation from the applicable SOP or standard storage protocol. True triggers a deviation investigation workflow in the quality management system (Veeva Vault or MasterControl) and requires documented justification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the storage event has received a valid electronic acknowledgment (e-signature) from the responsible operator or custodian in compliance with FDA 21 CFR Part 11 electronic records requirements. True confirms the event is electronically signed and locked.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this storage event, formatted as SE-{YYYY}-{YYYYMMDD}-{sequence}. Used in audit reports, chain-of-custody documentation, and regulatory submissions to uniquely reference a specific custody transfer or placement event.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSiteName rdf:type rdf:Property ;
    rdfs:label 'External Site Name' ;
    rdfs:comment 'Name of the external facility, partner laboratory, or clinical site to which the specimen or aliquot was transferred during an inter-site or external transfer event. Populated only for event_type = external_transfer. Supports chain-of-custody documentation for multi-site genomics studies.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTransferTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'External Transfer Tracking Number' ;
    rdfs:comment 'Shipping or courier tracking number associated with an external specimen transfer event. Enables end-to-end shipment traceability for specimens transferred to external sites, partner labs, or clinical collaborators. Populated only for event_type = external_transfer.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCycleCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Cycle Count' ;
    rdfs:comment 'Cumulative number of freeze-thaw cycles the specimen or aliquot has undergone up to and including this storage event. Excessive freeze-thaw cycles degrade nucleic acid and protein integrity; this count is critical for sample quality assessment in genomic and clinical workflows.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isImmutable rdf:type rdf:Property ;
    rdfs:label 'Is Immutable' ;
    rdfs:comment 'Indicates whether this storage event record has been locked and made immutable following electronic acknowledgment and audit finalization. Immutable records cannot be modified or deleted, satisfying FDA 21 CFR Part 11 and GxP requirements for tamper-evident audit trails.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsEventReference rdf:type rdf:Property ;
    rdfs:label 'Lims Event Reference' ;
    rdfs:comment 'The native event or transaction identifier assigned by LabVantage LIMS for this storage event. Enables bidirectional traceability between the Databricks Silver Layer data product and the operational LIMS system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the specimen or aliquot was placed into or removed from quarantine status as part of this storage event. Quarantined samples are restricted from use in assays or downstream workflows pending investigation or quality review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Standardized reason for placing the specimen or aliquot into quarantine. Populated only when quarantine_flag is True. Drives investigation workflows and determines the path to quarantine release or disposal.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized reason code explaining the business justification for the storage event. Used for operational reporting, compliance audits, and workflow analytics. [ENUM-REF-CANDIDATE: routine_storage|retrieval_for_assay|transfer_to_external_site|quarantine|inter_section_transfer|disposal_scheduled|emergency_retrieval — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or justification for the storage event beyond the standardized reason code. Captures operator notes, special circumstances, or deviations from standard operating procedures (SOPs) that require documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Max C' ;
    rdfs:comment 'The maximum acceptable storage temperature in degrees Celsius for the specimen or aliquot type involved in this event, as defined by the applicable SOP or specimen handling protocol. Used in conjunction with required_temp_min_c to define the acceptable temperature window.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTempMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Min C' ;
    rdfs:comment 'The minimum acceptable storage temperature in degrees Celsius for the specimen or aliquot type involved in this event, as defined by the applicable SOP or specimen handling protocol. Used to evaluate whether a temperature excursion occurred.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specimenVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Specimen Volume Ul' ;
    rdfs:comment 'Volume of the specimen or aliquot in microliters (µL) at the time of this storage event. Captured to track volume consumption across retrieval events and to flag low-volume specimens that may be insufficient for planned assays.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Standardized code representing the required storage condition category for the specimen or aliquot at the destination location. Drives storage unit assignment logic and temperature monitoring alert thresholds in the LIMS and facility management systems.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtEventC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Event C' ;
    rdfs:comment 'Recorded ambient or storage unit temperature in degrees Celsius at the time of the storage event. Captured from connected monitoring systems or manually entered by the operator. Used to assess sample integrity and document temperature excursion conditions.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion (deviation from the required storage temperature range) was detected or reported in association with this storage event. True signals a potential sample integrity risk requiring investigation and documentation per GxP and CLIA requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assentObtained rdf:type rdf:Property ;
    rdfs:label 'Assent Obtained' ;
    rdfs:comment 'Indicates whether assent was obtained from a minor subject in addition to parental/guardian consent. Applicable for pediatric genomics studies. Required for IRB compliance in pediatric research protocols.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biobankConsent rdf:type rdf:Property ;
    rdfs:label 'Biobank Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to long-term biobanking and storage of their specimen for future unspecified research use. Governs specimen retention policies in LabVantage LIMS.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Method' ;
    rdfs:comment 'Method by which informed consent was obtained and documented. \'paper\' — wet ink signature; \'electronic\' — eConsent platform; \'verbal_with_waiver\' — IRB-approved verbal consent with waiver of written documentation; \'remote_electronic\' — remote eConsent; \'delegated\' — consent delegated to authorized representative.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCollectionSite rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Site' ;
    rdfs:comment 'Name or code of the clinical or research site where informed consent was obtained (e.g., hospital, clinic, research center). Supports multi-site study management and site-level compliance reporting.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The calendar date on which the research subject or patient provided signed informed consent. This is the principal business event date for the consent agreement and is required for regulatory compliance timelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the consent authorization expires and must be renewed or re-consented. Null for open-ended broad consents. Used to trigger re-consent workflows and enforce data use restrictions.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the IRB-approved informed consent form presented to and signed by the subject (e.g., v1.0, v2.1). Critical for regulatory audit trails to confirm the subject received the current approved version.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNotes rdf:type rdf:Property ;
    rdfs:label 'Consent Notes' ;
    rdfs:comment 'Free-text field for documenting special circumstances, subject questions, deviations from standard consent process, or other relevant observations recorded during the consent encounter. Confidential — not for general access.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the consent model applied. \'broad\' permits use across multiple future research purposes; \'specific\' restricts use to a defined study; \'tiered\' allows subject to select permitted uses; \'re_consent\' indicates updated consent obtained for changed scope; \'emergency_waiver\' denotes IRB-approved waiver; \'assent\' applies to minors. [ENUM-REF-CANDIDATE: broad|specific|tiered|re_consent|emergency_waiver|assent — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationStatus rdf:type rdf:Property ;
    rdfs:label 'Deidentification Status' ;
    rdfs:comment 'Current PHI de-identification status of the specimen and associated data. \'identified\' — PHI present; \'de_identified\' — HIPAA Safe Harbor or Expert Determination method applied; \'limited_dataset\' — HIPAA limited dataset with DUA; \'pseudonymized\' — GDPR pseudonymization applied; \'anonymized\' — irreversibly anonymized.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futureContactConsent rdf:type rdf:Property ;
    rdfs:label 'Future Contact Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to being contacted for future research studies or re-consent requests. Governs subject outreach activities in Salesforce CRM.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR Article 6/9 lawful basis under which personal and special-category genomic data is processed for subjects in EU/EEA jurisdictions. \'not_applicable\' for non-EU subjects. Required for GDPR compliance documentation.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentalFindingsConsent rdf:type rdf:Property ;
    rdfs:label 'Incidental Findings Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to disclosure of incidental or secondary genomic findings identified during sequencing or analysis (e.g., ACMG secondary findings). Distinct from primary study results.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterUsed rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used' ;
    rdfs:comment 'Indicates whether a language interpreter was used during the consent process. When true, additional interpreter documentation is required per GCP guidelines.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Protocol Number' ;
    rdfs:comment 'The unique protocol number assigned by the Institutional Review Board (IRB) governing the study or research program under which this consent was obtained. Required for regulatory traceability and audit.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code of the consent form presented to the subject (e.g., \'en\', \'es\', \'fr\', \'zh-CN\'). Ensures the subject received consent documentation in their primary language as required by FDA and ICH guidelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legallyAuthorizedRepresentative rdf:type rdf:Property ;
    rdfs:label 'Legally Authorized Representative' ;
    rdfs:comment 'Indicates whether consent was obtained from a Legally Authorized Representative (LAR) rather than the subject directly (e.g., for incapacitated adults or minors). Triggers additional documentation requirements.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsConsentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Lims Consent Record Code' ;
    rdfs:comment 'The native consent record identifier assigned by LabVantage LIMS. Enables bidirectional traceability between the Databricks Silver Layer data product and the operational LIMS system of record.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedUseClinical rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Clinical' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen for clinical diagnostic purposes, including In Vitro Diagnostic (IVD) assay validation and Laboratory Developed Test (LDT) workflows under CLIA/CAP.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseCommercial rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Commercial' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen and genomic data for commercial product development, including reagent validation, instrument development, and product commercialization activities.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseDataSharing rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Data Sharing' ;
    rdfs:comment 'Indicates whether the subject has authorized sharing of their de-identified genomic data with external parties, including public genomic databases (e.g., dbGaP, GEO), research consortia, or partner institutions under the NIH Genomic Data Sharing Policy.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseResearch rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Research' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen and associated genomic data for internal Research and Development (R&D) purposes. Governs bioinformatics pipeline processing and variant analysis workflows.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiAuthorization rdf:type rdf:Property ;
    rdfs:label 'Phi Authorization' ;
    rdfs:comment 'Indicates whether the subject has provided explicit HIPAA authorization for use and disclosure of their Protected Health Information (PHI) in conjunction with specimen and genomic data processing.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Consent Due Date' ;
    rdfs:comment 'Target date by which re-consent must be obtained from the subject. Null if re-consent is not required. Used to manage compliance timelines and subject outreach scheduling.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required' ;
    rdfs:comment 'Indicates whether a re-consent is required from the subject due to protocol amendments, expanded data use scope, or consent expiry. Triggers re-consent workflow in LabVantage LIMS and MasterControl.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary regulatory jurisdiction applicable to this consent record, using ISO 3166-1 alpha-3 country codes. Determines which regulatory framework (FDA, EMA, IVDR, etc.) governs consent requirements and data handling obligations. [ENUM-REF-CANDIDATE: USA|EU|GBR|CAN|AUS|JPN|CHN|IND|BRA|OTHER — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOfResultsConsent rdf:type rdf:Property ;
    rdfs:label 'Return Of Results Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to receive individual genomic research results or incidental findings. Governs clinical reporting workflows and genetic counseling referral processes.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Name of the sponsoring organization or institution for the study under which consent was obtained. May be Genomics Biotech itself or an external sponsor for collaborative studies.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Code' ;
    rdfs:comment 'The document identifier in Veeva Vault for the executed consent form document. Provides a direct link to the regulatory document management system for audit and inspection readiness.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'The date on which the subject formally withdrew consent. Null if consent has not been withdrawn. When populated, triggers downstream data quarantine and use-restriction enforcement per GDPR right-to-erasure and HIPAA requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Categorized reason for consent withdrawal. Required for regulatory reporting and adverse event tracking. Null if consent has not been withdrawn. [ENUM-REF-CANDIDATE: subject_request|adverse_event|protocol_deviation|lost_to_followup|deceased|administrative|other — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageAtEnrollment rdf:type rdf:Property ;
    rdfs:label 'Age At Enrollment' ;
    rdfs:comment 'Age of the subject in whole years at the time of study enrollment, derived from year_of_birth and enrollment_date at data ingestion. Stored as a pre-computed integer to support cohort age-stratification queries without requiring DOB. Enables pediatric vs. adult cohort segmentation and age-related genomic analyses.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancestryGroup rdf:type rdf:Property ;
    rdfs:label 'Ancestry Group' ;
    rdfs:comment 'Self-reported or genetically inferred ancestry/ethnicity group of the subject, used for population genomics stratification, Minor Allele Frequency (MAF) reference panel selection, and pharmacogenomics analyses. Stored as a controlled vocabulary term aligned with gnomAD and 1000 Genomes Project population labels. [ENUM-REF-CANDIDATE: AFR|AMR|EAS|EUR|MID|SAS|ASH|LAT|OTH — promote to reference product]' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biologicalSex rdf:type rdf:Property ;
    rdfs:label 'Biological Sex' ;
    rdfs:comment 'Biological sex of the subject as recorded at enrollment, distinct from gender identity. Used for sex-stratified genomic analyses, reference genome selection (e.g., chrX/chrY copy number), population genomics cohort stratification, and clinical assay interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCountry rdf:type rdf:Property ;
    rdfs:label 'Collection Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the subject\'s specimens were collected. Drives GDPR data residency requirements, export control compliance for genomic data, and population genomics geographic stratification.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the informed consent document that was in effect and signed by the subject at the time of enrollment into this cohort. Required for IRB compliance and consent audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessTier rdf:type rdf:Property ;
    rdfs:label 'Data Access Tier' ;
    rdfs:comment 'Permissible data access level for genomic data derived from this subject, aligned with NIH Genomic Data Sharing Policy tiers. Open access data is publicly available; registered access requires user registration; controlled access requires dbGaP or equivalent approval; restricted access is limited to named investigators under a data use agreement (DUA).' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationMethod rdf:type rdf:Property ;
    rdfs:label 'Deidentification Method' ;
    rdfs:comment 'The HIPAA-recognized or GDPR-compliant method applied to de-identify or pseudonymize the subject record. HIPAA Safe Harbor removes 18 specified identifiers; Expert Determination uses statistical analysis to certify re-identification risk is very small. Pseudonymization replaces direct identifiers with a code while retaining a linkage key in a separate access-controlled system. Drives data access tier assignment and downstream PHI handling rules.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationTier rdf:type rdf:Property ;
    rdfs:label 'Deidentification Tier' ;
    rdfs:comment 'Classification of the subject record\'s de-identification level per HIPAA and GDPR frameworks. Fully de-identified records have no re-identification pathway; pseudonymized records retain a coded linkage to PHI managed separately; limited dataset records retain certain geographic and date information under a data use agreement (DUA). Governs permissible downstream data uses and sharing.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseIndication rdf:type rdf:Property ;
    rdfs:label 'Disease Indication' ;
    rdfs:comment 'Primary disease indication or phenotype associated with the subject, encoded using a standardized ontology term (e.g., ICD-10, OMIM, HPO). Drives cohort assembly for clinical genomics studies, variant interpretation in clinical assay workflows, and regulatory submission stratification. Free-text or ontology code depending on study protocol.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseIndicationOntology rdf:type rdf:Property ;
    rdfs:label 'Disease Indication Ontology' ;
    rdfs:comment 'Ontology or coding system used to encode the disease_indication field (e.g., ICD-10, OMIM, HPO, SNOMED-CT). Enables interoperability across clinical, research, and regulatory systems and ensures consistent variant interpretation and cohort queries.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyRelationship rdf:type rdf:Property ;
    rdfs:label 'Family Relationship' ;
    rdfs:comment 'Role of this subject within the family pedigree identified by family_id. Used for trio-based variant calling, de novo mutation detection, and inheritance pattern analysis in WGS/WES (Whole Exome Sequencing) workflows. Null for unrelated subjects.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR applies to this subject\'s data, based on the subject\'s collection country and data processing location. When True, GDPR Article 9 special category data protections apply to genetic data, and data subject rights (access, erasure, portability) must be honored. Drives EU data residency and transfer compliance workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genomicDataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Genomic Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the subject has provided explicit consent for their genomic data to be shared with external repositories (e.g., dbGaP, EGA, UK Biobank). Required for NIH Genomic Data Sharing Policy compliance and international data sharing agreements. When False, data must not be submitted to public or controlled-access repositories.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable' ;
    rdfs:comment 'Indicates whether HIPAA Privacy Rule applies to this subject\'s data, based on whether the subject is a US patient or the data is held by a HIPAA-covered entity or business associate. When True, PHI handling, minimum necessary standard, and de-identification requirements apply.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsSubjectCode rdf:type rdf:Property ;
    rdfs:label 'Lims Subject Code' ;
    rdfs:comment 'Native subject identifier assigned by LabVantage LIMS at the time of accessioning. Used for cross-system traceability between the Databricks Silver Layer data product and the operational LIMS workflow. Enables reconciliation and lineage tracking back to the system of record.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiLinkageAvailable rdf:type rdf:Property ;
    rdfs:label 'Phi Linkage Available' ;
    rdfs:comment 'Indicates whether a PHI linkage record exists for this subject in the access-controlled consent and identity management system. When True, the subject_code can be re-linked to direct PHI by authorized personnel only. When False, the record is fully de-identified with no re-linkage pathway. Supports HIPAA Safe Harbor compliance auditing.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAssayType rdf:type rdf:Property ;
    rdfs:label 'Primary Assay Type' ;
    rdfs:comment 'The primary genomic assay type intended or performed for this subject\'s specimens. Drives bioinformatics pipeline selection, QC (Quality Control) metric thresholds, and data product routing. WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), targeted panel, SNP (Single Nucleotide Polymorphism) array, RNA-seq, and methylation array are the principal assay categories. [ENUM-REF-CANDIDATE: WGS|WES|targeted_panel|SNP_array|RNA_seq|methylation_array|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recontactConsent rdf:type rdf:Property ;
    rdfs:label 'Recontact Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to being re-contacted for additional studies, incidental findings disclosure, or updated consent. Relevant for longitudinal genomics studies and return-of-results workflows. When False, no re-contact is permitted without a new consent process.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Monotonically incrementing version number for the subject record, incremented on each update. Supports optimistic concurrency control, SCD Type 2 history tracking, and GxP audit trail requirements for regulated genomics data. Version 1 represents the initial record creation.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species of the subject. Determines applicable reference genome, annotation pipeline, and regulatory classification (human vs. animal model). Critical for bioinformatics pipeline routing and IRB/IACUC compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCode rdf:type rdf:Property ;
    rdfs:label 'Subject Code' ;
    rdfs:comment 'Externally-known, de-identified alphanumeric code assigned to the subject at accessioning or enrollment. Used as the operational identifier across LIMS, bioinformatics pipelines, and clinical reports without exposing direct PHI. Equivalent to the participant ID or pseudonym in study documentation.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDate rdf:type rdf:Property ;
    rdfs:label 'Subject Date' ;
    rdfs:comment 'The calendar date on which the subject was formally enrolled into the cohort. Required for IRB compliance and cohort timeline reporting.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectStatus rdf:type rdf:Property ;
    rdfs:label 'Subject Status' ;
    rdfs:comment 'Current lifecycle status of the subject\'s enrollment in the cohort. Tracks whether the subject is actively participating, has withdrawn, or is in a pending/suspended state.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the biological source individual by their role in the study or clinical workflow. Drives consent requirements, regulatory handling, and data access controls. Research participants and patients require IRB/ethics board oversight; animal models require IACUC approval.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOfBirth rdf:type rdf:Property ;
    rdfs:label 'Year Of Birth' ;
    rdfs:comment 'Four-digit birth year of the subject. Stored instead of full date of birth (DOB) to comply with HIPAA Safe Harbor de-identification requirements (45 CFR §164.514(b)(2)(i)), which prohibit retention of specific birth dates. Enables age-range calculations and cohort age-stratification for population genomics without re-identification risk.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionKitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Collection events use specific collection kit products (PAXgene, Tempus, saliva kits). Critical for tracking kit performance across collection sites, supplier quality monitoring, and correlating pre-a' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:collectionKitLotId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: GMP/GLP collection kit lot traceability: collection_kit_lot_number is a plain text denormalization. Regulatory requirements (CAP, CLIA, ISO 15189) mandate linking collection events to specific reagent' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Foreign key linking to quality.training_record. Business justification: Training records document that collectors are qualified to perform collections. Labs link training to collection events for regulatory compliance and audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRecord .

ind:anatomicalSite rdf:type rdf:Property ;
    rdfs:label 'Anatomical Site' ;
    rdfs:comment 'Standardized anatomical location from which the specimen was collected (e.g., left antecubital vein, right breast core, nasopharynx). Encoded using SNOMED CT or ICD-10 topography codes where applicable. Critical for oncology and clinical genomics interpretation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Event Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the collection event, assigned by LabVantage LIMS at accessioning. Used for chain-of-custody documentation, deviation reports, and cross-system traceability. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionNotes rdf:type rdf:Property ;
    rdfs:label 'Collection Notes' ;
    rdfs:comment 'Free-text field for additional collector observations, special circumstances, or contextual notes recorded at the time of collection that do not fit into structured fields. Supports clinical interpretation and deviation investigation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSopVersion rdf:type rdf:Property ;
    rdfs:label 'Collection Sop Version' ;
    rdfs:comment 'Version number of the SOP document used at the time of collection (e.g., v1.2, v3.0). Stored alongside the SOP ID to capture the exact approved version in effect, as SOP versions change over time.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Collection Temperature C' ;
    rdfs:comment 'Ambient or transport temperature in degrees Celsius at the time of or immediately following specimen collection. Used to assess cold-chain compliance and pre-analytical stability. Critical for cfDNA liquid biopsy and RNA specimens.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionTubeCount rdf:type rdf:Property ;
    rdfs:label 'Collection Tube Count' ;
    rdfs:comment 'Number of collection tubes or containers used during the collection event. Relevant for blood draw events with multiple tube types (EDTA, SST, Streck cfDNA). Supports aliquot planning and chain-of-custody reconciliation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionUrgency rdf:type rdf:Property ;
    rdfs:label 'Collection Urgency' ;
    rdfs:comment 'Priority classification of the collection event that governs Turnaround Time (TAT) expectations and workflow prioritization in LabVantage LIMS. \'stat\' = immediate priority; \'urgent\' = same-day; \'routine\' = standard TAT.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Collection Volume Ml' ;
    rdfs:comment 'Volume of specimen collected, expressed in millilitres (mL). Used for pre-analytical QC assessment (e.g., short draw detection), yield estimation, and aliquot planning. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category (non-monetary transaction).' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Collection Volume Unit' ;
    rdfs:comment 'Unit of measure for the collection volume field. Typically mL for liquid specimens; mg or g for solid tissue specimens; uL for micro-volume collections.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Collector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the individual who performed the collection (e.g., phlebotomy certification, nursing license). Required for CLIA and CAP compliance documentation and chain-of-custody integrity.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingStatus rdf:type rdf:Property ;
    rdfs:label 'Fasting Status' ;
    rdfs:comment 'Pre-analytical fasting status of the subject at the time of collection. Relevant for metabolomics, lipid panels, and certain genomic assays where fasting state affects analyte stability and downstream data quality interpretation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hemolysisIndex rdf:type rdf:Property ;
    rdfs:label 'Hemolysis Index' ;
    rdfs:comment 'Semi-quantitative assessment of hemolysis in the collected blood specimen, graded on a standardized scale (none, 1+ to 4+). Hemolysis is a key pre-analytical variable that degrades DNA/RNA quality and affects NGS library preparation success rates.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Collection Date' ;
    rdfs:comment 'Planned calendar date for the collection event as defined in the study protocol or clinical order. Compared against collection_date to calculate collection compliance and protocol adherence metrics.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToProcessingMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Processing Minutes' ;
    rdfs:comment 'Elapsed time in minutes between specimen collection timestamp and the start of primary processing (e.g., centrifugation, nucleic acid extraction). A critical pre-analytical variable for NGS data quality; exceeding thresholds may trigger QC flags or deviation records.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportCondition rdf:type rdf:Property ;
    rdfs:label 'Transport Condition' ;
    rdfs:comment 'Required transport temperature condition for the collected specimen from collection site to processing laboratory. Drives cold-chain logistics and is compared against actual temperature readings for pre-analytical QC.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:a260A230Ratio rdf:type rdf:Property ;
    rdfs:label 'A260 A230 Ratio' ;
    rdfs:comment 'Absorbance ratio at 260nm and 230nm wavelengths, indicating contamination by organic compounds or chaotropic salts. Expected range is 2.0-2.2 for pure nucleic acid.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationNgPerUl rdf:type rdf:Property ;
    rdfs:label 'Concentration Ng Per Ul' ;
    rdfs:comment 'Concentration of extracted nucleic acid measured in nanograms per microliter (ng/µL), typically measured by spectrophotometry or fluorometry.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Boolean flag indicating whether contamination was detected during or after extraction (True = contamination detected, False = no contamination).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dv200Percentage rdf:type rdf:Property ;
    rdfs:label 'Dv200 Percentage' ;
    rdfs:comment 'Percentage of RNA fragments greater than 200 nucleotides, used as quality metric for degraded RNA samples (e.g., FFPE). Values >30% are typically acceptable for NGS.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elutionVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Elution Volume Ul' ;
    rdfs:comment 'Final elution volume of the extracted nucleic acid, measured in microliters (µL).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionDate rdf:type rdf:Property ;
    rdfs:label 'Extraction Date' ;
    rdfs:comment 'Date when the nucleic acid extraction was performed, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extractionMethod rdf:type rdf:Property ;
    rdfs:label 'Extraction Method' ;
    rdfs:comment 'The nucleic acid extraction methodology applied to the specimen (e.g., column-based, magnetic bead, phenol-chloroform, manual, automated, salting-out).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Extraction Timestamp' ;
    rdfs:comment 'Precise timestamp when the extraction process was completed, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inputMassMg rdf:type rdf:Property ;
    rdfs:label 'Input Mass Mg' ;
    rdfs:comment 'Mass of input material used for extraction (applicable for solid tissue specimens), measured in milligrams (mg).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Input Volume Ul' ;
    rdfs:comment 'Volume of input material used for extraction, measured in microliters (µL).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this extraction record was last modified in the LIMS system, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalYieldNg rdf:type rdf:Property ;
    rdfs:label 'Total Yield Ng' ;
    rdfs:comment 'Total yield of extracted nucleic acid in nanograms (ng), calculated as concentration multiplied by elution volume.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Qc Measurement Id' ;
    rdfs:comment 'Unique identifier for the quality control measurement record. Primary key for the qc_measurement data product.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Measurement Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: QC measurements (Qubit quantification, Bioanalyzer sizing, qPCR validation) use specific reagent/standard lots. Essential for assessing measurement validity, investigating out-of-specification results' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:originalMeasurementQcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Original Measurement Qc Measurement Id' ;
    rdfs:comment 'Reference to the original QC measurement record if this is a repeat measurement. Enables traceability of repeat testing and comparison of results.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcMeasurement .

ind:qcReagentCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Qc Reagent Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: QC measurements use specific reagent products (Qubit assays, Bioanalyzer chips, TapeStation reagents). Business need: measurement validity verification, reagent lot correlation with QC failures, regul' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:testMethodId rdf:type rdf:Property ;
    rdfs:label 'Test Method Id' ;
    rdfs:comment 'Foreign key linking to quality.test_method. Business justification: Every QC measurement is performed using a specific validated test method (e.g., Qubit fluorometry, Bioanalyzer RIN, PicoGreen). Linking to test_method provides analytical traceability, method version ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestMethod .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the instrument used for this measurement was last calibrated. Ensures measurement accuracy and compliance with quality standards. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:controlSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Control Sample Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement was performed on a control sample (positive control, negative control, or reference standard) rather than a patient or research specimen. True indicates control.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Type of control sample used in the measurement, if applicable. Defines the role of the control in the quality assurance process.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dinScore rdf:type rdf:Property ;
    rdfs:label 'Din Score' ;
    rdfs:comment 'DNA Integrity Number (DIN) score ranging from 1 (highly degraded) to 10 (highly intact). Measured via TapeStation electrophoresis. Assesses genomic DNA fragmentation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentSizeBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Bp' ;
    rdfs:comment 'Average or modal fragment size of nucleic acid measured in base pairs. Determined via electrophoresis (Bioanalyzer, TapeStation, or Fragment Analyzer). Critical for library prep QC.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fragmentSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Distribution' ;
    rdfs:comment 'Textual or encoded representation of the fragment size distribution profile. May include peak positions, distribution shape, or reference to an electropherogram file.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Lims Record Code' ;
    rdfs:comment 'External identifier for this measurement in the source Laboratory Information Management System (LabVantage LIMS). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodFlag rdf:type rdf:Property ;
    rdfs:label 'Lod Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value is below the Limit of Detection (LOD) for the assay. True indicates below LOD. Critical for clinical and research interpretation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Quantitative result of the QC measurement. The numeric value obtained from the instrument or assay. Precision supports high-resolution measurements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the operator regarding the measurement. May include observations about sample quality, instrument behavior, or deviations from SOP (Standard Operating Procedure).' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle status of the QC measurement. Tracks the measurement from initiation through completion or failure.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the QC measurement was performed. Critical for traceability and TAT (Turnaround Time) tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passFailFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value falls within the acceptable reference range. True indicates pass, False indicates fail. Drives pre-analytical QC gating decisions.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceRangeLower rdf:type rdf:Property ;
    rdfs:label 'Reference Range Lower' ;
    rdfs:comment 'Lower bound of the acceptable reference range for this measurement type. Used to determine pass/fail status and quality gating decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Reference Range Upper' ;
    rdfs:comment 'Upper bound of the acceptable reference range for this measurement type. Used to determine pass/fail status and quality gating decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repeatMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Measurement Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement is a repeat or retest of a previous measurement. True indicates repeat. Used for tracking measurement reproducibility and troubleshooting.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Storage temperature or condition of the specimen prior to QC measurement. Impacts nucleic acid stability and quality. Critical for pre-analytical quality assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measurement for the measured value. Standardized units ensure consistent interpretation across laboratories and workflows. [ENUM-REF-CANDIDATE: ng_ul|ng|ug|pg|ng_ml|a260_a280_ratio|rin|din|bp|percent — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accessioned Timestamp' ;
    rdfs:comment 'Date and time when the container was first registered and accessioned into the LabVantage LIMS system. Marks the start of the container lifecycle and chain-of-custody record. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capColor rdf:type rdf:Property ;
    rdfs:label 'Cap Color' ;
    rdfs:comment 'Color of the container cap or closure used for visual specimen type identification per laboratory SOP (e.g., red = serum, purple = EDTA whole blood, yellow = SST). Supports pre-analytical sorting and specimen type verification at accessioning.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current integrity status of the chain-of-custody record for this container. Intact = unbroken custody from collection to current location; Broken = a custody gap or anomaly has been detected; Under Review = custody discrepancy under investigation; Verified = custody independently confirmed.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Current Volume Ul' ;
    rdfs:comment 'Current volume of specimen or reagent held within the container expressed in microliters (µL). Updated by LabVantage LIMS upon each aliquoting, dispensing, or consumption event. Enables remaining volume tracking for sample sufficiency checks.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discardedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discarded Timestamp' ;
    rdfs:comment 'Date and time when the container was formally discarded or destroyed in LabVantage LIMS. Null if the container has not been discarded. Required for chain-of-custody closure, biohazardous waste disposal documentation, and regulatory audit trails.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Identifier assigned by an external system, partner laboratory, or originating institution (e.g., hospital LIMS ID, biobank accession number). Enables cross-system reconciliation and chain-of-custody linkage.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDnaseRnaseFree rdf:type rdf:Property ;
    rdfs:label 'Is Dnase Rnase Free' ;
    rdfs:comment 'Indicates whether the container is certified DNase- and RNase-free (True), ensuring nucleic acid integrity for genomic and transcriptomic applications. Critical for NGS library preparation, RNA sequencing, and qPCR workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLowBind rdf:type rdf:Property ;
    rdfs:label 'Is Low Bind' ;
    rdfs:comment 'Indicates whether the container has a low-binding surface treatment (True) to minimize nucleic acid or protein adsorption to container walls. Important for low-input NGS library preparation and single-cell genomics workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSterile rdf:type rdf:Property ;
    rdfs:label 'Is Sterile' ;
    rdfs:comment 'Indicates whether the container was manufactured and certified as sterile (True) or is non-sterile (False). Determines eligibility for clinical specimen collection, cell culture applications, and GMP manufacturing workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsContainerCode rdf:type rdf:Property ;
    rdfs:label 'Lims Container Code' ;
    rdfs:comment 'Native container identifier assigned by the LabVantage LIMS source system. Preserved for bidirectional reconciliation between the Databricks Silver layer and the operational LIMS. Distinct from the surrogate container_id.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:material rdf:type rdf:Property ;
    rdfs:label 'Material' ;
    rdfs:comment 'Primary material composition of the container (e.g., polypropylene, glass, polystyrene). Determines chemical compatibility with specimen types, sterilization method eligibility, and storage temperature range.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFreezeThawCycles rdf:type rdf:Property ;
    rdfs:label 'Max Freeze Thaw Cycles' ;
    rdfs:comment 'Maximum number of freeze-thaw cycles permitted for the specimen type held in this container before the sample is considered compromised per laboratory SOP. Drives automated QC alerts in LabVantage when freeze_thaw_count is exceeded.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platePosition rdf:type rdf:Property ;
    rdfs:label 'Plate Position' ;
    rdfs:comment 'Alphanumeric well position identifier for containers that are wells within a microplate or array plate (e.g., A01, H12, P24). Null for standalone tubes and vials. Enables plate-map tracking and automated liquid handling coordination.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the container lot was received into laboratory inventory from the manufacturer or supplier. Used for FIFO inventory management, shelf-life calculation, and incoming QC inspection records in SAP MM.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruoFlag rdf:type rdf:Property ;
    rdfs:label 'Ruo Flag' ;
    rdfs:comment 'Indicates whether the container is designated for Research Use Only (RUO) and is not intended for use in clinical diagnostic procedures. True = RUO; False = clinical or IVD use. Required for FDA regulatory compliance labeling and downstream workflow routing.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tubeFormat rdf:type rdf:Property ;
    rdfs:label 'Tube Format' ;
    rdfs:comment 'Standardized format designation of the container (e.g., 1.5 mL Eppendorf, 96-well plate, 384-well plate). Determines compatibility with automated liquid handling instruments, centrifuge rotors, and storage rack configurations. [ENUM-REF-CANDIDATE: 0.2ml|0.5ml|1.5ml|2.0ml|5.0ml|15ml|50ml|96_well|384_well — promote to reference product]' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityUl rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Ul' ;
    rdfs:comment 'Maximum volumetric capacity of the container expressed in microliters (µL). Used for liquid handling automation, aliquot volume validation, and storage planning. Typical values range from 0.2 µL (PCR strip tube) to 50,000 µL (50 mL conical).' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: R&D projects frequently serve specific customer accounts for collaborative research, custom assay development, or evaluation programs. Critical for project planning, resource allocation, IP ownership ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date on which the R&D project was completed or closed. Null if the project is still active. Used for schedule performance analysis and lessons-learned reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual expenditure incurred against the R&D project budget to date, in US Dollars, sourced from SAP CO actual cost postings. Used for budget variance analysis, R&D COGS tracking, and financial reporting.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchlingProjectReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Project Reference' ;
    rdfs:comment 'External identifier linking this R&D project to its corresponding project workspace in Benchling, the electronic lab notebook (ELN) and molecular biology platform. Enables cross-system navigation to experimental protocols, sequences, and notebook entries.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Usd' ;
    rdfs:comment 'Total approved budget allocated to the R&D project in US Dollars, as recorded in SAP CO internal order or WBS element. Represents the authorized spend ceiling for the project lifecycle. Used for R&D spend tracking and EBITDA impact analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Nature of the collaboration model for the R&D project: internal (Genomics Biotech only), academic (university partnership), industry (pharma/biotech partner), government (NIH/DARPA funded), or consortium (multi-party). Drives contract and IP agreement requirements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Required' ;
    rdfs:comment 'Indicates whether this R&D project is subject to the NIH Genomic Data Sharing (GDS) Policy or other mandatory data sharing requirements (e.g., GDPR data sharing agreements, EMA data transparency). When true, a data management and sharing plan must be filed.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'External funding grant number (e.g., NIH R01, SBIR/STTR, EU Horizon grant) associated with this R&D project. Used for grant compliance reporting, indirect cost recovery, and financial audit trails. Null for internally funded projects.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpApplicable rdf:type rdf:Property ;
    rdfs:label 'Gxp Applicable' ;
    rdfs:comment 'Indicates whether Good Practice Regulations (GxP) — including GMP, GLP, or GCP — apply to this R&D project. When true, the project must comply with applicable GxP documentation, validation, and audit trail requirements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipClassification rdf:type rdf:Property ;
    rdfs:label 'Ip Classification' ;
    rdfs:comment 'Classification of the intellectual property (IP) status and ownership model for discoveries and innovations generated by this R&D project. Drives IP protection strategy, licensing decisions, and freedom-to-operate assessments.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of defined project milestones registered for this R&D project in the project management system. Used for portfolio progress tracking and gate review scheduling. Not a calculated metric — represents the registered count at the time of record update.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Achieved Count' ;
    rdfs:comment 'Number of project milestones that have been formally completed and signed off as of the last record update. Used alongside milestone_count for portfolio progress reporting and earned value analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Application Number' ;
    rdfs:comment 'Official patent application number filed with the USPTO or EPO for inventions arising from this R&D project. Null if no patent has been filed. Used for IP portfolio tracking and freedom-to-operate analysis.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current stage in the R&D project lifecycle from ideation through commercialization. Used for portfolio gate reviews, resource allocation, and regulatory readiness tracking. [ENUM-REF-CANDIDATE: ideation|preclinical|pilot|scale-up|clinical|commercialization|sunset — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiInvolved rdf:type rdf:Property ;
    rdfs:label 'Phi Involved' ;
    rdfs:comment 'Indicates whether this R&D project involves the use, processing, or storage of Protected Health Information (PHI) as defined under HIPAA. When true, the project must comply with HIPAA Privacy and Security Rules and applicable data use agreements.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Originally planned completion date for the R&D project as established at project initiation or last approved baseline. Used for schedule variance analysis and portfolio planning.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The principal quantitative or qualitative Key Performance Indicator (KPI) used to determine project success (e.g., LOD ≤ 1% VAF, sensitivity ≥ 99%, on-target editing efficiency ≥ 80%). Defined at project initiation and used for go/no-go gate decisions.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the R&D project, used across Benchling ELN, SAP CO cost objects, and internal communications (e.g., CRISPR-20240001, ASSAY-20230042). Serves as the cross-system reference key.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Free-text narrative description of the R&D project objectives, scientific rationale, and expected outcomes. Provides context for portfolio reviews, regulatory submissions, and cross-functional stakeholder communication.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the R&D project record: active (in progress), on_hold (paused), completed (objectives met), cancelled (terminated), or pending_approval (awaiting gate sign-off). Drives portfolio dashboards and resource planning.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the R&D project by its scientific and business purpose: discovery (early-stage hypothesis), development (product/tool build), validation (clinical or analytical validation), feasibility (proof-of-concept), or translational (bench-to-clinic). Drives workflow routing and milestone templates.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationCount rdf:type rdf:Property ;
    rdfs:label 'Publication Count' ;
    rdfs:comment 'Number of peer-reviewed scientific publications, conference abstracts, or preprints that have been generated from this R&D project. Used for scientific impact tracking, IP disclosure management, and NIH reporting compliance.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'Planned regulatory submission pathway for the project output: 510(k) premarket notification, PMA (Premarket Approval), De Novo classification, CE-IVD (EU conformity), Emergency Use Authorization (EUA), or none for non-regulated outputs. Determines submission strategy and timeline.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this R&D project is expected to result in a regulatory submission to the FDA, EMA, or other governing body (e.g., 510(k), PMA, CE-IVD technical file). Drives regulatory affairs resource planning and submission timeline tracking.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Work Breakdown Structure (WBS) element code that maps this R&D project to the SAP S/4HANA project system for cost collection, budget control, and financial reporting. Enables drill-through from analytics to source ERP records.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Name of the internal business unit or division that is the primary sponsor and budget owner for the R&D project (e.g., Clinical Genomics, Sequencing R&D, Agricultural Genomics, Instrument Engineering). Maps to SAP CO cost center hierarchy.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Planned or actual start date of the R&D project, formatted as yyyy-MM-dd. Used for timeline planning, milestone scheduling, and portfolio Gantt reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Business-assigned strategic priority level of the R&D project relative to the corporate portfolio. Drives resource allocation decisions, executive review cadence, and budget protection during planning cycles.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIndication rdf:type rdf:Property ;
    rdfs:label 'Target Indication' ;
    rdfs:comment 'The clinical indication, disease area, or application domain that the project is designed to address (e.g., oncology, rare disease, agricultural genomics, infectious disease diagnostics, pharmacogenomics). Informs market segmentation and regulatory pathway selection.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductProfile rdf:type rdf:Property ;
    rdfs:label 'Target Product Profile' ;
    rdfs:comment 'Free-text or structured description of the Target Product Profile (TPP) defining the desired performance characteristics, intended use, and clinical/analytical claims for the product or technology being developed. Guides experimental design and success criteria.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Primary genomics technology domain addressed by the project: Next-Generation Sequencing (NGS), array-based genotyping, CRISPR gene-editing, PCR/qPCR, bioinformatics pipeline, reagent/consumable, instrument engineering, or other. Aligns with Genomics Biotech core business processes. [ENUM-REF-CANDIDATE: NGS|array|CRISPR|PCR|bioinformatics|reagent|instrument|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full descriptive title of the R&D project as registered in the Benchling electronic lab notebook (ELN) and SAP project system. Used in reporting, publications, and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trl rdf:type rdf:Property ;
    rdfs:label 'Trl' ;
    rdfs:comment 'Technology Readiness Level (TRL) score on the 1–9 scale indicating the maturity of the technology being developed. TRL 1 = basic principles observed; TRL 9 = proven in operational environment. Used for portfolio prioritization and commercialization readiness assessment.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Reference' ;
    rdfs:comment 'Reference identifier linking this R&D project to its primary regulatory or quality document package in Veeva Vault (e.g., design history file, validation protocol, regulatory submission dossier). Enables cross-system navigation to controlled documents.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Primary key for milestone' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Milestone .

ind:veevaDocumentId rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Id' ;
    rdfs:comment 'Document control number from Veeva Vault associated with the formal milestone deliverable or regulatory submission package. Enables cross-system traceability between the milestone record and the controlled document management system.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the milestone was formally completed and outcome recorded. Null if the milestone has not yet been completed. Used to calculate schedule variance (actual vs. planned) for R&D performance reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advancementCriteria rdf:type rdf:Property ;
    rdfs:label 'Advancement Criteria' ;
    rdfs:comment 'Predefined criteria that must be met to advance to the next TRL level or stage gate. Captures the forward-looking requirements established at the time of assessment (e.g., \'Demonstrate analytical sensitivity in clinical matrix to advance from TRL 4 to TRL 5\'). Applicable primarily to trl_assessment and decision_gate milestone types.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assessment Rationale' ;
    rdfs:comment 'Narrative explanation of the outcome determination, including scientific justification, data interpretation, and any deviations from the original success criteria. Required for TRL assessments and go/no-go decision gates. Stored as free text aligned with Benchling ELN entries.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Planned budget (in spend_currency_code) allocated to achieve this milestone as defined in the R&D project financial plan. Used for budget vs. actual variance analysis and R&D portfolio financial management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional context, exceptions, risk notes, or stakeholder communications related to the milestone. Captures information not covered by structured fields, such as interim findings, resource constraints, or scientific observations noted during review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative justification for the go/no-go decision recorded at a decision_gate milestone. Documents the scientific, commercial, and regulatory factors considered by the review board. Required for GxP-compliant stage-gate documentation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceArtifactReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Artifact Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the supporting evidence artifacts stored in Benchling ELN, Veeva Vault, or MasterControl (e.g., experiment IDs, document control numbers, study report references). Enables traceability from milestone outcome to underlying scientific data.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Formal decision recorded at a decision_gate milestone: go (proceed to next phase), no_go (terminate or pivot program), conditional_go (proceed with defined conditions), or hold (decision deferred pending additional data). Null for non-decision-gate milestone types.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGxpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Gxp Relevant' ;
    rdfs:comment 'Indicates whether this milestone involves GxP-regulated activities (True) — including GMP, GLP, or GCP — requiring formal documentation, audit trails, and quality system controls per applicable regulations. Drives quality oversight and Veeva Vault document control requirements.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIpGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Ip Generating' ;
    rdfs:comment 'Indicates whether achievement of this milestone is expected to generate patentable intellectual property or trade secrets (True) or not (False). Triggers IP disclosure workflows and patent filing timelines in the R&D IP management process.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCritical rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Critical' ;
    rdfs:comment 'Indicates whether this milestone lies on the critical regulatory submission path (True), meaning its delay would directly impact an FDA, EMA, or IVDR submission timeline. Used for regulatory affairs prioritization and risk management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the milestone record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for GxP audit trail compliance and change tracking under 21 CFR Part 11.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the milestone within the R&D portfolio management system (e.g., Benchling or SAP PS). Used in project plans, stage-gate reports, and regulatory submissions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the milestone (e.g., \'IND-Enabling Toxicology Study Completion\', \'Proof-of-Concept CRISPR Readout\', \'TRL-4 Assessment\'). Used in portfolio dashboards and stage-gate presentations.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current workflow state of the milestone: planned (scheduled but not started), in_progress (active work underway), met (successfully completed against success criteria), missed (not completed by planned date), deferred (rescheduled to a future date), or cancelled (removed from scope).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone: decision_gate (go/no-go stage gate), deliverable (tangible output such as a report or prototype), trl_assessment (Technology Readiness Level evaluation), or regulatory_checkpoint (pre-submission meeting, IND filing, FDA/EMA interaction).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Date of the next scheduled review or reassessment for milestones with status of in_progress, deferred, or conditional_go. Supports proactive portfolio monitoring and escalation scheduling.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Formal recorded outcome of the milestone at its evaluation point: met (all success criteria satisfied), missed (criteria not met by deadline), deferred (evaluation postponed), partial (criteria partially met with documented exceptions), or cancelled (milestone removed from plan).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled date by which the milestone was expected to be achieved, as defined in the R&D project plan. Used for schedule variance analysis and portfolio stage-gate tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorTrlScore rdf:type rdf:Property ;
    rdfs:label 'Prior Trl Score' ;
    rdfs:comment 'TRL score recorded at the immediately preceding TRL assessment milestone for the same project. Enables calculation of TRL advancement delta and tracking of technology maturation velocity across the R&D portfolio.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority classification of the milestone within the R&D portfolio: critical (program-blocking, must not slip), high (significant impact if delayed), medium (important but manageable), low (nice-to-have or supporting). Used for resource allocation and escalation decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdSpendRecognized rdf:type rdf:Property ;
    rdfs:label 'Rd Spend Recognized' ;
    rdfs:comment 'Cumulative R&D expenditure (in USD) formally recognized upon achievement of this milestone for financial reporting purposes. Supports milestone-based R&D spend recognition per ASC 730 (R&D accounting) and SOX-compliant financial controls. Null if milestone has not been met.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Regulatory authority associated with a regulatory_checkpoint milestone (e.g., FDA = U.S. Food and Drug Administration, EMA = European Medicines Agency, PMDA = Japan Pharmaceuticals and Medical Devices Agency). Null for non-regulatory milestone types. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|Health_Canada|TGA|ANVISA|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which the formal milestone review meeting or assessment was conducted by the review board or stage-gate committee. Distinct from actual_completion_date, which records when the work was completed. Used for governance audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedTargetDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Date' ;
    rdfs:comment 'Updated target completion date when the original planned date has been formally revised due to scope changes, resource constraints, or scientific findings. Null if no revision has occurred. Supports deferred milestone tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Calculated difference in calendar days between actual_completion_date and planned_date (positive = late, negative = early). Populated upon milestone completion. Used for R&D portfolio schedule performance reporting and KPI dashboards. Note: derived field retained as a persisted business metric for reporting efficiency.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the rd_spend_recognized amount (e.g., USD, EUR, GBP). Supports multi-currency R&D portfolio financial reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Predefined, measurable criteria that must be satisfied for the milestone to be declared \'met\'. Examples: \'LOD ≤ 0.1% VAF confirmed in triplicate\', \'TRL score ≥ 4 validated by independent review board\', \'IND submission package approved by regulatory affairs\'. Captured from Benchling ELN or project charter.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trlScore rdf:type rdf:Property ;
    rdfs:label 'Trl Score' ;
    rdfs:comment 'Numeric Technology Readiness Level score on the 1–9 scale assigned at the time of a trl_assessment milestone. TRL 1 = basic principles observed; TRL 9 = system proven in operational environment. Null for non-TRL milestone types. Enables portfolio stage-gating from basic research through product development readiness.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crisprConstructId rdf:type rdf:Property ;
    rdfs:label 'Crispr Construct Id' ;
    rdfs:comment 'Foreign key linking to research.crispr_construct. Business justification: CRISPR gene-editing experiments use specific constructs from the construct registry. Currently experiment has crispr_guide_rna_sequence (STRING) and target_gene_symbol (STRING) but no FK to crispr_con' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrisprConstruct .

ind:limsSampleBatchId rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Batch Id' ;
    rdfs:comment 'The batch or worklist identifier from LabVantage LIMS linking this experiment to the set of samples processed. Enables bidirectional traceability between the ELN experiment record and the LIMS sample tracking workflow.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:reagentSkuId rdf:type rdf:Property ;
    rdfs:label 'Reagent Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Experiments consume specific reagent SKUs (kits, consumables, controls). Lab managers track SKU usage for cost accounting, inventory planning, protocol optimization, and reagent performance evaluation' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'The actual total cost in US Dollars (USD) incurred to execute this experiment, as recorded in SAP. Compared against estimated_cost_usd for budget variance analysis and R&D spend efficiency reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date on which the experiment commenced. Compared against planned_start_date to measure schedule adherence and identify delays in R&D execution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchlingElnEntryReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Eln Entry Reference' ;
    rdfs:comment 'The unique identifier of the corresponding Electronic Lab Notebook (ELN) entry in Benchling. Provides direct traceability from the data product to the authoritative scientific record in the system of record for R&D documentation.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionType rdf:type rdf:Property ;
    rdfs:label 'Contribution Type' ;
    rdfs:comment 'Classifies how the experiment\'s output contributes to the publication: raw_data, processed_result, statistical_analysis, visualization, or protocol_description. Belongs to the relationship because the same experiment\'s data may be used differently across publications.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisprGuideRnaSequence rdf:type rdf:Property ;
    rdfs:label 'Crispr Guide Rna Sequence' ;
    rdfs:comment 'The nucleotide sequence of the guide RNA (gRNA) used in CRISPR gene-editing experiments. Captured for IP prosecution, reproducibility, and molecular design traceability. Applicable only to CRISPR experiment types; null for non-CRISPR experiments. Classified as confidential due to IP sensitivity.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Included Flag' ;
    rdfs:comment 'Indicates whether the experiment\'s data is directly included in the publication (true) versus merely referenced or cited without inclusion of underlying data (false). Critical for data-sharing compliance and repository deposition requirements.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataIntegritySignature rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Signature' ;
    rdfs:comment 'Cryptographic hash or electronic signature value applied to the experiment record at the time of ELN entry finalization. Ensures data integrity and non-repudiation of the scientific record as required by 21 CFR Part 11 and GxP data integrity guidelines.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'The statistical or methodological design framework applied to the experiment (e.g., controlled, factorial, dose-response, observational, screening, comparative). Informs data analysis approach and statistical power assessment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnEntryType rdf:type rdf:Property ;
    rdfs:label 'Eln Entry Type' ;
    rdfs:comment 'Categorizes the nature of the ELN entry associated with this experiment record (observation, result, protocol execution, data analysis). Drives downstream data routing and review workflows in Benchling.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Code' ;
    rdfs:comment 'Human-readable, externally-known alphanumeric code uniquely identifying the experiment within the organization (e.g., EXP-CRISPR0042). Used in lab notebooks, reports, IP filings, and cross-system references.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentRole rdf:type rdf:Property ;
    rdfs:label 'Experiment Role' ;
    rdfs:comment 'Describes the evidentiary role this experiment plays in the publication: primary_evidence, validation, supplementary, negative_control, or replication. Belongs to the relationship because the same experiment may serve different roles in different publications.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current workflow state of the experiment in its lifecycle (planned, in-progress, completed, failed, cancelled, on-hold). Drives operational dashboards, resource planning, and milestone reporting.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentType rdf:type rdf:Property ;
    rdfs:label 'Experiment Type' ;
    rdfs:comment 'Classification of the experiment by scientific domain or workflow category (e.g., CRISPR editing efficiency assay, library preparation optimization, sequencing chemistry validation, reagent formulation trial, custom assay development, dose-response). [ENUM-REF-CANDIDATE: crispr_editing|library_prep_optimization|sequencing_chemistry_validation|reagent_formulation|assay_development|dose_response|other — promote to reference product]' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:figureReference rdf:type rdf:Property ;
    rdfs:label 'Figure Reference' ;
    rdfs:comment 'Identifies the specific figure(s), table(s), or supplementary section(s) in the publication where this experiment\'s data appears (e.g., \'Figure 3B\', \'Supplementary Table S2\'). Belongs to the relationship because the same experiment may appear in different figures across different publications.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The scientific hypothesis or research question that the experiment is designed to test. Captured as free text from the ELN entry. Critical for IP prosecution documentation and scientific reproducibility.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisclosureFiled rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Filed' ;
    rdfs:comment 'Indicates whether an Intellectual Property (IP) invention disclosure has been filed based on the findings of this experiment. Triggers IP prosecution workflows and ensures novel discoveries are protected prior to publication.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labLocationCode rdf:type rdf:Property ;
    rdfs:label 'Lab Location Code' ;
    rdfs:comment 'Reference to the physical laboratory facility or room where the experiment is conducted. Supports environmental monitoring, equipment qualification traceability, and site-level compliance reporting.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organism rdf:type rdf:Property ;
    rdfs:label 'Organism' ;
    rdfs:comment 'The biological organism or model system used in the experiment (e.g., Homo sapiens, Mus musculus, E. coli, cell line HEK293T, in vitro). Required for regulatory submissions, biosafety classification, and cross-species genomics analytics.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeSummary rdf:type rdf:Property ;
    rdfs:label 'Outcome Summary' ;
    rdfs:comment 'Free-text narrative summarizing the scientific outcome, key findings, and conclusions of the experiment. Captured from the ELN entry and used for IP documentation, publication preparation, and knowledge management.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'The scheduled start date for the experiment as defined in the project plan. Used for resource scheduling, milestone tracking, and R&D timeline reporting.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryResultMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Result Metric' ;
    rdfs:comment 'The name of the principal quantitative or qualitative metric used to evaluate the experiment outcome (e.g., CRISPR editing efficiency percentage, Phred Score threshold, library yield ng/uL, LOD value). Enables structured result comparison across experiments.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResultUnit rdf:type rdf:Property ;
    rdfs:label 'Primary Result Unit' ;
    rdfs:comment 'The unit of measure for the primary result value (e.g., percent, ng/uL, copies/mL, Phred score, fold-change). Ensures dimensional correctness in analytics and cross-experiment comparisons.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResultValue rdf:type rdf:Property ;
    rdfs:label 'Primary Result Value' ;
    rdfs:comment 'The numeric value of the primary result metric for this experiment (e.g., 87.5 for 87.5% editing efficiency, 35.2 for Phred Score). Paired with primary_result_unit for dimensional analysis and cross-experiment benchmarking.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rAndDCostCenter rdf:type rdf:Property ;
    rdfs:label 'R And D Cost Center' ;
    rdfs:comment 'The SAP cost center code to which R&D expenditure for this experiment is charged. Enables R&D spend tracking, budget vs. actual analysis, and EBITDA reporting at the project and portfolio level.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replicateCount rdf:type rdf:Property ;
    rdfs:label 'Replicate Count' ;
    rdfs:comment 'The number of technical or biological replicates included in the experimental design. Distinct from sample_count; captures the replication strategy for statistical validity assessment and reproducibility documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetGeneSymbol rdf:type rdf:Property ;
    rdfs:label 'Target Gene Symbol' ;
    rdfs:comment 'The HGNC-approved gene symbol for the primary gene targeted or studied in this experiment (e.g., BRCA1, TP53, EGFR). Links the experiment to reference genomics data and enables gene-centric analytics across the research portfolio.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Readiness Level' ;
    rdfs:comment 'Numeric scale (1–9) indicating the maturity of the technology or discovery generated by this experiment, per NASA/DoD TRL framework adapted for genomics product development. Used for R&D portfolio stage-gate decisions and commercialization planning.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCurriculumId rdf:type rdf:Property ;
    rdfs:label 'Training Curriculum Id' ;
    rdfs:comment 'Identifier of the associated training curriculum or course in MasterControl that personnel must complete to be qualified to execute this protocol. Populated when training_required is True.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCurriculum .

ind:applicableInstruments rdf:type rdf:Property ;
    rdfs:label 'Applicable Instruments' ;
    rdfs:comment 'Comma-separated list of instrument platforms or models for which this protocol is validated and applicable (e.g., \'NovaSeq 6000, NextSeq 2000, MiSeq\'). Critical for ensuring protocol-instrument compatibility in sequencing and assay workflows.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSampleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Sample Types' ;
    rdfs:comment 'Comma-separated list of biological sample types for which this protocol is validated (e.g., \'FFPE tissue, whole blood, saliva, cell line, cfDNA\'). Ensures protocol is applied only to compatible sample matrices.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoredBy rdf:type rdf:Property ;
    rdfs:label 'Authored By' ;
    rdfs:comment 'Name or employee identifier of the primary author who drafted the protocol. Captured as a display name string for audit trail and document control purposes. Supports accountability and traceability per GxP requirements.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchlingProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Protocol Reference' ;
    rdfs:comment 'External identifier assigned by Benchling (Electronic Lab Notebook / ELN) to the corresponding protocol entry. Enables bidirectional traceability between the lakehouse catalog and the Benchling R&D system of record.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Brief narrative description of the changes made in this version relative to the superseded version. Captured at the time of approval to support change control documentation and regulatory audit trails. Required for GxP change control.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaApplicable rdf:type rdf:Property ;
    rdfs:label 'Clia Applicable' ;
    rdfs:comment 'Indicates whether this protocol is subject to CLIA (Clinical Laboratory Improvement Amendments) requirements, applicable when the protocol is used in a clinical laboratory setting for patient testing.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageDepthTarget rdf:type rdf:Property ;
    rdfs:label 'Coverage Depth Target' ;
    rdfs:comment 'Target sequencing coverage depth (in X, i.e., fold coverage) specified by this protocol for NGS applications (e.g., 30 for WGS, 100 for WES, 500 for targeted panels). Null for non-sequencing protocols. Used in run planning and QC acceptance criteria.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated total hands-on and elapsed time required to execute the protocol from start to finish, expressed in decimal hours. Used for laboratory scheduling, resource planning, and Turnaround Time (TAT) estimation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReferenceStandard rdf:type rdf:Property ;
    rdfs:label 'External Reference Standard' ;
    rdfs:comment 'Citation or identifier of the external compendial, regulatory, or industry standard that this protocol is based on or aligned with (e.g., \'CLSI EP17-A2\', \'ISO 20166-1\', \'FDA Guidance for NGS-Based IVDs\', \'ACMG/AMP Variant Classification Guidelines\'). Supports regulatory submission traceability.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpCompliant rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant' ;
    rdfs:comment 'Indicates whether this protocol has been designed and validated to comply with Good Laboratory Practice (GLP) regulations. True = GLP-compliant protocol; False = not GLP-compliant. Relevant for non-clinical safety studies submitted to regulatory agencies.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipGenerating rdf:type rdf:Property ;
    rdfs:label 'Ip Generating' ;
    rdfs:comment 'Indicates whether this protocol is associated with or has generated Intellectual Property (IP) such as a patent application, trade secret, or proprietary method. True = IP-generating; False = no IP association. Classified as confidential to protect competitive information.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Required' ;
    rdfs:comment 'Indicates whether Institutional Review Board (IRB) approval is required before this protocol can be executed on human-derived samples. True = IRB approval mandatory; False = IRB approval not required (e.g., non-human samples or RUO context).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lod rdf:type rdf:Property ;
    rdfs:label 'Lod' ;
    rdfs:comment 'Limit of Detection (LOD) for the assay or method described by this protocol, expressed as a value with units (e.g., \'0.1% VAF\', \'1 ng/µL\', \'10 copies/mL\'). Stored as a string to accommodate varied units across protocol types. Key analytical performance characteristic.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolDocReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Doc Reference' ;
    rdfs:comment 'Document control identifier assigned by MasterControl, the enterprise document control and training management system. Used to cross-reference the approved controlled document record for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Name of the organizational department or team responsible for maintaining and updating the protocol (e.g., \'Molecular Biology R&D\', \'Genomics Assay Development\', \'Quality Assurance\'). Determines accountability for periodic review.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentReference rdf:type rdf:Property ;
    rdfs:label 'Patent Reference' ;
    rdfs:comment 'Patent application number or granted patent number associated with the method or invention described in this protocol (e.g., \'US20230123456A1\'). Populated when ip_generating is True. Classified as confidential.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalScientist rdf:type rdf:Property ;
    rdfs:label 'Principal Scientist' ;
    rdfs:comment 'Name or employee identifier of the principal scientist or subject matter expert (SME) who is the scientific owner of the protocol. Responsible for technical accuracy and scientific validity of the procedure.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolCategory rdf:type rdf:Property ;
    rdfs:label 'Protocol Category' ;
    rdfs:comment 'Scientific or operational category of the protocol describing the laboratory discipline it covers (e.g., \'Library Preparation\', \'CRISPR Gene Editing\', \'PCR/qPCR\', \'Cell Transfection\', \'Sequencing Run Setup\', \'Nucleic Acid Extraction\', \'Variant Calling\'). [ENUM-REF-CANDIDATE: library_preparation|crispr_gene_editing|pcr_qpcr|cell_transfection|sequencing_run_setup|nucleic_acid_extraction|variant_calling|array_hybridization|cell_culture|bioinformatics_pipeline — promote to reference product]' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Number' ;
    rdfs:comment 'Externally-known, human-readable unique document number assigned under the document numbering scheme (e.g., RD-SOP-001234). Used in regulatory submissions, audit trails, and cross-referencing in publications and SOPs.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'Classification of the protocol by document type. SOP = Standard Operating Procedure; method = analytical or experimental method; assay_protocol = specific assay procedure; work_instruction = step-level task instruction; reference_method = compendial or regulatory reference method; study_plan = experimental study design document.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory use classification of the protocol indicating the compliance framework under which it operates. GLP = Good Laboratory Practice; GMP = Good Manufacturing Practice; GCP = Good Clinical Practice; RUO = Research Use Only; IVD = In Vitro Diagnostic; LDT = Laboratory Developed Test; CE-IVD = Conformité Européenne In Vitro Diagnostic; non_regulated = no regulatory classification applies. [ENUM-REF-CANDIDATE: GLP|GMP|GCP|RUO|IVD|LDT|CE-IVD|non_regulated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredReagentSkus rdf:type rdf:Property ;
    rdfs:label 'Required Reagent Skus' ;
    rdfs:comment 'Comma-separated list of reagent and consumable SKU (Stock Keeping Unit) codes required to execute this protocol. Enables Bill of Materials (BOM) linkage, inventory planning, and reagent lot tracking in SAP MM and LabVantage LIMS.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Biosafety Level (BSL) classification of the protocol indicating the containment level required for safe execution. BSL1–BSL4 per CDC/NIH biosafety guidelines. Non_hazardous for protocols involving no biological risk agents. Drives laboratory safety requirements and access controls.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or colloquial name for the protocol used in laboratory workflows, LIMS entries, and internal communications (e.g., \'gRNA Design SOP\'). Distinct from the full controlled document title.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Version Number' ;
    rdfs:comment 'Version number of the immediately preceding protocol version that this record replaces. Enables forward and backward traceability across the protocol version history chain. Null for the initial version.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technologyPlatform rdf:type rdf:Property ;
    rdfs:label 'Technology Platform' ;
    rdfs:comment 'Primary genomics technology platform that this protocol supports. NGS = Next-Generation Sequencing; array = microarray-based; PCR = Polymerase Chain Reaction; qPCR = Quantitative PCR; CRISPR = gene editing; Sanger = Sanger sequencing; ddPCR = droplet digital PCR. [ENUM-REF-CANDIDATE: NGS|array|PCR|qPCR|CRISPR|Sanger|ddPCR|digital_PCR|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether personnel must complete a formal training and competency assessment before being authorized to execute this protocol. True = training mandatory; False = no formal training requirement. Drives training assignment in MasterControl.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:synthesisBatchId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Batch Id' ;
    rdfs:comment 'Foreign key linking to supply.batch. Business justification: CRISPR constructs are received as synthesized batches from vendors. GMP/GLP lot traceability requires linking each construct record to its synthesis batch — enabling recall management, CoA traceabilit' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:synthesisSupplierId rdf:type rdf:Property ;
    rdfs:label 'Synthesis Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: CRISPR constructs are synthesized by qualified external vendors (e.g., IDT, Twist Bioscience). synthesis_vendor is currently a plain text denormalization. Linking to supply.supplier enables vendor qua' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:benchlingEntityReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Entity Reference' ;
    rdfs:comment 'Unique entity identifier in Benchling electronic lab notebook system linking to the molecular design record and sequence data.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casProteinVariant rdf:type rdf:Property ;
    rdfs:label 'Cas Protein Variant' ;
    rdfs:comment 'Specific Cas protein variant used in the construct (e.g., Cas9, Cas12a, Cas13, dCas9, base editor variant). Identifies the nuclease or effector protein component.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellType rdf:type rdf:Property ;
    rdfs:label 'Cell Type' ;
    rdfs:comment 'Specific cell type or tissue targeted by the construct. Defines the cellular context for editing or expression.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructCode rdf:type rdf:Property ;
    rdfs:label 'Construct Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier assigned to the construct for tracking and cataloging purposes within the R&D system.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructLengthBp rdf:type rdf:Property ;
    rdfs:label 'Construct Length Bp' ;
    rdfs:comment 'Total length of the construct sequence measured in base pairs. Defines the size of the molecular construct.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructName rdf:type rdf:Property ;
    rdfs:label 'Construct Name' ;
    rdfs:comment 'Human-readable name or designation assigned to the CRISPR construct for identification and reference in laboratory workflows and publications.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructType rdf:type rdf:Property ;
    rdfs:label 'Construct Type' ;
    rdfs:comment 'Classification of the molecular construct type. Defines the category of the construct within the molecular biology design framework.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Method or vehicle used to deliver the CRISPR construct into target cells. Defines the delivery mechanism for the molecular payload.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRationale rdf:type rdf:Property ;
    rdfs:label 'Design Rationale' ;
    rdfs:comment 'Scientific justification and reasoning behind the construct design choices. Documents the strategic approach and expected outcomes.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designStatus rdf:type rdf:Property ;
    rdfs:label 'Design Status' ;
    rdfs:comment 'Current lifecycle status of the construct design. Tracks progression through design review and approval workflow.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTool rdf:type rdf:Property ;
    rdfs:label 'Design Tool' ;
    rdfs:comment 'Software tool or algorithm used to design the construct (e.g., Benchling, CRISPOR, Cas-OFFinder). Documents the computational design methodology.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStage rdf:type rdf:Property ;
    rdfs:label 'Development Stage' ;
    rdfs:comment 'Current stage of the construct in the R&D pipeline. Tracks progression from discovery through commercialization.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editingModality rdf:type rdf:Property ;
    rdfs:label 'Editing Modality' ;
    rdfs:comment 'Type of genomic editing or modulation intended by the CRISPR construct. Defines the functional outcome of the gene editing strategy.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcContentPercent rdf:type rdf:Property ;
    rdfs:label 'Gc Content Percent' ;
    rdfs:comment 'Percentage of guanine and cytosine nucleotides in the construct sequence. Influences stability and expression characteristics.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genomicCoordinates rdf:type rdf:Property ;
    rdfs:label 'Genomic Coordinates' ;
    rdfs:comment 'Precise genomic coordinates in standard format (chromosome:start-end) based on reference genome assembly GRCh38/hg38.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grnaSequence rdf:type rdf:Property ;
    rdfs:label 'Grna Sequence' ;
    rdfs:comment 'Nucleotide sequence of the guide RNA component that directs Cas protein to the target genomic locus. Proprietary sequence data for CRISPR targeting.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Status' ;
    rdfs:comment 'Intellectual property classification and protection status of the construct. Tracks IP rights and licensing obligations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or identifier of the user who last modified the construct record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offTargetScore rdf:type rdf:Property ;
    rdfs:label 'Off Target Score' ;
    rdfs:comment 'Computational prediction score for off-target binding potential. Lower scores indicate higher specificity and reduced off-target risk.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTargetEfficiencyScore rdf:type rdf:Property ;
    rdfs:label 'On Target Efficiency Score' ;
    rdfs:comment 'Predicted or measured efficiency of the construct at the intended target site. Higher scores indicate greater editing efficiency.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pamSequence rdf:type rdf:Property ;
    rdfs:label 'Pam Sequence' ;
    rdfs:comment 'PAM sequence required for Cas protein recognition and binding adjacent to the target site. Critical for CRISPR targeting specificity.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plasmidBackbone rdf:type rdf:Property ;
    rdfs:label 'Plasmid Backbone' ;
    rdfs:comment 'Name or identifier of the plasmid backbone vector used for construct assembly. Defines the vector framework for cloning and expression.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Name of the principal investigator or lead scientist responsible for the construct design and development.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoterElement rdf:type rdf:Property ;
    rdfs:label 'Promoter Element' ;
    rdfs:comment 'Promoter sequence or element driving expression of the construct components. Defines transcriptional regulation of the construct.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Quality control verification status for the synthesized construct. Indicates whether sequence verification and purity checks were successful.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionMarker rdf:type rdf:Property ;
    rdfs:label 'Selection Marker' ;
    rdfs:comment 'Antibiotic resistance or fluorescent marker gene included for selection and identification of successfully transformed cells.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceDataReference rdf:type rdf:Property ;
    rdfs:label 'Sequence Data Reference' ;
    rdfs:comment 'Reference identifier linking to the full sequence data stored in Benchling or other molecular design system. Typically a Benchling entity ID or accession number.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisDate rdf:type rdf:Property ;
    rdfs:label 'Synthesis Date' ;
    rdfs:comment 'Date when the construct was physically synthesized or assembled. Tracks manufacturing timeline.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetLocus rdf:type rdf:Property ;
    rdfs:label 'Target Locus' ;
    rdfs:comment 'Genomic coordinates or locus identifier for the target region. Specifies the precise genomic location targeted by the construct.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or identifier of the researcher who created the construct record in the system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to research.grant. Business justification: Assay development programs are frequently funded by external grants (e.g., NIH SBIR/STTR, BARDA contracts). assay_development has rd_budget_allocated and rd_spend_to_date but no FK to the grant entity' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:analyticalSensitivityPercent rdf:type rdf:Property ;
    rdfs:label 'Analytical Sensitivity Percent' ;
    rdfs:comment 'The proportion of true positive results correctly identified by the assay, expressed as a percentage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyticalSpecificityPercent rdf:type rdf:Property ;
    rdfs:label 'Analytical Specificity Percent' ;
    rdfs:comment 'The proportion of true negative results correctly identified by the assay, expressed as a percentage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayCode rdf:type rdf:Property ;
    rdfs:label 'Assay Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the assay for internal tracking and reference.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayName rdf:type rdf:Property ;
    rdfs:label 'Assay Name' ;
    rdfs:comment 'The official name or title of the assay under development.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercializationDate rdf:type rdf:Property ;
    rdfs:label 'Commercialization Date' ;
    rdfs:comment 'The date on which the assay was launched for commercial sale or clinical use.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentPhase rdf:type rdf:Property ;
    rdfs:label 'Development Phase' ;
    rdfs:comment 'The current stage of the assay development lifecycle (feasibility, optimization, pre-validation, analytical validation, clinical validation, commercialization).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Development Start Date' ;
    rdfs:comment 'The date on which the assay development project officially commenced.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentStatus rdf:type rdf:Property ;
    rdfs:label 'Development Status' ;
    rdfs:comment 'The current operational status of the assay development project.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCogs rdf:type rdf:Property ;
    rdfs:label 'Estimated Cogs' ;
    rdfs:comment 'The estimated per-test cost of goods sold for the assay, including reagents, consumables, and direct labor.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feasibilityCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Feasibility Completion Date' ;
    rdfs:comment 'The date on which the feasibility phase of the assay development was completed.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lodValue rdf:type rdf:Property ;
    rdfs:label 'Lod Value' ;
    rdfs:comment 'The lowest quantity of target analyte that can be reliably detected by the assay, expressed in appropriate units.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loqUnit rdf:type rdf:Property ;
    rdfs:label 'Loq Unit' ;
    rdfs:comment 'The unit of measure for the LOQ value (e.g., copies/mL, ng/mL, percentage).' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loqValue rdf:type rdf:Property ;
    rdfs:label 'Loq Value' ;
    rdfs:comment 'The lowest quantity of target analyte that can be reliably quantified with acceptable precision and accuracy.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiplexingCapacity rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Capacity' ;
    rdfs:comment 'The number of samples that can be processed simultaneously in a single sequencing run or batch (applicable for NGS assays).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelSize rdf:type rdf:Property ;
    rdfs:label 'Panel Size' ;
    rdfs:comment 'The number of genes, variants, or targets included in the assay panel (applicable for NGS panels and genotyping arrays).' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'The patent number(s) associated with the assay technology or methodology, if applicable.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Name' ;
    rdfs:comment 'The name of the principal investigator or lead scientist responsible for the assay development project.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Citation or DOI of any peer-reviewed publication(s) resulting from the assay development work.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdBudgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Rd Budget Allocated' ;
    rdfs:comment 'The total budget allocated for the assay development project.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rdSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Rd Spend To Date' ;
    rdfs:comment 'The cumulative R&D expenditure on the assay development project as of the current date.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reproducibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Reproducibility Assessment' ;
    rdfs:comment 'Qualitative or quantitative assessment of the assay\'s ability to produce consistent results across different operators, instruments, reagent lots, and time points.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'The biological specimen type(s) compatible with the assay (e.g., whole blood, plasma, saliva, tissue, FFPE). [ENUM-REF-CANDIDATE: Whole Blood|Plasma|Serum|Saliva|Buccal Swab|Tissue|FFPE|DNA|RNA — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAnalyte rdf:type rdf:Property ;
    rdfs:label 'Target Analyte' ;
    rdfs:comment 'The specific genetic variant, gene, biomarker, or molecular target that the assay is designed to detect or measure.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAsp rdf:type rdf:Property ;
    rdfs:label 'Target Asp' ;
    rdfs:comment 'The target average selling price per test for the assay upon commercialization.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTatHours rdf:type rdf:Property ;
    rdfs:label 'Target Tat Hours' ;
    rdfs:comment 'The intended turnaround time from sample receipt to result reporting, measured in hours.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'The date on which analytical validation of the assay was completed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendId rdf:type rdf:Property ;
    rdfs:label 'Spend Id' ;
    rdfs:comment 'Primary key for spend' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collaborationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Agreement Id' ;
    rdfs:comment 'Reference to the external collaboration or partnership agreement under which this R&D spend is incurred, if applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollaborationAgreement .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary value of the R&D expenditure in the transaction currency.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocal rdf:type rdf:Property ;
    rdfs:label 'Amount Local' ;
    rdfs:comment 'The spend amount converted to the local reporting currency of the business unit or legal entity.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the spend transaction was approved by the authorized approver.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetLineItemCode rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Code' ;
    rdfs:comment 'Reference to the budget line item against which this spend is tracked, enabling budget vs. actuals variance analysis.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible' ;
    rdfs:comment 'Indicates whether this R&D spend is eligible for capitalization under accounting standards (ASC 730 for US GAAP or IAS 38 for IFRS). True if eligible, False if expensed immediately.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationStatus rdf:type rdf:Property ;
    rdfs:label 'Capitalization Status' ;
    rdfs:comment 'Current capitalization treatment status: expensed (immediately recognized), capitalized (added to intangible asset), pending review (awaiting finance decision), or deferred (to be allocated in future periods).' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of the R&D spend by type: personnel costs (FTE allocation), external CRO/CMO service fees, reagent and consumable purchases, instrument depreciation allocations, HPC/cloud compute costs, facility overhead, travel, or other. [ENUM-REF-CANDIDATE: personnel|external_services|reagents_consumables|instrument_depreciation|compute_infrastructure|facility_overhead|travel|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert the transaction currency to the local reporting currency.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year in which the spend was recorded.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the spend was recorded, used for annual budget tracking and financial reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'The proportion of an employee\'s time allocated to this R&D project, expressed as a decimal (e.g., 0.50 for 50% allocation, 1.00 for full-time).' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this R&D spend is posted, linking to the chart of accounts in the ERP system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor invoice number associated with this spend transaction, used for accounts payable reconciliation.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which payment was made to the vendor or the spend was settled, if applicable.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current payment status of the spend transaction: unpaid (invoice received but not paid), partially paid (partial payment made), paid (fully settled), or overdue (past due date).' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The date on which the R&D expenditure was incurred or posted to the general ledger.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendDescription rdf:type rdf:Property ;
    rdfs:label 'Spend Description' ;
    rdfs:comment 'Free-text description of the R&D spend transaction, providing additional context about the nature of the expenditure.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendNumber rdf:type rdf:Property ;
    rdfs:label 'Spend Number' ;
    rdfs:comment 'Business identifier for the spend transaction, typically sourced from the ERP system (e.g., SAP document number).' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The tax amount (VAT, sales tax, GST) associated with this R&D spend, if applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the external vendor or service provider associated with this R&D spend.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The WBS element code from the project management system, used for hierarchical project cost tracking and reporting.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchlingProjectId rdf:type rdf:Property ;
    rdfs:label 'Benchling Project Id' ;
    rdfs:comment 'Identifier linking to the associated R&D project in Benchling electronic lab notebook system where collaboration research activities are documented.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:partnerAccountId rdf:type rdf:Property ;
    rdfs:label 'Partner Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: External research collaborations (with academic institutions, pharma companies, biotech partners) are with entities tracked as customer accounts. This links research partnerships to the authoritative ' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the collaboration agreement, typically formatted with prefix and sequential number (e.g., CDA-20230045, SRA-2024001).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Full descriptive title of the collaboration agreement as stated in the contract document.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the collaboration agreement type. Sponsored research: academic institution performs research funded by Genomics Biotech. Co-development: joint R&D with shared IP. Licensing-in: acquiring rights to external technology. Material transfer: exchange of biological materials or reagents. Data sharing: exchange of genomic or clinical datasets. Consortium membership: participation in industry collaborative groups.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the agreement automatically renews upon expiration unless either party provides notice.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the collaboration agreement. Draft: initial preparation. Under negotiation: terms being discussed. Pending approval: awaiting internal or partner sign-off. Active: in force and operational. Suspended: temporarily paused. Terminated: ended before expiration. Completed: successfully concluded. Expired: reached end date. [ENUM-REF-CANDIDATE: draft|under_negotiation|pending_approval|active|suspended|terminated|completed|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTier rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Tier' ;
    rdfs:comment 'Classification of confidentiality requirements for the collaboration. Standard: typical NDA protections. High: enhanced confidentiality with limited disclosure. Critical: highly sensitive strategic partnership with strict access controls.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingObligation rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Obligation' ;
    rdfs:comment 'Defines data sharing requirements between parties. Full sharing: all research data exchanged. Limited sharing: only specified datasets or summary data. No sharing: data remains with generating party. Upon request: data shared on case-by-case basis.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseRestrictions rdf:type rdf:Property ;
    rdfs:label 'Data Use Restrictions' ;
    rdfs:comment 'Specific limitations on how shared data may be used, including permitted research purposes, prohibited uses, and requirements for data security and privacy compliance.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines exclusivity terms. Exclusive: only Genomics Biotech has rights in defined field/territory. Non-exclusive: partner may grant rights to others. Co-exclusive: limited number of licensees. Field-limited exclusive: exclusive within specific application area.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the agreement was signed by all parties.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when the collaboration agreement terminates unless renewed or extended. Nullable for open-ended agreements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantFundingSource rdf:type rdf:Property ;
    rdfs:label 'Grant Funding Source' ;
    rdfs:comment 'Name of government or foundation grant program funding the collaboration, if applicable (e.g., NIH R01, BARDA contract, DARPA program, Gates Foundation grant).' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Model' ;
    rdfs:comment 'Framework governing ownership of intellectual property generated under the collaboration. Genomics Biotech owns: all IP vests in Genomics Biotech. Partner owns: all IP vests in partner. Joint ownership: co-ownership with defined exploitation rights. Background-foreground split: each party retains background IP, foreground IP allocated per agreement. Case-by-case: determined per invention.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingRights rdf:type rdf:Property ;
    rdfs:label 'Licensing Rights' ;
    rdfs:comment 'Description of licensing rights granted to Genomics Biotech or partner, including field of use, territory, exclusivity, and sublicensing permissions.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'Financial payment model for the agreement. Lump sum: single upfront payment. Milestone-based: payments tied to achievement of defined milestones. Periodic: regular installments (monthly, quarterly). Cost reimbursement: actual costs plus overhead. Hybrid: combination of structures.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationEmbargoDays rdf:type rdf:Property ;
    rdfs:label 'Publication Embargo Days' ;
    rdfs:comment 'Number of days that publication must be delayed to allow for patent application filing or confidential information review. Typically 30-90 days.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationRights rdf:type rdf:Property ;
    rdfs:label 'Publication Rights' ;
    rdfs:comment 'Terms governing publication of research results. Unrestricted: parties may publish freely. Review required: other party reviews manuscripts before submission. Embargo period: delay publication for patent filing. Restricted: publication requires mutual consent.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionPlanned rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Planned' ;
    rdfs:comment 'Indicates whether the collaboration is intended to generate data for regulatory submission (FDA, EMA, etc.) for product approval.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to expiration that either party must provide notice to prevent auto-renewal or to initiate renewal discussions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:researchFocus rdf:type rdf:Property ;
    rdfs:label 'Research Focus' ;
    rdfs:comment 'Description of the scientific or clinical research focus area of the collaboration (e.g., oncology genomics, rare disease diagnostics, agricultural genomics, population health).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Contract number in SAP S/4HANA system for financial tracking and procurement integration.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the agreement was terminated, if applicable. Populated only for terminated agreements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFundingAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount Usd' ;
    rdfs:comment 'Total financial commitment from Genomics Biotech to the partner under this agreement, expressed in USD. Includes sponsored research funding, milestone payments, and upfront fees.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryIrbBenchlingProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Irb Benchling Project Id' ;
    rdfs:comment 'Reference identifier to the associated Benchling R&D project where experimental protocols and lab notebook entries are maintained.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:adverseEventCount rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Count' ;
    rdfs:comment 'Cumulative count of adverse events reported to the IRB for this study. Tracked for ongoing safety monitoring.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of protocol amendments submitted and approved since initial IRB approval. Tracks protocol evolution.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date the IRB approval expires, requiring continuing review or renewal. Typically one year from approval date for greater-than-minimal-risk studies.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalTrialRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registration Number' ;
    rdfs:comment 'ClinicalTrials.gov registration number (NCT number) if the study is a clinical trial requiring public registration. Format: NCT########.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date the study was formally closed with the IRB, indicating all research activities and data collection have been completed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuingReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Continuing Review Due Date' ;
    rdfs:comment 'Date by which continuing review submission is due to maintain active IRB approval. Typically 30-60 days before expiration.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyImpactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Impact Assessment Completed' ;
    rdfs:comment 'Boolean flag indicating whether a Data Privacy Impact Assessment has been completed for this study, as required by GDPR for high-risk processing.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRepositoryName rdf:type rdf:Property ;
    rdfs:label 'Data Repository Name' ;
    rdfs:comment 'Name of the public genomic data repository where study data will be deposited (e.g., \'dbGaP\', \'EGA\', \'AnVIL\'). Null if data sharing not required.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Estimated Enrollment' ;
    rdfs:comment 'Estimated total number of human subjects to be enrolled in the research study.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Primary source of funding for the research study. Determines reporting and compliance obligations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicDataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Genomic Data Sharing Required' ;
    rdfs:comment 'Boolean flag indicating whether the study is subject to NIH Genomic Data Sharing (GDS) Policy requirements for depositing genomic data into public repositories.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaWaiverStatus rdf:type rdf:Property ;
    rdfs:label 'Hipaa Waiver Status' ;
    rdfs:comment 'Status of HIPAA authorization waiver or alteration request for use of Protected Health Information (PHI) in the research study.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbBoardName rdf:type rdf:Property ;
    rdfs:label 'Irb Board Name' ;
    rdfs:comment 'Name of the Institutional Review Board that reviews this submission (e.g., \'Stanford IRB\', \'Western IRB\', \'Internal Genomics Biotech IRB\').' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbBoardRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Board Registration Number' ;
    rdfs:comment 'Federal registration number (IORG or IRB registration) assigned by OHRP or FDA for the reviewing IRB board.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContinuingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Continuing Review Date' ;
    rdfs:comment 'Date of the most recent continuing review approval by the IRB. Null if no continuing review has occurred.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiHandlingClassification rdf:type rdf:Property ;
    rdfs:label 'Phi Handling Classification' ;
    rdfs:comment 'Classification of how Protected Health Information is handled in the study. Determines HIPAA compliance requirements.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTitle rdf:type rdf:Property ;
    rdfs:label 'Protocol Title' ;
    rdfs:comment 'Full title of the research protocol submitted for IRB review. Describes the study purpose and scope.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of IRB review process applied to this submission based on risk and study characteristics.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'IRB-assigned risk level for human subjects participating in the study. Determines review pathway and oversight requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousAdverseEventCount rdf:type rdf:Property ;
    rdfs:label 'Serious Adverse Event Count' ;
    rdfs:comment 'Cumulative count of serious adverse events (SAEs) reported to the IRB for this study. Requires expedited reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Study Coordinator Name' ;
    rdfs:comment 'Full name of the study coordinator or research manager responsible for operational execution of the protocol.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Planned duration of the research study in months from first enrollment to study completion.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the research study type. Determines regulatory pathway and risk assessment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the IRB submission was formally submitted to the IRB board for review. Principal business event timestamp.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vulnerablePopulationInvolved rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Involved' ;
    rdfs:comment 'Boolean flag indicating whether the study involves vulnerable populations (children, prisoners, pregnant women, cognitively impaired) requiring additional IRB protections.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerablePopulationType rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Type' ;
    rdfs:comment 'Specific type of vulnerable population involved in the study (e.g., \'children\', \'prisoners\', \'pregnant_women\', \'cognitively_impaired\'). Null if not applicable.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Id' ;
    rdfs:comment 'Unique identifier for the intellectual property disclosure record. Primary key.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpDisclosure .

ind:assignedIpCounsel rdf:type rdf:Property ;
    rdfs:label 'Assigned Ip Counsel' ;
    rdfs:comment 'Name of the internal or external IP attorney or patent agent assigned to manage the disclosure and any subsequent patent prosecution.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialPotential rdf:type rdf:Property ;
    rdfs:label 'Commercial Potential' ;
    rdfs:comment 'Assessment of the invention\'s potential commercial value and market impact, used to prioritize IP investment decisions.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveAdvantage rdf:type rdf:Property ;
    rdfs:label 'Competitive Advantage' ;
    rdfs:comment 'Description of how the invention provides competitive advantage over existing solutions or competitor offerings in the genomics-biotechnology market.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureCode rdf:type rdf:Property ;
    rdfs:label 'Disclosure Code' ;
    rdfs:comment 'Business identifier for the IP disclosure, typically formatted as IPD-XXXXXX for external reference and tracking.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which the invention was formally disclosed to the IP management office. Critical for establishing priority date and patent filing deadlines.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the IP disclosure in the evaluation and decision workflow. [ENUM-REF-CANDIDATE: submitted|under_review|novelty_assessment|prior_art_search|decision_pending|approved_for_filing|abandoned|trade_secret — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFilingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Filing Cost Usd' ;
    rdfs:comment 'Estimated cost in USD for patent filing, prosecution, and maintenance over the patent lifecycle. Used for IP budget planning and ROI analysis.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Filing Decision Date' ;
    rdfs:comment 'Date when the patent filing decision was made by the IP committee or executive leadership.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Filing Decision Rationale' ;
    rdfs:comment 'Business and technical justification for the patent filing decision, including strategic value, competitive landscape, and cost-benefit analysis.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentInterestStatement rdf:type rdf:Property ;
    rdfs:label 'Government Interest Statement' ;
    rdfs:comment 'Statement acknowledging government funding and rights in the invention, required for patent applications when research was federally funded.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDescription rdf:type rdf:Property ;
    rdfs:label 'Invention Description' ;
    rdfs:comment 'Detailed technical description of the invention, including the problem solved, novel aspects, and potential applications. Confidential business information.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionType rdf:type rdf:Property ;
    rdfs:label 'Invention Type' ;
    rdfs:comment 'Classification of the invention according to patent law categories: composition of matter (e.g., novel sequencing chemistry, CRISPR construct), method (e.g., assay protocol), process (e.g., manufacturing workflow), software (e.g., bioinformatics algorithm), apparatus (e.g., instrument component), or design.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventors rdf:type rdf:Property ;
    rdfs:label 'Inventors' ;
    rdfs:comment 'Comma-separated list of full names of all inventors who contributed to the conception of the invention. Required for patent applications and inventor recognition.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Ip Counsel Firm' ;
    rdfs:comment 'Name of the external law firm providing IP counsel services, if applicable.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Ownership Flag' ;
    rdfs:comment 'Indicates whether the IP is jointly owned with an external party due to collaborative research or co-invention.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noveltyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment Date' ;
    rdfs:comment 'Date when the novelty assessment was completed by the IP review committee or external counsel.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noveltyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment Status' ;
    rdfs:comment 'Status and outcome of the internal novelty assessment to determine if the invention is sufficiently novel and non-obvious for patent protection.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyRationale rdf:type rdf:Property ;
    rdfs:label 'Novelty Rationale' ;
    rdfs:comment 'Summary of the novelty assessment findings, including key differentiators from prior art and justification for novelty determination.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Date' ;
    rdfs:comment 'Date on which the patent application was officially filed with the patent office. Establishes the priority date for patent rights.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentFilingDecision rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Decision' ;
    rdfs:comment 'Strategic decision on how to protect the invention: file a patent application, abandon (no protection), maintain as trade secret, or publish defensively to prevent others from patenting.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Patent Jurisdiction' ;
    rdfs:comment 'Primary patent jurisdiction or filing route: USA (United States Patent and Trademark Office), EPO (European Patent Office), PCT (Patent Cooperation Treaty for international filing), or specific country codes. [ENUM-REF-CANDIDATE: USA|EPO|PCT|JPN|CHN|KOR|CAN|AUS|BRA|IND — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtReferences rdf:type rdf:Property ;
    rdfs:label 'Prior Art References' ;
    rdfs:comment 'List of relevant prior art references identified during the search, including patent numbers, publication citations, and public disclosures.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtSearchDate rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Date' ;
    rdfs:comment 'Date when the prior art search was completed.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorArtSearchStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Status' ;
    rdfs:comment 'Status and outcome of the prior art search conducted to identify existing patents, publications, or public disclosures that may affect patentability.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date of any public disclosure of the invention (publication, presentation, product launch, etc.). Triggers one-year grace period for US patent filing and may bar foreign patent rights.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Assessment of whether the invention has regulatory implications (e.g., requires FDA approval, impacts IVD classification, affects GxP compliance).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Assessment of the invention\'s strategic importance to the company\'s competitive position, product roadmap, and long-term R&D goals.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductApplication rdf:type rdf:Property ;
    rdfs:label 'Target Product Application' ;
    rdfs:comment 'Description of the intended product or service application for the invention, linking IP to commercialization strategy.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationId rdf:type rdf:Property ;
    rdfs:label 'Publication Id' ;
    rdfs:comment 'Unique identifier for the scientific publication record.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationBenchlingProjectId rdf:type rdf:Property ;
    rdfs:label 'Publication Benchling Project Id' ;
    rdfs:comment 'Identifier linking the publication to the associated Benchling electronic lab notebook (ELN) project where the research was documented.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:publicationRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Publication Rd Project Id' ;
    rdfs:comment 'Foreign key reference to the R&D project that generated this publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'Full text of the publication abstract summarizing the research objectives, methods, results, and conclusions.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date the manuscript was accepted for publication by the journal or conference. Null for preprints and rejected submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authors rdf:type rdf:Property ;
    rdfs:label 'Authors' ;
    rdfs:comment 'Comma-separated list of all authors in publication order, including Genomics Biotech staff and external collaborators.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationCount rdf:type rdf:Property ;
    rdfs:label 'Citation Count' ;
    rdfs:comment 'Number of times the publication has been cited by other scientific works, as tracked by citation databases (e.g., Google Scholar, Web of Science).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conferenceName rdf:type rdf:Property ;
    rdfs:label 'Conference Name' ;
    rdfs:comment 'Name of the scientific conference where the abstract or presentation was delivered (e.g., ASHG, AGBT, AACR). Null for journal articles and preprints.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondingAuthorEmail rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Email' ;
    rdfs:comment 'Email address of the corresponding author for publication inquiries.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondingAuthorName rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Name' ;
    rdfs:comment 'Name of the corresponding author responsible for communication regarding the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Data Repository Url' ;
    rdfs:comment 'URL of the public data repository where the underlying research data is deposited (e.g., dbGaP, GEO, SRA). Null if data sharing is not required or not yet completed.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doi rdf:type rdf:Property ;
    rdfs:label 'Doi' ;
    rdfs:comment 'Unique Digital Object Identifier assigned to the publication for permanent citation and retrieval.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoEndDate rdf:type rdf:Property ;
    rdfs:label 'Embargo End Date' ;
    rdfs:comment 'Date when the embargo restrictions are lifted and the publication can be publicly disclosed. Null if no embargo applies.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether the publication is under embargo restrictions that prevent public disclosure until a specified date (True) or not (False).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuthorCount rdf:type rdf:Property ;
    rdfs:label 'External Author Count' ;
    rdfs:comment 'Number of external collaborators (non-Genomics Biotech) listed as authors on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstAuthorName rdf:type rdf:Property ;
    rdfs:label 'First Author Name' ;
    rdfs:comment 'Name of the first author listed on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactFactor rdf:type rdf:Property ;
    rdfs:label 'Impact Factor' ;
    rdfs:comment 'Journal Impact Factor (JIF) of the journal at the time of publication, reflecting the average number of citations to recent articles. Null for conferences and preprints.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalAuthorCount rdf:type rdf:Property ;
    rdfs:label 'Internal Author Count' ;
    rdfs:comment 'Number of Genomics Biotech employees or contractors listed as authors on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Date' ;
    rdfs:comment 'Date when the IP clearance review was completed and the publication was approved for submission.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Status' ;
    rdfs:comment 'Status of intellectual property review and clearance for the publication: pending (under review), cleared (approved for publication), restricted (requires redaction), or blocked (cannot be published).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalName rdf:type rdf:Property ;
    rdfs:label 'Journal Name' ;
    rdfs:comment 'Name of the peer-reviewed journal where the article was published (e.g., Nature, Science, Cell). Null for conference presentations and preprints.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or index terms describing the publication content for search and categorization.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAccessClassification rdf:type rdf:Property ;
    rdfs:label 'Open Access Classification' ;
    rdfs:comment 'Classification of the publication\'s open access status: gold (fully open access journal), green (self-archived), hybrid (open access option in subscription journal), bronze (free to read without license), or closed (subscription-only).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preprintServer rdf:type rdf:Property ;
    rdfs:label 'Preprint Server' ;
    rdfs:comment 'Name of the preprint server where the manuscript was posted (e.g., bioRxiv, medRxiv). Null for published articles and conference presentations.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationCode rdf:type rdf:Property ;
    rdfs:label 'Publication Code' ;
    rdfs:comment 'Business-assigned unique code for tracking and referencing the publication internally.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date the article was officially published online or in print, or the date the preprint was posted.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the publication: draft (in preparation), submitted, under review, accepted, published, rejected, or withdrawn. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|published|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Classification of the publication format: peer-reviewed journal article, conference abstract, conference presentation, preprint (bioRxiv/medRxiv), review article, or book chapter.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pubmedIdentifier rdf:type rdf:Property ;
    rdfs:label 'Pubmed Identifier' ;
    rdfs:comment 'PubMed unique identifier for the publication in the National Library of Medicine database. Null for non-indexed publications.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Application Submission Date' ;
    rdfs:comment 'Date the grant application was submitted to the funding agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date the grant was officially awarded by the funding agency. This is the principal business event timestamp for the grant lifecycle.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Classification of the grant mechanism (e.g., R01 Research Project Grant, R21 Exploratory/Developmental Research Grant, R43/R44 Small Business Innovation Research (SBIR), U01 Research Project Cooperative Agreement, contract, philanthropic grant). [ENUM-REF-CANDIDATE: R01|R21|R43|R44|U01|U54|P01|P50|contract|cooperative_agreement|philanthropic — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coInvestigatorNames rdf:type rdf:Property ;
    rdfs:label 'Co Investigator Names' ;
    rdfs:comment 'Comma-separated list of co-investigator names contributing to the grant project.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Summary of key compliance requirements attached to this grant (e.g., NIH Genomic Data Sharing Policy, HIPAA compliance, IRB oversight, animal welfare assurance, export control restrictions).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBudgetPeriodAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period Amount Usd' ;
    rdfs:comment 'Funding amount for the current budget period in United States Dollars (USD).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBudgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period End Date' ;
    rdfs:comment 'End date of the current budget period. Triggers annual progress reporting and continuation application requirements.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBudgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period Start Date' ;
    rdfs:comment 'Start date of the current budget period (typically one year for multi-year grants). Used for annual funding increments.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Direct Costs Usd' ;
    rdfs:comment 'Total direct costs portion of the grant award in United States Dollars (USD). Excludes indirect costs (Facilities and Administrative costs).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Due Date' ;
    rdfs:comment 'Due date for the final technical and financial report, typically 90 days after project period end date.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingAgency rdf:type rdf:Property ;
    rdfs:label 'Funding Agency' ;
    rdfs:comment 'Name of the organization providing the grant funding (e.g., National Institutes of Health, Biomedical Advanced Research and Development Authority, National Science Foundation, European Commission, Bill & Melinda Gates Foundation).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAgencyDivision rdf:type rdf:Property ;
    rdfs:label 'Funding Agency Division' ;
    rdfs:comment 'Specific division, institute, or program within the funding agency (e.g., National Human Genome Research Institute (NHGRI), National Cancer Institute (NCI), NSF Division of Biological Infrastructure).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the grant. Pending: application submitted, awaiting decision. Active: grant awarded and project period is current. Suspended: temporarily halted by agency or institution. Closed: project period completed, final reporting submitted. Terminated: grant ended prematurely.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iacucApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Iacuc Approval Number' ;
    rdfs:comment 'IACUC approval number if the grant involves animal research. Required for compliance with Animal Welfare Act and PHS Policy.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostRatePercent rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Percent' ;
    rdfs:comment 'Negotiated indirect cost rate (Facilities and Administrative rate) applied to the grant, expressed as a percentage of direct costs.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Indirect Costs Usd' ;
    rdfs:comment 'Total indirect costs (Facilities and Administrative costs) portion of the grant award in United States Dollars (USD).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date the most recent progress or financial report was submitted to the funding agency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'Due date for the next scheduled progress or financial report to the funding agency. Used for compliance tracking and alert generation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentCount rdf:type rdf:Property ;
    rdfs:label 'Patent Count' ;
    rdfs:comment 'Number of patent applications or issued patents resulting from this grant. Required for Intellectual Property (IP) reporting to federal funders under Bayh-Dole Act.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Program Officer Email' ;
    rdfs:comment 'Email address of the program officer for grant-related communications.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOfficerName rdf:type rdf:Property ;
    rdfs:label 'Program Officer Name' ;
    rdfs:comment 'Name of the program officer or grants management specialist assigned to oversee this grant at the funding agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Project Period End Date' ;
    rdfs:comment 'End date of the total project period for which funding is approved. Marks the effective-until date of the grant agreement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Period Start Date' ;
    rdfs:comment 'Start date of the total project period for which funding is approved. Marks the effective-from date of the grant agreement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalanceUsd rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Usd' ;
    rdfs:comment 'Remaining unspent balance of the grant award in United States Dollars (USD). Calculated as total_award_amount_usd minus actual_spend_usd.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingSchedule rdf:type rdf:Property ;
    rdfs:label 'Reporting Schedule' ;
    rdfs:comment 'Frequency of required progress reports to the funding agency (e.g., annual Research Performance Progress Report (RPPR), semi-annual technical reports, quarterly financial reports).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapGrantFundCode rdf:type rdf:Property ;
    rdfs:label 'Sap Grant Fund Code' ;
    rdfs:comment 'SAP fund code or grant account code used to segregate grant financial transactions in the general ledger.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAwardAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Award Amount Usd' ;
    rdfs:comment 'Total funding amount awarded for the entire project period, including direct and indirect costs, in United States Dollars (USD).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Design Algorithm Version' ;
    rdfs:comment 'Version number of the design tool or algorithm used, enabling reproducibility and traceability of design methodology.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCode rdf:type rdf:Property ;
    rdfs:label 'Design Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier assigned to the molecular design for tracking and cataloging purposes.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable name assigned to the molecular design artifact for identification and reference purposes.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Date' ;
    rdfs:comment 'Date when the intellectual property disclosure was filed for this molecular design.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meltingTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Melting Temperature Celsius' ;
    rdfs:comment 'Calculated melting temperature (Tm) of the oligonucleotide or primer in degrees Celsius, critical for PCR and hybridization protocols.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organismStrain rdf:type rdf:Property ;
    rdfs:label 'Organism Strain' ;
    rdfs:comment 'Specific strain, cell line, or variant of the target organism for which this design is optimized.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceLengthBp rdf:type rdf:Property ;
    rdfs:label 'Sequence Length Bp' ;
    rdfs:comment 'Total length of the molecular design sequence measured in base pairs for DNA/RNA constructs.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Celsius' ;
    rdfs:comment 'Recommended or actual storage temperature for the molecular construct in degrees Celsius to maintain stability.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisMethod rdf:type rdf:Property ;
    rdfs:label 'Synthesis Method' ;
    rdfs:comment 'Technical method or platform used for synthesizing the molecular construct, such as solid-phase synthesis, gene synthesis, or PCR amplification.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerAccountId rdf:type rdf:Property ;
    rdfs:label 'Header Account Id' ;
    rdfs:comment 'Foreign key reference to the party (location, facility, or contact) where the order should be physically delivered. May differ from bill-to party for multi-site organizations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:headerBillToPartyAccountId rdf:type rdf:Property ;
    rdfs:label 'Header Bill To Party Account Id' ;
    rdfs:comment 'Foreign key reference to the party responsible for payment. Invoices are sent to this party. May differ from ship-to party for centralized billing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:headerCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Header Customer Account Id' ;
    rdfs:comment 'Foreign key reference to the customer account that placed this order. Links to the customer master data entity.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:headerSoldToPartyAccountId rdf:type rdf:Property ;
    rdfs:label 'Header Sold To Party Account Id' ;
    rdfs:comment 'Foreign key reference to the primary contracting party. Represents the legal entity entering into the sales agreement.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date when the order was physically delivered to the customer site and accepted. Used for SLA performance measurement and revenue recognition triggers.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason code or description for order cancellation. Null for non-cancelled orders. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'Date when the order was confirmed to ship from the fulfillment center or manufacturing facility. Null until shipment is confirmed.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'SAP distribution channel code representing the route-to-market for this order (e.g., direct, wholesale, online). Used for pricing and logistics determination.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'SAP division code representing the product line or business segment (e.g., sequencing systems, array products, clinical genomics). Used for P&L reporting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSalesDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Sales Document Number' ;
    rdfs:comment 'SAP S/4HANA SD module sales document number. System-of-record identifier linking this order to the ERP order-to-cash process.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether this order contains items subject to export control regulations (ITAR, EAR, dual-use technology). True requires additional compliance review and documentation.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Relevant Flag' ;
    rdfs:comment 'Indicates whether this order is for a customer operating under GxP regulations (GMP, GLP, GCP). True triggers additional quality documentation, certificates of analysis, and audit trail requirements.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Standard trade terms defining the responsibilities of buyers and sellers for delivery, insurance, and risk transfer. Based on ICC Incoterms 2020. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms clause where risk and cost transfer occurs (e.g., San Diego Port, customer facility address).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the customer order was officially placed and accepted into the system. Represents the business event timestamp for order creation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the sales order. Used in customer communications, invoices, and shipment tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Order Source Channel' ;
    rdfs:comment 'Sales channel through which the order was received. Direct sales for company sales team, distributor for channel partners, OEM for original equipment manufacturer partnerships, e-commerce for online store, field application for scientific support-driven sales.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the sales order. Tracks progression from initial creation through fulfillment and delivery. On-hold indicates temporary suspension due to credit check, regulatory review, or customer request. [ENUM-REF-CANDIDATE: draft|open|in_fulfillment|shipped|delivered|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order based on the primary product category being purchased: instrument (sequencing systems, arrays), reagent (library prep kits, flow cells), consumable (tips, plates), sequencing service (WGS, WES, targeted panels), software license (bioinformatics tools), or support contract (maintenance, training).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Agreed payment conditions specifying when payment is due. Net terms indicate days from invoice date. Prepaid requires payment before shipment. [ENUM-REF-CANDIDATE: net_30|net_60|net_90|due_on_receipt|prepaid|credit_card|letter_of_credit — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productClassification rdf:type rdf:Property ;
    rdfs:label 'Product Classification' ;
    rdfs:comment 'Regulatory classification of the ordered products. RUO (Research Use Only) for non-clinical research, IVD (In Vitro Diagnostic) for FDA-cleared clinical use, LDT (Laboratory Developed Test) for CLIA-certified lab use, CE-IVD for European clinical diagnostic use.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Customer-requested date for order delivery. Used for logistics planning and SLA commitment calculation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'Geographic sales office or region responsible for this order. Used for territory management and sales performance tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP sales organization code representing the legal entity or business unit responsible for this sale. Used for revenue recognition and reporting segmentation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCarrier rdf:type rdf:Property ;
    rdfs:label 'Shipping Carrier' ;
    rdfs:comment 'Name of the logistics carrier or freight forwarder handling shipment (e.g., FedEx, UPS, DHL, specialized biotech logistics provider).' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Logistics method for order delivery. Specialized cold chain required for temperature-sensitive reagents and biological materials. Customer pickup for local instrument installations.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service level tier determining turnaround time commitments and fulfillment priority. Critical tier for time-sensitive clinical or research projects.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field for special delivery, packaging, or handling requirements (e.g., temperature control, hazmat labeling, installation coordination, security clearance requirements).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Tat Commitment Date' ;
    rdfs:comment 'Date by which the order must be delivered to meet the SLA commitment. Calculated from order date plus SLA tier turnaround time. Used for performance tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalNetValue rdf:type rdf:Property ;
    rdfs:label 'Total Net Value' ;
    rdfs:comment 'Total order value before taxes, fees, and adjustments. Sum of all line item net values in the order currency.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total order value including all taxes, fees, shipping charges, and adjustments. Final amount to be invoiced to the customer.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax amount applied to the order, including sales tax, VAT, GST, or other applicable taxes based on ship-to jurisdiction.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for shipment monitoring. Null until order ships. Used for customer self-service tracking and delivery confirmation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique identifier for the order line item. Primary key for the order line entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:ivdTestCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ivd Test Catalog Id' ;
    rdfs:comment 'Foreign key linking to clinical.test_catalog. Business justification: Order lines for clinical testing services reference the specific test from the catalog. Required for order fulfillment, specimen routing, TAT tracking, and billing. Core business process linking comme' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCatalog .

ind:labelingId rdf:type rdf:Property ;
    rdfs:label 'Labeling Id' ;
    rdfs:comment 'Foreign key linking to regulatory.labeling. Business justification: IVD and reagent order lines must reference the regulatory-approved labeling version to ensure the correct labeling is fulfilled. EU IVDR/FDA 21 CFR requires labeling version traceability per order lin' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Labeling .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Foreign key linking to product.pricing. Business justification: Pricing Audit and Contract Compliance: Order lines must reference the specific product.pricing record applied at order time. Supports revenue recognition, contract price verification, and pricing audi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pricing .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date when the line item was shipped from the warehouse or manufacturing facility. Null if not yet shipped.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Delivery date confirmed by Available-to-Promise (ATP) check and production planning. Represents the committed delivery date to the customer.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed for delivery based on Available-to-Promise (ATP) check and inventory availability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Cumulative quantity that has been shipped and delivered to the customer across all shipments for this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority level for fulfillment and shipping of this line item. Influences warehouse picking sequence and carrier service selection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount amount applied to this line item including volume discounts, promotional discounts, and customer-specific pricing agreements.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Discount percentage applied to the list price for this line item. Calculated as (line_discount_amount / (list_unit_price * ordered_quantity)) * 100.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Hazardous material classification code if the product contains dangerous goods requiring special shipping compliance. References UN number and shipping class.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'SAP SD item category code that controls line item processing behavior. TAN=Standard Item, ZSEQ=Sequencing Service, ZKIT=Reagent Kit, ZINS=Instrument, ZSVC=Service, ZCON=Consumable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the sales order. Determines the ordering and display sequence of line items.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current fulfillment status of the order line item. Tracks the line through its lifecycle from order entry to delivery completion. [ENUM-REF-CANDIDATE: open|confirmed|in_production|ready_to_ship|partially_shipped|fully_shipped|delivered|cancelled|on_hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listUnitPrice rdf:type rdf:Property ;
    rdfs:label 'List Unit Price' ;
    rdfs:comment 'Standard catalog list price per unit before any discounts or adjustments. Expressed in order currency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Net Unit Price' ;
    rdfs:comment 'Net price per unit after applying all applicable discounts and before taxes. Expressed in order currency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value for this line item calculated as net_unit_price * ordered_quantity, before taxes. Expressed in order currency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity not yet shipped or fulfilled. Calculated as ordered_quantity minus delivered_quantity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the product ordered by the customer as specified in the original sales order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Regulatory classification of the product. RUO=Research Use Only, IVD=In Vitro Diagnostic, CE-IVD=European Conformité Européenne IVD, LDT=Laboratory Developed Test.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingServiceType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Service Type' ;
    rdfs:comment 'Type of Next-Generation Sequencing (NGS) service when product_type is sequencing_service. WGS=Whole Genome Sequencing, WES=Whole Exome Sequencing. Empty for non-sequencing products.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'Organizational unit responsible for shipping activities for this line item. Determines shipping logistics and carrier selection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax jurisdiction and rate code applied to this line item. Determines applicable sales tax, VAT, or GST calculation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Required storage and shipping temperature condition for the product. Critical for reagent and biological sample integrity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total value for this line item including taxes. Calculated as line_net_value + tax_amount. Expressed in order currency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Committed Turnaround Time (TAT) in days from order confirmation to delivery for this line item. Critical SLA metric for sequencing services.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotationId rdf:type rdf:Property ;
    rdfs:label 'Quotation Id' ;
    rdfs:comment 'Unique system-generated identifier for the quotation record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quotation .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Reference to the specific customer contact person who requested or received the quotation.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Boolean indicator whether this quotation requires management approval before submission to customer due to special pricing, terms, or high value.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of competitor who won the business if quotation was lost to competition. Used for competitive intelligence and market analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedToOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Converted To Order Flag' ;
    rdfs:comment 'Boolean indicator whether this quotation has been converted to a sales order. True: quotation accepted and order created; False: quotation still pending or rejected.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Notes' ;
    rdfs:comment 'Special instructions or terms communicated to the customer on the quotation document. Printed on customer-facing quotation PDF.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Named delivery location or Incoterms location for the quoted goods (e.g., customer facility address, port name).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTier rdf:type rdf:Property ;
    rdfs:label 'Discount Tier' ;
    rdfs:comment 'Discount tier applied to this quotation. Standard: list price; Volume: quantity-based discount; Strategic: key account pricing; Promotional: campaign offer; Custom: special approval pricing.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP SD distribution channel through which products are sold. Two-character code (e.g., direct sales, distributor, online).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP SD division representing the product line or business unit. Two-character code (e.g., sequencing instruments, reagents, services).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpQuotationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Quotation Document Number' ;
    rdfs:comment 'SAP S/4HANA SD module quotation document number. Ten-digit numeric identifier from the source ERP system.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order placement to delivery at customer site. Used for customer planning and SLA commitment.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Three-letter Incoterms 2020 code defining delivery terms and risk transfer point (e.g., EXW, FOB, CIF, DDP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Net Quoted Value' ;
    rdfs:comment 'Final net quotation value after applying discounts and adding taxes. Total amount customer will pay if quotation is accepted.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP SD payment terms code defining due date calculation and cash discount conditions (e.g., Net 30, Net 60, 2/10 Net 30).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionsApplied rdf:type rdf:Property ;
    rdfs:label 'Pricing Conditions Applied' ;
    rdfs:comment 'Comma-separated list of SAP SD pricing condition types applied to this quotation (e.g., PR00 base price, K004 volume discount, MWST tax).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Primary product category being quoted. Instrument: sequencing or array platforms; Reagent: chemistry kits; Consumable: flow cells, cartridges; Service: sequencing-as-a-service; Software: bioinformatics licenses; Bundle: multi-product package.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Date' ;
    rdfs:comment 'Date the quotation was created and issued to the customer. Business event timestamp for quotation generation.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Business-facing unique quotation document number used for customer communication and reference. Format: QT-YYYYNNNN.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the quotation. Draft: being prepared; Submitted: sent to customer; Accepted: customer approved; Rejected: customer declined; Expired: validity period lapsed; Withdrawn: seller cancelled.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationType rdf:type rdf:Property ;
    rdfs:label 'Quotation Type' ;
    rdfs:comment 'Classification of quotation by business purpose. Standard: catalog products; Custom: configured solutions; Renewal: subscription extension; Upgrade: existing customer expansion; Trial: evaluation offer.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text explanation of quotation rejection or withdrawal. Captures customer feedback for continuous improvement.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP SD sales organization responsible for this quotation. Four-character alphanumeric code representing the selling entity.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPricingJustification rdf:type rdf:Property ;
    rdfs:label 'Special Pricing Justification' ;
    rdfs:comment 'Business justification for non-standard pricing or discounts exceeding standard approval thresholds. Required for audit and compliance when custom pricing is applied.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Value' ;
    rdfs:comment 'Total monetary value of the quotation including all line items, before discounts and taxes. Gross quotation amount.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Start date of the quotation validity period. Pricing and terms are binding from this date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'End date of the quotation validity period. Quotation expires after this date unless extended or converted to order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationLineId rdf:type rdf:Property ;
    rdfs:label 'Quotation Line Id' ;
    rdfs:comment 'Unique identifier for the quotation line item. Primary key for this entity.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionRoutingId rdf:type rdf:Property ;
    rdfs:label 'Production Routing Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_routing. Business justification: Custom genomics product quoting: production routing defines standard lead times and labor/machine costs used to populate delivery_lead_time_days and quoted_unit_price on quotation lines for custom seq' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionRouting .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier of the sales representative or system user who created this quotation line item. Provides accountability and audit trail for quotation authorship.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order acceptance to product delivery or service completion. Represents the Turnaround Time (TAT) commitment for this line item.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value for this quotation line calculated as quoted_unit_price multiplied by quoted_quantity. Represents the subtotal for this line item before taxes and shipping.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Standard catalog list price per unit before any discounts or adjustments. Represents the published price from the official price list for the product or service.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group classification for the quoted product. Groups similar products for procurement, pricing, and reporting purposes within the enterprise resource planning system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User identifier of the person who last modified this quotation line item. Tracks who made the most recent changes to pricing, configuration, or status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD pricing condition type code that determines how the quoted price was calculated. Identifies the specific pricing rule, discount scheme, or surcharge applied to this line item.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of the product or service being quoted. Represents the number of units, kits, instruments, or service hours proposed to the customer.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Actual unit price quoted to the customer after applying discounts, volume pricing, or negotiated rates. This is the effective price per unit that will be charged if the quotation is accepted.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequencingCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Sequencing Coverage Depth' ;
    rdfs:comment 'Target coverage depth specification for sequencing services expressed as fold coverage (e.g., 30X, 100X). Indicates how many times each base position will be sequenced on average. Applicable when product_category is sequencing_service.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for line-specific special handling instructions, custom configuration notes, or customer-requested modifications. Communicates unique requirements to fulfillment and operations teams.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'Tax classification code determining applicable tax rates and rules for this line item. Used for Value Added Tax (VAT), Goods and Services Tax (GST), or sales tax calculation based on product type and jurisdiction.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date until which this quotation line item pricing and terms remain valid. After this date, pricing may need to be re-quoted. Defines the end of the quotation validity period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which this quotation line item pricing and terms become valid. Defines the beginning of the quotation validity period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Unique identifier for the outbound delivery document. Primary key.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.complaint. Business justification: Delivery issues (temperature excursions, damaged shipments, cold chain failures, late delivery) trigger customer complaints. Complaint investigations reference delivery records (tracking, temperature ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:finishedGoodsReleaseId rdf:type rdf:Property ;
    rdfs:label 'Finished Goods Release Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.finished_goods_release. Business justification: GMP distribution authorization: delivery of IVD reagents and clinical genomics products is only permitted after finished goods release approval. Direct FK enforces this regulatory control, enables aut' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinishedGoodsRelease .

ind:fulfillmentInstructionId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Instruction Id' ;
    rdfs:comment 'Foreign key linking to order.fulfillment_instruction. Business justification: A fulfillment_instruction is the operational directive that triggers the creation of a delivery document. Linking delivery.fulfillment_instruction_id -> order.fulfillment_instruction.fulfillment_instr' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentInstruction .

ind:shipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Cold-chain and hazmat delivery compliance: genomics biotech deliveries of reagents and instruments must be validated against the canonical customer site address (biosafety level, cold-chain eligibilit' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Reference to the warehouse or distribution center from which the delivery is being fulfilled.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Reference to the logistics carrier or shipping company responsible for transporting the delivery.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier or shipping company (e.g., FedEx, UPS, DHL, specialized cold-chain provider).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code - a unique 2-4 letter code used to identify transportation companies in North America.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether this delivery requires temperature-controlled cold-chain logistics to maintain reagent and consumable integrity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the delivery contains dangerous goods or hazardous materials requiring special handling and documentation per IATA/DOT regulations.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Planned or actual date when the delivery is scheduled to reach the customer.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery document (created, picked, packed, goods issued, in transit, delivered, cancelled). [ENUM-REF-CANDIDATE: created|picked|packed|goods_issued|in_transit|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery based on fulfillment method and handling requirements (standard, rush, cold-chain, hazardous materials, direct ship, drop ship).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known business identifier for the delivery document, typically a 10-digit SAP delivery number.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Carrier-provided estimated date when the shipment will be delivered to the customer. Used for customer communication and SLA monitoring.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Number' ;
    rdfs:comment 'Customs export declaration number for international shipments, required for regulatory compliance and border clearance.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'Date when goods were physically issued from the warehouse and inventory was decremented. Critical for revenue recognition and inventory accounting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Status of the goods issue posting (not issued, partially issued, fully issued, reversed).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when goods issue was posted in the ERP system. Used for audit trail and SLA tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of individual packages or handling units in the delivery.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging used for the delivery (standard box, insulated box, dry ice shipper, gel pack shipper, cryogenic shipper, pallet).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Url' ;
    rdfs:comment 'URL link to the electronic proof of delivery document or signature capture from the carrier system.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Reference number for the Safety Data Sheet document providing hazard information and safe handling instructions for chemical reagents and consumables.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation mode used for the delivery (ground, air, ocean, cold-chain ground, cold-chain air, courier).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for cold-chain shipments to ensure product stability and quality.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for cold-chain shipments to ensure product stability and quality.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the delivery including packaging materials, measured in kilograms. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of the delivery excluding packaging materials, measured in kilograms. Represents the actual product weight.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN number identifying hazardous substances for international transport (e.g., UN1845 for dry ice). Required when dangerous_goods_flag is true.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.batch_record. Business justification: GMP goods issue control: delivery of IVD reagents and clinical genomics products requires confirming the batch record is approved before shipment. Direct FK enables automated release verification at g' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:inventoryTransactionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Transaction Id' ;
    rdfs:comment 'Foreign key linking to reagent.inventory_transaction. Business justification: GMP lot traceability requires linking each delivery line to the inventory transaction that posted the goods issue. Enables audit trail from customer shipment back to exact stock movement — mandatory f' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryTransaction .

ind:salesOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Id' ;
    rdfs:comment 'Reference to the specific sales order line item being fulfilled by this delivery line. Establishes one-to-one or many-to-one fulfillment relationship.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:sourceStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Storage Location Id' ;
    rdfs:comment 'Foreign key linking to reagent.storage_location. Business justification: GMP traceability requires recording which qualified storage location a reagent lot was picked from for each delivery. The existing plain-text storage_location_code is a denormalization of reagent.stor' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:coldChainHandlingInstruction rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Handling Instruction' ;
    rdfs:comment 'Temperature control requirements for shipping and storage of this product. Critical for reagent stability and assay performance. Specifies required temperature range during transit.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where this product was manufactured. Required for customs documentation and trade compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLineStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Status' ;
    rdfs:comment 'Overall lifecycle status of this delivery line. Tracks progression from order release through goods issue and shipment. [ENUM-REF-CANDIDATE: open|in_picking|picked|packed|goods_issued|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'The quantity of product being shipped on this delivery line. Represents the actual amount picked, packed, and dispatched to the customer.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsIssueQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Quantity' ;
    rdfs:comment 'The quantity for which goods issue has been posted in the ERP system. Represents the inventory reduction and financial posting amount. May differ from delivery quantity in case of partial shipments.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Gross weight of the product on this delivery line in kilograms, including all packaging materials. Used for carrier billing and freight planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International harmonized system code for customs classification. Determines duty rates, import restrictions, and trade statistics reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValueAmount rdf:type rdf:Property ;
    rdfs:label 'Line Value Amount' ;
    rdfs:comment 'Total monetary value of this delivery line based on the delivered quantity and unit price. Used for shipment insurance valuation and customs declaration.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this product lot or batch was manufactured. Used for shelf-life calculation, quality tracking, and regulatory traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the product on this delivery line in kilograms, excluding packaging. Used for shipping cost calculation and customs documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current status of the packing process for this delivery line. Indicates whether the item has been placed in shipping containers with appropriate cold-chain or hazmat packaging.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Status' ;
    rdfs:comment 'Current status of the warehouse picking process for this delivery line. Tracks progression from pick list generation through physical item retrieval.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Product Regulatory Status' ;
    rdfs:comment 'Regulatory classification of the product being shipped. RUO (Research Use Only) for research products, IVD (In Vitro Diagnostic) for clinical products, CE-IVD for European market, FDA-cleared/approved for US clinical use.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume occupied by this delivery line item in cubic meters. Used for warehouse space planning and freight optimization.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Unique identifier for the shipment record. Primary key.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:destinationAddressId rdf:type rdf:Property ;
    rdfs:label 'Destination Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Temperature-sensitive shipment routing compliance: genomics biotech shipments of sequencing reagents and kits require cold-chain validation against the customer site address record (cold_chain_eligibl' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:carrierSlaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the carrier failed to meet the committed delivery Service Level Agreement (SLA). True if actual delivery date exceeds estimated delivery date by the SLA tolerance threshold.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Unique tracking identifier assigned by the carrier for real-time shipment visibility and proof of delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'Customer-provided purchase order number, project code, or internal reference for shipment tracking and invoice reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight and logistics cost charged by the carrier for this shipment, in the company\'s reporting currency. Used for Cost of Goods Sold (COGS) calculation and profitability analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'United Nations (UN) hazard classification code for hazardous materials in the shipment (e.g., Class 6.2 for infectious substances, Class 9 for miscellaneous). Null if hazmat_flag is false.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials requiring special handling, labeling, and regulatory documentation per Department of Transportation (DOT) or International Air Transport Association (IATA) regulations. True if hazmat present.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterms code defining the division of costs, risks, and responsibilities between seller and buyer for international shipments (e.g., DDP = Delivered Duty Paid, FOB = Free On Board). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the shipment contents for insurance purposes. Used to determine coverage limits and premium calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the insurance value amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of individual packages, boxes, or containers included in this shipment. Used for receiving verification and inventory reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference identifier or URI to the signed proof of delivery document (e.g., signature image, electronic confirmation). Used for dispute resolution and audit trail.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date the shipment departed from the origin facility. Used for Turnaround Time (TAT) calculation and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business-facing unique shipment identifier used for tracking and customer communication. Format: SHP-xxxxxxxxxx.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. Values: booked (carrier confirmed), in_transit (en route), out_for_delivery (final mile), delivered (received by customer), exception (delay or issue), cancelled (shipment voided).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tat Compliance Status' ;
    rdfs:comment 'Indicates whether the shipment met the customer-committed Turnaround Time (TAT) from order placement to delivery. Values: compliant (delivered within TAT), at_risk (approaching deadline), breached (missed TAT), not_applicable (no TAT commitment).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureLogReference rdf:type rdf:Property ;
    rdfs:label 'Temperature Log Reference' ;
    rdfs:comment 'Reference identifier or URI to the detailed temperature monitoring log file (e.g., data logger serial number, cloud storage path). Used for compliance audit and quality investigation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold-chain shipments. Null for non-temperature-controlled shipments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for cold-chain shipments. Null for non-temperature-controlled shipments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric size of the shipment in cubic meters. Used for dimensional weight pricing and warehouse space planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging materials. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Id' ;
    rdfs:comment 'Primary key for return_authorization' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnAuthorization .

ind:fieldSafetyActionId rdf:type rdf:Property ;
    rdfs:label 'Field Safety Action Id' ;
    rdfs:comment 'Foreign key linking to regulatory.field_safety_action. Business justification: Recall and FSCA management: return authorizations in genomics biotech are frequently initiated by field safety corrective actions (FSCAs) for IVD kits or sequencing instruments. Direct FK enables reca' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldSafetyAction .

ind:originalCoaId rdf:type rdf:Property ;
    rdfs:label 'Original Coa Id' ;
    rdfs:comment 'Foreign key linking to reagent.coa. Business justification: QC re-inspection of returned reagents requires comparing current condition against the original release CoA. Linking return_authorization to reagent.coa via original_coa_id supports GMP deviation inve' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:primaryReturnHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Header Id' ;
    rdfs:comment 'Reference to the original sales order from which this return originated.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:returnDeliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Return Delivery Line Id' ;
    rdfs:comment 'Foreign key linking to order.delivery_line. Business justification: A return authorization references the specific delivery line that was physically shipped to the customer. Linking return_authorization.return_delivery_line_id -> order.delivery_line.delivery_line_id e' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryLine .

ind:returnOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Return Order Line Id' ;
    rdfs:comment 'Foreign key linking to order.line. Business justification: A return authorization is typically initiated for a specific order line item (specific SKU, lot, serial number, quantity). While return_authorization has primary_return_header_id -> order.header, link' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:returnStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Return Storage Location Id' ;
    rdfs:comment 'Foreign key linking to reagent.storage_location. Business justification: Returned reagents must be directed to a designated GMP-qualified quarantine or return storage location. Linking return_authorization to storage_location enables warehouse staff to route returned lots ' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Boolean indicator whether this return requires a formal CAPA investigation and corrective action plan.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference to the financial credit memo document issued to the customer upon return approval.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Final disposition decision for the returned goods based on inspection results (restock, quarantine, destroy, rework, scrap, return-to-vendor).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Boolean indicator whether this return triggered a GMP deviation investigation due to quality or compliance concerns.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Restocking fee charged to the customer for processing the return, if applicable per return policy.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizedDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorized Date' ;
    rdfs:comment 'Date when the return authorization was approved and RMA number was issued.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnCreditedDate rdf:type rdf:Property ;
    rdfs:label 'Return Credited Date' ;
    rdfs:comment 'Date when the credit memo was issued and the customer account was credited.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of units being returned by the customer.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the return request.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the return reason provided by the customer or customer service representative.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Return Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the warehouse or facility.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Return Requested Date' ;
    rdfs:comment 'Date when the customer initially requested the return authorization.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of shipping the returned goods, which may be borne by the customer or the company depending on return reason.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return authorization workflow. [ENUM-REF-CANDIDATE: requested|authorized|in-transit|received|inspected|credited|rejected|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Return Value Amount' ;
    rdfs:comment 'Total monetary value of the returned goods in the transaction currency.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-known return authorization number issued to the customer for tracking and processing the return.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the root cause identified during return investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Unique identifier for each order status transition event. Primary key for the order status event log.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Name of the upstream data source or integration pipeline that delivered this event record (e.g., SAP_SD_CDC, Salesforce_API, Manual_Entry).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of this event within the lifecycle of the parent order (1 for first transition, 2 for second, etc.). Enables chronological reconstruction of order history.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The expected delivery date communicated to the customer at the time of this status transition. Updated as the order progresses through fulfillment.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when this event record was ingested into the Databricks lakehouse. Distinct from event_timestamp, which represents the business event time.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Is Reversal Flag' ;
    rdfs:comment 'Indicates whether this status transition represents a reversal or rollback of a previous status (e.g., moving from shipped back to in_fulfillment due to a return). True for backward transitions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The order status after this transition event. Captures the to-state in the order lifecycle state machine. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|in_fulfillment|shipped|delivered|completed|cancelled|on_hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status change (e.g., email, SMS, customer portal). Null if no notification was sent.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether an automated customer notification (email, SMS) was sent for this status transition. Supports customer communication audit.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level of the order at the time of this status transition. Affects SLA targets and fulfillment sequencing.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The order status immediately before this transition event. Captures the from-state in the order lifecycle state machine. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|in_fulfillment|shipped|delivered|completed|cancelled|on_hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why the order status was reversed or rolled back. Null for forward-progressing transitions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier tracking number assigned when the order status transitions to shipped. Null for pre-shipment status transitions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachSeverity rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Severity' ;
    rdfs:comment 'Classification of the severity of the SLA breach based on how much the TAT exceeded the target (e.g., minor for <4 hours late, major for >24 hours late).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Flag' ;
    rdfs:comment 'Indicates whether this status transition represents a contractual SLA milestone (e.g., order-confirmed, shipped-on-time, delivered-on-time). True if this event is an SLA checkpoint.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMilestoneName rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Name' ;
    rdfs:comment 'Name of the SLA milestone associated with this status transition (e.g., Order Confirmation, Shipment Dispatch, Delivery Completion). Null if not an SLA milestone.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'Unique transaction or event identifier from the source system (SAP SD document number, Salesforce event ID) that triggered this status change. Enables traceability back to the originating system.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status transition (e.g., customer_request, inventory_available, quality_hold, shipment_dispatched).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Description' ;
    rdfs:comment 'Free-text explanation or additional context describing why the order status changed. Provides human-readable detail beyond the reason code.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatElapsedHours rdf:type rdf:Property ;
    rdfs:label 'Tat Elapsed Hours' ;
    rdfs:comment 'Total elapsed time in hours from order creation to this status transition. Enables TAT tracking and performance analysis against committed delivery timelines.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'The source system or application that initiated this status transition (e.g., SAP SD for fulfillment updates, Salesforce CRM for order entry, manual override by user).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByUserName rdf:type rdf:Property ;
    rdfs:label 'Triggered By User Name' ;
    rdfs:comment 'Full name of the user who triggered the status change. Supports audit trail and accountability for manual interventions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationQualificationId rdf:type rdf:Property ;
    rdfs:label 'Installation Qualification Id' ;
    rdfs:comment 'Foreign key linking to instrument.installation_qualification. Business justification: For regulated genomics/IVD instrument installations, the fulfillment instruction must reference the IQ record confirming GxP-compliant installation was completed. This links commercial order fulfillme' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstallationQualification .

ind:pickStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Pick Storage Location Id' ;
    rdfs:comment 'Foreign key linking to reagent.storage_location. Business justification: Fulfillment instructions for cold-chain reagents must specify the exact GMP-qualified storage location from which goods are picked. Linking to reagent.storage_location enables pick-list generation tie' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Timestamp when fulfillment was successfully completed (shipment dispatched, installation signed off, or license activated). Used for TAT compliance reporting and customer notification.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualExecutionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Start Timestamp' ;
    rdfs:comment 'Timestamp when fulfillment execution actually began (warehouse pick started, field engineer arrived on site, or activation process initiated). Used for TAT performance measurement.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionConfirmationSignature rdf:type rdf:Property ;
    rdfs:label 'Completion Confirmation Signature' ;
    rdfs:comment 'Digital signature or confirmation code from customer or field engineer acknowledging successful fulfillment completion. Used for proof of delivery, installation acceptance, or service completion.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for shipment notifications, installation appointment confirmations, and service dispatch updates. Used for automated customer communication.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the individual at the delivery location authorized to receive shipment or coordinate installation. Used for carrier delivery confirmation and field service appointment scheduling.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for delivery coordination, installation scheduling, or service dispatch communication. Used by carriers and field service engineers.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs authority reference number for international shipments. Required for cross-border fulfillment to comply with import/export regulations and tariff classification.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current state of the fulfillment instruction in its execution lifecycle. Pending = awaiting assignment; Assigned = allocated to facility or team; In_Progress = actively being executed; Completed = successfully fulfilled; Cancelled = instruction voided; On_Hold = temporarily suspended; Failed = execution unsuccessful. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|cancelled|on_hold|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'U.S. Commerce Department Export Control Classification Number for dual-use technology and controlled items. Required for sequencing instruments and bioinformatics software with encryption. Ensures compliance with Export Administration Regulations (EAR).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNotes rdf:type rdf:Property ;
    rdfs:label 'Failure Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for fulfillment failure or cancellation. Captured by warehouse staff, field engineer, or logistics coordinator.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code explaining why fulfillment execution failed or was cancelled. None = no failure. Used for root cause analysis and process improvement. [ENUM-REF-CANDIDATE: address_invalid|recipient_unavailable|customs_hold|damaged_in_transit|installation_site_not_ready|technical_issue|cancelled_by_customer|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationAppointmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Appointment Timestamp' ;
    rdfs:comment 'Scheduled date and time for instrument installation or field service visit. Applicable for install and service_dispatch instruction types. Coordinated with customer and field service engineer availability.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Business-readable unique identifier for the fulfillment instruction, formatted as FI- followed by 10 digits. Used for tracking and communication with warehouse, logistics, and field service teams.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Category of fulfillment action required. Ship = standard pick-pack-ship; Install = instrument installation with field service engineer; Service_Dispatch = field service task; Activate = software license or cloud service activation; Sample_Kit_Dispatch = sequencing service sample collection kit; Cold_Chain_Ship = temperature-controlled logistics for reagents/enzymes.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseActivationKey rdf:type rdf:Property ;
    rdfs:label 'License Activation Key' ;
    rdfs:comment 'Unique activation key for software license or cloud service entitlement. Applicable for activate instruction type. Generated by license management system and delivered to customer via secure channel.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListNumber rdf:type rdf:Property ;
    rdfs:label 'Packing List Number' ;
    rdfs:comment 'Reference to the warehouse packing list document detailing items included in shipment. Used for shipment verification and customs documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Execution Date' ;
    rdfs:comment 'Planned date for fulfillment execution (ship date, installation date, or service dispatch date). Used for capacity planning and customer communication.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Carrier Code' ;
    rdfs:comment 'Standard carrier identifier for logistics provider (e.g., FEDEX, UPS, DHL, WORLDCOURIER). Applicable for ship and cold_chain_ship instruction types. Null for non-shipping fulfillment.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Shipping Service Level' ;
    rdfs:comment 'Carrier service tier selected for shipment. Overnight = next-day delivery; Two_Day = 2-business-day; Ground = standard surface; International_Express = expedited cross-border; International_Standard = economy cross-border; White_Glove = premium instrument delivery with setup.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Logistics and handling requirements for this fulfillment. Dry_Ice = dry ice packaging for frozen reagents; Controlled_Rate_Freezer = CRF shipping for enzyme stability; Ambient = room temperature; Refrigerated = 2-8°C cold chain; Hazmat = hazardous materials compliance; Fragile = delicate instruments; High_Value = security escort; Biohazard = biosafety protocols; None = standard handling. [ENUM-REF-CANDIDATE: dry_ice|controlled_rate_freezer|ambient|refrigerated|hazmat|fragile|high_value|biohazard|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tat Deadline Timestamp' ;
    rdfs:comment 'Service Level Agreement (SLA) deadline by which this fulfillment instruction must be completed. Derived from order TAT commitment and used for SLA compliance monitoring.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether cold-chain temperature monitoring is required during transit. True for reagents, enzymes, and temperature-sensitive consumables requiring Good Distribution Practice (GDP) compliance. Triggers data logger inclusion in shipment.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo record. Primary key.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Reference' ;
    rdfs:comment 'Reference to the general ledger accounting document created for this credit memo. Links credit memo to financial postings in the ERP system.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'The ERP system billing document number associated with this credit memo. Used for financial reconciliation and audit trail in SAP FI/CO modules.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity issuing the credit memo. Used for legal entity reporting and statutory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center to which the credit memo impact is allocated for internal cost accounting and profitability analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross credit amount issued to the customer before tax adjustments. Represents the base value of goods or services being credited.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoType rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Type' ;
    rdfs:comment 'Classification of the credit memo based on the business reason for issuance. Determines accounting treatment and approval workflow.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized code indicating the specific reason for credit issuance. Used for root cause analysis, quality tracking, and process improvement. Examples: defective product, shipping damage, pricing error, SLA breach, customer satisfaction.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for issuing the credit memo. Provides context for audits, customer service, and dispute resolution.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date when the credit memo was officially issued to the customer. Represents the business event date for revenue reversal and accounts receivable adjustment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Reference to the user who last modified the credit memo record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which the credit will be returned to the customer. Determines cash flow impact and accounts receivable treatment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'Date when the credit memo was posted to the general ledger and customer account. May differ from issue_date due to batch processing or period-end adjustments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center for internal management reporting and segment profitability analysis. Tracks credit impact by business segment.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund payment was processed and sent to the customer. Null if payment method is account credit or offset.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Status of the refund payment process if the credit memo requires a cash refund. Not applicable for account credits or invoice offsets.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Reversal Flag' ;
    rdfs:comment 'Indicates whether this credit memo triggers a revenue reversal in the financial system. True for credits against recognized revenue (e.g., sequencing service orders with milestone-based recognition), false for credits that do not impact revenue (e.g., advance payment adjustments).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total credit amount including tax. Represents the full value credited to the customer account (credit_amount + tax_amount).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerPoId rdf:type rdf:Property ;
    rdfs:label 'Customer Po Id' ;
    rdfs:comment 'Unique identifier for the customer purchase order record. Primary key.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address specified on the customer purchase order. Used for invoice generation and accounts receivable processing.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address specified on the customer purchase order. Optional additional address detail.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the billing address specified on the customer purchase order. Used for tax jurisdiction determination and regulatory compliance.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal code or ZIP code component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact person listed on the purchase order for order-related communication.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the customer contact person listed on the purchase order for order-related inquiries and coordination.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact person listed on the purchase order for order-related communication.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerErpPoReference rdf:type rdf:Property ;
    rdfs:label 'Customer Erp Po Reference' ;
    rdfs:comment 'The internal purchase order reference or document ID from the customer\'s ERP system. Enables reconciliation between customer procurement records and Genomics Biotech sales records.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerErpSystem rdf:type rdf:Property ;
    rdfs:label 'Customer Erp System' ;
    rdfs:comment 'The name or identifier of the customer\'s ERP system from which the purchase order originated. Used for system integration and procurement process traceability.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poConsumedValue rdf:type rdf:Property ;
    rdfs:label 'Po Consumed Value' ;
    rdfs:comment 'The cumulative monetary value that has been consumed against this purchase order through fulfilled sales orders and invoices. Used to calculate remaining PO balance.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poIssueDate rdf:type rdf:Property ;
    rdfs:label 'Po Issue Date' ;
    rdfs:comment 'The date on which the customer formally issued the purchase order. This is the principal business event timestamp for the PO and serves as the contractual reference date.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'The customer-issued purchase order number as it appears on the formal procurement document. This is the externally-known identifier used for contractual reference and invoice matching.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Po Received Date' ;
    rdfs:comment 'The date on which Genomics Biotech received and registered the customer purchase order in SAP SD. Used for order processing SLA tracking and TAT measurement.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poRemainingBalance rdf:type rdf:Property ;
    rdfs:label 'Po Remaining Balance' ;
    rdfs:comment 'The remaining available monetary value on the purchase order calculated as PO total value minus PO consumed value. Indicates how much additional value can be fulfilled against this PO.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the customer purchase order. Open indicates available for fulfillment, partially-consumed indicates partial delivery against PO value, fully-consumed indicates PO value exhausted, cancelled indicates customer revocation, expired indicates validity period ended, on-hold indicates temporary suspension.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poTotalValue rdf:type rdf:Property ;
    rdfs:label 'Po Total Value' ;
    rdfs:comment 'The total authorized monetary value of the purchase order as stated by the customer. Represents the maximum amount that can be invoiced against this PO.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type indicating the procurement structure. Standard for one-time orders, blanket for recurring releases, framework for multi-year agreements, government for public sector contracts, contract for negotiated terms, spot for ad-hoc purchases.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Po Validity End Date' ;
    rdfs:comment 'The expiration date after which the purchase order is no longer valid for order fulfillment. Nullable for open-ended POs. Defines the end of the PO authorization period.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Po Validity Start Date' ;
    rdfs:comment 'The effective start date from which the purchase order is valid and can be used for order fulfillment. Defines the beginning of the PO authorization period.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the individual at the customer organization who initiated or requested the purchase order. Used for order verification and approval workflows.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingTerms rdf:type rdf:Property ;
    rdfs:label 'Shipping Terms' ;
    rdfs:comment 'The shipping and delivery terms specified on the customer purchase order, such as FOB, CIF, DDP, or other Incoterms. Defines responsibility for shipping costs and risk transfer.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialTermsNotes rdf:type rdf:Property ;
    rdfs:label 'Special Terms Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, conditions, or instructions noted on the customer purchase order that require attention during order fulfillment. May include delivery instructions, quality requirements, or contractual clauses.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPlanApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Approved Date' ;
    rdfs:comment 'Actual date when the corrective and preventive action plan was formally approved by Quality Assurance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target date by which the corrective and preventive action plan must be developed and approved.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed narrative describing the quality issue, nonconformance, or improvement opportunity that triggered the CAPA initiation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business-facing unique identifier for the CAPA, typically formatted per organizational numbering scheme (e.g., CAPA-2024-001). Used for external communication and regulatory submissions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record. Tracks progression from initiation through investigation, action implementation, effectiveness verification, and closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|effectiveness_check|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing an existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the CAPA was formally closed after successful completion of all actions and effectiveness verification. Marks the end of the CAPA lifecycle.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments and summary provided at CAPA closure, documenting the overall outcome, lessons learned, and any residual risks or follow-up actions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions planned or implemented to address the identified root cause and prevent recurrence of the nonconformance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Completed Date' ;
    rdfs:comment 'Actual date when the effectiveness verification was completed and results documented.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckCriteria rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Criteria' ;
    rdfs:comment 'Defined measurable criteria and acceptance thresholds used to verify that the implemented corrective and preventive actions have been effective in resolving the issue and preventing recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Due Date' ;
    rdfs:comment 'Target date by which the effectiveness verification of implemented actions must be completed. Typically scheduled after a defined monitoring period post-implementation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Outcome of the effectiveness verification assessment, indicating whether the implemented actions successfully resolved the issue and met the defined effectiveness criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpClassification rdf:type rdf:Property ;
    rdfs:label 'Gxp Classification' ;
    rdfs:comment 'Classification of the CAPA under applicable Good Practice regulations (GMP for manufacturing, GLP for laboratory, GCP for clinical, GDP for distribution, or non-GxP for non-regulated activities).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completed Date' ;
    rdfs:comment 'Actual date when all planned corrective and preventive actions were fully implemented and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationDueDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Due Date' ;
    rdfs:comment 'Target date by which all corrective and preventive actions must be fully implemented.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the CAPA was formally initiated in the quality system. Marks the start of the CAPA lifecycle and is used for turnaround time (TAT) tracking and regulatory reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiationSource rdf:type rdf:Property ;
    rdfs:label 'Initiation Source' ;
    rdfs:comment 'The triggering event or source that initiated the CAPA. Identifies the quality system input that identified the need for corrective or preventive action. [ENUM-REF-CANDIDATE: deviation|audit_finding|customer_complaint|oos_result|regulatory_inspection|management_review|risk_assessment|supplier_issue — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Actual date when the root cause investigation was completed and documented. Used for TAT metrics and compliance tracking.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date by which the root cause investigation must be completed. Driven by priority, severity, and regulatory requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mastercontrolRecordReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Record Reference' ;
    rdfs:comment 'Unique identifier of the CAPA record in MasterControl document control and training management system, used for SOP update tracking and training workflow integration.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Detailed description of the preventive actions planned or implemented to eliminate potential causes of nonconformance and prevent occurrence in other areas or products.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productImpact rdf:type rdf:Property ;
    rdfs:label 'Product Impact' ;
    rdfs:comment 'Indicates whether the quality issue has confirmed or potential impact on released product quality, safety, or performance. Drives product disposition and recall assessment.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The structured methodology used to identify the root cause of the quality issue (e.g., 5-Why, Fishbone/Ishikawa, Fault Tree Analysis, FMEA, Pareto analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Narrative summary of the identified root cause(s) of the quality issue, documenting the outcome of the root cause analysis investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the underlying quality issue based on potential impact to product quality, patient safety, regulatory compliance, or business operations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdatesRequired rdf:type rdf:Property ;
    rdfs:label 'Sop Updates Required' ;
    rdfs:comment 'Boolean flag indicating whether the CAPA requires updates to existing SOPs or creation of new SOPs to prevent recurrence. Triggers document control workflow in MasterControl.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the originating quality event (e.g., deviation number, audit finding ID, complaint number, OOS investigation number) that triggered this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Unique identifier of the CAPA record in Veeva Vault quality management system, used for controlled document linkage and audit trail integration.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSopNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Sop Number' ;
    rdfs:comment 'Document control number of the Standard Operating Procedure that was not followed or was inadequate, leading to the deviation.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the deviation was formally closed following QA approval of the investigation, impact assessment, and disposition decision. Represents lifecycle completion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Boolean indicator of whether affected customers must be notified of the deviation due to potential impact on product performance, safety, or data quality. Triggers customer communication workflow.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Externally-known unique business identifier for the deviation, typically system-generated and used in regulatory submissions and audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation: open (newly reported), under_investigation (root cause analysis in progress), pending_approval (awaiting QA sign-off), closed (investigation complete and approved), cancelled (determined not to be a deviation).' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Classification of the deviation by operational category: process (procedure departure), equipment (instrument malfunction), material (reagent/consumable issue), environmental (cleanroom/storage condition), documentation (record error), or personnel (training/qualification gap).' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final quality decision on the affected batch, lot, or data: accept (meets specifications despite deviation), reject (does not meet specifications), rework (reprocess to meet specifications), retest (repeat testing), use_as_is (acceptable with justification), scrap (destroy).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of containment actions taken immediately upon discovery of the deviation to prevent further impact, such as quarantine of affected materials, equipment shutdown, or process halt.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Date and time when the deviation actually occurred or was discovered during operations. May differ from reported_timestamp if deviation was identified retrospectively.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Product Impact Assessment' ;
    rdfs:comment 'Quality assessment determining whether the deviation affected product quality, safety, efficacy, or data integrity. Includes scientific justification for disposition decision.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Boolean indicator of whether the deviation meets criteria for mandatory reporting to regulatory authorities such as FDA (Field Alert Report, Medical Device Report) or EMA (Vigilance Report).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Deviation Flag' ;
    rdfs:comment 'Boolean indicator of whether this deviation is a recurrence of a previously identified and closed deviation, suggesting ineffective CAPA or systemic quality system weakness.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the deviation was first reported into the quality management system. Represents the business event timestamp for deviation initiation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysisSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Summary' ;
    rdfs:comment 'Summary of the investigation findings identifying the underlying systemic cause of the deviation. May reference formal RCA methodologies such as 5-Why, Fishbone, or Fault Tree Analysis.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityGrade rdf:type rdf:Property ;
    rdfs:label 'Severity Grade' ;
    rdfs:comment 'Risk-based severity classification of the deviation impact: critical (patient safety or data integrity risk), major (significant quality impact or regulatory non-compliance), minor (limited impact with no patient or product risk).' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeContactId rdf:type rdf:Property ;
    rdfs:label 'Auditee Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Customer site audits (GxP, CAP, ISO 15189 supplier audits) in genomics biotech require a named auditee contact for scheduling, notification, and follow-up. auditee_department_head is a denormalized pl' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:establishmentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Establishment Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.establishment_registration. Business justification: GMP/ISO 13485 audits are conducted at registered manufacturing establishments. FDA establishment inspections, notified body audits, and competent authority inspections are tied to specific facility re' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstablishmentRegistration .

ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of regulatory standards, frameworks, or requirements against which the audit is conducted. Examples: ISO 13485, FDA 21 CFR Part 820, CLIA 42 CFR Part 493, CAP accreditation requirements, GMP, ISO 15189.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business-facing unique audit identifier used in quality management systems and regulatory documentation. Format: AUD-NNNNNN.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope including processes, departments, systems, or standards being audited. Defines boundaries and focus areas for the audit activity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Tracks progression from planning through execution to closure. Planned indicates scheduled but not started; in_progress indicates active fieldwork; fieldwork_complete indicates data collection done; report_draft indicates findings being documented; report_final indicates report approved; closed indicates all follow-up actions complete; cancelled indicates audit was terminated before completion. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|report_draft|report_final|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its purpose and scope. Includes internal GMP (Good Manufacturing Practice) audits, ISO 13485 compliance audits, CLIA (Clinical Laboratory Improvement Amendments) and CAP (College of American Pathologists) readiness audits, supplier qualification audits, regulatory inspection readiness audits, and process-specific audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or major nonconformities identified during the audit. Critical findings require immediate corrective action and may impact product quality or regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentScope rdf:type rdf:Property ;
    rdfs:label 'Department Scope' ;
    rdfs:comment 'Comma-separated list of departments or functional areas included in the audit scope. Examples: Manufacturing, Quality Control, Research and Development, Regulatory Affairs.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the audit fieldwork in hours. Used for resource planning and audit efficiency metrics.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which follow-up audit or verification of corrective actions must be completed. Null if no follow-up is required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether follow-up audit or verification activities are required. True indicates that corrective actions must be verified through a subsequent audit or review.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the regulatory authority or certification body for which this audit serves as readiness preparation. Examples: FDA, EMA, CAP, CLIA, Notified Body. Null for internal audits not tied to external inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this audit is a regulatory inspection readiness audit or mock inspection. True indicates the audit simulates or prepares for an FDA, EMA, or other regulatory body inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date the final audit report was issued or approved. Marks the formal completion of audit documentation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk-based classification of the audit based on the criticality of the audited area, prior audit history, and potential impact on product quality or regulatory compliance. Used for audit prioritization and frequency determination.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date for the audit fieldwork to conclude. Used for audit scheduling and resource planning.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date for the audit to commence. Used for audit scheduling and resource planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names or identifiers. Includes all auditors, technical experts, and observers participating in the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings (observations, nonconformities, opportunities for improvement) identified during the audit. Detailed findings are tracked in the audit_finding product.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the earlier audit finding that this current finding repeats, if applicable. Used to track recurrence patterns.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:affectedDepartment rdf:type rdf:Property ;
    rdfs:label 'Affected Department' ;
    rdfs:comment 'Organizational department or business unit responsible for the process or area where the finding was identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'Business process or functional area impacted by the finding (e.g., Library Preparation, Sequencing QC, Document Control, Training Management, CAPA Process).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Affected Site Location' ;
    rdfs:comment 'Physical site, facility, or laboratory location where the finding was observed. Relevant for multi-site organizations.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Tracks progression from identification through response, verification, and closure. [ENUM-REF-CANDIDATE: open|under_investigation|response_submitted|pending_verification|verified_closed|rejected|reopened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Related Flag' ;
    rdfs:comment 'Indicates whether this finding is related to or triggered by customer complaints, product quality issues, or field performance problems.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataIntegrityIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Issue Flag' ;
    rdfs:comment 'Indicates whether the finding involves data integrity concerns such as incomplete records, missing audit trails, unauthorized data modification, or non-compliance with FDA 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaWarningLetterRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Warning Letter Related Flag' ;
    rdfs:comment 'Indicates whether this finding is related to or triggered by an FDA Warning Letter, 483 observation, or other regulatory inspection finding. Requires expedited response and executive visibility.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the finding. Critical: immediate risk to product safety or regulatory compliance; Major: significant GxP or quality system deviation; Minor: isolated procedural deviation; Observation: opportunity for improvement without regulatory impact.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the nonconformance, deficiency, or observation. Describes what was found, the gap between actual and expected state, and the potential impact.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the finding, typically formatted as audit number plus sequential finding number (e.g., AUD-2024-001-F01).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Type of finding identified. Nonconformance: failure to meet a specified requirement; Deficiency: gap in system or process; Observation: noted condition without immediate action; Opportunity for improvement: proactive enhancement suggestion.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Impact Flag' ;
    rdfs:comment 'Indicates whether the finding has direct impact on GxP-regulated activities (GMP, GLP, GCP). GxP findings require heightened scrutiny and formal quality system response.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the finding was first identified during the audit. Represents the business event timestamp for the finding discovery.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this finding record. Part of the electronic audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveEvidence rdf:type rdf:Property ;
    rdfs:label 'Objective Evidence' ;
    rdfs:comment 'Factual, verifiable evidence supporting the finding. May reference documents reviewed, records examined, observations made, interviews conducted, or data analyzed during the audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory requirement, standard clause, or guideline that the finding relates to (e.g., FDA 21 CFR 820.30, ISO 13485:2016 Section 7.3.2, CLIA 493.1256).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat of a previously identified and supposedly corrected issue. Repeat findings indicate ineffective CAPA and require escalation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredResponseType rdf:type rdf:Property ;
    rdfs:label 'Required Response Type' ;
    rdfs:comment 'Type of response action required to address the finding. CAPA required: formal corrective and preventive action; Correction only: immediate fix without preventive action; Observation acknowledgment: awareness without formal action; No action required: informational only.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Target date by which the auditee must submit a formal response to the finding. Typically 30 days for major findings, 60 days for minor findings, per organizational policy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseOverdueFlag rdf:type rdf:Property ;
    rdfs:label 'Response Overdue Flag' ;
    rdfs:comment 'Indicates whether the response submission is past the due date. Calculated field for tracking compliance with response timelines.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Actual date when the auditee submitted their formal response to the finding.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual responsible for the finding response. Used for notification and communication.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual assigned responsibility for responding to and resolving the finding. Typically a manager or process owner in the affected department.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Required Flag' ;
    rdfs:comment 'Indicates whether formal root cause analysis is required for this finding. Typically true for critical and major findings, false for minor findings and observations.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the effectiveness of corrective actions was verified and the finding was confirmed as resolved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that corrective actions have been implemented and are effective. Document review: examination of updated procedures; Follow-up audit: re-audit of the process; Process observation: direct observation of corrected process; Data analysis: review of performance metrics; Management review: executive assessment.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether formal verification of corrective action effectiveness is required before the finding can be closed. Typically true for critical and major findings.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the quality professional or auditor who performed the verification and approved closure of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Identifier of the product line or product family to which this document applies. Nullable for enterprise-wide documents. Links to product hierarchy master data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Identifier of the regulatory submission dossier or application with which this document is associated. Nullable if not part of a submission.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:supersededDocumentControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Controlled Document Id' ;
    rdfs:comment 'Identifier of the previous version of this document that this version replaces. Enables version lineage tracking. Nullable for initial versions.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'Date on which the document was moved to archival storage. Nullable if not yet archived.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivedFlag rdf:type rdf:Property ;
    rdfs:label 'Archived Flag' ;
    rdfs:comment 'Indicates whether the document has been moved to long-term archival storage. True if archived, False if active or accessible.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Identifier of the change control request or deviation that authorized the creation or revision of this document version. Links to CAPA or change management system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the document content. Determines access controls and distribution restrictions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of roles, departments, or individuals authorized to access or receive this document. Supports controlled distribution per ISO 13485.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level functional category grouping for the document. Supports cross-functional document organization and retrieval. [ENUM-REF-CANDIDATE: Quality|Manufacturing|R&D|Regulatory|Clinical|IT|Safety|Environmental|HR — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format or media type of the controlled document. Supports format-specific rendering and archival strategies. [ENUM-REF-CANDIDATE: PDF|Word|Excel|PowerPoint|HTML|XML|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the controlled document. Tracks progression through authoring, review, approval, activation, and retirement stages. [ENUM-REF-CANDIDATE: Draft|In Review|Approved|Effective|Superseded|Obsolete|Archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full descriptive title of the controlled document. Human-readable identity label.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the controlled document by its functional purpose within the quality management system. Categorical field that segments the document population. [ENUM-REF-CANDIDATE: SOP|Work Instruction|Specification|Validation Protocol|Batch Record|Form|Policy|Procedure|Test Method|Quality Manual — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Applied Flag' ;
    rdfs:comment 'Indicates whether an FDA 21 CFR Part 11 compliant electronic signature was applied to this document. True if electronically signed, False otherwise.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Reference identifier from an external system or regulatory authority (e.g., FDA submission number, ISO standard number, customer specification reference).' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the document was last formally reviewed for accuracy and continued applicability. Distinct from approval date; supports periodic review tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Used for completeness verification and printing logistics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained after obsolescence per regulatory and business requirements. Typical values: 5, 7, 10, or indefinite (represented as NULL or 9999).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Periodic review interval in months. Defines how frequently the document must be re-evaluated for continued accuracy and relevance. Typical values: 12, 24, 36 months.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionSummary rdf:type rdf:Property ;
    rdfs:label 'Revision Summary' ;
    rdfs:comment 'Brief narrative summary of changes made in this version compared to the previous version. Supports change traceability and impact assessment.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Document Reference' ;
    rdfs:comment 'Unique identifier of the document in the source system (Veeva Vault or MasterControl). Enables traceability back to the operational system of record.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether personnel must complete formal training on this document before performing related tasks. True if training is mandatory, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentAttempts rdf:type rdf:Property ;
    rdfs:label 'Assessment Attempts' ;
    rdfs:comment 'Number of attempts the trainee made to pass the assessment. Used for identifying training effectiveness issues and retraining needs.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal assessment (test, quiz, practical demonstration) is required to complete this training per Good Practice (GxP) requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved by the trainee on the training assessment, expressed as a percentage. Used to determine qualification status and identify retraining needs.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the qualified assessor who evaluated trainee competency. Required for regulatory inspection readiness and audit trail.' ;
