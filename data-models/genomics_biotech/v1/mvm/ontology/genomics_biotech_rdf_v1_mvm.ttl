    rdfs:comment 'True if the assay has received all required regulatory approvals for clinical use.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompanionAssay rdf:type rdf:Property ;
    rdfs:label 'Is Companion Assay' ;
    rdfs:comment 'Indicates whether the assay is a companion diagnostic for a specific therapy.' ;
    rdfs:domain ind:Assay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:price rdf:type rdf:Property ;
