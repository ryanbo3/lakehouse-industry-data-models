ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance verification status of the bundle.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Timestamp when the bundle record was first created in the system.' ;
