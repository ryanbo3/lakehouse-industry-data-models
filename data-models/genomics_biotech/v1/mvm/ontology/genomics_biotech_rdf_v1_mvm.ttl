    rdfs:comment 'Text describing criteria for sample inclusion in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDataUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Data Update Date' ;
    rdfs:comment 'Date of the most recent data refresh for the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phenotype rdf:type rdf:Property ;
    rdfs:label 'Phenotype' ;
    rdfs:comment 'Phenotypic characteristic(s) defining the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyTier rdf:type rdf:Property ;
    rdfs:label 'Privacy Tier' ;
    rdfs:comment 'Privacy classification tier for the cohort data.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date the cohort record was first created.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predecessorClinicalAssayId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Clinical Assay Id' ;
    rdfs:comment 'Self-referencing FK on clinical_assay (predecessor_clinical_assay_id)' ;
    rdfs:domain ind:Assay ;
