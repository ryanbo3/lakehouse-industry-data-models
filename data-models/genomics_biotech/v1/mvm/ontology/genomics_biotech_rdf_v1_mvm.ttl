    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:dataRetentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Data Retention Policy' ;
    rdfs:comment 'Reference to the internal policy governing data archiving and disposal.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingStatus rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Status' ;
    rdfs:comment 'Current policy governing external data access.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:design rdf:type rdf:Property ;
    rdfs:label 'Design' ;
    rdfs:comment 'Methodological framework of the study.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseArea rdf:type rdf:Property ;
    rdfs:label 'Disease Area' ;
    rdfs:comment 'Therapeutic or biological domain the study addresses.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total monetary amount allocated to the study.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMultiCenter rdf:type rdf:Property ;
    rdfs:label 'Is Multi Center' ;
    rdfs:comment 'Indicates whether the study is conducted across multiple sites.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfSites rdf:type rdf:Property ;
    rdfs:label 'Number Of Sites' ;
    rdfs:comment 'Count of distinct research locations participating in the study.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary scientific question or hypothesis the study seeks to answer.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of subjects enrolled in the study.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteLocations rdf:type rdf:Property ;
    rdfs:label 'Site Locations' ;
    rdfs:comment 'Comma-separated list of site identifiers or city/country codes.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Free-text explanation for the current status, e.g., cause of suspension.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'External reference code used in lab notebooks and regulatory filings.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDescription rdf:type rdf:Property ;
    rdfs:label 'Study Description' ;
    rdfs:comment 'Narrative summary of the study objectives and methods.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Human-readable title of the study.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Primary key for the bundle_component association' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBundleComponent rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Component' ;
    rdfs:comment 'Indicates whether this SKU is sold as part of a bundle or kit (true) or as a standalone item (false). Used to manage Bill of Materials (BOM) relationships. [Moved from sku: This BOOLEAN flag on the SKU table indicates whether the SKU participates in any bundle, but it cannot capture which bundles or the terms of participation. With the bundle_component association table in place, this information is derivable (a SKU is a bundle component if any bundle_component record references its sku_id). The flag becomes redundant and should be removed from sku to avoid denormalization and potential inconsistency.]' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryComponent rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Component' ;
    rdfs:comment 'Indicates whether this SKU is a required component of the bundle (true) or an optional/substitutable component (false). Belongs to the pairing because the same SKU may be mandatory in one bundle and optional in another.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityPerBundle rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Bundle' ;
    rdfs:comment 'Number of units of this SKU included in one bundle. Belongs to the bundle-SKU pairing because the same SKU may be included at different quantities in different bundles.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationRunId rdf:type rdf:Property ;
    rdfs:label 'Validation Run Id' ;
    rdfs:comment 'Primary key for the validation_run association' ;
    rdfs:domain ind:ValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Whether this run met the acceptance criteria defined in the validation protocol. Values: ACCEPTED, REJECTED, PENDING_REVIEW. Belongs to the relationship because acceptance is evaluated against the specific study\'s protocol criteria, not the batch\'s general quality disposition.' ;
    rdfs:domain ind:ValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runOutcome rdf:type rdf:Property ;
    rdfs:label 'Run Outcome' ;
    rdfs:comment 'The overall outcome of this specific validation run: PASS, FAIL, or INCONCLUSIVE. Distinct from batch disposition — a batch may be released (PASS disposition) but still FAIL a validation run criterion.' ;
    rdfs:domain ind:ValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'The sequential order of this batch within the validation study (e.g., 1, 2, 3). Required by regulatory guidance to demonstrate consecutive run consistency. Belongs to the relationship, not to the batch or study alone.' ;
    rdfs:domain ind:ValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructAssayEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Construct Assay Evaluation Id' ;
    rdfs:comment 'Primary key for the construct_assay_evaluation association' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concentrationUsed rdf:type rdf:Property ;
    rdfs:label 'Concentration Used' ;
    rdfs:comment 'The specific concentration at which the CRISPR construct was applied during evaluation in this assay program (e.g., nM, µg/mL). Varies per construct-assay pairing and is a property of the evaluation event, not of the construct or assay independently.' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'The date on which this construct was first evaluated within this assay development program. Supports regulatory traceability and timeline documentation for submission packages.' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inclusionRationale rdf:type rdf:Property ;
    rdfs:label 'Inclusion Rationale' ;
    rdfs:comment 'Scientific justification for including this specific CRISPR construct in this assay development program. Required for regulatory documentation (FDA 510(k), CE-IVD submissions) and internal R&D governance. Belongs to the evaluation relationship, not to the construct or assay independently.' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRole rdf:type rdf:Property ;
    rdfs:label 'Usage Role' ;
    rdfs:comment 'The functional role the CRISPR construct plays within this specific assay development program (e.g., positive control, test article, reference standard). This role is specific to the construct-assay pairing and cannot reside on either entity alone.' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatusInAssay rdf:type rdf:Property ;
    rdfs:label 'Validation Status In Assay' ;
    rdfs:comment 'The validation outcome for this specific construct within this specific assay development program. A construct may pass validation in one assay and fail in another — this status belongs to the pairing, not to either entity alone.' ;
    rdfs:domain ind:ConstructAssayEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSiteAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Test Site Authorization Id' ;
    rdfs:comment 'Primary key for the test_site_authorization association' ;
    rdfs:domain ind:TestSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isActiveOffering rdf:type rdf:Property ;
    rdfs:label 'Is Active Offering' ;
    rdfs:comment 'Indicates whether this test-site authorization is currently active and available for clinical order routing. False indicates the authorization has been suspended, expired, or retired.' ;
    rdfs:domain ind:TestSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
