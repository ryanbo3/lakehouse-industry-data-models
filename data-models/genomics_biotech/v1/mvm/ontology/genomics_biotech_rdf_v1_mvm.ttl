    rdfs:comment 'Text describing criteria for sample exclusion from the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderInclusion rdf:type rdf:Property ;
    rdfs:label 'Gender Inclusion' ;
    rdfs:comment 'Gender categories included in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region(s) covered by the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
