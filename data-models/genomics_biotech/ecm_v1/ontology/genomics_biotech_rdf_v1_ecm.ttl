    rdfs:range xsd:date .

ind:dealStage rdf:type rdf:Property ;
    rdfs:label 'Deal Stage' ;
    rdfs:comment 'Current sales stage of the registered deal.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endCustomerCity rdf:type rdf:Property ;
    rdfs:label 'End Customer City' ;
    rdfs:comment 'City where the end-customer is located.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endCustomerCountryCode rdf:type rdf:Property ;
    rdfs:label 'End Customer Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the end-customer location.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endCustomerName rdf:type rdf:Property ;
    rdfs:label 'End Customer Name' ;
    rdfs:comment 'Name of the end-customer organization for whom the partner is registering the deal.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endCustomerStateProvince rdf:type rdf:Property ;
    rdfs:label 'End Customer State Province' ;
    rdfs:comment 'State or province where the end-customer is located.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Close Date' ;
    rdfs:comment 'Anticipated date when the partner expects to close the deal with the end-customer.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value Amount' ;
    rdfs:comment 'Estimated total value of the registered deal in the specified currency.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerIncentiveTier rdf:type rdf:Property ;
    rdfs:label 'Partner Incentive Tier' ;
    rdfs:comment 'Incentive tier applicable to this deal registration based on partner program level.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the partner submitted the deal registration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Externally visible unique registration number assigned to this partner deal registration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Channel or system through which the partner submitted the deal registration.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the partner deal registration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise timestamp when the partner submitted the deal registration.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the deal registration was rejected.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:winProbabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Win Probability Percent' ;
    rdfs:comment 'Estimated probability of winning the deal, expressed as a percentage.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentPriceBookId rdf:type rdf:Property ;
    rdfs:label 'Parent Price Book Id' ;
    rdfs:comment 'Reference to the parent price book when this price book inherits or overrides pricing from another book, enabling hierarchical pricing structures.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'FK to finance.profit_center' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segment codes or names to which this price book applies (e.g., academic_research, clinical_diagnostics, pharma_r_and_d).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGeographies rdf:type rdf:Property ;
    rdfs:label 'Applicable Geographies' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region codes where this price book is valid (e.g., USA, CAN, GBR, EU).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSalesChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Sales Channels' ;
    rdfs:comment 'Comma-separated list of sales channel codes where this price book is used (e.g., direct_sales, distributor, online, oem_partner).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveBenchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Competitive Benchmark Source' ;
    rdfs:comment 'Source of competitive pricing intelligence used to inform this price book (e.g., market research firm, internal analysis, customer feedback). Confidential business information.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByName rdf:type rdf:Property ;
    rdfs:label 'Created By Name' ;
    rdfs:comment 'Full name of the user who created this price book record.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPolicy rdf:type rdf:Property ;
    rdfs:label 'Discount Policy' ;
    rdfs:comment 'Type of discount policy applied within this price book. None = list prices only; Volume Based = quantity discounts; Contract Based = negotiated contract pricing; Promotional = temporary promotional pricing; Custom = special pricing arrangements.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelCode rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Code' ;
    rdfs:comment 'SAP SD distribution channel code indicating the route-to-market for products priced under this book (e.g., direct, distributor, online).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSystemCode rdf:type rdf:Property ;
    rdfs:label 'External System Code' ;
    rdfs:comment 'Identifier for this price book in external systems such as Salesforce CRM or e-commerce platforms, used for cross-system integration and reconciliation.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultPriceBook rdf:type rdf:Property ;
    rdfs:label 'Is Default Price Book' ;
    rdfs:comment 'Boolean flag indicating whether this is the default price book for a given segment or geography when no specific price book is assigned. True = default; False = non-default.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Boolean flag indicating whether this price book is publicly available (e.g., published list prices) or confidential (e.g., negotiated contract pricing). True = public; False = confidential.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Maximum Discount Percentage' ;
    rdfs:comment 'Maximum allowable discount percentage that can be applied to prices in this price book, used for discount authorization controls.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum order value required to use this price book, expressed in the price book currency. Null indicates no minimum.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBookCode rdf:type rdf:Property ;
    rdfs:label 'Price Book Code' ;
    rdfs:comment 'Externally-known unique business identifier for the price book, used in commercial systems and customer communications.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookDescription rdf:type rdf:Property ;
    rdfs:label 'Price Book Description' ;
    rdfs:comment 'Detailed description of the price book purpose, scope, and applicability including business rationale and strategic intent.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookName rdf:type rdf:Property ;
    rdfs:label 'Price Book Name' ;
    rdfs:comment 'Human-readable name of the price book describing its purpose and target segment.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookStatus rdf:type rdf:Property ;
    rdfs:label 'Price Book Status' ;
    rdfs:comment 'Current lifecycle status of the price book. Draft = under construction; Pending Approval = submitted for review; Active = in use for pricing; Inactive = temporarily disabled; Archived = retired from use.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBookType rdf:type rdf:Property ;
    rdfs:label 'Price Book Type' ;
    rdfs:comment 'Classification of the price book by customer segment or channel. List = standard published pricing; Academic = research institution pricing; Government = public sector pricing; Biopharma = pharmaceutical and biotech company pricing; Distributor = channel partner pricing; OEM = original equipment manufacturer pricing.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy Notes' ;
    rdfs:comment 'Internal notes describing the strategic rationale, competitive positioning, and business objectives for this price book. Confidential business information.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresContract rdf:type rdf:Property ;
    rdfs:label 'Requires Contract' ;
    rdfs:comment 'Boolean flag indicating whether use of this price book requires an active contract or agreement with the customer. True = contract required; False = no contract required.' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Sales Organization Code' ;
    rdfs:comment 'SAP Sales and Distribution (SD) sales organization code that owns and manages this price book.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapConditionType rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Type' ;
    rdfs:comment 'SAP SD pricing condition type code associated with this price book for integration with SAP pricing procedures (e.g., PR00 for list price, K004 for customer-specific price).' ;
    rdfs:domain ind:PriceBook ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByEntryPriceBookEntryId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Entry Price Book Entry Id' ;
    rdfs:comment 'Reference to the price book entry that supersedes this entry. Used to maintain pricing history and version control when pricing is updated or replaced. Null for current active pricing that has not been superseded.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBookEntry .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Optional reference to a specific customer contract or master service agreement that governs this pricing. Used for customer-specific negotiated pricing tied to contractual commitments. Confidential commercial information.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'The current lifecycle status of the price book entry. Draft entries are under construction, Active entries are available for use, Inactive entries are temporarily disabled, Expired entries have passed their end date, Superseded entries have been replaced by newer pricing, and Pending Approval entries await commercial approval.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'The maximum quantity that can be ordered under this price book entry. Used to cap promotional pricing or enforce allocation limits for constrained products. Null indicates no maximum limit.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity that must be ordered for this price book entry to apply. Used to enforce volume commitments or packaging constraints. Null or 1 indicates no minimum order requirement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The commercial pricing strategy classification for this entry. Indicates whether this is standard list pricing, promotional pricing, volume-based pricing, customer-specific negotiated pricing, channel partner pricing, government contract pricing, or academic/research institution pricing. [ENUM-REF-CANDIDATE: Standard|Promotional|Volume|Customer Specific|Channel Partner|Government|Academic — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Optional promotional code or campaign identifier associated with this pricing entry. Links the price book entry to a specific marketing campaign or promotional offer. Null for standard non-promotional pricing.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'The effective unit price for a single unit of the catalog item. May differ from list price if volume discounts, promotional pricing, or customer-specific pricing applies. This is the price used in quotation and order processing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier1Percent rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Percent' ;
    rdfs:comment 'The discount percentage applied when the order quantity meets or exceeds the tier 1 quantity threshold. Expressed as a percentage (e.g., 5.00 for 5% discount). Null if no tier 1 discount applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier1Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 1 Quantity' ;
    rdfs:comment 'The minimum quantity threshold to qualify for the first volume discount tier. Orders meeting or exceeding this quantity receive the tier 1 discount percentage. Null if no volume discounting applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier2Percent rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Percent' ;
    rdfs:comment 'The discount percentage applied when the order quantity meets or exceeds the tier 2 quantity threshold. Expressed as a percentage (e.g., 10.00 for 10% discount). Null if no tier 2 discount applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier2Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 2 Quantity' ;
    rdfs:comment 'The minimum quantity threshold to qualify for the second volume discount tier. Orders meeting or exceeding this quantity receive the tier 2 discount percentage. Null if no tier 2 discount applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeDiscountTier3Percent rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Percent' ;
    rdfs:comment 'The discount percentage applied when the order quantity meets or exceeds the tier 3 quantity threshold. Expressed as a percentage (e.g., 15.00 for 15% discount). Null if no tier 3 discount applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountTier3Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Tier 3 Quantity' ;
    rdfs:comment 'The minimum quantity threshold to qualify for the third volume discount tier. Orders meeting or exceeding this quantity receive the tier 3 discount percentage. Null if no tier 3 discount applies.' ;
    rdfs:domain ind:PriceBookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractDocumentId rdf:type rdf:Property ;
    rdfs:label 'Contract Document Id' ;
    rdfs:comment 'Reference to the legal contract document or master service agreement governing this subscription in the document management system.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:parentSubscriptionReagentSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Parent Subscription Reagent Subscription Id' ;
    rdfs:comment 'Reference to a parent or master subscription if this subscription is part of a hierarchical subscription structure or enterprise agreement.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReagentSubscription .

ind:primaryReagentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reagent Employee Id' ;
    rdfs:comment 'Reference to the sales or account management employee responsible for this subscription relationship.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceContractId rdf:type rdf:Property ;
    rdfs:label 'Service Contract Id' ;
    rdfs:comment 'Foreign key linking to instrument.service_contract. Business justification: Bundled service+reagent contracts are common in genomics (e.g., instrument maintenance plus committed reagent volumes). Linking enables tracking bundled deals, enforcing contract dependencies (reagent' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date when the subscription was activated and became operational for order fulfillment.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'The cadence at which the customer is invoiced for subscription charges (e.g., monthly, quarterly, annually).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date when the subscription was cancelled by the customer or provider, if applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Days' ;
    rdfs:comment 'Number of days advance notice required from the customer to cancel the subscription without penalty.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Business reason or explanation for subscription cancellation, used for churn analysis and customer retention insights.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Committed Annual Volume' ;
    rdfs:comment 'The contracted quantity of reagent or consumable units the customer commits to purchase annually (e.g., flow cell count, kit quantity).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedVolumeToDate rdf:type rdf:Property ;
    rdfs:label 'Consumed Volume To Date' ;
    rdfs:comment 'Cumulative quantity of reagent or consumable units consumed by the customer since subscription start, tracked against committed volume.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionTrackingMethod rdf:type rdf:Property ;
    rdfs:label 'Consumption Tracking Method' ;
    rdfs:comment 'The method used to track customer consumption of subscribed reagents and consumables against committed volumes.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'The date of the most recent shipment of subscribed reagents or consumables to the customer.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Shipment Date' ;
    rdfs:comment 'The date of the next planned shipment of subscribed reagents or consumables to the customer.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overage Allowed Flag' ;
    rdfs:comment 'Indicates whether the customer is permitted to consume beyond the committed annual volume (True) or is capped at the commitment (False).' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overagePricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Overage Price Per Unit' ;
    rdfs:comment 'The unit price charged for consumption exceeding the committed annual volume, if overage is allowed.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pauseEndDate rdf:type rdf:Property ;
    rdfs:label 'Pause End Date' ;
    rdfs:comment 'The date when a paused subscription is scheduled to resume, if applicable.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pauseStartDate rdf:type rdf:Property ;
    rdfs:label 'Pause Start Date' ;
    rdfs:comment 'The date when the subscription was paused or temporarily suspended, if applicable.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'The contracted unit price for each reagent or consumable unit under this subscription agreement.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingVolume rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume' ;
    rdfs:comment 'Quantity of reagent or consumable units remaining in the subscription commitment that have not yet been consumed or shipped.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Shipment Frequency' ;
    rdfs:comment 'The cadence at which subscribed reagents and consumables are shipped to the customer (e.g., on-demand, monthly scheduled deliveries).' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionEndDate rdf:type rdf:Property ;
    rdfs:label 'Subscription End Date' ;
    rdfs:comment 'The date when the subscription agreement expires or terminates, after which the subscription terms no longer apply.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Human-readable business identifier for the subscription agreement, used in customer communications and invoicing.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStartDate rdf:type rdf:Property ;
    rdfs:label 'Subscription Start Date' ;
    rdfs:comment 'The date when the subscription agreement becomes effective and the customer can begin ordering under the subscription terms.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the subscription agreement indicating whether it is actively fulfilling orders or in a non-active state.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionTier rdf:type rdf:Property ;
    rdfs:label 'Subscription Tier' ;
    rdfs:comment 'Service level or pricing tier of the subscription, determining volume commitments, pricing, and service benefits.' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Category of reagent or consumable covered by this subscription agreement (e.g., flow cell subscriptions, library prep kit subscriptions, array consumable programs).' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'The unit in which the committed volume is measured (e.g., flow cells, kits, arrays, cartridges). [ENUM-REF-CANDIDATE: flow_cell|kit|array|cartridge|reagent_set|lane|run|unit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReagentSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentSubscriptionOrderId rdf:type rdf:Property ;
    rdfs:label 'Reagent Subscription Order Id' ;
    rdfs:comment 'Unique identifier for the reagent subscription release order or call-off order record.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReagentShipToAddressId rdf:type rdf:Property ;
    rdfs:label 'Primary Reagent Ship To Address Id' ;
    rdfs:comment 'Reference to the delivery address where the reagents should be shipped for this release order.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:quaternaryReagentLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Reagent Last Modified By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or automated process that last modified this release order record.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestedByContactId rdf:type rdf:Property ;
    rdfs:label 'Requested By Contact Id' ;
    rdfs:comment 'Reference to the customer contact person who submitted or authorized this release order.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:tertiaryReagentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Reagent Created By User Employee Id' ;
    rdfs:comment 'System user identifier of the person or automated process that created this release order record.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Reference to the warehouse or distribution center assigned to fulfill this release order based on inventory availability and proximity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the reagents were delivered to the customer, captured upon fulfillment completion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this release order requires internal approval before fulfillment, typically for high-value orders or special terms.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier or shipping company handling the delivery of this release order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Date confirmed by supply chain and logistics for delivery of the reagents, may differ from requested date based on availability and lead time.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes or comments related to this release order for internal coordination or customer communication.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'Channel or system through which this release order was submitted, enabling analysis of ordering patterns and channel effectiveness.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this release order for fulfillment scheduling and resource allocation.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Customer-provided purchase order number for their internal procurement tracking and invoice reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Release Order Date' ;
    rdfs:comment 'Date when the release order was created or submitted by the customer against the subscription agreement.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Release Order Number' ;
    rdfs:comment 'Business identifier for the release order or call-off order, externally visible and used for tracking and fulfillment coordination.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Release Order Status' ;
    rdfs:comment 'Current lifecycle status of the release order indicating its progression from creation through fulfillment. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|in_fulfillment|shipped|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Date by which the customer has requested delivery of the reagents specified in this release order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Internal requisition or request number from the customer organization that triggered this release order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the shipment associated with this release order, enabling customer visibility into delivery status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Method of shipment selected for delivery of reagents, critical for temperature-sensitive and time-sensitive materials.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text instructions for special handling requirements such as cold chain maintenance, hazardous material protocols, or delivery access instructions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionConsumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Subscription Consumption Percentage' ;
    rdfs:comment 'Percentage of the total subscription commitment consumed by this release order, calculated as order value divided by total subscription value.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLineItems rdf:type rdf:Property ;
    rdfs:label 'Total Line Items' ;
    rdfs:comment 'Count of distinct Stock Keeping Unit (SKU) line items included in this release order.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of this release order including all line items before taxes and adjustments, used for consumption tracking against subscription commitment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Ordered' ;
    rdfs:comment 'Aggregate quantity of all reagent units ordered across all line items in this release order, measured in base unit of measure.' ;
    rdfs:domain ind:ReagentSubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesQuotaId rdf:type rdf:Property ;
    rdfs:label 'Sales Quota Id' ;
    rdfs:comment 'Unique identifier for the sales quota record. Primary key for the sales quota entity.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Reference to the incentive compensation plan that governs commission and bonus calculations for this quota. Links quota attainment to payout rules.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompensationPlan .

ind:parentQuotaSalesQuotaId rdf:type rdf:Property ;
    rdfs:label 'Parent Quota Sales Quota Id' ;
    rdfs:comment 'Reference to the parent quota record in a hierarchical quota structure (e.g., a regional director\'s quota may be the parent of multiple territory manager quotas). Null for top-level quotas.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesQuota .

ind:primarySalesEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Employee Id' ;
    rdfs:comment 'Reference to the sales representative, territory manager, or regional director to whom this quota is assigned.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySalesModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Sales Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this quota record.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesHolderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Holder Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySalesCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sales Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created this quota record in the system.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The date and time when this quota was activated and became effective for attainment tracking. Null if not yet activated.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baseQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Base Quota Amount' ;
    rdfs:comment 'The baseline or standard quota amount before any adjustments, accelerators, or stretch targets are applied. Used to calculate attainment against the original target.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when this quota period was closed and final attainment was calculated. Null if still active or not yet closed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSegmentScope rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Scope' ;
    rdfs:comment 'The customer segment or market vertical to which this quota applies. Null or \'all_segments\' if quota applies across all customer types.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamilyScope rdf:type rdf:Property ;
    rdfs:label 'Product Family Scope' ;
    rdfs:comment 'The product family or product line to which this quota applies (e.g., NGS Sequencing Instruments, Microarray Platforms, CRISPR Gene Editing Tools, Reagents and Consumables, Bioinformatics Software). Null if quota applies to all products.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Quota Allocation Percentage' ;
    rdfs:comment 'The percentage of the parent quota (e.g., regional or team quota) allocated to this individual quota holder. Used in hierarchical quota rollup structures.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaAmount rdf:type rdf:Property ;
    rdfs:label 'Quota Amount' ;
    rdfs:comment 'The target value assigned to the quota holder for the specified period. For revenue and ARR quotas, this is a monetary amount. For unit and count quotas, this is a numeric quantity.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotaCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Quota Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary quota amounts (e.g., USD, EUR, GBP, JPY). Null for non-monetary quotas such as unit or count targets.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaHolderRole rdf:type rdf:Property ;
    rdfs:label 'Quota Holder Role' ;
    rdfs:comment 'The sales role or position of the quota holder within the commercial organization hierarchy.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Number' ;
    rdfs:comment 'Human-readable business identifier for the quota plan, typically following format QTA-YYYY-NNNNNN where YYYY is fiscal year and NNNNNN is sequential number.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period End Date' ;
    rdfs:comment 'The last day of the period for which this quota is effective, typically the end of the fiscal quarter or year.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Quota Period Start Date' ;
    rdfs:comment 'The first day of the period for which this quota is effective, typically the start of the fiscal quarter or year.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotaSource rdf:type rdf:Property ;
    rdfs:label 'Quota Source' ;
    rdfs:comment 'The methodology used to derive this quota: top-down allocation (executive-driven targets cascaded down), bottoms-up plan (aggregated from territory forecasts), hybrid (combination of both), carryover (rolled from prior period), or stretch target (aspirational goal beyond base quota).' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaStatus rdf:type rdf:Property ;
    rdfs:label 'Quota Status' ;
    rdfs:comment 'Current lifecycle status of the quota record. Draft: under construction; Approved: finalized but not yet active; Active: currently in effect; Closed: period completed; Suspended: temporarily inactive; Cancelled: voided before completion.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaType rdf:type rdf:Property ;
    rdfs:label 'Quota Type' ;
    rdfs:comment 'The category of quota target being measured: revenue (total bookings), instrument units (sequencer/array platform sales count), reagent ARR (Annual Recurring Revenue from reagent subscriptions), consumable units (kits and consumables volume), new logo count (new customer acquisition), or service contract value (support and maintenance contracts).' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quota Unit Of Measure' ;
    rdfs:comment 'The unit in which the quota amount is expressed: currency (for revenue quotas), units (for instrument/consumable volume), count (for new logos), or ARR (Annual Recurring Revenue for subscription products).' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Stretch Quota Amount' ;
    rdfs:comment 'An aspirational quota target above the base quota, often tied to accelerated commission rates or bonus tiers. Null if no stretch target is defined.' ;
    rdfs:domain ind:SalesQuota ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Reference to the parent territory in a hierarchical territory structure, enabling rollup reporting from sub-territories to regional or national territories. Null for top-level territories.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:accountCount rdf:type rdf:Property ;
    rdfs:label 'Account Count' ;
    rdfs:comment 'Number of customer accounts currently assigned to this territory. Updated periodically from account assignment rules.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualQuotaAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Quota Amount' ;
    rdfs:comment 'Annual sales quota target assigned to this territory in USD. Used for performance tracking and commission calculation.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentRule rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule' ;
    rdfs:comment 'Business rule or criteria used to automatically assign accounts to this territory (e.g., \'All academic institutions in postal codes 02101-02199 with annual revenue > $500K\'). Supports automated territory management.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageModel rdf:type rdf:Property ;
    rdfs:label 'Coverage Model' ;
    rdfs:comment 'Defines how accounts in this territory are covered: exclusive (single territory ownership), shared (multiple territories can claim same accounts), or overlay (specialized coverage layered on top of base territory).' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the primary business language in this territory (e.g., \'en\', \'de\', \'fr\', \'ja\', \'zh\'). Used for localized marketing and support materials.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Comma-separated list or range of postal codes included in this territory for precise geographic boundary definition (e.g., \'02101-02199,02201\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Strategic priority classification for resource allocation and management attention. Strategic territories receive highest investment and executive focus.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broader geographic region classification (e.g., \'North America\', \'EMEA\', \'Asia Pacific\', \'Latin America\') used for regional sales rollup and management hierarchy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Unique business identifier code for the territory used in sales operations and reporting. Typically alphanumeric format assigned by sales operations.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the sales territory, typically reflecting geographic or market segment focus (e.g., \'Northeast Academic Research\', \'West Coast Clinical Labs\').' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryStatus rdf:type rdf:Property ;
    rdfs:label 'Territory Status' ;
    rdfs:comment 'Current lifecycle status of the territory. Active territories are operational and assigned; inactive territories are no longer in use; pending territories are being set up; suspended territories are temporarily paused; archived territories are historical records.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory structure: geographic (region-based), named_account (specific high-value accounts), vertical (industry segment), hybrid (combination), strategic (key accounts), or overlay (specialized coverage).' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the territory\'s primary location (e.g., \'America/New_York\', \'Europe/London\', \'Asia/Tokyo\'). Used for scheduling and activity tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment Id' ;
    rdfs:comment 'Unique identifier for the territory assignment record. Primary key for the territory assignment entity.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTerritoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Territory Employee Id' ;
    rdfs:comment 'Reference to the sales representative assigned to the territory. Nullable when the assignment is for an account without a specific representative.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes providing additional context about the territory assignment, including special instructions, coverage agreements, transition plans, or historical context. Used for knowledge transfer and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Numeric priority ranking for this assignment when multiple representatives are assigned to the same territory or account. Lower numbers indicate higher priority. Used for commission crediting and conflict resolution. Typically ranges from 1 (highest) to 10 (lowest).' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business reason or trigger for creating this territory assignment. Territory realignment indicates periodic territory restructuring; new hire indicates assignment for a newly onboarded representative; promotion indicates role elevation; transfer indicates lateral move; account growth indicates expansion of coverage; strategic coverage indicates deliberate overlay for key accounts; backfill indicates replacement for departed representative; organizational change indicates structural reorganization; merger acquisition indicates integration activity; performance based indicates assignment driven by performance metrics. [ENUM-REF-CANDIDATE: territory_realignment|new_hire|promotion|transfer|account_growth|strategic_coverage|backfill|organizational_change|merger_acquisition|performance_based — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'The functional role of the sales representative in this territory assignment. Account Executive (AE) handles sales; Field Application Engineer (FAE) provides technical pre-sales support; Customer Success Manager (CSM) manages post-sales relationships; Clinical Specialist supports clinical assay applications; Technical Support provides troubleshooting; Sales Engineer provides technical sales expertise; Territory Manager oversees territory strategy; Regional Director manages multiple territories. [ENUM-REF-CANDIDATE: account_executive|field_application_engineer|customer_success_manager|clinical_specialist|technical_support|sales_engineer|territory_manager|regional_director — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the territory assignment. Active indicates the assignment is currently in effect; inactive indicates the assignment has been deactivated; pending indicates the assignment is scheduled but not yet effective; suspended indicates temporary hold; expired indicates the assignment has passed its end date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the territory assignment indicating the nature of the relationship. Primary indicates the main account owner or territory owner; overlay indicates additional coverage; specialist indicates subject matter expert coverage (e.g., Field Application Engineer (FAE), Clinical Specialist); support indicates secondary support role; backup indicates contingency coverage; temporary indicates short-term assignment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this territory assignment qualifies the representative for commission on sales within the territory or account. True indicates commission eligibility; False indicates non-commission assignment (e.g., support roles).' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Split Percentage' ;
    rdfs:comment 'The percentage of commission allocated to this representative for sales in this territory or account when multiple representatives share commission. Expressed as a decimal percentage (e.g., 50.00 for 50%). Must sum to 100.00 across all commission-eligible assignments for the same territory/account.' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSegmentFocus rdf:type rdf:Property ;
    rdfs:label 'Customer Segment Focus' ;
    rdfs:comment 'The customer segment or market vertical that this territory assignment targets. Academic research includes universities and research institutes; clinical diagnostics includes hospitals and diagnostic labs; pharmaceutical biotech includes drug development companies; agricultural genomics includes crop and livestock genomics; government includes public health and regulatory agencies; Contract Research Organization (CRO) includes outsourced research services; reference laboratory includes high-throughput testing facilities. [ENUM-REF-CANDIDATE: academic_research|clinical_diagnostics|pharmaceutical_biotech|agricultural_genomics|government|contract_research_organization|reference_laboratory — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossReviewId rdf:type rdf:Property ;
    rdfs:label 'Win Loss Review Id' ;
    rdfs:comment 'Unique identifier for the win/loss review record. Primary key for the win_loss_review product.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountExecutiveName rdf:type rdf:Property ;
    rdfs:label 'Account Executive Name' ;
    rdfs:comment 'Full name of the account executive who owned the opportunity and participated in the win/loss review.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Specific follow-up actions identified during the review to improve future win rates or address product/service gaps.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerInterviewConducted rdf:type rdf:Property ;
    rdfs:label 'Customer Interview Conducted' ;
    rdfs:comment 'Indicates whether a formal post-decision interview was conducted with the customer to gather feedback. True if interview occurred, False otherwise.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerStatedFactors rdf:type rdf:Property ;
    rdfs:label 'Customer Stated Factors' ;
    rdfs:comment 'Free-text capture of the decision factors as explicitly stated by the customer during post-decision interviews or feedback sessions.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the customer made the final purchase decision or when the opportunity was closed. Represents the real-world business event timestamp for this transaction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Final outcome of the commercial opportunity: won (Genomics Biotech secured the deal), lost (competitor won), no_decision (customer deferred or did not proceed), or cancelled (opportunity withdrawn).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date when the customer interview was conducted, if applicable. Nullable for reviews without formal customer interviews.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyLearnings rdf:type rdf:Property ;
    rdfs:label 'Key Learnings' ;
    rdfs:comment 'Summary of key insights and lessons learned from the win or loss that can inform future sales strategy and product development.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCompetitivenessRating rdf:type rdf:Property ;
    rdfs:label 'Pricing Competitiveness Rating' ;
    rdfs:comment 'Subjective assessment of how competitive Genomics Biotech pricing was relative to alternatives, based on customer feedback and market intelligence.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Reason Category' ;
    rdfs:comment 'Top-level category classifying the primary reason for the win or loss outcome. Used for systematic analysis of commercial performance drivers.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Primary Reason Detail' ;
    rdfs:comment 'Detailed explanation of the primary reason for the win or loss, providing specific context beyond the category classification.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFitRating rdf:type rdf:Property ;
    rdfs:label 'Product Fit Rating' ;
    rdfs:comment 'Assessment of how well the Genomics Biotech product or service met the customers technical and application requirements.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Specific product line within the product family (e.g., NovaSeq, MiSeq, TruSeq, Infinium).' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthRating rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Rating' ;
    rdfs:comment 'Assessment of the strength of the pre-existing relationship between Genomics Biotech and the customer account.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Human-readable business identifier for the win/loss review, formatted as WLR-YYYYNNNN where YYYY is year and NNNN is sequence number.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Full name of the individual who conducted the win/loss review (may be sales operations, commercial analyst, or sales manager).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesCycleDurationDays rdf:type rdf:Property ;
    rdfs:label 'Sales Cycle Duration Days' ;
    rdfs:comment 'Number of days from opportunity creation to decision date, representing the length of the sales cycle.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesManagerName rdf:type rdf:Property ;
    rdfs:label 'Sales Manager Name' ;
    rdfs:comment 'Full name of the sales manager who reviewed and approved the win/loss analysis.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Secondary Reason Category' ;
    rdfs:comment 'Secondary contributing factor category for the win or loss outcome. Nullable field for cases where multiple factors influenced the decision.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Secondary Reason Detail' ;
    rdfs:comment 'Detailed explanation of the secondary contributing reason, if applicable.' ;
    rdfs:domain ind:WinLossReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdmPolicyId rdf:type rdf:Property ;
    rdfs:label 'Mdm Policy Id' ;
    rdfs:comment 'Foreign key linking to data.mdm_policy. Business justification: Accounts must comply with master data management policies governing retention, access control, PHI handling, and cross-border transfer rules. Essential for regulatory compliance (GDPR, HIPAA) and oper' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MdmPolicy .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent account in a corporate hierarchy. Used for multi-site organizations, hospital systems, university networks, and corporate subsidiaries. Enables roll-up reporting and consolidated billing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Account has market_segment (STRING) which should be normalized to customer_segment_id FK. The customer_segment table exists as a reference table with segment_code, segment_name, regulatory_use_classif' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the customer account. Active (operational), Inactive (dormant but not closed), Suspended (temporarily blocked), Pending Approval (new account under review), Closed (permanently terminated).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Primary classification of the customer account based on business relationship and product usage. RUO (Research Use Only), IVD/Clinical (In Vitro Diagnostic), OEM (Original Equipment Manufacturer), Agricultural Genomics, Biopharma Partner, or Academic/Government Institution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTerritory rdf:type rdf:Property ;
    rdfs:label 'Assigned Territory' ;
    rdfs:comment 'Sales territory or region to which this account is assigned. Used for sales quota allocation, territory management, and field application scientist assignment.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit limit approved for the account in the account currency. Used for order approval workflows and credit risk management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'External identifier from Salesforce CRM Account object. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or operating name used by the customer if different from legal entity name. Common for research institutions and clinical laboratories.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Customer Number' ;
    rdfs:comment 'Customer master number from SAP S/4HANA SD (Sales and Distribution) module. Used for order processing, billing, and financial transactions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the customer account was first established in the system. Represents the start of the business relationship.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date when GDPR consent was obtained from the account. Used for consent lifecycle management and audit trails.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the account has provided consent for data processing under GDPR requirements. True if consent obtained, False otherwise. Required for EU-based accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaBaaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Baa Effective Date' ;
    rdfs:comment 'Effective date of the executed HIPAA Business Associate Agreement. Used for compliance tracking and audit readiness.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaBaaFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Baa Flag' ;
    rdfs:comment 'Indicates whether a HIPAA Business Associate Agreement is in place for this account. True if BAA executed, False otherwise. Required for clinical and IVD accounts handling Protected Health Information (PHI).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'Industry sector or vertical market segment of the customer. Examples: clinical diagnostics, pharmaceutical research, agricultural biotechnology, academic research, contract research organization.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent order placed by this account. Used for customer activity tracking, churn risk analysis, and reactivation campaigns.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official registered legal name of the customer organization or individual. Used for contracts, invoicing, and regulatory compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'Two-letter ISO language code for the accounts preferred communication language. Used for documentation, support, and correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier assigned to the account based on volume commitments, strategic relationship, and negotiated terms. Determines discount levels and special pricing agreements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line1' ;
    rdfs:comment 'First line of the primary business address for the account. Typically contains street number and street name.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line2' ;
    rdfs:comment 'Second line of the primary business address. Used for suite numbers, building names, department identifiers, or additional location details.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCity rdf:type rdf:Property ;
    rdfs:label 'Primary City' ;
    rdfs:comment 'City or municipality of the primary business address.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the primary business address. Used for regulatory compliance, export controls, and regional reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary business email address for account-level communication, notifications, and correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Postal Code' ;
    rdfs:comment 'Postal code or ZIP code of the primary business address. Format varies by country.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Primary State Province' ;
    rdfs:comment 'State, province, or administrative region of the primary business address. Format varies by country (two-letter state code in USA, province name in other jurisdictions).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentChangeReason rdf:type rdf:Property ;
    rdfs:label 'Segment Change Reason' ;
    rdfs:comment 'Business reason for the most recent market segment classification change. Examples: product portfolio shift, regulatory status change, acquisition, business model pivot.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Segment Effective Date' ;
    rdfs:comment 'Date when the current market segment classification became effective. Used for tracking segment transitions and historical analysis.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service level tier defining response times, technical support priority, and service commitments. Platinum (24/7 premium support), Gold (priority business hours), Silver (enhanced standard), Standard (basic support).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Tier' ;
    rdfs:comment 'Strategic importance tier assigned to the account. Key Account (top-tier strategic partners), Growth (high-potential emerging accounts), or Standard (regular commercial accounts). Drives resource allocation and service levels.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number for the customer entity. Format varies by jurisdiction (EIN in USA, VAT number in EU, GST number in other regions). Used for tax reporting and invoice compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT registration number for customers in VAT jurisdictions. Required for cross-border EU transactions and tax compliance.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the customer organization. Used for research, validation, and business intelligence.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique identifier for the account hierarchy relationship record.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy. References the downstream account such as subsidiary labs, satellite clinical genomics sites, or member institutions.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:billingRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Rollup Flag' ;
    rdfs:comment 'Indicates whether invoices for the child account should be consolidated and rolled up to the parent account for centralized billing. True for enterprise agreements with consolidated invoicing; false for independent billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessSegment rdf:type rdf:Property ;
    rdfs:label 'Business Segment' ;
    rdfs:comment 'Business segment classification for this hierarchical relationship, indicating the primary market focus. Enables segment-specific reporting and strategic analysis across RUO (Research Use Only), IVD (In Vitro Diagnostic), and other genomics applications.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Eligible Flag' ;
    rdfs:comment 'Indicates whether this hierarchical relationship qualifies for consolidated commercial reporting and volume-based pricing aggregation. True for relationships that should roll up revenue, orders, and usage; false for informational-only links.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the master service agreement, enterprise contract, or consortium agreement that governs this hierarchical relationship. Links to contract management systems for terms and conditions.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when the hierarchical relationship ends or is scheduled to terminate. Null for open-ended relationships. Enables time-bound hierarchy analysis and future-state planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the account hierarchy tree structure. Level 1 represents the top-level parent, with increasing numbers for deeper nested relationships. Enables depth-based queries and rollup aggregations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path representation of the full account hierarchy from root to current node, typically formatted as slash-delimited account identifiers (e.g., /1001/2045/3078/). Enables efficient ancestor and descendant queries without recursive joins.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the legal entity or company code under which this hierarchical relationship is registered for financial and regulatory reporting purposes. Aligns with ERP (Enterprise Resource Planning) company code structures.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or control the parent account holds over the child account. Used for financial consolidation, revenue attribution, and equity-based reporting. Null for non-ownership relationships such as consortium members or OEM (Original Equipment Manufacturer) resellers.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTierInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits volume-based pricing tiers and discounts from the parent account. True for subsidiaries and affiliates participating in enterprise pricing programs; false for independent pricing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryHierarchyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Hierarchy Flag' ;
    rdfs:comment 'Indicates whether this is the primary hierarchical relationship for the child account. True when this parent-child link is the authoritative path for reporting and aggregation; false for secondary or alternate hierarchies.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Relationship Description' ;
    rdfs:comment 'Free-text description providing additional context about the hierarchical relationship, such as the business rationale, legal structure details, or special commercial arrangements between parent and child accounts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchical relationship. Active relationships participate in volume-based pricing and consolidated reporting; inactive or terminated relationships are excluded.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classification of the hierarchical relationship between parent and child accounts. Defines the legal, operational, or commercial nature of the connection for consolidated reporting and pricing aggregation. [ENUM-REF-CANDIDATE: subsidiary|affiliate|consortium_member|oem_reseller|branch|division|franchise — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Hierarchy Code' ;
    rdfs:comment 'External identifier from Salesforce CRM (Customer Relationship Management) system representing this account hierarchy relationship. Enables traceability to the source system of record for customer master data.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Id' ;
    rdfs:comment 'Unique identifier for the laboratory accreditation record. Primary key.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Authorized Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Lab accreditations may be product-specific (e.g., CLIA-certified for specific IVD assays, CAP-accredited for certain tests). Required for regulatory compliance verification, product eligibility valida' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:laboratoryDirectorContactId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Director Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: accreditation has laboratory_director_name (STRING) which should be normalized to laboratory_director_contact_id FK to the contact table. Laboratory directors are key contacts responsible for accredit' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:laboratorySiteAddressId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Site Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: accreditation has embedded laboratory site address fields (laboratory_site_address_line_1, laboratory_site_address_line_2, laboratory_site_city, laboratory_site_state_province, laboratory_site_postal_' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'Type of laboratory accreditation or certification held by the customer. CLIA = Clinical Laboratory Improvement Amendments certification, CAP = College of American Pathologists accreditation, ISO_15189 = Medical Laboratories Quality and Competence certification, CE_IVD = Conformité Européenne In Vitro Diagnostic authorization, GxP = Good Practice Regulations compliance status, IRB = Institutional Review Board registration.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Standard interval in months between routine audits or inspections required by the accreditation body. Common values: 12, 24, 36.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the stored accreditation certificate or official documentation in the document management system (e.g., Veeva Vault).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gxp Compliance Status' ;
    rdfs:comment 'Compliance status with Good Practice regulations (GMP, GLP, GCP) relevant to the laboratory operations. Compliant = meets all GxP requirements, Non_Compliant = deficiencies identified, Not_Applicable = GxP not required for this lab type, Under_Review = compliance assessment in progress.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date the accreditation or certification was originally issued by the regulatory body.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ivdAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Ivd Authorized Flag' ;
    rdfs:comment 'Indicates whether the laboratory is authorized to perform clinical diagnostic testing with IVD-labeled products. True = IVD authorized, False = RUO only.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryDirectorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Director License Number' ;
    rdfs:comment 'Professional license number of the laboratory director (e.g., medical license, clinical laboratory scientist license). Required for regulatory compliance verification.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratorySiteName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Site Name' ;
    rdfs:comment 'Name of the specific laboratory facility or site covered by this accreditation. A customer may have multiple sites with separate accreditations.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent on-site or remote audit conducted by the accreditation body to verify compliance with standards.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next routine or surveillance audit by the accreditation body.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiHandlingAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Handling Authorized Flag' ;
    rdfs:comment 'Indicates whether the laboratory is authorized and compliant to handle Protected Health Information under HIPAA regulations. True = PHI handling authorized, False = not authorized.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Product Eligibility Flag' ;
    rdfs:comment 'Indicates whether this accreditation qualifies the customer to purchase and use In Vitro Diagnostic (IVD) products. True = eligible for IVD products, False = restricted to Research Use Only (RUO) products.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Target date by which the renewal application or re-certification process must be completed to avoid lapse in accreditation status.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceAccreditationCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Accreditation Code' ;
    rdfs:comment 'External identifier from the source Salesforce CRM system. Used for data lineage and reconciliation with the operational system of record.' ;
    rdfs:domain ind:Accreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the accreditation status was last verified by internal compliance or sales operations team against the issuing body\'s registry.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the address is currently active and available for use in transactions. True if active, False if inactive or deprecated.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of the address purpose: shipping destination for instruments and reagent kits, billing address for invoicing, legal registered address, laboratory site address, general mailing address, or headquarters location.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biosafetyLevel rdf:type rdf:Property ;
    rdfs:label 'Biosafety Level' ;
    rdfs:comment 'Biosafety containment level of the receiving laboratory site (BSL-1 through BSL-4) as defined by CDC/NIH guidelines. Determines permissible shipment of biological materials, reagents, and samples. BSL-1: minimal hazard; BSL-2: moderate hazard; BSL-3: serious/potentially lethal; BSL-4: dangerous/exotic. Not applicable for non-laboratory addresses.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Eligible Flag' ;
    rdfs:comment 'Indicates whether the address is equipped and authorized to receive temperature-sensitive shipments requiring cold-chain logistics (e.g., reagents, enzymes, library prep kits stored at -20°C or -80°C). True if eligible, False if not.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainTemperatureRange rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Temperature Range' ;
    rdfs:comment 'Acceptable temperature range for cold-chain shipments to this address (e.g., 2-8°C, -20°C, -80°C, ambient). Null if cold_chain_eligible_flag is False.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions for delivery to this address, including access codes, gate instructions, receiving hours, contact person for delivery, loading dock location, or other site-specific logistics guidance.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatReceivingAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Receiving Authorized Flag' ;
    rdfs:comment 'Indicates whether the address is authorized and equipped to receive hazardous materials shipments (e.g., flammable reagents, corrosive chemicals, biological agents) in compliance with DOT, IATA, and IMDG regulations. True if authorized, False if not.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatUnClassesAccepted rdf:type rdf:Property ;
    rdfs:label 'Hazmat Un Classes Accepted' ;
    rdfs:comment 'Comma-separated list of UN hazard classes that the receiving site is authorized to accept (e.g., Class 3: Flammable Liquids, Class 6.2: Infectious Substances, Class 8: Corrosives, Class 9: Miscellaneous). Null if hazmat_receiving_authorized_flag is False.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate in decimal degrees for precise geolocation of the address. Range: -90.0000000 to +90.0000000. Used for logistics routing and cold-chain planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and building identifier. First line of the physical or mailing address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, apartment, unit, building name, or other location details within the primary address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line for additional location details, department name, or care-of information.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingDockAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Loading Dock Available Flag' ;
    rdfs:comment 'Indicates whether the address has a loading dock or freight receiving area for large shipments (e.g., sequencing instruments, bulk reagent orders). True if available, False if not.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate in decimal degrees for precise geolocation of the address. Range: -180.0000000 to +180.0000000. Used for logistics routing and cold-chain planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryAddressFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Address Flag' ;
    rdfs:comment 'Indicates whether this is the primary or default address for the associated customer account. True if primary, False if secondary or alternate address.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivingHours rdf:type rdf:Property ;
    rdfs:label 'Receiving Hours' ;
    rdfs:comment 'Standard receiving hours for deliveries at this address (e.g., Monday-Friday 8:00 AM - 5:00 PM, 24/7, By Appointment Only). Used for logistics planning and carrier scheduling.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validatedFlag rdf:type rdf:Property ;
    rdfs:label 'Validated Flag' ;
    rdfs:comment 'Indicates whether the address has been validated against an authoritative postal or geocoding service. True if validated, False if not validated or validation failed.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the address validation service or system used to verify the address (e.g., USPS CASS, Google Maps Geocoding API, Loqate, Melissa Data, Canada Post SERP). Null if address has not been validated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if address has never been validated.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mailingAddressId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Id' ;
    rdfs:comment 'Foreign key linking to customer.address. Business justification: Contact has embedded mailing address fields (mailing_street, mailing_city, mailing_state_province, mailing_postal_code, mailing_country_code) which should be normalized to mailing_address_id FK to the' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Primary functional role of the contact within the customer relationship (technical, commercial, billing, regulatory, procurement, clinical, research). [ENUM-REF-CANDIDATE: technical|commercial|billing|regulatory|procurement|clinical|research — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record (active, inactive, suspended, pending_verification).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Specific classification of the contact based on their professional function (principal investigator, lab director, procurement officer, field application scientist, clinical specialist, purchasing contact).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete concatenated name of the contact including salutation, first, middle, last, and suffix.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Current GDPR consent status for processing the contacts personal data (consented, not_consented, withdrawn, pending).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO language code representing the contacts preferred language for communication (e.g., en, de, fr, es, ja, zh).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the contact has opted in to receive marketing communications (True/False).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt Out Flag' ;
    rdfs:comment 'Indicates whether the contact has opted out of marketing communications (True/False).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Mobile or cellular phone number for the contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Phi Authorization Date' ;
    rdfs:comment 'Date when PHI handling authorization was granted or last verified.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiHandlingAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Handling Authorization Flag' ;
    rdfs:comment 'Indicates whether the contact is authorized to handle Protected Health Information under HIPAA regulations (True/False).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contacts preferred method of communication (email, phone, mobile, fax, portal, in-person).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Professional or personal title prefix for the contact (Dr, Prof, Mr, Ms, Mrs, Mx).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Email Address' ;
    rdfs:comment 'Alternate email address for the contact, used for backup communication or specific purposes.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Professional or generational suffix for the contact (Jr, Sr, II, III, PhD, MD, DVM, ScD). [ENUM-REF-CANDIDATE: Jr|Sr|II|III|IV|PhD|MD|DVM|ScD — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalExpertiseArea rdf:type rdf:Property ;
    rdfs:label 'Technical Expertise Area' ;
    rdfs:comment 'Primary area of technical or scientific expertise for the contact (e.g., Next-Generation Sequencing, Bioinformatics, Clinical Genomics, CRISPR Gene Editing, Array-Based Genotyping).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique identifier for the customer credit profile record. Primary key.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditApprovalAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Credit approval authority exists as denormalized string. Linking to employee enables SOX compliance audit trails, approval authority verification, segregation of duties controls, and tracking of credi' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedCurrencies rdf:type rdf:Property ;
    rdfs:label 'Approved Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 three-letter currency codes in which the customer is authorized to transact (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Available Credit Amount' ;
    rdfs:comment 'Remaining credit capacity calculated as credit limit minus outstanding AR balance and open order commitments.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Amount' ;
    rdfs:comment 'Total amount covered by the bank guarantee or letter of credit, typically matching or exceeding the approved credit limit.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankGuaranteeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Expiry Date' ;
    rdfs:comment 'Expiration date of the bank guarantee or letter of credit, after which the guarantee is no longer valid.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the customer has provided a bank guarantee or letter of credit to secure credit terms.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankGuaranteeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Guarantee Reference Number' ;
    rdfs:comment 'Reference number or identifier for the bank guarantee or letter of credit provided by the customer to secure credit terms.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current collection status of outstanding receivables, indicating whether invoices are current, past due, in collections, or subject to legal action. [ENUM-REF-CANDIDATE: current|past_due_1_30|past_due_31_60|past_due_61_90|past_due_over_90|in_collections|legal_action — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approval Date' ;
    rdfs:comment 'Date when the current credit limit and terms were approved by the designated credit approval authority.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date when the credit hold was placed on the customer account.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the customer account is currently on credit hold, blocking new order releases until credit issues are resolved.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Detailed explanation for why the customer account is on credit hold, such as exceeded credit limit, overdue invoices, or failed credit review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Coverage Amount' ;
    rdfs:comment 'Maximum amount covered by the trade credit insurance policy for this customer account.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the customer account is covered by trade credit insurance to mitigate default risk.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Policy Number' ;
    rdfs:comment 'Policy number for the trade credit insurance covering this customer account, if applicable.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditNotes rdf:type rdf:Property ;
    rdfs:label 'Credit Notes' ;
    rdfs:comment 'Free-text field for internal notes and comments related to the customer credit profile, credit decisions, and payment behavior.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditProfileNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Number' ;
    rdfs:comment 'Business-facing unique identifier for the credit profile, typically sourced from SAP SD credit management module.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Alphanumeric credit rating classification (e.g., AAA, AA, A, BBB, BB, B, CCC, D) derived from internal credit assessment or external credit bureau such as Dun & Bradstreet. [ENUM-REF-CANDIDATE: AAA|AA|A|BBB|BB|B|CCC|CC|C|D — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingSource rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Source' ;
    rdfs:comment 'Source of the credit rating or credit score, indicating whether it is an internal assessment or provided by an external credit bureau or rating agency. [ENUM-REF-CANDIDATE: internal|dun_bradstreet|experian|equifax|moody|sp|fitch|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credit Review Date' ;
    rdfs:comment 'Date of the most recent credit review or assessment conducted for this customer.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditReviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Credit Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which the customer credit profile is reviewed and reassessed (e.g., 6, 12, 24 months).' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditScore rdf:type rdf:Property ;
    rdfs:label 'Credit Score' ;
    rdfs:comment 'Numerical credit score assigned to the customer based on internal credit assessment or external credit bureau data (e.g., Dun & Bradstreet). Higher scores indicate lower credit risk.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current lifecycle status of the customer credit profile governing order release and commercial transaction approvals.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days it takes the customer to pay invoices, calculated as (Accounts Receivable / Total Credit Sales) * Number of Days. Key metric for assessing payment behavior and credit risk.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level or escalation stage for overdue invoice collection activities (e.g., 0=none, 1=reminder, 2=warning, 3=final notice, 4=legal action).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCreditAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Credit Assessment Outcome' ;
    rdfs:comment 'Outcome of the most recent credit assessment, indicating whether credit was approved, declined, increased, decreased, or remained unchanged.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date when the most recent dunning notice or collection communication was sent to the customer.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review or reassessment of the customer credit profile.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingArBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Ar Balance' ;
    rdfs:comment 'Total unpaid invoices and receivables currently outstanding for this customer, sourced from SAP FI accounts receivable module.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Approved payment terms governing invoice due dates for instrument capital sales, reagent supply agreements, and service contracts. Common terms include net-30, net-60, and net-90 days. [ENUM-REF-CANDIDATE: net_30|net_60|net_90|net_120|prepayment|cod|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Internal risk classification assigned to the customer based on credit score, payment history, financial stability, and other risk factors.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCreditProfileCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Credit Profile Code' ;
    rdfs:comment 'External identifier for this credit profile record in Salesforce CRM, used for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreditAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Credit Account Number' ;
    rdfs:comment 'Credit account number or credit control area identifier in SAP SD credit management module, used for cross-system reconciliation.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Customer Consent Record Id' ;
    rdfs:comment 'Unique identifier for the customer consent record. Primary key for this entity.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentConsentRecordCustomerConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Record Customer Consent Record Id' ;
    rdfs:comment 'Reference to a parent or predecessor consent record that this record supersedes or amends. Used to track consent version history and re-consent workflows. Nullable if this is an original consent.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerConsentRecord .

ind:collectionChannel rdf:type rdf:Property ;
    rdfs:label 'Collection Channel' ;
    rdfs:comment 'The channel or method through which this consent was collected from the customer. Indicates whether consent was obtained via web portal, mobile application, paper form, email, CRM system entry, phone conversation, in-person interaction, or API integration. [ENUM-REF-CANDIDATE: web_portal|mobile_app|paper_form|email|crm_system|phone|in_person|api — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Consent Effective Date' ;
    rdfs:comment 'The date from which this consent becomes legally effective and enforceable. May differ from consent_date if there is a future start date specified in the agreement.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which this consent expires and is no longer valid. Nullable for consents that do not have a predetermined expiration. Used to trigger re-consent workflows and ensure compliance with time-limited authorizations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'The specific business or legal purpose for which this consent was obtained. Examples include research data sharing, marketing communications, clinical trial participation, genomic data analysis, or third-party data transfer.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Detailed description of the scope and boundaries of what this consent covers. Specifies the data types, processing activities, third parties, geographic regions, or specific use cases that are authorized under this consent.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTextReference rdf:type rdf:Property ;
    rdfs:label 'Consent Text Reference' ;
    rdfs:comment 'Reference identifier or document control number pointing to the full legal text of the consent agreement. Links to the controlled document repository (e.g., Veeva Vault) where the complete consent language is stored.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingPartyRole rdf:type rdf:Property ;
    rdfs:label 'Consenting Party Role' ;
    rdfs:comment 'The role or capacity in which the individual provided consent. Indicates whether they are the primary contact, an authorized representative, legal guardian, principal investigator, IRB (Institutional Review Board) coordinator, or data protection officer.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectEmail rdf:type rdf:Property ;
    rdfs:label 'Data Subject Email' ;
    rdfs:comment 'The email address of the individual who provided consent. Used for consent verification, withdrawal notifications, and audit trail purposes.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectName rdf:type rdf:Property ;
    rdfs:label 'Data Subject Name' ;
    rdfs:comment 'The full name of the individual data subject (person) who provided this consent. May differ from the customer account name if the consent is provided by an authorized representative or specific contact within an organization.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocation rdf:type rdf:Property ;
    rdfs:label 'Geolocation' ;
    rdfs:comment 'Geographic location information (e.g., country, region, or coordinates) from which the consent was provided. Used to determine applicable data protection regulations and jurisdictional compliance requirements.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the consent was submitted, if collected via electronic channel. Used for audit trail and fraud prevention purposes. May be considered PII under GDPR in certain jurisdictions.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction or geographic region whose data protection laws govern this consent. Examples include EU, USA, California, Brazil, Canada. Determines applicable compliance requirements and data subject rights.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the customer has opted in to receive marketing communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The primary regulatory or legal framework under which this consent was obtained. Includes GDPR (General Data Protection Regulation), HIPAA (Health Insurance Portability and Accountability Act), CCPA (California Consumer Privacy Act), LGPD (Brazilian General Data Protection Law), PIPEDA (Canadian Personal Information Protection and Electronic Documents Act), or NIH (National Institutes of Health) Genomic Data Sharing Policy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The frequency in months at which this consent must be renewed. Nullable if renewal is not required or if renewal is event-driven rather than time-based.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Boolean flag indicating whether this consent requires periodic renewal or re-confirmation. True if renewal is required, False if consent is perpetual or does not require renewal.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchParticipationConsent rdf:type rdf:Property ;
    rdfs:label 'Research Participation Consent' ;
    rdfs:comment 'Boolean flag indicating whether the customer or data subject has consented to participation in research studies or use of their data for research purposes. True if consent is granted, False otherwise.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'The precise date and time when the consent was signed or formally accepted by the data subject. Provides audit trail for electronic consent workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyList rdf:type rdf:Property ;
    rdfs:label 'Third Party List' ;
    rdfs:comment 'Comma-separated or structured list of specific third parties (organizations or categories) with whom data sharing is authorized under this consent. Nullable if no third-party sharing is allowed or if sharing is unrestricted.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingAllowed rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Allowed' ;
    rdfs:comment 'Boolean flag indicating whether the data subject has consented to sharing their data with third parties. True if third-party sharing is authorized, False otherwise.' ;
    rdfs:domain ind:CustomerConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Requirement Flag' ;
    rdfs:comment 'Indicates whether accounts in this segment require explicit consent management for data processing and marketing communications (True) or operate under standard terms (False). Relevant for GDPR and HIPAA compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Compliance Required Flag' ;
    rdfs:comment 'Indicates whether accounts in this segment operate under GxP regulations (GMP, GLP, GCP) and require validated systems, audit trails, and regulatory documentation (True) or not (False).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSubVertical rdf:type rdf:Property ;
    rdfs:label 'Market Sub Vertical' ;
    rdfs:comment 'More granular sub-classification within the market vertical (e.g., Oncology Research, Rare Disease Diagnostics, Crop Genomics, Companion Diagnostics).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketVertical rdf:type rdf:Property ;
    rdfs:label 'Market Vertical' ;
    rdfs:comment 'Primary market vertical or industry sector this segment serves (e.g., ACADEMIC for research institutions, CLINICAL_LAB for diagnostic laboratories, BIOPHARMA for pharmaceutical companies, AGRICULTURAL for agri-genomics clients). [ENUM-REF-CANDIDATE: ACADEMIC|CLINICAL_LAB|BIOPHARMA|AGRICULTURAL|OEM|GOVERNMENT|HOSPITAL|DIAGNOSTIC_CENTER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiHandlingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Handling Required Flag' ;
    rdfs:comment 'Indicates whether accounts in this segment handle Protected Health Information (PHI) and require HIPAA-compliant data handling, Business Associate Agreements (BAA), and enhanced security controls (True) or not (False).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Eligibility Flag' ;
    rdfs:comment 'Indicates whether accounts in this segment are eligible for promotional campaigns, special offers, and marketing programs (True) or excluded from promotions (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Support Priority Level' ;
    rdfs:comment 'Numeric priority level for technical support and field application scientist assistance (1=highest priority, 5=standard priority). Drives support queue prioritization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Annual Revenue Usd' ;
    rdfs:comment 'Target annual revenue contribution from all accounts in this segment. Used for segment performance tracking and strategic planning. Expressed in USD.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAspUsd rdf:type rdf:Property ;
    rdfs:label 'Target Asp Usd' ;
    rdfs:comment 'Target average selling price per transaction for accounts in this segment, used for pricing strategy and revenue forecasting. Expressed in USD.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalSupportModel rdf:type rdf:Property ;
    rdfs:label 'Technical Support Model' ;
    rdfs:comment 'Technical support delivery model for this segment: DEDICATED_FAE (dedicated Field Application Engineer), SHARED_FAE (shared FAE resources), SELF_SERVICE (online resources only), PARTNER_SUPPORT (through distributors), PREMIUM_SUPPORT (24/7 premium service).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalOrderSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Typical Order Size Category' ;
    rdfs:comment 'Typical order size category for accounts in this segment (e.g., SMALL for individual reagent orders, LARGE for instrument purchases, ENTERPRISE for multi-year contracts).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationProgramId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Program Id' ;
    rdfs:comment 'Unique identifier for the evaluation program record. Primary key.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldApplicationScientistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Field Application Scientist Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Field application scientist name exists as denormalized string. Linking to employee enables time tracking, performance metrics, territory management, and accountability for evaluation program outcomes' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ndaRecordId rdf:type rdf:Property ;
    rdfs:label 'Nda Record Id' ;
    rdfs:comment 'Foreign key linking to customer.nda_record. Business justification: evaluation_program has agreement_reference_number (STRING) and confidentiality_agreement_signed (BOOLEAN) flag, indicating that evaluation programs are often governed by confidentiality agreements (ND' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NdaRecord .

ind:salesforceOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Id' ;
    rdfs:comment 'Salesforce CRM opportunity identifier linking this evaluation program to the associated sales opportunity record for pipeline tracking and forecasting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:accountManagerName rdf:type rdf:Property ;
    rdfs:label 'Account Manager Name' ;
    rdfs:comment 'Name of the sales account manager responsible for the customer relationship and commercial aspects of the evaluation program.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSampleCount rdf:type rdf:Property ;
    rdfs:label 'Actual Sample Count' ;
    rdfs:comment 'Actual number of samples, runs, or assays completed by the customer during the evaluation program.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Internal business unit or division sponsoring the evaluation program: sequencing (NGS platforms), array (microarray solutions), gene_editing (CRISPR tools), clinical_genomics (IVD products), agricultural_genomics (ag-bio applications), research_solutions (RUO products).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Signed' ;
    rdfs:comment 'Indicates whether the customer has signed a Non-Disclosure Agreement (NDA) or Confidentiality Agreement covering the evaluation program and pre-commercial product information.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalIssuesCount rdf:type rdf:Property ;
    rdfs:label 'Critical Issues Count' ;
    rdfs:comment 'Number of critical or high-severity technical issues that significantly impacted the evaluation or required escalation.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerApplicationArea rdf:type rdf:Property ;
    rdfs:label 'Customer Application Area' ;
    rdfs:comment 'Primary research or clinical application area for which the customer is evaluating the product (e.g., \'Oncology Research\', \'Rare Disease Diagnostics\', \'Population Genomics\', \'Agricultural Breeding\').' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback Summary' ;
    rdfs:comment 'Consolidated summary of customer feedback collected during the evaluation program, including performance observations, usability comments, technical issues, and feature requests.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the customer has consented to share evaluation data, performance metrics, and results with the company for product development and marketing purposes.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of calendar days allocated for the evaluation program from start to planned end date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiPhase rdf:type rdf:Property ;
    rdfs:label 'Npi Phase' ;
    rdfs:comment 'Stage of the New Product Introduction lifecycle at which this evaluation is occurring: alpha (internal testing), beta (external pre-release), limited_release (controlled commercial launch), general_availability (full commercial release), post_launch (post-market evaluation).' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall customer assessment of product performance during the evaluation: excellent (exceeded expectations), good (met expectations), satisfactory (acceptable with minor issues), needs_improvement (significant gaps identified), poor (failed to meet requirements), not_rated (evaluation incomplete or rating not provided).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Program Owner Email' ;
    rdfs:comment 'Email address of the internal program owner for communication and coordination purposes.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwnerName rdf:type rdf:Property ;
    rdfs:label 'Program Owner Name' ;
    rdfs:comment 'Name of the internal employee responsible for managing and coordinating this evaluation program (typically from Product Management, R&D, or Commercial team).' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationRights rdf:type rdf:Property ;
    rdfs:label 'Publication Rights' ;
    rdfs:comment 'Agreement on publication and presentation rights for evaluation results: company_only (company may publish), joint_publication (co-authored publication), customer_only (customer may publish independently), no_publication (results confidential), pending_approval (rights under negotiation).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successCriteria rdf:type rdf:Property ;
    rdfs:label 'Success Criteria' ;
    rdfs:comment 'Defined objectives and measurable criteria that determine successful completion of the evaluation program (e.g., \'Achieve 95% concordance with reference method\', \'Complete 100 WGS runs with <1% error rate\', \'Validate LOD at 5% VAF\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSampleCount rdf:type rdf:Property ;
    rdfs:label 'Target Sample Count' ;
    rdfs:comment 'Planned number of samples, runs, or assays to be processed during the evaluation program to meet validation objectives.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalIssuesReported rdf:type rdf:Property ;
    rdfs:label 'Technical Issues Reported' ;
    rdfs:comment 'Number of technical issues, defects, or support cases logged by the customer during the evaluation program.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date when product training was delivered to the customer for the evaluation program.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Provided Flag' ;
    rdfs:comment 'Indicates whether formal product training was provided to the customer as part of the evaluation program setup.' ;
    rdfs:domain ind:EvaluationProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Approved Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Sequencing instruments require specific approved reagent materials (flow cells, library prep kits, buffers). Tracking approved material compatibility per instrument enables automated ordering validati' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Company-owned instruments placed at customer sites for evaluation or under service agreements are depreciable assets requiring fixed asset tracking for financial statements, tax depreciation, and asse' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:installationTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Installation Technician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Installation technician name exists as denormalized string. Linking to employee enables service history tracking, GxP training verification, and audit trail integrity for instrument qualification docu' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:instrumentModelCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Instrument Model Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Installed instruments must reference the catalog item representing that instrument model for asset tracking, service contract eligibility validation, consumables compatibility checks, and warranty man' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:salesforceAssetId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Asset Id' ;
    rdfs:comment 'Unique identifier for this installed instrument record in Salesforce CRM Asset object. Used for cross-system reconciliation and master data synchronization between Salesforce and enterprise data warehouse.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:siteAddressId rdf:type rdf:Property ;
    rdfs:label 'Site Address Id' ;
    rdfs:comment 'Reference to the physical address where the instrument is installed. Links to customer address master for field service dispatch and logistics planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:dataSharingConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Status' ;
    rdfs:comment 'Customer consent status for sharing instrument usage data, performance metrics, and anonymized run data with the manufacturer for product improvement and research. Consented allows full data sharing. Partial Consent limits data types. Withdrawn revokes previous consent.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the instrument was permanently removed from service at the customer site. Marks the end of the instrument lifecycle for installed base reporting. Null for active instruments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Reason for instrument decommissioning. Used for churn analysis, product lifecycle insights, and customer retention strategy development. [ENUM-REF-CANDIDATE: Upgrade to Newer Model|End of Life|Customer Closure|Relocation|Equipment Failure|Regulatory Non-Compliance|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Current firmware version installed on the instrument. Critical for compatibility tracking, upgrade planning, and technical support. Format: major.minor.patch (e.g., 2.5.1).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the instrument was installed and commissioned at the customer site. Marks the start of the instrument lifecycle for warranty, service contract, and utilization tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Instrument Location Description' ;
    rdfs:comment 'Detailed description of the instrument\'s physical location within the customer facility. Examples: Building 3, Room 205, Core Genomics Lab; Main Hospital, Molecular Diagnostics Suite, Bay 4. Used for field service dispatch and on-site navigation.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Instrument Serial Number' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for the physical instrument unit. Used for warranty tracking, service history, and asset identification. This is the customer-facing installed base view; engineering asset master is owned by the instrument domain.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Status' ;
    rdfs:comment 'Current operational status of the installed instrument. Active indicates the instrument is operational and in use. Under Repair indicates temporary service outage. Decommissioned indicates the instrument has been permanently removed from service.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance or repair service performed on this instrument. Used for service interval tracking and next maintenance scheduling.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkConnectivityType rdf:type rdf:Property ;
    rdfs:label 'Network Connectivity Type' ;
    rdfs:comment 'Type of network connection used by the instrument for data transfer, remote monitoring, and software updates. Offline indicates no network connection. Hybrid indicates multiple connection methods available.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Service Date' ;
    rdfs:comment 'Date when the next preventive maintenance service is scheduled. Enables proactive service planning, technician dispatch, and customer communication.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remoteMonitoringEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Enabled Flag' ;
    rdfs:comment 'Indicates whether the instrument is enrolled in remote monitoring and diagnostics services. True enables proactive issue detection, predictive maintenance, and automated performance reporting. False indicates customer opted out or network restrictions prevent remote access.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementInstrumentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Instrument Serial Number' ;
    rdfs:comment 'Serial number of the instrument that replaced this unit, if applicable. Used for upgrade tracking and customer migration analysis. Null if not replaced or customer discontinued service.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Contract End Date' ;
    rdfs:comment 'Date when the current service contract coverage ends. Used for renewal opportunity identification and customer retention campaigns.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceContractStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Contract Start Date' ;
    rdfs:comment 'Date when the current service contract coverage begins. May follow warranty expiry or overlap with warranty for enhanced coverage.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceTier rdf:type rdf:Property ;
    rdfs:label 'Service Tier' ;
    rdfs:comment 'Level of service coverage for this instrument. Basic provides business-hours support. Standard adds extended hours. Premium includes 24/7 support and priority dispatch. Enterprise adds dedicated field service engineer and proactive monitoring.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicenowConfigurationItemCode rdf:type rdf:Property ;
    rdfs:label 'Servicenow Configuration Item Code' ;
    rdfs:comment 'Unique identifier for this instrument in ServiceNow Configuration Management Database (CMDB). Links installed base registry to IT service management and field service dispatch systems.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Current control software version running on the instrument. Used for compatibility verification, troubleshooting, and upgrade eligibility assessment. Format: major.minor.patch.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOperationalHours rdf:type rdf:Property ;
    rdfs:label 'Total Operational Hours' ;
    rdfs:comment 'Cumulative hours the instrument has been in active operation since installation. Used for wear-and-tear assessment, maintenance interval calculation, and residual value estimation.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRunCount rdf:type rdf:Property ;
    rdfs:label 'Total Run Count' ;
    rdfs:comment 'Cumulative number of sequencing runs, array scans, or PCR cycles performed by this instrument since installation. Key metric for utilization analysis, lifecycle forecasting, and consumable demand prediction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility Flag' ;
    rdfs:comment 'Indicates whether this instrument is eligible for hardware or software upgrades based on model generation, current configuration, and customer service tier. True enables upgrade opportunity targeting. False indicates end-of-life model or configuration constraints.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationTier rdf:type rdf:Property ;
    rdfs:label 'Utilization Tier' ;
    rdfs:comment 'Classification of instrument usage intensity based on run frequency, sample throughput, or operational hours. Used for proactive maintenance scheduling, consumable forecasting, and upgrade targeting. Low: occasional use. Medium: regular use. High: daily intensive use. Very High: continuous 24/7 operation.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer warranty coverage ends. Critical for service contract renewal targeting and customer communication planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer warranty coverage begins. Typically aligned with installation date but may differ for pre-purchased or delayed-installation units.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current status of the warranty coverage. Active indicates warranty is in effect. Expired indicates warranty period has ended. Extended indicates customer purchased warranty extension. Voided indicates warranty was invalidated due to unauthorized modifications or misuse.' ;
    rdfs:domain ind:InstalledInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique identifier for the customer interaction record. Primary key.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Created By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who created this interaction record. Used for audit trail and data quality accountability.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Employee Id' ;
    rdfs:comment 'Reference to the internal Genomics Biotech employee who conducted or led the interaction. Typically a sales representative, Field Application Scientist (FAS), technical support engineer, or account manager.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:interactionLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Interaction Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the system user who most recently modified this interaction record. Used for audit trail and change management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supportCaseId rdf:type rdf:Property ;
    rdfs:label 'Support Case Id' ;
    rdfs:comment 'Reference to the associated technical support case or service request if this interaction is related to customer support activities. Nullable for non-support interactions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportCase .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of participants from the customer organization who attended the interaction. Used for engagement reach and influence analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication medium or platform through which the interaction took place. Distinct from interaction_type which describes the purpose.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveMentionFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Mention Flag' ;
    rdfs:comment 'Indicates whether competing vendors, products, or technologies were discussed during the interaction. Used for competitive intelligence and market positioning analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Length of the interaction in minutes. Used for resource planning, engagement scoring, and Field Application Scientist (FAS) time allocation analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeRole rdf:type rdf:Property ;
    rdfs:label 'Employee Role' ;
    rdfs:comment 'The functional role of the employee who conducted the interaction. Provides context for the type of expertise and support provided.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Quantitative score (0.00 to 100.00) representing the quality and depth of customer engagement during this interaction. Calculated based on duration, outcome, sentiment, and follow-up actions. Used for customer health scoring.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Verified Flag' ;
    rdfs:comment 'Indicates whether customer consent for data processing and communication was verified at the time of interaction, as required by GDPR for EU contacts. True if consent was confirmed.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'The calendar date on which the customer interaction occurred. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction record. Indicates whether the interaction occurred as planned or required rescheduling.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction started, including time zone information. Provides granular timing for scheduling and duration analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction activity. [ENUM-REF-CANDIDATE: sales_call|fas_site_visit|technical_support_call|webinar_attendance|trade_show_meeting|product_demonstration|training_session|scientific_advisory_board_meeting|customer_visit|email_correspondence|portal_inquiry|conference_call|onsite_consultation|remote_troubleshooting|application_review — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location or venue where the interaction took place for in-person meetings. May include customer site address, trade show venue, or Genomics Biotech office location. Nullable for remote interactions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the follow-up activity or commitment resulting from this interaction. May include scheduled tasks, deliverables, or customer requests.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next action or follow-up commitment should be completed. Used for task management and SLA tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesforceActivityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activity Code' ;
    rdfs:comment 'The unique identifier of this interaction record in the source Salesforce CRM system. Used for data lineage, reconciliation, and bidirectional synchronization.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Qualitative assessment of the customer mood, satisfaction, or receptiveness during the interaction. Used for relationship health monitoring and early warning indicators.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary or title describing the primary topic or purpose of the interaction. Used for quick identification and search.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Flag' ;
    rdfs:comment 'Indicates whether the interaction involved discussion or resolution of a technical problem, instrument malfunction, or assay performance issue. True if technical support was required.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Legal reviewer name exists as denormalized string. Linking to employee enables audit trails for contract approval authority, SOX compliance verification, and tracking of legal review workload and turn' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:signatoryContactId rdf:type rdf:Property ;
    rdfs:label 'Signatory Contact Id' ;
    rdfs:comment 'Reference to the customer contact who signed the NDA or MTA on behalf of the customer organization. Links to the contact master data in Salesforce CRM.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:veevaVaultDocumentId rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Id' ;
    rdfs:comment 'Reference to the executed NDA or MTA document stored in Veeva Vault regulatory document management system. Enables retrieval of the full legal document for audit and compliance purposes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the NDA or MTA document. Used for reference in legal correspondence and contract management systems.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the NDA or MTA. Active agreements are enforceable; expired or terminated agreements no longer provide IP protection. Superseded indicates replacement by a newer agreement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the confidentiality agreement. NDA = Non-Disclosure Agreement, MTA = Material Transfer Agreement, CDA = Confidential Disclosure Agreement, MNDA = Mutual Non-Disclosure Agreement. Determines the scope and nature of IP protection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Required Flag' ;
    rdfs:comment 'Indicates whether the receiving party is contractually obligated to notify Genomics Biotech of any unauthorized disclosure or breach of confidentiality. True = notification required, False = no explicit requirement.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessOwnerName rdf:type rdf:Property ;
    rdfs:label 'Business Owner Name' ;
    rdfs:comment 'Name of the Genomics Biotech business development, sales, or R&D representative who owns the customer relationship and is responsible for managing this NDA or MTA.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countersignatoryName rdf:type rdf:Property ;
    rdfs:label 'Countersignatory Name' ;
    rdfs:comment 'Full name of the Genomics Biotech representative who countersigned the NDA or MTA. Typically a legal counsel, business development executive, or authorized officer.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countersignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Countersignatory Title' ;
    rdfs:comment 'Job title or role of the Genomics Biotech countersignatory at the time of execution. Documents internal signatory authority.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosurePurpose rdf:type rdf:Property ;
    rdfs:label 'Disclosure Purpose' ;
    rdfs:comment 'Business rationale for sharing proprietary information under this agreement. Examples include product evaluation, collaborative research, OEM partnership discussions, or pre-commercial beta testing. Governs permissible use of disclosed information.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier of the NDA or MTA document template used. Tracks evolution of standard agreement terms and supports version control for legal compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionsFromConfidentiality rdf:type rdf:Property ;
    rdfs:label 'Exclusions From Confidentiality' ;
    rdfs:comment 'Description of information explicitly excluded from confidentiality obligations. Typically includes publicly available information, independently developed information, information received from third parties without restriction, or information disclosed under legal compulsion.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the NDA or MTA was fully executed by all parties. Marks the effective start of the confidentiality obligations and IP protection period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Applicable Flag' ;
    rdfs:comment 'Indicates whether the disclosed information or materials are subject to export control regulations (ITAR, EAR, or equivalent). True = export controls apply, False = no export restrictions.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Jurisdiction and legal framework under which the NDA or MTA is governed. Examples include Delaware law, California law, or English law. Critical for dispute resolution and enforceability.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipClassification rdf:type rdf:Property ;
    rdfs:label 'Ip Classification' ;
    rdfs:comment 'Internal classification of the IP sensitivity level covered by this agreement. Examples include trade secret, patent-pending, proprietary process, or competitive advantage. Governs internal disclosure controls and access restrictions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Flag' ;
    rdfs:comment 'Indicates whether the agreement has been reviewed and approved by Genomics Biotech legal counsel prior to execution. True = legal review completed, False = pending or not required.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date on which legal review was completed and the agreement was approved for execution. Null if no legal review was performed.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialTransferIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Material Transfer Included Flag' ;
    rdfs:comment 'Indicates whether the agreement includes provisions for physical transfer of proprietary materials (reagents, samples, prototypes). True = MTA provisions included, False = information disclosure only.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Mutual Agreement Flag' ;
    rdfs:comment 'Indicates whether the NDA is mutual (both parties disclose and receive confidential information) or unilateral (only one party discloses). True = mutual, False = unilateral.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required for termination or non-renewal of the agreement. Null if no notice period is specified.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permittedUseScope rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Scope' ;
    rdfs:comment 'Defines the permissible use of disclosed confidential information. Evaluation_only restricts use to assessment purposes; research_collaboration allows joint R&D; commercial_negotiation supports business discussions; product_development permits integration into customer products; regulatory_submission allows use in regulatory filings.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the agreement includes provisions for renewal or extension beyond the initial term. True = renewal option exists, False = no renewal provision.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualKnowledgeClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Residual Knowledge Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a residual knowledge clause allowing the receiving party to retain and use general knowledge, skills, or experience gained during the relationship. True = clause present, False = no residual rights.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnDestructionObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Return Destruction Obligation Flag' ;
    rdfs:comment 'Indicates whether the receiving party is obligated to return or destroy confidential materials and information upon agreement expiry or termination. True = return/destruction required, False = no such obligation.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual who signed the agreement on behalf of the customer. Captured for audit trail and legal enforceability even if contact record is updated or deactivated.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Job title or role of the customer signatory at the time of execution. Validates signatory authority and supports legal enforceability verification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectMatter rdf:type rdf:Property ;
    rdfs:label 'Subject Matter' ;
    rdfs:comment 'Description of the proprietary information, technology, or materials covered by the NDA or MTA. Examples include sequencing chemistry formulations, CRISPR intellectual property, custom array designs, pre-commercial product specifications, or reagent compositions. Defines the scope of IP protection.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivalPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Survival Period Years' ;
    rdfs:comment 'Number of years that confidentiality obligations survive after agreement expiry or termination. Common values are 2, 3, 5, or perpetual (represented as 99.99). Critical for determining ongoing IP protection obligations.' ;
    rdfs:domain ind:NdaRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyArea rdf:type rdf:Property ;
    rdfs:label 'Technology Area' ;
    rdfs:comment 'Primary genomics technology domain covered by the agreement. Enables segmentation of IP protection by product line and facilitates compliance tracking for technology-specific disclosures. [ENUM-REF-CANDIDATE: NGS|Array|CRISPR|PCR|qPCR|Library Prep|Reagent|Instrument|Bioinformatics|Clinical Assay|Other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchCollaborationId rdf:type rdf:Property ;
    rdfs:label 'Research Collaboration Id' ;
    rdfs:comment 'Unique identifier for the research collaboration record. Primary key.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalScientificLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Scientific Lead Employee Id' ;
    rdfs:comment 'Reference to the internal employee record for the scientific lead managing this collaboration from the Genomics Biotech side.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:principalInvestigatorContactId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Contact Id' ;
    rdfs:comment 'Reference to the customer contact serving as the principal investigator or lead scientist on the customer side for this collaboration.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:collaborationName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Name' ;
    rdfs:comment 'Descriptive name of the research collaboration, typically reflecting the scientific focus or project title.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationNumber rdf:type rdf:Property ;
    rdfs:label 'Collaboration Number' ;
    rdfs:comment 'Externally-known unique business identifier for the research collaboration, used in contracts, publications, and communications.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationOwnerName rdf:type rdf:Property ;
    rdfs:label 'Collaboration Owner Name' ;
    rdfs:comment 'Name of the Genomics Biotech business owner or account manager responsible for overall relationship management and commercial aspects of the collaboration.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Status' ;
    rdfs:comment 'Current lifecycle state of the collaboration: proposed (under negotiation), active (ongoing work), completed (successfully concluded), terminated (ended early), on hold (temporarily paused), or suspended (inactive pending resolution).' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationType rdf:type rdf:Property ;
    rdfs:label 'Collaboration Type' ;
    rdfs:comment 'Classification of the collaboration structure: co-development (joint product development), publication partnership (joint research publication), grant-funded (NIH/EU/foundation-funded project), consortium (multi-party academic/industry alliance), technology access (early access to pre-release platforms), or early access (beta testing program).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingTerms rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Terms' ;
    rdfs:comment 'Terms governing the sharing, use, and publication of genomic data generated during the collaboration, including compliance with NIH Genomic Data Sharing Policy, GDPR, and institutional data use agreements.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverables Description' ;
    rdfs:comment 'Detailed description of the expected outputs, milestones, and deliverables from the collaboration (e.g., joint publications, validated assays, sequencing datasets, software tools, clinical trial data).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundedAmount rdf:type rdf:Property ;
    rdfs:label 'Funded Amount' ;
    rdfs:comment 'Total monetary value of funding committed to this collaboration, including grants, co-funding, or in-kind contributions. Expressed in the currency specified in currency_code.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Name of the organization or program providing funding for the collaboration (e.g., NIH, European Commission Horizon 2020, Bill & Melinda Gates Foundation, internal R&D budget).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Official grant or award number assigned by the funding agency, if applicable. Used for tracking and compliance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Mta Reference Number' ;
    rdfs:comment 'Reference number of the associated material transfer agreement governing the exchange of biological materials, reagents, or samples, if applicable.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether the collaboration is subject to regulatory compliance requirements such as GxP, CLIA, HIPAA, or GDPR. True if compliance oversight is required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchFocusArea rdf:type rdf:Property ;
    rdfs:label 'Research Focus Area' ;
    rdfs:comment 'Primary scientific or application domain of the collaboration (e.g., cancer genomics, agricultural genomics, rare disease research, population health, CRISPR gene editing).' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCollaborationCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Collaboration Code' ;
    rdfs:comment 'Unique identifier for this collaboration record in the Salesforce CRM system, used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:ResearchCollaboration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted Opportunity Id' ;
    rdfs:comment 'Salesforce opportunity ID of the commercial sale resulting from a successful evaluation or beta program conversion.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:coveredCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Covered Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Service agreements cover specific products/instruments. Required for contract entitlement validation, warranty claim processing, service level compliance tracking, and determining which products are e' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:coveredReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Covered Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Service agreements include reagent supply commitments, covered products, or reagent rental terms. Tracks which reagents are included in service contracts for entitlement verification, usage tracking, ' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:requiredPersonnelPositionId rdf:type rdf:Property ;
    rdfs:label 'Required Personnel Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Service agreements in genomics often mandate specific qualified positions (CLIA director, GxP-qualified scientist) for regulatory compliance. Enables contract compliance verification and personnel ass' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the service agreement for easy identification (e.g., \'NovaSeq 6000 Premium Support - Broad Institute\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualContractValue rdf:type rdf:Property ;
    rdfs:label 'Annual Contract Value' ;
    rdfs:comment 'Total annualized revenue value of this service agreement in USD, used for sales forecasting and account planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialConversionOutcome rdf:type rdf:Property ;
    rdfs:label 'Commercial Conversion Outcome' ;
    rdfs:comment 'Outcome of evaluation engagement: not applicable (standard service agreement), converted (customer purchased product), not converted (customer declined), or pending decision (evaluation complete, decision awaited).' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Flag' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) or confidentiality clause is in place for this service agreement, typically required for beta and early-access programs.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Name or user ID of the Salesforce account owner or contract manager responsible for this service agreement.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredInstruments rdf:type rdf:Property ;
    rdfs:label 'Covered Instruments' ;
    rdfs:comment 'Comma-separated list or description of instrument serial numbers or models covered under this service agreement (e.g., \'NovaSeq 6000 SN12345, MiSeq SN67890\').' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Name, email, or phone number of the designated escalation contact for service issues or disputes under this agreement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation End Date' ;
    rdfs:comment 'Date when the evaluation or beta testing period concluded or is scheduled to conclude. Applicable only for evaluation-type agreements.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when the evaluation or beta testing period began. Applicable only for evaluation-type agreements.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Status of evaluation or beta engagement: not applicable (standard service agreement), planned (evaluation scheduled), in progress (active testing), completed (evaluation finished), converted to commercial (customer purchased), or discontinued (evaluation terminated without conversion).' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalScientificLead rdf:type rdf:Property ;
    rdfs:label 'Internal Scientific Lead' ;
    rdfs:comment 'Name or employee ID of the internal Field Application Scientist (FAS), R&D scientist, or technical lead responsible for managing this service agreement or evaluation engagement.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productsUnderEvaluation rdf:type rdf:Property ;
    rdfs:label 'Products Under Evaluation' ;
    rdfs:comment 'Comma-separated list of product names or SKUs being evaluated under this agreement (e.g., \'NextSeq 2000 Prototype, TruSight Oncology 500 v2 Beta Kit\').' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on regulatory compliance requirements applicable to this agreement, such as FDA, CLIA, CAP, IVDR, GDPR, or HIPAA obligations for clinical or IVD service agreements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Description of renewal conditions, auto-renewal clauses, notice periods, and pricing adjustments for contract extension.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Maximum number of hours within which the service provider commits to respond to a service request or incident under this agreement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelPenalties rdf:type rdf:Property ;
    rdfs:label 'Service Level Penalties' ;
    rdfs:comment 'Description of financial penalties, service credits, or remediation actions if SLA commitments (response time, uptime) are not met.' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of conditions under which either party may terminate the agreement, including notice periods, penalties, and exit terms.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uptimeGuaranteePercentage rdf:type rdf:Property ;
    rdfs:label 'Uptime Guarantee Percentage' ;
    rdfs:comment 'Guaranteed instrument or service availability percentage (e.g., 99.5% uptime for sequencing instruments under premium maintenance contracts).' ;
    rdfs:domain ind:ServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adverseEventReportId rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Report Id' ;
    rdfs:comment 'Foreign key linking to regulatory.adverse_event_report. Business justification: Support cases involving patient impact or device malfunction trigger MDR/MAUDE adverse event reporting obligations. Essential traceability for post-market surveillance and regulatory compliance in IVD' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseEventReport .

ind:fieldSafetyActionId rdf:type rdf:Property ;
    rdfs:label 'Field Safety Action Id' ;
    rdfs:comment 'Foreign key linking to regulatory.field_safety_action. Business justification: Quality issues escalate from support cases to field safety corrective actions (recalls, FSNs). Critical for complaint-to-FSCA traceability and regulatory reporting in genomics device post-market surve' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldSafetyAction .

ind:requiredQualificationPositionId rdf:type rdf:Property ;
    rdfs:label 'Required Qualification Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Certain support cases (GxP-critical, CLIA-regulated assays) require assignment to specific qualified positions for regulatory compliance. Enables intelligent case routing and ensures qualified personn' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:assignedToTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned To Team' ;
    rdfs:comment 'Name of the support team or queue assigned to the case (e.g., Instrument Support, Reagent QC, Bioinformatics, Field Applications).' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible unique case number assigned by ServiceNow or Salesforce CRM for customer reference and tracking.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the support case: open (newly created), in-progress (actively being worked), pending-customer (awaiting customer response), pending-internal (awaiting internal escalation or parts), resolved (solution provided), closed (customer confirmed resolution), or cancelled. [ENUM-REF-CANDIDATE: open|in_progress|pending_customer|pending_internal|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the support case by primary issue category: instrument fault (sequencer or array scanner malfunction), reagent QC complaint (lot quality or performance issue), software/pipeline issue (bioinformatics or BaseSpace problem), application support (protocol or experimental design question), billing inquiry, or general inquiry.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date the case was closed after customer confirmation or automatic closure.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Customer satisfaction rating provided by the customer after case closure, typically on a scale of 1 to 5.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the case has been escalated to senior technical staff or management due to complexity or customer impact.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Timestamp when the case was escalated, if applicable.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:onSiteVisitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'On Site Visit Required Flag' ;
    rdfs:comment 'Indicates whether an on-site field service engineer visit was required to resolve the case.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsShippedFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Shipped Flag' ;
    rdfs:comment 'Indicates whether replacement parts or consumables were shipped to the customer as part of case resolution.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Precise timestamp when the case was created in the support system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date the case was marked as resolved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionSummary rdf:type rdf:Property ;
    rdfs:label 'Resolution Summary' ;
    rdfs:comment 'Summary of the actions taken to resolve the case, including troubleshooting steps, parts replaced, software patches applied, or guidance provided.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Precise timestamp when the case was marked as resolved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the root cause identified by the support team.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Technical severity level of the issue. Sev1: complete system failure; Sev2: major functionality impaired; Sev3: minor functionality impaired; Sev4: cosmetic or documentation issue.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the case was resolved within the SLA target time.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target turnaround time in hours as defined by the customer\'s service level agreement for this case priority and type.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Support Case Description' ;
    rdfs:comment 'Detailed description of the issue as reported by the customer, including symptoms, error messages, and context.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatHours rdf:type rdf:Property ;
    rdfs:label 'Tat Hours' ;
    rdfs:comment 'Total turnaround time in hours from case creation to resolution, calculated as the difference between reported_timestamp and resolution_timestamp.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalRequirementId rdf:type rdf:Property ;
    rdfs:label 'Technical Requirement Id' ;
    rdfs:comment 'Unique identifier for the technical requirement record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalRequirement .

ind:preferredReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Preferred Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Customer technical requirements specify preferred reagent products (library prep methods, sequencing kits) for their applications. Tracks customer preferences for quote generation, opportunity qualifi' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:primaryTechnicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Technical Employee Id' ;
    rdfs:comment 'Identifier of the field application scientist, sales engineer, or support specialist who captured this technical requirement.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Primary sequencing application type required by the customer. WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), targeted panel, single-cell sequencing, RNA-seq, ChIP-seq, ATAC-seq, metagenomics, amplicon sequencing, or methylation profiling. [ENUM-REF-CANDIDATE: WGS|WES|targeted_panel|single_cell|RNA_seq|ChIP_seq|ATAC_seq|metagenomics|amplicon_sequencing|methylation_profiling — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetConstraintUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Constraint Usd' ;
    rdfs:comment 'Customer\'s budget constraint or target cost per sample in USD, used for configuring cost-effective sequencing and analysis solutions.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Date and time when this technical requirement was initially captured during pre-sales, onboarding, or support engagement.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataDeliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Data Delivery Format' ;
    rdfs:comment 'Required bioinformatics output format(s) for data delivery. FASTQ (raw sequence reads), BAM (aligned reads), VCF (variant calls), or combinations thereof.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Required data retention period in days, driven by customer policy, regulatory requirements (e.g., CLIA, CAP, GDPR), or contractual obligations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataStorageLocationPreference rdf:type rdf:Property ;
    rdfs:label 'Data Storage Location Preference' ;
    rdfs:comment 'Customer\'s preferred data storage and delivery location: on-premise, cloud (AWS, Azure, GCP), Illumina BaseSpace Sequence Hub, or hybrid model.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Type of customer engagement during which this technical requirement was captured.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStrategy rdf:type rdf:Property ;
    rdfs:label 'Index Strategy' ;
    rdfs:comment 'Indexing strategy for sample multiplexing: single index (i7 only), dual index (i7 + i5), unique dual index (UDI), or combinatorial dual index.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentPlatformPreference rdf:type rdf:Property ;
    rdfs:label 'Instrument Platform Preference' ;
    rdfs:comment 'Customer\'s preferred or required sequencing instrument platform (e.g., NovaSeq 6000, NextSeq 2000, MiSeq, iSeq 100). Free-text field to accommodate evolving product portfolio.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPrepMethod rdf:type rdf:Property ;
    rdfs:label 'Library Prep Method' ;
    rdfs:comment 'Preferred or required library preparation method or kit (e.g., TruSeq DNA PCR-Free, Nextera DNA Flex, Stranded mRNA, KAPA HyperPrep). Free-text field capturing customer-specific protocol preferences.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplexingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Required Flag' ;
    rdfs:comment 'Indicates whether multiplexing (pooling multiple samples with unique index barcodes in a single sequencing run) is required or preferred.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phredScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Phred Score Threshold' ;
    rdfs:comment 'Minimum acceptable Phred quality score threshold for base calling (commonly Q20 or Q30, representing 99% or 99.9% base call accuracy).' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcMetricRequirements rdf:type rdf:Property ;
    rdfs:label 'Qc Metric Requirements' ;
    rdfs:comment 'Specific quality control (QC) metrics and thresholds required by the customer (e.g., Q30 score >80%, cluster density, duplication rate <20%). Free-text field capturing detailed QC specifications.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readConfiguration rdf:type rdf:Property ;
    rdfs:label 'Read Configuration' ;
    rdfs:comment 'Sequencing read configuration: single-end (one read per fragment) or paired-end (two reads per fragment).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Externally-known unique business identifier for this technical requirement record, formatted as TR-NNNNNNNN.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle status of the technical requirement record in the customer engagement workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|active|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Type of biological sample to be sequenced (e.g., whole blood, saliva, FFPE tissue, fresh frozen tissue, cell line, plasma, DNA, RNA). Free-text to accommodate diverse sample matrices.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplesPerRun rdf:type rdf:Property ;
    rdfs:label 'Samples Per Run' ;
    rdfs:comment 'Expected or maximum number of samples to be multiplexed per sequencing run, if multiplexing is required.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species of the sample (e.g., Homo sapiens, Mus musculus, Arabidopsis thaliana, microbial species). Free-text to accommodate diverse research organisms.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Target Coverage Depth' ;
    rdfs:comment 'Required average sequencing coverage depth (e.g., 30x for WGS, 100x for WES, 500x for targeted panels). Represents the average number of reads covering each base position.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRequirementGb rdf:type rdf:Property ;
    rdfs:label 'Throughput Requirement Gb' ;
    rdfs:comment 'Required sequencing throughput in gigabases (Gb) per run or per sample, depending on application and multiplexing strategy.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Expected turnaround time (TAT) in calendar days from sample receipt to data delivery, as required by the customer\'s operational or clinical workflow.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variantCallingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Variant Calling Required Flag' ;
    rdfs:comment 'Indicates whether variant calling (SNP, indel, CNV detection) is required as part of the bioinformatics pipeline deliverable.' ;
    rdfs:domain ind:TechnicalRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Training Enrollment Id' ;
    rdfs:comment 'Unique identifier for the training enrollment record. Primary key for the training enrollment entity.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instructor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Instructor name exists as denormalized string. Linking to employee enables GxP training record integrity, instructor qualification verification for regulatory audits, and tracking of customer-facing t' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationFocus rdf:type rdf:Property ;
    rdfs:label 'Application Focus' ;
    rdfs:comment 'Primary genomic application or use case covered in the training (e.g., Whole Genome Sequencing (WGS), Whole Exome Sequencing (WES), Single Nucleotide Polymorphism (SNP) genotyping, Copy Number Variation (CNV) analysis, RNA-Seq, CRISPR screening). Aligns with customer research focus and technical requirements.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved on the training assessment or examination, typically expressed as a percentage (0.00 to 100.00). Null if no formal assessment was conducted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceHours rdf:type rdf:Property ;
    rdfs:label 'Attendance Hours' ;
    rdfs:comment 'Actual number of hours the contact attended or participated in the training program. Used to track engagement and compliance with minimum attendance requirements.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the certification expires and requires renewal or recertification. Null for certifications with no expiration or if no certification was issued. Critical for tracking compliance with Clinical Laboratory Improvement Amendments (CLIA) and College of American Pathologists (CAP) requirements for clinical assay training.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issue Date' ;
    rdfs:comment 'Date when the certification was officially issued to the contact. Typically aligns with or follows the completion date. Null if no certification was issued.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether a formal certification or credential was issued upon successful completion of the training program. True if certification was issued, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique certification identifier issued to the contact upon successful completion. Used for verification and audit purposes. Null if no certification was issued.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Compliant Flag' ;
    rdfs:comment 'Indicates whether this training meets Clinical Laboratory Improvement Amendments (CLIA) requirements for clinical laboratory personnel competency assessment. True if CLIA-compliant, False otherwise. Critical for Laboratory Developed Test (LDT) and In Vitro Diagnostic (IVD) applications.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Final outcome of the training program: pass (met all completion criteria), fail (did not meet criteria), incomplete (partially completed), or not applicable (for informational sessions without pass/fail criteria).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Format in which the training was delivered: in-person classroom or lab session, virtual live instructor-led, on-demand recorded content, hybrid combination, or self-paced online module.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee Amount' ;
    rdfs:comment 'Fee charged for enrollment in the training program, expressed in the billing currency. May be zero for complimentary training provided as part of instrument purchase or service agreement. Used for revenue recognition and training program profitability analysis.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Enrollment Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the enrollment fee (e.g., USD, EUR, GBP, JPY). Used for multi-currency financial reporting and analysis.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Additional free-text notes or comments related to the enrollment, such as special accommodations, prerequisites completed, or follow-up actions required. Used for operational tracking and customer success management.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the training enrollment: registered (enrolled but not started), in progress (actively participating), completed (successfully finished), failed (did not meet completion criteria), withdrawn (contact withdrew), cancelled (program cancelled), or expired (enrollment period lapsed). [ENUM-REF-CANDIDATE: registered|in_progress|completed|failed|withdrawn|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text feedback comments provided by the contact regarding the training experience, content quality, instructor effectiveness, or suggestions for improvement. Used for qualitative analysis and training program enhancement.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handsOnLabIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Hands On Lab Included Flag' ;
    rdfs:comment 'Indicates whether the training program included hands-on laboratory exercises or practical instrument operation. True if hands-on component was included, False for lecture-only or theoretical training.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training program, expressed as a percentage (0.00 to 100.00). Used to determine pass/fail status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Status of payment for the training enrollment fee: paid (payment received), pending (payment outstanding), waived (fee waived per agreement), refunded (payment returned), or not applicable (complimentary training).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether periodic recertification is required to maintain the credential. True if recertification is mandatory, False if certification is permanent or not applicable.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceEnrollmentCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Enrollment Code' ;
    rdfs:comment 'Unique identifier for this training enrollment record in the Salesforce CRM system. Used for system integration and data lineage tracking between the lakehouse and the source system of record.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date for the training session or program. For multi-day or extended programs, represents the final scheduled session date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned start date for the training session or program. For on-demand or self-paced training, this may represent the date access was granted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'High-level category of the training program to support segmentation and reporting (instrument operation, library preparation, bioinformatics pipeline, gene editing techniques, clinical assay validation, quality and compliance, or safety training). [ENUM-REF-CANDIDATE: instrument_operation|library_preparation|bioinformatics|gene_editing|clinical_assay|quality_compliance|safety — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training program expressed in hours. Includes all instructional time, lab sessions, and required activities. Used for scheduling and resource planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical location or facility where in-person training was conducted (e.g., customer site, Genomics Biotech training center, conference venue). For virtual training, may indicate the platform used (e.g., Zoom, Microsoft Teams). Null for on-demand training.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialsProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Materials Provided Flag' ;
    rdfs:comment 'Indicates whether training materials (manuals, protocols, Standard Operating Procedures (SOPs), reference guides) were provided to the contact. True if materials were provided, False otherwise.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingProgramCode rdf:type rdf:Property ;
    rdfs:label 'Training Program Code' ;
    rdfs:comment 'Unique code identifying the specific training program (e.g., NGS-INST-101 for NGS instrument operation, LIBPREP-ADV for advanced library preparation, CRISPR-APP for CRISPR application training).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProgramName rdf:type rdf:Property ;
    rdfs:label 'Training Program Name' ;
    rdfs:comment 'Full descriptive name of the training program (e.g., Next-Generation Sequencing (NGS) Instrument Operation Certification, Advanced Library Preparation Workshop, CRISPR Gene Editing Application Training).' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRegion rdf:type rdf:Property ;
    rdfs:label 'Training Region' ;
    rdfs:comment 'Geographic region where the training was delivered (e.g., North America, Europe, Asia Pacific, Latin America). Used for regional training analytics and field application scientist territory management.' ;
    rdfs:domain ind:TrainingEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Data Use Agreement Id' ;
    rdfs:comment 'Identifier linking this access request to the executed Data Use Agreement governing permitted uses and restrictions.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataUseAgreement .

ind:targetDatasetId rdf:type rdf:Property ;
    rdfs:label 'Target Dataset Id' ;
    rdfs:comment 'Identifier of the primary genomic dataset, clinical data collection, or biobank resource being requested for access.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dataset .

ind:accessDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Access Duration Months' ;
    rdfs:comment 'Total duration in months for which data access is granted, typically ranging from 12 to 36 months.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessGrantExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Access Grant Expiry Date' ;
    rdfs:comment 'Date when the approved data access expires and the requester must cease data use or request renewal.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessGrantStartDate rdf:type rdf:Property ;
    rdfs:label 'Access Grant Start Date' ;
    rdfs:comment 'Effective date when approved data access begins and the requester may commence data use.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Specific terms, restrictions, or conditions attached to the approved access, such as publication embargo, data destruction requirements, or usage limitations.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the Data Access Committee (DAC) member or governance body that authorized the access decision.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationAgreementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Collaboration Agreement Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal collaboration agreement with the data custodian is required as a condition of access.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Use Flag' ;
    rdfs:comment 'Boolean indicator of whether the requester intends to use the genomic data for commercial purposes or product development.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataReturnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Data Return Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the requester must return or destroy the data upon completion of the research or access expiry.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Data Sensitivity Level' ;
    rdfs:comment 'Classification of the requested dataset sensitivity level determining access control requirements: public (open access), registered (registration required), or controlled (DAC approval required).' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseStatement rdf:type rdf:Property ;
    rdfs:label 'Data Use Statement' ;
    rdfs:comment 'Detailed description of the intended research use, scientific objectives, and analytical methods for the requested genomic data.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsarReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dsar Reference Number' ;
    rdfs:comment 'Reference number if this access request is related to a GDPR Data Subject Access Request for an individual\'s own genomic data.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'Legal basis under GDPR Article 6 justifying the processing of personal genomic data for this access request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Expiry Date' ;
    rdfs:comment 'Date when the current IRB approval expires and requires renewal for continued research.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified the access request record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Included Flag' ;
    rdfs:comment 'Boolean indicator of whether the requested dataset contains Protected Health Information subject to HIPAA regulations.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Publication Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the requester is required to publish research findings as a condition of data access.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable business identifier for the access request, formatted as AR-YYYYNNNN where YYYY is year and NNNN is sequential number.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the access request indicating whether it is a new access request, renewal of existing access, amendment to approved access, or emergency access request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Primary email address of the requester for communication regarding the access request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterInstitution rdf:type rdf:Property ;
    rdfs:label 'Requester Institution' ;
    rdfs:comment 'Name of the academic, research, or clinical institution with which the requester is affiliated.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full legal name of the individual researcher or principal investigator submitting the access request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterOrcid rdf:type rdf:Property ;
    rdfs:label 'Requester Orcid' ;
    rdfs:comment 'ORCID persistent digital identifier for the requester, enabling unique identification across research systems.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchPurposeCategory rdf:type rdf:Property ;
    rdfs:label 'Research Purpose Category' ;
    rdfs:comment 'High-level classification of the research purpose for the data access request aligned with GA4GH Data Use Ontology categories.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the Data Access Committee completed its review and reached a decision on the access request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the Data Access Committee (DAC) formally began review of the access request.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetDatasetName rdf:type rdf:Property ;
    rdfs:label 'Target Dataset Name' ;
    rdfs:comment 'Human-readable name of the genomic dataset or clinical data collection being requested.' ;
    rdfs:domain ind:AccessRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Assignment Id' ;
    rdfs:comment 'Unique identifier for the asset tag assignment record. Primary key for the asset tag assignment entity.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:catalogTagId rdf:type rdf:Property ;
    rdfs:label 'Catalog Tag Id' ;
    rdfs:comment 'Reference to the catalog tag being assigned. Links to the tag definition in the enterprise tag taxonomy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogTag .

ind:dataAssetId rdf:type rdf:Property ;
    rdfs:label 'Data Asset Id' ;
    rdfs:comment 'Reference to the data asset being tagged. Links to the data asset catalog entry that this tag is assigned to.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:parentAssignmentAssetTagAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Assignment Asset Tag Assignment Id' ;
    rdfs:comment 'Reference to the parent tag assignment from which this assignment was inherited. Null for root assignments. Supports traceability of tag propagation through asset hierarchies.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetTagAssignment .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Reference to the user or system account that created the tag assignment. For automated assignments, references the service account or machine learning model identifier.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryAssetDeactivatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Asset Deactivated By User Employee Id' ;
    rdfs:comment 'Reference to the user who deactivated the tag assignment. Null for active assignments. Supports accountability and audit trail for classification changes.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAssetApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Asset Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user who approved the tag assignment. Null if not yet approved or approval not required. Links to the data steward or governance authority.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedByRole rdf:type rdf:Property ;
    rdfs:label 'Assigned By Role' ;
    rdfs:comment 'Role or function of the entity that assigned the tag. Captures the business context of who or what performed the assignment, supporting governance workflows and approval chains. [ENUM-REF-CANDIDATE: data_steward|data_owner|data_custodian|system_admin|ml_classifier|api_service|data_scientist|compliance_officer — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the tag was assigned to the data asset. Represents the business-effective date of the tag assignment, which may differ from the system creation timestamp.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise timestamp when the tag assignment was created in the system. Captures the exact moment the assignment record was persisted, supporting audit trail and temporal analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:businessCriticality rdf:type rdf:Property ;
    rdfs:label 'Business Criticality' ;
    rdfs:comment 'Business importance level associated with this tag assignment. Critical indicates essential for core operations, high indicates significant business impact, medium indicates moderate importance, low indicates minimal impact, not_assessed indicates pending evaluation.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Classification Algorithm' ;
    rdfs:comment 'Name or identifier of the automated classification algorithm or machine learning model used for automated tag assignments. Null for manual assignments. Examples include rule-based classifier, natural language processing model, or pattern matching engine.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingRestriction rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Restriction' ;
    rdfs:comment 'Data sharing constraint associated with this tag assignment. Unrestricted allows broad sharing, internal_only limits to organization, restricted_partners allows approved collaborators, regulatory_approval_required mandates authority consent, prohibited blocks all external sharing.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the tag assignment was deactivated or removed. Null for active assignments. Supports audit trail and historical analysis of asset classification changes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Free-text explanation for why the tag assignment was deactivated. May include business justification, data quality issues, or classification corrections. Null for active assignments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which the tag assignment is effective. Null indicates the assignment is currently active with no planned end date. Supports temporal validity and lifecycle management of tag assignments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairAccessibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Accessible Flag' ;
    rdfs:comment 'Indicates whether this tag assignment contributes to FAIR Accessible principle compliance. True if the tag supports access control or data sharing agreement classification.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairFindableFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Findable Flag' ;
    rdfs:comment 'Indicates whether this tag assignment contributes to FAIR Findable principle compliance. True if the tag enhances discoverability of genomic datasets through standardized metadata.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairInteroperableFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Interoperable Flag' ;
    rdfs:comment 'Indicates whether this tag assignment contributes to FAIR Interoperable principle compliance. True if the tag uses standardized vocabularies or ontologies enabling cross-system integration.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairReusableFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Reusable Flag' ;
    rdfs:comment 'Indicates whether this tag assignment contributes to FAIR Reusable principle compliance. True if the tag provides licensing, provenance, or usage context metadata supporting data reuse.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Relevant Flag' ;
    rdfs:comment 'Indicates whether this tag assignment is relevant for GDPR compliance. True if the tag identifies personal data, special category data, or data subject rights applicability.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Relevant Flag' ;
    rdfs:comment 'Indicates whether this tag assignment is relevant for HIPAA compliance. True if the tag identifies Protected Health Information (PHI) or supports HIPAA security rule requirements.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when the tag assignment was last reviewed by a data steward. Null if never reviewed. Supports audit trail and demonstrates governance diligence.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ontologyTerm rdf:type rdf:Property ;
    rdfs:label 'Ontology Term' ;
    rdfs:comment 'Specific term or concept from the referenced ontology that this tag represents. Provides human-readable label for the ontology concept.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontologyUri rdf:type rdf:Property ;
    rdfs:label 'Ontology Uri' ;
    rdfs:comment 'Uniform Resource Identifier linking the tag to a formal ontology or controlled vocabulary. Supports semantic interoperability and FAIR compliance by grounding tags in standardized knowledge representations.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propagationDepth rdf:type rdf:Property ;
    rdfs:label 'Propagation Depth' ;
    rdfs:comment 'Number of levels in the asset hierarchy to which this tag assignment should propagate. Null or zero indicates no propagation. Positive integer indicates maximum depth of inheritance.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:propagationFlag rdf:type rdf:Property ;
    rdfs:label 'Propagation Flag' ;
    rdfs:comment 'Indicates whether this tag assignment should be propagated to child or related data assets. True enables inheritance of tags through asset hierarchies, supporting consistent classification across related datasets.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityDimension rdf:type rdf:Property ;
    rdfs:label 'Quality Dimension' ;
    rdfs:comment 'Data quality dimension that this tag assignment supports or measures. Enables quality-focused asset discovery and quality rule association.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Impact Flag' ;
    rdfs:comment 'Indicates whether this tag assignment affects data retention requirements. True if the tag triggers specific retention policies or legal hold requirements.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Date by which the tag assignment should be reviewed by a data steward. Null if no review is required. Supports governance workflows and ensures tag accuracy over time.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes captured during the most recent review of the tag assignment. May include steward observations, justification for approval or rejection, or recommendations for future classification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Review Required Flag' ;
    rdfs:comment 'Indicates whether the tag assignment requires periodic review or steward validation. True for assignments that need governance oversight, false for trusted assignments. Supports data quality and governance workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'External identifier or reference key from the source system. Enables traceability back to the originating system and supports reconciliation during data integration.' ;
    rdfs:domain ind:AssetTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTagCatalogTagId rdf:type rdf:Property ;
    rdfs:label 'Parent Tag Catalog Tag Id' ;
    rdfs:comment 'Reference to the parent tag in a hierarchical tag taxonomy. Enables multi-level tag classification (e.g., genomics > sequencing > WGS). Null for top-level tags.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogTag .

ind:allowsMultipleValues rdf:type rdf:Property ;
    rdfs:label 'Allows Multiple Values' ;
    rdfs:comment 'Indicates whether multiple instances of this tag can be applied to a single data asset. True for tags like genomics_assay_type (a dataset may contain both WGS and WES data), false for mutually exclusive tags like sensitivity_level.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableAssetTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Asset Types' ;
    rdfs:comment 'Comma-separated list of data asset types to which this tag can be applied. Examples: dataset, table, column, pipeline, report, genomic_file, variant_call, sequencing_run.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether applying this tag to a data asset requires formal approval from a data steward or governance committee. True for sensitive or regulatory tags (e.g., PHI, clinical-grade), false for general classification tags.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogTagDescription rdf:type rdf:Property ;
    rdfs:label 'Catalog Tag Description' ;
    rdfs:comment 'Detailed business definition and purpose of the tag, including usage guidelines and examples of data assets to which this tag should be applied.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catalogTagStatus rdf:type rdf:Property ;
    rdfs:label 'Catalog Tag Status' ;
    rdfs:comment 'Current lifecycle status of the tag. Active tags are available for use. Deprecated tags are discouraged but still valid. Proposed tags are under review. Retired tags are no longer valid and should be removed from assets.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'The regulatory or compliance framework that mandates or recommends the use of this tag. Examples: HIPAA, GDPR, FDA 21 CFR Part 11, ISO 13485, GxP, NIH Genomic Data Sharing Policy. Null for non-regulatory tags.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledVocabularySource rdf:type rdf:Property ;
    rdfs:label 'Controlled Vocabulary Source' ;
    rdfs:comment 'The authoritative source or ontology from which this tag is derived. Examples: GA4GH Data Use Ontology, OBO Foundry, NCIT (NCI Thesaurus), internal governance committee, ISO 13485.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayColor rdf:type rdf:Property ;
    rdfs:label 'Display Color' ;
    rdfs:comment 'Hexadecimal color code used for visual representation of this tag in the data catalog user interface. Enables color-coded tag categories for improved user experience.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayIcon rdf:type rdf:Property ;
    rdfs:label 'Display Icon' ;
    rdfs:comment 'Name or reference to the icon used for visual representation of this tag in the data catalog user interface. Examples: dna-helix, shield, microscope, database.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairPrincipleAlignment rdf:type rdf:Property ;
    rdfs:label 'Fair Principle Alignment' ;
    rdfs:comment 'Indicates which FAIR principle(s) this tag supports. Values: Findable, Accessible, Interoperable, Reusable, or combinations. Used to track FAIR compliance of genomic datasets.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this tag must be applied to applicable data assets as part of data governance policy. True for required tags (e.g., sensitivity classification), false for optional tags.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether this tag is automatically applied by data catalog automation, lineage tools, or metadata scanners (true), or manually curated by data stewards (false).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerStewardEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Steward Email' ;
    rdfs:comment 'The email address of the data steward responsible for this tag. Used for governance inquiries and tag change requests.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerStewardName rdf:type rdf:Property ;
    rdfs:label 'Owner Steward Name' ;
    rdfs:comment 'The name of the data steward or governance team responsible for maintaining the definition, usage guidelines, and lifecycle of this tag.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTags rdf:type rdf:Property ;
    rdfs:label 'Related Tags' ;
    rdfs:comment 'Comma-separated list of related tag codes that are semantically associated with this tag. Used for tag recommendation and faceted navigation. Example: WGS tag may be related to variant-calling, BAM-format, FASTQ-format.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchWeight rdf:type rdf:Property ;
    rdfs:label 'Search Weight' ;
    rdfs:comment 'Numeric weight assigned to this tag for search ranking and relevance scoring in the data catalog. Higher weights boost assets with this tag in search results. Used to prioritize high-value or frequently-used tags.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:synonyms rdf:type rdf:Property ;
    rdfs:label 'Synonyms' ;
    rdfs:comment 'Comma-separated list of alternative names or synonyms for this tag. Used to improve search recall and accommodate different terminology across business units. Example: WGS may have synonyms whole-genome-sequencing, complete-genome.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagCategory rdf:type rdf:Property ;
    rdfs:label 'Tag Category' ;
    rdfs:comment 'High-level classification of the tag type. Genomics_assay_type includes WGS, WES, RNA-seq, array. Data_use_restriction includes clinical-grade, RUO. FAIR_principle includes findable, accessible, interoperable, reusable. Sensitivity_level includes PHI, de-identified. Domain includes sequencing, bioinformatics, clinical. Regulatory_classification includes IVD, LDT, GxP.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagCode rdf:type rdf:Property ;
    rdfs:label 'Tag Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the tag, used for programmatic reference and API integration. Must be unique within the catalog.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagLevel rdf:type rdf:Property ;
    rdfs:label 'Tag Level' ;
    rdfs:comment 'The depth level of this tag in the hierarchical taxonomy. Top-level tags are level 1, their children are level 2, and so on. Used for faceted navigation and drill-down search.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tagName rdf:type rdf:Property ;
    rdfs:label 'Tag Name' ;
    rdfs:comment 'The canonical name of the tag used for classification and discovery in the enterprise data catalog. Examples include WGS, WES, RNA-seq, array, CRISPR, clinical-grade, research-use-only, FAIR-compliant.' ;
    rdfs:domain ind:CatalogTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'The number of data assets currently tagged with this tag. Updated periodically to support tag popularity analysis and catalog search optimization.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automatedDecisionMakingFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Decision Making Flag' ;
    rdfs:comment 'Indicates whether the processing involves automated decision-making or profiling with legal or significant effects (e.g., AI-driven variant interpretation, automated clinical risk scoring). True if automated decision-making is used.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Flag' ;
    rdfs:comment 'Indicates whether the processing involves transfer of personal data outside the European Economic Area (EEA) or to third countries. True if cross-border transfer occurs.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCategories rdf:type rdf:Property ;
    rdfs:label 'Data Categories' ;
    rdfs:comment 'Categories of personal data involved in the processing activity (e.g., genomic data, Protected Health Information (PHI), biometric data, clinical assay results, patient identifiers, research consent records). Pipe-separated list.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectConsultationFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consultation Flag' ;
    rdfs:comment 'Indicates whether data subjects or their representatives were consulted during the DPIA process, as required where appropriate under GDPR Article 35(9). True if consultation occurred.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSubjectConsultationSummary rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consultation Summary' ;
    rdfs:comment 'Summary of data subject consultation activities, including feedback received and how it was incorporated into the DPIA and risk mitigation strategy.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectsDescription rdf:type rdf:Property ;
    rdfs:label 'Data Subjects Description' ;
    rdfs:comment 'Description of the categories of data subjects whose data is processed (e.g., patients, clinical trial participants, research subjects, healthcare providers, laboratory technicians).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVolumeScale rdf:type rdf:Property ;
    rdfs:label 'Data Volume Scale' ;
    rdfs:comment 'Scale of data processing in terms of number of data subjects or volume of genomic data. Large-scale processing triggers mandatory DPIA under GDPR Article 35(3)(b).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date on which the Data Protection Officer was consulted regarding the DPIA. DPO consultation is mandatory under GDPR Article 35(2).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsultationOutcome rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Outcome' ;
    rdfs:comment 'Outcome of the DPO consultation, including DPO advice, recommendations, and any concerns raised regarding the processing activity.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Fair Compliance Flag' ;
    rdfs:comment 'Indicates whether the genomic data processing activity complies with FAIR principles for scientific data management and stewardship. True if FAIR-compliant.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliance Flag' ;
    rdfs:comment 'Indicates whether the processing activity complies with HIPAA requirements for Protected Health Information (PHI) in the United States. True if HIPAA-compliant.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedRisks rdf:type rdf:Property ;
    rdfs:label 'Identified Risks' ;
    rdfs:comment 'Detailed list of identified risks to data subject rights and freedoms (e.g., unauthorized access to genomic data, re-identification risk, discrimination based on genetic information, data breach exposure). Pipe-separated or structured text.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 that justifies the processing of personal data (e.g., consent, legal obligation, legitimate interests). For special category data, additional Article 9 basis must be documented.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:necessityAssessment rdf:type rdf:Property ;
    rdfs:label 'Necessity Assessment' ;
    rdfs:comment 'Assessment of the necessity of the data processing for the stated purpose, demonstrating that the processing is essential and cannot be achieved through less intrusive means.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Description' ;
    rdfs:comment 'Detailed description of the data processing activity, including purpose, scope, data flows, systems involved, and business context.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityName rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Name' ;
    rdfs:comment 'Name of the data processing activity being assessed (e.g., Whole Genome Sequencing (WGS) Data Analysis Pipeline, Clinical Genomic Report Generation, Research Biobank Sample Storage).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'The specific purpose for which personal data is processed (e.g., clinical diagnosis, research and development, product commercialization, regulatory submission).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proportionalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Proportionality Assessment' ;
    rdfs:comment 'Assessment of the proportionality of the data processing in relation to the purpose, ensuring that the processing is not excessive and that data subject rights are adequately protected.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Human-readable business identifier for the DPIA, used in regulatory submissions and internal documentation. Format: DPIA-YYYY-####.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency for reviewing and updating the DPIA to ensure continued compliance and relevance as processing activities or risks evolve.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Summary of the risk assessment findings, including identified risks to data subject rights and freedoms, likelihood and severity analysis, and overall risk rating.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Measures' ;
    rdfs:comment 'Measures implemented to mitigate identified risks (e.g., encryption, pseudonymization, access controls, data minimization, anonymization techniques, secure data transfer protocols, audit logging).' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataFlag rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Flag' ;
    rdfs:comment 'Indicates whether the processing involves special categories of personal data under GDPR Article 9 (genetic data, health data, biometric data). True if special category data is processed.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialCategoryLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Special Category Legal Basis' ;
    rdfs:comment 'Additional legal basis under GDPR Article 9 for processing special categories of personal data (genetic, health, biometric). Required when special_category_data_flag is True.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was consulted regarding the high-risk processing activity, if required under GDPR Article 36.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required Flag' ;
    rdfs:comment 'Indicates whether prior consultation with the supervisory authority is required under GDPR Article 36 due to high residual risk. True if consultation is required.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryAuthorityResponse rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Response' ;
    rdfs:comment 'Response received from the supervisory authority following consultation, including any guidance, conditions, or restrictions imposed on the processing activity.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systematicMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Systematic Monitoring Flag' ;
    rdfs:comment 'Indicates whether the processing involves systematic monitoring of data subjects (e.g., continuous genomic data collection, longitudinal clinical studies). True if systematic monitoring occurs.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyProcessors rdf:type rdf:Property ;
    rdfs:label 'Third Party Processors' ;
    rdfs:comment 'List of third-party data processors involved in the processing activity (e.g., cloud service providers, bioinformatics service vendors, contract research organizations). Pipe-separated list.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism used for cross-border data transfers (e.g., Standard Contractual Clauses (SCC), Binding Corporate Rules (BCR), adequacy decision, explicit consent). Required when cross_border_transfer_flag is True.' ;
    rdfs:domain ind:Dpia ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDataAssetId rdf:type rdf:Property ;
    rdfs:label 'Target Data Asset Id' ;
    rdfs:comment 'Identifier of the genomic dataset or data asset being assessed for FAIR compliance.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:accessibleA1Score rdf:type rdf:Property ;
    rdfs:label 'Accessible A1 Score' ;
    rdfs:comment 'FAIR maturity score for A1 principle: Data and metadata are retrievable by their identifier using a standardized communications protocol. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibleA2Score rdf:type rdf:Property ;
    rdfs:label 'Accessible A2 Score' ;
    rdfs:comment 'FAIR maturity score for A2 principle: Metadata are accessible even when the data are no longer available. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the FAIR compliance assessment was conducted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Assessment Identifier' ;
    rdfs:comment 'Human-readable business identifier for the FAIR assessment, used for external reference and reporting.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Standardized methodology or framework used to conduct the FAIR assessment (e.g., FAIRsFAIR, RDA FAIR Maturity Indicators).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Additional notes, observations, or context captured during the FAIR assessment process.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the FAIR assessment record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the data steward, bioinformatician, or compliance officer who performed the assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityStandardCompliance rdf:type rdf:Property ;
    rdfs:label 'Community Standard Compliance' ;
    rdfs:comment 'Domain-relevant community standards the data asset complies with (e.g., GA4GH standards, MIAME for microarray, MINSEQE for sequencing).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLicense rdf:type rdf:Property ;
    rdfs:label 'Data License' ;
    rdfs:comment 'License governing the reuse of the data asset (e.g., CC0, CC-BY, CC-BY-NC, custom institutional license).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Data Repository Url' ;
    rdfs:comment 'URL of the public or institutional repository where the data asset is registered or deposited (e.g., NCBI SRA, ENA, dbGaP, Zenodo).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elixirFairCompliant rdf:type rdf:Property ;
    rdfs:label 'Elixir Fair Compliant' ;
    rdfs:comment 'Indicates whether the assessed data asset meets ELIXIR FAIR data obligations for European genomic data infrastructure.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findableF1Score rdf:type rdf:Property ;
    rdfs:label 'Findable F1 Score' ;
    rdfs:comment 'FAIR maturity score for F1 principle: Data are assigned globally unique and persistent identifiers. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findableF2Score rdf:type rdf:Property ;
    rdfs:label 'Findable F2 Score' ;
    rdfs:comment 'FAIR maturity score for F2 principle: Data are described with rich metadata. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findableF3Score rdf:type rdf:Property ;
    rdfs:label 'Findable F3 Score' ;
    rdfs:comment 'FAIR maturity score for F3 principle: Metadata clearly and explicitly include the identifier of the data they describe. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findableF4Score rdf:type rdf:Property ;
    rdfs:label 'Findable F4 Score' ;
    rdfs:comment 'FAIR maturity score for F4 principle: Metadata are registered or indexed in a searchable resource. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identifiedGaps rdf:type rdf:Property ;
    rdfs:label 'Identified Gaps' ;
    rdfs:comment 'Detailed narrative of specific FAIR principle gaps identified during the assessment (e.g., missing persistent identifiers, incomplete metadata, lack of standardized vocabularies).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interoperableI1Score rdf:type rdf:Property ;
    rdfs:label 'Interoperable I1 Score' ;
    rdfs:comment 'FAIR maturity score for I1 principle: Data and metadata use a formal, accessible, shared, and broadly applicable language for knowledge representation. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interoperableI2Score rdf:type rdf:Property ;
    rdfs:label 'Interoperable I2 Score' ;
    rdfs:comment 'FAIR maturity score for I2 principle: Data and metadata use vocabularies that follow FAIR principles. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interoperableI3Score rdf:type rdf:Property ;
    rdfs:label 'Interoperable I3 Score' ;
    rdfs:comment 'FAIR maturity score for I3 principle: Data and metadata include qualified references to other data and metadata. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic FAIR compliance reassessment of the data asset.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nihDmspCompliant rdf:type rdf:Property ;
    rdfs:label 'Nih Dmsp Compliant' ;
    rdfs:comment 'Indicates whether the assessed data asset meets NIH Data Management and Sharing Policy requirements for FAIR data sharing.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ontologyTermsUsed rdf:type rdf:Property ;
    rdfs:label 'Ontology Terms Used' ;
    rdfs:comment 'List of ontologies or controlled vocabularies used in metadata (e.g., Gene Ontology, SNOMED CT, LOINC, Human Phenotype Ontology).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallFairMaturityLevel rdf:type rdf:Property ;
    rdfs:label 'Overall Fair Maturity Level' ;
    rdfs:comment 'Aggregate FAIR maturity classification based on all dimension scores, aligned with capability maturity model levels.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallFairScore rdf:type rdf:Property ;
    rdfs:label 'Overall Fair Score' ;
    rdfs:comment 'Composite FAIR maturity score calculated as weighted or simple average of all F, A, I, R dimension scores. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:persistentIdentifierAssigned rdf:type rdf:Property ;
    rdfs:label 'Persistent Identifier Assigned' ;
    rdfs:comment 'Indicates whether a globally unique and persistent identifier (e.g., DOI, ARK, Handle) has been assigned to the data asset.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:persistentIdentifierValue rdf:type rdf:Property ;
    rdfs:label 'Persistent Identifier Value' ;
    rdfs:comment 'The actual persistent identifier value assigned to the data asset (e.g., DOI: 10.1234/example, ARK: ark:/12345/abc).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provenanceDocumented rdf:type rdf:Property ;
    rdfs:label 'Provenance Documented' ;
    rdfs:comment 'Indicates whether detailed data provenance (origin, processing history, transformations) is documented for the data asset.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedRemediationActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Remediation Actions' ;
    rdfs:comment 'Actionable recommendations to address identified FAIR gaps and improve maturity scores (e.g., implement DOI assignment, enrich metadata with ontology terms, publish to public repository).' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusableR11Score rdf:type rdf:Property ;
    rdfs:label 'Reusable R1 1 Score' ;
    rdfs:comment 'FAIR maturity score for R1.1 principle: Data and metadata are released with a clear and accessible data usage license. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reusableR12Score rdf:type rdf:Property ;
    rdfs:label 'Reusable R1 2 Score' ;
    rdfs:comment 'FAIR maturity score for R1.2 principle: Data and metadata are associated with detailed provenance. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reusableR13Score rdf:type rdf:Property ;
    rdfs:label 'Reusable R1 3 Score' ;
    rdfs:comment 'FAIR maturity score for R1.3 principle: Data and metadata meet domain-relevant community standards. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reusableR1Score rdf:type rdf:Property ;
    rdfs:label 'Reusable R1 Score' ;
    rdfs:comment 'FAIR maturity score for R1 principle: Data and metadata are richly described with a plurality of accurate and relevant attributes. Score range 0.00 to 5.00.' ;
    rdfs:domain ind:FairAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAssetName rdf:type rdf:Property ;
    rdfs:label 'Target Asset Name' ;
    rdfs:comment 'Name of the genomic dataset or data asset being assessed (e.g., WGS cohort, variant database, sequencing run collection).' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAssetType rdf:type rdf:Property ;
    rdfs:label 'Target Asset Type' ;
    rdfs:comment 'Classification of the data asset being assessed for FAIR compliance. [ENUM-REF-CANDIDATE: genomic_dataset|reference_genome|variant_database|sequencing_run|bioinformatics_pipeline|clinical_dataset|research_dataset — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseEntitlementId rdf:type rdf:Property ;
    rdfs:label 'License Entitlement Id' ;
    rdfs:comment 'Foreign key linking to product.license_entitlement. Business justification: Software licenses control access to analysis features and datasets. Clinical interpretation module license restricts access to ClinVar-annotated variants, oncology license enables somatic variant call' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseEntitlement .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'Classification tier defining the level of access restriction applied to the genomic data. Open = publicly accessible, Registered = requires registration, Controlled = requires DAC approval, Restricted = highest security with IRB and consent requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Name' ;
    rdfs:comment 'Name of the individual or committee that approved this access control policy.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLoggingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Logging Required Flag' ;
    rdfs:comment 'Indicates whether comprehensive audit logging of all data access events is required for compliance and security monitoring.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedRoles rdf:type rdf:Property ;
    rdfs:label 'Authorized Roles' ;
    rdfs:comment 'Comma-separated list of roles authorized to access the genomic data under this policy. Examples include Principal Investigator, Bioinformatician, Clinical Geneticist, Data Analyst.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedUserGroups rdf:type rdf:Property ;
    rdfs:label 'Authorized User Groups' ;
    rdfs:comment 'Comma-separated list of user groups or organizational units authorized to access the genomic data under this policy. May include research teams, clinical departments, or external collaborators.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessCommitteeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Data Access Committee Contact Email' ;
    rdfs:comment 'Email address for contacting the Data Access Committee for access requests and inquiries.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessCommitteeName rdf:type rdf:Property ;
    rdfs:label 'Data Access Committee Name' ;
    rdfs:comment 'Name of the Data Access Committee responsible for reviewing and approving access requests for controlled-access genomic data.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseLimitationCodes rdf:type rdf:Property ;
    rdfs:label 'Data Use Limitation Codes' ;
    rdfs:comment 'Comma-separated list of GA4GH Data Use Ontology (DUO) codes specifying permitted and restricted uses of the genomic data. Examples: GRU (General Research Use), HMB (Health/Medical/Biomedical), DS (Disease-Specific Research).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseLimitationDescription rdf:type rdf:Property ;
    rdfs:label 'Data Use Limitation Description' ;
    rdfs:comment 'Human-readable description of the data use limitations and restrictions governing access to the genomic data.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbgapAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Dbgap Accession Number' ;
    rdfs:comment 'dbGaP study accession number if the genomic dataset is registered with NIH dbGaP for controlled-access data sharing.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationMethod rdf:type rdf:Property ;
    rdfs:label 'Deidentification Method' ;
    rdfs:comment 'Method used to deidentify the genomic data to protect participant privacy. None indicates identifiable data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:egaAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Ega Accession Number' ;
    rdfs:comment 'EGA study or dataset accession number if the genomic dataset is registered with EGA for controlled-access data sharing in Europe.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Required Flag' ;
    rdfs:comment 'Indicates whether encryption at rest and in transit is required for the genomic data governed by this policy.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ga4ghPassportCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ga4gh Passport Compatible Flag' ;
    rdfs:comment 'Indicates whether this access control policy is compatible with GA4GH Passport standard for federated identity and access management.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic or jurisdictional restrictions on data access, specified as comma-separated ISO 3166-1 alpha-3 country codes. Empty if no geographic restrictions apply.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Irb Expiration Date' ;
    rdfs:comment 'Date on which the IRB approval expires, requiring renewal or policy suspension.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'URL or file path to the full policy document detailing the access control requirements and procedures.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Policy Identifier' ;
    rdfs:comment 'Business-readable unique identifier for the access control policy, used for external reference and audit trails.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the access control policy describing its purpose and scope.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Email' ;
    rdfs:comment 'Email address of the policy owner for inquiries and policy management.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwnerName rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Name' ;
    rdfs:comment 'Name of the individual or role responsible for maintaining and enforcing this access control policy.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the access control policy indicating whether it is actively enforced.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the access control policy based on the type of genomic resource being governed.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of this access control policy, incremented with each revision.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationMoratoriumEndDate rdf:type rdf:Property ;
    rdfs:label 'Publication Moratorium End Date' ;
    rdfs:comment 'Date on which the publication moratorium expires, allowing public disclosure of research findings.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationMoratoriumFlag rdf:type rdf:Property ;
    rdfs:label 'Publication Moratorium Flag' ;
    rdfs:comment 'Indicates whether a publication moratorium period is in effect, restricting public disclosure of research findings derived from the genomic data.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDatasetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Target Dataset Identifier' ;
    rdfs:comment 'Identifier of the genomic dataset or data asset to which this access control policy applies. May reference WGS/WES datasets, VCF repositories, or clinical genomic databases.' ;
    rdfs:domain ind:GenomicAccessControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text description of any special access controls, data use limitations, or consent requirements that apply to data governed by this term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the glossary term was formally approved by the data governance authority.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeLog rdf:type rdf:Property ;
    rdfs:label 'Change Log' ;
    rdfs:comment 'Chronological record of changes made to this glossary term definition, including dates, authors, and descriptions of modifications.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardEmail rdf:type rdf:Property ;
    rdfs:label 'Data Steward Email' ;
    rdfs:comment 'Email address of the data steward for inquiries and clarifications regarding this glossary term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStewardName rdf:type rdf:Property ;
    rdfs:label 'Data Steward Name' ;
    rdfs:comment 'Full name of the individual assigned as the data steward responsible for maintaining the accuracy and currency of this glossary term definition.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definition rdf:type rdf:Property ;
    rdfs:label 'Definition' ;
    rdfs:comment 'The authoritative, detailed business definition of the term that establishes its meaning and usage across the enterprise.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'Web link to external documentation, standards, or resources that provide additional context or authoritative definitions for this term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryStandardReference rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Reference' ;
    rdfs:comment 'Reference to industry standards, ontologies, or nomenclatures that define this term (e.g., SNOMED CT, LOINC, HGVS, ClinVar, dbSNP).' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedAttributes rdf:type rdf:Property ;
    rdfs:label 'Linked Attributes' ;
    rdfs:comment 'Comma-separated list of specific attribute or column names across data products that are tagged with or governed by this glossary term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedDataAssets rdf:type rdf:Property ;
    rdfs:label 'Linked Data Assets' ;
    rdfs:comment 'Comma-separated list of data product names, table names, or data asset identifiers that use or reference this glossary term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDomain rdf:type rdf:Property ;
    rdfs:label 'Owning Domain' ;
    rdfs:comment 'The primary data domain responsible for defining and maintaining this glossary term. [ENUM-REF-CANDIDATE: sequencing|sample_management|instrument|reagent_and_consumable|bioinformatics|clinical_genomics|research_and_development|customer|order_management|supply_chain|manufacturing|quality_and_compliance|finance|workforce|reference_genomics|data — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piiFlag rdf:type rdf:Property ;
    rdfs:label 'Pii Flag' ;
    rdfs:comment 'Indicates whether data governed by this term contains Personally Identifiable Information subject to privacy regulations such as GDPR.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of regulatory standards, guidelines, or frameworks that define or govern the use of this term (e.g., FDA Guidance, CLIA, CAP, GDPR, HIPAA).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedTerms rdf:type rdf:Property ;
    rdfs:label 'Related Terms' ;
    rdfs:comment 'Comma-separated list of related glossary term names that have semantic relationships or contextual connections to this term.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Number of months between scheduled reviews of this glossary term to ensure definition accuracy and relevance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortDefinition rdf:type rdf:Property ;
    rdfs:label 'Short Definition' ;
    rdfs:comment 'A concise summary definition of the term suitable for tooltips, quick reference, and user interface display (typically under 200 characters).' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCategory rdf:type rdf:Property ;
    rdfs:label 'Term Category' ;
    rdfs:comment 'High-level classification of the glossary term indicating the business domain or functional area it belongs to. [ENUM-REF-CANDIDATE: clinical|sequencing|bioinformatics|quality|regulatory|manufacturing|research|customer|general — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Unique business code or abbreviation for the glossary term used for system integration and cross-referencing (e.g., VUS, LIBPREP, FLOWCELL).' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'The canonical name of the business term as it appears in the enterprise glossary (e.g., Variant of Uncertain Significance, Library Preparation, Flow Cell, CRISPR Off-Target).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageContext rdf:type rdf:Property ;
    rdfs:label 'Usage Context' ;
    rdfs:comment 'Description of the business contexts, processes, or scenarios where this term is typically used (e.g., clinical reporting, variant calling pipelines, regulatory submissions).' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageExamples rdf:type rdf:Property ;
    rdfs:label 'Usage Examples' ;
    rdfs:comment 'Concrete examples demonstrating how this term is used in business communications, reports, or data assets.' ;
    rdfs:domain ind:GlossaryTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlLevel rdf:type rdf:Property ;
    rdfs:label 'Access Control Level' ;
    rdfs:comment 'The default data classification level for data governed by this policy: public (no restrictions), internal (internal use only), confidential (business-sensitive), or restricted (PII/PHI/PCI requiring strict access controls).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anonymizationRequired rdf:type rdf:Property ;
    rdfs:label 'Anonymization Required' ;
    rdfs:comment 'Indicates whether data governed by this policy must be anonymized or de-identified before use in research, analytics, or sharing. True if anonymization is required, False otherwise.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:archivalRequired rdf:type rdf:Property ;
    rdfs:label 'Archival Required' ;
    rdfs:comment 'Indicates whether data must be archived (moved to long-term storage) rather than deleted after the retention period expires. True if archival is required, False if deletion is permitted.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequired rdf:type rdf:Property ;
    rdfs:label 'Consent Required' ;
    rdfs:comment 'Indicates whether explicit patient or subject consent is required before data governed by this policy can be collected, processed, or shared. True if consent is mandatory, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderTransferAllowed rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Allowed' ;
    rdfs:comment 'Indicates whether data governed by this policy may be transferred across international borders. True if cross-border transfer is permitted (subject to applicable safeguards), False if data must remain within the originating jurisdiction.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataDomain rdf:type rdf:Property ;
    rdfs:label 'Data Domain' ;
    rdfs:comment 'The primary data domain to which this policy applies (e.g., Sequencing, Sample Management, Clinical Genomics, Bioinformatics, Quality and Compliance, Customer, Finance).' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityThreshold rdf:type rdf:Property ;
    rdfs:label 'Data Quality Threshold' ;
    rdfs:comment 'The minimum acceptable data quality score (as a percentage) for data governed by this policy. Applicable for quality-type policies. For example, 95.00 means 95% completeness or accuracy is required.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'The method or system by which this policy is enforced (e.g., automated data quality rules in LIMS, access control lists in data catalog, manual review by QA, workflow gates in MES).' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'The specific master data entity type governed by this policy (e.g., Patient, Sample, Reagent Lot, Genomic Variant, Instrument, Assay, Test Order).' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionProcess rdf:type rdf:Property ;
    rdfs:label 'Exception Process' ;
    rdfs:comment 'The documented process for requesting and approving exceptions to this policy, including escalation path and approval authority.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairCompliant rdf:type rdf:Property ;
    rdfs:label 'Fair Compliant' ;
    rdfs:comment 'Indicates whether this policy enforces FAIR (Findable, Accessible, Interoperable, Reusable) principles for genomic datasets. True if FAIR compliance is required, False otherwise.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiApplicable rdf:type rdf:Property ;
    rdfs:label 'Phi Applicable' ;
    rdfs:comment 'Indicates whether this policy governs data that contains Protected Health Information (PHI) as defined by HIPAA. True if PHI is in scope, False otherwise.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiApplicable rdf:type rdf:Property ;
    rdfs:label 'Pii Applicable' ;
    rdfs:comment 'Indicates whether this policy governs data that contains Personally Identifiable Information (PII) as defined by GDPR and other privacy regulations. True if PII is in scope, False otherwise.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the policy, following the format MDM-POL-XXXX.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'The role or department responsible for maintaining and enforcing this policy (e.g., Data Governance Office, Quality Assurance, Regulatory Affairs).' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyScope rdf:type rdf:Property ;
    rdfs:label 'Policy Scope' ;
    rdfs:comment 'The domain, entity, or data asset to which this policy applies (e.g., Patient, Sample, Reagent Lot, Genomic Variant, Sequencing Run).' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyText rdf:type rdf:Property ;
    rdfs:label 'Policy Text' ;
    rdfs:comment 'The full text of the governance policy, including rules, standards, and procedures that govern the master data entity or domain.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Url' ;
    rdfs:comment 'The URL or document management system link where the full policy document is stored and accessible.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopReference rdf:type rdf:Property ;
    rdfs:label 'Related Sop Reference' ;
    rdfs:comment 'Reference to the Standard Operating Procedure (SOP) document that provides detailed operational instructions for implementing this policy.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The number of years that data governed by this policy must be retained before it is eligible for archival or deletion. Applicable for retention-type policies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retired Timestamp' ;
    rdfs:comment 'The timestamp when this policy was retired and ceased to be active. Null if the policy is still active or under review.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'The frequency in months at which the policy must be reviewed and revalidated (e.g., 12 for annual review, 24 for biennial).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:traceabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Traceability Required' ;
    rdfs:comment 'Indicates whether full chain-of-custody and data lineage traceability is required for data governed by this policy. True if traceability is mandatory, False otherwise.' ;
    rdfs:domain ind:MdmPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentSchemaMetadataSchemaId rdf:type rdf:Property ;
    rdfs:label 'Parent Schema Metadata Schema Id' ;
    rdfs:comment 'Reference to a parent or base schema from which this schema inherits or extends. Null if this is a root schema.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetadataSchema .

ind:applicableDataAssetTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Data Asset Types' ;
    rdfs:comment 'Comma-separated list of data asset types to which this schema applies (e.g., sequencing runs, variant calls, clinical specimens, bioinformatics pipelines).' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwardCompatible rdf:type rdf:Property ;
    rdfs:label 'Backward Compatible' ;
    rdfs:comment 'Indicates whether this schema version is backward compatible with previous versions. True if data conforming to older versions remains valid.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledVocabularyReference rdf:type rdf:Property ;
    rdfs:label 'Controlled Vocabulary Reference' ;
    rdfs:comment 'Reference to the controlled vocabulary, ontology, or code system used by this schema (e.g., SNOMED CT, LOINC, HPO, SO). Ensures semantic consistency.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'The date on which this schema version was deprecated and marked for retirement. Null if schema is still active.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairComplianceLevel rdf:type rdf:Property ;
    rdfs:label 'Fair Compliance Level' ;
    rdfs:comment 'Assessment of how well this schema supports FAIR (Findable, Accessible, Interoperable, Reusable) principles for genomic data sharing.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interoperabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Interoperability Standard' ;
    rdfs:comment 'The overarching interoperability framework or standard this schema aligns with (e.g., HL7 FHIR, GA4GH, ISO 23494, CDISC). Enables cross-system data exchange.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExtensible rdf:type rdf:Property ;
    rdfs:label 'Is Extensible' ;
    rdfs:comment 'Indicates whether this schema allows custom extensions or additional fields beyond the core specification. True if extensible, False if strictly defined.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryFields rdf:type rdf:Property ;
    rdfs:label 'Mandatory Fields' ;
    rdfs:comment 'Comma-separated list of field names that are required by this schema. Used for validation and compliance checking.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionalFields rdf:type rdf:Property ;
    rdfs:label 'Optional Fields' ;
    rdfs:comment 'Comma-separated list of field names that are optional in this schema. Provides flexibility for diverse use cases.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Alignment' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks or compliance requirements this schema supports (e.g., HIPAA, GDPR, FDA 21 CFR Part 11, CLIA).' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaDescription rdf:type rdf:Property ;
    rdfs:label 'Schema Description' ;
    rdfs:comment 'Detailed textual description of the purpose, scope, and intended use cases for this metadata schema.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Schema Documentation Url' ;
    rdfs:comment 'URL pointing to the official documentation, user guide, or specification document for this schema.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaFormat rdf:type rdf:Property ;
    rdfs:label 'Schema Format' ;
    rdfs:comment 'The technical format or serialization standard used to represent this schema (e.g., JSON Schema, XML Schema, RDF, Avro). [ENUM-REF-CANDIDATE: json|xml|rdf|csv|avro|parquet|protobuf — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaName rdf:type rdf:Property ;
    rdfs:label 'Schema Name' ;
    rdfs:comment 'The official name of the metadata schema or standard (e.g., GA4GH Phenopackets, ISA-Tab, MIMARKS, Dublin Core).' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaNamespace rdf:type rdf:Property ;
    rdfs:label 'Schema Namespace' ;
    rdfs:comment 'The namespace or domain under which this schema is defined, preventing naming collisions with other schemas.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaOwner rdf:type rdf:Property ;
    rdfs:label 'Schema Owner' ;
    rdfs:comment 'Name or identifier of the individual, team, or organization responsible for maintaining and governing this schema.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaStatus rdf:type rdf:Property ;
    rdfs:label 'Schema Status' ;
    rdfs:comment 'Current lifecycle status of the metadata schema. Active schemas are approved for production use; deprecated schemas are being phased out.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaSteward rdf:type rdf:Property ;
    rdfs:label 'Schema Steward' ;
    rdfs:comment 'Name or identifier of the data steward responsible for day-to-day schema quality, compliance, and issue resolution.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaType rdf:type rdf:Property ;
    rdfs:label 'Schema Type' ;
    rdfs:comment 'Classification of the schema by its primary domain of application within genomics and biotechnology operations. [ENUM-REF-CANDIDATE: genomic|phenotypic|clinical|operational|experimental|reference|interoperability — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaUri rdf:type rdf:Property ;
    rdfs:label 'Schema Uri' ;
    rdfs:comment 'Globally unique URI or URL where the authoritative definition of this schema can be accessed. Supports schema resolution and validation.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemaVersion rdf:type rdf:Property ;
    rdfs:label 'Schema Version' ;
    rdfs:comment 'Version identifier of the metadata schema (e.g., v2.0, 1.3.5). Tracks schema evolution and compatibility.' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRules rdf:type rdf:Property ;
    rdfs:label 'Validation Rules' ;
    rdfs:comment 'Description or reference to the validation rules and constraints enforced by this schema (e.g., data type checks, cardinality, value ranges).' ;
    rdfs:domain ind:MetadataSchema ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyScore rdf:type rdf:Property ;
    rdfs:label 'Accuracy Score' ;
    rdfs:comment 'Data accuracy dimension score, measuring correctness of values against reference data (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedBySystem rdf:type rdf:Property ;
    rdfs:label 'Assessed By System' ;
    rdfs:comment 'Name of the system or pipeline that executed the assessment (e.g., Databricks_DQ_Pipeline, Great_Expectations, Manual_Review).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessedByUser rdf:type rdf:Property ;
    rdfs:label 'Assessed By User' ;
    rdfs:comment 'Username or system account that executed the quality assessment (e.g., data_steward_id, automated_pipeline_service).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Overall pass/fail result of the quality assessment based on threshold comparison: pass, fail, or conditional_pass.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Run Number' ;
    rdfs:comment 'Business-friendly identifier for the quality assessment run, formatted as QA-YYYYMMDD-HHMMSS.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScope rdf:type rdf:Property ;
    rdfs:label 'Assessment Scope' ;
    rdfs:comment 'Scope of data evaluated: full dataset, sample subset, incremental (new records only), or targeted (specific columns/rules).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Type of quality assessment execution: automated pipeline, manual review, hybrid, scheduled, or on-demand.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Data completeness dimension score, measuring presence of required values (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consistencyScore rdf:type rdf:Property ;
    rdfs:label 'Consistency Score' ;
    rdfs:comment 'Data consistency dimension score, measuring uniformity across related datasets (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFailuresCount rdf:type rdf:Property ;
    rdfs:label 'Critical Failures Count' ;
    rdfs:comment 'Number of critical quality rule failures that require immediate remediation (e.g., PHI exposure, regulatory non-compliance).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataStewardNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Steward Notified Flag' ;
    rdfs:comment 'Indicates whether the data steward was notified of assessment results (True/False).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'Date and time when the quality assessment run was executed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureSummary rdf:type rdf:Property ;
    rdfs:label 'Failure Summary' ;
    rdfs:comment 'Summary description of key quality rule failures and their business impact.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when data steward or stakeholders were notified of assessment results, in ISO 8601 format.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overallDqScore rdf:type rdf:Property ;
    rdfs:label 'Overall Dq Score' ;
    rdfs:comment 'Composite data quality score for this assessment, calculated as percentage of rules passed (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Threshold' ;
    rdfs:comment 'Minimum data quality score required for the assessment to be considered passing (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phiExposureDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Exposure Detected Flag' ;
    rdfs:comment 'Indicates whether Protected Health Information exposure or non-compliance was detected during assessment (True/False).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordsAssessedCount rdf:type rdf:Property ;
    rdfs:label 'Records Assessed Count' ;
    rdfs:comment 'Total number of data records evaluated during this quality assessment run.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordsFailedCount rdf:type rdf:Property ;
    rdfs:label 'Records Failed Count' ;
    rdfs:comment 'Number of data records that failed one or more quality rules during this assessment.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationActionsTriggered rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions Triggered' ;
    rdfs:comment 'Comma-separated list of automated remediation actions triggered by this assessment (e.g., data_quarantine, alert_steward, block_pipeline).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether data remediation actions are required based on assessment results (True/False).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleSetName rdf:type rdf:Property ;
    rdfs:label 'Rule Set Name' ;
    rdfs:comment 'Name of the data quality rule set applied during this assessment (e.g., NGS_Data_Validation, Clinical_PHI_Compliance).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleSetVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Set Version' ;
    rdfs:comment 'Semantic version of the quality rule set applied (e.g., 1.2.3).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulesFailedCount rdf:type rdf:Property ;
    rdfs:label 'Rules Failed Count' ;
    rdfs:comment 'Number of quality rules that failed validation during this assessment.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Rules Passed Count' ;
    rdfs:comment 'Number of quality rules that passed validation during this assessment.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesWarningCount rdf:type rdf:Property ;
    rdfs:label 'Rules Warning Count' ;
    rdfs:comment 'Number of quality rules that generated warnings (non-critical issues) during this assessment.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelinessScore rdf:type rdf:Property ;
    rdfs:label 'Timeliness Score' ;
    rdfs:comment 'Data timeliness dimension score, measuring currency and availability when needed (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRulesExecuted rdf:type rdf:Property ;
    rdfs:label 'Total Rules Executed' ;
    rdfs:comment 'Total number of data quality rules executed during this assessment run.' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uniquenessScore rdf:type rdf:Property ;
    rdfs:label 'Uniqueness Score' ;
    rdfs:comment 'Data uniqueness dimension score, measuring absence of duplicate records (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityScore rdf:type rdf:Property ;
    rdfs:label 'Validity Score' ;
    rdfs:comment 'Data validity dimension score, measuring conformance to defined formats and business rules (0.00 to 100.00).' ;
    rdfs:domain ind:QualityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryQualityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Quality Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that detected or reported the quality issue, enabling accountability and follow-up communication.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryQualityVerifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quality Verified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who verified that the quality issue resolution was effective and the data now meets quality standards.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual value found in the data that violated the quality rule, enabling comparison with expected value for root cause analysis (may be NULL, malformed, or out-of-range).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Affected Record Count' ;
    rdfs:comment 'Number of data records impacted by this quality issue, quantifying the scope of the problem for prioritization and remediation planning.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRecordIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Affected Record Identifiers' ;
    rdfs:comment 'Comma-separated list or JSON array of primary key values for records affected by this issue, enabling direct navigation to problematic data for remediation (truncated if exceeds storage limit).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the quality issue was assigned to a data steward for remediation, marking the start of active resolution efforts.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessImpact rdf:type rdf:Property ;
    rdfs:label 'Business Impact' ;
    rdfs:comment 'Assessment of the business impact caused by this quality issue, including effects on clinical reporting, regulatory submissions, research accuracy, customer deliverables, or operational decisions.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Impact Flag' ;
    rdfs:comment 'Boolean indicator whether this quality issue impacts regulatory compliance (FDA, CLIA, CAP, GDPR, HIPAA) or audit requirements, requiring elevated attention and documentation.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'Date when the quality issue was first identified, establishing the timeline for issue age and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Precise timestamp when the quality issue was first identified, enabling detailed audit trail and time-to-resolution metrics.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Method by which the quality issue was identified: automated_rule (scheduled DQ check), manual_review (steward inspection), user_report (end-user feedback), reconciliation (cross-system comparison), profiling (data discovery scan).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedValue rdf:type rdf:Property ;
    rdfs:label 'Expected Value' ;
    rdfs:comment 'The correct or expected value according to the data quality rule or business standard, providing a reference for remediation (e.g., required metadata field, valid enumeration value, correct format).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueDescription rdf:type rdf:Property ;
    rdfs:label 'Issue Description' ;
    rdfs:comment 'Detailed narrative description of the quality issue, including specific examples of violations, business context, and potential downstream impact on genomic analysis or regulatory compliance.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'Human-readable business identifier for the quality issue, formatted as DQ-YYYYMMDD sequence for tracking and reference in communications.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueType rdf:type rdf:Property ;
    rdfs:label 'Issue Type' ;
    rdfs:comment 'Category of data quality dimension violated: completeness (missing data), accuracy (incorrect values), consistency (conflicting data across sources), validity (format/constraint violations), timeliness (stale/outdated data), uniqueness (duplicate records).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive actions implemented to avoid recurrence of similar quality issues (e.g., enhanced validation rules, updated Standard Operating Procedure (SOP), additional training, system configuration changes).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Issue Status' ;
    rdfs:comment 'Current lifecycle state of the quality issue: open (newly identified), assigned (steward assigned), in_progress (under remediation), resolved (fix applied pending verification), closed (verified and complete), rejected (false positive or accepted risk).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Detailed description of the remediation action taken to resolve the quality issue (e.g., corrected missing metadata, updated variant classification, merged duplicate records, fixed referential integrity).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'Method used to resolve the issue: data_correction (fixed data values), rule_adjustment (modified DQ rule), source_system_fix (corrected at source), accepted_exception (documented business exception), false_positive (rule triggered incorrectly).' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceColumn rdf:type rdf:Property ;
    rdfs:label 'Source Column' ;
    rdfs:comment 'Specific column or field name within the source table where the quality issue was identified, enabling field-level remediation.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTable rdf:type rdf:Property ;
    rdfs:label 'Source Table' ;
    rdfs:comment 'Fully qualified name of the data asset (database table, file, or dataset) containing the quality issue, enabling precise traceability to the affected data structure.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the quality issue should be resolved, based on Service Level Agreement (SLA), severity, and business requirements.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of post-resolution verification: pending (awaiting verification), verified (fix confirmed effective), failed (issue persists or recurred, requires re-work).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'Date when the quality issue resolution was verified as effective, completing the issue lifecycle and enabling closure.' ;
    rdfs:domain ind:QualityIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softwareReleaseId rdf:type rdf:Property ;
    rdfs:label 'Software Release Id' ;
    rdfs:comment 'Foreign key linking to product.software_release. Business justification: Software releases include embedded quality rules. Variant callers have built-in quality filters (QUAL>30, DP>10), alignment software has mapping quality thresholds. Release notes document rule changes' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoftwareRelease .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to product.product_specification. Business justification: Product specifications define acceptance criteria that become automated quality rules. Spec says read length ≥150bp, quality rule enforces it. Spec defines LOD ≤10 copies/mL, rule validates it. Design' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:alertThresholdBreachCount rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Breach Count' ;
    rdfs:comment 'Number of consecutive executions where this rule failed to meet its threshold. Used to trigger escalation workflows after sustained violations.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationUrl rdf:type rdf:Property ;
    rdfs:label 'Documentation Url' ;
    rdfs:comment 'Link to detailed documentation, Standard Operating Procedure (SOP), or knowledge base article explaining this rule\'s business context, validation logic, and remediation procedures.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Automated action taken when rule fails: block (halt pipeline), warn (continue with warning), quarantine (isolate bad records), log (record only), alert (notify stakeholders).' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionFrequency rdf:type rdf:Property ;
    rdfs:label 'Execution Frequency' ;
    rdfs:comment 'How often this rule is evaluated: real-time (streaming/DLT), batch at scheduled intervals, or on-demand for ad-hoc validation.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionPlatform rdf:type rdf:Property ;
    rdfs:label 'Execution Platform' ;
    rdfs:comment 'Technical platform or framework used to execute this rule (e.g., Databricks Delta Live Tables, Great Expectations, AWS Deequ, custom Spark job).' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairPrinciple rdf:type rdf:Property ;
    rdfs:label 'Fair Principle' ;
    rdfs:comment 'Which FAIR data principle this rule supports for genomic datasets: Findable (metadata completeness), Accessible (access control validation), Interoperable (format/standard compliance), Reusable (provenance/license checks).' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this rule is automatically enforced by data pipelines (true) or requires manual validation (false).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Execution Timestamp' ;
    rdfs:comment 'Timestamp of the most recent execution of this rule. Used to monitor rule execution health and identify stale validations.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastFailureCount rdf:type rdf:Property ;
    rdfs:label 'Last Failure Count' ;
    rdfs:comment 'Number of records that failed validation in the most recent rule execution. Used for impact assessment and prioritization.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPassRate rdf:type rdf:Property ;
    rdfs:label 'Last Pass Rate' ;
    rdfs:comment 'Pass rate (0.0000 to 1.0000) from the most recent rule execution. Represents the proportion of records that satisfied the rule. Used for trend analysis and alerting.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Citation of specific regulatory requirement, compliance framework, or industry standard this rule supports (e.g., FDA 21 CFR Part 11, CLIA, CAP, GDPR Article 5, HIPAA Security Rule).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationGuidance rdf:type rdf:Property ;
    rdfs:label 'Remediation Guidance' ;
    rdfs:comment 'Step-by-step instructions for data stewards or engineers to investigate and remediate rule violations. May include links to Standard Operating Procedures (SOPs) or runbooks.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Business domain category this rule applies to, enabling domain-specific rule management and governance workflows.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Standardized unique code identifier for the rule following pattern DQR-{DOMAIN}-{NUMBER}, enabling cross-system reference and traceability.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of what the rule validates, why it matters, and the expected data behavior. Should be understandable by non-technical stakeholders.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'The executable logic or SQL expression that defines the rule validation. May contain Spark SQL syntax, Python validation logic, or declarative constraint definition.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the data quality rule. Should be descriptive and follow organizational naming conventions.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Name or identifier of the business data steward or domain owner accountable for defining and maintaining this rule.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStewardEmail rdf:type rdf:Property ;
    rdfs:label 'Rule Steward Email' ;
    rdfs:comment 'Email contact for the data steward responsible for this rule. Used for automated alerts and remediation workflows.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of data quality dimension this rule enforces: completeness (non-null checks), uniqueness (duplicate detection), validity (format/range checks), consistency (cross-field logic), timeliness (freshness checks), or referential integrity (FK validation).' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Semantic version number of the rule logic (format: vMAJOR.MINOR.PATCH). Incremented when rule expression or thresholds change, enabling audit trail and rollback.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Impact severity of rule violations: critical (blocks pipeline/report release), major (requires immediate remediation), minor (tracked for improvement), warning (informational only).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of custom tags for rule categorization, search, and filtering (e.g., \'genomic,NGS,FASTQ\', \'clinical,IVD,FDA\', \'PII,GDPR\'). Supports flexible rule discovery and governance workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetColumnName rdf:type rdf:Property ;
    rdfs:label 'Target Column Name' ;
    rdfs:comment 'Specific column or attribute name within the target asset that this rule validates. Null if rule applies to entire asset or multiple columns.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDomain rdf:type rdf:Property ;
    rdfs:label 'Target Domain' ;
    rdfs:comment 'The data domain this rule applies to (e.g., Sequencing, Sample Management, Clinical Genomics, Customer). Maps to enterprise data domain taxonomy.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'Comparison operator applied between actual metric and threshold value to determine rule compliance.' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measurement for the threshold value (e.g., percentage for pass rates, count for record volumes, days for timeliness checks). [ENUM-REF-CANDIDATE: percentage|count|ratio|seconds|minutes|hours|days — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QualityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric threshold for rule pass/fail determination. Interpretation depends on threshold_operator (e.g., pass rate >= 0.95 means 95% of records must pass).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryClassificationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification Id' ;
    rdfs:comment 'Foreign key linking to product.regulatory_classification. Business justification: Regulatory classification dictates data retention periods. FDA Class II IVD devices require different retention than RUO products. IVDR Class C has stricter requirements than Class A. Regulatory audit' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryClassification .

ind:supersededByPolicyRetentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Retention Policy Id' ;
    rdfs:comment 'Reference to the retention policy that replaces this policy when status is \'superseded\'. Null if policy is still active or not replaced.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:appliesToPhi rdf:type rdf:Property ;
    rdfs:label 'Applies To Phi' ;
    rdfs:comment 'Indicates whether this retention policy governs data containing Protected Health Information (PHI) subject to HIPAA privacy and security rules (True) or non-PHI data (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToPii rdf:type rdf:Property ;
    rdfs:label 'Applies To Pii' ;
    rdfs:comment 'Indicates whether this retention policy governs data containing Personally Identifiable Information (PII) subject to GDPR, CCPA, or other privacy regulations (True) or non-PII data (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether all access, modification, and disposal actions on data governed by this policy must be logged in an immutable audit trail (True) or audit logging is optional (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Backup Retention Period Days' ;
    rdfs:comment 'Number of days that backup copies of data governed by this policy must be retained, which may differ from primary data retention period for disaster recovery purposes.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataAssetCategory rdf:type rdf:Property ;
    rdfs:label 'Data Asset Category' ;
    rdfs:comment 'Category or type of data asset this policy applies to (e.g., \'Genomic Raw Data (FASTQ/BAM)\', \'Clinical Genomic Reports\', \'Patient PHI\', \'Research ELN Records\', \'GxP Batch Records\', \'Financial Data\', \'Quality Control Data\', \'Instrument Calibration Records\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingPermitted rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permitted' ;
    rdfs:comment 'Indicates whether data governed by this policy may be shared externally with research partners, regulatory agencies, or public repositories (True) or must remain internal only (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Disposal Approval Required' ;
    rdfs:comment 'Indicates whether formal approval from data owner, legal, or compliance is required before data disposal can proceed (True) or if disposal can be automated (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which data is disposed at end of retention period: secure_deletion (cryptographic erasure), anonymization (de-identification for research), archival (long-term cold storage), physical_destruction (media destruction), transfer_to_archive (move to external archive).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionRequired rdf:type rdf:Property ;
    rdfs:label 'Encryption Required' ;
    rdfs:comment 'Indicates whether data assets governed by this policy must be encrypted at rest and in transit throughout the retention period (True) or encryption is optional (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Fair Compliance Required' ;
    rdfs:comment 'Indicates whether data assets governed by this policy must comply with FAIR data principles for genomic datasets (True), typically for research and public data sharing, or not required (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litigationHoldOverride rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Override' ;
    rdfs:comment 'Indicates whether this retention policy can be overridden by a litigation hold order (True), suspending disposal until legal matter is resolved, or policy is absolute (False).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Period Days' ;
    rdfs:comment 'Maximum number of days the data asset may be retained before mandatory disposal or anonymization is required (e.g., GDPR storage limitation principle). Null indicates no maximum limit (permanent retention).' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Period Days' ;
    rdfs:comment 'Minimum number of days the data asset must be retained to satisfy legal, regulatory, or business requirements before disposal is permitted.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed description of the retention policy purpose, scope, and business rationale, including specific regulatory requirements and business justification.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Policy Owner Department' ;
    rdfs:comment 'Department or business unit responsible for this retention policy (e.g., \'Data Governance\', \'Quality and Compliance\', \'Legal\', \'Information Security\').' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Event' ;
    rdfs:comment 'Business event that starts the retention clock (e.g., \'Date of Last Patient Contact\', \'Batch Release Date\', \'Study Completion Date\', \'Invoice Payment Date\', \'Data Creation Date\'). Defines when the retention period begins counting.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationConstraint rdf:type rdf:Property ;
    rdfs:label 'Storage Location Constraint' ;
    rdfs:comment 'Geographic or infrastructure constraints on where data governed by this policy may be stored (e.g., \'US Data Centers Only\', \'EU Region Only\', \'On-Premises Only\', \'No Cloud Storage\'). Null indicates no constraint.' ;
    rdfs:domain ind:RetentionPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Unique identifier for the accounts payable transaction record. Primary key for the accounts payable entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated. Typically the invoice date or goods receipt date depending on payment term configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business area or division to which this payable is assigned. Enables cross-company code financial reporting by business segment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character alphanumeric code representing the legal entity within the enterprise for which this payable is recorded. Used for financial consolidation and reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount available if payment is made within the discount period as defined in payment terms.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the accounting document in the system. May differ from invoice date and posting date depending on document workflow.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor according to the agreed payment terms. Critical for cash flow forecasting and avoiding late payment penalties.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert foreign currency invoice amounts to the company code local currency. Null for local currency invoices.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'The general ledger account number to which the expense portion of this invoice is posted. Determines the expense classification in financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming physical receipt of materials or services. Critical for GR/IR (Goods Receipt/Invoice Receipt) clearing and three-way match.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date on which the vendor issued the invoice. Used for aging analysis and payment term calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the invoice contents. May include details about the goods or services procured, project references, or special instructions.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'The total invoice amount including all taxes, fees, and charges before any discounts or adjustments.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The unique invoice number assigned by the vendor. This is the externally-known identifier for the invoice document.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice. Draft invoices are being prepared; posted invoices are in the ledger; blocked invoices require approval; approved invoices are ready for payment; paid invoices are settled; cancelled invoices are voided.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. Standard invoices are for goods/services received; credit memos reduce payables; debit memos increase payables; down payments and prepayments are advance payments.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The invoice amount converted to the company code local currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The net amount payable to the vendor after applying all taxes, discounts, and adjustments. This is the amount that will be paid.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Code indicating why payment is blocked. Common reasons include pending approval, price variance, quantity variance, or quality issues. Null if no block is active.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which payment was made to the vendor. Null if invoice is unpaid. Used for cash flow analysis and vendor payment performance tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The reference number of the payment run or payment document that settled this invoice. Null if invoice is unpaid.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the invoice was posted to the general ledger. Determines the fiscal period for financial reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'The difference between the invoice price and the purchase order price. Positive values indicate the invoice price exceeds PO price; negative values indicate invoice price is lower.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'The difference between the invoiced quantity and the goods receipt quantity. Used to identify over-billing or under-billing situations.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The total tax amount included in the invoice. May include VAT, sales tax, withholding tax, or other applicable taxes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation comparing purchase order, goods receipt, and invoice. Matched indicates all three documents agree within tolerance; variances indicate discrepancies requiring resolution.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference' ;
    rdfs:comment 'Additional reference information provided by the vendor, such as their internal order number, delivery note number, or contract reference.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the vendor payment. This amount is remitted to tax authorities on behalf of the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'Code representing the withholding tax type and rate applied to this invoice. Required for tax compliance in jurisdictions with withholding tax requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Classification of receivable age for aging analysis (current, 1-30 days, 31-60 days, 61-90 days, over 90 days past due).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the receivable indicating whether it is open, partially paid, fully cleared, overdue, written off, or under dispute.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingBlockCode rdf:type rdf:Property ;
    rdfs:label 'Billing Block Code' ;
    rdfs:comment 'Code indicating if billing is blocked for this receivable pending resolution of credit hold, compliance check, or other business rule.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date the receivable was fully cleared through payment or other settlement mechanism. Null if still open.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionAgency rdf:type rdf:Property ;
    rdfs:label 'Collection Agency' ;
    rdfs:comment 'Name of the third-party collection agency to which this overdue receivable has been assigned for recovery, if applicable.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoReference rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Reference' ;
    rdfs:comment 'Reference number of any credit memo issued against this invoice for returns, adjustments, or billing corrections.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator whether this receivable is currently under dispute by the customer (True=disputed, False=not disputed).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason the customer is disputing this receivable (pricing error, quality issue, delivery problem, etc.).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'SAP distribution channel code indicating how the product or service was sold (direct, distributor, OEM, online).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the accounts receivable document type (invoice, credit memo, debit memo, payment on account, down payment request).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount' ;
    rdfs:comment 'The gross invoice amount billed to the customer before any adjustments, discounts, or payments.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net receivable amount after applying all adjustments, discounts, and credits. The amount the customer owes.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Amount' ;
    rdfs:comment 'Current outstanding balance remaining unpaid on this receivable. Equals net amount minus payments received.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference document number such as customer purchase order number, contract number, or delivery note associated with this receivable.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrganization rdf:type rdf:Property ;
    rdfs:label 'Sales Organization' ;
    rdfs:comment 'SAP sales organization code responsible for this receivable transaction (regional or product-line based).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date this receivable was written off as bad debt. Null if not written off.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Boolean indicator whether this receivable has been written off as uncollectible bad debt (True=written off, False=active).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capexRequestId rdf:type rdf:Property ;
    rdfs:label 'Capex Request Id' ;
    rdfs:comment 'Unique identifier for the capital expenditure request. Primary key for the CAPEX request record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexRequest .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Capital expenditure requests must track the requesting employee for approval workflow routing (based on org hierarchy), budget accountability, post-implementation review assignment, and audit trail. E' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Foreign key linking to finance.wbs_element. Business justification: Replace WBS element code with FK to wbs_element for project accounting linkage.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Capital expenditure amount approved by the governance committee or authorized approver. May differ from requested amount due to budget constraints or scope adjustments. Null if not yet approved.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Category of asset being acquired or developed through this capital expenditure: sequencing instrument, manufacturing equipment (GMP production lines), facility (building/cleanroom expansion), IT infrastructure (HPC/cloud), laboratory automation, or other.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Budget version identifier (e.g., PLAN, FORECAST, REVISED) indicating which budget cycle this CAPEX request is associated with.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'Fiscal year for which the capital expenditure is budgeted and planned. Format: YYYY (e.g., 2024).' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the expenditure qualifies for capitalization under GAAP/IFRS accounting standards (True) or must be expensed immediately (False).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method to be used for depreciating the capital asset: straight_line (equal annual expense), declining_balance (accelerated depreciation), units_of_production (usage-based), or not_applicable (non-depreciable asset).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment' ;
    rdfs:comment 'Summary of the capital project\'s environmental impact, including energy consumption, waste generation, and sustainability considerations. Required for facility and manufacturing equipment investments.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentProgram rdf:type rdf:Property ;
    rdfs:label 'Investment Program' ;
    rdfs:comment 'Name of the strategic investment program or portfolio to which this CAPEX request belongs (e.g., NGS Platform Expansion 2024, GMP Facility Modernization).' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrPercentage rdf:type rdf:Property ;
    rdfs:label 'Irr Percentage' ;
    rdfs:comment 'Internal rate of return for the capital investment, expressed as a percentage. Represents the discount rate at which NPV equals zero. Used to assess investment attractiveness.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npvAmount rdf:type rdf:Property ;
    rdfs:label 'Npv Amount' ;
    rdfs:comment 'Calculated net present value of the capital investment, representing the present value of expected future cash flows minus the initial investment. Used for investment prioritization.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Number of months required to recover the initial capital investment through generated cash flows or cost savings. Used for liquidity and risk assessment.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectCategory rdf:type rdf:Property ;
    rdfs:label 'Project Category' ;
    rdfs:comment 'Strategic classification of the capital project: strategic (long-term competitive advantage), operational (business-as-usual improvement), or mandatory (regulatory/compliance-driven).' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDriver rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driver' ;
    rdfs:comment 'Specific regulatory requirement or compliance mandate driving the capital expenditure (e.g., FDA 21 CFR Part 11, IVDR 2017/746, ISO 13485). Null if not compliance-driven.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the capital expenditure request was formally submitted for approval. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDescription rdf:type rdf:Property ;
    rdfs:label 'Request Description' ;
    rdfs:comment 'Detailed business justification and description of the capital expenditure request, including strategic rationale, expected benefits, and project scope.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTitle rdf:type rdf:Property ;
    rdfs:label 'Request Title' ;
    rdfs:comment 'Short descriptive title of the capital expenditure request, summarizing the investment purpose.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Amount' ;
    rdfs:comment 'Total capital expenditure amount requested by the business unit, in the company\'s reporting currency. Includes all project costs: equipment, installation, training, and contingency.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'Target date by which the capital asset or project must be operational to meet business objectives. Used for prioritization and resource planning. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk assessment for the capital investment project: low (proven technology, low execution risk), medium (moderate complexity), high (significant technical or market uncertainty), or critical (high probability of failure or cost overrun).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Expected return on investment expressed as a percentage of the capital expenditure. Calculated as (expected benefit - investment cost) / investment cost * 100.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this CAPEX request is subject to SOX internal control requirements due to materiality thresholds or financial statement impact.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Full name of the executive sponsor or business owner accountable for the capital investment. Typically a VP or C-level executive.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Strategic Alignment Score' ;
    rdfs:comment 'Quantitative score (typically 1-10) assessing how well the capital investment aligns with corporate strategic priorities. Used in governance committee prioritization.' ;
    rdfs:domain ind:CapexRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the capital asset in years, used for depreciation calculation and asset accounting. Null if not applicable or not yet determined.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy. Enables roll-up reporting and hierarchical cost allocation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Reference to the employee who is the responsible manager or cost center owner. Accountable for budget and cost performance.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total annual budget allocated to this cost center in the local currency. Used for budget vs. actual variance analysis and cost control.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Flag' ;
    rdfs:comment 'Indicates whether this cost center has a formal budget allocation. True if budget is assigned and tracked, false otherwise.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocation Flag' ;
    rdfs:comment 'Indicates whether costs from this cost center are allocated to COGS. True for manufacturing, production, and direct service delivery cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP CO controlling area that governs this cost center. Defines the organizational unit for cost accounting and internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used for allocating costs from this cost center to other cost objects: direct (direct assignment), activity-based (ABC costing), step-down (sequential allocation), reciprocal (mutual services), or none (no allocation).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Functional category of the cost center: production (manufacturing and operations), research and development (R&D activities), sales and marketing, administration (corporate overhead), quality assurance (QA/QC), or regulatory affairs.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'Grouping classification for aggregated reporting (e.g., All R&D Centers, All Manufacturing Centers, All Clinical Centers). Enables multi-dimensional analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center (e.g., NGS Operations, Bioinformatics Engineering, Clinical Assay Validation, R&D Gene Editing, Manufacturing GMP).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center: active (operational and accepting postings), inactive (closed, no postings allowed), blocked (temporarily suspended), or planned (future activation).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the organizational unit: cost center (cost tracking only), profit center (revenue and cost), investment center (ROI tracking), revenue center (revenue focus), or service center (internal services).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'Primary cost element group associated with this cost center (e.g., labor, materials, overhead, depreciation). Used for cost structure analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Department code to which this cost center belongs. Links cost center to organizational structure for workforce and operational reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Functional area classification for cost-of-sales accounting (e.g., COGS, R&D, SG&A). Used for P&L reporting by function.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Regulated Flag' ;
    rdfs:comment 'Indicates whether this cost center operates under GMP regulations. True for manufacturing and quality centers subject to FDA/EMA GMP requirements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Physical location or site code where the cost center operates (e.g., facility, campus, building). Used for geographic cost analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the cost center for display in reports and dashboards.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX internal controls and audit requirements. True for cost centers involved in financial reporting processes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in intercompany transfer pricing. True for profit centers involved in cross-entity transactions requiring transfer pricing documentation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Effective start date for this cost center. Defines when the cost center becomes active and can accept cost postings.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Effective end date for this cost center. Defines when the cost center is closed and no longer accepts cost postings. Null for open-ended cost centers.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeBudgetId rdf:type rdf:Property ;
    rdfs:label 'Finance Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key for the finance budget entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBudget .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'The actual spend or revenue posted to the general ledger for this budget line as of the reporting date. Used for budget-vs-actuals variance analysis and performance tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The planned budget amount for this cost center, profit center, GL account, and fiscal period combination. Represents the financial target or allocation in the base currency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBudget rdf:type rdf:Property ;
    rdfs:label 'Available Budget' ;
    rdfs:comment 'The remaining available budget calculated as budget_amount minus commitment_amount minus actual_amount. Indicates the unencumbered budget available for future spending.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'The detailed budget category or sub-classification (e.g., salaries, reagent materials, instrument depreciation, travel, consulting, software licenses). Provides granular budget segmentation for detailed variance analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'The category of budget. OPEX (operating expenses such as reagent production, clinical validation), CAPEX (capital expenditures such as instrument lines, HPC infrastructure), R&D (research and development for NGS pipelines, CRISPR programs), headcount (FTE planning), or revenue (sales targets).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this R&D budget is eligible for capitalization under accounting standards (e.g., software development costs, patent filing costs). Supports R&D capitalization tracking per GAAP/IFRS.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'The amount of budget that has been committed through purchase orders or contracts but not yet invoiced. Supports commitment tracking and available budget calculation (budget - commitment - actuals).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'The latest forecast estimate for this budget line. Updated periodically (monthly or quarterly) to reflect current business expectations. Used for budget-vs-forecast gap analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastHorizon rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon' ;
    rdfs:comment 'The time horizon for this forecast. Monthly (rolling 12-month forecast), quarterly (rolling 4-quarter forecast), annual (single-year plan), or multi-year (strategic 3-5 year plan).' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geography rdf:type rdf:Property ;
    rdfs:label 'Geography' ;
    rdfs:comment 'The geographic region or country to which this budget applies (e.g., North America, EMEA, APAC, USA, DEU, CHN). Enables regional budget planning and performance tracking.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountFte rdf:type rdf:Property ;
    rdfs:label 'Headcount Fte' ;
    rdfs:comment 'The planned headcount in full-time equivalents for this budget line. Used for workforce planning and labor cost budgeting. Supports FTE-based budget allocation for R&D teams, manufacturing staff, and clinical operations.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'Boolean flag indicating whether this budget line represents a capital expenditure (true) or an operating expense (false). CAPEX includes long-term assets such as instrument manufacturing lines, HPC infrastructure, and facility improvements.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp when this budget record was last modified. Supports audit trail and change tracking for budget revisions and forecast updates.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalEntity rdf:type rdf:Property ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'The legal entity or subsidiary to which this budget belongs. Supports multi-entity financial consolidation and statutory reporting requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningScenario rdf:type rdf:Property ;
    rdfs:label 'Planning Scenario' ;
    rdfs:comment 'The planning scenario or sensitivity case for this budget record. Base case (most likely), best case (optimistic), worst case (conservative), or stretch target (aspirational). Supports scenario planning and risk analysis.' ;
    rdfs:domain ind:FinanceBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The calculated variance between budget and forecast (forecast_amount - budget_amount). Positive values indicate forecast exceeds budget; negative values indicate forecast is below budget. Supports variance analysis reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'The work breakdown structure element code for project-based budgets. Provides hierarchical project structure for detailed budget allocation and tracking within large R&D or CAPEX programs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Employee assigned as the custodian or responsible party for the asset. Used for accountability and asset audit trails.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since acquisition. Subtracted from acquisition cost to calculate net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or capitalized cost of the fixed asset including installation, freight, and other capitalizable costs. Basis for depreciation calculation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the asset was acquired or placed in service. Used as the starting point for depreciation calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Depreciation Amount' ;
    rdfs:comment 'Calculated annual depreciation expense for the asset based on depreciation method and useful life. Used for budgeting and P&L forecasting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed description of the fixed asset including model, specifications, and configuration details.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocation rdf:type rdf:Property ;
    rdfs:label 'Asset Location' ;
    rdfs:comment 'Physical location of the asset (e.g., building, room, facility site). Critical for asset audits, SOX compliance, and insurance purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetMainNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Main Number' ;
    rdfs:comment 'SAP FI-AA main asset number for parent asset when this record represents a sub-asset or component. Used for hierarchical asset reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the fixed asset (e.g., \'NovaSeq 6000 Sequencer Unit 3\', \'HPC Cluster Node 12\', \'GMP Clean Room HVAC System\').' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset identifier assigned by SAP FI-AA. Used for asset tracking, reporting, and SOX compliance documentation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Determines whether depreciation is active and whether the asset is included in net book value calculations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA subnumber used to track major components or sub-assets within a parent asset (e.g., flow cells within a sequencer). Enables component-level depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetValueDate rdf:type rdf:Property ;
    rdfs:label 'Asset Value Date' ;
    rdfs:comment 'Reference date for asset valuation. Used for revaluation, impairment testing, and fair value reporting under IFRS.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date when the asset was formally capitalized in the general ledger. May differ from acquisition date for assets under construction or R&D projects.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStartDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Start Date' ;
    rdfs:comment 'Date when depreciation posting begins. May differ from acquisition date if asset is under construction or not yet in service.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the asset was retired, sold, scrapped, or otherwise disposed. Triggers final depreciation calculation and removal from active asset register.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from sale or trade-in of the asset. Used to calculate gain or loss on disposal for P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Amount' ;
    rdfs:comment 'Cumulative impairment loss recognized on the asset due to obsolescence, damage, or market value decline. Reduces net book value below depreciated cost.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Investment Order Number' ;
    rdfs:comment 'SAP CO internal order number used to accumulate costs during asset construction or R&D capitalization. Settled to fixed asset upon completion.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFullyDepreciated rdf:type rdf:Property ;
    rdfs:label 'Is Fully Depreciated' ;
    rdfs:comment 'Flag indicating whether the asset has been fully depreciated (net book value equals zero or salvage value). Fully depreciated assets may still be in service.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date of the most recent physical verification of the asset. Required for SOX compliance and internal control testing.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the equipment manufacturer or vendor (e.g., Illumina, Thermo Fisher, Agilent). Used for vendor management and service contract tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model or part number of the asset. Used for spare parts procurement and technical support.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset calculated as acquisition cost minus accumulated depreciation. Used for balance sheet reporting and SOX asset controls.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Number of years remaining in the assets useful life. Used for forecasting future depreciation expense and asset replacement planning.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique equipment identifier. Used for warranty tracking, service contracts, and asset verification during physical audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDepreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Depreciation Method' ;
    rdfs:comment 'Depreciation method used for tax reporting purposes. May differ from book depreciation method to optimize tax deductions.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer warranty expires. Used to plan service contract renewals and budget for maintenance costs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Unique identifier for the general ledger entry. Primary key for the general ledger data product.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: general_ledger represents detailed posting lines that belong to a journal_entry header document. This is a classic header-line relationship. GL lines inherit document-level attributes from the JE head' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'Original transaction amount in the currency in which the business transaction occurred. Preserved for audit trail and foreign exchange gain/loss calculation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignment rdf:type rdf:Property ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Free-text field used for additional reference information, payment allocation, or internal tracking codes. Often used for bank reconciliation and payment matching.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocument rdf:type rdf:Property ;
    rdfs:label 'Clearing Document' ;
    rdfs:comment 'Document number of the clearing document that settled this open item. Populated only for cleared items. Links payment to invoice.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational unit code from SAP CO (Controlling) representing the department or functional area responsible for the cost or revenue. Used for internal management reporting and cost allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountGroup rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Group' ;
    rdfs:comment 'Credit amount translated into the group reporting currency for consolidated financial statements. Zero if the posting is a debit. Enables multi-entity consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Local' ;
    rdfs:comment 'Credit amount posted to the GL account in the local currency of the company code. Zero if the posting is a debit. Used for trial balance and financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountGroup rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Group' ;
    rdfs:comment 'Debit amount translated into the group reporting currency for consolidated financial statements. Zero if the posting is a credit. Enables multi-entity consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Debit Amount Local' ;
    rdfs:comment 'Debit amount posted to the GL account in the local currency of the company code. Zero if the posting is a credit. Used for trial balance and financial statement preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentLineItem rdf:type rdf:Property ;
    rdfs:label 'Document Line Item' ;
    rdfs:comment 'Sequential line item number within the accounting document. Combined with document_number, uniquely identifies each individual debit or credit posting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date when the document was entered into the SAP system. Used for audit trail and document control. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'Mapping to the specific line item on the financial statements (P&L, balance sheet, cash flow statement) where this account balance is reported. Enables automated financial statement generation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountName rdf:type rdf:Property ;
    rdfs:label 'Gl Account Name' ;
    rdfs:comment 'Descriptive name of the GL account providing business context for the account classification (e.g., Sequencing Reagent Revenue, R&D Salaries, Instrument COGS).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Account Number' ;
    rdfs:comment 'Unique account number from the chart of accounts identifying the GL account. Defines the classification of the transaction (revenue, COGS, R&D expense, SG&A, asset, liability, equity).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the corporate group\'s reporting currency used in consolidated financial statements (typically USD for US-based multinationals).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Identifier for parallel accounting ledgers (e.g., 0L=leading ledger, 2L=IFRS ledger, 3L=tax ledger). Enables simultaneous accounting under multiple GAAPs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code\'s local currency (e.g., USD, EUR, GBP). All local amounts are denominated in this currency.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code controlling the posting characteristics (debit/credit, account type, field status). Determines which fields are required or optional during posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Management-oriented organizational unit for internal profit and loss reporting. Enables P&L analysis by product line, business unit, or geographic region.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceKey rdf:type rdf:Property ;
    rdfs:label 'Reference Key' ;
    rdfs:comment 'Reference identifier linking the GL posting to the originating business transaction (e.g., sales order number, purchase order number, invoice number). Enables drill-back to source documents.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this posting is a reversal of a previous entry. True if this is a reversal document, False otherwise. Used for audit trail and error correction tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'Document number of the original posting that this entry reverses. Populated only when reversal_indicator is True. Maintains audit trail for corrections.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Organizational unit for segment reporting under IFRS 8 and GAAP ASC 280. Represents reportable business segments for external financial reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Single-character code identifying special GL transactions such as down payments, bills of exchange, or guarantees. Blank for standard postings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmountLocal rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local' ;
    rdfs:comment 'Tax amount calculated and posted in local currency. Separated from base amount for tax reporting and reconciliation purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction and tax rate applied to the transaction. Used for automatic tax calculation and tax reporting compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:text rdf:type rdf:Property ;
    rdfs:label 'Text' ;
    rdfs:comment 'Descriptive text providing business context for the posting. May include vendor name, customer name, or transaction description for audit and reporting purposes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Company code of the intercompany trading partner for intercompany transactions. Used for intercompany reconciliation and elimination entries in consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the original business transaction was denominated. May differ from local_currency for foreign currency transactions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'SAP user ID of the person who posted the document. Used for audit trail and SOX compliance to track who made financial postings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key for this entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:reversedTransactionIntercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Intercompany Transaction Id' ;
    rdfs:comment 'Foreign key reference to the original intercompany transaction that this record reverses, if applicable. Null if not a reversal.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IntercompanyTransaction .

ind:businessPurpose rdf:type rdf:Property ;
    rdfs:label 'Business Purpose' ;
    rdfs:comment 'Textual description of the business rationale and purpose for the intercompany transaction (e.g., shared service charge for IT support, royalty for IP licensing, cost allocation for R&D).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this intercompany transaction should be eliminated during financial consolidation to avoid double-counting in group reporting.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliminationStatus rdf:type rdf:Property ;
    rdfs:label 'Elimination Status' ;
    rdfs:comment 'Status of the consolidation elimination process for this intercompany transaction (not required, pending, completed, failed).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency for consolidated financial statements.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the group reporting currency (typically USD for Genomics Biotech).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyAccountCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account Code' ;
    rdfs:comment 'General Ledger (GL) account code used for posting the intercompany transaction. Typically a dedicated intercompany receivable or payable account in the chart of accounts.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the local currency of the sending legal entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'Name or user identifier of the individual who posted the intercompany transaction to the general ledger.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity receiving or being charged in the intercompany transaction. Four-character alphanumeric code representing the destination entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Receiving Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the tax jurisdiction of the receiving legal entity (e.g., USA, DEU, SGP).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingLegalEntityName rdf:type rdf:Property ;
    rdfs:label 'Receiving Legal Entity Name' ;
    rdfs:comment 'Full legal name of the entity receiving the intercompany transaction (e.g., Genomics Biotech APAC Pte Ltd).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this intercompany transaction is a reversal or correction of a previously posted transaction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity initiating or sending the intercompany transaction. Four-character alphanumeric code representing the originating entity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Sending Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the tax jurisdiction of the sending legal entity (e.g., USA, DEU, SGP).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingLegalEntityName rdf:type rdf:Property ;
    rdfs:label 'Sending Legal Entity Name' ;
    rdfs:comment 'Full legal name of the entity initiating the intercompany transaction (e.g., Genomics Biotech Inc., Genomics Biotech EU GmbH).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary value of the intercompany transaction in the transaction currency before any adjustments or taxes.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique identifier for the intercompany transaction, typically following format IC followed by 10 digits. Used for external reference and audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction in the financial workflow (draft, pending approval, approved, posted, eliminated, rejected, cancelled). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|posted|eliminated|rejected|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the intercompany transaction indicating the nature of the cross-entity financial activity (charge, loan, royalty, transfer pricing, service fee, cost allocation).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Documentation Reference' ;
    rdfs:comment 'Reference identifier or document number linking to the supporting transfer pricing documentation, master file, or local file that justifies the pricing of this intercompany transaction.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPricingMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Pricing Method' ;
    rdfs:comment 'The OECD transfer pricing method applied to determine the arm\'s length price for this intercompany transaction (CUP: Comparable Uncontrolled Price, Resale Price, Cost Plus, TNMM: Transactional Net Margin Method, Profit Split, Not Applicable).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Manager Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for managing this internal order. Accountable for budget adherence, deliverable completion, and cost control.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInternalResponsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal Responsible Cost Center Id' ;
    rdfs:comment 'Identifier of the cost center responsible for managing and executing this internal order. Links to the organizational unit accountable for budget and deliverables.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primaryInternalTechnicalLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Internal Technical Lead Employee Id' ;
    rdfs:comment 'Identifier of the employee serving as technical lead for this internal order. Responsible for technical execution and quality of deliverables.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual costs posted to this internal order to date. Includes direct costs, allocations, and internal activity charges.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetProfile rdf:type rdf:Property ;
    rdfs:label 'Budget Profile' ;
    rdfs:comment 'SAP CO budget profile code defining budget control parameters: tolerance limits, availability checks, and budget release procedures for this internal order.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs from purchase requisitions and purchase orders assigned to this internal order. Represents future obligations not yet invoiced.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Current Budget Amount' ;
    rdfs:comment 'Current approved budget amount including all supplements, returns, and transfers. Represents the total available funding for cost postings.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Relevant Flag' ;
    rdfs:comment 'Indicates whether this internal order is subject to GxP regulations (GMP, GLP, GCP). True for manufacturing, laboratory, or clinical projects requiring validated processes and audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Detailed description of the internal order purpose, scope, and objectives. Used for comprehensive project documentation and audit trails.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCategory rdf:type rdf:Property ;
    rdfs:label 'Order Category' ;
    rdfs:comment 'Business category of the internal order defining the nature of cost tracking: R&D programs, capital investments, overhead allocation, marketing campaigns, quality initiatives, or manufacturing projects.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of internal order as real (actual cost posting) or statistical (informational tracking only). Real orders allow direct cost postings; statistical orders are used for parallel cost tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'Initial approved budget amount for this internal order in the company code currency. Represents the baseline funding allocation before any supplements or returns.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning End Date' ;
    rdfs:comment 'Planned completion date for this internal order. Used for project scheduling, milestone tracking, and settlement planning.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Start Date' ;
    rdfs:comment 'Planned start date for work on this internal order. Used for project scheduling and resource planning.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Flag' ;
    rdfs:comment 'Indicates whether this internal order supports a regulatory submission or compliance program requiring FDA, EMA, or other regulatory body approval. True for IVD validation studies, clinical assay development, or GxP facility upgrades.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementProfile rdf:type rdf:Property ;
    rdfs:label 'Settlement Profile' ;
    rdfs:comment 'SAP CO settlement profile code defining the rules for allocating internal order costs to receiving cost objects (cost centers, assets, G/L accounts) at period-end.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRule rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule' ;
    rdfs:comment 'Detailed settlement rule specification defining target cost objects, allocation percentages, and settlement types for distributing internal order costs.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant Flag' ;
    rdfs:comment 'Indicates whether this internal order is subject to SOX financial controls and audit requirements. True for orders involving capitalized R&D, fixed asset construction, or material financial statement impacts.' ;
    rdfs:domain ind:InternalOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Posted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SOX compliance and segregation of duties validation require tracking which employee posted each journal entry. Critical for audit trail, maker-checker controls, and access certification reviews in GxP' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Batch input session name if this journal entry was created through batch processing. Used for mass data upload tracking and error resolution.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Changed Timestamp' ;
    rdfs:comment 'System timestamp when this journal entry record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'Document number of the clearing document if this journal entry has been cleared (e.g., payment clearing an invoice). Used for open item management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description at the document header level providing context about the journal entry purpose or business transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP FI document number assigned to this journal entry. Unique business identifier for the accounting document within the fiscal year and company code.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Number of line items contained in this journal entry document. Used for document completeness validation and processing efficiency analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingProcess rdf:type rdf:Property ;
    rdfs:label 'Originating Process' ;
    rdfs:comment 'Business process that originated this journal entry. Identifies the source transaction type for traceability and process-specific reporting. [ENUM-REF-CANDIDATE: revenue_recognition|cogs_allocation|rd_capitalization|payroll|procurement|asset_depreciation|intercompany|manual_adjustment|accrual|tax_provision|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is in parked status (saved but not yet posted). Parked documents do not update the general ledger until posted.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'Posting period within the fiscal year (1-12 for regular periods, 13-16 for special periods). Used for monthly financial close and reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this journal entry to source documents such as invoices, purchase orders, or contracts. Used for cross-system reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when this journal entry was reversed. Null if the document has not been reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversing journal entry. Null if this document has not been reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Amount' ;
    rdfs:comment 'Total document amount in transaction currency. Sum of all line item amounts in the original transaction currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current workflow status of the journal entry document. Used for approval workflows and SOX controls on manual journal entries.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction record in SAP FI. Primary key for the payment entity.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAccountId rdf:type rdf:Property ;
    rdfs:label 'Payment Account Id' ;
    rdfs:comment 'Reference to the customer master record making the incoming payment. Includes research institutions, clinical laboratories, and biopharma partners purchasing sequencing services or instruments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:paymentBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Payment Bank Account Id' ;
    rdfs:comment 'Reference to the house bank account used for the payment transaction. Links to bank master data containing account number, routing information, and bank details.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Bank fees and charges deducted for processing the payment transaction (wire fees, foreign exchange fees, intermediary bank charges). Allocated to treasury cost center.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the bank for the payment transaction. Used for bank statement reconciliation and payment tracking with financial institutions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockCode rdf:type rdf:Property ;
    rdfs:label 'Block Code' ;
    rdfs:comment 'Single-character code indicating if payment is blocked for processing (A=blocked for approval, Q=blocked for quality issue, blank=not blocked). Supports SOX segregation of duties controls.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text explanation for why the payment is blocked. Examples: pending invoice verification, disputed amount, missing receiving documentation, compliance hold.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'General ledger account number to which the payment is posted. Determines financial statement line item classification (cash, accounts payable, expense) for SOX-compliant reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'Payment amount converted to the company code local currency for financial consolidation and P&L reporting. Used when payment_currency differs from company_code base currency.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates whether this payment represents a partial settlement of the invoice (True) or full settlement (False). Used for open item management and aging analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Run Number' ;
    rdfs:comment 'Identifier for the automated payment run batch that generated this payment. Used for grouping payments processed together and tracking payment proposal execution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of payment direction and counterparty type. Outgoing vendor payments include reagent suppliers, CROs, CMOs, instrument component vendors. Incoming customer payments include research institutions, clinical labs, biopharma partners.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Bank statement reconciliation status indicating whether the payment has been matched to a bank statement line item. Critical for cash management and SOX cash reconciliation controls.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceText rdf:type rdf:Property ;
    rdfs:label 'Reference Text' ;
    rdfs:comment 'Free-text field for additional payment details, remittance information, or special instructions. Appears on bank transfer and vendor remittance advice.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsCode rdf:type rdf:Property ;
    rdfs:label 'Terms Code' ;
    rdfs:comment 'SAP payment terms code defining the due date calculation and discount conditions (e.g., Net 30, 2/10 Net 30). Drives automatic payment proposal and cash discount capture.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds are debited or credited for interest calculation and cash position management. May differ from payment_date for bank processing timing.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amortizationMethod rdf:type rdf:Property ;
    rdfs:label 'Amortization Method' ;
    rdfs:comment 'Method used to amortize the capitalized intangible asset over its useful life.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Amortization Period Months' ;
    rdfs:comment 'Expected useful life of the intangible asset in months. Used to calculate monthly amortization expense.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amortizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Amortization Start Date' ;
    rdfs:comment 'Date when amortization of the capitalized intangible asset begins. Typically aligned with product launch or regulatory approval.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the individual or committee that approved the capitalization decision (e.g., CFO, Finance Committee).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDecisionNumber rdf:type rdf:Property ;
    rdfs:label 'Capitalization Decision Number' ;
    rdfs:comment 'Unique business identifier for the capitalization assessment decision. Used for audit trail and cross-reference with approval documentation.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationStatus rdf:type rdf:Property ;
    rdfs:label 'Capitalization Status' ;
    rdfs:comment 'Current status of the capitalization decision workflow. Tracks approval state and posting status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizedAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalized Amount' ;
    rdfs:comment 'Amount of R&D expenditure approved for capitalization as intangible asset. Posted to balance sheet rather than expensed.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialViabilityConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Viability Confirmed Flag' ;
    rdfs:comment 'Indicates whether commercial viability and market potential have been confirmed. Required criterion for capitalization under IAS 38.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Date' ;
    rdfs:comment 'Date when the capitalization eligibility assessment was completed and decision was made.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expensedAmount rdf:type rdf:Property ;
    rdfs:label 'Expensed Amount' ;
    rdfs:comment 'Amount of R&D expenditure that does not qualify for capitalization and is immediately expensed to P&L.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountAsset rdf:type rdf:Property ;
    rdfs:label 'Gl Account Asset' ;
    rdfs:comment 'General ledger account number for capitalized intangible asset. Used when development costs are capitalized to balance sheet.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountExpense rdf:type rdf:Property ;
    rdfs:label 'Gl Account Expense' ;
    rdfs:comment 'General ledger account number for R&D expense posting. Used when costs are immediately expensed.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Indicates whether impairment indicators have been identified for the capitalized asset requiring impairment testing under ASC 360 / IAS 36.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intendedUseClassification rdf:type rdf:Property ;
    rdfs:label 'Intended Use Classification' ;
    rdfs:comment 'Regulatory classification of intended product use. RUO (Research Use Only) vs IVD (In Vitro Diagnostic) impacts capitalization eligibility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Type of genomics product being developed. Determines applicable regulatory pathway and capitalization criteria. [ENUM-REF-CANDIDATE: ngs_assay|array_product|crispr_tool|bioinformatics_pipeline|reagent_kit|instrument|software — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current phase of the R&D project lifecycle. Research phase costs are expensed; development phase costs may qualify for capitalization under ASC 730 / IAS 38.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory approval was received (FDA 510k, PMA, CE-IVD, etc.). Often triggers amortization start for capitalized development costs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalMilestone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Milestone' ;
    rdfs:comment 'Current regulatory approval milestone status for IVD products. Critical trigger for capitalization decisions in genomics biotech.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Business reason for reversing the capitalization (e.g., project cancelled, technical feasibility not sustained, regulatory rejection).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlAttestation rdf:type rdf:Property ;
    rdfs:label 'Sox Control Attestation' ;
    rdfs:comment 'Reference to SOX control documentation and attestation for this capitalization decision. Required for SOX 404 compliance.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalFeasibilityAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Achieved Flag' ;
    rdfs:comment 'Indicates whether technical feasibility has been established for the project. Key criterion for capitalization eligibility under ASC 730.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalFeasibilityDate rdf:type rdf:Property ;
    rdfs:label 'Technical Feasibility Date' ;
    rdfs:comment 'Date when technical feasibility was established. Marks the earliest point at which development costs may be capitalized.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:therapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Clinical or research therapeutic area targeted by the product (e.g., oncology, rare disease, reproductive health). Used for strategic reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalExpenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Total Expenditure Amount' ;
    rdfs:comment 'Total R&D expenditure amount for the project or period being evaluated for capitalization. Gross amount before capitalization split.' ;
    rdfs:domain ind:RdCapitalization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalRecognitionRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Revenue Recognition Id' ;
    rdfs:comment 'For reversal or adjustment records, references the revenue_recognition_id of the original recognition event being corrected. Null for original recognition events.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Reference to the specific performance obligation within the contract that this revenue recognition event satisfies.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'The cost of goods sold associated with this revenue recognition event, used for gross margin calculation and profitability analysis. Sourced from SAP CO product costing.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition event is eligible for sales commission calculation (True) or excluded from commission (False), based on company commission policy.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The remaining unearned revenue balance that has been invoiced but not yet recognized, representing future performance obligations. Calculated as allocated_amount minus recognized_amount.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The date on which the performance obligation was fulfilled (goods delivered, service completed, milestone achieved), triggering the revenue recognition event.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this revenue recognition event is posted in the financial system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMargin rdf:type rdf:Property ;
    rdfs:label 'Gross Margin' ;
    rdfs:comment 'The gross profit margin for this revenue recognition event, calculated as recognized_amount minus cogs_amount. Used for profitability analysis and pricing strategy evaluation.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'The date on which a contract modification was executed that affected this revenue recognition event. Null if modification_flag is False.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationFlag rdf:type rdf:Property ;
    rdfs:label 'Modification Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition event resulted from a contract modification (True) or is part of the original contract terms (False). Contract modifications require re-evaluation of performance obligations and transaction price allocation per ASC 606.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'For over-time revenue recognition, the percentage of the performance obligation that has been satisfied as of the recognition date. Used to calculate recognized_amount. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which revenue was recognized and posted to the general ledger. This is the date the performance obligation was satisfied per ASC 606.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The method by which revenue is recognized: point in time (upon delivery), over time (ratable recognition), milestone-based (upon achievement of contract milestones), usage-based (per unit consumed), or subscription ratable (monthly/quarterly allocation).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Recognition Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) in which this revenue was recognized, used for period-based financial reporting and consolidation.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle status of the revenue recognition event: pending (awaiting fulfillment), recognized (posted to GL), deferred (not yet earned), partially recognized (multi-period recognition in progress), reversed (corrected), or adjusted (modified post-recognition).' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The amount of revenue recognized in the current accounting period for this performance obligation. For point-in-time recognition, equals allocated_amount; for over-time recognition, represents the period-specific portion.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Business category of the revenue: instrument sales, reagent kits, consumables, sequencing services, bioinformatics services, clinical assay licensing, support contracts, training, or other. [ENUM-REF-CANDIDATE: instrument|reagent|consumable|sequencing_service|bioinformatics_service|clinical_assay|support_contract|training|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStream rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream' ;
    rdfs:comment 'High-level revenue stream classification for strategic reporting: core product sales, aftermarket (consumables/reagents), service revenue, subscription revenue, licensing/royalties, or other.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Three-letter geographic region code where the revenue was generated (e.g., USA, EUR, CHN, JPN), used for regional revenue analysis and geographic segment reporting.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'The total transaction price allocated to this performance obligation per ASC 606 Step 3, representing the amount of consideration the entity expects to receive in exchange for transferring goods or services.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:soxControlId rdf:type rdf:Property ;
    rdfs:label 'Sox Control Id' ;
    rdfs:comment 'Unique identifier for the SOX control. Primary key for the sox_control data product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SoxControl .

ind:controlOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Control Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SOX control ownership must link to employee master for responsibility tracking, organizational change impact analysis, access reviews, and control testing assignments. Essential for SOX 404 compliance' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compensatingControlDescription rdf:type rdf:Property ;
    rdfs:label 'Compensating Control Description' ;
    rdfs:comment 'Description of any compensating or mitigating controls in place while a deficiency is being remediated. Compensating controls provide interim assurance that risks are managed during the remediation period.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDescription rdf:type rdf:Property ;
    rdfs:label 'Control Description' ;
    rdfs:comment 'Detailed narrative describing the control objective, procedures performed, evidence retained, and how the control mitigates the identified risk. Includes who performs the control, what is reviewed, and acceptance criteria.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Control Documentation Reference' ;
    rdfs:comment 'Reference to the formal control documentation (e.g., process narrative, flowchart, risk-control matrix document ID) that provides detailed control design specifications.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrequency rdf:type rdf:Property ;
    rdfs:label 'Control Frequency' ;
    rdfs:comment 'How often the control is performed or operates. Continuous controls operate in real-time (e.g., system access restrictions), while periodic controls operate at defined intervals (e.g., monthly reconciliations). [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|annually|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNature rdf:type rdf:Property ;
    rdfs:label 'Control Nature' ;
    rdfs:comment 'Describes the execution mechanism of the control: manual (performed entirely by people), automated (system-enforced), IT-dependent manual (manual control relying on system reports), or IT general control (infrastructure/access control).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlNumber rdf:type rdf:Property ;
    rdfs:label 'Control Number' ;
    rdfs:comment 'Business-facing unique identifier for the control, typically formatted as domain prefix followed by sequential number (e.g., FIN-001, IT-GC-045). Used in audit documentation and management reporting.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPerformerName rdf:type rdf:Property ;
    rdfs:label 'Control Performer Name' ;
    rdfs:comment 'Name of the individual or role that executes the control activity. May differ from control owner. For automated controls, this may reference the system or application name.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of the control. Active controls are in operation and subject to testing. Inactive or retired controls are no longer in effect.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTitle rdf:type rdf:Property ;
    rdfs:label 'Control Title' ;
    rdfs:comment 'Short descriptive title of the control activity (e.g., \'Journal Entry Approval Over $50K\', \'Segregation of Duties - AP Processing\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlType rdf:type rdf:Property ;
    rdfs:label 'Control Type' ;
    rdfs:comment 'Classification of the control based on its timing and purpose: preventive (stops errors before they occur), detective (identifies errors after occurrence), or corrective (remediates identified issues).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyClassification rdf:type rdf:Property ;
    rdfs:label 'Deficiency Classification' ;
    rdfs:comment 'Severity classification of any identified control deficiency. Control deficiency: minor issue. Significant deficiency: important enough to merit attention by those charged with governance. Material weakness: reasonable possibility of material misstatement not being prevented or detected.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Deficiency Description' ;
    rdfs:comment 'Detailed description of the control deficiency identified during testing, including root cause analysis, impact assessment, and specific instances where the control failed to operate as designed.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAuditorReliance rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reliance' ;
    rdfs:comment 'Flag indicating whether external auditors plan to rely on this control for their financial statement audit. Controls with auditor reliance require more rigorous testing and documentation.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementAssertion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Assertion' ;
    rdfs:comment 'The financial statement assertion(s) addressed by this control: existence/occurrence, completeness, valuation/allocation, rights/obligations, presentation/disclosure. Multiple assertions may be listed if applicable.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Key Control Indicator' ;
    rdfs:comment 'Flag indicating whether this is a key control upon which external auditors may place reliance for financial statement audit purposes. Key controls are subject to more rigorous testing requirements.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Test Date' ;
    rdfs:comment 'Date when the control was most recently tested for design and operating effectiveness. Used to track testing currency and plan future testing cycles.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementReviewConclusion rdf:type rdf:Property ;
    rdfs:label 'Management Review Conclusion' ;
    rdfs:comment 'Management\'s assessment of control effectiveness based on testing results and operational performance. Used for Section 302/404 certifications and disclosure decisions.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date when management last reviewed the control design and operating effectiveness as part of their Section 302/404 certification process.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Test Due Date' ;
    rdfs:comment 'Scheduled date for the next control testing activity. Calculated based on control frequency, risk rating, and prior test results. Used for test planning and resource allocation.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The business process or financial cycle to which this control belongs (e.g., \'Revenue Recognition\', \'Accounts Payable\', \'Inventory Valuation\', \'Payroll Processing\', \'Fixed Assets\', \'Period-End Close\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name of the individual accountable for executing the remediation plan and achieving control effectiveness. May differ from the control owner if organizational changes are required.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Documented action plan to address identified control deficiencies. Includes specific corrective actions, responsible parties, resources required, and interim compensating controls if applicable.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Committed date by which the control deficiency will be fully remediated and the control will operate effectively. Used for management tracking and external auditor follow-up.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Description of the financial reporting risk that this control is designed to mitigate. Articulates what could go wrong in the absence of the control (e.g., \'Unauthorized journal entries could result in material misstatement\').' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationOfDutiesMatrixReference rdf:type rdf:Property ;
    rdfs:label 'Segregation Of Duties Matrix Reference' ;
    rdfs:comment 'Reference to the documented segregation of duties matrix that defines incompatible functions and role assignments. Links this control to the broader SOD framework.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemApplication rdf:type rdf:Property ;
    rdfs:label 'System Application' ;
    rdfs:comment 'Name of the primary system or application in which the control operates or from which control evidence is generated (e.g., \'SAP FI\', \'Oracle Cloud HCM\', \'Veeva Vault\'). Critical for IT general control mapping.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testApproach rdf:type rdf:Property ;
    rdfs:label 'Test Approach' ;
    rdfs:comment 'Primary testing methodology used to evaluate control effectiveness: inquiry (asking questions), observation (watching execution), inspection (reviewing evidence), reperformance (executing control independently), or data analytics (statistical sampling).' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEvidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Test Evidence Location' ;
    rdfs:comment 'File path, document management system reference, or repository location where control testing evidence is stored. Required for audit trail and external auditor review.' ;
    rdfs:domain ind:SoxControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting transaction record in SAP FI. Primary key for tax transaction tracking across all jurisdictions.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Reference to the general ledger account to which this tax posting is recorded. Links to the chart of accounts structure.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:customerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Tax Number' ;
    rdfs:comment 'Tax identification number of the customer for output tax postings. Used for reverse charge VAT and cross-border transaction reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredTaxFlag rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Flag' ;
    rdfs:comment 'Indicates whether this tax posting represents a deferred tax asset or liability. True for deferred tax entries, false for current tax postings.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, province) where the tax obligation arises. Examples: US-CA (California), GB (United Kingdom), DE (Germany), SG (Singapore).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Amount' ;
    rdfs:comment 'Tax amount converted to local reporting currency using the exchange rate at posting date. Used for statutory financial reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Base Amount' ;
    rdfs:comment 'Tax base amount converted to local reporting currency using the exchange rate at posting date. Used for statutory financial reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number of the payment transaction used to settle this tax liability with the tax authority. Links to payment document for reconciliation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current status of the tax posting in the financial system. Posted (finalized), parked (draft), cleared (settled with tax authority), reversed (corrected), cancelled (voided).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdProjectCode rdf:type rdf:Property ;
    rdfs:label 'Rd Project Code' ;
    rdfs:comment 'Project code for R&D activities eligible for tax credits. Links tax postings to qualifying R&D expenditure for credit claim substantiation.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdTaxCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Rd Tax Credit Flag' ;
    rdfs:comment 'Indicates whether this posting relates to R&D tax credit claims (Section 41 US, HMRC UK R&D relief). True for R&D tax credit transactions.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reverseChargeFlag rdf:type rdf:Property ;
    rdfs:label 'Reverse Charge Flag' ;
    rdfs:comment 'Indicates whether the reverse charge mechanism applies (customer self-assesses VAT/GST instead of supplier charging it). True for reverse charge transactions.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxAuthority rdf:type rdf:Property ;
    rdfs:label 'Tax Authority' ;
    rdfs:comment 'Name of the tax authority or revenue agency to which the tax is owed or from which a credit is claimed. Examples: IRS, HMRC, Finanzamt, IRAS.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Base Amount' ;
    rdfs:comment 'The taxable base amount (net amount before tax) on which the tax calculation is performed. Denominated in transaction currency.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether the tax is input (paid to suppliers), output (collected from customers), payable (owed to tax authority), or receivable (refund/credit from tax authority).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Reference number of the tax exemption certificate or ruling that supports the exemption claim. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Code' ;
    rdfs:comment 'Code indicating the reason for tax exemption or reduced rate. Examples: export (zero-rated export), RUO (research use only exempt), IVD_exempt. Blank if no exemption applies.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'The tax rate percentage applied to the tax base amount. Examples: 20.00 (UK VAT), 7.00 (California sales tax), 19.00 (German VAT).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Tax registration or identification number of the company code in the jurisdiction. Examples: VAT number (EU), GST registration (Singapore), EIN (US). Used for tax return filing.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'Tax reporting period to which this posting belongs. Format: YYYY-QN for quarterly (e.g., 2024-Q1) or YYYY-MNN for monthly (e.g., 2024-M03). Determines which tax return filing includes this transaction.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax transaction type. Includes VAT (Value Added Tax), GST (Goods and Services Tax), sales tax, withholding tax, use tax, excise tax, customs duty, and R&D tax credit. [ENUM-REF-CANDIDATE: VAT|GST|sales_tax|withholding_tax|use_tax|excise_tax|customs_duty|rd_tax_credit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transaction. Examples: USD, EUR, GBP, SGD.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Tax Number' ;
    rdfs:comment 'Tax identification number of the vendor or supplier for input tax postings. Used for VAT/GST reclaim validation and withholding tax reporting.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxFlag rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Flag' ;
    rdfs:comment 'Indicates whether this posting represents withholding tax deducted at source from payments to vendors or employees. True for withholding tax entries.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calibrationRecordId rdf:type rdf:Property ;
    rdfs:label 'Calibration Record Id' ;
    rdfs:comment 'Unique identifier for the calibration record. Primary key. Inferred role: TRANSACTION_HEADER (calibration event with lifecycle, timestamps, and references to instrument asset).' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentQualificationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Qualification Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.equipment_qualification. Business justification: Instrument calibrations satisfy equipment qualification requirements in GMP manufacturing. Regulatory auditors require cross-reference between calibration events and qualification protocols to verify ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentQualification .

ind:maintenanceEventId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Event Id' ;
    rdfs:comment 'Foreign key linking to instrument.maintenance_event. Business justification: Calibration activities are often performed as part of a maintenance event (preventive or corrective). Many calibration records can be part of one maintenance event. This links the calibration executio' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Foreign key linking to instrument.pm_schedule. Business justification: Calibration events may be scheduled as part of the preventive maintenance schedule. Many calibration records can reference one pm_schedule. Removing calibration_frequency_days from calibration_record ' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:primaryCalibrationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Calibration Employee Id' ;
    rdfs:comment 'Reference to the technician or field service engineer who performed the calibration. Links to workforce or employee master data.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:researchProtocolId rdf:type rdf:Property ;
    rdfs:label 'Research Protocol Id' ;
    rdfs:comment 'Reference to the Standard Operating Procedure (SOP) or work instruction used to perform the calibration. Links to the document control system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchProtocol .

ind:calibrationCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Reference' ;
    rdfs:comment 'Reference number or document identifier for the calibration certificate issued after the calibration event. Links to the formal calibration documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date when the calibration was performed. Principal business event timestamp for the calibration activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Date when the next calibration is due. Used to schedule preventive maintenance and ensure continuous compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration End Timestamp' ;
    rdfs:comment 'Timestamp when the calibration activity was completed. Used for turnaround time (TAT) tracking and resource planning.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calibrationEventNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Event Number' ;
    rdfs:comment 'Business identifier for the calibration event. Externally-known unique number used for traceability and audit purposes.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationLocation rdf:type rdf:Property ;
    rdfs:label 'Calibration Location' ;
    rdfs:comment 'Physical location where the calibration was performed (e.g., customer site, service center, manufacturing facility). Important for field service tracking.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationNotes rdf:type rdf:Property ;
    rdfs:label 'Calibration Notes' ;
    rdfs:comment 'Free-text notes or observations recorded by the technician during the calibration event. Captures additional context not covered by structured fields.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationProcedureVersion rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Version' ;
    rdfs:comment 'Version number of the calibration procedure used. Ensures traceability to the specific version of the SOP in effect at the time of calibration.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandardCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Certificate Number' ;
    rdfs:comment 'Certificate number of the calibration standard used. Provides traceability to the certifying authority.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationStandardExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Standard Expiry Date' ;
    rdfs:comment 'Expiration date of the calibration standard used. Ensures that only valid, in-date standards are used for calibration.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calibration Start Timestamp' ;
    rdfs:comment 'Timestamp when the calibration activity started. Used for turnaround time (TAT) tracking and resource planning.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calibrationStatus rdf:type rdf:Property ;
    rdfs:label 'Calibration Status' ;
    rdfs:comment 'Current lifecycle status of the calibration event. Tracks the calibration workflow from scheduling through completion and expiration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationType rdf:type rdf:Property ;
    rdfs:label 'Calibration Type' ;
    rdfs:comment 'Type of calibration performed on the instrument. Categorizes the calibration by the system or subsystem being calibrated.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of the corrective action taken or required if the calibration failed or showed out-of-tolerance results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective action is required based on the calibration results. Triggers follow-up activities if calibration failed or showed significant deviation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationFromStandard rdf:type rdf:Property ;
    rdfs:label 'Deviation From Standard' ;
    rdfs:comment 'Calculated deviation of the measured value from the calibration standard. Used for trend analysis and predictive maintenance.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Environmental Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage at the time of calibration. Environmental conditions can affect calibration accuracy.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Environmental Temperature C' ;
    rdfs:comment 'Ambient temperature in degrees Celsius at the time of calibration. Environmental conditions can affect calibration accuracy.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Actual value measured during the calibration event. Compared against tolerance limits to determine pass/fail status.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Outcome of the calibration event. Indicates whether the instrument met the calibration tolerance requirements.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Service Order Number' ;
    rdfs:comment 'Reference to the field service order or work order under which the calibration was performed. Links to ServiceNow or SAP PM.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Certification or qualification number of the technician who performed the calibration. Ensures that only qualified personnel perform calibration activities.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the technician who performed the calibration. Captured for audit trail and traceability purposes.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'Lower acceptable limit for the calibration measurement. Defines the minimum acceptable value for the calibrated parameter.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'Upper acceptable limit for the calibration measurement. Defines the maximum acceptable value for the calibrated parameter.' ;
    rdfs:domain ind:CalibrationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldServiceRequestId rdf:type rdf:Property ;
    rdfs:label 'Field Service Request Id' ;
    rdfs:comment 'Unique identifier for the field service request. Primary key for this entity.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer account requesting the field service. Links to customer master data in Salesforce CRM and SAP SD.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:siteContactId rdf:type rdf:Property ;
    rdfs:label 'Site Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Service requests need primary site contact for coordination, facility access, safety protocols, and service sign-off. Different from account-level contacts. Essential for field service execution and c' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual total cost in USD incurred for this field service request, including labor, travel, and parts. Used for financial reporting and profitability analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual on-site service duration in hours from start to completion, used for labor cost calculation and future estimation refinement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the field service work was completed on-site, used for SLA compliance and labor cost calculation.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the field service engineer began work on-site, used for SLA tracking and billing.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether this field service request is billable to the customer. True for out-of-warranty or non-contract services; false for warranty or contract-covered services.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Timestamp when the field service request was cancelled, if applicable. Null for non-cancelled requests.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp when the field service request was marked as completed and closed, indicating successful resolution and customer acceptance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated on-site service duration in hours, based on request type and historical data, used for scheduling and resource allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldServiceRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Field Service Request Status' ;
    rdfs:comment 'Current lifecycle status of the field service request. Tracks progression from draft through assignment, scheduling, execution, and closure. [ENUM-REF-CANDIDATE: draft|submitted|assigned|scheduled|in_progress|on_hold|completed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Invoice Amount Usd' ;
    rdfs:comment 'Total amount in USD invoiced to the customer for this billable field service request, including labor, travel, parts, and applicable taxes.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Required Flag' ;
    rdfs:comment 'Indicates whether replacement parts or consumables are required for this field service request. True if parts needed; false otherwise.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Detailed description of the issue, symptom, or service requirement as reported by the customer or internal requester. Includes error codes, performance degradation details, or installation specifications.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Planned completion timestamp for the field service visit, used for resource planning and customer communication.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise scheduled start timestamp for the field service visit, including time zone information for accurate coordination.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Visit Date' ;
    rdfs:comment 'Planned date for the field service engineer to visit the customer or internal site to perform the requested service.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Status' ;
    rdfs:comment 'Current compliance status against SLA commitments. Met indicates within target; at_risk indicates approaching deadline; breached indicates SLA violation; not_applicable for requests without SLA.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Special instructions or requirements for the field service visit, such as site access procedures, safety protocols, customer contact preferences, or specific tools required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Required Flag' ;
    rdfs:comment 'Indicates whether the field service engineer must travel to perform this service. True for on-site visits; false for remote support or internal lab work.' ;
    rdfs:domain ind:FieldServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firmwareDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Firmware Deployment Id' ;
    rdfs:comment 'Unique identifier for the firmware deployment event. Primary key for the firmware deployment data product.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmwareVersionId rdf:type rdf:Property ;
    rdfs:label 'Firmware Version Id' ;
    rdfs:comment 'Reference to the specific firmware version being deployed from the approved version catalog.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FirmwareVersion .

ind:primaryFirmwareEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Firmware Employee Id' ;
    rdfs:comment 'Reference to the field service technician or engineer who executed the firmware deployment.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFirmwareScheduledByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Firmware Scheduled By User Employee Id' ;
    rdfs:comment 'Reference to the user who scheduled this firmware deployment event.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:backupCreatedFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Created Flag' ;
    rdfs:comment 'Indicates whether a backup of the previous firmware and instrument configuration was created before deployment.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupLocation rdf:type rdf:Property ;
    rdfs:label 'Backup Location' ;
    rdfs:comment 'Storage location or path where the pre-deployment backup was saved.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Completion Date' ;
    rdfs:comment 'Date when post-deployment calibration was completed and verified.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Calibration Required Flag' ;
    rdfs:comment 'Indicates whether instrument recalibration is required following this firmware deployment.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerApprovalReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Received Date' ;
    rdfs:comment 'Date when customer approval was received for the firmware deployment.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required Flag' ;
    rdfs:comment 'Indicates whether customer approval was required before executing this firmware deployment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer was notified about the scheduled firmware deployment and any associated downtime.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'The date when the firmware deployment was executed or scheduled.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Deployment Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the firmware deployment process.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deploymentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment End Timestamp' ;
    rdfs:comment 'Precise timestamp when the firmware deployment process completed or failed.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentLocation rdf:type rdf:Property ;
    rdfs:label 'Deployment Location' ;
    rdfs:comment 'Physical or logical location where the firmware deployment was executed.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentMethod rdf:type rdf:Property ;
    rdfs:label 'Deployment Method' ;
    rdfs:comment 'The technical method used to deploy the firmware to the target instrument.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentNotes rdf:type rdf:Property ;
    rdfs:label 'Deployment Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the technician during the firmware deployment process.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Business identifier for the firmware deployment event, used for tracking and audit purposes.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentPackageChecksum rdf:type rdf:Property ;
    rdfs:label 'Deployment Package Checksum' ;
    rdfs:comment 'Cryptographic checksum of the firmware deployment package to verify integrity and authenticity.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentPriority rdf:type rdf:Property ;
    rdfs:label 'Deployment Priority' ;
    rdfs:comment 'Business priority level assigned to this firmware deployment based on urgency and impact.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the firmware deployment process began.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the firmware deployment event.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total instrument downtime in minutes caused by the firmware deployment activity.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iqOqPqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Iq Oq Pq Completion Date' ;
    rdfs:comment 'Date when the IQ/OQ/PQ requalification was completed following the firmware deployment.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iqOqPqRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iq Oq Pq Required Flag' ;
    rdfs:comment 'Indicates whether this firmware deployment requires formal IQ/OQ/PQ requalification of the instrument per GxP requirements.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postDeploymentValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Post Deployment Validation Status' ;
    rdfs:comment 'Status of validation checks performed after firmware deployment to verify successful installation and functionality.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preDeploymentValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Deployment Validation Status' ;
    rdfs:comment 'Status of validation checks performed before firmware deployment to ensure instrument readiness.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Previous Firmware Version' ;
    rdfs:comment 'The firmware version number that was active on the instrument before this deployment.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether this firmware deployment has regulatory implications requiring additional documentation or approval under GxP or FDA regulations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackFlag rdf:type rdf:Property ;
    rdfs:label 'Rollback Flag' ;
    rdfs:comment 'Indicates whether this deployment was a rollback to a previous firmware version due to issues.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollbackReason rdf:type rdf:Property ;
    rdfs:label 'Rollback Reason' ;
    rdfs:comment 'Detailed explanation of why the firmware was rolled back to a previous version.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Service Ticket Number' ;
    rdfs:comment 'Reference to the ServiceNow field service ticket associated with this firmware deployment event.' ;
    rdfs:domain ind:FirmwareDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationQualificationId rdf:type rdf:Property ;
    rdfs:label 'Installation Qualification Id' ;
    rdfs:comment 'Unique identifier for the installation qualification record. Primary key for the IQ/OQ/PQ lifecycle event.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDocumentId rdf:type rdf:Property ;
    rdfs:label 'Protocol Document Id' ;
    rdfs:comment 'Document management system identifier for the qualification protocol, linking to the controlled document repository (e.g., Veeva Vault, MasterControl).' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:cfrPart11CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cfr Part 11 Compliant Flag' ;
    rdfs:comment 'Boolean indicator confirming whether electronic records and signatures for this qualification meet FDA 21 CFR Part 11 requirements for electronic records in regulated environments.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Date' ;
    rdfs:comment 'Date on which the customer formally accepted the qualification results and instrument readiness for use.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured Flag' ;
    rdfs:comment 'Boolean indicator confirming whether customer acceptance signature was captured as part of the qualification closeout process.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Number of deviations or non-conformances identified during the qualification execution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationSummary rdf:type rdf:Property ;
    rdfs:label 'Deviation Summary' ;
    rdfs:comment 'Summary description of deviations, non-conformances, or out-of-specification results noted during qualification, including corrective actions taken.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Recorded environmental conditions during qualification execution, including temperature, humidity, and other relevant parameters required for instrument performance validation.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Compliant Flag' ;
    rdfs:comment 'Boolean indicator confirming whether this qualification was performed under GxP-regulated conditions (GMP, GLP, GCP) as required for FDA, EMA, or other regulatory submissions.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performedByEngineerName rdf:type rdf:Property ;
    rdfs:label 'Performed By Engineer Name' ;
    rdfs:comment 'Full name of the field service engineer or validation specialist who executed the qualification protocol.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Externally-known unique document number or protocol identifier for this IQ/OQ/PQ qualification event, used for traceability and regulatory submission.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of the qualification event: scheduled, in progress, passed, failed, conditional pass (with deviations), cancelled, or pending approval. [ENUM-REF-CANDIDATE: scheduled|in_progress|passed|failed|conditional_pass|cancelled|pending_approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification performed: IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification), or combined phases.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Planned date for the qualification event, used for resource planning and customer coordination.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testCaseCount rdf:type rdf:Property ;
    rdfs:label 'Test Case Count' ;
    rdfs:comment 'Total number of test cases or acceptance criteria executed as part of the qualification protocol.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCasePassedCount rdf:type rdf:Property ;
    rdfs:label 'Test Case Passed Count' ;
    rdfs:comment 'Number of test cases that met acceptance criteria and passed during qualification execution.' ;
    rdfs:domain ind:InstallationQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerSupplierId rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Instruments are procured from suppliers/manufacturers; tracking the supplier enables warranty claim processing, service escalation to vendor technical support, and supplier performance analysis for in' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_center. Business justification: Sequencers and analytical instruments are physically assigned to manufacturing work centers (library prep stations, QC bays) for capacity planning, scheduling, and operational tracking. Essential for ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:gxpClassification rdf:type rdf:Property ;
    rdfs:label 'Gxp Classification' ;
    rdfs:comment 'Regulatory classification indicating whether the instrument is used for Research Use Only (RUO), In Vitro Diagnostic (IVD), Laboratory Developed Test (LDT), Good Manufacturing Practice (GMP), or non-regulated purposes. Determines qualification and validation requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'High-level classification of the instrument platform type. Used for operational segmentation and capacity planning. [ENUM-REF-CANDIDATE: NGS Sequencer|Array Scanner|PCR System|qPCR System|Liquid Handler|Gene Editor|Flow Cytometer|Mass Spectrometer — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Iq Completion Date' ;
    rdfs:comment 'Date when Installation Qualification protocol was successfully completed. Required for GxP-classified instruments.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isValidated rdf:type rdf:Property ;
    rdfs:label 'Is Validated' ;
    rdfs:comment 'Indicates whether the instrument has completed all required IQ/OQ/PQ validation protocols and is qualified for GxP use.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration event. Critical for maintaining measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPreventiveMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Preventive Maintenance Date' ;
    rdfs:comment 'Date of the most recent scheduled preventive maintenance service.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration event. Used for preventive maintenance planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPreventiveMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Preventive Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service. Used for service dispatch planning.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the instrument. Determines availability for production runs and service scheduling. [ENUM-REF-CANDIDATE: Active|Idle|Maintenance|Calibration|Quarantine|Decommissioned|Retired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Oq Completion Date' ;
    rdfs:comment 'Date when Operational Qualification protocol was successfully completed. Verifies instrument operates according to specifications.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the instrument is owned by Genomics Biotech, leased, rented, on loan, or owned by a customer but managed by Genomics Biotech.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pqCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pq Completion Date' ;
    rdfs:comment 'Date when Performance Qualification protocol was successfully completed. Demonstrates consistent performance under routine conditions.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runTimeHours rdf:type rdf:Property ;
    rdfs:label 'Run Time Hours' ;
    rdfs:comment 'Typical duration of a single instrument run in hours. Used for scheduling and turnaround time (TAT) estimation.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceContractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Service Contract Expiry Date' ;
    rdfs:comment 'Date when the current service contract expires. Used for contract renewal planning.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Identifier for the active service or maintenance contract covering this instrument. Links to ServiceNow service agreements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tag rdf:type rdf:Property ;
    rdfs:label 'Tag' ;
    rdfs:comment 'Internal asset tracking identifier assigned by Genomics Biotech for fixed asset accounting and physical inventory management. Links to SAP PM asset master.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity' ;
    rdfs:comment 'Maximum throughput capacity of the instrument per run or per day, measured in instrument-specific units (e.g., samples per run, gigabases per run for sequencers). Used for capacity planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputUnit rdf:type rdf:Property ;
    rdfs:label 'Throughput Unit' ;
    rdfs:comment 'Unit of measure for throughput capacity (e.g., samples/run, Gb/run, reads/run, wells/plate).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUptimeHours rdf:type rdf:Property ;
    rdfs:label 'Total Uptime Hours' ;
    rdfs:comment 'Cumulative operational uptime in hours since installation. Used for reliability and availability metrics.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Validation Expiry Date' ;
    rdfs:comment 'Date when the current validation status expires and requalification is required. Applicable for GxP-classified instruments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configurationId rdf:type rdf:Property ;
    rdfs:label 'Configuration Id' ;
    rdfs:comment 'Unique identifier for the instrument configuration record. Primary key.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Baseline Configuration Id' ;
    rdfs:comment 'Reference to the validated baseline configuration from which this configuration was derived or against which it is compared.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Configuration .

ind:genomicRegionId rdf:type rdf:Property ;
    rdfs:label 'Genomic Region Id' ;
    rdfs:comment 'Foreign key linking to reference.genomic_region. Business justification: Targeted sequencing configurations specify which genomic regions (exome capture targets, gene panels, regulatory elements) the instrument is validated to analyze. Defines the assay\'s analytical scope ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicRegion .

ind:validatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Validated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GxP-validated instrument configurations require documented validator identity for 21 CFR Part 11 compliance, audit trails, and regulatory inspections. Replaces denormalized approved_by text field with' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled Flag' ;
    rdfs:comment 'Indicates whether audit trail logging is enabled for this configuration, capturing all user actions and system events.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupConfiguration rdf:type rdf:Property ;
    rdfs:label 'Backup Configuration' ;
    rdfs:comment 'Settings for automated data backup including frequency, retention policy, and backup destination.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationProfile rdf:type rdf:Property ;
    rdfs:label 'Calibration Profile' ;
    rdfs:comment 'Reference to the calibration settings or calibration curve applied in this configuration, ensuring measurement accuracy.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference to the formal change control request or ticket that authorized this configuration change.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed description of what was changed in this configuration version compared to the previous version.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'Cryptographic hash or checksum of the configuration file ensuring integrity and detecting unauthorized changes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name or label for this configuration profile (e.g., \'WGS High Throughput v3.2\', \'Clinical IVD Baseline\').' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this configuration profile.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationType rdf:type rdf:Property ;
    rdfs:label 'Configuration Type' ;
    rdfs:comment 'Classification of the configuration profile indicating its intended use context.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataOutputFormat rdf:type rdf:Property ;
    rdfs:label 'Data Output Format' ;
    rdfs:comment 'Primary data format produced by the instrument under this configuration (e.g., FASTQ for sequencing, IDAT for arrays).' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataStoragePath rdf:type rdf:Property ;
    rdfs:label 'Data Storage Path' ;
    rdfs:comment 'Default file system path or cloud storage location where instrument output data is written.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deployedBy rdf:type rdf:Property ;
    rdfs:label 'Deployed By' ;
    rdfs:comment 'Name or identifier of the person or system that deployed this configuration to the instrument.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deployment Timestamp' ;
    rdfs:comment 'Timestamp when this configuration was deployed to the instrument.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationFromBaseline rdf:type rdf:Property ;
    rdfs:label 'Deviation From Baseline' ;
    rdfs:comment 'Structured description of any deviations from the validated baseline configuration, including justification and risk assessment.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective From Timestamp' ;
    rdfs:comment 'Timestamp when this configuration became active on the instrument.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Until Timestamp' ;
    rdfs:comment 'Timestamp when this configuration was superseded or deactivated. Null if currently active.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electronicSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Required Flag' ;
    rdfs:comment 'Indicates whether electronic signatures are required for critical operations under this configuration.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enabledModules rdf:type rdf:Property ;
    rdfs:label 'Enabled Modules' ;
    rdfs:comment 'Comma-separated or JSON list of software modules, features, or capabilities enabled in this configuration (e.g., \'WGS,WES,Targeted_Panel,Methylation\').' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureFlags rdf:type rdf:Property ;
    rdfs:label 'Feature Flags' ;
    rdfs:comment 'JSON or key-value pairs representing software feature toggles and experimental capabilities enabled or disabled in this configuration.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'File system path or repository location where the full configuration file is stored.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Validated Flag' ;
    rdfs:comment 'Indicates whether this configuration has been validated under GxP regulations (GMP, GLP, GCP) for use in regulated environments.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ivdCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ivd Compliant Flag' ;
    rdfs:comment 'Indicates whether this configuration meets IVD regulatory requirements for clinical diagnostic use.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkConfiguration rdf:type rdf:Property ;
    rdfs:label 'Network Configuration' ;
    rdfs:comment 'Network settings for the instrument including IP address, subnet, gateway, DNS, proxy settings, and firewall rules.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlThresholds rdf:type rdf:Property ;
    rdfs:label 'Quality Control Thresholds' ;
    rdfs:comment 'JSON or structured text defining QC pass/fail thresholds for metrics such as Phred score, coverage depth, cluster density, and error rates.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Revalidation Due Date' ;
    rdfs:comment 'Date by which this configuration must be revalidated to maintain compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runParameterDefaults rdf:type rdf:Property ;
    rdfs:label 'Run Parameter Defaults' ;
    rdfs:comment 'JSON or structured text capturing default run parameters for sequencing or assay execution (e.g., read length, cycle count, flow cell type, chemistry version).' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySettings rdf:type rdf:Property ;
    rdfs:label 'Security Settings' ;
    rdfs:comment 'Security configuration including authentication method, encryption settings, access control policies, and audit logging parameters.' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAccessRoles rdf:type rdf:Property ;
    rdfs:label 'User Access Roles' ;
    rdfs:comment 'JSON or structured list defining user roles and permissions configured for this instrument (e.g., operator, supervisor, administrator, service engineer).' ;
    rdfs:domain ind:Configuration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Recommended calibration interval in days as specified by the manufacturer. Drives preventive maintenance scheduling and quality control compliance.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ceMarkCertificate rdf:type rdf:Property ;
    rdfs:label 'Ce Mark Certificate' ;
    rdfs:comment 'CE-IVD certificate number for instruments marketed in the European Union under IVDR 2017/746. Required for clinical diagnostic use in EU.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityRequirements rdf:type rdf:Property ;
    rdfs:label 'Connectivity Requirements' ;
    rdfs:comment 'Network and connectivity specifications (e.g., Ethernet, Wi-Fi, cloud integration, BaseSpace Sequence Hub). Required for IT infrastructure planning and data transfer.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'Date when the manufacturer discontinues production and sales of this instrument model. Critical for long-term procurement and replacement planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endOfSupportDate rdf:type rdf:Property ;
    rdfs:label 'End Of Support Date' ;
    rdfs:comment 'Date when the manufacturer discontinues technical support, software updates, and spare parts availability. Drives instrument lifecycle and replacement decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalRequirements rdf:type rdf:Property ;
    rdfs:label 'Environmental Requirements' ;
    rdfs:comment 'Operating environment specifications including temperature range, humidity range, and ventilation requirements. Required for facility qualification and instrument performance.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Clearance Number' ;
    rdfs:comment 'FDA 510(k) clearance number or PMA (Premarket Approval) number if the instrument is cleared for clinical diagnostic use in the United States.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'Date when the instrument model was first commercially released to the market. Used for product lifecycle tracking and competitive analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listPriceUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Usd' ;
    rdfs:comment 'Manufacturer list price in United States Dollars (USD). Used for budgeting, capital expenditure (CAPEX) planning, and return on investment (ROI) analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxReadsPerRun rdf:type rdf:Property ;
    rdfs:label 'Max Reads Per Run' ;
    rdfs:comment 'Maximum number of sequencing reads generated per instrument run. Used for sample multiplexing calculations and project planning.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxThroughputGb rdf:type rdf:Property ;
    rdfs:label 'Max Throughput Gb' ;
    rdfs:comment 'Maximum data output per run in gigabases (Gb). Key specification for capacity planning and application suitability (e.g., 6000 Gb for NovaSeq 6000 S4 flow cell).' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Manufacturer-specified mean time between failures (MTBF) in operational hours. Key reliability metric for capacity planning and uptime forecasting.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time required to repair and restore the instrument to operational status. Used for service level agreement (SLA) planning and downtime estimation.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelDescription rdf:type rdf:Property ;
    rdfs:label 'Model Description' ;
    rdfs:comment 'Detailed technical and marketing description of the instrument model, including key features, differentiators, and intended use cases.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle status of the instrument model in the product catalog. Active models are available for purchase; discontinued models are no longer sold but may still be supported.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplexingCapacity rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Capacity' ;
    rdfs:comment 'Maximum number of samples that can be pooled and sequenced simultaneously using index barcodes. Enables high-throughput sample processing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalDimensions rdf:type rdf:Property ;
    rdfs:label 'Physical Dimensions' ;
    rdfs:comment 'Instrument physical dimensions (length x width x height) in standard units. Required for laboratory space planning and installation.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformGeneration rdf:type rdf:Property ;
    rdfs:label 'Platform Generation' ;
    rdfs:comment 'Generation or version of the sequencing/analysis platform (e.g., NextSeq 1000/2000, NovaSeq X Series, Illumina DRAGEN). Indicates technology evolution and capability tier.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerRequirements rdf:type rdf:Property ;
    rdfs:label 'Power Requirements' ;
    rdfs:comment 'Electrical power specifications (voltage, amperage, phase) required for instrument operation. Critical for facility planning and installation qualification (IQ).' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveMaintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Preventive Maintenance Schedule' ;
    rdfs:comment 'Manufacturer-recommended preventive maintenance schedule (e.g., quarterly, semi-annual, annual tasks). Ensures instrument reliability and regulatory compliance.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLengthCapability rdf:type rdf:Property ;
    rdfs:label 'Read Length Capability' ;
    rdfs:comment 'Supported read length configurations in base pairs (e.g., 2x150bp, 2x250bp, single-end 75bp). Critical for application compatibility (WGS, WES, RNA-Seq).' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingChemistry rdf:type rdf:Property ;
    rdfs:label 'Sequencing Chemistry' ;
    rdfs:comment 'Supported sequencing chemistry or detection method (e.g., Sequencing by Synthesis (SBS), Reversible Terminator, Two-Channel SBS). Defines compatible reagent kits and flow cells.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractAvailable rdf:type rdf:Property ;
    rdfs:label 'Service Contract Available' ;
    rdfs:comment 'Indicates whether extended service contracts or service level agreements (SLAs) are available for this instrument model. True if available, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:softwarePlatform rdf:type rdf:Property ;
    rdfs:label 'Software Platform' ;
    rdfs:comment 'Onboard or companion software platform name and version (e.g., Illumina DRAGEN, BaseSpace, Instrument Control Software). Critical for bioinformatics pipeline compatibility.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedApplications rdf:type rdf:Property ;
    rdfs:label 'Supported Applications' ;
    rdfs:comment 'Comma-separated list of validated genomic applications (e.g., WGS, WES, RNA-Seq, Targeted Sequencing, Methylation, CNV Detection, SNP Genotyping). Guides customer application selection.' ;
    rdfs:domain ind:Model ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Standard manufacturer warranty period in months from date of installation. Impacts service agreement planning and total cost of ownership.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Instrument weight in kilograms. Required for shipping, handling, and facility floor load calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cartridgeId rdf:type rdf:Property ;
    rdfs:label 'Cartridge Id' ;
    rdfs:comment 'Unique identifier or serial number of the array cartridge, PCR plate, or reagent cartridge used in the run. Applicable to array scanners and qPCR/ddPCR platforms.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cartridge .

ind:reagentKitLotId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: GxP/FDA compliance mandates lot-level traceability for clinical runs. Enables quality investigations linking run failures to specific reagent lots, supports batch record requirements, and facilitates ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:variantDatabaseId rdf:type rdf:Property ;
    rdfs:label 'Variant Database Id' ;
    rdfs:comment 'Foreign key linking to reference.variant_database. Business justification: Clinical sequencing runs specify which variant databases (ClinVar, COSMIC, gnomAD) to use for annotation during analysis. This determines pathogenicity classification and clinical reporting content. R' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantDatabase .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_order. Business justification: Sequencing runs support work order QC checkpoints (library quality validation, intermediate product testing). Manufacturing execution systems require linking analytical runs to work orders for real-ti' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the instrument run completed or terminated, as recorded by the instrument control software.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the instrument run commenced, as recorded by the instrument control software or BaseSpace Sequence Hub.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cycleCount rdf:type rdf:Property ;
    rdfs:label 'Cycle Count' ;
    rdfs:comment 'Total number of sequencing cycles executed in the run, determining read length and paired-end configuration. Applicable to NGS platforms.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorRate rdf:type rdf:Property ;
    rdfs:label 'Error Rate' ;
    rdfs:comment 'Estimated sequencing error rate as a percentage, typically calculated from PhiX control spike-in. Lower values indicate higher accuracy.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Business-facing unique identifier or run name assigned by the operator or Laboratory Information Management System (LIMS). Often includes date, instrument serial, and sequence number.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Instrument Software Version' ;
    rdfs:comment 'Version number of the instrument control software or firmware used to execute the run, critical for reproducibility and troubleshooting.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClinicalRun rdf:type rdf:Property ;
    rdfs:label 'Is Clinical Run' ;
    rdfs:comment 'Boolean flag indicating whether this run was performed under Clinical Laboratory Improvement Amendments (CLIA) or In Vitro Diagnostic (IVD) regulatory requirements (True) or for Research Use Only (RUO) purposes (False).' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Quality Score' ;
    rdfs:comment 'Average Phred quality score across all bases in the run, indicating base-calling accuracy. Phred score of 30 corresponds to 99.9% accuracy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiplexingIndexStrategy rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Index Strategy' ;
    rdfs:comment 'Indexing strategy used for sample multiplexing: single index (one barcode), dual index (two barcodes), unique dual index (UDI for collision avoidance), or none (single sample run).' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputDataLocation rdf:type rdf:Property ;
    rdfs:label 'Output Data Location' ;
    rdfs:comment 'File system path or cloud storage URI (e.g., Amazon Web Services (AWS) S3 bucket, BaseSpace project path) where raw output data (FASTQ, BAM, or array intensity files) is stored.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentAlignedToPhix rdf:type rdf:Property ;
    rdfs:label 'Percent Aligned To Phix' ;
    rdfs:comment 'Percentage of reads that aligned to the PhiX control genome, confirming the expected spike-in concentration (typically 1%).' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentPfClusters rdf:type rdf:Property ;
    rdfs:label 'Percent Pf Clusters' ;
    rdfs:comment 'Percentage of clusters passing Illumina chastity filter, indicating the proportion of high-quality clusters. Typical target is >80%.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentQ30Bases rdf:type rdf:Property ;
    rdfs:label 'Percent Q30 Bases' ;
    rdfs:comment 'Percentage of bases with Phred quality score of 30 or higher (≥99.9% accuracy). Industry standard quality threshold for clinical and research sequencing.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phixErrorRate rdf:type rdf:Property ;
    rdfs:label 'Phix Error Rate' ;
    rdfs:comment 'Error rate measured specifically from PhiX control library spike-in, used as internal quality control for sequencing accuracy.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Qc Performed By' ;
    rdfs:comment 'Reference to the laboratory personnel or bioinformatician who performed the quality control review and approved or rejected the run.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Review Timestamp' ;
    rdfs:comment 'Date and time when the quality control review was completed and the run QC status was finalized.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readLength rdf:type rdf:Property ;
    rdfs:label 'Read Length' ;
    rdfs:comment 'Length of sequencing reads in base pairs (bp) for NGS runs, e.g., 150 bp paired-end. Null for non-sequencing assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runMode rdf:type rdf:Property ;
    rdfs:label 'Run Mode' ;
    rdfs:comment 'Operational mode or workflow configuration selected for the run: standard (default protocol), rapid (accelerated turnaround), high-throughput (maximum sample capacity), low-throughput (small batch), or custom (user-defined parameters).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Type of genomic assay or experiment performed: Whole Genome Sequencing (WGS), Whole Exome Sequencing (WES), targeted sequencing panel, RNA sequencing, ChIP sequencing, array-based genotyping, gene expression array, quantitative Polymerase Chain Reaction (qPCR), droplet digital PCR (ddPCR), CRISPR screening, or library quality control. [ENUM-REF-CANDIDATE: WGS|WES|targeted_sequencing|RNA_seq|ChIP_seq|array_genotyping|array_expression|qPCR|ddPCR|CRISPR_screen|library_QC — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the run was scheduled to begin, as recorded in the instrument scheduling system or LIMS.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalReadsGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Reads Generated' ;
    rdfs:comment 'Total number of sequencing reads (or read pairs for paired-end) generated by the run. Null for non-sequencing assays.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalYieldGb rdf:type rdf:Property ;
    rdfs:label 'Total Yield Gb' ;
    rdfs:comment 'Total sequencing yield in gigabases (Gb) produced by the run, calculated as total reads multiplied by read length. Null for non-sequencing assays.' ;
    rdfs:domain ind:InstrumentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedExperimentId rdf:type rdf:Property ;
    rdfs:label 'Affected Experiment Id' ;
    rdfs:comment 'Foreign key linking to research.experiment. Business justification: Unplanned maintenance impacts in-progress experiments. Business process: sample/run impact assessment, deviation documentation, and determining if experiments must be repeated. Critical for quality an' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Experiment .

ind:impactedWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Impacted Work Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_order. Business justification: Instrument downtime impacts production schedules. Operations teams need to track which work orders were delayed or affected by maintenance events for root cause analysis, capacity planning, and custom' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Reference to the primary field service technician or engineer who performed the maintenance.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceSupplierId rdf:type rdf:Property ;
    rdfs:label 'Service Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Field service events often involve supplier-provided technical support, warranty repairs, or factory-trained engineers. Tracking which supplier performed service is critical for warranty claim validat' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:verificationTestId rdf:type rdf:Property ;
    rdfs:label 'Verification Test Id' ;
    rdfs:comment 'Reference to the post-maintenance verification test or qualification run performed to validate instrument performance.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchTest .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work was completed.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time when maintenance work began.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Timestamp when the maintenance event record was first created in the system.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSignoffDatetime rdf:type rdf:Property ;
    rdfs:label 'Customer Signoff Datetime' ;
    rdfs:comment 'Date and time when the customer or authorized site representative signed off on the completed maintenance work.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSignoffName rdf:type rdf:Property ;
    rdfs:label 'Customer Signoff Name' ;
    rdfs:comment 'Name of the customer representative who signed off on the maintenance completion.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignoffRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Signoff Required' ;
    rdfs:comment 'Indicates whether customer or site manager sign-off is required for this maintenance event per service agreement terms.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Minutes' ;
    rdfs:comment 'Total instrument downtime in minutes during which the instrument was unavailable for production use.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Business impact assessment of the maintenance event on operations, customer commitments, and data quality.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours spent on the maintenance activity, including diagnostics, repair, and verification.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Timestamp when the maintenance event record was last updated.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maintenanceEventStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Event Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance event.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this maintenance event must be reported to regulatory authorities (FDA, EMA) due to patient safety or device malfunction implications.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Runs Affected Count' ;
    rdfs:comment 'Number of sequencing runs or assay runs impacted by the instrument issue that triggered this maintenance event.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplesImpactedCount rdf:type rdf:Property ;
    rdfs:label 'Samples Impacted Count' ;
    rdfs:comment 'Number of biological samples affected by the instrument failure or maintenance downtime.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned start date and time for the maintenance activity.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaActualResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Response Hours' ;
    rdfs:comment 'Actual response time in hours from event trigger to technician arrival or remote engagement.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicates whether the maintenance event met the contractual SLA response and resolution time commitments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Response Hours' ;
    rdfs:comment 'Target response time in hours per the service level agreement for this maintenance event priority level.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerSource rdf:type rdf:Property ;
    rdfs:label 'Trigger Source' ;
    rdfs:comment 'What initiated the maintenance event: scheduled preventive maintenance, instrument alarm, operator report, performance degradation detected, quality event, or regulatory inspection finding.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Coverage Flag' ;
    rdfs:comment 'Indicates whether the maintenance event and parts are covered under manufacturer or extended warranty.' ;
    rdfs:domain ind:MaintenanceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'External work order number from ServiceNow field service management system or SAP PM notification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTelemetryId rdf:type rdf:Property ;
    rdfs:label 'Performance Telemetry Id' ;
    rdfs:comment 'Unique identifier for the performance telemetry record. Primary key for time-series instrument performance data.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Foreign key linking to research.experiment. Business justification: Telemetry metrics (Q30, cluster density, error rates) are reviewed against experimental context for QC decisions. Critical for correlating instrument performance with experiment success/failure and tr' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Experiment .

ind:serviceEventId rdf:type rdf:Property ;
    rdfs:label 'Service Event Id' ;
    rdfs:comment 'Reference to the field service event or maintenance activity associated with this telemetry record. Links to ServiceNow service tickets for post-service performance validation. Nullable for routine operational telemetry.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceEvent .

ind:anomalyDetectionScore rdf:type rdf:Property ;
    rdfs:label 'Anomaly Detection Score' ;
    rdfs:comment 'Machine learning-derived anomaly score indicating deviation from expected instrument behavior. Range 0.0000 to 1.0000, where higher values indicate greater anomaly likelihood. Enables predictive maintenance.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountCumulative rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Cumulative' ;
    rdfs:comment 'Total number of sequencing cycles, PCR cycles, or operational cycles completed by the instrument. High-precision counter for component wear prediction and preventive maintenance.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Sequencing cycle, PCR cycle, or scan pass number when the metric was captured. Enables per-cycle performance trending and quality degradation analysis. Nullable for run-level or system-level metrics.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Assessment of telemetry data quality and reliability. Flags sensor malfunctions, calibration drift, or communication errors that may compromise data integrity.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Code identifying the laboratory, manufacturing site, or customer facility where the instrument is installed. Enables multi-site performance comparison and regional trend analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowRateMlPerMin rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Ml Per Min' ;
    rdfs:comment 'Reagent or buffer flow rate in milliliters per minute. Ensures proper reagent delivery timing and volume. Deviations indicate pump wear or fluidics issues. Nullable for instruments without fluidics.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'Timestamp when the telemetry record was ingested into the Databricks Lakehouse. Distinct from telemetry_timestamp; used for data pipeline monitoring and latency analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laserPowerWatts rdf:type rdf:Property ;
    rdfs:label 'Laser Power Watts' ;
    rdfs:comment 'Optical laser power output in watts. Critical for imaging-based sequencers and array scanners. Degradation over time indicates laser aging and need for replacement. Nullable for non-optical instruments.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the telemetry metric being captured. Discriminates between sequencing performance data, PCR curves, array intensities, system health parameters, and operational usage counters.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phredScoreMean rdf:type rdf:Property ;
    rdfs:label 'Phred Score Mean' ;
    rdfs:comment 'Average Phred quality score across all base calls in the measurement window. Logarithmic scale representing base call accuracy. Nullable for non-sequencing instruments.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Psi' ;
    rdfs:comment 'Fluidics system pressure in pounds per square inch. Monitors pump performance and detects blockages or leaks in liquid handling systems. Nullable for instruments without fluidics.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readNumber rdf:type rdf:Property ;
    rdfs:label 'Read Number' ;
    rdfs:comment 'Read identifier for paired-end or multi-read sequencing protocols (e.g., Read 1, Read 2, Index Read). Nullable for single-read runs or non-sequencing instruments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentVolumeConsumedMl rdf:type rdf:Property ;
    rdfs:label 'Reagent Volume Consumed Ml' ;
    rdfs:comment 'Volume of reagent consumed during the measurement period in milliliters. Tracks reagent usage for inventory management and cost accounting. Cumulative or per-run depending on metric granularity.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionPolicyClass rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Class' ;
    rdfs:comment 'Data retention classification determining how long this telemetry record is stored in the lakehouse. Varies by metric type: operational counters may be archived longer than per-cycle metrics.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCountCumulative rdf:type rdf:Property ;
    rdfs:label 'Run Count Cumulative' ;
    rdfs:comment 'Total number of analytical runs completed by the instrument since installation or last counter reset. Operational counter for predictive maintenance scheduling and warranty tracking.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalIntensityMean rdf:type rdf:Property ;
    rdfs:label 'Signal Intensity Mean' ;
    rdfs:comment 'Average fluorescence or optical signal intensity. Used for array scanners and imaging-based sequencers. Higher values indicate better signal-to-noise ratio. Arbitrary units specific to instrument platform.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalToNoiseRatio rdf:type rdf:Property ;
    rdfs:label 'Signal To Noise Ratio' ;
    rdfs:comment 'Ratio of signal intensity to background noise. Higher values indicate cleaner data and better instrument performance. Dimensionless ratio. Nullable for non-imaging instruments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telemetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Telemetry Timestamp' ;
    rdfs:comment 'Precise date and time when the telemetry data point was captured by the instrument. Represents the real-world event time of the measurement or observation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Instrument operating temperature in degrees Celsius. Critical system health indicator for thermal cyclers, flow cells, and reagent storage compartments. Out-of-range values trigger maintenance alerts.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Limit' ;
    rdfs:comment 'Lower acceptable boundary for the metric value. Values below this threshold trigger quality alerts or instrument service notifications. Defined per metric type and instrument model.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Limit' ;
    rdfs:comment 'Upper acceptable boundary for the metric value. Values above this threshold trigger quality alerts or instrument service notifications. Defined per metric type and instrument model.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Violation Flag' ;
    rdfs:comment 'Indicates whether the metric value falls outside acceptable thresholds. True when metric_value is below threshold_lower_limit or above threshold_upper_limit. Drives automated alerting and service dispatch.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tileNumber rdf:type rdf:Property ;
    rdfs:label 'Tile Number' ;
    rdfs:comment 'Imaging tile or spatial region identifier within a lane or array. Supports spatial performance analysis and detection of localized instrument issues. Nullable for non-imaging instruments.' ;
    rdfs:domain ind:PerformanceTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Reference to the SAP PM maintenance plan identifier that governs this schedule. Used for integration with SAP PM module.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: PM schedules are owned and managed by specific organizational units responsible for maintenance execution, resource allocation, and budget tracking. Critical for maintenance planning, cost center allo' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:sopDocumentId rdf:type rdf:Property ;
    rdfs:label 'Sop Document Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_document. Business justification: Preventive maintenance SOPs are controlled regulatory documents required for quality system compliance. Links PM schedule to approved procedure for version control and audit trail. Removes denormalize' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:applicableInstrumentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Instrument Types' ;
    rdfs:comment 'Comma-separated list of instrument types or categories to which this PM schedule applies (e.g., \'NGS Sequencer\', \'Array Scanner\', \'qPCR Platform\', \'Liquid Handler\').' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoGenerateWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order Flag' ;
    rdfs:comment 'Indicates whether work orders should be automatically generated based on this PM schedule. True enables automated work order creation via ServiceNow integration.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Business criticality of this preventive maintenance task based on impact to instrument performance, regulatory compliance, and operational continuity (low, medium, high, critical).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Expected time required to complete this preventive maintenance task, expressed in minutes. Used for field service resource planning and scheduling.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Days' ;
    rdfs:comment 'Numeric representation of the maintenance frequency expressed in days (e.g., 1 for daily, 7 for weekly, 90 for quarterly, 365 for annual). Used for automated work order scheduling.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after the scheduled maintenance date during which the task can still be completed without being considered overdue. Provides scheduling flexibility.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'Date when this preventive maintenance task was last successfully completed. Used to calculate next scheduled date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency' ;
    rdfs:comment 'Frequency at which this preventive maintenance task must be performed (daily, weekly, biweekly, monthly, quarterly, semiannual, annual, biennial). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|semiannual|annual|biennial — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceTaskType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Task Type' ;
    rdfs:comment 'Category of preventive maintenance task to be performed (calibration, inspection, cleaning, lubrication, alignment, replacement, software update, performance verification). [ENUM-REF-CANDIDATE: calibration|inspection|cleaning|lubrication|alignment|replacement|software_update|performance_verification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Calculated date for the next occurrence of this preventive maintenance task. Updated after each completed maintenance event. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicates whether this preventive maintenance task is mandated by regulatory requirements (FDA, CLIA, CAP, ISO 13485) or is a best-practice recommendation. True if regulatory-mandated.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of certifications or training qualifications required for personnel performing this maintenance task (e.g., \'Illumina Certified Engineer\', \'Laser Safety Level 2\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Required Skill Level' ;
    rdfs:comment 'Minimum skill or certification level required for field service engineers to perform this maintenance task (basic, intermediate, advanced, specialist, certified engineer).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique business identifier or code for this PM schedule used in work order generation and ServiceNow integration (e.g., \'PM-SEQ-Q1\', \'PM-PCR-A1\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or title for this preventive maintenance schedule (e.g., \'Quarterly Flow Cell Calibration\', \'Annual Laser Alignment\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of this preventive maintenance schedule (active, inactive, suspended, under review, obsolete). Only active schedules generate work orders.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicenowScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Servicenow Schedule Reference' ;
    rdfs:comment 'External identifier for this PM schedule in the ServiceNow field service management system. Used for bi-directional integration and work order dispatch.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Work Order Template Code' ;
    rdfs:comment 'Reference to the ServiceNow work order template used for automated PM work order generation based on this schedule.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Service contracts are managed by specific employees serving as contract/account managers for renewal tracking, customer relationship management, escalation handling, and contract administration. Essen' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:predecessorContractServiceContractId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Contract Service Contract Id' ;
    rdfs:comment 'Reference to the previous service contract that this contract renews or replaces. Enables contract history tracking and customer tenure analysis. Null for initial contracts.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceContract .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Service contracts need designated contact person for contract administration, renewal notifications, service coordination, and escalation management. Distinct from account owner. Essential for contrac' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'How the service contract was obtained: bundled with instrument purchase, separately purchased after installation, promotional offer, or upgrade from a lower tier.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimEligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Claim Eligibility Rules' ;
    rdfs:comment 'Free-text description of conditions that must be met for a service claim to be honored: instrument must be in qualified environment (temperature, humidity per IQ/OQ), operated by trained personnel, using approved consumables, with calibration current. Exclusions for misuse, unauthorized modifications, or force majeure.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumablesDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Consumables Discount Percent' ;
    rdfs:comment 'Percentage discount on reagents, flow cells, arrays, and other consumables as a benefit of this service contract. Typically 5-15% for premium tiers. Null if no discount applies.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary values in this contract (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the customer and service provider executed the service contract agreement. Used for contract age analysis and renewal forecasting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageScope rdf:type rdf:Property ;
    rdfs:label 'Coverage Scope' ;
    rdfs:comment 'Defines which subsystems and components of the instrument are covered: full system, optics module only, fluidics subsystem, electronics, software updates, or exclusions such as consumables.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where this service contract is valid. Instruments moved outside this territory may void coverage. Critical for field service dispatch and regulatory compliance.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Fixed amount the customer must pay per service incident before contract coverage applies. Common in lower-tier contracts. Null if no deductible.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:includedPmVisits rdf:type rdf:Property ;
    rdfs:label 'Included Pm Visits' ;
    rdfs:comment 'Number of on-site preventive maintenance visits included in the contract term at no additional charge. Typically 1-4 per year depending on instrument type and SLA tier.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborCoverageIncluded rdf:type rdf:Property ;
    rdfs:label 'Labor Coverage Included' ;
    rdfs:comment 'Indicates whether field service engineer labor (on-site and remote) is included at no additional charge. True for comprehensive and labor-only contracts, false for parts-only.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanerInstrumentIncluded rdf:type rdf:Property ;
    rdfs:label 'Loaner Instrument Included' ;
    rdfs:comment 'Indicates whether a temporary replacement instrument is provided during extended repairs (typically >5 business days downtime). Available only in platinum and gold tiers.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxClaimsPerYear rdf:type rdf:Property ;
    rdfs:label 'Max Claims Per Year' ;
    rdfs:comment 'Maximum number of service incidents that can be claimed under this contract within a 12-month period. Null for unlimited. Exceeding this cap triggers time-and-materials billing.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsCoverageIncluded rdf:type rdf:Property ;
    rdfs:label 'Parts Coverage Included' ;
    rdfs:comment 'Indicates whether replacement parts (optics, sensors, pumps, valves, circuit boards) are included at no additional charge. True for comprehensive and parts-only contracts, false for labor-only or time-and-materials.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmVisitFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Pm Visit Frequency Months' ;
    rdfs:comment 'Scheduled interval in months between preventive maintenance visits (e.g., 3 for quarterly, 6 for semi-annual, 12 for annual). Drives field service scheduling.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityPartsShipping rdf:type rdf:Property ;
    rdfs:label 'Priority Parts Shipping' ;
    rdfs:comment 'Indicates whether replacement parts are shipped via expedited carrier (overnight or same-day) at no additional charge. Standard for platinum/gold, optional upgrade for silver/bronze.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteSupportIncluded rdf:type rdf:Property ;
    rdfs:label 'Remote Support Included' ;
    rdfs:comment 'Indicates whether 24/7 remote diagnostics, troubleshooting, and software support via secure VPN connection are included. Standard for all tiers except bronze.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceProvider rdf:type rdf:Property ;
    rdfs:label 'Service Provider' ;
    rdfs:comment 'Entity responsible for delivering service under this contract: manufacturer (Genomics Biotech), authorized service partner, third-party maintenance organization, or customer self-service with remote support.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceProviderName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Name' ;
    rdfs:comment 'Legal name of the organization providing service under this contract. For manufacturer service, this is Genomics Biotech. For partners, the authorized partner company name.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareUpdatesIncluded rdf:type rdf:Property ;
    rdfs:label 'Software Updates Included' ;
    rdfs:comment 'Indicates whether instrument control software, firmware, and bioinformatics pipeline updates are included. Critical for maintaining regulatory compliance (FDA 21 CFR Part 11, IVDR) and performance optimization.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelExpensesIncluded rdf:type rdf:Property ;
    rdfs:label 'Travel Expenses Included' ;
    rdfs:comment 'Indicates whether field service engineer travel costs (airfare, mileage, lodging, meals) are included in the contract or billed separately. Typically true for platinum/gold tiers, false for bronze/standard.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uptimeGuaranteePercent rdf:type rdf:Property ;
    rdfs:label 'Uptime Guarantee Percent' ;
    rdfs:comment 'Contractually guaranteed instrument availability percentage over the measurement period (typically monthly or quarterly). Failure to meet this may trigger service credits.' ;
    rdfs:domain ind:ServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartId rdf:type rdf:Property ;
    rdfs:label 'Spare Part Id' ;
    rdfs:comment 'Unique identifier for the spare part or field-replaceable unit (FRU). Primary key.' ;
    rdfs:domain ind:Instrument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SparePart .

ind:consignmentAccountId rdf:type rdf:Property ;
    rdfs:label 'Consignment Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Customer-specific spare parts inventory (consignment stock, customer-owned parts at customer sites, vendor-managed inventory) requires account linkage for inventory management, billing triggers, and s' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:compatibleInstrumentModels rdf:type rdf:Property ;
    rdfs:label 'Compatible Instrument Models' ;
    rdfs:comment 'Comma-separated list of instrument model identifiers that this spare part is compatible with (e.g., \'NovaSeq6000,NextSeq2000,MiSeqDx\'). Used for field service parts selection and maintenance planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Business criticality of the spare part based on impact to instrument uptime and service level agreements (SLA): critical (immediate failure if unavailable), high (significant impact), medium (moderate impact), low (minimal impact).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensions rdf:type rdf:Property ;
    rdfs:label 'Dimensions' ;
    rdfs:comment 'Physical dimensions of the spare part in format \'Length x Width x Height\' with units (e.g., \'25.4 x 15.2 x 10.1 cm\'). Used for packaging and storage planning.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the spare part is classified as hazardous material requiring special handling, storage, and shipping procedures per regulatory requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order for this spare part. Used for demand analysis and supplier performance tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Controlled Flag' ;
    rdfs:comment 'Indicates whether this spare part is tracked by lot number for batch traceability and quality control purposes, typically for consumables and reagents.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) or supplier of the spare part.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original equipment manufacturer (OEM) part number for cross-referencing with supplier catalogs and procurement systems.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'SAP material group classification code for procurement categorization and spend analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average operational time in hours between failures for this spare part, based on historical field service data. Used for preventive maintenance scheduling and reliability analysis.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Level' ;
    rdfs:comment 'Minimum inventory quantity that must be maintained to support field service operations and prevent stockouts. Triggers reorder when stock falls below this threshold.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date when the spare part will become obsolete and no longer available for ordering. Used for last-time-buy planning and instrument lifecycle management.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable name or description of the spare part (e.g., \'Flow Cell Optical Sensor\', \'Laser Diode Assembly\', \'Reagent Pump Module\').' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer-assigned unique part number for the spare part or FRU. Used for ordering, inventory tracking, and cross-referencing with supplier catalogs.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'Current lifecycle status of the spare part: active (available for use), obsolete (no longer supported), discontinued (no longer manufactured), phase_out (being retired), or restricted (limited availability or use).' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the spare part by functional category: FRU (Field-Replaceable Unit), consumable, tool, optical component, electronic component, mechanical component, or software license. [ENUM-REF-CANDIDATE: FRU|consumable|tool|optical_component|electronic_component|mechanical_component|software_license — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productHierarchy rdf:type rdf:Property ;
    rdfs:label 'Product Hierarchy' ;
    rdfs:comment 'Hierarchical product classification path for reporting and analytics (e.g., \'Instruments/Sequencing/NovaSeq/Optics/Laser\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered, calculated based on lead time, usage rate, and safety stock requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Replacement Frequency Months' ;
    rdfs:comment 'Recommended replacement interval in months for preventive maintenance, based on manufacturer specifications and field performance data.' ;
    rdfs:domain ind:SparePart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Reference Number' ;
    rdfs:comment 'Reference number or document identifier for the Safety Data Sheet (SDS) associated with this spare part, if applicable. Required for hazardous materials.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializedFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Flag' ;
    rdfs:comment 'Indicates whether individual units of this spare part are tracked by unique serial numbers for traceability, warranty management, and quality control.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Maximum storage duration in months before the spare part expires or degrades beyond acceptable quality standards. Null for non-perishable parts.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard unit cost of the spare part in the base currency for inventory valuation and cost accounting. Used for maintenance event cost tracking and financial reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditions rdf:type rdf:Property ;
    rdfs:label 'Storage Conditions' ;
    rdfs:comment 'Required environmental storage conditions for the spare part (e.g., \'Store at 2-8°C\', \'Keep dry, room temperature\', \'Protect from light\'). Critical for maintaining part quality and warranty compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRecordId rdf:type rdf:Property ;
    rdfs:label 'Batch Record Id' ;
    rdfs:comment 'Unique identifier for the electronic batch record. Primary key for the batch record entity. Serves as the GMP-compliant reference for all manufacturing documentation associated with a specific production batch.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:manufacturingSiteId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Id' ;
    rdfs:comment 'Reference to the GMP-registered manufacturing facility where this batch was produced. Critical for regulatory compliance, site-specific SOPs, and supply chain traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingSite .

ind:masterBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Master Batch Record Id' ;
    rdfs:comment 'Reference to the approved master batch record template that this executed batch record is based on. Ensures manufacturing followed validated procedures.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:primaryBatchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Batch Employee Id' ;
    rdfs:comment 'Reference to the qualified operator or production supervisor who initiated the batch record in the MES. Part of 21 CFR Part 11 electronic signature trail.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryBatchRejectedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Batch Rejected By User Employee Id' ;
    rdfs:comment 'Reference to the QA reviewer or manager who rejected the batch record due to non-conformance, deviation, or quality failure. Null if batch was not rejected.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryBatchApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Batch Approved By User Employee Id' ;
    rdfs:comment 'Reference to the authorized QA manager or qualified person who approved the batch record for release. Must hold appropriate GMP training and delegation of authority. Part of electronic signature trail.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vaultDocumentId rdf:type rdf:Property ;
    rdfs:label 'Vault Document Id' ;
    rdfs:comment 'Unique document identifier in Veeva Vault QMS where the finalized, approved batch record PDF is archived for regulatory retention. Supports 21 CFR Part 11 compliant long-term storage.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:batchRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Record Number' ;
    rdfs:comment 'Human-readable unique business identifier for the electronic batch record. Externally referenced in regulatory submissions, audits, and quality investigations. Format follows site-specific EBR numbering convention.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Record Status' ;
    rdfs:comment 'Current lifecycle state of the electronic batch record in the GMP workflow. Governs whether the batch can be released for distribution. Transitions follow 21 CFR Part 11 audit trail requirements. [ENUM-REF-CANDIDATE: draft|in_process|in_review|approved|rejected|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeUom rdf:type rdf:Property ;
    rdfs:label 'Batch Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity. Standardized to SAP MM UOM codes for consistency across manufacturing and supply chain systems. [ENUM-REF-CANDIDATE: EA|KIT|L|ML|KG|G|M|DOSE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier of the Bill of Materials used for this batch. Ensures traceability to the approved component list and material specifications. Links to SAP PP BOM master.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Coa Document Reference' ;
    rdfs:comment 'External reference or URI to the Certificate of Analysis document for this batch. Links to Veeva Vault or QMS document repository. Null if COA not yet issued.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a Certificate of Analysis has been issued for this batch. True indicates COA is available; false indicates pending or not yet generated.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalClass rdf:type rdf:Property ;
    rdfs:label 'Environmental Class' ;
    rdfs:comment 'ISO 14644 cleanroom classification where the batch was manufactured. Critical for sterile and aseptic product compliance. Null or unclassified for non-cleanroom manufacturing.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTrain rdf:type rdf:Property ;
    rdfs:label 'Equipment Train' ;
    rdfs:comment 'Comma-separated list or identifier of the qualified equipment units used in this batch production (e.g., Reactor-101, Filler-203). Critical for equipment qualification traceability and investigation.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'Total number of in-process QC exceptions or out-of-specification results recorded during batch production. Each exception requires investigation and quality disposition.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the batch record was first created or initiated in the MES. Marks the start of the GMP-documented manufacturing event. ISO 8601 format with timezone.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Mes Document Reference' ;
    rdfs:comment 'External reference or URI to the batch record document stored in the MES platform. Enables traceability to the source system of record for shop-floor execution data.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Process Order Number' ;
    rdfs:comment 'SAP PP process order number that governs the manufacturing execution for this batch. Links batch record to ERP planning and material consumption transactions.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Boolean indicator of whether the batch is currently under quarantine pending investigation or disposition. True indicates batch is on hold; false indicates released or rejected.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejected Timestamp' ;
    rdfs:comment 'Date and time when the batch record was rejected. Null if batch was not rejected. Triggers investigation and CAPA workflow per GMP requirements.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the batch was officially released by QA for distribution and sale. Marks the completion of all GMP release activities including batch record review, QC testing, and disposition. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date by which the batch must be retested to confirm continued conformance to specifications. Applicable for raw materials and intermediates with defined retest intervals. Null if not applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the QA review of the batch record was completed. Null if review has not yet occurred. Part of the GMP release workflow.' ;
    rdfs:domain ind:BatchRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sterilizationMethod rdf:type rdf:Property ;
    rdfs:label 'Sterilization Method' ;
    rdfs:comment 'Method used to sterilize the product or components during manufacturing, if applicable. Critical for sterile product compliance and validation. Null or not_applicable for non-sterile products.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomComponentId rdf:type rdf:Property ;
    rdfs:label 'Bom Component Id' ;
    rdfs:comment 'Unique identifier for the BOM component line item. Primary key.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturingBomId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Bom Id' ;
    rdfs:comment 'Reference to the parent BOM header that this component belongs to. Links component to the assembly being manufactured.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufacturingBom .

ind:alternativeBomIndicator rdf:type rdf:Property ;
    rdfs:label 'Alternative Bom Indicator' ;
    rdfs:comment 'Identifier for alternative or substitute components that can be used in place of the primary component. Supports supply chain flexibility and shortage management.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backflushIndicator rdf:type rdf:Property ;
    rdfs:label 'Backflush Indicator' ;
    rdfs:comment 'Indicates whether the component is consumed via backflushing (automatic goods issue upon operation confirmation) rather than manual issue. Common for high-volume consumables.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseQuantity rdf:type rdf:Property ;
    rdfs:label 'Base Quantity' ;
    rdfs:comment 'The reference quantity of the parent assembly for which the component quantity is specified. Typically 1, but may vary for batch-based formulations.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether this component requires batch-level traceability and lot tracking. Critical for GMP compliance and recall management in genomics manufacturing.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required Flag' ;
    rdfs:comment 'Indicates whether the component requires temperature-controlled storage and handling (e.g., reagents, enzymes). Critical for maintaining reagent stability and assay performance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentCost rdf:type rdf:Property ;
    rdfs:label 'Component Cost' ;
    rdfs:comment 'Standard cost or moving average price of the component. Used for product costing, cost roll-up, and COGS calculation. Business-confidential financial data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component, including technical specifications, grade, purity, or other distinguishing characteristics relevant to manufacturing.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentNumber rdf:type rdf:Property ;
    rdfs:label 'Component Number' ;
    rdfs:comment 'The material number (SKU) of the component as defined in the material master. Business identifier for the component.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'Required quantity of the component per base quantity of the parent assembly. Used for material requirements planning (MRP) and production order explosion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSource rdf:type rdf:Property ;
    rdfs:label 'Component Source' ;
    rdfs:comment 'Origin of the component: internally manufactured, externally procured, customer-supplied, or OEM (Original Equipment Manufacturer) supplied.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the component within the BOM. Controls whether the component is used in production planning and execution.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Flag' ;
    rdfs:comment 'Indicates whether the component is a controlled or hazardous substance requiring special handling, storage, and regulatory reporting under GxP and safety regulations.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the component cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPartFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Part Flag' ;
    rdfs:comment 'Designates the component as critical for product quality, safety, or regulatory compliance. Triggers enhanced quality control and documentation requirements.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineeringChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Engineering Change Number' ;
    rdfs:comment 'Engineering change order or revision number that introduced or modified this component in the BOM. Supports change control and traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the component type: stock item (inventory-managed), non-stock item (procured per order), variable size item (cut-to-length), document item (reference document), text item (instruction), or class item (configurable characteristic).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Sequential line item number within the BOM, used for ordering and referencing components in the assembly structure.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRemainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life required at the time of goods issue for production. Prevents use of near-expiry materials that could compromise product quality.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationNumber rdf:type rdf:Property ;
    rdfs:label 'Operation Number' ;
    rdfs:comment 'The routing operation number at which this component is consumed or installed. Links BOM component to the production routing step.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Defines how the component is sourced: manufactured in-house, purchased externally, or both. Drives MRP planning strategy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether incoming or in-process quality inspection is mandatory for this component before use in production. Enforces QC checkpoints per GMP requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapPercentage rdf:type rdf:Property ;
    rdfs:label 'Scrap Percentage' ;
    rdfs:comment 'Expected scrap or waste factor for this component during production, expressed as a percentage. Used to increase material requirements in MRP calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Serial number management profile for components requiring unit-level serialization (e.g., instruments, flow cells). Defines serialization rules and format.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum shelf life of the component in days from manufacturing or receipt date. Used for expiry management and FEFO (First Expired First Out) inventory strategies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyArea rdf:type rdf:Property ;
    rdfs:label 'Supply Area' ;
    rdfs:comment 'Production supply area or staging location where the component is kitted or staged before consumption. Used in lean manufacturing and kanban systems.' ;
    rdfs:domain ind:BomComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:envMonitoringResultId rdf:type rdf:Property ;
    rdfs:label 'Env Monitoring Result Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring result record. Primary key for this entity.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringEventId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Event Id' ;
    rdfs:comment 'Business identifier for the environmental monitoring event. Externally-known unique code for traceability and audit purposes.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringEvent .

ind:monitoringLocationId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Id' ;
    rdfs:comment 'Reference to the specific location within the manufacturing facility where the environmental monitoring was performed.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringLocation .

ind:primaryEnvEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Env Employee Id' ;
    rdfs:comment 'Reference to the qualified operator who performed the environmental monitoring sampling or measurement.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionLimit rdf:type rdf:Property ;
    rdfs:label 'Action Limit' ;
    rdfs:comment 'The action threshold that requires immediate corrective action and investigation when exceeded. Action limits represent the maximum acceptable deviation from specification.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionLimitBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Action Limit Breach Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value exceeded the action limit. True if action limit was breached, false otherwise.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertLimit rdf:type rdf:Property ;
    rdfs:label 'Alert Limit' ;
    rdfs:comment 'The alert threshold that triggers investigation when exceeded. Alert limits are set below action limits to provide early warning of potential environmental control drift.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertLimitBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Limit Breach Flag' ;
    rdfs:comment 'Boolean flag indicating whether the measured value exceeded the alert limit. True if alert limit was breached, false otherwise.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanRoomClassification rdf:type rdf:Property ;
    rdfs:label 'Clean Room Classification' ;
    rdfs:comment 'ISO 14644-1 classification of the clean room based on airborne particulate cleanliness (ISO 3 through ISO 8).' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number or identifier linking to the corrective action or CAPA (Corrective and Preventive Action) record initiated in response to this monitoring result, if applicable.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpGrade rdf:type rdf:Property ;
    rdfs:label 'Gmp Grade' ;
    rdfs:comment 'EU GMP Annex 1 grade classification for the manufacturing area (Grade A, B, C, or D) indicating the level of environmental control required.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incubationPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Incubation Period Hours' ;
    rdfs:comment 'Duration in hours for which viable particulate samples were incubated before colony counting. Applicable only to viable monitoring; null for non-viable and physical parameter monitoring.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incubationTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Incubation Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which viable particulate samples were incubated. Applicable only to viable monitoring.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Type of environmental parameter being monitored: viable particulate (microbial), non-viable particulate, temperature, humidity, differential pressure, or HVAC airflow.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organismIdentified rdf:type rdf:Property ;
    rdfs:label 'Organism Identified' ;
    rdfs:comment 'Genus and species of microorganism identified from viable particulate monitoring, if applicable. Used for contamination source investigation and trending.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandardApplied rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Applied' ;
    rdfs:comment 'The specific regulatory standard or guideline applied for this environmental monitoring (e.g., EU GMP Annex 1, ISO 14644-1, FDA Aseptic Processing Guidance).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByQcName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Qc Name' ;
    rdfs:comment 'Full name of the QC personnel who reviewed and approved the environmental monitoring result.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampledByOperatorName rdf:type rdf:Property ;
    rdfs:label 'Sampled By Operator Name' ;
    rdfs:comment 'Full name of the operator who performed the environmental monitoring sampling. Included for audit trail and traceability.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDatetime rdf:type rdf:Property ;
    rdfs:label 'Sampling Datetime' ;
    rdfs:comment 'The date and time when the environmental monitoring sample was collected or measurement was taken. This is the principal business event timestamp for this monitoring result.' ;
    rdfs:domain ind:EnvMonitoringResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specificationLimit rdf:type rdf:Property ;
    rdfs:label 'Specification Limit' ;
    rdfs:comment 'The target or maximum allowable value for this monitoring parameter as defined in the environmental control specification for the location and monitoring type.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Id' ;
    rdfs:comment 'Identifier of the manufacturing equipment being qualified. Links to the equipment master record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether a CAPA was required to address qualification findings (True/False).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of manufacturing equipment (e.g., sequencer, thermal cycler, liquid handler, centrifuge, incubator, biosafety cabinet, clean room, assembly station, inspection system, packaging equipment). [ENUM-REF-CANDIDATE: sequencer|thermal_cycler|liquid_handler|centrifuge|incubator|biosafety_cabinet|clean_room|assembly_station|inspection_system|packaging_equipment|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the equipment to maintain GMP compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Completion Date' ;
    rdfs:comment 'Date when all qualification testing and documentation were completed, regardless of pass/fail outcome.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Cycle Number' ;
    rdfs:comment 'Sequential number indicating which qualification cycle this record represents (1 for initial qualification, 2+ for requalifications).' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the qualification was successfully completed and the equipment was approved for GMP use.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Qualification Protocol Reference' ;
    rdfs:comment 'Document number or identifier of the qualification protocol that defines the test procedures and acceptance criteria (e.g., IQ-2024-001).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationReportReference rdf:type rdf:Property ;
    rdfs:label 'Qualification Report Reference' ;
    rdfs:comment 'Document number or Veeva Vault identifier of the qualification report containing test results and approval signatures.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Date when the qualification activity was initiated.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationValidityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Qualification Validity Period Days' ;
    rdfs:comment 'Number of days the qualification remains valid before requalification is required, as defined by the equipment qualification plan.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Reference' ;
    rdfs:comment 'Document number or identifier of the risk assessment performed to determine qualification scope and acceptance criteria.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'High-level summary of qualification test outcomes, including pass/fail status and any deviations observed.' ;
    rdfs:domain ind:EquipmentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finishedGoodsReleaseId rdf:type rdf:Property ;
    rdfs:label 'Finished Goods Release Id' ;
    rdfs:comment 'Unique identifier for the finished goods release record. Primary key for this entity.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFinishedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Finished Employee Id' ;
    rdfs:comment 'Identifier of the quality control (QC) personnel who performed the initial batch review and quality assessment.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaIssueDate rdf:type rdf:Property ;
    rdfs:label 'Coa Issue Date' ;
    rdfs:comment 'Date when the Certificate of Analysis was formally issued for the released batch.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coaNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Number' ;
    rdfs:comment 'Unique identifier for the Certificate of Analysis document that accompanies the released batch, certifying product quality and specifications.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Authorization Date' ;
    rdfs:comment 'Date when the batch was formally authorized for commercial distribution or internal use following quality release approval.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electronicSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Reference' ;
    rdfs:comment 'Reference identifier for the electronic signature applied to the release record, ensuring compliance with 21 CFR Part 11 requirements for electronic records and signatures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that the batch was manufactured in accordance with Good Manufacturing Practice (GMP) requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Deviation Count' ;
    rdfs:comment 'Number of unresolved quality deviations or non-conformances associated with this batch at the time of release decision.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcTestResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Qc Test Results Summary' ;
    rdfs:comment 'High-level summary of quality control test results and acceptance criteria verification performed on the batch.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityApproverName rdf:type rdf:Property ;
    rdfs:label 'Quality Approver Name' ;
    rdfs:comment 'Full name of the Qualified Person or QA manager who authorized the release decision.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReviewerName rdf:type rdf:Property ;
    rdfs:label 'Quality Reviewer Name' ;
    rdfs:comment 'Full name of the quality reviewer who conducted the batch quality assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the batch is under regulatory hold, preventing distribution pending regulatory clearance or investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of finished goods units rejected and not approved for distribution due to quality non-conformance.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseCriteriaChecklistStatus rdf:type rdf:Property ;
    rdfs:label 'Release Criteria Checklist Status' ;
    rdfs:comment 'Status indicating whether all mandatory release criteria and quality checkpoints have been completed and verified.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Release Decision Date' ;
    rdfs:comment 'Date when the final quality release decision was made by the authorized quality personnel.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseNotes rdf:type rdf:Property ;
    rdfs:label 'Release Notes' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to the batch release decision, including any conditional release terms or distribution restrictions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Release Record Number' ;
    rdfs:comment 'Externally-known unique business identifier for the finished goods release record, used for traceability and regulatory documentation.' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current workflow status of the release record in the quality review and approval process.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Classification of the release decision: full release (approved for distribution), conditional release (approved with restrictions), reject (not approved), quarantine (hold pending investigation), or rework (return to production).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Quantity of finished goods units approved for release and distribution from this batch (may be less than batch size if partial release or rejection occurred).' ;
    rdfs:domain ind:FinishedGoodsRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapQmInspectionLot rdf:type rdf:Property ;
    rdfs:label 'Sap Qm Inspection Lot' ;
    rdfs:comment 'SAP QM inspection lot number associated with the finished goods quality inspection and usage decision.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Requirement' ;
    rdfs:comment 'Required storage conditions for the finished goods batch (e.g., temperature range, humidity, light protection) to maintain product stability and quality.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inprocessQcResultId rdf:type rdf:Property ;
    rdfs:label 'Inprocess Qc Result Id' ;
    rdfs:comment 'Unique identifier for the in-process quality control inspection result record. Primary key.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Inspection Equipment Id' ;
    rdfs:comment 'Identifier of the measurement equipment or instrument used to perform the inspection. Required for equipment qualification traceability.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Equipment .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Employee identifier of the quality control inspector who performed the measurement. Required for GMP accountability and training records.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:oosInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Oos Investigation Id' ;
    rdfs:comment 'Foreign key linking to quality.oos_investigation. Business justification: Out-of-specification in-process results trigger formal OOS investigations per FDA/ICH guidelines. Regulatory requirement for genomics-biotechnology manufacturing to investigate and document all OOS ev' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosInvestigation .

ind:primaryInprocessApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inprocess Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the quality assurance (QA) supervisor or manager who reviewed and approved the inspection result and disposition.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionOperationId rdf:type rdf:Property ;
    rdfs:label 'Production Operation Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_operation. Business justification: In-process QC checkpoints occur at specific manufacturing operations. Cardinality: N QC results : 1 production_operation (multiple measurements per operation). Adding production_operation_id FK links ' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOperation .

ind:qcSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Qc Specification Id' ;
    rdfs:comment 'Foreign key linking to reagent.qc_specification. Business justification: In-process QC results must link to the specification defining acceptance criteria for automated pass/fail determination, trend analysis, and regulatory compliance. Real-world manufacturing execution s' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcSpecification .

ind:retestResultId rdf:type rdf:Property ;
    rdfs:label 'Retest Result Id' ;
    rdfs:comment 'Reference to the follow-up retest inspection result record if a retest was performed.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InprocessQcResult .

ind:controlChartRuleViolation rdf:type rdf:Property ;
    rdfs:label 'Control Chart Rule Violation' ;
    rdfs:comment 'Identifier of any Statistical Process Control (SPC) rule violation detected (e.g., Western Electric rules, trend, shift, out-of-control point).' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifier of the source system from which this inspection result was captured (SAP QM, Manufacturing Execution System, Laboratory Information Management System, or manual entry).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Number of defective units identified in the sample for attribute-based inspections (e.g., visual defects, functional failures).' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Boolean indicator whether this inspection result represents an out-of-specification (OOS) condition requiring deviation investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Reference number of the formal deviation investigation record if this result triggered an out-of-specification (OOS) investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'Quality disposition decision for the inspected material: accept for next step, reject, conditional release with restrictions, rework, scrap, or hold pending investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionReason rdf:type rdf:Property ;
    rdfs:label 'Disposition Reason' ;
    rdfs:comment 'Textual explanation or justification for the disposition decision, especially for conditional releases or rejections.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditionHumidity rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Humidity' ;
    rdfs:comment 'Relative humidity percentage at the time of inspection. Required for humidity-sensitive measurements and GMP environmental monitoring.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalConditionTemperature rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition Temperature' ;
    rdfs:comment 'Ambient temperature in degrees Celsius at the time of inspection. Required for temperature-sensitive measurements and GMP environmental monitoring.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCharacteristicCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Code' ;
    rdfs:comment 'Code identifying the specific quality characteristic being measured (e.g., pH, concentration, optical density, dimensional tolerance, purity percentage).' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCharacteristicDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Characteristic Description' ;
    rdfs:comment 'Human-readable description of the quality characteristic being inspected.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Lot Number' ;
    rdfs:comment 'SAP QM inspection lot number assigned to this quality control checkpoint. Used for traceability and integration with SAP QM module.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethodCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Method Code' ;
    rdfs:comment 'Code identifying the Standard Operating Procedure (SOP) or analytical method used to perform the inspection (e.g., HPLC, spectrophotometry, visual inspection, dimensional measurement).' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes or observations recorded by the inspector during the quality control inspection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPlanCode rdf:type rdf:Property ;
    rdfs:label 'Inspection Plan Code' ;
    rdfs:comment 'Reference to the master inspection plan that defines the QC checkpoints, characteristics, and acceptance criteria for this product.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResultStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Result Status' ;
    rdfs:comment 'Pass/fail determination for this inspection characteristic based on comparison of measured value against specification limits.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the in-process quality control inspection was performed. Critical for batch record chronology and Turnaround Time (TAT) tracking.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'Code identifying the manufacturing facility or plant where this inspection was performed. Required for multi-site GMP compliance.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionLineCode rdf:type rdf:Property ;
    rdfs:label 'Production Line Code' ;
    rdfs:comment 'Identifier of the specific production line or work center where the inspection occurred.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStepSequence rdf:type rdf:Property ;
    rdfs:label 'Production Step Sequence' ;
    rdfs:comment 'Sequential number of the manufacturing step at which this QC checkpoint occurred within the overall production routing.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this in-process QC result record was first created in the system.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordLastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Last Modified Timestamp' ;
    rdfs:comment 'Timestamp when this in-process QC result record was last updated or modified.' ;
    rdfs:domain ind:InprocessQcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Required Flag' ;
    rdfs:comment 'Boolean indicator whether this result requires a confirmatory retest before final disposition.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentBuildRecordId rdf:type rdf:Property ;
    rdfs:label 'Instrument Build Record Id' ;
    rdfs:comment 'Unique identifier for the instrument build record. Primary key for tracking the complete assembly and build history of a manufactured genomics instrument.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInstrumentAssemblyTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Instrument Assembly Technician Employee Id' ;
    rdfs:comment 'Employee identifier of the primary technician responsible for instrument assembly. Used for traceability, quality accountability, and workforce performance tracking.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assemblyEndDate rdf:type rdf:Property ;
    rdfs:label 'Assembly End Date' ;
    rdfs:comment 'Date when physical assembly of the instrument was completed. Used to calculate assembly cycle time and transition to testing phase.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assemblyStartDate rdf:type rdf:Property ;
    rdfs:label 'Assembly Start Date' ;
    rdfs:comment 'Date when physical assembly of the instrument began on the manufacturing floor. Marks the beginning of the build cycle for production tracking and TAT calculation.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assemblyTechnicianName rdf:type rdf:Property ;
    rdfs:label 'Assembly Technician Name' ;
    rdfs:comment 'Full name of the primary assembly technician for human-readable reference in build records and quality documentation.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchRecordReference rdf:type rdf:Property ;
    rdfs:label 'Batch Record Reference' ;
    rdfs:comment 'Reference to the Device History Record (DHR) or batch record documenting all manufacturing steps, materials, and quality checks for this instrument build. Required for GMP compliance and regulatory traceability.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildCycleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Build Cycle Time Hours' ;
    rdfs:comment 'Total elapsed time in hours from assembly start to final release. Key performance indicator for manufacturing efficiency and capacity planning.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Build Record Number' ;
    rdfs:comment 'Externally-known unique business identifier for the instrument build record. Used for traceability and reference in manufacturing documentation and quality systems.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildStatus rdf:type rdf:Property ;
    rdfs:label 'Build Status' ;
    rdfs:comment 'Current lifecycle status of the instrument build process. Tracks progression from initial assembly through final acceptance testing and release to finished goods inventory. [ENUM-REF-CANDIDATE: planned|in_progress|assembly_complete|testing|calibration|inspection|fat_complete|released|on_hold|rejected — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeModuleSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Compute Module Serial Number' ;
    rdfs:comment 'Serial number of the embedded compute sub-assembly installed in this instrument. Handles data acquisition, real-time processing, and instrument control. Provides component-level traceability.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fat Completion Date' ;
    rdfs:comment 'Date when Factory Acceptance Test was successfully completed. Authorizes release of the instrument to finished goods inventory or direct shipment to customer.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fatReportReference rdf:type rdf:Property ;
    rdfs:label 'Fat Report Reference' ;
    rdfs:comment 'Document identifier for the FAT report containing detailed test results, performance data, and acceptance signatures. Delivered to customer as part of instrument documentation package.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatStatus rdf:type rdf:Property ;
    rdfs:label 'Fat Status' ;
    rdfs:comment 'Outcome of the Factory Acceptance Test performed before instrument shipment. Comprehensive end-to-end validation that the instrument meets all customer specifications and performance requirements.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Date' ;
    rdfs:comment 'Date when final quality inspection was completed. Represents the last quality gate before Factory Acceptance Test.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Status' ;
    rdfs:comment 'Outcome of the final quality inspection before release. Verifies cosmetic condition, labeling, documentation completeness, and overall build quality.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidicsModuleSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Fluidics Module Serial Number' ;
    rdfs:comment 'Serial number of the fluidics control sub-assembly installed in this instrument. Manages reagent delivery and flow cell operations. Provides component-level traceability.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalTestDate rdf:type rdf:Property ;
    rdfs:label 'Functional Test Date' ;
    rdfs:comment 'Date when functional testing was completed. Used for build cycle tracking and quality milestone documentation.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalTestProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Functional Test Protocol Reference' ;
    rdfs:comment 'Document identifier for the functional test protocol executed during this build. Links to controlled quality documentation in the document management system.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalTestStatus rdf:type rdf:Property ;
    rdfs:label 'Functional Test Status' ;
    rdfs:comment 'Overall outcome of functional testing performed on the assembled instrument. Verifies that all subsystems operate according to design specifications.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentModel rdf:type rdf:Property ;
    rdfs:label 'Instrument Model' ;
    rdfs:comment 'Model designation of the instrument being built. Examples include sequencing platforms (NGS instruments), array scanners, PCR/qPCR systems, or liquid handling robots.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalModuleSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Optical Module Serial Number' ;
    rdfs:comment 'Serial number of the optical detection sub-assembly installed in this instrument. Critical for sequencing and array scanning platforms. Provides component-level traceability.' ;
    rdfs:domain ind:InstrumentBuildRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisprConstructId rdf:type rdf:Property ;
    rdfs:label 'Crispr Construct Id' ;
    rdfs:comment 'Foreign key linking to research.crispr_construct. Business justification: CRISPR constructs developed in R&D become manufactured components in gene editing products. BOMs must reference specific construct designs for regulatory traceability, IP protection, and quality contr' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrisprConstruct .

ind:molecularDesignId rdf:type rdf:Property ;
    rdfs:label 'Molecular Design Id' ;
    rdfs:comment 'Foreign key linking to research.molecular_design. Business justification: Manufacturing BOMs for genomic products (sequencing panels, gene editing kits) include molecular designs (oligos, probes, guides) developed in R&D. Essential for IP traceability, regulatory submission' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MolecularDesign .

ind:productBomId rdf:type rdf:Property ;
    rdfs:label 'Product Bom Id' ;
    rdfs:comment 'Foreign key linking to product.bom. Business justification: Manufacturing BOMs are plant-specific implementations of engineering BOMs. Process engineers trace manufacturing variants to master product BOMs for change control, validation protocols, and regulator' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductBom .

ind:alternative rdf:type rdf:Property ;
    rdfs:label 'Alternative' ;
    rdfs:comment 'Alternative BOM sequence number. Allows multiple BOMs for the same material (e.g., different production methods, regional variants, or process alternatives). Default is typically 01.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyType rdf:type rdf:Property ;
    rdfs:label 'Assembly Type' ;
    rdfs:comment 'The type of finished product assembly defined by this BOM. Instruments are capital equipment; reagent kits and arrays are consumables; flow cells are single-use sequencing components. [ENUM-REF-CANDIDATE: instrument|reagent_kit|array|flow_cell|consumable|accessory|spare_part — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationGroup rdf:type rdf:Property ;
    rdfs:label 'Authorization Group' ;
    rdfs:comment 'Security authorization group controlling access to this BOM. Restricts visibility and modification rights based on user roles and organizational responsibilities.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the base quantity (e.g., EA for each, KG for kilogram, L for liter). Must align with the material master base UoM.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomCategory rdf:type rdf:Property ;
    rdfs:label 'Bom Category' ;
    rdfs:comment 'The structural category of the BOM. Material BOMs define physical assemblies; equipment BOMs define installed base configurations; document BOMs group related documentation.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM. Active BOMs are used in production; inactive or blocked BOMs are not available for MRP or manufacturing execution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomText rdf:type rdf:Property ;
    rdfs:label 'Bom Text' ;
    rdfs:comment 'Free-form descriptive text or notes about the BOM. May include assembly instructions, special handling requirements, or process notes.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Number' ;
    rdfs:comment 'The engineering change order or change request number that authorized the creation or modification of this BOM. Links to change management and document control systems.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether the finished product requires temperature-controlled storage and shipping (typically 2-8°C or -20°C). True for many reagent kits and biological materials.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costingLotSize rdf:type rdf:Property ;
    rdfs:label 'Costing Lot Size' ;
    rdfs:comment 'The production lot size used for standard cost calculation. Fixed costs are amortized over this quantity. May differ from actual production batch sizes.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this BOM is marked for deletion. True means the BOM is flagged for archival and will not be used in future production planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:explosionType rdf:type rdf:Property ;
    rdfs:label 'Explosion Type' ;
    rdfs:comment 'Defines how the BOM is exploded in MRP and production planning. Single-level shows only immediate components; multi-level recursively expands all sub-assemblies; summarized aggregates across levels.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpRelevant rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant' ;
    rdfs:comment 'Indicates whether this BOM is subject to GMP regulations and requires enhanced documentation, validation, and change control. True for IVD and clinical products.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'The hazardous material classification code for the finished product if it contains dangerous goods (e.g., flammable reagents, corrosive chemicals). Used for shipping and safety compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivdClassification rdf:type rdf:Property ;
    rdfs:label 'Ivd Classification' ;
    rdfs:comment 'The regulatory classification of the product defined by this BOM. RUO (Research Use Only) products have minimal regulatory burden; IVD products require CE-IVD or FDA clearance; LDT (Laboratory Developed Test) products are lab-specific. [ENUM-REF-CANDIDATE: ruo|ivd|ldt|class_i|class_ii|class_iii|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryDesignOffice rdf:type rdf:Property ;
    rdfs:label 'Laboratory Design Office' ;
    rdfs:comment 'The R&D laboratory or engineering design office responsible for creating and maintaining this BOM. Links to organizational master data.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeFrom rdf:type rdf:Property ;
    rdfs:label 'Lot Size From' ;
    rdfs:comment 'The minimum production lot size for which this BOM is valid. Supports lot-size-dependent BOMs where component quantities or assembly methods vary by batch size.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotSizeTo rdf:type rdf:Property ;
    rdfs:label 'Lot Size To' ;
    rdfs:comment 'The maximum production lot size for which this BOM is valid. Nullable for open-ended upper bound. Used in conjunction with lot_size_from for range-based BOM selection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'The finished product material number for which this BOM is defined. Represents the parent assembly (instrument, reagent kit, array, flow cell, or consumable).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The manufacturing plant where this BOM is valid and used for production. Aligns with SAP plant organizational structure.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionVersion rdf:type rdf:Property ;
    rdfs:label 'Production Version' ;
    rdfs:comment 'Links this BOM to a specific production version that combines BOM alternative, routing, and production line. Enables integrated production planning and execution.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializationRequired rdf:type rdf:Property ;
    rdfs:label 'Serialization Required' ;
    rdfs:comment 'Indicates whether finished goods produced from this BOM must be individually serialized for traceability. True for instruments and high-value components; false for bulk consumables.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'The purpose or application context for this BOM. Production BOMs drive MRP and shop-floor execution; engineering BOMs support R&D and design; costing BOMs enable standard cost rollup.' ;
    rdfs:domain ind:ManufacturingBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingExecutionId rdf:type rdf:Property ;
    rdfs:label 'Packaging Execution Id' ;
    rdfs:comment 'Unique identifier for the packaging execution record. Primary key for this entity.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelingId rdf:type rdf:Property ;
    rdfs:label 'Labeling Id' ;
    rdfs:comment 'Foreign key linking to regulatory.labeling. Business justification: Packaging operations must use the approved labeling version for the product and target market. Critical for genomics IVD compliance - wrong labeling version can trigger field safety actions and regula' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Labeling .

ind:primaryPackagingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Packaging Employee Id' ;
    rdfs:comment 'Reference to the employee who performed the packaging operation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPackagingQcReleasedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Packaging Qc Released By Employee Id' ;
    rdfs:comment 'Reference to the QC personnel who authorized the quality release.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:environmentalMonitoringZone rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Zone' ;
    rdfs:comment 'Cleanroom or environmental monitoring zone classification where packaging was performed (e.g., A, B, C, D per EU GMP Annex 1).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelDestroyedCount rdf:type rdf:Property ;
    rdfs:label 'Label Destroyed Count' ;
    rdfs:comment 'Total number of labels destroyed or discarded during this execution (damaged, misprinted, or unused). Part of GMP label reconciliation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelIssuedCount rdf:type rdf:Property ;
    rdfs:label 'Label Issued Count' ;
    rdfs:comment 'Total number of labels issued to the packaging line for this execution. Part of GMP label reconciliation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labelReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Label Reconciliation Status' ;
    rdfs:comment 'Status of the label reconciliation process verifying that issued = used + destroyed. GMP requirement for label control.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelUsedCount rdf:type rdf:Property ;
    rdfs:label 'Label Used Count' ;
    rdfs:comment 'Total number of labels actually applied to products during this execution. Part of GMP label reconciliation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineClearanceConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Line Clearance Confirmed Flag' ;
    rdfs:comment 'Indicates whether line clearance was confirmed before packaging started. GMP requirement to prevent cross-contamination and mix-ups.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineClearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Line Clearance Timestamp' ;
    rdfs:comment 'Date and time when line clearance was confirmed and documented.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packaging End Timestamp' ;
    rdfs:comment 'Date and time when the packaging operation was completed or stopped.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingOperatorName rdf:type rdf:Property ;
    rdfs:label 'Packaging Operator Name' ;
    rdfs:comment 'Name of the operator who executed the packaging operation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Packaging Order Number' ;
    rdfs:comment 'Business identifier for the packaging order. Externally-known unique number assigned to this packaging operation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packaging Start Timestamp' ;
    rdfs:comment 'Date and time when the packaging operation began. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingStatus rdf:type rdf:Property ;
    rdfs:label 'Packaging Status' ;
    rdfs:comment 'Current lifecycle status of the packaging execution operation.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Classification of the packaging operation: primary packaging (vials, cartridges, tubes), secondary packaging (boxes, cartons), labeling, or kit assembly.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Hold Flag' ;
    rdfs:comment 'Indicates whether the packaged product is on QC hold pending quality release.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Release Timestamp' ;
    rdfs:comment 'Date and time when the packaged batch was released by Quality Control for distribution.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityPackaged rdf:type rdf:Property ;
    rdfs:label 'Quantity Packaged' ;
    rdfs:comment 'Total quantity of units successfully packaged during this execution.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'Total quantity of units rejected during packaging due to defects, damage, or quality failures.' ;
    rdfs:domain ind:PackagingExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryProcessControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Process Controlled Document Id' ;
    rdfs:comment 'Document identifier in Veeva Vault or document management system for the final validation report.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:technologyTransferId rdf:type rdf:Property ;
    rdfs:label 'Technology Transfer Id' ;
    rdfs:comment 'Foreign key linking to research.technology_transfer. Business justification: Process validation in manufacturing is a required outcome of technology transfer per GMP. Validation protocols reference tech transfer acceptance criteria. Essential for regulatory submissions demonst' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnologyTransfer .

ind:batchSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit' ;
    rdfs:comment 'Unit of measure for the validated batch size: units, liters, kilograms, flow cells, arrays, or kits.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeValidated rdf:type rdf:Property ;
    rdfs:label 'Batch Size Validated' ;
    rdfs:comment 'Production batch size (in units or volume) for which the process was validated. Process changes outside this range may require revalidation.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether Corrective and Preventive Action (CAPA) was required based on validation findings.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeControlReference rdf:type rdf:Property ;
    rdfs:label 'Change Control Reference' ;
    rdfs:comment 'Reference number of the change control record that triggered this validation or revalidation activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalProcessParameters rdf:type rdf:Property ;
    rdfs:label 'Critical Process Parameters' ;
    rdfs:comment 'List of critical process parameters (CPPs) monitored and controlled during validation (e.g., temperature, pressure, time, reagent concentration). Comma-separated list.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalQualityAttributes rdf:type rdf:Property ;
    rdfs:label 'Critical Quality Attributes' ;
    rdfs:comment 'List of critical quality attributes (CQAs) measured during validation to ensure product quality (e.g., purity, potency, yield, accuracy). Comma-separated list.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Qualification Status' ;
    rdfs:comment 'Status of equipment qualification for the manufacturing equipment used in this process: IQ/OQ/PQ complete (Installation/Operational/Performance Qualification), IQ/OQ complete, not qualified, or requalification required.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Classification' ;
    rdfs:comment 'GMP classification of the product being validated: IVD (In Vitro Diagnostic), RUO (Research Use Only), LDT (Laboratory Developed Test), medical device, or pharmaceutical.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processCapabilityIndex rdf:type rdf:Property ;
    rdfs:label 'Process Capability Index' ;
    rdfs:comment 'Statistical process capability index (Cpk) calculated from validation data, indicating how well the process meets specifications. Values ≥1.33 typically indicate capable process.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityApprover rdf:type rdf:Property ;
    rdfs:label 'Quality Approver' ;
    rdfs:comment 'Name of the Quality Assurance (QA) manager or authorized person who approved the validation report.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary regulatory authority for which this validation was conducted: FDA (United States), EMA (European Union), MHRA (United Kingdom), TGA (Australia), PMDA (Japan), NMPA (China).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Method' ;
    rdfs:comment 'Statistical methods and tools used for validation data analysis (e.g., ANOVA, control charts, process capability analysis, hypothesis testing).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationOutcome rdf:type rdf:Property ;
    rdfs:label 'Validation Outcome' ;
    rdfs:comment 'Overall outcome of the validation study: passed (all acceptance criteria met), failed (criteria not met), conditional pass (minor deviations with justification), in progress, or not started.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Number' ;
    rdfs:comment 'Unique business identifier for the validation protocol document. Externally-known reference number used across regulatory submissions and quality systems.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRunsCompleted rdf:type rdf:Property ;
    rdfs:label 'Validation Runs Completed' ;
    rdfs:comment 'Number of validation runs successfully completed to date.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationRunsPlanned rdf:type rdf:Property ;
    rdfs:label 'Validation Runs Planned' ;
    rdfs:comment 'Number of validation runs planned in the protocol (typically 3 consecutive successful runs for prospective validation per FDA guidance).' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationScope rdf:type rdf:Property ;
    rdfs:label 'Validation Scope' ;
    rdfs:comment 'Detailed description of the validation scope, including process steps, equipment, materials, and environmental conditions covered by the validation study.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStage rdf:type rdf:Property ;
    rdfs:label 'Validation Stage' ;
    rdfs:comment 'Current lifecycle status of the validation study: protocol approved, execution in progress, report approved, validated (active), revalidation required, or expired.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTeamLead rdf:type rdf:Property ;
    rdfs:label 'Validation Team Lead' ;
    rdfs:comment 'Name of the validation team lead or principal investigator responsible for the validation study.' ;
    rdfs:domain ind:ProcessValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mesBatchId rdf:type rdf:Property ;
    rdfs:label 'Mes Batch Id' ;
    rdfs:comment 'Unique batch identifier in the Manufacturing Execution System (MES) for shop-floor execution tracking.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:primaryProductionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Employee Id' ;
    rdfs:comment 'Reference to the quality assurance personnel who reviewed the batch record.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:productionLineId rdf:type rdf:Property ;
    rdfs:label 'Production Line Id' ;
    rdfs:comment 'Reference to the specific production line or work center used for this batch.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionLine .

ind:batchDisposition rdf:type rdf:Property ;
    rdfs:label 'Batch Disposition' ;
    rdfs:comment 'Quality disposition decision for the batch indicating release readiness. Linked to QM usage decision.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Externally-known unique batch or lot number assigned to this production run. Used for traceability and Certificate of Analysis (COA) reference.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSizeActual rdf:type rdf:Property ;
    rdfs:label 'Batch Size Actual' ;
    rdfs:comment 'Actual quantity of units produced in this batch after manufacturing completion.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchSizePlanned rdf:type rdf:Property ;
    rdfs:label 'Batch Size Planned' ;
    rdfs:comment 'Planned quantity of units to be produced in this batch as defined in the production order.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the production batch in the manufacturing workflow. [ENUM-REF-CANDIDATE: planned|in_production|completed|on_hold|released|rejected|quarantine — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Number' ;
    rdfs:comment 'Reference number for the Certificate of Analysis document issued for this batch.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebrApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Ebr Approval Date' ;
    rdfs:comment 'Date when the batch record was formally approved for batch release.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebrApproverName rdf:type rdf:Property ;
    rdfs:label 'Ebr Approver Name' ;
    rdfs:comment 'Full name of the quality manager who approved the batch record.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebrDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Ebr Document Reference' ;
    rdfs:comment 'Unique document identifier for the Electronic Batch Record in the document management system (e.g., Veeva Vault).' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebrReviewDate rdf:type rdf:Property ;
    rdfs:label 'Ebr Review Date' ;
    rdfs:comment 'Date when the batch record review was completed.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ebrReviewerName rdf:type rdf:Property ;
    rdfs:label 'Ebr Reviewer Name' ;
    rdfs:comment 'Full name of the quality assurance reviewer who reviewed the batch record.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebrStatus rdf:type rdf:Property ;
    rdfs:label 'Ebr Status' ;
    rdfs:comment 'Current status of the Electronic Batch Record (EBR) in the review and approval workflow.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebrVersion rdf:type rdf:Property ;
    rdfs:label 'Ebr Version' ;
    rdfs:comment 'Version number of the Electronic Batch Record document.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingEndDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing End Date' ;
    rdfs:comment 'Date when manufacturing operations for this batch were completed.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingStartDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Start Date' ;
    rdfs:comment 'Date when manufacturing operations for this batch commenced.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Process Validation Status' ;
    rdfs:comment 'Indicates whether the manufacturing process used for this batch is in a validated state per GMP requirements.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Qc Checkpoint Count' ;
    rdfs:comment 'Number of in-process quality control checkpoints executed during batch production.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcFailCount rdf:type rdf:Property ;
    rdfs:label 'Qc Fail Count' ;
    rdfs:comment 'Number of quality control checkpoints that failed acceptance criteria and required investigation.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcPassCount rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Count' ;
    rdfs:comment 'Number of quality control checkpoints that passed acceptance criteria.' ;
    rdfs:domain ind:ProductionBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Manufacturing yield calculated as (actual batch size / planned batch size) * 100. Key performance indicator for production efficiency.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Time Minutes' ;
    rdfs:comment 'Actual labor time in minutes recorded during operation execution.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Machine Time Minutes' ;
    rdfs:comment 'Actual machine processing time in minutes recorded during operation execution.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Setup Time Minutes' ;
    rdfs:comment 'Actual setup time in minutes recorded during operation execution. Used for variance analysis and continuous improvement.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'SAP PP confirmation document number generated when the operation is confirmed. Links to detailed confirmation data including times and quantities.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the operation was confirmed in SAP PP or MES system. Represents the official recording of operation completion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlKey rdf:type rdf:Property ;
    rdfs:label 'Control Key' ;
    rdfs:comment 'SAP control key that determines operation characteristics such as scheduling, costing, confirmation requirements, and external processing flags (e.g., PP01, PP02, PP03).' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Timestamp' ;
    rdfs:comment 'Date and time when the electronic signature was applied to this operation record. Part of the audit trail for GMP compliance.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inProcessQcCheckpointFlag rdf:type rdf:Property ;
    rdfs:label 'In Process Qc Checkpoint Flag' ;
    rdfs:comment 'Indicates whether this operation includes a mandatory in-process quality control checkpoint that must be completed before proceeding.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Labor Time Standard Minutes' ;
    rdfs:comment 'Standard labor time in minutes per unit required for operator activities during this operation.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:machineTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Machine Time Standard Minutes' ;
    rdfs:comment 'Standard machine processing time in minutes per unit for this operation. Used for capacity planning and costing.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mesTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Mes Transaction Reference' ;
    rdfs:comment 'Reference identifier to the originating transaction in the Manufacturing Execution System. Enables traceability between MES and ERP systems.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationLongText rdf:type rdf:Property ;
    rdfs:label 'Operation Long Text' ;
    rdfs:comment 'Detailed description of the operation including specific instructions, parameters, and Standard Operating Procedure (SOP) references for shop-floor execution.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationShortText rdf:type rdf:Property ;
    rdfs:label 'Operation Short Text' ;
    rdfs:comment 'Brief description of the manufacturing operation (e.g., \'Reagent Dispensing\', \'PCR Amplification\', \'Optical Alignment\', \'Fill-Finish\').' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationStatus rdf:type rdf:Property ;
    rdfs:label 'Operation Status' ;
    rdfs:comment 'Current lifecycle status of the manufacturing operation indicating its execution state on the shop floor. [ENUM-REF-CANDIDATE: not_started|released|in_progress|confirmed|partially_confirmed|completed|skipped|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled completion date and time for this operation based on standard values and capacity planning.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled start date and time for this operation based on work order scheduling and capacity planning.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processValidationRunFlag rdf:type rdf:Property ;
    rdfs:label 'Process Validation Run Flag' ;
    rdfs:comment 'Indicates whether this operation is part of a formal process validation study (IQ/OQ/PQ). Requires enhanced documentation and data collection.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcInspectionLotNumber rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Lot Number' ;
    rdfs:comment 'SAP QM inspection lot number created for in-process quality inspection at this operation. Links to detailed inspection results.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcResultStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Result Status' ;
    rdfs:comment 'Status of the in-process quality control inspection for this operation. Determines whether production can proceed to the next step.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkQuantity rdf:type rdf:Property ;
    rdfs:label 'Rework Quantity' ;
    rdfs:comment 'Quantity of units requiring rework or reprocessing due to non-conformance identified during this operation.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scrapQuantity rdf:type rdf:Property ;
    rdfs:label 'Scrap Quantity' ;
    rdfs:comment 'Quantity of units rejected or scrapped during this operation due to quality defects or process failures.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupTimeStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Standard Minutes' ;
    rdfs:comment 'Standard setup time in minutes required to prepare the work center and equipment before production can begin for this operation.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Document Number' ;
    rdfs:comment 'Reference to the Standard Operating Procedure document that governs the execution of this operation. Critical for GMP compliance and training verification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopVersion rdf:type rdf:Property ;
    rdfs:label 'Sop Version' ;
    rdfs:comment 'Version number of the SOP document used during operation execution. Ensures operators followed the correct approved procedure version.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Planned quantity to be produced in this operation. Represents the expected output based on work order requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'Actual good quantity produced and confirmed for this operation. Represents units that passed in-process quality checks.' ;
    rdfs:domain ind:ProductionOperation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryProductionSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Sku Id' ;
    rdfs:comment 'Reference to the product or material that this routing produces. Links to the master product catalog.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:tertiaryProductionResponsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Production Responsible Engineer Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alternativeRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Routing Number' ;
    rdfs:comment 'Reference to an alternative routing that can be used if this routing is unavailable. Enables flexible production planning and capacity management.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Validation Date' ;
    rdfs:comment 'Date when the most recent process validation study for this routing was completed and approved. Used to track validation currency.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mesIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Mes Integration Reference' ;
    rdfs:comment 'External reference identifier used to link this routing to the shop-floor MES system for real-time production execution and data collection.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRevalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Revalidation Due Date' ;
    rdfs:comment 'Date by which the routing must undergo revalidation to maintain its validated status. Periodic revalidation is required per GMP regulations.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationCount rdf:type rdf:Property ;
    rdfs:label 'Operation Count' ;
    rdfs:comment 'Total number of manufacturing operations defined in this routing. Each operation represents a discrete production step with its own work center and times.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processValidationRequired rdf:type rdf:Property ;
    rdfs:label 'Process Validation Required' ;
    rdfs:comment 'Flag indicating whether this routing requires formal process validation studies before use in commercial production. Required for IVD and RUO products per FDA and ISO 13485.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference to the regulatory submission (510(k), PMA, CE-IVD dossier) that includes this routing as part of the manufacturing process description. Critical for IVD products.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresBatchRecord rdf:type rdf:Property ;
    rdfs:label 'Requires Batch Record' ;
    rdfs:comment 'Flag indicating whether production using this routing requires a formal batch manufacturing record (BMR) for traceability and compliance. Mandatory for GMP-regulated products.' ;
    rdfs:domain ind:Manufacturing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Electronic Signature' ;
    rdfs:comment 'Flag indicating whether operations in this routing require electronic signatures for GMP compliance. True for IVD and regulated product routings per FDA 21 CFR Part 11.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingGroup rdf:type rdf:Property ;
    rdfs:label 'Routing Group' ;
    rdfs:comment 'Group key that categorizes related routings together. Used in SAP PP to organize routings by product family or process type.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingGroupCounter rdf:type rdf:Property ;
    rdfs:label 'Routing Group Counter' ;
    rdfs:comment 'Sequential counter within the routing group to distinguish multiple routings for the same material. Part of the composite routing key in SAP PP.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Business identifier for the routing. Externally-known unique code used in SAP PP for routing identification and work order generation.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current lifecycle status of the routing. Active routings are available for work order generation, released routings are approved for production, locked routings are temporarily unavailable, and obsolete routings are retired.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Classification of the routing by its usage pattern. Standard routings are used for regular production, rate routings for repetitive manufacturing, reference routings as templates, and special routings for one-time or custom orders.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingUsage rdf:type rdf:Property ;
    rdfs:label 'Routing Usage' ;
    rdfs:comment 'SAP PP usage indicator defining the purpose of the routing (1=production, 2=maintenance, 3=quality inspection, etc.). Controls which business processes can reference this routing.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaborTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Labor Time Minutes' ;
    rdfs:comment 'Sum of all labor times across all operations in the routing for the base quantity. Labor time represents manual work and scales with lot size.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMachineTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Machine Time Minutes' ;
    rdfs:comment 'Sum of all machine processing times across all operations in the routing for the base quantity. Machine time is equipment-dependent and scales with lot size.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSetupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Setup Time Minutes' ;
    rdfs:comment 'Sum of all setup times across all operations in the routing. Setup time is independent of lot size and occurs once per production run.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStandardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Total Standard Lead Time Days' ;
    rdfs:comment 'Total manufacturing lead time in days required to complete all operations in this routing, including setup, processing, queue, and move times. Used for production planning and scheduling.' ;
    rdfs:domain ind:ProductionRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Reference to the employee record of the person responsible for this work center.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allowsOverlappingOperations rdf:type rdf:Property ;
    rdfs:label 'Allows Overlapping Operations' ;
    rdfs:comment 'Flag indicating whether this work center supports overlapping operations where subsequent operations can begin before the previous operation is fully complete.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableCapacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Hours Per Day' ;
    rdfs:comment 'Total available production hours per day calculated from shifts and hours per shift, accounting for planned downtime.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCategory rdf:type rdf:Property ;
    rdfs:label 'Capacity Category' ;
    rdfs:comment 'SAP PP capacity category code used for grouping work centers with similar capacity characteristics for planning purposes.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityHoursPerShift rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Shift' ;
    rdfs:comment 'Standard operating hours per shift for this work center, used for capacity planning and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityShiftsPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Shifts Per Day' ;
    rdfs:comment 'Number of production shifts this work center operates per day (e.g., 1.0 for single shift, 2.0 for two shifts, 3.0 for continuous operation).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efficiencyFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Efficiency Factor Percent' ;
    rdfs:comment 'Standard efficiency factor as a percentage representing the work center\'s expected performance relative to theoretical maximum (e.g., 85.00 means 85% efficiency).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentList rdf:type rdf:Property ;
    rdfs:label 'Equipment List' ;
    rdfs:comment 'Comma-separated list or summary of major equipment assets assigned to this work center (e.g., sequencers, liquid handlers, autoclaves, fill-finish machines).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulaKey rdf:type rdf:Property ;
    rdfs:label 'Formula Key' ;
    rdfs:comment 'SAP PP formula key used for calculating operation times, setup times, and processing times based on lot size and work center parameters.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBottleneck rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck' ;
    rdfs:comment 'Flag indicating whether this work center is identified as a production bottleneck requiring special capacity management and scheduling attention.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'Date when the work center last completed qualification (IQ/OQ/PQ) or requalification activities.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationBuilding rdf:type rdf:Property ;
    rdfs:label 'Location Building' ;
    rdfs:comment 'Building identifier or name where the work center is physically located within the plant.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationFloor rdf:type rdf:Property ;
    rdfs:label 'Location Floor' ;
    rdfs:comment 'Floor or level within the building where the work center is located.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationRoom rdf:type rdf:Property ;
    rdfs:label 'Location Room' ;
    rdfs:comment 'Room number or identifier for the specific room or area where the work center operates.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification or recertification of the work center per GMP maintenance schedules.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingTimePerUnitMinutes rdf:type rdf:Property ;
    rdfs:label 'Processing Time Per Unit Minutes' ;
    rdfs:comment 'Standard processing time in minutes required to produce one unit of output at this work center, used for capacity and scheduling calculations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Queue Time Minutes' ;
    rdfs:comment 'Standard queue time in minutes representing the typical wait time before an operation can start at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schedulingType rdf:type rdf:Property ;
    rdfs:label 'Scheduling Type' ;
    rdfs:comment 'Default scheduling direction for operations at this work center (forward from start date, backward from due date, or midpoint scheduling).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Setup Time Minutes' ;
    rdfs:comment 'Standard setup or changeover time in minutes required to prepare the work center for a new production run or product changeover.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardValueKey rdf:type rdf:Property ;
    rdfs:label 'Standard Value Key' ;
    rdfs:comment 'SAP PP standard value key defining the costing and time calculation parameters for operations performed at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Teardown Time Minutes' ;
    rdfs:comment 'Standard teardown or cleanup time in minutes required after completing a production run, including cleaning and decontamination for GMP compliance.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Usage Unit Of Measure' ;
    rdfs:comment 'Unit of measure for tracking work center usage and capacity consumption (e.g., hours, minutes, units produced, batches, cycles).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Current utilization rate as a percentage of available capacity actually used for production operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Work Center Category' ;
    rdfs:comment 'Classification of the work center type indicating its primary operational mode (machine-based, labor-intensive, full production line, assembly station, controlled environment clean room, or packaging line).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Business identifier for the work center used in production planning and scheduling. Externally visible code used in SAP PP module.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Work Center Description' ;
    rdfs:comment 'Detailed description of the work center\'s purpose, capabilities, and operational scope.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterName rdf:type rdf:Property ;
    rdfs:label 'Work Center Name' ;
    rdfs:comment 'Human-readable name of the work center (e.g., \'Flow Cell Assembly Line 3\', \'Reagent Fill-Finish Suite A\', \'NGS Library Prep Station\').' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Work Center Status' ;
    rdfs:comment 'Current operational status of the work center in its lifecycle (active for production, inactive/idle, under maintenance, undergoing qualification, or permanently decommissioned).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWorkEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Employee Id' ;
    rdfs:comment 'Reference to the production supervisor or manufacturing lead responsible for this work order execution. Links to workforce/employee master.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFinishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Timestamp' ;
    rdfs:comment 'Actual date and time when all production operations were completed and final goods receipt was posted. Used for TAT analysis and performance metrics.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity produced and confirmed through goods receipt. May differ from planned quantity due to yield variance, scrap, or rework.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Flag' ;
    rdfs:comment 'Indicates whether this work order is subject to GMP regulations and requires full electronic batch record, validation, and quality oversight. True for IVD and clinical products; False for RUO products.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Target quantity to be produced as specified in the work order. Measured in the base unit of measure for the material.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productClassification rdf:type rdf:Property ;
    rdfs:label 'Product Classification' ;
    rdfs:comment 'Regulatory classification of the product being manufactured. IVD: In Vitro Diagnostic (FDA-cleared); RUO: Research Use Only; LDT: Laboratory Developed Test; CE-IVD: European IVD regulation compliant.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'SAP reservation document number that reserves component materials from inventory for this work order. Links to inventory allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Version' ;
    rdfs:comment 'Version number of the routing used (e.g., 01, 02). Ensures process consistency and supports validation requirements.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sales Order Number' ;
    rdfs:comment 'Reference to the originating customer sales order if this is a make-to-order production. Null for make-to-stock orders. Enables order-to-cash traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledFinishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Finish Date' ;
    rdfs:comment 'Planned date for production completion and goods receipt. Used for delivery commitment and capacity planning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blanketOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Id' ;
    rdfs:comment 'Unique identifier for the blanket order framework agreement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlanketOrder .

ind:primaryBlanketAddressId rdf:type rdf:Property ;
    rdfs:label 'Primary Blanket Address Id' ;
    rdfs:comment 'Default shipping destination location for releases under this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:primaryBlanketEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Blanket Employee Id' ;
    rdfs:comment 'Sales representative responsible for managing this blanket order relationship.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sequencingProtocolId rdf:type rdf:Property ;
    rdfs:label 'Sequencing Protocol Id' ;
    rdfs:comment 'Foreign key linking to sequencing.sequencing_protocol. Business justification: Volume agreements for recurring sequencing services specify standard protocol for consistent pricing and service delivery. Enables "Customer ABC blanket order: 100 WGS runs/year at protocol P123" for ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SequencingProtocol .

ind:tertiaryBlanketContractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Blanket Contract Owner Employee Id' ;
    rdfs:comment 'Internal employee responsible for contract administration and compliance for this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'Expiration date when this blanket order agreement terminates and no further releases are permitted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'Effective start date when this blanket order agreement becomes active and releases can begin.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blanketOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the blanket order, used in customer communications and invoicing.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Blanket Order Status' ;
    rdfs:comment 'Current lifecycle status of the blanket order agreement. [ENUM-REF-CANDIDATE: draft|active|partially_consumed|fully_consumed|expired|cancelled|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Cumulative quantity that has been released and consumed against this blanket order to date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedValue rdf:type rdf:Property ;
    rdfs:label 'Consumed Value' ;
    rdfs:comment 'Cumulative monetary value that has been invoiced and consumed against this blanket order to date.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpSchedulingAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Scheduling Agreement Number' ;
    rdfs:comment 'SAP S/4HANA SD scheduling agreement or contract number that governs this blanket order in the system of record.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Incoterms code defining shipping responsibilities and risk transfer for deliveries under this blanket order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumReleaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Release Quantity' ;
    rdfs:comment 'Maximum quantity permitted in a single call-off release against this blanket order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumReleaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Release Quantity' ;
    rdfs:comment 'Minimum quantity that must be requested in each individual call-off release against this blanket order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Release Frequency' ;
    rdfs:comment 'Agreed-upon frequency pattern for call-off releases against this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Quantity remaining available for future call-off releases under this blanket order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingValue rdf:type rdf:Property ;
    rdfs:label 'Remaining Value' ;
    rdfs:comment 'Monetary value remaining available for future releases under this blanket order.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialTermsConditions rdf:type rdf:Property ;
    rdfs:label 'Special Terms Conditions' ;
    rdfs:comment 'Additional negotiated terms, conditions, or clauses specific to this blanket order agreement.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Committed Quantity' ;
    rdfs:comment 'Total quantity of product or service units committed under this blanket order agreement over its full term.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedValue rdf:type rdf:Property ;
    rdfs:label 'Total Committed Value' ;
    rdfs:comment 'Total monetary value committed under this blanket order agreement over its full term.' ;
    rdfs:domain ind:BlanketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Unique identifier for the credit memo record. Primary key.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Foreign key linking to quality.complaint. Business justification: Credits issued for quality-related complaints (defective products, failed sequencing runs, service failures). Finance links credit memos to complaint records for revenue impact tracking, customer sati' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:returnAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Id' ;
    rdfs:comment 'Reference to the return order that triggered this credit memo, if applicable. Null for non-return credit scenarios such as pricing corrections or goodwill credits.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnAuthorization .

ind:accountingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Reference' ;
    rdfs:comment 'Reference to the general ledger accounting document created for this credit memo. Links credit memo to financial postings in the ERP system.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'The ERP system billing document number associated with this credit memo. Used for financial reconciliation and audit trail in SAP FI/CO modules.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross credit amount issued to the customer before tax adjustments. Represents the base value of goods or services being credited.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Externally-known business identifier for the credit memo, typically generated by the ERP billing system. Used for customer communication and accounting reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoType rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Type' ;
    rdfs:comment 'Classification of the credit memo based on the business reason for issuance. Determines accounting treatment and approval workflow.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonCode rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Code' ;
    rdfs:comment 'Standardized code indicating the specific reason for credit issuance. Used for root cause analysis, quality tracking, and process improvement. Examples: defective product, shipping damage, pricing error, SLA breach, customer satisfaction.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Credit Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for issuing the credit memo. Provides context for audits, customer service, and dispute resolution.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Reference Number' ;
    rdfs:comment 'Customer-provided reference number or purchase order number associated with the original transaction. Used for customer reconciliation and dispute resolution.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'SAP division code representing the product line or business unit. Examples: sequencing instruments, reagents and consumables, bioinformatics software.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date when the refund payment was processed and sent to the customer. Null if payment method is account credit or offset.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Status of the refund payment process if the credit memo requires a cash refund. Not applicable for account credits or invoice offsets.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Reversal Flag' ;
    rdfs:comment 'Indicates whether this credit memo triggers a revenue reversal in the financial system. True for credits against recognized revenue (e.g., sequencing service orders with milestone-based recognition), false for credits that do not impact revenue (e.g., advance payment adjustments).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Total Credit Amount' ;
    rdfs:comment 'The total credit amount including tax. Represents the full value credited to the customer account (credit_amount + tax_amount).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAcceptanceId rdf:type rdf:Property ;
    rdfs:label 'Customer Acceptance Id' ;
    rdfs:comment 'Unique identifier for the customer acceptance record. Primary key for this entity.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the shipment delivery associated with this acceptance event. Tracks physical delivery of goods.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Calendar date on which the customer formally accepted the delivered goods or completed services. Key milestone for revenue recognition under ASC 606 and contract fulfillment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Acceptance Document Url' ;
    rdfs:comment 'Storage location or reference path to the signed acceptance document or certificate. Points to document management system (Veeva Vault) for audit and compliance retrieval.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceMethod rdf:type rdf:Property ;
    rdfs:label 'Acceptance Method' ;
    rdfs:comment 'Mechanism through which the customer provided acceptance confirmation. Distinguishes between electronic signature, paper-based signature, email confirmation, customer portal acknowledgment, or automated system integration.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceNotes rdf:type rdf:Property ;
    rdfs:label 'Acceptance Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special conditions related to the acceptance event. Captures context not covered by structured fields.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceNumber rdf:type rdf:Property ;
    rdfs:label 'Acceptance Number' ;
    rdfs:comment 'Business-facing unique identifier for the acceptance record. Human-readable reference number used in customer communications and audit trails.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Current lifecycle state of the acceptance record. Tracks progression from pending customer review through final accepted or rejected state. Critical for revenue recognition trigger and order closure workflow.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Precise date and time when the customer acceptance was recorded in the system. Provides audit trail for compliance and SLA tracking.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptanceType rdf:type rdf:Property ;
    rdfs:label 'Acceptance Type' ;
    rdfs:comment 'Category of acceptance event. Distinguishes between physical goods receipt confirmation, instrument installation qualification sign-off (IQ/OQ/PQ), sequencing data delivery acceptance, software implementation go-live acknowledgment, or service completion confirmation.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAcceptanceDays rdf:type rdf:Property ;
    rdfs:label 'Actual Acceptance Days' ;
    rdfs:comment 'Actual number of days elapsed from delivery to customer acceptance. Calculated as the difference between delivery date and acceptance date. Used for SLA compliance reporting.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaInitiated rdf:type rdf:Property ;
    rdfs:label 'Capa Initiated' ;
    rdfs:comment 'Boolean indicator of whether a Corrective and Preventive Action was initiated as a result of this acceptance event. True when rejection or conditional acceptance triggers quality investigation.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityMetricPassed rdf:type rdf:Property ;
    rdfs:label 'Data Quality Metric Passed' ;
    rdfs:comment 'Boolean indicator of whether delivered sequencing data met agreed-upon quality thresholds (Phred score, coverage depth, read length). True indicates data passed QC specifications. Applicable for sequencing data delivery acceptance.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installationQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Installation Qualification Status' ;
    rdfs:comment 'Status of instrument qualification protocol execution for IVD and GxP installations. Tracks completion of Installation Qualification, Operational Qualification, and Performance Qualification phases. Applicable only for instrument acceptance types. [ENUM-REF-CANDIDATE: not_applicable|iq_passed|oq_passed|pq_passed|iq_failed|oq_failed|pq_failed|in_progress — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which acceptance documentation was submitted to regulatory authorities. Null if no regulatory submission is required or submission has not yet occurred.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Boolean indicator of whether this acceptance event requires submission to regulatory authorities (FDA, EMA) as part of post-market surveillance or clinical trial reporting. True for IVD and clinical genomics acceptances.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for customer rejection or conditional acceptance. Used for root cause analysis and quality improvement. Null when acceptance status is accepted. [ENUM-REF-CANDIDATE: damaged_goods|incomplete_delivery|specification_mismatch|failed_qualification|data_quality_issue|late_delivery|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the rejection or conditional acceptance. Captures customer-provided specifics for quality investigation and corrective action. Null when acceptance status is accepted.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Monetary value of revenue recognized upon this acceptance event. Represents the portion of the sales order value that becomes recognizable revenue based on customer acceptance.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue was recognized in the financial system based on this acceptance event. Aligns with ASC 606 performance obligation satisfaction. Null if revenue recognition has not yet occurred.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionTriggered rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Triggered' ;
    rdfs:comment 'Boolean indicator of whether this acceptance event triggered revenue recognition in the financial system. True when acceptance satisfies ASC 606 performance obligation criteria and revenue can be recognized.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Signatory Email' ;
    rdfs:comment 'Email address of the signatory for acceptance confirmation and audit trail purposes. Used for electronic signature verification and communication.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetAcceptanceDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Acceptance Days' ;
    rdfs:comment 'Number of days from delivery within which customer acceptance is expected per contractual SLA. Used to track on-time acceptance performance and customer responsiveness.' ;
    rdfs:domain ind:CustomerAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerPoId rdf:type rdf:Property ;
    rdfs:label 'Customer Po Id' ;
    rdfs:comment 'Unique identifier for the customer purchase order record. Primary key.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address specified on the customer purchase order. Used for invoice generation and accounts receivable processing.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address specified on the customer purchase order. Optional additional address detail.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the billing address specified on the customer purchase order. Used for tax jurisdiction determination and regulatory compliance.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal code or ZIP code component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province component of the billing address specified on the customer purchase order.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact person listed on the purchase order for order-related communication.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the customer contact person listed on the purchase order for order-related inquiries and coordination.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact person listed on the purchase order for order-related communication.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerErpPoReference rdf:type rdf:Property ;
    rdfs:label 'Customer Erp Po Reference' ;
    rdfs:comment 'The internal purchase order reference or document ID from the customer\'s ERP system. Enables reconciliation between customer procurement records and Genomics Biotech sales records.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerErpSystem rdf:type rdf:Property ;
    rdfs:label 'Customer Erp System' ;
    rdfs:comment 'The name or identifier of the customer\'s ERP system from which the purchase order originated. Used for system integration and procurement process traceability.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poConsumedValue rdf:type rdf:Property ;
    rdfs:label 'Po Consumed Value' ;
    rdfs:comment 'The cumulative monetary value that has been consumed against this purchase order through fulfilled sales orders and invoices. Used to calculate remaining PO balance.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poIssueDate rdf:type rdf:Property ;
    rdfs:label 'Po Issue Date' ;
    rdfs:comment 'The date on which the customer formally issued the purchase order. This is the principal business event timestamp for the PO and serves as the contractual reference date.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'The customer-issued purchase order number as it appears on the formal procurement document. This is the externally-known identifier used for contractual reference and invoice matching.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Po Received Date' ;
    rdfs:comment 'The date on which Genomics Biotech received and registered the customer purchase order in SAP SD. Used for order processing SLA tracking and TAT measurement.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poRemainingBalance rdf:type rdf:Property ;
    rdfs:label 'Po Remaining Balance' ;
    rdfs:comment 'The remaining available monetary value on the purchase order calculated as PO total value minus PO consumed value. Indicates how much additional value can be fulfilled against this PO.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the customer purchase order. Open indicates available for fulfillment, partially-consumed indicates partial delivery against PO value, fully-consumed indicates PO value exhausted, cancelled indicates customer revocation, expired indicates validity period ended, on-hold indicates temporary suspension.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poTotalValue rdf:type rdf:Property ;
    rdfs:label 'Po Total Value' ;
    rdfs:comment 'The total authorized monetary value of the purchase order as stated by the customer. Represents the maximum amount that can be invoiced against this PO.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type indicating the procurement structure. Standard for one-time orders, blanket for recurring releases, framework for multi-year agreements, government for public sector contracts, contract for negotiated terms, spot for ad-hoc purchases.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Po Validity End Date' ;
    rdfs:comment 'The expiration date after which the purchase order is no longer valid for order fulfillment. Nullable for open-ended POs. Defines the end of the PO authorization period.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Po Validity Start Date' ;
    rdfs:comment 'The effective start date from which the purchase order is valid and can be used for order fulfillment. Defines the beginning of the PO authorization period.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the individual at the customer organization who initiated or requested the purchase order. Used for order verification and approval workflows.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line1' ;
    rdfs:comment 'First line of the shipping destination address specified on the customer purchase order. Used for order fulfillment and logistics planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Ship To Address Line2' ;
    rdfs:comment 'Second line of the shipping destination address specified on the customer purchase order. Optional additional address detail.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCity rdf:type rdf:Property ;
    rdfs:label 'Ship To City' ;
    rdfs:comment 'City component of the shipping destination address specified on the customer purchase order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the shipping destination address specified on the customer purchase order. Used for export compliance and logistics routing.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToPostalCode rdf:type rdf:Property ;
    rdfs:label 'Ship To Postal Code' ;
    rdfs:comment 'Postal code or ZIP code component of the shipping destination address specified on the customer purchase order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipToStateProvince rdf:type rdf:Property ;
    rdfs:label 'Ship To State Province' ;
    rdfs:comment 'State or province component of the shipping destination address specified on the customer purchase order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingTerms rdf:type rdf:Property ;
    rdfs:label 'Shipping Terms' ;
    rdfs:comment 'The shipping and delivery terms specified on the customer purchase order, such as FOB, CIF, DDP, or other Incoterms. Defines responsibility for shipping costs and risk transfer.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialTermsNotes rdf:type rdf:Property ;
    rdfs:label 'Special Terms Notes' ;
    rdfs:comment 'Free-text field capturing any special terms, conditions, or instructions noted on the customer purchase order that require attention during order fulfillment. May include delivery instructions, quality requirements, or contractual clauses.' ;
    rdfs:domain ind:CustomerPo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Unique identifier for the outbound delivery document. Primary key.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Delivery .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Reference to the logistics carrier or shipping company responsible for transporting the delivery.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code - a unique 2-4 letter code used to identify transportation companies in North America.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the delivery contains dangerous goods or hazardous materials requiring special handling and documentation per IATA/DOT regulations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Planned or actual date when the delivery is scheduled to reach the customer.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery document (created, picked, packed, goods issued, in transit, delivered, cancelled). [ENUM-REF-CANDIDATE: created|picked|packed|goods_issued|in_transit|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryType rdf:type rdf:Property ;
    rdfs:label 'Delivery Type' ;
    rdfs:comment 'Classification of the delivery based on fulfillment method and handling requirements (standard, rush, cold-chain, hazardous materials, direct ship, drop ship).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Export Declaration Number' ;
    rdfs:comment 'Customs export declaration number for international shipments, required for regulatory compliance and border clearance.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Date' ;
    rdfs:comment 'Date when goods were physically issued from the warehouse and inventory was decremented. Critical for revenue recognition and inventory accounting.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Status of the goods issue posting (not issued, partially issued, fully issued, reversed).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when goods issue was posted in the ERP system. Used for audit trail and SLA tracking.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of individual packages or handling units in the delivery.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfDeliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Url' ;
    rdfs:comment 'URL link to the electronic proof of delivery document or signature capture from the carrier system.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation mode used for the delivery (ground, air, ocean, cold-chain ground, cold-chain air, courier).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPoint rdf:type rdf:Property ;
    rdfs:label 'Shipping Point' ;
    rdfs:comment 'SAP shipping point code representing the organizational unit responsible for shipping activities. Typically a 4-character alphanumeric code.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max C' ;
    rdfs:comment 'Maximum allowable temperature in Celsius for cold-chain shipments to ensure product stability and quality.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min C' ;
    rdfs:comment 'Minimum allowable temperature in Celsius for cold-chain shipments to ensure product stability and quality.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of the delivery including packaging materials, measured in kilograms. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Kg' ;
    rdfs:comment 'Total net weight of the delivery excluding packaging materials, measured in kilograms. Represents the actual product weight.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for real-time shipment visibility and customer self-service tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN number identifying hazardous substances for international transport (e.g., UN1845 for dry ice). Required when dangerous_goods_flag is true.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLineId rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Id' ;
    rdfs:comment 'Unique identifier for the delivery line item within the outbound delivery document. Primary key for this entity.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coaId rdf:type rdf:Property ;
    rdfs:label 'Coa Id' ;
    rdfs:comment 'Foreign key linking to reagent.coa. Business justification: Certificates of Analysis must accompany reagent shipments in genomics biotech. FK enables automated CoA document retrieval for customer portals, regulatory audit trails, and quality documentation requ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:salesOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Id' ;
    rdfs:comment 'Reference to the specific sales order line item being fulfilled by this delivery line. Establishes one-to-one or many-to-one fulfillment relationship.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:coldChainHandlingInstruction rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Handling Instruction' ;
    rdfs:comment 'Temperature control requirements for shipping and storage of this product. Critical for reagent stability and assay performance. Specifies required temperature range during transit.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where this product was manufactured. Required for customs documentation and trade compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLineStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Line Status' ;
    rdfs:comment 'Overall lifecycle status of this delivery line. Tracks progression from order release through goods issue and shipment. [ENUM-REF-CANDIDATE: open|in_picking|picked|packed|goods_issued|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'The quantity of product being shipped on this delivery line. Represents the actual amount picked, packed, and dispatched to the customer.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsIssueQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Quantity' ;
    rdfs:comment 'The quantity for which goods issue has been posted in the ERP system. Represents the inventory reduction and financial posting amount. May differ from delivery quantity in case of partial shipments.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Gross weight of the product on this delivery line in kilograms, including all packaging materials. Used for carrier billing and freight planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International harmonized system code for customs classification. Determines duty rates, import restrictions, and trade statistics reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineValueAmount rdf:type rdf:Property ;
    rdfs:label 'Line Value Amount' ;
    rdfs:comment 'Total monetary value of this delivery line based on the delivered quantity and unit price. Used for shipment insurance valuation and customs declaration.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Date' ;
    rdfs:comment 'The date on which this product lot or batch was manufactured. Used for shelf-life calculation, quality tracking, and regulatory traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netWeightKg rdf:type rdf:Property ;
    rdfs:label 'Net Weight Kg' ;
    rdfs:comment 'Net weight of the product on this delivery line in kilograms, excluding packaging. Used for shipping cost calculation and customs documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packStatus rdf:type rdf:Property ;
    rdfs:label 'Pack Status' ;
    rdfs:comment 'Current status of the packing process for this delivery line. Indicates whether the item has been placed in shipping containers with appropriate cold-chain or hazmat packaging.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Status' ;
    rdfs:comment 'Current status of the warehouse picking process for this delivery line. Tracks progression from pick list generation through physical item retrieval.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productRegulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Product Regulatory Status' ;
    rdfs:comment 'Regulatory classification of the product being shipped. RUO (Research Use Only) for research products, IVD (In Vitro Diagnostic) for clinical products, CE-IVD for European market, FDA-cleared/approved for US clinical use.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'The warehouse storage location code from which this product was picked. Identifies the specific bin, shelf, or cold storage zone within the distribution center.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume occupied by this delivery line item in cubic meters. Used for warehouse space planning and freight optimization.' ;
    rdfs:domain ind:DeliveryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentInstructionId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Instruction Id' ;
    rdfs:comment 'Unique identifier for the fulfillment instruction record. Primary key for the fulfillment instruction entity.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTeamOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Org Unit Id' ;
    rdfs:comment 'Reference to the field service team, logistics crew, or installation squad assigned to execute this instruction. Used for install, service_dispatch, and field-based fulfillment types.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Timestamp when fulfillment was successfully completed (shipment dispatched, installation signed off, or license activated). Used for TAT compliance reporting and customer notification.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualExecutionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Start Timestamp' ;
    rdfs:comment 'Timestamp when fulfillment execution actually began (warehouse pick started, field engineer arrived on site, or activation process initiated). Used for TAT performance measurement.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionConfirmationSignature rdf:type rdf:Property ;
    rdfs:label 'Completion Confirmation Signature' ;
    rdfs:comment 'Digital signature or confirmation code from customer or field engineer acknowledging successful fulfillment completion. Used for proof of delivery, installation acceptance, or service completion.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address for shipment notifications, installation appointment confirmations, and service dispatch updates. Used for automated customer communication.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the individual at the delivery location authorized to receive shipment or coordinate installation. Used for carrier delivery confirmation and field service appointment scheduling.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number for delivery coordination, installation scheduling, or service dispatch communication. Used by carriers and field service engineers.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs authority reference number for international shipments. Required for cross-border fulfillment to comply with import/export regulations and tariff classification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current state of the fulfillment instruction in its execution lifecycle. Pending = awaiting assignment; Assigned = allocated to facility or team; In_Progress = actively being executed; Completed = successfully fulfilled; Cancelled = instruction voided; On_Hold = temporarily suspended; Failed = execution unsuccessful. [ENUM-REF-CANDIDATE: pending|assigned|in_progress|completed|cancelled|on_hold|failed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlClassification rdf:type rdf:Property ;
    rdfs:label 'Export Control Classification' ;
    rdfs:comment 'U.S. Commerce Department Export Control Classification Number for dual-use technology and controlled items. Required for sequencing instruments and bioinformatics software with encryption. Ensures compliance with Export Administration Regulations (EAR).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureNotes rdf:type rdf:Property ;
    rdfs:label 'Failure Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for fulfillment failure or cancellation. Captured by warehouse staff, field engineer, or logistics coordinator.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized code explaining why fulfillment execution failed or was cancelled. None = no failure. Used for root cause analysis and process improvement. [ENUM-REF-CANDIDATE: address_invalid|recipient_unavailable|customs_hold|damaged_in_transit|installation_site_not_ready|technical_issue|cancelled_by_customer|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationAppointmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Appointment Timestamp' ;
    rdfs:comment 'Scheduled date and time for instrument installation or field service visit. Applicable for install and service_dispatch instruction types. Coordinated with customer and field service engineer availability.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Business-readable unique identifier for the fulfillment instruction, formatted as FI- followed by 10 digits. Used for tracking and communication with warehouse, logistics, and field service teams.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Category of fulfillment action required. Ship = standard pick-pack-ship; Install = instrument installation with field service engineer; Service_Dispatch = field service task; Activate = software license or cloud service activation; Sample_Kit_Dispatch = sequencing service sample collection kit; Cold_Chain_Ship = temperature-controlled logistics for reagents/enzymes.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseActivationKey rdf:type rdf:Property ;
    rdfs:label 'License Activation Key' ;
    rdfs:comment 'Unique activation key for software license or cloud service entitlement. Applicable for activate instruction type. Generated by license management system and delivered to customer via secure channel.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingListNumber rdf:type rdf:Property ;
    rdfs:label 'Packing List Number' ;
    rdfs:comment 'Reference to the warehouse packing list document detailing items included in shipment. Used for shipment verification and customs documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Execution Date' ;
    rdfs:comment 'Planned date for fulfillment execution (ship date, installation date, or service dispatch date). Used for capacity planning and customer communication.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Carrier Code' ;
    rdfs:comment 'Standard carrier identifier for logistics provider (e.g., FEDEX, UPS, DHL, WORLDCOURIER). Applicable for ship and cold_chain_ship instruction types. Null for non-shipping fulfillment.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Shipping Service Level' ;
    rdfs:comment 'Carrier service tier selected for shipment. Overnight = next-day delivery; Two_Day = 2-business-day; Ground = standard surface; International_Express = expedited cross-border; International_Standard = economy cross-border; White_Glove = premium instrument delivery with setup.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Logistics and handling requirements for this fulfillment. Dry_Ice = dry ice packaging for frozen reagents; Controlled_Rate_Freezer = CRF shipping for enzyme stability; Ambient = room temperature; Refrigerated = 2-8°C cold chain; Hazmat = hazardous materials compliance; Fragile = delicate instruments; High_Value = security escort; Biohazard = biosafety protocols; None = standard handling. [ENUM-REF-CANDIDATE: dry_ice|controlled_rate_freezer|ambient|refrigerated|hazmat|fragile|high_value|biohazard|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tat Deadline Timestamp' ;
    rdfs:comment 'Service Level Agreement (SLA) deadline by which this fulfillment instruction must be completed. Derived from order TAT commitment and used for SLA compliance monitoring.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether cold-chain temperature monitoring is required during transit. True for reagents, enzymes, and temperature-sensitive consumables requiring Good Distribution Practice (GDP) compliance. Triggers data logger inclusion in shipment.' ;
    rdfs:domain ind:FulfillmentInstruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billToPartyAccountId rdf:type rdf:Property ;
    rdfs:label 'Bill To Party Account Id' ;
    rdfs:comment 'Foreign key reference to the party responsible for payment. Invoices are sent to this party. May differ from ship-to party for centralized billing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:crmOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Id' ;
    rdfs:comment 'Salesforce CRM opportunity identifier representing the sales opportunity that converted into this order. Enables opportunity-to-order traceability.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'System user ID of the person or service account that last modified this order record. Audit trail for change tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:soldToPartyAccountId rdf:type rdf:Property ;
    rdfs:label 'Sold To Party Account Id' ;
    rdfs:comment 'Foreign key reference to the primary contracting party. Represents the legal entity entering into the sales agreement.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:confirmedShipDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Ship Date' ;
    rdfs:comment 'Date when the order was confirmed to ship from the fulfillment center or manufacturing facility. Null until shipment is confirmed.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpSalesDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Sales Document Number' ;
    rdfs:comment 'SAP S/4HANA SD module sales document number. System-of-record identifier linking this order to the ERP order-to-cash process.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exportControlFlag rdf:type rdf:Property ;
    rdfs:label 'Export Control Flag' ;
    rdfs:comment 'Indicates whether this order contains items subject to export control regulations (ITAR, EAR, dual-use technology). True requires additional compliance review and documentation.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'Named place or port specified in the Incoterms clause where risk and cost transfer occurs (e.g., San Diego Port, customer facility address).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Order Source Channel' ;
    rdfs:comment 'Sales channel through which the order was received. Direct sales for company sales team, distributor for channel partners, OEM for original equipment manufacturer partnerships, e-commerce for online store, field application for scientific support-driven sales.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOffice rdf:type rdf:Property ;
    rdfs:label 'Sales Office' ;
    rdfs:comment 'Geographic sales office or region responsible for this order. Used for territory management and sales performance tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCarrier rdf:type rdf:Property ;
    rdfs:label 'Shipping Carrier' ;
    rdfs:comment 'Name of the logistics carrier or freight forwarder handling shipment (e.g., FedEx, UPS, DHL, specialized biotech logistics provider).' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatCommitmentDate rdf:type rdf:Property ;
    rdfs:label 'Tat Commitment Date' ;
    rdfs:comment 'Date by which the order must be delivered to meet the SLA commitment. Calculated from order date plus SLA tier turnaround time. Used for performance tracking.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalNetValue rdf:type rdf:Property ;
    rdfs:label 'Total Net Value' ;
    rdfs:comment 'Total order value before taxes, fees, and adjustments. Sum of all line item net values in the order currency.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax amount applied to the order, including sales tax, VAT, GST, or other applicable taxes based on ship-to jurisdiction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Unique identifier for the order line item. Primary key for the order line entity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualShipDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ship Date' ;
    rdfs:comment 'Actual date when the line item was shipped from the warehouse or manufacturing facility. Null if not yet shipped.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedQuantity rdf:type rdf:Property ;
    rdfs:label 'Confirmed Quantity' ;
    rdfs:comment 'Quantity confirmed for delivery based on Available-to-Promise (ATP) check and inventory availability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Cumulative quantity that has been shipped and delivered to the customer across all shipments for this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority level for fulfillment and shipping of this line item. Influences warehouse picking sequence and carrier service selection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listUnitPrice rdf:type rdf:Property ;
    rdfs:label 'List Unit Price' ;
    rdfs:comment 'Standard catalog list price per unit before any discounts or adjustments. Expressed in order currency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Net Unit Price' ;
    rdfs:comment 'Net price per unit after applying all applicable discounts and before taxes. Expressed in order currency.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'Total net value for this line item calculated as net_unit_price * ordered_quantity, before taxes. Expressed in order currency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity not yet shipped or fulfilled. Calculated as ordered_quantity minus delivered_quantity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the product ordered by the customer as specified in the original sales order.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Regulatory classification of the product. RUO=Research Use Only, IVD=In Vitro Diagnostic, CE-IVD=European Conformité Européenne IVD, LDT=Laboratory Developed Test.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingServiceType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Service Type' ;
    rdfs:comment 'Type of Next-Generation Sequencing (NGS) service when product_type is sequencing_service. WGS=Whole Genome Sequencing, WES=Whole Exome Sequencing. Empty for non-sequencing products.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRequirement rdf:type rdf:Property ;
    rdfs:label 'Temperature Requirement' ;
    rdfs:comment 'Required storage and shipping temperature condition for the product. Critical for reagent and biological sample integrity.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total value for this line item including taxes. Calculated as line_net_value + tax_amount. Expressed in order currency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Unique identifier for each order status transition event. Primary key for the order status event log.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Name of the upstream data source or integration pipeline that delivered this event record (e.g., SAP_SD_CDC, Salesforce_API, Manual_Entry).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of this event within the lifecycle of the parent order (1 for first transition, 2 for second, etc.). Enables chronological reconstruction of order history.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The expected delivery date communicated to the customer at the time of this status transition. Updated as the order progresses through fulfillment.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Is Reversal Flag' ;
    rdfs:comment 'Indicates whether this status transition represents a reversal or rollback of a previous status (e.g., moving from shipped back to in_fulfillment due to a return). True for backward transitions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The order status after this transition event. Captures the to-state in the order lifecycle state machine. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|in_fulfillment|shipped|delivered|completed|cancelled|on_hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status change (e.g., email, SMS, customer portal). Null if no notification was sent.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether an automated customer notification (email, SMS) was sent for this status transition. Supports customer communication audit.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level of the order at the time of this status transition. Affects SLA targets and fulfillment sequencing.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The order status immediately before this transition event. Captures the from-state in the order lifecycle state machine. [ENUM-REF-CANDIDATE: draft|submitted|confirmed|in_fulfillment|shipped|delivered|completed|cancelled|on_hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachSeverity rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Severity' ;
    rdfs:comment 'Classification of the severity of the SLA breach based on how much the TAT exceeded the target (e.g., minor for <4 hours late, major for >24 hours late).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Flag' ;
    rdfs:comment 'Indicates whether this status transition represents a contractual SLA milestone (e.g., order-confirmed, shipped-on-time, delivered-on-time). True if this event is an SLA checkpoint.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaMilestoneName rdf:type rdf:Property ;
    rdfs:label 'Sla Milestone Name' ;
    rdfs:comment 'Name of the SLA milestone associated with this status transition (e.g., Order Confirmation, Shipment Dispatch, Delivery Completion). Null if not an SLA milestone.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'Unique transaction or event identifier from the source system (SAP SD document number, Salesforce event ID) that triggered this status change. Enables traceability back to the originating system.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the status transition (e.g., customer_request, inventory_available, quality_hold, shipment_dispatched).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Description' ;
    rdfs:comment 'Free-text explanation or additional context describing why the order status changed. Provides human-readable detail beyond the reason code.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatElapsedHours rdf:type rdf:Property ;
    rdfs:label 'Tat Elapsed Hours' ;
    rdfs:comment 'Total elapsed time in hours from order creation to this status transition. Enables TAT tracking and performance analysis against committed delivery timelines.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tatTargetHours rdf:type rdf:Property ;
    rdfs:label 'Tat Target Hours' ;
    rdfs:comment 'The target TAT in hours for reaching this status milestone, as defined by customer SLA or internal operational standards. Null if no target is defined for this transition.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'The source system or application that initiated this status transition (e.g., SAP SD for fulfillment updates, Salesforce CRM for order entry, manual override by user).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByUserName rdf:type rdf:Property ;
    rdfs:label 'Triggered By User Name' ;
    rdfs:comment 'Full name of the user who triggered the status change. Supports audit trail and accountability for manual interventions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactId rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Id' ;
    rdfs:comment 'Reference to the specific customer contact person who requested or received the quotation.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:quotationApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quotation Approved By User Employee Id' ;
    rdfs:comment 'Reference to the manager or approver who authorized this quotation. Null if approval not required or still pending.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quotation Employee Id' ;
    rdfs:comment 'Reference to the sales representative or account manager who prepared and owns this quotation.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotationPreparedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quotation Prepared By User Employee Id' ;
    rdfs:comment 'Reference to the system user who created and prepared the quotation document. May differ from sales rep if prepared by sales operations.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:convertedToOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Converted To Order Flag' ;
    rdfs:comment 'Boolean indicator whether this quotation has been converted to a sales order. True: quotation accepted and order created; False: quotation still pending or rejected.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Notes' ;
    rdfs:comment 'Special instructions or terms communicated to the customer on the quotation document. Printed on customer-facing quotation PDF.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Named delivery location or Incoterms location for the quoted goods (e.g., customer facility address, port name).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTier rdf:type rdf:Property ;
    rdfs:label 'Discount Tier' ;
    rdfs:comment 'Discount tier applied to this quotation. Standard: list price; Volume: quantity-based discount; Strategic: key account pricing; Promotional: campaign offer; Custom: special approval pricing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'SAP SD division representing the product line or business unit. Two-character code (e.g., sequencing instruments, reagents, services).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpQuotationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Quotation Document Number' ;
    rdfs:comment 'SAP S/4HANA SD module quotation document number. Ten-digit numeric identifier from the source ERP system.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order placement to delivery at customer site. Used for customer planning and SLA commitment.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Three-letter Incoterms 2020 code defining delivery terms and risk transfer point (e.g., EXW, FOB, CIF, DDP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Net Quoted Value' ;
    rdfs:comment 'Final net quotation value after applying discounts and adding taxes. Total amount customer will pay if quotation is accepted.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingConditionsApplied rdf:type rdf:Property ;
    rdfs:label 'Pricing Conditions Applied' ;
    rdfs:comment 'Comma-separated list of SAP SD pricing condition types applied to this quotation (e.g., PR00 base price, K004 volume discount, MWST tax).' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Date' ;
    rdfs:comment 'Date the quotation was created and issued to the customer. Business event timestamp for quotation generation.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Business-facing unique quotation document number used for customer communication and reference. Format: QT-YYYYNNNN.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the quotation. Draft: being prepared; Submitted: sent to customer; Accepted: customer approved; Rejected: customer declined; Expired: validity period lapsed; Withdrawn: seller cancelled.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationType rdf:type rdf:Property ;
    rdfs:label 'Quotation Type' ;
    rdfs:comment 'Classification of quotation by business purpose. Standard: catalog products; Custom: configured solutions; Renewal: subscription extension; Upgrade: existing customer expansion; Trial: evaluation offer.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPricingJustification rdf:type rdf:Property ;
    rdfs:label 'Special Pricing Justification' ;
    rdfs:comment 'Business justification for non-standard pricing or discounts exceeding standard approval thresholds. Required for audit and compliance when custom pricing is applied.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuotedValue rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Value' ;
    rdfs:comment 'Total monetary value of the quotation including all line items, before discounts and taxes. Gross quotation amount.' ;
    rdfs:domain ind:Quotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotationLineId rdf:type rdf:Property ;
    rdfs:label 'Quotation Line Id' ;
    rdfs:comment 'Unique identifier for the quotation line item. Primary key for this entity.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Estimated number of calendar days from order acceptance to product delivery or service completion. Represents the Turnaround Time (TAT) commitment for this line item.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineNetValue rdf:type rdf:Property ;
    rdfs:label 'Line Net Value' ;
    rdfs:comment 'Total net value for this quotation line calculated as quoted_unit_price multiplied by quoted_quantity. Represents the subtotal for this line item before taxes and shipping.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'SAP material group classification for the quoted product. Groups similar products for procurement, pricing, and reporting purposes within the enterprise resource planning system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'SAP SD pricing condition type code that determines how the quoted price was calculated. Identifies the specific pricing rule, discount scheme, or surcharge applied to this line item.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of the product or service being quoted. Represents the number of units, kits, instruments, or service hours proposed to the customer.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Actual unit price quoted to the customer after applying discounts, volume pricing, or negotiated rates. This is the effective price per unit that will be charged if the quotation is accepted.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequencingCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Sequencing Coverage Depth' ;
    rdfs:comment 'Target coverage depth specification for sequencing services expressed as fold coverage (e.g., 30X, 100X). Indicates how many times each base position will be sequenced on average. Applicable when product_category is sequencing_service.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'Tax classification code determining applicable tax rates and rules for this line item. Used for Value Added Tax (VAT), Goods and Services Tax (GST), or sales tax calculation based on product type and jurisdiction.' ;
    rdfs:domain ind:QuotationLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date until which this quotation line item pricing and terms remain valid. After this date, pricing may need to be re-quoted. Defines the end of the quotation validity period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which this quotation line item pricing and terms become valid. Defines the beginning of the quotation validity period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryReturnEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Employee Id' ;
    rdfs:comment 'Reference to the quality control inspector who performed the return inspection.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReturnHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Header Id' ;
    rdfs:comment 'Reference to the original sales order from which this return originated.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Reference to the CAPA investigation record if corrective action was initiated.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Deviation Flag' ;
    rdfs:comment 'Boolean indicator whether this return triggered a GMP deviation investigation due to quality or compliance concerns.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Date' ;
    rdfs:comment 'Date when the quality control inspection of the returned goods was completed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcInspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Notes' ;
    rdfs:comment 'Detailed notes and observations recorded by the QC inspector during the return inspection.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Result' ;
    rdfs:comment 'Quality control inspection outcome upon receipt of the returned goods.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Restocking fee charged to the customer for processing the return, if applicable per return policy.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizedDate rdf:type rdf:Property ;
    rdfs:label 'Return Authorized Date' ;
    rdfs:comment 'Date when the return authorization was approved and RMA number was issued.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnCreditedDate rdf:type rdf:Property ;
    rdfs:label 'Return Credited Date' ;
    rdfs:comment 'Date when the credit memo was issued and the customer account was credited.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Quantity of units being returned by the customer.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the return request.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the return reason provided by the customer or customer service representative.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Return Received Date' ;
    rdfs:comment 'Date when the returned goods were physically received at the warehouse or facility.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Return Requested Date' ;
    rdfs:comment 'Date when the customer initially requested the return authorization.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnShippingCost rdf:type rdf:Property ;
    rdfs:label 'Return Shipping Cost' ;
    rdfs:comment 'Cost of shipping the returned goods, which may be borne by the customer or the company depending on return reason.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the return authorization workflow. [ENUM-REF-CANDIDATE: requested|authorized|in-transit|received|inspected|credited|rejected|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnValueAmount rdf:type rdf:Property ;
    rdfs:label 'Return Value Amount' ;
    rdfs:comment 'Total monetary value of the returned goods in the transaction currency.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-known return authorization number issued to the customer for tracking and processing the return.' ;
    rdfs:domain ind:ReturnAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Boolean indicator whether the returned product experienced temperature excursion during storage or transit, affecting product integrity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierSlaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Carrier Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the carrier failed to meet the committed delivery Service Level Agreement (SLA). True if actual delivery date exceeds estimated delivery date by the SLA tolerance threshold.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Number' ;
    rdfs:comment 'Unique tracking identifier assigned by the carrier for real-time shipment visibility and proof of delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'Primary street address line of the customer delivery location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line2' ;
    rdfs:comment 'Secondary address line for suite, building, or department information at the delivery location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the customer delivery location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the customer delivery location (e.g., USA, GBR, DEU, CHN).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the customer delivery location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Destination State Province' ;
    rdfs:comment 'State, province, or region of the customer delivery location. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCostAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Amount' ;
    rdfs:comment 'Total freight and logistics cost charged by the carrier for this shipment, in the company\'s reporting currency. Used for Cost of Goods Sold (COGS) calculation and profitability analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the freight cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'United Nations (UN) hazard classification code for hazardous materials in the shipment (e.g., Class 6.2 for infectious substances, Class 9 for miscellaneous). Null if hazmat_flag is false.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials requiring special handling, labeling, and regulatory documentation per Department of Transportation (DOT) or International Air Transport Association (IATA) regulations. True if hazmat present.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'Three-letter Incoterms code defining the division of costs, risks, and responsibilities between seller and buyer for international shipments (e.g., DDP = Delivered Duty Paid, FOB = Free On Board). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Amount' ;
    rdfs:comment 'Declared value of the shipment contents for insurance purposes. Used to determine coverage limits and premium calculation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the insurance value amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Code' ;
    rdfs:comment 'Code identifying the warehouse, distribution center, or manufacturing plant from which the shipment originated. Format: XXX-XXXX.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of individual packages, boxes, or containers included in this shipment. Used for receiving verification and inventory reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference identifier or URI to the signed proof of delivery document (e.g., signature image, electronic confirmation). Used for dispute resolution and audit trail.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'Date the shipment departed from the origin facility. Used for Turnaround Time (TAT) calculation and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business-facing unique shipment identifier used for tracking and customer communication. Format: SHP-xxxxxxxxxx.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment. Values: booked (carrier confirmed), in_transit (en route), out_for_delivery (final mile), delivered (received by customer), exception (delay or issue), cancelled (shipment voided).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tatComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Tat Compliance Status' ;
    rdfs:comment 'Indicates whether the shipment met the customer-committed Turnaround Time (TAT) from order placement to delivery. Values: compliant (delivered within TAT), at_risk (approaching deadline), breached (missed TAT), not_applicable (no TAT commitment).' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureLogReference rdf:type rdf:Property ;
    rdfs:label 'Temperature Log Reference' ;
    rdfs:comment 'Reference identifier or URI to the detailed temperature monitoring log file (e.g., data logger serial number, cloud storage path). Used for compliance audit and quality investigation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum allowable temperature in degrees Celsius for cold-chain shipments. Null for non-temperature-controlled shipments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum allowable temperature in degrees Celsius for cold-chain shipments. Null for non-temperature-controlled shipments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric size of the shipment in cubic meters. Used for dimensional weight pricing and warehouse space planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total gross weight of the shipment in kilograms, including packaging materials. Used for freight cost calculation and carrier capacity planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Trade Compliance Check Id' ;
    rdfs:comment 'Unique identifier for the trade compliance check record. Primary key for the trade compliance check entity.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTradeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Employee Id' ;
    rdfs:comment 'Reference to the trade compliance officer who performed manual review or approval of this check. Populated when compliance_officer_review_flag is True.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Human-readable business identifier for the compliance check record. Format: TCC-YYYYMMDD followed by sequence number.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Check Validity End Date' ;
    rdfs:comment 'Date until which this compliance check remains valid. After this date, a new compliance check must be performed before shipment can proceed. Typically 30-90 days from screening date depending on risk profile.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Check Validity Start Date' ;
    rdfs:comment 'Date from which this compliance check is valid. Compliance checks have limited validity periods and must be refreshed if the order is delayed or circumstances change.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceOfficerReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Review Flag' ;
    rdfs:comment 'Indicates whether this compliance check requires or has received manual review by a trade compliance officer. True if manual review is required or completed; False if automated screening is sufficient.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current status of the trade compliance check. Cleared indicates approval for export; blocked indicates denial; pending-review requires manual review; conditional-approval requires additional documentation; escalated requires senior compliance officer review; expired indicates check validity has lapsed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Customer Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the customer destination. Used to determine export control jurisdiction and licensing requirements.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyListName rdf:type rdf:Property ;
    rdfs:label 'Denied Party List Name' ;
    rdfs:comment 'Name of the specific denied party list where a match was found (e.g., BIS Denied Persons List, BIS Entity List, OFAC SDN List). Populated only when denied_party_screening_result is fail or manual-review-required.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedPartyScreeningResult rdf:type rdf:Property ;
    rdfs:label 'Denied Party Screening Result' ;
    rdfs:comment 'Result of screening the customer and end-user against U.S. government denied parties lists including the Denied Persons List, Entity List, Unverified List, and Specially Designated Nationals. Pass indicates no match; fail indicates a match requiring transaction block; manual-review-required indicates potential match requiring compliance officer investigation.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualUseFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Use Flag' ;
    rdfs:comment 'Indicates whether the product being exported is classified as dual-use technology (items that have both commercial and military or proliferation applications). True for dual-use items requiring enhanced export control scrutiny.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eccn rdf:type rdf:Property ;
    rdfs:label 'Eccn' ;
    rdfs:comment 'Export Control Classification Number assigned to the product being exported. Alphanumeric code (e.g., 3A001.b) that identifies items subject to U.S. Department of Commerce export controls under the Commerce Control List.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endUseDeclaration rdf:type rdf:Property ;
    rdfs:label 'End Use Declaration' ;
    rdfs:comment 'Customer-provided statement describing the intended use of the genomic instruments, reagents, or data products. Required for dual-use technology assessment and export control classification.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itarControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Itar Controlled Flag' ;
    rdfs:comment 'Indicates whether the product is subject to ITAR controls administered by the U.S. Department of State Directorate of Defense Trade Controls. True if ITAR-controlled; False if subject only to EAR or no export controls.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExceptionCode rdf:type rdf:Property ;
    rdfs:label 'License Exception Code' ;
    rdfs:comment 'Three-letter code identifying the applicable license exception (e.g., ENC for encryption, TSU for technology and software unrestricted, RPL for servicing and replacement parts). Populated when no full export license is required but an exception applies.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Government-issued export license number authorizing the shipment. Populated when license_requirement_flag is True and a valid license has been obtained from the Bureau of Industry and Security or other regulatory authority.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'License Requirement Flag' ;
    rdfs:comment 'Indicates whether an export license is required for this transaction based on the product ECCN, destination country, and end-use. True if license required; False if license exception or no license required applies.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reference' ;
    rdfs:comment 'Reference number or identifier for any regulatory hold, investigation, or enforcement action related to this compliance check. Populated when the transaction is subject to ongoing regulatory scrutiny or voluntary self-disclosure.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numerical risk score (0.00 to 100.00) assigned by the screening system based on destination country, product sensitivity, customer profile, and end-use. Higher scores indicate elevated export control risk requiring enhanced due diligence.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routedExportTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Routed Export Transaction Flag' ;
    rdfs:comment 'Indicates whether this is a routed export transaction where a foreign principal party in interest (FPPI) authorizes a U.S. agent to facilitate export. True for routed exports requiring special documentation and compliance procedures.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date when the trade compliance screening was performed. Represents the business event date for the compliance check execution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningSystemName rdf:type rdf:Property ;
    rdfs:label 'Screening System Name' ;
    rdfs:comment 'Name and version of the automated trade compliance screening system used to perform the check (e.g., SAP Global Trade Services, Descartes Visual Compliance, Amber Road). Used for audit trail and system validation.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Precise timestamp when the automated screening system executed the compliance check. Used for audit trail and time-sensitive compliance validation.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentValueAmount rdf:type rdf:Property ;
    rdfs:label 'Shipment Value Amount' ;
    rdfs:comment 'Total commercial value of the goods being exported in the transaction currency. Used for export documentation, customs declaration, and license threshold determination.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ultimateConsigneeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ultimate Consignee Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the ultimate consignee location. May differ from customer_country_code if goods are transshipped or re-exported.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateConsigneeName rdf:type rdf:Property ;
    rdfs:label 'Ultimate Consignee Name' ;
    rdfs:comment 'Name of the ultimate end-user or consignee who will receive and use the exported goods. May differ from the bill-to customer. Required for denied party screening and end-use verification.' ;
    rdfs:domain ind:TradeComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryComponentProductSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Component Product Sku Id' ;
    rdfs:comment 'Reference to the component material, sub-assembly, reagent, consumable, or bundled SKU that is part of this BOM. Links to the product master record.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:tertiaryProductSubstituteComponentSkuId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Product Substitute Component Sku Id' ;
    rdfs:comment 'Reference to an alternative component that can be used in place of the primary component. Supports supply chain flexibility and risk mitigation.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assemblyInstruction rdf:type rdf:Property ;
    rdfs:label 'Assembly Instruction' ;
    rdfs:comment 'Textual description of how this component should be assembled, installed, or integrated into the parent product. May reference work instructions, SOPs, or engineering drawings.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Number' ;
    rdfs:comment 'Business identifier for the BOM. Human-readable unique code used in manufacturing, engineering, and supply chain systems.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomType rdf:type rdf:Property ;
    rdfs:label 'Bom Type' ;
    rdfs:comment 'Classification of the BOM purpose: production (manufacturing execution), engineering (design specification), costing (cost rollup), commercial-bundle (solution-selling package), service (field service parts), or planning (supply chain planning).' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Change Order Number' ;
    rdfs:comment 'Reference to the engineering change order (ECO) or change request that authorized this BOM version or component change. Critical for design control and audit trails.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coProductIndicator rdf:type rdf:Property ;
    rdfs:label 'Co Product Indicator' ;
    rdfs:comment 'Flag indicating whether this item is a co-product (additional output) rather than a component input. True if co-product, false if component.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentPosition rdf:type rdf:Property ;
    rdfs:label 'Component Position' ;
    rdfs:comment 'Sequential position or item number of this component within the BOM structure. Used for ordering and assembly instructions.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costRollupMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Rollup Method' ;
    rdfs:comment 'Costing methodology used to calculate the component cost contribution to the parent product: standard (predetermined cost), average (moving average), FIFO (first-in-first-out), LIFO (last-in-first-out), or actual (transaction-based).' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rules' ;
    rdfs:comment 'Business rules or conditions that determine when this component is included in the BOM. May reference customer segments, geographic regions, regulatory classifications, or product configurations.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalComponent rdf:type rdf:Property ;
    rdfs:label 'Is Critical Component' ;
    rdfs:comment 'Flag indicating whether this component is critical for product functionality, regulatory compliance, or supply chain risk. True if critical, false otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhantomAssembly rdf:type rdf:Property ;
    rdfs:label 'Is Phantom Assembly' ;
    rdfs:comment 'Flag indicating whether this component is a phantom (transient sub-assembly that is not stocked). True if phantom, false if physical inventory item.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Offset Days' ;
    rdfs:comment 'Number of days before the parent product start date that this component must be available. Used for backward scheduling in production planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotTraceabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Required' ;
    rdfs:comment 'Flag indicating whether lot-level traceability is required for this component per regulatory or quality requirements. True if lot tracking is mandatory, false otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationSequence rdf:type rdf:Property ;
    rdfs:label 'Operation Sequence' ;
    rdfs:comment 'Routing operation number at which this component is consumed. Links BOM items to production routing steps.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scrapFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Scrap Factor Percent' ;
    rdfs:comment 'Expected waste or loss percentage for this component during manufacturing. Used for material requirements planning (MRP) and cost rollup calculations.' ;
    rdfs:domain ind:ProductBom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomLineId rdf:type rdf:Property ;
    rdfs:label 'Bom Line Id' ;
    rdfs:comment 'Unique identifier for the BOM line item. Primary key for the BOM line entity.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomSkuId rdf:type rdf:Property ;
    rdfs:label 'Bom Sku Id' ;
    rdfs:comment 'FK to product.sku' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryBomSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Bom Sku Id' ;
    rdfs:comment 'Reference to the product master record for the component material, sub-assembly, reagent, consumable, or service item required in this BOM line.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:alternativeItemGroup rdf:type rdf:Property ;
    rdfs:label 'Alternative Item Group' ;
    rdfs:comment 'Identifier for a group of interchangeable components that can substitute for one another in the BOM. Enables flexible sourcing and component substitution management during production or supply shortages.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOM line: active (in production use), inactive (temporarily disabled), pending_approval (awaiting engineering or quality approval), obsolete (phased out, retained for historical reference).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRole rdf:type rdf:Property ;
    rdfs:label 'Component Role' ;
    rdfs:comment 'Functional role of the component within a commercial bundle or product offering. Used for revenue allocation, customer communication, and bundle composition analysis. [ENUM-REF-CANDIDATE: primary_instrument|reagent|consumable|software|accessory|service|documentation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Component Flag' ;
    rdfs:comment 'Indicates whether this component is critical to product performance, safety, or regulatory compliance. Critical components require enhanced quality control, supplier qualification, and change control procedures.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Expiry Control Required Flag' ;
    rdfs:comment 'Indicates whether expiration date tracking is required for this component. Essential for reagents, biological materials, and consumables with limited shelf life.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Control Required Flag' ;
    rdfs:comment 'Indicates whether lot number tracking is required for this component. Critical for reagents, consumables, and materials subject to GMP, traceability, and recall management.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this component is mandatory for the finished product or optional. Optional components may be included based on customer configuration or production variant.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceDesignator rdf:type rdf:Property ;
    rdfs:label 'Reference Designator' ;
    rdfs:comment 'Alphanumeric code identifying the physical location or position of the component in the assembly (e.g., R1, C5, U3 for electronics; position codes for mechanical assemblies). Used in assembly drawings and work instructions.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Required Quantity' ;
    rdfs:comment 'The quantity of the component required to produce one unit of the parent finished good or assembly. Supports fractional quantities for reagents and consumables.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Allocation Percentage' ;
    rdfs:comment 'Percentage of the total bundle or product revenue allocated to this component. Used for revenue recognition, performance obligations under ASC 606, and component-level profitability analysis in commercial bundles.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumberControlFlag rdf:type rdf:Property ;
    rdfs:label 'Serial Number Control Flag' ;
    rdfs:comment 'Indicates whether serial number tracking is required for this component. Typically applies to high-value instruments, critical sub-assemblies, and items requiring individual traceability.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:substitutionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Eligible Flag' ;
    rdfs:comment 'Indicates whether this component can be substituted with an alternative item from the same alternative item group during production or order fulfillment.' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyType rdf:type rdf:Property ;
    rdfs:label 'Supply Type' ;
    rdfs:comment 'Source of the component: in_house (manufactured internally), external (purchased from vendor), subcontract (manufactured by third party to our spec), customer_supplied (provided by customer for custom orders).' ;
    rdfs:domain ind:BomLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGenomeAssemblyId rdf:type rdf:Property ;
    rdfs:label 'Primary Genome Assembly Id' ;
    rdfs:comment 'Foreign key linking to reference.genome_assembly. Business justification: Sequencing kits, arrays, and analysis software are designed and validated for specific reference genomes (hg38, GRCh37, mm10). Required for product specifications, regulatory submissions (FDA 510k, IV' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomeAssembly .

ind:primaryVariantDatabaseId rdf:type rdf:Property ;
    rdfs:label 'Primary Variant Database Id' ;
    rdfs:comment 'Foreign key linking to reference.variant_database. Business justification: Clinical interpretation products and variant calling pipelines are validated against specific variant databases (ClinVar, gnomAD, COSMIC). Critical for IVD regulatory clearances, clinical validation s' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantDatabase .

ind:averageSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Average Selling Price' ;
    rdfs:comment 'Average price at which the product is sold across all channels and customer segments. Used for revenue forecasting, pricing strategy, and competitive analysis. Expressed in USD.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bomReference rdf:type rdf:Property ;
    rdfs:label 'Bom Reference' ;
    rdfs:comment 'Reference identifier linking to the Bill of Materials in the manufacturing system (SAP PP) defining component parts and assembly instructions. Applicable primarily to instruments and kits.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Bundle Discount Percentage' ;
    rdfs:comment 'Percentage discount applied when products are purchased as part of a bundle versus individual purchase. Nullable for non-bundle items. Used for bundle pricing calculations.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility Rules' ;
    rdfs:comment 'Business rules defining which customer segments, regions, or purchase conditions qualify for bundle pricing. Nullable for non-bundle items.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentPlatformCompatibility rdf:type rdf:Property ;
    rdfs:label 'Instrument Platform Compatibility' ;
    rdfs:comment 'List of instrument platforms with which this reagent, consumable, or software is compatible. Applicable to reagents, flow cells, and bioinformatics software. Null for instruments and services.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBundle rdf:type rdf:Property ;
    rdfs:label 'Is Bundle' ;
    rdfs:comment 'Indicates whether this catalog item is a bundle of multiple products sold together as a package. True for bundles, False for individual products.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the product lifecycle from initial concept through end-of-life. Drives business decisions on investment, marketing, manufacturing, and support. [ENUM-REF-CANDIDATE: concept|development|validation|launch|growth|maturity|decline|end_of_life — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingTagline rdf:type rdf:Property ;
    rdfs:label 'Marketing Tagline' ;
    rdfs:comment 'Brief marketing message or slogan associated with the product for promotional campaigns and brand positioning.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Comprehensive description of the product including technical specifications, intended use, key features, and benefits. Used for catalog documentation and customer communication.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productUrl rdf:type rdf:Property ;
    rdfs:label 'Product Url' ;
    rdfs:comment 'Web address linking to the product detail page on the company website or customer portal for additional information and specifications.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Indicates whether the product requires temperature-controlled logistics (cold chain) during shipping and storage. True for temperature-sensitive reagents and biological materials.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated product name for use in constrained display contexts such as mobile interfaces, reports, and order forms.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Unique alphanumeric code identifying the commercial product offering. The canonical business identifier used across all systems for product identification, ordering, and inventory management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareLicenseType rdf:type rdf:Property ;
    rdfs:label 'Software License Type' ;
    rdfs:comment 'Type of software licensing model for bioinformatics and analysis software products. Defines usage rights, renewal requirements, and pricing structure. Null for non-software products.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max Celsius' ;
    rdfs:comment 'Maximum temperature in Celsius allowed for proper product storage. Critical for reagents and biological materials. Null for products without temperature requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min Celsius' ;
    rdfs:comment 'Minimum temperature in Celsius required for proper product storage. Critical for reagents and biological materials. Null for products without temperature requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compatibilityMatrixId rdf:type rdf:Property ;
    rdfs:label 'Compatibility Matrix Id' ;
    rdfs:comment 'Unique identifier for the compatibility matrix record. Primary key.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCompatibilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compatibility Employee Id' ;
    rdfs:comment 'Reference to the user who approved this compatibility relationship. Typically a product manager, quality assurance manager, or regulatory affairs specialist.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceSkuId rdf:type rdf:Property ;
    rdfs:label 'Source Sku Id' ;
    rdfs:comment 'Reference to the source catalog item or SKU in the compatibility relationship. The item for which compatibility is being defined.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supersededByCompatibilityMatrixId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Compatibility Matrix Id' ;
    rdfs:comment 'Reference to the compatibility matrix record that supersedes this relationship. Used to maintain historical lineage when compatibility relationships are updated or replaced.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompatibilityMatrix .

ind:targetSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Sku Id' ;
    rdfs:comment 'Reference to the target catalog item or SKU in the compatibility relationship. The item that is compatible with or substitutes for the source item.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:tertiaryCompatibilityLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compatibility Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this compatibility matrix record.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bioinformaticsPipelineCompatibility rdf:type rdf:Property ;
    rdfs:label 'Bioinformatics Pipeline Compatibility' ;
    rdfs:comment 'Describes compatibility with bioinformatics analysis pipelines and software versions. Specifies which pipeline versions, output formats (FASTQ, BAM, VCF), and analysis workflows are supported for this compatibility relationship.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibilityConditions rdf:type rdf:Property ;
    rdfs:label 'Compatibility Conditions' ;
    rdfs:comment 'Detailed conditions, restrictions, or prerequisites that must be met for this compatibility relationship to be valid. Examples: specific run configurations, temperature ranges, sample types, workflow protocols, or instrument calibration requirements.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionality rdf:type rdf:Property ;
    rdfs:label 'Directionality' ;
    rdfs:comment 'Indicates whether the compatibility relationship is one-way (source to target only) or bidirectional (mutual compatibility). Critical for order validation logic and substitution workflows.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldApplicationNotes rdf:type rdf:Property ;
    rdfs:label 'Field Application Notes' ;
    rdfs:comment 'Technical guidance and recommendations for field application scientists and customer support teams regarding this compatibility relationship. May include protocol adjustments, troubleshooting tips, or customer communication templates.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCellCompatibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Compatibility Notes' ;
    rdfs:comment 'Specific notes regarding flow cell type compatibility, run configuration requirements, multiplexing limitations, and demultiplexing considerations for Next-Generation Sequencing (NGS) applications.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCompatibilityScope rdf:type rdf:Property ;
    rdfs:label 'Instrument Compatibility Scope' ;
    rdfs:comment 'Defines the scope of instrument models, serial number ranges, or firmware versions for which this compatibility relationship is validated. Critical for sequencing platform and array scanner compatibility.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPreparationCompatibility rdf:type rdf:Property ;
    rdfs:label 'Library Preparation Compatibility' ;
    rdfs:comment 'Describes compatibility with library preparation kits, protocols, and workflows. Includes information on adapter compatibility, index compatibility, and protocol modifications required.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTraceabilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Impact Flag' ;
    rdfs:comment 'Indicates whether this compatibility relationship has implications for lot traceability and Certificate of Analysis (COA) requirements. True indicates additional traceability documentation required; false indicates standard traceability applies.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Impact Description' ;
    rdfs:comment 'Description of any performance differences, quality impacts, or operational considerations when using the target item with the source item. Examples: read length differences, coverage depth variations, Phred score impacts, Turnaround Time (TAT) changes, cost implications.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDifferentialPercent rdf:type rdf:Property ;
    rdfs:label 'Price Differential Percent' ;
    rdfs:comment 'Percentage price difference between target and source items. Positive values indicate target is more expensive; negative values indicate target is less expensive. Used for customer communication and order adjustment workflows.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Control Requirements' ;
    rdfs:comment 'Additional quality control or quality assurance requirements that must be met when using this compatibility relationship. Examples: additional QC metrics, control samples, calibration procedures, or Standard Operating Procedure (SOP) references.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceVersionMax rdf:type rdf:Property ;
    rdfs:label 'Source Version Max' ;
    rdfs:comment 'Maximum version or revision of the source item for which this compatibility relationship applies. Null indicates no upper version limit.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceVersionMin rdf:type rdf:Property ;
    rdfs:label 'Source Version Min' ;
    rdfs:comment 'Minimum version or revision of the source item for which this compatibility relationship applies. Used for software, firmware, and versioned hardware components.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionPriority rdf:type rdf:Property ;
    rdfs:label 'Substitution Priority' ;
    rdfs:comment 'Numeric priority ranking for substitute items when multiple substitutes are available. Lower numbers indicate higher priority. Used in backorder resolution and inventory allocation workflows.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetVersionMax rdf:type rdf:Property ;
    rdfs:label 'Target Version Max' ;
    rdfs:comment 'Maximum version or revision of the target item for which this compatibility relationship applies. Null indicates no upper version limit.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetVersionMin rdf:type rdf:Property ;
    rdfs:label 'Target Version Min' ;
    rdfs:comment 'Minimum version or revision of the target item for which this compatibility relationship applies. Used for software, firmware, and versioned hardware components.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Validation Evidence Reference' ;
    rdfs:comment 'Reference identifier to the validation study, test report, or documentation that supports this compatibility relationship. May reference analytical validation study ID, technical bulletin number, or quality management system document.' ;
    rdfs:domain ind:CompatibilityMatrix ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eolPlanId rdf:type rdf:Property ;
    rdfs:label 'Eol Plan Id' ;
    rdfs:comment 'Unique identifier for the end-of-life plan record. Primary key.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Affected Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: EOL inventory disposition requires identifying affected materials (raw materials, components, finished goods) for write-off, liquidation, or transition planning. Finance and operations need material-l' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:primaryEolCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Eol Catalog Item Id' ;
    rdfs:comment 'Reference to the catalog item (product, instrument, reagent kit, consumable, software license, or service) being discontinued under this EOL plan.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:primaryEolEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Eol Employee Id' ;
    rdfs:comment 'Reference to the product manager responsible for overseeing the EOL plan execution and stakeholder coordination.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryEolLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Eol Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the EOL plan record.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryNotificationSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: End-of-life plans for regulated genomics products (sequencers, IVD kits, diagnostic assays) require regulatory notifications/submissions to FDA/competent authorities. The eol_plan.regulatory_submissio' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:replacementRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Replacement Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: End-of-life planning evaluates whether replacement products are in R&D pipeline. Product managers link EOL plans to active projects to coordinate customer transition timing, inventory planning, and co' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:stabilityStudyId rdf:type rdf:Property ;
    rdfs:label 'Stability Study Id' ;
    rdfs:comment 'Foreign key linking to quality.stability_study. Business justification: End-of-life decisions may be driven by inability to maintain stability specifications or expiration of stability data supporting shelf life claims. Links EOL plan to stability study justifying discont' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StabilityStudy .

ind:tertiaryEolCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Eol Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the EOL plan record.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeServiceContractCount rdf:type rdf:Property ;
    rdfs:label 'Active Service Contract Count' ;
    rdfs:comment 'Number of active service agreements, maintenance contracts, or SLAs associated with the discontinued product that must be honored or renegotiated.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedCustomerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Count' ;
    rdfs:comment 'Number of active customers who have purchased or are currently using the discontinued product, requiring notification and transition support.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationEmbargoDate rdf:type rdf:Property ;
    rdfs:label 'Communication Embargo Date' ;
    rdfs:comment 'Date before which the EOL plan must remain confidential and not be communicated externally. Used to coordinate internal preparation before public announcement.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitorNotificationRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Notification Risk Flag' ;
    rdfs:comment 'Indicates whether early disclosure of the EOL plan poses a competitive risk (e.g., competitors may target affected customers). Influences communication timing and strategy.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationPlan rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Plan' ;
    rdfs:comment 'Structured plan for communicating the EOL to customers, including notification channels (email, portal, field sales), timing, message templates, and escalation procedures for high-value accounts.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Years' ;
    rdfs:comment 'Number of years that product-related data, documentation, and records must be retained after discontinuation to meet regulatory, legal, and audit requirements (typically 7-10 years for IVD products).' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'Primary business reason for discontinuing the product: technology superseded (newer platform available), low demand (insufficient market), regulatory change (compliance issue), strategic portfolio rationalization (business focus shift), manufacturing obsolescence (production capability retired), component unavailability (supply chain constraint).' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason Detail' ;
    rdfs:comment 'Detailed explanation of the discontinuation reason, including business context, market conditions, technical factors, or regulatory drivers that led to the EOL decision.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationArchiveLocation rdf:type rdf:Property ;
    rdfs:label 'Documentation Archive Location' ;
    rdfs:comment 'Reference to the archive location (document management system path, repository URL) where product documentation, user manuals, technical specifications, and regulatory files will be retained for compliance and historical reference.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eolAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Eol Announcement Date' ;
    rdfs:comment 'Date when the EOL plan is officially announced to customers, partners, and internal stakeholders. Marks the beginning of the transition period.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eolPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Eol Plan Number' ;
    rdfs:comment 'Business identifier for the EOL plan, used for tracking and communication with stakeholders (e.g., EOL-2024001).' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eolStatus rdf:type rdf:Property ;
    rdfs:label 'Eol Status' ;
    rdfs:comment 'Current lifecycle status of the EOL plan: draft (under development), approved (management sign-off), announced (communicated to customers), active (in execution), completed (all dates passed), cancelled (plan withdrawn).' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpSystemDeactivationDate rdf:type rdf:Property ;
    rdfs:label 'Erp System Deactivation Date' ;
    rdfs:comment 'Date when the product SKU is deactivated or marked as discontinued in the ERP system (SAP S/4HANA), preventing new sales orders and purchase requisitions.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldSalesBriefingDate rdf:type rdf:Property ;
    rdfs:label 'Field Sales Briefing Date' ;
    rdfs:comment 'Date when field sales teams and customer-facing personnel are briefed on the EOL plan, enabling them to proactively address customer questions and concerns.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate Usd' ;
    rdfs:comment 'Estimated financial impact of the product discontinuation in US dollars, including revenue loss, inventory write-offs, transition costs, and potential customer retention investments.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryDispositionPlan rdf:type rdf:Property ;
    rdfs:label 'Inventory Disposition Plan' ;
    rdfs:comment 'Plan for managing remaining inventory of the discontinued product, including sell-through strategy, return policies, disposal procedures for expired stock, and write-off accounting treatment.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Ship Date' ;
    rdfs:comment 'Final date by which the product will be shipped to customers. Typically follows the last order date to allow for order fulfillment.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSupportDate rdf:type rdf:Property ;
    rdfs:label 'Last Support Date' ;
    rdfs:comment 'Final date by which technical support, warranty service, and customer assistance will be provided for the discontinued product. After this date, no support is available.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingStopDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Stop Date' ;
    rdfs:comment 'Date when production of the discontinued product will cease. Typically precedes the last ship date to allow for inventory depletion.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Partner Notification Date' ;
    rdfs:comment 'Date when distribution partners, OEMs, and channel partners are formally notified of the product discontinuation, allowing them to adjust their sales and support strategies.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productRegulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Product Regulatory Classification' ;
    rdfs:comment 'Regulatory classification of the discontinued product: RUO (Research Use Only), IVD (In Vitro Diagnostic), CE-IVD (European IVD), LDT (Laboratory Developed Test), or FDA device class (I, II, III). Determines regulatory notification requirements. [ENUM-REF-CANDIDATE: RUO|IVD|CE-IVD|LDT|Class_I|Class_II|Class_III — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySystemImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Quality System Impact Assessment' ;
    rdfs:comment 'Assessment of the impact of the product discontinuation on the Quality Management System (QMS), including document control, training records, validation studies, and audit trails that must be retained per ISO 13485 and GxP requirements.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sparePartsAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Availability Date' ;
    rdfs:comment 'Final date by which spare parts, consumables, or accessories for the discontinued product will be available for purchase. Relevant for instruments and hardware platforms.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionSupportOffering rdf:type rdf:Property ;
    rdfs:label 'Transition Support Offering' ;
    rdfs:comment 'Description of support services offered to customers during the transition period, such as migration assistance, training on replacement products, data transfer services, or extended warranty options.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Website Update Date' ;
    rdfs:comment 'Date when the company website, product catalog, and online ordering systems are updated to reflect the EOL status and remove or flag the discontinued product.' ;
    rdfs:domain ind:EolPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchPlanId rdf:type rdf:Property ;
    rdfs:label 'Launch Plan Id' ;
    rdfs:comment 'Unique identifier for the commercial launch plan record. Primary key for the launch plan entity.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLaunchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Launch Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for overall launch execution and cross-functional coordination. Typically a product manager or commercial operations lead.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:targetGenomeAssemblyId rdf:type rdf:Property ;
    rdfs:label 'Target Genome Assembly Id' ;
    rdfs:comment 'Foreign key linking to reference.genome_assembly. Business justification: Product launches must specify target genome build(s) for go-to-market positioning and competitive differentiation (e.g., first-to-market with T2T-CHM13 support). Drives marketing messaging, field trai' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomeAssembly .

ind:tertiaryLaunchLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Launch Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this launch plan record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'Actual date when the product became commercially available. Null until launch occurs. Used for performance tracking and post-launch analysis.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commercialOpsSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Commercial Ops Signoff Date' ;
    rdfs:comment 'Date when commercial operations approved launch readiness. Null until approval obtained. Final gate before launch execution.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commercialOpsSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Commercial Ops Signoff Status' ;
    rdfs:comment 'Status of commercial operations readiness approval covering sales enablement, marketing materials, pricing, order management, and distribution: pending (review not complete), approved (ready to launch), rejected (gaps identified), conditional (approved with mitigation plans). Final launch readiness gate.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic positioning statement describing how this product differentiates from competitor offerings (e.g., \'First CRISPR tool with 99.9% specificity\', \'Lowest cost per genome WGS platform\'). Informs marketing messaging and sales strategy.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossSellProducts rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Products' ;
    rdfs:comment 'Comma-separated list of product IDs for complementary products to be promoted alongside this launch (e.g., reagent kits for new sequencer, analysis software for array platform). Used for bundling and sales strategy.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldApplicationTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Field Application Training Completion Date' ;
    rdfs:comment 'Date when field application scientist training was completed and team certified to support customers. Null until training complete. Launch readiness gate.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldApplicationTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Field Application Training Status' ;
    rdfs:comment 'Status of field application scientist training and certification for product support: not_started (training not begun), in_progress (training underway), completed (training done), certified (competency verified), at_risk (insufficient coverage). Launch readiness gate for customer-facing technical support.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstOrderActualDate rdf:type rdf:Property ;
    rdfs:label 'First Order Actual Date' ;
    rdfs:comment 'Actual date when the first customer order was received post-launch. Null until first order occurs. Key launch success metric.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstOrderTargetDate rdf:type rdf:Property ;
    rdfs:label 'First Order Target Date' ;
    rdfs:comment 'Target date for receiving the first customer order post-launch. Used for sales pipeline planning and launch success measurement.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstShipmentActualDate rdf:type rdf:Property ;
    rdfs:label 'First Shipment Actual Date' ;
    rdfs:comment 'Actual date when first product was shipped to customer. Null until first shipment occurs. Key operational launch metric.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstShipmentTargetDate rdf:type rdf:Property ;
    rdfs:label 'First Shipment Target Date' ;
    rdfs:comment 'Target date for first product shipment to customer. Used for supply chain and logistics planning.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyValuePropositions rdf:type rdf:Property ;
    rdfs:label 'Key Value Propositions' ;
    rdfs:comment 'Comma-separated list of primary customer value propositions for this launch (e.g., \'reduced TAT\', \'improved accuracy\', \'lower COGS\', \'regulatory compliance\'). Used for sales enablement and marketing.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchActualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Launch Actual Spend Usd' ;
    rdfs:comment 'Actual spend to date in USD for launch activities. Updated throughout launch execution. Used for budget variance tracking and post-launch financial analysis.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Launch Announcement Date' ;
    rdfs:comment 'Date of public announcement or press release for the product launch. May precede actual commercial availability. Used for marketing and investor relations.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:launchBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Launch Budget Usd' ;
    rdfs:comment 'Total approved budget in USD for launch activities including marketing, training, events, promotional materials, and launch support. Used for financial planning and ROI analysis.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchPlanName rdf:type rdf:Property ;
    rdfs:label 'Launch Plan Name' ;
    rdfs:comment 'Human-readable name of the launch plan, typically including product name and launch wave identifier (e.g., \'NovaSeq X Plus Global Launch Q2 2024\').' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Launch Plan Number' ;
    rdfs:comment 'Externally-known business identifier for the launch plan, formatted as LP-NNNNNN. Used for cross-functional communication and tracking.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchReadinessScore rdf:type rdf:Property ;
    rdfs:label 'Launch Readiness Score' ;
    rdfs:comment 'Composite readiness score (0.00 to 100.00) calculated from weighted checklist completion across regulatory, manufacturing, training, and commercial operations dimensions. Used for go/no-go decision making.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:launchRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Launch Risk Assessment' ;
    rdfs:comment 'Summary of identified launch risks and mitigation strategies covering regulatory delays, supply constraints, competitive threats, and market adoption challenges. Updated throughout launch planning and execution.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchStatus rdf:type rdf:Property ;
    rdfs:label 'Launch Status' ;
    rdfs:comment 'Current lifecycle status of the launch plan: planning (initial development), readiness_review (cross-functional assessment), approved (go decision made), in_progress (execution underway), launched (product available), completed (post-launch review done), cancelled (plan terminated), on_hold (temporarily paused). [ENUM-REF-CANDIDATE: planning|readiness_review|approved|in_progress|launched|completed|cancelled|on_hold — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchType rdf:type rdf:Property ;
    rdfs:label 'Launch Type' ;
    rdfs:comment 'Classification of the launch strategy: global (worldwide availability), regional (specific geographies), limited_release (select customers), controlled_launch (phased rollout), soft_launch (pre-announcement availability), or pilot (evaluation phase).' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingReadinessDate rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Readiness Date' ;
    rdfs:comment 'Date when manufacturing was confirmed ready to support launch demand. Null until readiness achieved. Used for launch timing decisions.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturingReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Readiness Status' ;
    rdfs:comment 'Status of manufacturing capability to support launch volumes: not_started (planning phase), in_progress (scale-up underway), validation_complete (process validation done per GMP), production_ready (capacity confirmed), at_risk (supply constraints identified). Launch readiness gate.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Target date for commercial availability of the product. Established during launch planning and used for cross-functional coordination.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postLaunchReviewDate rdf:type rdf:Property ;
    rdfs:label 'Post Launch Review Date' ;
    rdfs:comment 'Date when post-launch review was conducted to assess launch success, capture lessons learned, and identify improvement opportunities. Typically 90-180 days post-launch.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postLaunchReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Post Launch Review Outcome' ;
    rdfs:comment 'Overall assessment from post-launch review: exceeded_expectations (outperformed targets), met_expectations (achieved targets), partially_met (some targets missed), below_expectations (significant gaps), not_reviewed (review not yet conducted).' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clearance Date' ;
    rdfs:comment 'Date when regulatory approval was obtained for the primary target market. Null if not required or not yet approved. Critical milestone for IVD and CE-IVD products.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clearance Status' ;
    rdfs:comment 'Status of required regulatory approvals for target markets: not_required (RUO products), pending (submission planned), in_review (under agency review), approved (clearance obtained), conditional_approval (approved with restrictions), denied (clearance rejected). Launch readiness gate.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segments' ;
    rdfs:comment 'Comma-separated list of primary customer segments targeted for this launch: research (academic/government labs), clinical (diagnostic labs/hospitals), biopharma (drug development), agricultural (crop/livestock genomics), consumer (direct-to-consumer). Informs marketing and sales strategy.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeographies rdf:type rdf:Property ;
    rdfs:label 'Target Geographies' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the geographic markets included in this launch (e.g., \'USA,GBR,DEU,JPN\'). Drives regulatory, supply chain, and commercial operations planning.' ;
    rdfs:domain ind:LaunchPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationMechanism rdf:type rdf:Property ;
    rdfs:label 'Activation Mechanism' ;
    rdfs:comment 'Method by which the customer activates the license: online (internet-based activation server), offline (manual activation file), token-based (API token exchange), hardware dongle (USB security key), or cloud-native (no activation required for SaaS).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiCallLimit rdf:type rdf:Property ;
    rdfs:label 'Api Call Limit' ;
    rdfs:comment 'Maximum number of API (Application Programming Interface) calls allowed per billing period for cloud-based software services. Null indicates unlimited API access. Critical for BaseSpace Sequence Hub and bioinformatics platform integrations.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceAuditRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Requirement' ;
    rdfs:comment 'Frequency and method of license compliance audits: none (no audit rights), annual (yearly audit), quarterly (every 3 months), on-demand (vendor-initiated), or continuous telemetry (automated usage reporting).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingLimitGb rdf:type rdf:Property ;
    rdfs:label 'Data Processing Limit Gb' ;
    rdfs:comment 'Maximum amount of genomic data (in gigabytes) that can be processed under this license entitlement per billing period. Common for cloud-based bioinformatics pipelines and BaseSpace subscriptions. Null indicates unlimited processing.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entitlementCode rdf:type rdf:Property ;
    rdfs:label 'Entitlement Code' ;
    rdfs:comment 'Unique business identifier for this license entitlement template, used in sales orders, quotes, and customer communications.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementDescription rdf:type rdf:Property ;
    rdfs:label 'Entitlement Description' ;
    rdfs:comment 'Detailed description of the usage rights, technical constraints, and business terms granted by this license entitlement template.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Entitlement Duration Months' ;
    rdfs:comment 'Duration of the license entitlement in months. Null or zero indicates perpetual license with no expiration. Common values: 12 (annual), 36 (three-year), 60 (five-year).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Human-readable name of the license entitlement template, such as \'DRAGEN Enterprise Annual Subscription\' or \'BaseSpace Pro Node-Locked License\'.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliance Required' ;
    rdfs:comment 'Indicates whether this license entitlement requires GDPR (General Data Protection Regulation) compliance controls for processing personal data of EU residents. True for software handling human genomic data in EU jurisdictions.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicUsageRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Usage Restriction' ;
    rdfs:comment 'Geographic regions where the license is valid, specified as comma-separated ISO 3166-1 alpha-3 country codes (e.g., \'USA,CAN,GBR\') or region codes. Null indicates worldwide usage rights. Critical for export control compliance (EAR, ITAR).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Hipaa Compliance Required' ;
    rdfs:comment 'Indicates whether this license entitlement requires HIPAA (Health Insurance Portability and Accountability Act) compliance controls for handling PHI (Protected Health Information). True for clinical diagnostic software; False for research-only tools.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPerpetual rdf:type rdf:Property ;
    rdfs:label 'Is Perpetual' ;
    rdfs:comment 'Indicates whether this is a perpetual license (True) with indefinite usage rights, or a term-based license (False) that expires after the entitlement duration.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseKeyGenerationMethod rdf:type rdf:Property ;
    rdfs:label 'License Key Generation Method' ;
    rdfs:comment 'Method used to generate license keys or activation tokens for this entitlement: manual (generated by support team), automated API (system-generated), token-based (JWT or OAuth tokens), hardware fingerprint (tied to device ID), or cloud entitlement (managed by cloud platform).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle status of the license entitlement template. Active templates are available for new sales; deprecated templates are phased out; retired templates are no longer offered.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of license deployment model: node-locked (tied to specific hardware), floating (shared pool), site (unlimited within location), cloud (cloud-hosted), SaaS subscription (software-as-a-service), or perpetual (one-time purchase with indefinite use).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensedFeatureSet rdf:type rdf:Property ;
    rdfs:label 'Licensed Feature Set' ;
    rdfs:comment 'Comma-separated list of software features and modules included in this entitlement, such as \'DRAGEN alignment, variant calling, tumor-normal analysis, RNA-Seq, methylation analysis\'. Defines functional scope of the license.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Maintenance Included' ;
    rdfs:comment 'Indicates whether software maintenance (bug fixes, security patches, minor updates) is included in the license entitlement (True) or requires separate purchase (False).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxComputeNodes rdf:type rdf:Property ;
    rdfs:label 'Max Compute Nodes' ;
    rdfs:comment 'Maximum number of compute nodes (servers, HPC (High-Performance Computing) nodes, or cloud instances) on which the software can be deployed. Critical for bioinformatics pipeline scaling. Null indicates unlimited nodes.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxConcurrentUsers rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Users' ;
    rdfs:comment 'Maximum number of users who can simultaneously access the software under this license entitlement. Null indicates unlimited concurrent access.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleThroughputLimit rdf:type rdf:Property ;
    rdfs:label 'Sample Throughput Limit' ;
    rdfs:comment 'Maximum number of samples that can be processed under this license entitlement per billing period. Relevant for clinical assay software and LIMS (Laboratory Information Management System) integrations. Null indicates unlimited sample processing.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageQuotaGb rdf:type rdf:Property ;
    rdfs:label 'Storage Quota Gb' ;
    rdfs:comment 'Maximum cloud storage capacity (in gigabytes) included with this license entitlement for storing sequencing data, analysis results, and project files. Null indicates unlimited storage or storage not included.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sublicensingAllowed rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Allowed' ;
    rdfs:comment 'Indicates whether the customer is permitted to sublicense the software to third parties (True) or must use it exclusively for their own operations (False). Critical for service bureau and contract research organization (CRO) business models.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'Level of technical support included with this license entitlement: basic (email support, business hours), standard (phone and email, extended hours), premium (24/7 support, dedicated engineer), enterprise (named account team, SLA (Service Level Agreement) guarantees), or none (no support included).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemetryReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Telemetry Reporting Enabled' ;
    rdfs:comment 'Indicates whether the software automatically reports usage telemetry back to the vendor for license compliance monitoring and product analytics. True enables automated usage tracking; False requires manual compliance reporting.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingEntitlement rdf:type rdf:Property ;
    rdfs:label 'Training Entitlement' ;
    rdfs:comment 'Description of training services included with this license, such as \'two on-site training sessions\', \'unlimited online training portal access\', or \'annual certification workshop\'. Null if no training is included.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRestriction rdf:type rdf:Property ;
    rdfs:label 'Transfer Restriction' ;
    rdfs:comment 'Policy governing whether the license can be transferred to another legal entity or organizational unit: non-transferable (locked to original purchaser), transferable with approval (requires vendor consent), or freely transferable (no restrictions).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeEligibility rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility' ;
    rdfs:comment 'Defines which software upgrades the customer is entitled to receive: full upgrade (all major and minor versions), minor version only (patches and minor releases), no upgrade (locked to purchased version), maintenance only (bug fixes), or feature add-on (specific feature unlocks).' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestrictionTerms rdf:type rdf:Property ;
    rdfs:label 'Usage Restriction Terms' ;
    rdfs:comment 'Additional usage restrictions beyond geography, such as \'RUO (Research Use Only) - not for clinical diagnostics\', \'internal use only - no service bureau\', \'academic institution only\', or \'non-commercial research only\'. Critical for regulatory compliance.' ;
    rdfs:domain ind:LicenseEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Unique identifier for the pricing record. Primary key.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:asp rdf:type rdf:Property ;
    rdfs:label 'Asp' ;
    rdfs:comment 'Average Selling Price realized across all transactions for this SKU in the specified period and region. Used for revenue forecasting, margin analysis, and competitive benchmarking. Confidential business metric.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'Cost of Goods Sold (COGS) per unit. Used for margin calculation and profitability analysis. Confidential financial data.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'Gross margin percentage calculated as (unit_price - cost_price) / unit_price. Used for profitability analysis and pricing strategy optimization. Confidential financial metric.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the commercial operations team member responsible for maintaining this pricing record. Primary contact for pricing inquiries and updates.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListVersion rdf:type rdf:Property ;
    rdfs:label 'Price List Version' ;
    rdfs:comment 'Version identifier of the price list or pricing schedule that contains this record. Used to manage pricing history and track price list updates.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing record: list (standard catalog price), contract (customer-specific negotiated), distributor (channel partner pricing), OEM (original equipment manufacturer pricing), government (public sector pricing), transfer (intercompany pricing), promotional (temporary campaign pricing). [ENUM-REF-CANDIDATE: list|contract|distributor|oem|government|transfer|promotional — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Unique code identifying the promotional campaign associated with this pricing. Null for non-promotional pricing. Used for campaign tracking and ROI analysis.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this pricing is part of a temporary promotional campaign (True) or standard pricing (False). Used to track promotional effectiveness and revenue impact.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code where this pricing applies (e.g., USA, GBR, DEU, CHN, JPN). Supports regional pricing strategies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPrice rdf:type rdf:Property ;
    rdfs:label 'Transfer Price' ;
    rdfs:comment 'Intercompany transfer price used for transactions between legal entities or business units. Used for internal cost allocation and tax compliance. Confidential.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier1Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Price' ;
    rdfs:comment 'Unit price applicable when order quantity meets or exceeds volume_tier_1_quantity. Null if no volume pricing applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier1Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Quantity' ;
    rdfs:comment 'Minimum quantity threshold for the first volume discount tier. Null if no volume pricing applies.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier2Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Price' ;
    rdfs:comment 'Unit price applicable when order quantity meets or exceeds volume_tier_2_quantity. Null if tier does not exist.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier2Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Quantity' ;
    rdfs:comment 'Minimum quantity threshold for the second volume discount tier. Null if tier does not exist.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier3Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 3 Price' ;
    rdfs:comment 'Unit price applicable when order quantity meets or exceeds volume_tier_3_quantity. Null if tier does not exist.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier3Quantity rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 3 Quantity' ;
    rdfs:comment 'Minimum quantity threshold for the third volume discount tier. Null if tier does not exist.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeNoticeId rdf:type rdf:Property ;
    rdfs:label 'Change Notice Id' ;
    rdfs:comment 'Unique identifier for the product change notice record. Primary key.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedProductFamilies rdf:type rdf:Property ;
    rdfs:label 'Affected Product Families' ;
    rdfs:comment 'Comma-separated list of product family codes impacted by this change, enabling portfolio-level impact analysis and customer communication planning.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalChain rdf:type rdf:Property ;
    rdfs:label 'Approval Chain' ;
    rdfs:comment 'Comma-separated list of approvers and their roles who authorized this change, in sequence. Typically includes Engineering, Quality, Regulatory, and Management approvals as required by change control procedures.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Risk-based categorization of the change: major (significant impact on form, fit, function, or regulatory status), minor (limited impact with no regulatory implications), or administrative (documentation-only change with no product impact).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTitle rdf:type rdf:Property ;
    rdfs:label 'Change Title' ;
    rdfs:comment 'Brief descriptive title summarizing the nature of the product change for quick identification and reporting.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Usd' ;
    rdfs:comment 'Estimated financial impact of implementing this change in US dollars. Positive values indicate cost increases, negative values indicate cost savings. Includes one-time implementation costs and ongoing per-unit cost changes.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which formal customer notification was sent or published. Used to track compliance with notification lead time requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Lead Time Days' ;
    rdfs:comment 'Number of days advance notice provided to customers before the change becomes effective. Typically 30, 60, or 90 days depending on change impact and regulatory requirements.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether customers must be formally notified of this change. True if customer notification is required per regulatory requirements or commercial policy, False if change is transparent to customers.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferences rdf:type rdf:Property ;
    rdfs:label 'Document References' ;
    rdfs:comment 'Comma-separated list of supporting document identifiers, including design specifications, validation reports, risk assessments, regulatory submissions, and quality records that provide detailed documentation for this change.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date the change was implemented in production systems, manufacturing processes, or product specifications. May differ from effective_date if implementation occurs earlier or later than planned.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatorDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiator Department' ;
    rdfs:comment 'Department or business unit of the change initiator, such as R&D, Manufacturing, Quality Assurance, Regulatory Affairs, or Product Management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatorName rdf:type rdf:Property ;
    rdfs:label 'Initiator Name' ;
    rdfs:comment 'Full name of the individual who initiated or requested this product change notice. Typically an engineer, product manager, or quality professional.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTimeBuyDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Buy Date' ;
    rdfs:comment 'Final date customers can place orders for products with the old specification before the change takes effect. Used for inventory planning and customer transition management.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTimeShipDate rdf:type rdf:Property ;
    rdfs:label 'Last Time Ship Date' ;
    rdfs:comment 'Final date products with the old specification will be shipped to customers. After this date, only products incorporating the change will be available.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcnNumber rdf:type rdf:Property ;
    rdfs:label 'Pcn Number' ;
    rdfs:comment 'Externally-known unique business identifier for the product change notice, typically formatted as PCN-NNNNNN. Used for customer communication and regulatory submissions.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnStatus rdf:type rdf:Property ;
    rdfs:label 'Pcn Status' ;
    rdfs:comment 'Current lifecycle status of the product change notice: draft (initial creation), under_review (pending approval), approved (change authorized), customer_notification_pending (awaiting customer communication), customer_notification_sent (customers notified), implemented (change in production), closed (change complete and verified), or cancelled (change withdrawn). [ENUM-REF-CANDIDATE: draft|under_review|approved|customer_notification_pending|customer_notification_sent|implemented|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcnType rdf:type rdf:Property ;
    rdfs:label 'Pcn Type' ;
    rdfs:comment 'Classification of the change being documented: design (product specification or BOM change), process (manufacturing process change), labeling (packaging or labeling change), regulatory (classification or clearance change), material (raw material or component change), supplier (supplier change), or manufacturing_site (production location change). [ENUM-REF-CANDIDATE: design|process|labeling|regulatory|material|supplier|manufacturing_site — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Flag' ;
    rdfs:comment 'Indicates whether this change impacts product quality attributes, specifications, or quality control procedures. True if quality documentation or QC methods must be updated, False if no quality impact.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Assessment' ;
    rdfs:comment 'Analysis of regulatory implications of the change, including whether the change requires regulatory submission (510(k), PMA amendment, CE-IVD notification), changes to Instructions for Use (IFU), or updates to regulatory documentation.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required Flag' ;
    rdfs:comment 'Indicates whether this change requires a formal regulatory submission to FDA, EMA, or other governing bodies. True if submission is required, False if change can be implemented under existing clearances.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedChangeOrders rdf:type rdf:Property ;
    rdfs:label 'Related Change Orders' ;
    rdfs:comment 'Comma-separated list of related engineering change order (ECO) numbers, deviation requests, or corrective action (CAPA) identifiers that are associated with or triggered by this product change notice.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk classification assigned to this change based on risk assessment: low (minimal impact), medium (moderate impact requiring controls), high (significant impact requiring extensive validation), or critical (potential safety or regulatory impact requiring full revalidation).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyChainImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Impact Flag' ;
    rdfs:comment 'Indicates whether this change impacts supply chain operations, including supplier changes, component sourcing, manufacturing location changes, or logistics. True if supply chain coordination is required, False if no supply chain impact.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Reference' ;
    rdfs:comment 'Reference identifier to the validation protocol document(s) executed to verify this change meets specifications and regulatory requirements. Links to quality management system documentation.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Required Flag' ;
    rdfs:comment 'Indicates whether formal validation or verification activities are required before implementing this change. True if validation studies, performance testing, or clinical validation is needed, False if change can be implemented without additional validation.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentFamilyId rdf:type rdf:Property ;
    rdfs:label 'Parent Family Id' ;
    rdfs:comment 'Reference to the parent product family for hierarchical multi-level product family structures. Null for top-level families.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:averageSellingPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Average Selling Price Usd' ;
    rdfs:comment 'Average selling price for products within this family, expressed in USD. Used for portfolio-level revenue planning and pricing strategy analysis.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossSellAffinityScore rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Affinity Score' ;
    rdfs:comment 'Quantitative score (0.00 to 1.00) representing the likelihood of cross-sell or upsell opportunities with other product families. Used for portfolio optimization and sales strategy.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Impact Flag' ;
    rdfs:comment 'Indicates whether the product family processes or generates data subject to privacy regulations such as HIPAA (Health Insurance Portability and Accountability Act), GDPR (General Data Protection Regulation), or NIH Genomic Data Sharing Policy. True if privacy-sensitive, False otherwise.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether the product family is subject to environmental compliance regulations such as RoHS (Restriction of Hazardous Substances), REACH (Registration, Evaluation, Authorization of Chemicals), or WEEE (Waste Electrical and Electronic Equipment). True if subject to environmental regulations, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:familyCode rdf:type rdf:Property ;
    rdfs:label 'Family Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the product family for operational and reporting purposes (e.g., SR-SEQ for Short-Read Sequencing, LR-SEQ for Long-Read Sequencing, CRISPR-EDIT for CRISPR Editing tools).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyDescription rdf:type rdf:Property ;
    rdfs:label 'Family Description' ;
    rdfs:comment 'Detailed business description of the product family, including its purpose, target applications, and key differentiators in the genomics-biotechnology market.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'Full business name of the product family (e.g., Next-Generation Sequencing (NGS) Platforms, Microarray Solutions, Gene Editing Tools).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyType rdf:type rdf:Property ;
    rdfs:label 'Family Type' ;
    rdfs:comment 'High-level classification of the product family by offering type: instrument (sequencing platforms, array scanners), reagent (library prep kits, PCR reagents), consumable (flow cells, chips), software (bioinformatics pipelines, analysis tools), service (sequencing services, technical support), or assay (clinical test kits, diagnostic panels).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goToMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Go To Market Segment' ;
    rdfs:comment 'Target market segment for the product family (e.g., Academic Research, Clinical Diagnostics, Pharmaceutical R&D, Agricultural Biotech, Direct-to-Consumer, Population Genomics).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentPortfolioReference rdf:type rdf:Property ;
    rdfs:label 'Patent Portfolio Reference' ;
    rdfs:comment 'Reference to the intellectual property (IP) and patent portfolio protecting the product family technology. May include patent numbers or internal IP tracking codes.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementSystemScope rdf:type rdf:Property ;
    rdfs:label 'Quality Management System Scope' ;
    rdfs:comment 'Quality management system framework governing the product family: ISO_13485 (medical devices), ISO_9001 (general quality), GMP (Good Manufacturing Practice), GLP (Good Laboratory Practice), or none for non-regulated products.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelMix rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Mix' ;
    rdfs:comment 'Primary sales and distribution channels for the product family (e.g., Direct Sales, Distributor Network, OEM (Original Equipment Manufacturer) Partnerships, E-commerce, Field Application Scientists).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementTier rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Tier' ;
    rdfs:comment 'Standard service level agreement tier offered with the product family: standard (basic support), premium (enhanced support and turnaround time (TAT)), enterprise (dedicated support), custom (negotiated SLA terms).' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for the product family, used for profitability planning and pricing decisions.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Certification Required Flag' ;
    rdfs:comment 'Indicates whether customer training or operator certification is required or recommended for the product family. True if training/certification is required, False otherwise.' ;
    rdfs:domain ind:Family ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceMarkingStatus rdf:type rdf:Property ;
    rdfs:label 'Ce Marking Status' ;
    rdfs:comment 'Indicates whether the product carries CE marking for European market compliance. True if CE marked, False otherwise.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Applicable Flag' ;
    rdfs:comment 'Indicates whether the product is applicable for use in CLIA-certified clinical laboratories. True if applicable, False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clusterDensityKPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Cluster Density K Per Mm2' ;
    rdfs:comment 'Optimal cluster density in thousands of clusters per square millimeter (K/mm²) for sequencing flow cells.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cnvResolutionKb rdf:type rdf:Property ;
    rdfs:label 'Cnv Resolution Kb' ;
    rdfs:comment 'Resolution of copy number variation detection in kilobases (kb) for array-based or sequencing-based CNV analysis.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoodsSoldUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold Usd' ;
    rdfs:comment 'Manufacturing cost of goods sold per unit in USD, used for margin analysis and financial reporting.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageDepthMin rdf:type rdf:Property ;
    rdfs:label 'Coverage Depth Min' ;
    rdfs:comment 'Minimum recommended sequencing coverage depth (number of reads covering each base) for reliable variant calling, applicable to WGS and WES assays.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crisprTargetSpecificityPercent rdf:type rdf:Property ;
    rdfs:label 'Crispr Target Specificity Percent' ;
    rdfs:comment 'On-target specificity percentage for CRISPR gene-editing tools, indicating precision of genome editing.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Chemical hazard classification per GHS (Globally Harmonized System) for reagents and consumables (e.g., flammable, corrosive, toxic, non-hazardous).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCompatibility rdf:type rdf:Property ;
    rdfs:label 'Instrument Compatibility' ;
    rdfs:comment 'List of compatible sequencing or array instruments for this reagent kit or consumable (e.g., NovaSeq 6000, MiSeq, NextSeq 2000).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso13485CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Compliant Flag' ;
    rdfs:comment 'Indicates whether the product is manufactured under ISO 13485 quality management system for medical devices. True if compliant, False otherwise.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libraryCompatibility rdf:type rdf:Property ;
    rdfs:label 'Library Compatibility' ;
    rdfs:comment 'Compatible library preparation kits or protocols (e.g., TruSeq, Nextera, Stranded mRNA). May be a comma-separated list.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodCopiesPerMl rdf:type rdf:Property ;
    rdfs:label 'Lod Copies Per Ml' ;
    rdfs:comment 'Analytical sensitivity expressed as the Limit of Detection (LOD) in copies per milliliter, applicable to qPCR and molecular diagnostic assays.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pcrCycleCount rdf:type rdf:Property ;
    rdfs:label 'Pcr Cycle Count' ;
    rdfs:comment 'Recommended or maximum number of PCR amplification cycles for library preparation or qPCR assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Product Lifecycle Stage' ;
    rdfs:comment 'Current stage in the product lifecycle from R&D through commercialization to end-of-life: research, development, validation, commercialization, active, mature, end-of-life, or discontinued. [ENUM-REF-CANDIDATE: research|development|validation|commercialization|active|mature|end_of_life|discontinued — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:q30ScoreThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Q30 Score Threshold Percent' ;
    rdfs:comment 'Minimum percentage of bases with Phred quality score ≥30 (Q30), indicating base call accuracy of 99.9%. Critical quality metric for NGS data.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Reaction Volume Ul' ;
    rdfs:comment 'Standard reaction volume in microliters (µL) for reagent kits and assays.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reactionsPerKit rdf:type rdf:Property ;
    rdfs:label 'Reactions Per Kit' ;
    rdfs:comment 'Total number of reactions or tests provided in a single reagent kit package.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snpArrayProbeCount rdf:type rdf:Property ;
    rdfs:label 'Snp Array Probe Count' ;
    rdfs:comment 'Total number of SNP probes on the array product, indicating genotyping capacity.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:softwareVersionCompatibility rdf:type rdf:Property ;
    rdfs:label 'Software Version Compatibility' ;
    rdfs:comment 'Compatible software versions or bioinformatics pipeline versions required to process data from this product (e.g., BaseSpace v2.0+, DRAGEN 3.9+).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name or title of the product specification document.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification document: draft, under review, approved, active, obsolete, or superseded by a newer version.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Required storage temperature or temperature range in degrees Celsius for reagents and consumables (e.g., -20°C, 2-8°C, room temperature).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputGbPerRun rdf:type rdf:Property ;
    rdfs:label 'Throughput Gb Per Run' ;
    rdfs:comment 'Data output capacity in gigabases (Gb) per sequencing run. Key performance metric for sequencing platforms.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date when regulatory authorization was granted by the governing authority in the specified jurisdiction. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'Date when the regulatory authorization expires and requires renewal. Null for authorizations without expiration. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique authorization or clearance number assigned by the regulatory authority (e.g., FDA 510(k) number, premarket approval number, or equivalent jurisdiction-specific identifier).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current regulatory authorization status in the specified jurisdiction. Authorized (approved for market), Pending (under review), Withdrawn (voluntarily removed), Suspended (temporarily halted), Expired (authorization lapsed).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biocompatibilityTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Biocompatibility Testing Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether biocompatibility testing per ISO 10993 series is required for regulatory approval in the jurisdiction.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Ce Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the EU Notified Body for CE-IVD marked products, demonstrating conformity with EU IVDR requirements.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEvidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Evidence Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether clinical evidence (clinical trials, performance studies, or clinical evaluation reports) is required for regulatory authorization in this jurisdiction.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'DEA controlled substance schedule if the product contains or is used with controlled substances. Applicable to certain reagents or diagnostic kits.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cybersecurityRequirementsFlag rdf:type rdf:Property ;
    rdfs:label 'Cybersecurity Requirements Flag' ;
    rdfs:comment 'Boolean flag indicating whether cybersecurity controls and documentation are required for regulatory submission, applicable to connected devices, software, and bioinformatics platforms.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Required' ;
    rdfs:comment 'Comma-separated list of data privacy regulations that must be complied with for this product in the jurisdiction (e.g., HIPAA, GDPR, CCPA, PIPEDA). Applicable to products handling patient or customer data.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Required' ;
    rdfs:comment 'Comma-separated list of environmental regulations applicable to the product (e.g., RoHS, REACH, WEEE) for manufacturing, distribution, and disposal in the jurisdiction.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaDeviceClass rdf:type rdf:Property ;
    rdfs:label 'Fda Device Class' ;
    rdfs:comment 'FDA device classification under 21 CFR for US market. Class I (low risk, general controls), Class II (moderate risk, special controls), Class III (high risk, premarket approval required), or Not Applicable for non-device products or non-US jurisdictions.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaProductCode rdf:type rdf:Property ;
    rdfs:label 'Fda Product Code' ;
    rdfs:comment 'Three-letter FDA product code assigned to the device type for classification and regulatory tracking purposes in the US market.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmdnCode rdf:type rdf:Property ;
    rdfs:label 'Gmdn Code' ;
    rdfs:comment 'Five-digit GMDN code providing internationally recognized nomenclature for medical devices. Used for regulatory submissions and device identification across jurisdictions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmdnTermName rdf:type rdf:Property ;
    rdfs:label 'Gmdn Term Name' ;
    rdfs:comment 'Human-readable GMDN term name corresponding to the GMDN code, describing the device type in standardized nomenclature.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivdrRiskClass rdf:type rdf:Property ;
    rdfs:label 'Ivdr Risk Class' ;
    rdfs:comment 'EU IVDR 2017/746 risk classification for in vitro diagnostic medical devices. Class A (lowest risk), Class B (low risk), Class C (moderate risk), Class D (highest risk), or Not Applicable for non-IVD products or non-EU jurisdictions.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingLanguageRequired rdf:type rdf:Property ;
    rdfs:label 'Labeling Language Required' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 two-letter language codes required for product labeling and instructions for use in the specified jurisdiction (e.g., en, de, fr, es, zh, ja).' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedBodyNumber rdf:type rdf:Property ;
    rdfs:label 'Notified Body Number' ;
    rdfs:comment 'Four-digit identification number of the EU Notified Body responsible for conformity assessment and CE certification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether post-market surveillance activities (adverse event reporting, periodic safety updates, vigilance reporting) are mandated for this product in the jurisdiction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityManagementSystemStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Management System Standard' ;
    rdfs:comment 'Quality management system standard required for manufacturing and commercialization in the jurisdiction (e.g., ISO 13485 for medical devices, FDA 21 CFR Part 820 for US QSR, MDSAP for Medical Device Single Audit Program).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementCode rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Code' ;
    rdfs:comment 'Healthcare reimbursement code (CPT, HCPCS, or jurisdiction-specific code) associated with the product for insurance billing and reimbursement purposes.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of reimbursement approval for the product in the jurisdiction. Approved (reimbursement granted), Pending (under review), Not Applicable (not seeking reimbursement), Denied (reimbursement rejected).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareValidationLevel rdf:type rdf:Property ;
    rdfs:label 'Software Validation Level' ;
    rdfs:comment 'FDA software validation level of concern for products containing software or bioinformatics pipelines. Level A (minor concern), Level B (moderate concern), Level C (major concern), or Not Applicable for non-software products.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sterilization Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether the product must be sterilized per regulatory requirements for the intended use and jurisdiction.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:udiDi rdf:type rdf:Property ;
    rdfs:label 'Udi Di' ;
    rdfs:comment 'Device Identifier component of the UDI, a unique numeric or alphanumeric code specific to the device model and version, assigned by an FDA-accredited or EU-recognized issuing agency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiIssuingAgency rdf:type rdf:Property ;
    rdfs:label 'Udi Issuing Agency' ;
    rdfs:comment 'Organization that issued the UDI-DI. Common agencies include GS1, HIBCC (Health Industry Business Communications Council), ICCBBA (International Council for Commonality in Blood Banking Automation), IFA (ICCBBA for Medical Devices).' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Udi Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether Unique Device Identification (UDI) labeling is required for this product in the specified jurisdiction per FDA UDI rule or EU IVDR requirements.' ;
    rdfs:domain ind:RegulatoryClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Unique identifier for the service offering record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceOffering .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Service delivery (sequencing services, bioinformatics pipelines) often requires supplier partnerships for reagents, consumables, or subcontracted analysis. Service costing, supplier performance tracki' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:qualityTrainingCurriculumId rdf:type rdf:Property ;
    rdfs:label 'Quality Training Curriculum Id' ;
    rdfs:comment 'Foreign key linking to quality.training_curriculum. Business justification: Technical service delivery requires certified training (field application scientists, service engineers, laboratory technicians). Links service offering to required training curriculum ensuring person' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityTrainingCurriculum .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated internal cost to deliver the service including labor, travel, materials, and overhead. Used for margin analysis and profitability tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Method by which the service is delivered to the customer: on-site (at customer location), remote (virtual/online), or hybrid (combination of on-site and remote).' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the service offering was or will be discontinued and no longer available for new customer engagements. Existing contracts may continue beyond this date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes or region codes where this service is available for delivery. Reflects field service coverage, regulatory approvals, and operational capacity.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Materials Included Flag' ;
    rdfs:comment 'Indicates whether consumable materials, reagents, or spare parts required for service delivery are included in the standard price or billed separately.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumParticipants rdf:type rdf:Property ;
    rdfs:label 'Maximum Participants' ;
    rdfs:comment 'Maximum number of customer participants allowed per service engagement. Primarily applicable to training and consulting services.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Notice Days' ;
    rdfs:comment 'Minimum number of business days advance notice required to schedule the service. Used for resource planning and customer expectation management.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prerequisiteServices rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Services' ;
    rdfs:comment 'Comma-separated list of service codes that must be completed before this service can be delivered (e.g., installation must precede qualification, basic training must precede advanced training).' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteDeliveryCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Delivery Capable Flag' ;
    rdfs:comment 'Indicates whether the service can be delivered remotely without requiring on-site presence. True for virtual training, remote troubleshooting, and bioinformatics consulting.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this service offering is eligible for contract renewal or recurring subscription. True for maintenance contracts, support agreements, and subscription-based services.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Primary classification of the service offering type: installation (instrument setup), qualification (IQ/OQ/PQ validation), maintenance (preventive/corrective), field application scientist (FAS on-site support), training (customer education programs), consulting (bioinformatics/assay development), or sequencing-service (sequencing-as-a-service). [ENUM-REF-CANDIDATE: installation|qualification|maintenance|field_application_scientist|training|consulting|sequencing_service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the service offering used in commercial transactions and service delivery documentation.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the service offering including scope, objectives, and key activities performed during service delivery.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Full commercial name of the service offering as presented to customers and used in contracts.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOwner rdf:type rdf:Property ;
    rdfs:label 'Service Owner' ;
    rdfs:comment 'Name or identifier of the individual or team responsible for service definition, quality, and continuous improvement. Accountable for service performance and customer satisfaction.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service offering: active (available for sale and delivery), inactive (temporarily unavailable), discontinued (end-of-life), under development (not yet launched), or pilot (limited availability for testing).' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Service Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the service category (e.g., preventive_maintenance, corrective_maintenance, IQ, OQ, PQ, basic_training, advanced_training).' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDurationDays rdf:type rdf:Property ;
    rdfs:label 'Standard Duration Days' ;
    rdfs:comment 'Expected duration of the service engagement measured in business days. Used for multi-day engagements such as installation, qualification, or training programs.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardDurationHours rdf:type rdf:Property ;
    rdfs:label 'Standard Duration Hours' ;
    rdfs:comment 'Expected duration of the service engagement measured in hours under normal conditions. Used for resource planning and scheduling.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Price Usd' ;
    rdfs:comment 'List price for the service offering in United States Dollars before any discounts, volume adjustments, or contract negotiations. Used as baseline for pricing analytics and Average Selling Price (ASP) calculations.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelExpensesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Expenses Included Flag' ;
    rdfs:comment 'Indicates whether travel expenses (airfare, lodging, meals, ground transportation) are included in the standard price or billed separately. Applicable to on-site services.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Days' ;
    rdfs:comment 'Number of days after service completion during which rework or corrections are provided at no additional charge if service deliverables do not meet specifications.' ;
    rdfs:domain ind:ServiceOffering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Procurement operations track preferred/approved suppliers per SKU for sourcing decisions, supplier performance evaluation, and supply chain risk management. Critical for reagent/consumable procurement' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:replacementSkuId rdf:type rdf:Property ;
    rdfs:label 'Replacement Sku Id' ;
    rdfs:comment 'Reference to the successor SKU that replaces this SKU when discontinued. Used for customer migration planning and order substitution workflows.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:configuration rdf:type rdf:Property ;
    rdfs:label 'Configuration' ;
    rdfs:comment 'Specific configuration or variant details distinguishing this SKU from other SKUs of the same product (e.g., \'8-plex flow cell\', \'96-sample kit\', \'2x150bp read length\', \'single-user license\').' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryAvailability rdf:type rdf:Property ;
    rdfs:label 'Country Availability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where this SKU is approved for sale and distribution (e.g., \'USA,CAN,GBR,DEU,JPN\'). Reflects regulatory clearances and market authorizations.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'GS1 Global Trade Item Number (GTIN-8, GTIN-12, GTIN-13, or GTIN-14) for global supply chain identification and barcode scanning.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introductionDate rdf:type rdf:Property ;
    rdfs:label 'Introduction Date' ;
    rdfs:comment 'Date when the SKU was first made available for sale or distribution. Marks the beginning of the SKU lifecycle.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBundleComponent rdf:type rdf:Property ;
    rdfs:label 'Is Bundle Component' ;
    rdfs:comment 'Indicates whether this SKU is sold as part of a bundle or kit (true) or as a standalone item (false). Used to manage Bill of Materials (BOM) relationships.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether the SKU contains hazardous materials requiring special handling, labeling, and shipping compliance (e.g., flammable reagents, biohazards). Triggers Safety Data Sheet (SDS) requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrderable rdf:type rdf:Property ;
    rdfs:label 'Is Orderable' ;
    rdfs:comment 'Indicates whether the SKU is currently available for customer orders. True if orderable, false if blocked for ordering (e.g., due to regulatory hold, supply constraint, or discontinuation).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShippable rdf:type rdf:Property ;
    rdfs:label 'Is Shippable' ;
    rdfs:comment 'Indicates whether the SKU is a physical item that requires shipping (true) or a non-physical item such as a software license or service (false).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current lifecycle state of the SKU: active (orderable and shippable), inactive (temporarily unavailable), discontinued (end-of-life announced), pending launch (approved but not yet released), obsolete (no longer supported).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'Quantity increment in which the SKU must be ordered (e.g., order multiple of 10 means orders must be in quantities of 10, 20, 30, etc.). Used to align with packaging or manufacturing batch sizes.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of units or samples included in one orderable pack (e.g., 96 for a 96-sample kit, 1 for a single instrument, 10 for a 10-pack of flow cells).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesChannelEligibility rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Eligibility' ;
    rdfs:comment 'Comma-separated list of sales channels through which this SKU may be sold: direct (direct sales force), distributor, OEM (Original Equipment Manufacturer partner), ecommerce (online store), government (public sector contracts).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the orderable, shippable, or licensable variant. Used across order management, inventory, supply chain, and customer-facing systems.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Human-readable description of the SKU including configuration details, pack size, and distinguishing characteristics (e.g., \'NovaSeq 6000 S4 Reagent Kit v1.5 - 300 cycles\').' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuType rdf:type rdf:Property ;
    rdfs:label 'Sku Type' ;
    rdfs:comment 'Classification of the SKU by product category: instrument (sequencing platforms, gene editors), reagent kit, consumable (tips, plates), flow cell, array product (genotyping arrays), software license (bioinformatics tools), service (support, training), accessory, or bundle (multi-item package). [ENUM-REF-CANDIDATE: instrument|reagent_kit|consumable|flow_cell|array_product|software_license|service|accessory|bundle — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCostUsd rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Usd' ;
    rdfs:comment 'Standard manufacturing or procurement cost of the SKU in USD, used for Cost of Goods Sold (COGS) calculation, margin analysis, and inventory valuation.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum recommended storage temperature in degrees Celsius for maintaining product stability and quality (e.g., -20.00 for frozen reagents, 25.00 for room temperature items).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum recommended storage temperature in degrees Celsius for maintaining product stability and quality (e.g., -80.00 for ultra-low temperature reagents).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeLiters rdf:type rdf:Property ;
    rdfs:label 'Volume Liters' ;
    rdfs:comment 'Volume of one unit of the SKU in liters, used for warehouse space planning, shipping container optimization, and storage capacity management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qa Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: QA approval for software releases is a GxP-critical control point for software as medical device (SaMD) regulatory compliance (FDA 21 CFR Part 820, IEC 62304). Qa_approved_by is currently bare text; l' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:apiVersion rdf:type rdf:Property ;
    rdfs:label 'Api Version' ;
    rdfs:comment 'Version number of the public API (Application Programming Interface) exposed by this software release (e.g., \'v2.1\', \'v3.0\'). Used for integration and backward compatibility tracking.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethodsSupported rdf:type rdf:Property ;
    rdfs:label 'Authentication Methods Supported' ;
    rdfs:comment 'Comma-separated list of authentication mechanisms supported (e.g., \'LDAP, SAML 2.0, OAuth 2.0, Multi-Factor Authentication (MFA), API (Application Programming Interface) keys\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backwardCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Backward Compatible Flag' ;
    rdfs:comment 'Indicates whether this release is backward compatible with previous versions (True) or contains breaking changes requiring migration (False).' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Internal build identifier generated by the continuous integration system (e.g., Jenkins build #4523). Used for traceability and debugging.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Ce Mark Certificate Number' ;
    rdfs:comment 'CE-IVD certification number issued by a Notified Body if this software is approved for diagnostic use in the European Union under IVDR 2017/746.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockerImageTag rdf:type rdf:Property ;
    rdfs:label 'Docker Image Tag' ;
    rdfs:comment 'Docker container image tag for this release if distributed as a containerized application (e.g., \'genomics-pipeline:2.5.1\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStandard rdf:type rdf:Property ;
    rdfs:label 'Encryption Standard' ;
    rdfs:comment 'Encryption algorithms and standards used for data at rest and in transit (e.g., \'AES-256, TLS 1.3, RSA 2048\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationPackageUrl rdf:type rdf:Property ;
    rdfs:label 'Installation Package Url' ;
    rdfs:comment 'Download link for the software installation package (installer, Docker image, or deployment artifact).' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownIssuesLogReference rdf:type rdf:Property ;
    rdfs:label 'Known Issues Log Reference' ;
    rdfs:comment 'Reference identifier or URL to the known issues log documenting bugs, limitations, and workarounds for this release.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseModel rdf:type rdf:Property ;
    rdfs:label 'License Model' ;
    rdfs:comment 'Licensing and pricing model for this software release: perpetual (one-time purchase), subscription (recurring fee), SaaS (Software as a Service cloud-hosted), open_source (freely available), trial (time-limited evaluation).' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermsUrl rdf:type rdf:Property ;
    rdfs:label 'License Terms Url' ;
    rdfs:comment 'Web link to the End User License Agreement (EULA) or software license terms document for this release.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:migrationGuideUrl rdf:type rdf:Property ;
    rdfs:label 'Migration Guide Url' ;
    rdfs:comment 'Web link to the migration guide document for customers upgrading from previous versions. Critical for releases with breaking changes.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSystemRequirements rdf:type rdf:Property ;
    rdfs:label 'Minimum System Requirements' ;
    rdfs:comment 'Minimum hardware and software specifications required to run this release (e.g., \'CPU: 8 cores, RAM: 32GB, Storage: 500GB SSD, Python 3.8+\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Package Size Mb' ;
    rdfs:comment 'Size of the installation package in megabytes. Used for download planning and storage capacity estimation.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Release Date' ;
    rdfs:comment 'Originally scheduled date for the software release. Used for tracking schedule adherence and planning. Follows yyyy-MM-dd format.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Status' ;
    rdfs:comment 'Quality Assurance approval status for this release: pending (under review), approved (passed all tests), rejected (failed quality gates), conditional (approved with known limitations).' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Timestamp' ;
    rdfs:comment 'Date and time when QA (Quality Assurance) approval was granted. Follows yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recommendedSystemRequirements rdf:type rdf:Property ;
    rdfs:label 'Recommended System Requirements' ;
    rdfs:comment 'Recommended hardware and software specifications for optimal performance (e.g., \'CPU: 16 cores, RAM: 64GB, Storage: 1TB NVMe SSD, Python 3.10+\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseManager rdf:type rdf:Property ;
    rdfs:label 'Release Manager' ;
    rdfs:comment 'Name or employee identifier of the release manager responsible for coordinating and approving this software release.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseName rdf:type rdf:Property ;
    rdfs:label 'Release Name' ;
    rdfs:comment 'Marketing or code name for the software release (e.g., \'Aurora\', \'Phoenix\', \'Q4 2023 Release\'). Optional friendly identifier.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotesSummary rdf:type rdf:Property ;
    rdfs:label 'Release Notes Summary' ;
    rdfs:comment 'High-level summary of key features, enhancements, and bug fixes included in this release. Detailed release notes are stored separately.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Release Notes Url' ;
    rdfs:comment 'Web link to the complete release notes document hosted on the company documentation portal or knowledge base.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Semantic version number of the software release following the pattern major.minor.patch (e.g., 2.5.1, 3.0.0-beta). Follows semantic versioning standard.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityCertification rdf:type rdf:Property ;
    rdfs:label 'Security Certification' ;
    rdfs:comment 'Security certifications and compliance standards met by this release (e.g., \'ISO 27001, SOC 2 Type II, HIPAA (Health Insurance Portability and Accountability Act) compliant, GDPR (General Data Protection Regulation) compliant\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedCloudPlatforms rdf:type rdf:Property ;
    rdfs:label 'Supported Cloud Platforms' ;
    rdfs:comment 'Comma-separated list of cloud platforms where this software can be deployed (e.g., \'AWS (Amazon Web Services), Azure, GCP, on-premise, HPC (High-Performance Computing)\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedOsPlatforms rdf:type rdf:Property ;
    rdfs:label 'Supported Os Platforms' ;
    rdfs:comment 'Comma-separated list of operating systems compatible with this release (e.g., \'Linux Ubuntu 20.04, CentOS 7, Windows Server 2019, macOS 12\').' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialsUrl rdf:type rdf:Property ;
    rdfs:label 'Training Materials Url' ;
    rdfs:comment 'Web link to training documentation, videos, or e-learning modules for this software release.' ;
    rdfs:domain ind:SoftwareRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether formal training or certification is required for users to operate this software release (True/False). Relevant for IVD (In Vitro Diagnostic) and clinical software.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Employee Id' ;
    rdfs:comment 'Identifier of the qualified lead auditor responsible for planning, conducting, and reporting the audit. Must be a trained and qualified auditor per ISO 19011 or equivalent.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:establishmentRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Establishment Registration Id' ;
    rdfs:comment 'Foreign key linking to regulatory.establishment_registration. Business justification: GMP/ISO 13485 audits are conducted at registered manufacturing establishments. FDA establishment inspections, notified body audits, and competent authority inspections are tied to specific facility re' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstablishmentRegistration .

ind:primaryLeadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lead Auditor Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Identifier of the overarching audit program or annual audit plan to which this audit belongs. Links to the audit program master for strategic audit planning and coverage tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicsBiotech .

ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of regulatory standards, frameworks, or requirements against which the audit is conducted. Examples: ISO 13485, FDA 21 CFR Part 820, CLIA 42 CFR Part 493, CAP accreditation requirements, GMP, ISO 15189.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business-facing unique audit identifier used in quality management systems and regulatory documentation. Format: AUD-NNNNNN.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope including processes, departments, systems, or standards being audited. Defines boundaries and focus areas for the audit activity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Tracks progression from planning through execution to closure. Planned indicates scheduled but not started; in_progress indicates active fieldwork; fieldwork_complete indicates data collection done; report_draft indicates findings being documented; report_final indicates report approved; closed indicates all follow-up actions complete; cancelled indicates audit was terminated before completion. [ENUM-REF-CANDIDATE: planned|in_progress|fieldwork_complete|report_draft|report_final|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit based on its purpose and scope. Includes internal GMP (Good Manufacturing Practice) audits, ISO 13485 compliance audits, CLIA (Clinical Laboratory Improvement Amendments) and CAP (College of American Pathologists) readiness audits, supplier qualification audits, regulatory inspection readiness audits, and process-specific audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeDepartmentHead rdf:type rdf:Property ;
    rdfs:label 'Auditee Department Head' ;
    rdfs:comment 'Name or identifier of the department head or process owner responsible for the audited area. Primary contact for audit findings and corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or major nonconformities identified during the audit. Critical findings require immediate corrective action and may impact product quality or regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentScope rdf:type rdf:Property ;
    rdfs:label 'Department Scope' ;
    rdfs:comment 'Comma-separated list of departments or functional areas included in the audit scope. Examples: Manufacturing, Quality Control, Research and Development, Regulatory Affairs.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether follow-up audit or verification activities are required. True indicates that corrective actions must be verified through a subsequent audit or review.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the regulatory authority or certification body for which this audit serves as readiness preparation. Examples: FDA, EMA, CAP, CLIA, Notified Body. Null for internal audits not tied to external inspection.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Flag' ;
    rdfs:comment 'Boolean flag indicating whether this audit is a regulatory inspection readiness audit or mock inspection. True indicates the audit simulates or prepares for an FDA, EMA, or other regulatory body inspection.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date the final audit report was issued or approved. Marks the formal completion of audit documentation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names or identifiers. Includes all auditors, technical experts, and observers participating in the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings (observations, nonconformities, opportunities for improvement) identified during the audit. Detailed findings are tracked in the audit_finding product.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the earlier audit finding that this current finding repeats, if applicable. Used to track recurrence patterns.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Reference to the regulatory inspection event if this finding originated from an external regulatory audit (FDA, EMA, Notified Body, CAP, CLIA).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:affectedDepartment rdf:type rdf:Property ;
    rdfs:label 'Affected Department' ;
    rdfs:comment 'Organizational department or business unit responsible for the process or area where the finding was identified.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcedureSop rdf:type rdf:Property ;
    rdfs:label 'Affected Procedure Sop' ;
    rdfs:comment 'Specific SOP, work instruction, or controlled document that is the subject of the finding. References document control system identifier.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'Business process or functional area impacted by the finding (e.g., Library Preparation, Sequencing QC, Document Control, Training Management, CAPA Process).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSiteLocation rdf:type rdf:Property ;
    rdfs:label 'Affected Site Location' ;
    rdfs:comment 'Physical site, facility, or laboratory location where the finding was observed. Relevant for multi-site organizations.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the audit finding. Tracks progression from identification through response, verification, and closure. [ENUM-REF-CANDIDATE: open|under_investigation|response_submitted|pending_verification|verified_closed|rejected|reopened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureComments rdf:type rdf:Property ;
    rdfs:label 'Closure Comments' ;
    rdfs:comment 'Final comments or notes documenting the closure decision, verification results, and any residual considerations.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the finding was formally closed after successful verification of corrective actions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerComplaintRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Related Flag' ;
    rdfs:comment 'Indicates whether this finding is related to or triggered by customer complaints, product quality issues, or field performance problems.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataIntegrityIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Issue Flag' ;
    rdfs:comment 'Indicates whether the finding involves data integrity concerns such as incomplete records, missing audit trails, unauthorized data modification, or non-compliance with FDA 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaWarningLetterRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Warning Letter Related Flag' ;
    rdfs:comment 'Indicates whether this finding is related to or triggered by an FDA Warning Letter, 483 observation, or other regulatory inspection finding. Requires expedited response and executive visibility.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Severity classification of the finding. Critical: immediate risk to product safety or regulatory compliance; Major: significant GxP or quality system deviation; Minor: isolated procedural deviation; Observation: opportunity for improvement without regulatory impact.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the nonconformance, deficiency, or observation. Describes what was found, the gap between actual and expected state, and the potential impact.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the finding, typically formatted as audit number plus sequential finding number (e.g., AUD-2024-001-F01).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Impact Flag' ;
    rdfs:comment 'Indicates whether the finding has direct impact on GxP-regulated activities (GMP, GLP, GCP). GxP findings require heightened scrutiny and formal quality system response.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectiveEvidence rdf:type rdf:Property ;
    rdfs:label 'Objective Evidence' ;
    rdfs:comment 'Factual, verifiable evidence supporting the finding. May reference documents reviewed, records examined, observations made, interviews conducted, or data analyzed during the audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory requirement, standard clause, or guideline that the finding relates to (e.g., FDA 21 CFR 820.30, ISO 13485:2016 Section 7.3.2, CLIA 493.1256).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat of a previously identified and supposedly corrected issue. Repeat findings indicate ineffective CAPA and require escalation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredResponseType rdf:type rdf:Property ;
    rdfs:label 'Required Response Type' ;
    rdfs:comment 'Type of response action required to address the finding. CAPA required: formal corrective and preventive action; Correction only: immediate fix without preventive action; Observation acknowledgment: awareness without formal action; No action required: informational only.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Target date by which the auditee must submit a formal response to the finding. Typically 30 days for major findings, 60 days for minor findings, per organizational policy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseOverdueFlag rdf:type rdf:Property ;
    rdfs:label 'Response Overdue Flag' ;
    rdfs:comment 'Indicates whether the response submission is past the due date. Calculated field for tracking compliance with response timelines.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Actual date when the auditee submitted their formal response to the finding.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual responsible for the finding response. Used for notification and communication.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual assigned responsibility for responding to and resolving the finding. Typically a manager or process owner in the affected department.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Required Flag' ;
    rdfs:comment 'Indicates whether formal root cause analysis is required for this finding. Typically true for critical and major findings, false for minor findings and observations.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that corrective actions have been implemented and are effective. Document review: examination of updated procedures; Follow-up audit: re-audit of the process; Process observation: direct observation of corrected process; Data analysis: review of performance metrics; Management review: executive assessment.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether formal verification of corrective action effectiveness is required before the finding can be closed. Typically true for critical and major findings.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the quality professional or auditor who performed the verification and approved closure of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Employee Id' ;
    rdfs:comment 'User identifier of the person who created this CAPA record. Part of the audit trail required for FDA 21 CFR Part 11 electronic signature and record integrity.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this CAPA record. Part of the audit trail required for FDA 21 CFR Part 11 electronic signature and record integrity.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaQualityApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Quality Approver Employee Id' ;
    rdfs:comment 'Identifier of the Quality Assurance personnel who reviewed and approved the CAPA investigation, action plan, and closure. Part of the approval chain required for GxP compliance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to quality.risk_assessment. Business justification: CAPA references a risk assessment via a free-text field; adding a proper FK enables traceability and eliminates the siloed risk_assessment table.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:actionPlanApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Approved Date' ;
    rdfs:comment 'Actual date when the corrective and preventive action plan was formally approved by Quality Assurance.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target date by which the corrective and preventive action plan must be developed and approved.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedProductLines rdf:type rdf:Property ;
    rdfs:label 'Affected Product Lines' ;
    rdfs:comment 'Comma-separated list or narrative description of product lines, SKUs, or lot numbers affected by the quality issue. Used for impact assessment and product disposition decisions.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Description' ;
    rdfs:comment 'Detailed narrative describing the quality issue, nonconformance, or improvement opportunity that triggered the CAPA initiation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA record. Tracks progression from initiation through investigation, action implementation, effectiveness verification, and closure. [ENUM-REF-CANDIDATE: open|investigation|action_plan|implementation|effectiveness_check|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the CAPA as corrective (addressing an existing nonconformance), preventive (preventing potential nonconformance), or combined (both corrective and preventive actions).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Completed Date' ;
    rdfs:comment 'Actual date when the effectiveness verification was completed and results documented.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckCriteria rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Criteria' ;
    rdfs:comment 'Defined measurable criteria and acceptance thresholds used to verify that the implemented corrective and preventive actions have been effective in resolving the issue and preventing recurrence.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Due Date' ;
    rdfs:comment 'Target date by which the effectiveness verification of implemented actions must be completed. Typically scheduled after a defined monitoring period post-implementation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Outcome of the effectiveness verification assessment, indicating whether the implemented actions successfully resolved the issue and met the defined effectiveness criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completed Date' ;
    rdfs:comment 'Actual date when all planned corrective and preventive actions were fully implemented and verified.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationDueDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Due Date' ;
    rdfs:comment 'Target date by which all corrective and preventive actions must be fully implemented.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the CAPA was formally initiated in the quality system. Marks the start of the CAPA lifecycle and is used for turnaround time (TAT) tracking and regulatory reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiationSource rdf:type rdf:Property ;
    rdfs:label 'Initiation Source' ;
    rdfs:comment 'The triggering event or source that initiated the CAPA. Identifies the quality system input that identified the need for corrective or preventive action. [ENUM-REF-CANDIDATE: deviation|audit_finding|customer_complaint|oos_result|regulatory_inspection|management_review|risk_assessment|supplier_issue — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Actual date when the root cause investigation was completed and documented. Used for TAT metrics and compliance tracking.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationDueDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Due Date' ;
    rdfs:comment 'Target date by which the root cause investigation must be completed. Driven by priority, severity, and regulatory requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mastercontrolRecordReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Record Reference' ;
    rdfs:comment 'Unique identifier of the CAPA record in MasterControl document control and training management system, used for SOP update tracking and training workflow integration.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Detailed description of the preventive actions planned or implemented to eliminate potential causes of nonconformance and prevent occurrence in other areas or products.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productImpact rdf:type rdf:Property ;
    rdfs:label 'Product Impact' ;
    rdfs:comment 'Indicates whether the quality issue has confirmed or potential impact on released product quality, safety, or performance. Drives product disposition and recall assessment.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Indicates whether the underlying quality issue requires regulatory reporting to FDA, EMA, or other governing bodies per applicable regulations (e.g., MDR, field alert, recall).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Method' ;
    rdfs:comment 'The structured methodology used to identify the root cause of the quality issue (e.g., 5-Why, Fishbone/Ishikawa, Fault Tree Analysis, FMEA, Pareto analysis).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Summary' ;
    rdfs:comment 'Narrative summary of the identified root cause(s) of the quality issue, documenting the outcome of the root cause analysis investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopUpdatesRequired rdf:type rdf:Property ;
    rdfs:label 'Sop Updates Required' ;
    rdfs:comment 'Boolean flag indicating whether the CAPA requires updates to existing SOPs or creation of new SOPs to prevent recurrence. Triggers document control workflow in MasterControl.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the originating quality event (e.g., deviation number, audit finding ID, complaint number, OOS investigation number) that triggered this CAPA.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief descriptive title summarizing the quality issue or improvement opportunity addressed by this CAPA.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Boolean flag indicating whether the CAPA requires personnel training or retraining as part of the corrective or preventive action plan. Triggers training management workflow.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'Unique identifier of the CAPA record in Veeva Vault quality management system, used for controlled document linkage and audit trail integration.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Change Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryChangeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Change Employee Id' ;
    rdfs:comment 'Identifier of the employee who initiated the change control request. Links to workforce or employee master data.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryChangeInitiatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Change Initiator Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryChangeRegulatoryApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Change Regulatory Approver Employee Id' ;
    rdfs:comment 'Identifier of the Regulatory Affairs representative who approved the change control. Links to workforce or employee master data. Null if Regulatory approval is not yet obtained or not required.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date on which the change was fully implemented. Null if implementation is not yet complete.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedEquipmentList rdf:type rdf:Property ;
    rdfs:label 'Affected Equipment List' ;
    rdfs:comment 'Comma-separated or structured list of equipment asset IDs or instrument serial numbers impacted by the change. Used for equipment qualification and maintenance planning.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedFacilityList rdf:type rdf:Property ;
    rdfs:label 'Affected Facility List' ;
    rdfs:comment 'Comma-separated or structured list of facility locations, cleanrooms, or manufacturing sites impacted by the change. Used for facility qualification and environmental monitoring.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductList rdf:type rdf:Property ;
    rdfs:label 'Affected Product List' ;
    rdfs:comment 'Comma-separated or structured list of product SKUs, catalog numbers, or product families impacted by the change. Used for traceability and scope definition.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRoutingPath rdf:type rdf:Property ;
    rdfs:label 'Approval Routing Path' ;
    rdfs:comment 'Structured representation of the approval workflow path, listing required approvers by role or department (e.g., Quality Assurance, Regulatory Affairs, Manufacturing, Engineering, R&D). May be comma-separated or JSON-encoded.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlDescription rdf:type rdf:Property ;
    rdfs:label 'Change Control Description' ;
    rdfs:comment 'Detailed narrative describing the proposed change, including current state, proposed future state, rationale, and business justification. Provides comprehensive context for impact assessment and approval decision-making.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current lifecycle status of the change control request. Tracks progression from initiation through approval, implementation, and closure. Draft: initial creation. Submitted: routed for review. Under Review: impact assessment and approval routing in progress. Approved: authorized for implementation. Rejected: not approved. Implementation: change being executed. Completed: implementation finished, awaiting effectiveness check. Closed: effectiveness verified and change control archived. Cancelled: withdrawn before completion. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|implementation|completed|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the change based on regulatory and business impact. Major: significant process/product changes requiring regulatory submission. Minor: low-impact changes with limited scope. Critical: urgent changes affecting patient safety or product quality. Administrative: documentation-only changes with no GxP impact.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Document Impact Flag' ;
    rdfs:comment 'Indicates whether the change requires updates to controlled documents (SOPs, specifications, protocols, work instructions, batch records, device master records). True if document updates are required; False otherwise.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Date on which the post-implementation effectiveness check was completed. Null if effectiveness check is not yet performed or not required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required Flag' ;
    rdfs:comment 'Indicates whether a post-implementation effectiveness check is required to verify that the change achieved its intended objectives and did not introduce unintended consequences. True if effectiveness check is required; False otherwise.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Summary' ;
    rdfs:comment 'Consolidated summary of cross-functional impact assessment results, covering regulatory, validation, training, documentation, supply chain, and operational impacts. Informs approval decision and implementation planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Plan' ;
    rdfs:comment 'Detailed plan describing how the approved change will be executed, including tasks, responsibilities, timelines, resource requirements, and success criteria. May reference linked project plans or work orders.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business and technical rationale for the proposed change. May include quality improvement objectives, cost reduction, regulatory compliance requirements, risk mitigation, process optimization, or corrective action linkage.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Target date for completing the implementation of the approved change. Used for scheduling, resource planning, and tracking.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Qa Approval Date' ;
    rdfs:comment 'Date on which Quality Assurance approved the change control. Null if QA approval is not yet obtained or not required.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Training Impact Flag' ;
    rdfs:comment 'Indicates whether the change requires training or retraining of personnel (SOP training, equipment training, software training). True if training is required; False otherwise.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Impact Flag' ;
    rdfs:comment 'Indicates whether the change requires revalidation, requalification, or verification activities (process validation, equipment qualification, software validation, analytical method validation). True if validation activities are required; False otherwise.' ;
    rdfs:domain ind:ChangeControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this complaint record.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complaintEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Employee Id' ;
    rdfs:comment 'Reference to the quality assurance or customer service team member assigned to handle this complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complaintModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Complaint Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this complaint record.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Reference to the formal quality investigation record initiated for this complaint, if applicable.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes documenting the closure rationale, resolution summary, and any follow-up actions.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint type based on the nature of the quality issue reported. [ENUM-REF-CANDIDATE: reagent_performance|instrument_malfunction|sequencing_quality|bioinformatics_pipeline_error|labeling_packaging|documentation|delivery_shipping|customer_service|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Detailed narrative description of the complaint as reported by the customer, including symptoms, context, and impact.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally-visible unique complaint tracking number assigned upon receipt. Format: CMP-YYYYNNNN.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Channel through which the complaint was received. [ENUM-REF-CANDIDATE: customer_direct|field_service|technical_support|sales_representative|distributor|regulatory_authority|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle status of the complaint in the quality management workflow. [ENUM-REF-CANDIDATE: new|under_review|investigation_in_progress|pending_customer_info|resolved|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date the formal response was sent to the customer.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerResponseSent rdf:type rdf:Property ;
    rdfs:label 'Customer Response Sent' ;
    rdfs:comment 'Indicates whether a formal response has been sent to the customer regarding the complaint resolution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Customer Response Summary' ;
    rdfs:comment 'Summary of the response provided to the customer, including findings, actions taken, and resolution.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosticImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Diagnostic Impact Assessment' ;
    rdfs:comment 'Assessment of the complaint\'s impact on diagnostic test results, clinical decision-making, or patient care pathways.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationRequired rdf:type rdf:Property ;
    rdfs:label 'Investigation Required' ;
    rdfs:comment 'Indicates whether a formal quality investigation is required for this complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mdrReportable rdf:type rdf:Property ;
    rdfs:label 'Mdr Reportable' ;
    rdfs:comment 'Indicates whether the complaint meets FDA Medical Device Reporting (MDR) criteria and requires regulatory submission.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Patient Safety Impact' ;
    rdfs:comment 'Indicates whether the complaint has potential or actual impact on patient safety or clinical diagnostic outcomes.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Number' ;
    rdfs:comment 'Reference number for any regulatory report (MDR, vigilance, or other) submitted to authorities in connection with this complaint.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByEmail rdf:type rdf:Property ;
    rdfs:label 'Reported By Email' ;
    rdfs:comment 'Email address of the individual who reported the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the individual who reported the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByPhone rdf:type rdf:Property ;
    rdfs:label 'Reported By Phone' ;
    rdfs:comment 'Contact phone number of the individual who reported the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vigilanceReportable rdf:type rdf:Property ;
    rdfs:label 'Vigilance Reportable' ;
    rdfs:comment 'Indicates whether the complaint meets EU vigilance reporting requirements under IVDR.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryControlledEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Controlled Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for the content accuracy, maintenance, and periodic review of the document. Links to workforce master data.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededDocumentControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Controlled Document Id' ;
    rdfs:comment 'Identifier of the previous version of this document that this version replaces. Enables version lineage tracking. Nullable for initial versions.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:archivedDate rdf:type rdf:Property ;
    rdfs:label 'Archived Date' ;
    rdfs:comment 'Date on which the document was moved to archival storage. Nullable if not yet archived.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivedFlag rdf:type rdf:Property ;
    rdfs:label 'Archived Flag' ;
    rdfs:comment 'Indicates whether the document has been moved to long-term archival storage. True if archived, False if active or accessible.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the document content. Determines access controls and distribution restrictions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of roles, departments, or individuals authorized to access or receive this document. Supports controlled distribution per ISO 13485.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level functional category grouping for the document. Supports cross-functional document organization and retrieval. [ENUM-REF-CANDIDATE: Quality|Manufacturing|R&D|Regulatory|Clinical|IT|Safety|Environmental|HR — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format or media type of the controlled document. Supports format-specific rendering and archival strategies. [ENUM-REF-CANDIDATE: PDF|Word|Excel|PowerPoint|HTML|XML|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the controlled document. Tracks progression through authoring, review, approval, activation, and retirement stages. [ENUM-REF-CANDIDATE: Draft|In Review|Approved|Effective|Superseded|Obsolete|Archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full descriptive title of the controlled document. Human-readable identity label.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Applied Flag' ;
    rdfs:comment 'Indicates whether an FDA 21 CFR Part 11 compliant electronic signature was applied to this document. True if electronically signed, False otherwise.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Reference identifier from an external system or regulatory authority (e.g., FDA submission number, ISO standard number, customer specification reference).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of searchable keywords or tags associated with the document. Enhances discoverability in document management systems.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Used for completeness verification and printing logistics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionSummary rdf:type rdf:Property ;
    rdfs:label 'Revision Summary' ;
    rdfs:comment 'Brief narrative summary of changes made in this version compared to the previous version. Supports change traceability and impact assessment.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Document Reference' ;
    rdfs:comment 'Unique identifier of the document in the source system (Veeva Vault or MasterControl). Enables traceability back to the operational system of record.' ;
    rdfs:domain ind:ControlledDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerComplaintId rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Id' ;
    rdfs:comment 'Foreign key reference to the originating customer complaint record if the nonconformance was detected post-sale.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:inboundDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Inbound Delivery Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_delivery. Business justification: Cold chain excursions, carrier damage, or customs delays detected at delivery trigger NCRs. Link required for temperature log review, carrier claims, and supplier performance impact assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundDelivery .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: NCRs for incoming material defects (wrong spec, damaged goods, missing CoA) must trace to the originating PO for supplier notification, debit memos, and supplier performance scorecards.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the quality professional who closed the nonconformance record after verification of completion.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containmentAction rdf:type rdf:Property ;
    rdfs:label 'Containment Action' ;
    rdfs:comment 'Immediate containment actions taken to prevent further use or distribution of the nonconforming material.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'Name or identifier of the person or system that detected the nonconformance.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'Origin point where the nonconformance was identified: incoming inspection, in-process QC, final release testing, customer complaint, supplier notification, or internal audit.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'Name or identifier of the quality authority who approved the disposition decision.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the disposition decision was finalized and approved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on how to handle the nonconforming material: use as-is (with concession), rework, reject, scrap, return to supplier, or quarantine pending further investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Detailed rationale and technical justification for the disposition decision, including risk assessment and impact analysis.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureMode rdf:type rdf:Property ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Description of how the material or product failed to meet specifications (e.g., out-of-specification result, physical defect, labeling error, contamination).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated or actual financial impact of the nonconformance, including scrap cost, rework cost, and potential liability exposure.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number of the nonconforming material for traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Textual description of the affected material, product, reagent, or component.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Business identifier for the nonconformance report, typically formatted as NCR-YYYYNNNN for external reference and traceability.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrType rdf:type rdf:Property ;
    rdfs:label 'Ncr Type' ;
    rdfs:comment 'Classification of the nonconforming item: material, product, component, reagent, instrument, or raw material.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonconformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Status' ;
    rdfs:comment 'Current lifecycle status of the nonconformance record: open, under investigation, pending disposition, closed, or cancelled.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityNotificationNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Notification Number' ;
    rdfs:comment 'SAP QM notification number linking this NCR to the SAP Quality Management module for integrated workflow.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Numeric quantity of nonconforming material or units identified, expressed in the material\'s base unit of measure.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationParameter rdf:type rdf:Property ;
    rdfs:label 'Specification Parameter' ;
    rdfs:comment 'Specific quality parameter or attribute that was out of specification (e.g., purity, concentration, pH, sterility).' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the quality specification, acceptance criteria, or SOP that the material failed to meet.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Notification Date' ;
    rdfs:comment 'Date when the supplier was formally notified of the nonconformance, if applicable.' ;
    rdfs:domain ind:Nonconformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryOosEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Oos Employee Id' ;
    rdfs:comment 'Reference to the quality assurance or laboratory personnel who initiated the investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOosQaReviewerUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Oos Qa Reviewer User Employee Id' ;
    rdfs:comment 'Reference to the QA professional who reviewed and approved the investigation findings.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:testMethodId rdf:type rdf:Property ;
    rdfs:label 'Test Method Id' ;
    rdfs:comment 'Reference to the analytical test method or assay protocol used when the OOS result was obtained.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestMethod .

ind:deviationMagnitude rdf:type rdf:Property ;
    rdfs:label 'Deviation Magnitude' ;
    rdfs:comment 'Calculated magnitude of deviation from the specification limit, expressed as absolute difference or percentage.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invalidationJustification rdf:type rdf:Property ;
    rdfs:label 'Invalidation Justification' ;
    rdfs:comment 'Detailed scientific justification for invalidating the OOS result, required when result_invalidated is true. Must demonstrate clear laboratory error per FDA guidance.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Business identifier for the OOS investigation, typically formatted as OOS-YYYY-NNNNNN for external reference and regulatory reporting.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the OOS investigation workflow. [ENUM-REF-CANDIDATE: initiated|phase_i_in_progress|phase_i_complete|phase_ii_in_progress|phase_ii_complete|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation: Out-of-Specification (OOS), Out-of-Trend (OOT), atypical result, or failed specification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'The actual measured or observed test result value that fell outside specification limits.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current phase of the investigation: Phase I (laboratory investigation for analyst error, instrument malfunction, calculation error) or Phase II (full investigation for process failure, raw material failure, method failure).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIAssignableCauseFound rdf:type rdf:Property ;
    rdfs:label 'Phase I Assignable Cause Found' ;
    rdfs:comment 'Indicates whether an assignable laboratory cause was identified during Phase I investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseICompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase I Completion Date' ;
    rdfs:comment 'Date when Phase I laboratory investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIFindings rdf:type rdf:Property ;
    rdfs:label 'Phase I Findings' ;
    rdfs:comment 'Detailed findings from Phase I laboratory investigation including assessment of analyst error, instrument malfunction, calculation error, or other laboratory-related causes.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseIiAssignableCauseFound rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Assignable Cause Found' ;
    rdfs:comment 'Indicates whether an assignable manufacturing or process cause was identified during Phase II investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseIiCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Completion Date' ;
    rdfs:comment 'Date when Phase II full investigation was completed.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseIiFindings rdf:type rdf:Property ;
    rdfs:label 'Phase Ii Findings' ;
    rdfs:comment 'Detailed findings from Phase II full investigation including assessment of process failure, raw material failure, method failure, or other manufacturing-related causes.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or product identifier for the item under investigation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qa Review Date' ;
    rdfs:comment 'Date when the investigation was reviewed and approved by quality assurance.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Indicates whether the OOS investigation findings require reporting to regulatory authorities (FDA, EMA, etc.).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultInvalidated rdf:type rdf:Property ;
    rdfs:label 'Result Invalidated' ;
    rdfs:comment 'Indicates whether the original OOS result was invalidated based on investigation findings demonstrating laboratory error.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Retest Authorization Date' ;
    rdfs:comment 'Date when retesting was authorized by quality assurance.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestAuthorized rdf:type rdf:Property ;
    rdfs:label 'Retest Authorized' ;
    rdfs:comment 'Indicates whether retesting of the sample was authorized as part of the investigation.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retestResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Retest Results Summary' ;
    rdfs:comment 'Summary of retest results including number of retests performed and outcomes.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationLimitLower rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Lower' ;
    rdfs:comment 'Lower acceptance criterion or specification limit for the test parameter.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Specification Limit Upper' ;
    rdfs:comment 'Upper acceptance criterion or specification limit for the test parameter.' ;
    rdfs:domain ind:OosInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryQcEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Qc Employee Id' ;
    rdfs:comment 'Identifier of the laboratory technician or quality control analyst who performed the test.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coaIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Included Flag' ;
    rdfs:comment 'Indicates whether this QC result is included in the official Certificate of Analysis for the lot.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryLocation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Location' ;
    rdfs:comment 'The physical laboratory or testing facility where the QC test was performed.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotDisposition rdf:type rdf:Property ;
    rdfs:label 'Lot Disposition' ;
    rdfs:comment 'The final quality decision for the lot based on cumulative QC results: released for use, rejected, or held in quarantine.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Specification Limit' ;
    rdfs:comment 'The minimum acceptable value for the test characteristic as defined in the product specification or quality standard.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfSpecificationFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Specification Flag' ;
    rdfs:comment 'Boolean indicator that this result exceeded specification limits and triggered an OOS investigation.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replicateNumber rdf:type rdf:Property ;
    rdfs:label 'Replicate Number' ;
    rdfs:comment 'The replicate or repeat number when multiple measurements are taken from the same sample for statistical validity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Number' ;
    rdfs:comment 'The controlled document number of the SOP that governed the execution of this test.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationVersion rdf:type rdf:Property ;
    rdfs:label 'Specification Version' ;
    rdfs:comment 'Version identifier of the product specification or quality standard applied to evaluate this result.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The ideal or nominal value for the test characteristic, representing the center of the specification range.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCategory rdf:type rdf:Property ;
    rdfs:label 'Test Category' ;
    rdfs:comment 'The analytical category or discipline of the QC test method.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Test Characteristic' ;
    rdfs:comment 'The specific quality characteristic or parameter being measured (e.g., purity, concentration, pH, viscosity, sterility).' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The calendar date on which the QC test was performed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodCode rdf:type rdf:Property ;
    rdfs:label 'Test Method Code' ;
    rdfs:comment 'Code identifying the standardized test method or analytical procedure used for this QC measurement.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTimestamp rdf:type rdf:Property ;
    rdfs:label 'Test Timestamp' ;
    rdfs:comment 'The precise date and time when the QC test was executed, supporting audit trail and chronological traceability.' ;
    rdfs:domain ind:QcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the QC test based on the stage of production or purpose of testing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperSpecificationLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Specification Limit' ;
    rdfs:comment 'The maximum acceptable value for the test characteristic as defined in the product specification or quality standard.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationInvestigationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deviation Investigation Owner Employee Id' ;
    rdfs:comment 'Identifier of the Quality Assurance or subject matter expert employee assigned to lead the deviation investigation and root cause analysis.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviationQaReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deviation Qa Reviewer Employee Id' ;
    rdfs:comment 'Identifier of the Quality Assurance reviewer who approved the deviation investigation, impact assessment, and disposition decision. Required for GxP compliance.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviationReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Deviation Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee who initially reported the deviation. Links to workforce management system for accountability and training tracking.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedBatchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Batch Lot Number' ;
    rdfs:comment 'Manufacturing batch or lot number of the product, reagent, or consumable affected by the deviation. Critical for traceability and potential recall decisions.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductSku rdf:type rdf:Property ;
    rdfs:label 'Affected Product Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier of the product impacted by the deviation. Used to assess commercial impact and customer notification requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSopNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Sop Number' ;
    rdfs:comment 'Document control number of the Standard Operating Procedure that was not followed or was inadequate, leading to the deviation.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed narrative description of what occurred, including the specific departure from the approved procedure, specification, or regulatory requirement. Must be sufficiently detailed for regulatory inspection review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current lifecycle state of the deviation: open (newly reported), under_investigation (root cause analysis in progress), pending_approval (awaiting QA sign-off), closed (investigation complete and approved), cancelled (determined not to be a deviation).' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Classification of the deviation by operational category: process (procedure departure), equipment (instrument malfunction), material (reagent/consumable issue), environmental (cleanroom/storage condition), documentation (record error), or personnel (training/qualification gap).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityLocationCode rdf:type rdf:Property ;
    rdfs:label 'Facility Location Code' ;
    rdfs:comment 'Code identifying the manufacturing site, laboratory, or clinical facility where the deviation occurred. Used for site-level trending and regulatory inspection readiness.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of containment actions taken immediately upon discovery of the deviation to prevent further impact, such as quarantine of affected materials, equipment shutdown, or process halt.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Date and time when the deviation actually occurred or was discovered during operations. May differ from reported_timestamp if deviation was identified retrospectively.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Product Impact Assessment' ;
    rdfs:comment 'Quality assessment determining whether the deviation affected product quality, safety, efficacy, or data integrity. Includes scientific justification for disposition decision.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Deviation Flag' ;
    rdfs:comment 'Boolean indicator of whether this deviation is a recurrence of a previously identified and closed deviation, suggesting ineffective CAPA or systemic quality system weakness.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisSummary rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Summary' ;
    rdfs:comment 'Summary of the investigation findings identifying the underlying systemic cause of the deviation. May reference formal RCA methodologies such as 5-Why, Fishbone, or Fault Tree Analysis.' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityGrade rdf:type rdf:Property ;
    rdfs:label 'Severity Grade' ;
    rdfs:comment 'Risk-based severity classification of the deviation impact: critical (patient safety or data integrity risk), major (significant quality impact or regulatory non-compliance), minor (limited impact with no patient or product risk).' ;
    rdfs:domain ind:Deviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedShelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Assigned Shelf Life Months' ;
    rdfs:comment 'Shelf life in months assigned to the product based on stability study results. Determined by the longest time point where all acceptance criteria are met with appropriate statistical confidence. Appears on product labeling and Certificate of Analysis (COA).' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchScale rdf:type rdf:Property ;
    rdfs:label 'Batch Scale' ;
    rdfs:comment 'Manufacturing scale of the lot enrolled in the stability study. Pilot batches are small-scale development batches; production batches are commercial-scale; validation batches are used for process validation and initial regulatory submission.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Reference Flag' ;
    rdfs:comment 'Indicates whether this stability study is referenced on the product Certificate of Analysis (COA) for expiry dating justification. True for primary stability studies supporting shelf-life claims.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerClosureSystem rdf:type rdf:Property ;
    rdfs:label 'Container Closure System' ;
    rdfs:comment 'Description of the primary packaging configuration used in the stability study. Includes container type, material, size, and closure mechanism. Must match commercial packaging to ensure representative stability data.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDateFormat rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Format' ;
    rdfs:comment 'Format specification for expiry date labeling on product packaging. Day-level precision for short shelf-life products; month-level precision for products with shelf life greater than 12 months per regulatory guidance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichClimaticZone rdf:type rdf:Property ;
    rdfs:label 'Ich Climatic Zone' ;
    rdfs:comment 'ICH climatic zone classification for the intended market. Zone I: temperate climate; Zone II: subtropical/Mediterranean; Zone III: hot/dry; Zone IV: hot/humid; Zone IVa: hot/humid with high temperature; Zone IVb: hot/very humid. Determines storage condition requirements.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsStudyReference rdf:type rdf:Property ;
    rdfs:label 'Lims Study Reference' ;
    rdfs:comment 'External identifier for the stability study in LabVantage LIMS. Used for integration with laboratory workflow, sample scheduling, and test result capture.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigator rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Name of the scientist or quality professional responsible for stability study design, execution, and data interpretation. Accountable for study integrity and regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPurpose rdf:type rdf:Property ;
    rdfs:label 'Regulatory Purpose' ;
    rdfs:comment 'Regulatory driver for conducting the stability study. Initial registration supports new product approval; post-approval commitment fulfills regulatory agency requirements; annual stability ensures ongoing compliance; change control evaluates impact of manufacturing changes; shelf-life extension supports expiry date extension; market surveillance monitors commercial product stability.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityIndicatingAssays rdf:type rdf:Property ;
    rdfs:label 'Stability Indicating Assays' ;
    rdfs:comment 'Comma-separated list of analytical test methods used to assess product stability. Examples: HPLC for purity, qPCR for enzyme activity, spectrophotometry for concentration, visual inspection for appearance, pH measurement. These assays must be validated to detect degradation.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Percent' ;
    rdfs:comment 'Target relative humidity percentage for the stability study storage condition. Null for frozen storage conditions where humidity control is not applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Study Completion Date' ;
    rdfs:comment 'Date when the final time point testing was completed and study data analysis finalized. Null for ongoing studies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Total planned duration of the stability study in months. Typical durations: 12-36 months for real-time studies, 6 months for accelerated studies, 12 months for intermediate studies per ICH guidelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyNotes rdf:type rdf:Property ;
    rdfs:label 'Study Notes' ;
    rdfs:comment 'Free-text field for additional study information, observations, and context. Includes notes on study design rationale, deviations, special handling requirements, and lessons learned.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Number' ;
    rdfs:comment 'Unique protocol identifier assigned to the stability study following ICH Q1A/Q1B guidelines. Used for regulatory submission and traceability.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studySponsor rdf:type rdf:Property ;
    rdfs:label 'Study Sponsor' ;
    rdfs:comment 'Business unit or department sponsoring the stability study. Typically Quality Assurance, Regulatory Affairs, or Product Development. Responsible for study oversight and funding.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'Current lifecycle status of the stability study. Planned indicates study design approved but not initiated; active indicates ongoing testing; on-hold indicates temporary suspension; completed indicates all time points tested and data analyzed; cancelled indicates study terminated; under-review indicates final data review and shelf-life determination in progress.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the stability study program. Real-time studies establish shelf life under recommended storage conditions; accelerated studies predict shelf life under elevated stress; intermediate studies bridge real-time and accelerated; stress studies determine degradation pathways; in-use studies assess stability after package opening; photostability studies evaluate light exposure effects.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timePointSchedule rdf:type rdf:Property ;
    rdfs:label 'Time Point Schedule' ;
    rdfs:comment 'Comma-separated list of planned time points in months for sample testing. Example: 0,3,6,9,12,18,24,36 for long-term real-time study. Defines the pull schedule for stability sample testing.' ;
    rdfs:domain ind:StabilityStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDepartments rdf:type rdf:Property ;
    rdfs:label 'Applicable Departments' ;
    rdfs:comment 'Comma-separated list of departments or organizational units to which this curriculum applies (e.g., \'Manufacturing\', \'Quality Control\', \'Research and Development\').' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableJobRoles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Roles' ;
    rdfs:comment 'Comma-separated list or description of job roles, titles, or functions to which this curriculum applies (e.g., \'Manufacturing Operator\', \'Quality Control Analyst\', \'Laboratory Technician\').' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal assessment (test, practical demonstration, competency evaluation) is required upon completion of this curriculum.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Applicable Flag' ;
    rdfs:comment 'Indicates whether this curriculum is required to meet CAP accreditation standards for laboratory personnel training.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curriculumCode rdf:type rdf:Property ;
    rdfs:label 'Curriculum Code' ;
    rdfs:comment 'Unique business identifier for the training curriculum, used for external reference and system integration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumDescription rdf:type rdf:Property ;
    rdfs:label 'Curriculum Description' ;
    rdfs:comment 'Detailed description of the training curriculum purpose, scope, and learning objectives.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumName rdf:type rdf:Property ;
    rdfs:label 'Curriculum Name' ;
    rdfs:comment 'Descriptive name of the training curriculum (e.g., \'GMP Manufacturing Operator Qualification\', \'CLIA Laboratory Personnel Training\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumOwner rdf:type rdf:Property ;
    rdfs:label 'Curriculum Owner' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for maintaining and updating this curriculum.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumType rdf:type rdf:Property ;
    rdfs:label 'Curriculum Type' ;
    rdfs:comment 'Classification of the curriculum by its organizational scope and purpose.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumVersion rdf:type rdf:Property ;
    rdfs:label 'Curriculum Version' ;
    rdfs:comment 'Version number of the training curriculum, incremented upon revision or update.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Applicable Flag' ;
    rdfs:comment 'Indicates whether this curriculum is subject to Good Practice regulations (GMP, GLP, GCP) and requires enhanced documentation and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso13485ApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Applicable Flag' ;
    rdfs:comment 'Indicates whether this curriculum is required to meet ISO 13485 quality management system requirements for medical device personnel.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedDocumentRevisionTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Linked Document Revision Trigger Flag' ;
    rdfs:comment 'Indicates whether a revision to any linked controlled document automatically triggers retraining for personnel assigned to this curriculum.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mastercontrolTrainingReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Training Reference' ;
    rdfs:comment 'External identifier linking this curriculum to its training record in MasterControl document control and training management system.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteCurriculumList rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Curriculum List' ;
    rdfs:comment 'Comma-separated list of training curriculum codes that must be completed before this curriculum can be assigned.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Qualification Level' ;
    rdfs:comment 'The competency or qualification level this curriculum is designed to achieve or maintain.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTrainingCurriculumStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Training Curriculum Status' ;
    rdfs:comment 'Current lifecycle status of the training curriculum.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Regulatory requirement or standard that mandates this training curriculum (e.g., \'FDA 21 CFR Part 211.25\', \'CLIA Personnel Standards 42 CFR 493.1489\', \'ISO 13485:2016 Section 6.2\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentList rdf:type rdf:Property ;
    rdfs:label 'Required Document List' ;
    rdfs:comment 'Comma-separated list of controlled document identifiers (SOPs, work instructions, policies) that are part of this training curriculum.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrainingIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Retraining Interval Months' ;
    rdfs:comment 'Number of months between required retraining cycles. Null if training is initial-only or event-driven.' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Business or regulatory reason for the most recent revision of this curriculum (e.g., \'Updated SOP reference\', \'New regulatory requirement\', \'Process change\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingFrequency rdf:type rdf:Property ;
    rdfs:label 'Training Frequency' ;
    rdfs:comment 'Frequency at which this curriculum must be completed or refreshed (initial, annual, event-driven upon document revision, etc.).' ;
    rdfs:domain ind:QualityTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Unique identifier for the individual training record. Primary key for the training record entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRecord .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who completed or is assigned this training. Links to workforce management system.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTrainingAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Assessor Employee Id' ;
    rdfs:comment 'Unique identifier of the qualified assessor who evaluated the trainee competency. May differ from trainer for on-the-job training (OJT) practical assessments.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforceAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Workforce Assignment Id' ;
    rdfs:comment 'Unique identifier of the training assignment that triggered this training record. Links to training curriculum or assignment management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceAssignment .

ind:assessmentAttempts rdf:type rdf:Property ;
    rdfs:label 'Assessment Attempts' ;
    rdfs:comment 'Number of attempts the trainee made to pass the assessment. Used for identifying training effectiveness issues and retraining needs.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date on which the training certificate was formally issued to the trainee. Used for external certifications and regulatory inspection documentation.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentRevision rdf:type rdf:Property ;
    rdfs:label 'Document Revision' ;
    rdfs:comment 'Revision or version number of the controlled document at the time of training. Critical for demonstrating training currency and compliance with current procedures.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTrainingProvider rdf:type rdf:Property ;
    rdfs:label 'External Training Provider' ;
    rdfs:comment 'Name of the external training organization or vendor that delivered the training. Required for externally-sourced regulatory or technical training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Effective Date' ;
    rdfs:comment 'Date from which the trainee is considered qualified to perform the trained activity. Used for personnel authorization and access control.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date on which the qualification expires and retraining or requalification is required. Used for proactive retraining scheduling and compliance monitoring.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Reference' ;
    rdfs:comment 'Citation of the specific regulatory requirement or standard that mandates this training (e.g., FDA 21 CFR Part 211.25, ISO 13485 Clause 6.2, Clinical Laboratory Improvement Amendments (CLIA) personnel requirements). Used for regulatory inspection readiness.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Retraining Due Date' ;
    rdfs:comment 'Date by which periodic retraining or refresher training must be completed to maintain qualification status. Calculated based on training frequency requirements.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:traineeEmployeeNumber rdf:type rdf:Property ;
    rdfs:label 'Trainee Employee Number' ;
    rdfs:comment 'Human-readable employee number or badge identifier for the trainee. Used for regulatory inspection readiness and audit documentation.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerName rdf:type rdf:Property ;
    rdfs:label 'Trainer Name' ;
    rdfs:comment 'Full name of the qualified trainer or assessor. Used for training certificate generation and regulatory inspection documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'Total cost incurred for this training event, including external provider fees, materials, and internal resource costs. Used for training budget management and cost analysis.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Training Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the training cost amount. Supports multi-currency training cost tracking for global operations.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMethod rdf:type rdf:Property ;
    rdfs:label 'Training Method' ;
    rdfs:comment 'Method by which the training was delivered to the trainee. Determines assessment and documentation requirements per Good Practice (GxP) regulations.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingNotes rdf:type rdf:Property ;
    rdfs:label 'Training Notes' ;
    rdfs:comment 'Free-text notes or comments from the trainer or assessor regarding trainee performance, special circumstances, or follow-up actions required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training event indicating the business driver or trigger for the training requirement. [ENUM-REF-CANDIDATE: initial|refresher|requalification|change_control|capa_driven|role_based|regulatory_mandated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alt5ValidationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Validation Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the validation study record.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryValidationControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Validation Controlled Document Id' ;
    rdfs:comment 'Reference to the controlled validation protocol document in Veeva Vault or MasterControl that defines the study design, procedures, and acceptance criteria.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:primaryValidationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Validation Employee Id' ;
    rdfs:comment 'Reference to the internal department, project, or business unit sponsoring the validation study.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualificationProtocolId rdf:type rdf:Property ;
    rdfs:label 'Qualification Protocol Id' ;
    rdfs:comment 'Foreign key linking to quality.qualification_protocol. Business justification: Validation studies follow a specific qualification protocol; the FK captures this relationship.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationProtocol .

ind:quaternaryValidationRegulatoryApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Validation Regulatory Approver Employee Id' ;
    rdfs:comment 'Reference to the regulatory affairs personnel who approved the validation study for regulatory submission purposes.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryValidationCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Validation Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the validation study record.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryValidationQaReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Validation Qa Reviewer Employee Id' ;
    rdfs:comment 'Reference to the QA personnel responsible for reviewing and approving the validation study report.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conclusionSummary rdf:type rdf:Property ;
    rdfs:label 'Conclusion Summary' ;
    rdfs:comment 'Detailed summary of the validation study conclusion, including key findings, performance metrics achieved, and any deviations or limitations.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processName rdf:type rdf:Property ;
    rdfs:label 'Process Name' ;
    rdfs:comment 'Name of the manufacturing or laboratory process being validated. Applicable for process validation studies.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Primary regulatory standard or guideline governing this validation study, such as FDA 21 CFR Part 11, ICH Q2(R1), CLSI EP05-A3, CLSI EP06-A, CLSI EP15-A3, ISO 13485, or CLIA/CAP requirements.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareSystemName rdf:type rdf:Property ;
    rdfs:label 'Software System Name' ;
    rdfs:comment 'Name of the software system being validated. Applicable for Computer System Validation (CSV) studies.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Date when the validation study execution was completed.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyObjective rdf:type rdf:Property ;
    rdfs:label 'Study Objective' ;
    rdfs:comment 'Detailed objective and purpose of the validation study, including what is being validated and why.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPhase rdf:type rdf:Property ;
    rdfs:label 'Study Phase' ;
    rdfs:comment 'Phase of process validation: phase_1 (process design), phase_2 (process qualification), phase_3 (continued process verification), revalidation (periodic revalidation), ongoing_verification (routine monitoring). Primarily applicable to process validation studies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Descriptive title of the validation study summarizing the scope and purpose.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationConclusion rdf:type rdf:Property ;
    rdfs:label 'Validation Conclusion' ;
    rdfs:comment 'Overall conclusion of the validation study: passed (all acceptance criteria met), failed (one or more criteria not met), conditional_pass (passed with minor deviations or additional controls), inconclusive (insufficient data or study issues prevent conclusion).' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationSubtype rdf:type rdf:Property ;
    rdfs:label 'Validation Subtype' ;
    rdfs:comment 'Further classification of the validation study within the primary type, such as IQ (Installation Qualification), OQ (Operational Qualification), PQ (Performance Qualification) for equipment qualification, or full validation vs partial validation for methods.' ;
    rdfs:domain ind:ValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedToAccountId rdf:type rdf:Property ;
    rdfs:label 'Issued To Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Certificates of Analysis are issued to specific customers for regulatory compliance and quality documentation. Customer-specific CoAs support audit trails for GxP customers and enable tracking of whic' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primarySupersededByCoaId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Coa Id' ;
    rdfs:comment 'Reference to the COA that supersedes this one, if applicable. Used when a COA is reissued due to corrections, additional testing, or updated specifications.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coa .

ind:acceptanceCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Summary' ;
    rdfs:comment 'Summary of the acceptance criteria applied to this lot. May reference specification limits, compendial standards, or customer-specific requirements.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalMethodReferences rdf:type rdf:Property ;
    rdfs:label 'Analytical Method References' ;
    rdfs:comment 'Comma-separated list or structured reference to the analytical methods and standard operating procedures (SOPs) used for testing. Links to controlled method documents.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaStatus rdf:type rdf:Property ;
    rdfs:label 'Coa Status' ;
    rdfs:comment 'Current lifecycle status of the COA document. Tracks progression from draft through approval to release, and handles superseded or voided states for regulatory compliance.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Boolean flag indicating whether this COA is intended for customer delivery. True indicates the COA will be provided to external customers; false indicates internal use only.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationsNoted rdf:type rdf:Property ;
    rdfs:label 'Deviations Noted' ;
    rdfs:comment 'Boolean flag indicating whether any deviations from standard testing procedures or specifications were noted during testing. Triggers investigation and documentation requirements.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpReleaseAuthorized rdf:type rdf:Property ;
    rdfs:label 'Gmp Release Authorized' ;
    rdfs:comment 'Boolean flag indicating whether the lot has been authorized for GMP release based on COA results. True indicates the lot meets all acceptance criteria and is approved for distribution.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Issuing Laboratory' ;
    rdfs:comment 'Name or identifier of the laboratory or facility that performed the QC testing and issued the COA. May be an internal GMP facility or a contracted testing laboratory.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLaboratoryLocation rdf:type rdf:Property ;
    rdfs:label 'Issuing Laboratory Location' ;
    rdfs:comment 'Geographic location or site identifier of the issuing laboratory. Required for regulatory traceability and multi-site operations.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall pass/fail determination for the lot based on all QC tests performed. A pass result authorizes lot release; fail or conditional results trigger investigation and disposition.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Release Authorization Date' ;
    rdfs:comment 'Date on which the lot was authorized for release following COA approval. Critical for regulatory compliance and lot traceability.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedByName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Name' ;
    rdfs:comment 'Full name of the quality control analyst or reviewer who performed the initial review of test results before QA approval.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Document Number' ;
    rdfs:comment 'Controlled document number of the product specification used for testing. Links to the master specification repository.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSummary rdf:type rdf:Property ;
    rdfs:label 'Test Summary' ;
    rdfs:comment 'High-level summary of tests performed, including test names and categories (e.g., identity, purity, potency, sterility). Provides quick overview of COA scope.' ;
    rdfs:domain ind:Coa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingEventId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Event Id' ;
    rdfs:comment 'Unique identifier for the reagent dispensing event record. Primary key for tracking individual material movement transactions.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpBatchRecordId rdf:type rdf:Property ;
    rdfs:label 'Gmp Batch Record Id' ;
    rdfs:comment 'Reference to the GMP batch production record that documents the use of this reagent in manufacturing. Required for FDA-regulated production.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchRecord .

ind:primaryDispensingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Dispensing Employee Id' ;
    rdfs:comment 'Employee or technician who performed the dispensing or transfer operation. Required for GMP chain-of-custody documentation.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Storage location, facility, or inventory site from which the reagent was dispensed or transferred.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:tertiaryDispensingModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Dispensing Modified By Employee Id' ;
    rdfs:comment 'Employee or system user who last modified this dispensing event record. Required for audit trail and data integrity compliance.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chainOfCustodyConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Confirmed Flag' ;
    rdfs:comment 'Indicates whether the material transfer was acknowledged and confirmed by the receiving party or system. Required for GMP audit trails.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant Flag' ;
    rdfs:comment 'Indicates whether the reagent was maintained within required temperature range during the movement event. Critical for temperature-sensitive materials like enzymes and CRISPR reagents.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:custodyConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Custody Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the receiving party confirmed custody of the transferred material.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Destination Reference Code' ;
    rdfs:comment 'Identifier of the specific destination entity (experiment ID, assay run ID, work order number, instrument serial number, or storage location code).' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationType rdf:type rdf:Property ;
    rdfs:label 'Destination Type' ;
    rdfs:comment 'Category of destination receiving the reagent: experiment, assay run, production work order, instrument, storage location, or waste disposal.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingNotes rdf:type rdf:Property ;
    rdfs:label 'Dispensing Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the operator during the dispensing event. May include observations, deviations, or special handling instructions.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP Material Management (MM) document number generated for the goods movement transaction. Links dispensing event to ERP inventory posting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the material movement event: dispense to experiment/assay, internal transfer between storage locations, return to stock, inter-site shipment, instrument consumption, or quarantine relocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Movement Type Code' ;
    rdfs:comment 'SAP MM movement type code (e.g., 261 for goods issue to production, 311 for transfer posting). Standardizes inventory transaction classification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Amount of reagent material moved in this event. Precision supports micro-volume measurements common in genomics workflows.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingLotQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Lot Quantity' ;
    rdfs:comment 'Quantity of reagent remaining in the source lot after this dispensing event. Supports real-time inventory tracking and reorder triggers.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Required storage condition for the reagent: ambient (room temperature), refrigerated (2-8°C), frozen (-20°C), ultra-low (-80°C), or cryogenic (liquid nitrogen).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Source system that generated the dispensing event record: LIMS (Laboratory Information Management System), ERP (Enterprise Resource Planning), MES (Manufacturing Execution System), manual entry, or instrument integration.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature recorded during the dispensing or transfer event, measured in degrees Celsius. Used to verify cold-chain compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature recorded during the dispensing or transfer event, measured in degrees Celsius. Used to verify cold-chain compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business justification for the material movement: lab request, cold-chain relocation, quarantine move, expiry management, facility consolidation, or production demand.' ;
    rdfs:domain ind:DispensingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalRecordId rdf:type rdf:Property ;
    rdfs:label 'Disposal Record Id' ;
    rdfs:comment 'Unique identifier for the reagent disposal record. Primary key.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Disposal Authorization Id' ;
    rdfs:comment 'The authorization or approval identifier issued by quality assurance or management permitting the disposal action.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalAuthorization .

ind:disposalCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Disposal events charge to cost centers for waste management cost tracking, environmental compliance reporting, and variance analysis of expired/failed inventory. Enables financial analysis of disposal' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:authorizedBy rdf:type rdf:Property ;
    rdfs:label 'Authorized By' ;
    rdfs:comment 'Name or identifier of the quality assurance or management personnel who authorized the disposal.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'Reference identifier to the Certificate of Analysis for the disposed lot, linking disposal to original quality documentation.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCost rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost' ;
    rdfs:comment 'The cost incurred for the disposal activity, including vendor fees and internal labor.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Location' ;
    rdfs:comment 'The physical location or facility where the disposal was performed (e.g., warehouse, disposal room, external vendor site).' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNotes rdf:type rdf:Property ;
    rdfs:label 'Disposal Notes' ;
    rdfs:comment 'Free-text field for additional comments, observations, or special instructions related to the disposal activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'The business reason for disposal (e.g., expired, failed quality control, product recall, damage, contamination, obsolescence).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current lifecycle status of the disposal record (e.g., pending approval, approved, completed, cancelled).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Precise date and time when the disposal activity was completed, supporting audit trail requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalVendor rdf:type rdf:Property ;
    rdfs:label 'Disposal Vendor' ;
    rdfs:comment 'Name of the external waste disposal vendor or contractor, if applicable.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'The environmental permit or license number under which the disposal is authorized, if required by local regulations.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Release Status' ;
    rdfs:comment 'The GMP release status of the lot at the time of disposal (e.g., released, quarantined, rejected, blocked).' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcFailureCode rdf:type rdf:Property ;
    rdfs:label 'Qc Failure Code' ;
    rdfs:comment 'The quality control failure code or defect classification if disposal is due to failed QC testing.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDisposed rdf:type rdf:Property ;
    rdfs:label 'Quantity Disposed' ;
    rdfs:comment 'The numeric quantity of reagent or consumable disposed in this transaction.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'The recall identifier if the disposal is part of a product recall action.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsReference rdf:type rdf:Property ;
    rdfs:label 'Sds Reference' ;
    rdfs:comment 'Reference identifier to the Safety Data Sheet document for the reagent, ensuring proper handling and disposal procedures are followed.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationPrior rdf:type rdf:Property ;
    rdfs:label 'Storage Location Prior' ;
    rdfs:comment 'The storage location or bin where the reagent was held immediately before disposal (e.g., quarantine area, expired goods zone).' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Regulatory classification of the waste material for environmental and safety compliance (e.g., hazardous, biohazardous, non-hazardous, chemical, radioactive).' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteManifestNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Manifest Number' ;
    rdfs:comment 'The unique identifier for the waste manifest document that tracks the disposal from generation to final treatment or disposal site.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryBalanceId rdf:type rdf:Property ;
    rdfs:label 'Inventory Balance Id' ;
    rdfs:comment 'Unique identifier for the inventory balance record. Primary key for the inventory balance entity.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsId rdf:type rdf:Property ;
    rdfs:label 'Sds Id' ;
    rdfs:comment 'Reference to the Safety Data Sheet (SDS) document for this reagent. SDS contains hazard information, handling instructions, and emergency procedures required for workplace safety compliance.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sds .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Quantity available for immediate use or reservation, calculated as on-hand quantity minus reserved quantity minus any quality hold quantity. Drives dispensing and allocation logic.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Consignment Flag' ;
    rdfs:comment 'Boolean indicator that this inventory is held on consignment from the vendor and is not owned by the company until consumed. Affects inventory valuation and accounts payable processing. True indicates consignment stock.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysToExpiry rdf:type rdf:Property ;
    rdfs:label 'Days To Expiry' ;
    rdfs:comment 'Number of days remaining until the reagent lot reaches its expiry date. Used for expiry alerts, FEFO prioritization, and inventory aging reports.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Expiry Alert Flag' ;
    rdfs:comment 'Boolean indicator that the reagent lot is approaching expiry (typically within 30-90 days based on business rules). True indicates alert condition requiring expedited usage or disposal planning.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fefoPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Fefo Priority Rank' ;
    rdfs:comment 'Calculated ranking for First Expired First Out (FEFO) dispensing logic. Lower rank indicates earlier expiry and higher dispensing priority. Prevents expiry waste and ensures Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Reason' ;
    rdfs:comment 'Reason code for the most recent inventory adjustment transaction. Supports audit trail, root cause analysis, and inventory accuracy improvement initiatives. [ENUM-REF-CANDIDATE: physical_count|damage|expiry|transfer|correction|theft|spillage|quality_issue — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction (goods receipt, dispensing, transfer, adjustment) affecting this balance record. Used for inventory aging and slow-moving stock analysis.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or cycle count for this reagent lot at this storage location. Supports Good Manufacturing Practice (GMP) inventory reconciliation and audit requirements.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowStockAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Low Stock Alert Flag' ;
    rdfs:comment 'Boolean indicator that the available quantity has fallen below the reorder point, triggering a low-stock alert for procurement action. True indicates alert condition.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the reagent lot was manufactured. Used for shelf-life calculation, traceability, and quality control purposes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum inventory level allowed at the storage location to prevent overstocking, manage storage capacity, and minimize expiry risk. Used for replenishment order quantity calculation.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'Total physical quantity of the reagent lot currently present at the storage location. Represents the actual inventory count before any reservations or allocations.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity of the reagent lot placed under quality hold or quarantine pending Quality Control (QC) inspection, Certificate of Analysis (COA) review, or investigation. Not available for use.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the reagent lot was received into inventory at the storage location. Marks the start of internal shelf-life tracking and inventory aging analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity of the reagent lot that has been reserved or allocated for specific orders, experiments, or production runs but not yet physically dispensed. Reduces available-to-use quantity.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedUseFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Use Flag' ;
    rdfs:comment 'Boolean indicator that this reagent lot has usage restrictions (e.g., Research Use Only (RUO), specific project allocation, regulatory hold). True indicates restricted access requiring authorization.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Valuation Amount' ;
    rdfs:comment 'Total inventory value for this balance record, calculated as on-hand quantity multiplied by valuation price. Used for balance sheet reporting and inventory turnover analysis.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the valuation price (e.g., USD, EUR, GBP). Supports multi-currency inventory valuation.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationPrice rdf:type rdf:Property ;
    rdfs:label 'Valuation Price' ;
    rdfs:comment 'Standard or moving average price per unit of measure used for inventory valuation and Cost of Goods Sold (COGS) calculation. Supports financial reporting and profitability analysis.' ;
    rdfs:domain ind:InventoryBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTransactionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Transaction Id' ;
    rdfs:comment 'Unique identifier for the inventory transaction record. Primary key for the inventory transaction entity.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Storage Location Id' ;
    rdfs:comment 'Storage location to which the reagent was moved. Null for goods issue or consumption transactions where material leaves inventory. References the storage location master data including facility, room, and environmental controls.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:primaryInventoryStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Storage Location Id' ;
    rdfs:comment 'Storage location from which the reagent was moved. Null for goods receipt transactions where material enters inventory from external sources. References the storage location master data including facility, room, and environmental controls.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:reversedTransactionInventoryTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Inventory Transaction Id' ;
    rdfs:comment 'Reference to the original inventory transaction that this record reverses or cancels. Null for original transactions. Populated for reversal entries to maintain audit trail.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryTransaction .

ind:movementReasonCode rdf:type rdf:Property ;
    rdfs:label 'Movement Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the inventory movement, such as production consumption, quality control testing, research and development (R&D) use, expired material disposal, or inventory adjustment.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Reference Document Line Item' ;
    rdfs:comment 'Line item number within the reference document that corresponds to this inventory transaction. Used when a single document contains multiple material movements.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'Type of source document that triggered or authorized this inventory transaction. Enables traceability back to originating business process. [ENUM-REF-CANDIDATE: purchase_order|work_order|transfer_order|sales_order|quality_order|adjustment_document|disposal_record — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionValue rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Value' ;
    rdfs:comment 'Total financial value of the inventory transaction calculated as quantity multiplied by unit cost. Used for financial reporting, inventory valuation, and cost accounting.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNotes rdf:type rdf:Property ;
    rdfs:label 'Transaction Notes' ;
    rdfs:comment 'Free-text notes or comments providing additional context about the inventory transaction, such as special handling instructions, deviation explanations, or operational observations.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the inventory transaction was executed in the operational system. Represents the actual business event time of the inventory movement.' ;
    rdfs:domain ind:InventoryTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit of measure for the reagent at the time of transaction. Used for inventory valuation and Cost of Goods Sold (COGS) calculation. May represent standard cost, moving average price, or actual purchase price depending on valuation method.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kitComponentId rdf:type rdf:Property ;
    rdfs:label 'Kit Component Id' ;
    rdfs:comment 'Unique identifier for the kit component association record. Primary key for the kit_component entity.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Kit Catalog Id' ;
    rdfs:comment 'Reference to the individual component reagent catalog item. Links to the specific reagent, enzyme, buffer, adapter, or consumable that is part of the kit Bill of Materials (BOM).' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:parentKitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Parent Kit Catalog Id' ;
    rdfs:comment 'Reference to the parent multi-component reagent kit catalog item. Links to the master kit product definition in the reagent catalog.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:parentKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Kit parent must reference the commercial catalog item for BOM costing, pricing rollup, and product configuration management. Enables multi-level product structures and kit-to-catalog synchronization f' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:primaryKitSubstituteComponentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Kit Substitute Component Catalog Id' ;
    rdfs:comment 'Reference to an approved substitute component catalog item. Used when the primary component is unavailable or discontinued. Substitution must be validated and documented per Good Manufacturing Practice (GMP) change control procedures.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:componentCostUsd rdf:type rdf:Property ;
    rdfs:label 'Component Cost Usd' ;
    rdfs:comment 'Standard cost of the component in United States Dollars (USD). Used for kit Cost of Goods Sold (COGS) calculation, pricing analysis, and Profit and Loss (P&L) reporting. Confidential business data.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Ordinal position of this component within the kit Bill of Materials (BOM). Used for assembly instructions, kit documentation, and Certificate of Analysis (COA) reporting.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentStabilityDurationDays rdf:type rdf:Property ;
    rdfs:label 'Component Stability Duration Days' ;
    rdfs:comment 'Number of days the component remains stable within the kit under specified storage conditions. Used to calculate kit expiry date based on the shortest-lived component. Critical for In Vitro Diagnostic (IVD) and Research Use Only (RUO) product labeling.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentStorageRequirement rdf:type rdf:Property ;
    rdfs:label 'Component Storage Requirement' ;
    rdfs:comment 'Storage temperature requirement for this component within the kit. Drives warehouse zoning, kit assembly logistics, and shipping validation. Must align with the most restrictive component requirement for the overall kit.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Component Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the component quantity. Aligns with reagent catalog specifications and manufacturing Bill of Materials (BOM) standards. [ENUM-REF-CANDIDATE: ml|ul|mg|ug|units|reactions|wells|tubes — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentVersion rdf:type rdf:Property ;
    rdfs:label 'Component Version' ;
    rdfs:comment 'Version identifier for the component reagent. Tracks formulation changes, protocol updates, and component substitutions over the kit lifecycle. Critical for Lot (LOT) traceability and regulatory submissions.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSubstitutable rdf:type rdf:Property ;
    rdfs:label 'Is Substitutable' ;
    rdfs:comment 'Indicates whether this component can be substituted with an alternative component during kit assembly without requiring protocol changes or revalidation. Used for supply chain flexibility and manufacturing continuity planning.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum acceptable quantity of the component for kit release. Used for Quality Control (QC) inspection and Good Manufacturing Practice (GMP) batch record verification. Values above this threshold trigger non-conformance investigations.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum acceptable quantity of the component for kit release. Used for Quality Control (QC) inspection and Good Manufacturing Practice (GMP) batch record verification. Values below this threshold trigger non-conformance investigations.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresSeparateShipment rdf:type rdf:Property ;
    rdfs:label 'Requires Separate Shipment' ;
    rdfs:comment 'Indicates whether this component must be shipped separately from the main kit due to storage incompatibility, hazardous material regulations, or customs restrictions. True for components requiring dry ice, liquid nitrogen, or dangerous goods handling.' ;
    rdfs:domain ind:KitComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qc Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GxP batch release requires qualified employee signature for regulatory compliance. QC approval is a critical control point in genomics reagent manufacturing; employee identity must be traceable for FD' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reservedForAccountId rdf:type rdf:Property ;
    rdfs:label 'Reserved For Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: GMP lots are frequently manufactured for specific customer contracts or reserved for strategic accounts. Critical for contract fulfillment tracking, consignment inventory management, and regulatory tr' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final disposition status of the lot: available for use, allocated to specific orders or projects, fully consumed, expired and awaiting disposal, returned to supplier, or destroyed.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCoaReference rdf:type rdf:Property ;
    rdfs:label 'Internal Coa Reference' ;
    rdfs:comment 'Document reference or identifier for the internally generated Certificate of Analysis for this lot. Links to the quality documentation in the document management system.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the lot origin: manufactured in-house, purchased from supplier, consignment inventory, sample lot, or rework/reprocessed lot.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Approval Timestamp' ;
    rdfs:comment 'Timestamp when the lot was approved for release by QC/QA. Immutable audit field. Null if not yet approved.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcTestCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Test Completion Date' ;
    rdfs:comment 'Date when all required QC tests for this lot were completed and results finalized. Null if testing is not yet complete.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcTestStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Test Status' ;
    rdfs:comment 'Current status of quality control testing for this lot: not started, in progress, passed, failed, conditional pass (released with restrictions), or waived (testing not required).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Current available quantity of the lot after consumption, allocation, and wastage. Updated in real-time by laboratory information management system (LIMS) and manufacturing execution system (MES).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityManufactured rdf:type rdf:Property ;
    rdfs:label 'Quantity Manufactured' ;
    rdfs:comment 'Total quantity produced or received in this lot, expressed in the unit of measure defined for the reagent (e.g., liters, kilograms, units, reactions).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Free-text explanation of why the lot is quarantined. Examples: pending incoming inspection, QC test failure investigation, supplier quality alert, deviation under review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Free-text explanation of the regulatory hold. Examples: FDA inspection finding, supplier quality alert, product recall, import detention.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilizationDate rdf:type rdf:Property ;
    rdfs:label 'Sterilization Date' ;
    rdfs:comment 'Date the lot was sterilized. Null if sterilization is not applicable or not performed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierCoaReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Coa Reference' ;
    rdfs:comment 'Document reference or identifier for the supplier\'s Certificate of Analysis. Links to the quality documentation provided by the supplier.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Number' ;
    rdfs:comment 'Lot or batch number assigned by the supplier. Used for traceability back to the supplier\'s manufacturing records and for supplier quality investigations.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Supplier Quality Grade' ;
    rdfs:comment 'Quality grade or certification level assigned by the supplier: Research Use Only (RUO), GMP Grade, Clinical Grade, In Vitro Diagnostic (IVD) Grade, or Molecular Biology Grade. Determines permissible use cases.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:traceabilityCode rdf:type rdf:Property ;
    rdfs:label 'Traceability Code' ;
    rdfs:comment 'Unique traceability identifier used for end-to-end supply chain tracking, including serialization and aggregation per regulatory requirements (e.g., FDA UDI, EU IVDR).' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Method Validation Study Id' ;
    rdfs:comment 'Reference to the analytical method validation study that established the scientific basis for this specification. Links to validation protocol and report documentation.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValidationStudy .

ind:owningCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Owning Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: QC testing specifications are owned and maintained by quality assurance cost centers. Required for quality cost allocation, method validation cost tracking, and SOX control documentation linking testi' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:acceptanceCriteriaType rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Type' ;
    rdfs:comment 'Format of the acceptance criteria: numeric_range (min-max bounds), minimum_threshold (greater than or equal to), maximum_threshold (less than or equal to), pass_fail (binary result), qualitative (descriptive evaluation).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalParameter rdf:type rdf:Property ;
    rdfs:label 'Analytical Parameter' ;
    rdfs:comment 'Specific quality attribute being measured (e.g., Purity, Concentration, pH, Endotoxin Level, Enzyme Activity, Amplification Efficiency).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProductGrade rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Grade' ;
    rdfs:comment 'Regulatory grade of reagent to which this specification applies: RUO (Research Use Only), IVD (In Vitro Diagnostic), GMP (Good Manufacturing Practice), research (basic research), clinical (clinical trial use). Specifications may differ by grade.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoaReportable rdf:type rdf:Property ;
    rdfs:label 'Is Coa Reportable' ;
    rdfs:comment 'Indicates whether test results for this specification must be included on the Certificate of Analysis (COA) provided to customers. True for customer-facing specifications, false for internal-only tests.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStabilityIndicating rdf:type rdf:Property ;
    rdfs:label 'Is Stability Indicating' ;
    rdfs:comment 'Indicates whether this specification is used in stability studies to establish reagent shelf life and storage conditions. True for parameters that degrade over time (e.g., enzyme activity, purity).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfSpecificationEscalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Out Of Specification Escalation Procedure' ;
    rdfs:comment 'Reference to the procedure or workflow triggered when test results fail this specification (e.g., \'Initiate OOS investigation per SOP-QA-5678\', \'Quarantine lot and notify QA Manager\'). Supports deviation management.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Criteria Description' ;
    rdfs:comment 'Textual description of acceptance criteria for qualitative or pass/fail tests (e.g., \'No visible particulates\', \'Amplification curve within 3 Ct of reference\', \'Sterility test shows no growth\').' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandardReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Reference' ;
    rdfs:comment 'Citation of the regulatory standard or compendial method governing this specification (e.g., USP <85>, EP 2.6.14, FDA Guidance for Industry, ISO 13485:2016 Section 7.5.6).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeRequirement rdf:type rdf:Property ;
    rdfs:label 'Sample Size Requirement' ;
    rdfs:comment 'Required sample size or sampling plan for the test (e.g., \'n=3 replicates\', \'AQL 1.5\', \'10 units per lot\'). Supports statistical quality control.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCode rdf:type rdf:Property ;
    rdfs:label 'Specification Code' ;
    rdfs:comment 'Business identifier for the QC specification. Unique alphanumeric code used in quality documentation and Certificate of Analysis (COA) references.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationRationale rdf:type rdf:Property ;
    rdfs:label 'Specification Rationale' ;
    rdfs:comment 'Scientific and regulatory justification for the acceptance criteria limits. Documents the basis for specification setting (e.g., \'Based on method validation data showing 95% confidence interval\', \'Aligned with USP monograph requirements\').' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Category of QC specification defining the nature of the quality test: identity (confirms correct reagent), purity (contaminant levels), potency (biological activity), sterility (microbial contamination), endotoxin (bacterial toxin levels), functional (performance in assay).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFrequency rdf:type rdf:Property ;
    rdfs:label 'Test Frequency' ;
    rdfs:comment 'Required frequency of testing for this specification: per_lot (every manufacturing lot), per_batch (every production batch), periodic (scheduled intervals), skip_lot (reduced testing per approved plan), continuous (in-process monitoring).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodName rdf:type rdf:Property ;
    rdfs:label 'Test Method Name' ;
    rdfs:comment 'Name of the analytical test method used to evaluate the reagent (e.g., HPLC Purity Analysis, Endotoxin LAL Assay, qPCR Functional Performance).' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethodSopReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Sop Reference' ;
    rdfs:comment 'Document control number of the Standard Operating Procedure (SOP) defining the test method execution (e.g., SOP-QC-1234). Supports method validation and audit traceability.' ;
    rdfs:domain ind:QcSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Originating Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Catalog products often originate from R&D projects before commercialization (assay development, novel reagent formulations). Tracks technology transfer from research to commercial catalog. Essential f' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:strategicAccountId rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Strategic pharma/biotech accounts often have custom-validated or co-developed reagent products. Tracks which reagents are approved/qualified for specific customer workflows, supporting sales targeting' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:catalogNumber rdf:type rdf:Property ;
    rdfs:label 'Catalog Number' ;
    rdfs:comment 'Externally-known unique catalog number or SKU (Stock Keeping Unit) for the reagent product. Used for ordering, inventory management, and customer communication.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coa Required Flag' ;
    rdfs:comment 'Indicates whether a COA (Certificate of Analysis) is required for each LOT (Lot Number) of this reagent. True indicates COA must be issued; False indicates no COA requirement. COAs document QC test results and compliance.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibleInstruments rdf:type rdf:Property ;
    rdfs:label 'Compatible Instruments' ;
    rdfs:comment 'List of instrument platforms or models compatible with this reagent. Critical for flow cells, sequencing kits, and instrument-specific consumables. Comma-separated list of instrument identifiers.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentration rdf:type rdf:Property ;
    rdfs:label 'Concentration' ;
    rdfs:comment 'Concentration specification of the reagent with units (e.g., 10X, 5 mg/ml, 100 mM). Critical for protocol development and quality control.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCycleLimit rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Cycle Limit' ;
    rdfs:comment 'Maximum number of freeze-thaw cycles the reagent can withstand before degradation. Critical for maintaining reagent performance and ensuring reproducible results.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmpCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant Flag' ;
    rdfs:comment 'Indicates whether the reagent is manufactured under GMP (Good Manufacturing Practice) regulations. True indicates GMP-compliant manufacturing; False indicates non-GMP. Critical for IVD and clinical applications.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intendedApplication rdf:type rdf:Property ;
    rdfs:label 'Intended Application' ;
    rdfs:comment 'Primary intended use case or application for the reagent. Describes the genomic workflow or assay type the reagent is designed for (e.g., NGS library preparation, WGS, WES, CRISPR gene editing, qPCR, SNP genotyping, array hybridization).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightSensitivityFlag rdf:type rdf:Property ;
    rdfs:label 'Light Sensitivity Flag' ;
    rdfs:comment 'Indicates whether the reagent is light-sensitive and requires storage in dark or amber containers. True indicates light-sensitive; False indicates no special light protection required.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'Quantity of reagent per package in the specified unit_of_measure. Defines the standard package configuration for ordering and inventory.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:puritySpecification rdf:type rdf:Property ;
    rdfs:label 'Purity Specification' ;
    rdfs:comment 'Purity level or grade specification of the reagent (e.g., >95%, molecular biology grade, sequencing grade). Ensures reagent quality meets application requirements.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlTestedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Control Tested Flag' ;
    rdfs:comment 'Indicates whether each LOT (Lot Number) of this reagent undergoes QC (Quality Control) testing before release. True indicates mandatory QC testing; False indicates no routine QC testing required.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reagentCategory rdf:type rdf:Property ;
    rdfs:label 'Reagent Category' ;
    rdfs:comment 'Secondary hierarchical category classification for the reagent. Provides finer-grained grouping within reagent_type (e.g., polymerase, ligase, restriction enzyme under enzyme type). [ENUM-REF-CANDIDATE: library_prep|sequencing|pcr_qpcr|gene_editing|array_hybridization|sample_prep|quality_control|storage_transport — promote to reference product]' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentType rdf:type rdf:Property ;
    rdfs:label 'Reagent Type' ;
    rdfs:comment 'Primary classification of the reagent product type. Categorizes reagents into major functional groups for inventory and usage tracking.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterilityRequirement rdf:type rdf:Property ;
    rdfs:label 'Sterility Requirement' ;
    rdfs:comment 'Sterility classification of the reagent. Sterile indicates validated sterile manufacturing; non_sterile indicates no sterility requirement; aseptic indicates aseptic processing without terminal sterilization.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageHumidityMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Max Percent' ;
    rdfs:comment 'Maximum relative humidity requirement for storage as a percentage. Prevents moisture-related degradation of reagent components.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageHumidityMinPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Humidity Min Percent' ;
    rdfs:comment 'Minimum relative humidity requirement for storage as a percentage. Ensures reagent stability in controlled environmental conditions.' ;
    rdfs:domain ind:Catalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Unique identifier for the recall event record. Primary key.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedAccountId rdf:type rdf:Property ;
    rdfs:label 'Affected Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Recalls must identify which customers received affected lots for notification and retrieval. Regulatory requirement (FDA 21 CFR Part 7) for traceability. Supports recall effectiveness checks and custo' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:affectedRdProjectId rdf:type rdf:Property ;
    rdfs:label 'Affected Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Recalls of research-grade reagents require project impact assessment to determine if active research is affected and whether experiments need repeating. Critical for research continuity planning and r' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:internalInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Internal Investigation Id' ;
    rdfs:comment 'Reference identifier linking this recall event to the internal quality investigation or non-conformance report that triggered the recall.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalInvestigation .

ind:responsibleCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Responsible Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Recall investigations and remediation costs are charged to responsible cost centers. Critical for financial impact analysis, insurance claims processing, quality cost reporting, and management account' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Recall events require internal employee ownership for CAPA execution, regulatory reporting (FDA/EMA), and customer communication. Links to employee record for contact information, organizational accou' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventCount rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Count' ;
    rdfs:comment 'Number of reported adverse events (injuries, incorrect results, patient harm) associated with the recalled product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Numbers' ;
    rdfs:comment 'Comma-separated list of reagent lot numbers affected by this recall event. Critical for traceability and scope determination.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Affected Unit Count' ;
    rdfs:comment 'Total number of product units (kits, vials, flow cells, etc.) affected by the recall across all lots and distribution channels.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Completion Date' ;
    rdfs:comment 'Date when all corrective and preventive actions were verified as complete and effective. Null if CAPA is still in progress.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerComplaintCount rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Count' ;
    rdfs:comment 'Number of customer complaints received related to the defect or issue that led to the recall event.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Status of customer notification activities: not_started (notifications pending), in_progress (notifications being sent), or completed (all customers notified).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionMethod rdf:type rdf:Property ;
    rdfs:label 'Disposition Method' ;
    rdfs:comment 'Method used to dispose of retrieved recalled products: destruction (incineration/disposal), rework (repair/reprocess), return_to_vendor, or quarantine (hold for investigation).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Geographic scope of product distribution affected by the recall: internal_only (internal labs), domestic (within country), international (multiple countries), or global (worldwide distribution).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact' ;
    rdfs:comment 'Estimated total financial impact of the recall event in USD, including product replacement costs, retrieval logistics, customer credits, and regulatory penalties.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthHazardEvaluation rdf:type rdf:Property ;
    rdfs:label 'Health Hazard Evaluation' ;
    rdfs:comment 'Assessment of the potential health risk posed by the defective product, including probability and severity of adverse events. Used to determine recall classification.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'Date when the recall event was officially initiated and announced to stakeholders.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date when initial customer notifications were sent regarding the recall event.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Primary method used to notify affected customers and stakeholders about the recall event.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'Date when the public press release was issued. Null if no press release was issued.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseIssued rdf:type rdf:Property ;
    rdfs:label 'Press Release Issued' ;
    rdfs:comment 'Boolean flag indicating whether a public press release was issued for this recall event. True if press release was issued, False otherwise.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA recall classification indicating the severity of the health hazard: Class I (serious injury or death), Class II (temporary or reversible adverse health consequences), Class III (unlikely to cause adverse health consequences).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEffectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Check Date' ;
    rdfs:comment 'Date when the recall effectiveness check was conducted to verify that the recall achieved its intended purpose and all affected products were retrieved.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallEffectivenessResult rdf:type rdf:Property ;
    rdfs:label 'Recall Effectiveness Result' ;
    rdfs:comment 'Result of the recall effectiveness check: effective (recall goals met), partially_effective (some goals met), ineffective (recall goals not met), or pending (check not yet completed).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event: initiated (recall announced), ongoing (retrieval in progress), completed (all actions finished), terminated (recall stopped), or closed (regulatory closure achieved).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Type of recall action: voluntary (initiated by manufacturer), mandatory (required by regulatory authority), field correction (on-site correction without removal), or market withdrawal (removal for non-safety reasons).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory report submitted to authorities (e.g., FDA MedWatch report number, IVDR vigilance report ID).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retrieval Completion Percentage' ;
    rdfs:comment 'Percentage of affected units successfully retrieved, calculated as (units_retrieved / affected_unit_count) * 100. Key performance indicator for recall effectiveness.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsRetrieved rdf:type rdf:Property ;
    rdfs:label 'Units Retrieved' ;
    rdfs:comment 'Number of affected product units successfully retrieved from customers and internal inventory as of the current status update.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accidentalReleaseMeasures rdf:type rdf:Property ;
    rdfs:label 'Accidental Release Measures' ;
    rdfs:comment 'Emergency procedures, protective equipment, and proper methods for containment and cleanup of spills or leaks. Section 6 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service to every chemical substance. Format: XXXXXX-XX-X.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compositionDescription rdf:type rdf:Property ;
    rdfs:label 'Composition Description' ;
    rdfs:comment 'Detailed description of the chemical composition, including hazardous ingredients, concentration ranges, and CAS numbers for components. Section 3 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIssue rdf:type rdf:Property ;
    rdfs:label 'Country Of Issue' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the country for which this SDS was prepared (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalConsiderations rdf:type rdf:Property ;
    rdfs:label 'Disposal Considerations' ;
    rdfs:comment 'Guidance on proper disposal methods, waste treatment, and applicable regulations for the substance and contaminated packaging. Section 13 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLanguage rdf:type rdf:Property ;
    rdfs:label 'Document Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language in which this SDS is written (e.g., ENG for English, DEU for German).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecNumber rdf:type rdf:Property ;
    rdfs:label 'Ec Number' ;
    rdfs:comment 'Seven-digit identifier assigned to chemical substances registered in the European Union. Format: XXX-XXX-X.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Ecological Information' ;
    rdfs:comment 'Environmental effects including ecotoxicity, persistence and degradability, bioaccumulative potential, and mobility in soil. Section 12 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Phone' ;
    rdfs:comment '24-hour emergency telephone number for chemical emergencies (e.g., CHEMTREC, manufacturer emergency line). Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureControls rdf:type rdf:Property ;
    rdfs:label 'Exposure Controls' ;
    rdfs:comment 'Occupational exposure limits, engineering controls, and personal protective equipment recommendations (respiratory, hand, eye, skin protection). Section 8 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firefightingMeasures rdf:type rdf:Property ;
    rdfs:label 'Firefighting Measures' ;
    rdfs:comment 'Suitable extinguishing media, specific hazards arising from the chemical, and special protective equipment for firefighters. Section 5 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAidMeasures rdf:type rdf:Property ;
    rdfs:label 'First Aid Measures' ;
    rdfs:comment 'Instructions for first aid treatment following exposure by different routes (inhalation, skin contact, eye contact, ingestion). Section 4 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification' ;
    rdfs:comment 'GHS hazard class and category codes for the substance (e.g., Flam. Liq. 2, Acute Tox. 3, Skin Corr. 1A). Multiple classifications separated by semicolons.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingPrecautions rdf:type rdf:Property ;
    rdfs:label 'Handling Precautions' ;
    rdfs:comment 'Precautions for safe handling including advice on protective measures, hygiene practices, and conditions to avoid. Section 7 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatements rdf:type rdf:Property ;
    rdfs:label 'Hazard Statements' ;
    rdfs:comment 'Standardized GHS hazard statement codes and text describing the nature of the hazards (e.g., H225: Highly flammable liquid and vapor). Multiple statements separated by semicolons.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerAddress rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Address' ;
    rdfs:comment 'Complete mailing address of the manufacturer or supplier. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPhone rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Phone' ;
    rdfs:comment 'Primary contact telephone number for the manufacturer or supplier. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalProperties rdf:type rdf:Property ;
    rdfs:label 'Physical Properties' ;
    rdfs:comment 'Physical and chemical characteristics including appearance, odor, pH, melting point, boiling point, flash point, vapor pressure, density, solubility. Section 9 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pictogramCodes rdf:type rdf:Property ;
    rdfs:label 'Pictogram Codes' ;
    rdfs:comment 'GHS pictogram codes indicating hazard symbols (e.g., GHS02 for flame, GHS06 for skull and crossbones). Multiple codes separated by semicolons.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatements rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statements' ;
    rdfs:comment 'Standardized GHS precautionary statement codes and text describing recommended measures to minimize or prevent adverse effects (e.g., P210: Keep away from heat/sparks/open flames). Multiple statements separated by semicolons.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Reach Registration Number' ;
    rdfs:comment 'Registration number issued under the EU REACH regulation for substances manufactured or imported in quantities of one tonne or more per year.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInformation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Information' ;
    rdfs:comment 'Safety, health, and environmental regulations specific to the product including TSCA, REACH, OSHA, EPA listings and restrictions. Section 15 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when this version of the SDS was last revised or updated. Critical for ensuring users have current safety information.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Number' ;
    rdfs:comment 'Business identifier for the SDS document, typically assigned by the manufacturer or regulatory system. Externally-known unique code.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsStatus rdf:type rdf:Property ;
    rdfs:label 'Sds Status' ;
    rdfs:comment 'Current lifecycle status of the SDS document. Active indicates the document is currently in use; superseded indicates it has been replaced by a newer version.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalWord rdf:type rdf:Property ;
    rdfs:label 'Signal Word' ;
    rdfs:comment 'GHS signal word indicating the relative level of severity of hazard: Danger (more severe) or Warning (less severe).' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityReactivity rdf:type rdf:Property ;
    rdfs:label 'Stability Reactivity' ;
    rdfs:comment 'Chemical stability, possibility of hazardous reactions, conditions to avoid, incompatible materials, and hazardous decomposition products. Section 10 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Conditions for safe storage including temperature range, humidity control, incompatible materials, and special storage requirements. Section 7 of SDS.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDate rdf:type rdf:Property ;
    rdfs:label 'Supersedes Date' ;
    rdfs:comment 'Date of the previous SDS version that this document replaces. Nullable for initial SDS versions.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:toxicologicalInformation rdf:type rdf:Property ;
    rdfs:label 'Toxicological Information' ;
    rdfs:comment 'Information on toxicological effects including routes of exposure, symptoms, acute and chronic effects, and numerical measures of toxicity (LD50, LC50). Section 11 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportInformation rdf:type rdf:Property ;
    rdfs:label 'Transport Information' ;
    rdfs:comment 'Transportation classification including UN number, proper shipping name, transport hazard class, packing group, and environmental hazards. Section 14 of SDS.' ;
    rdfs:domain ind:Sds ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Reference to the parent facility or site where this storage location physically resides. Links to facility master data for geographic and organizational context.' ;
    rdfs:domain ind:Reagent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:parentLocationStorageLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Storage Location Id' ;
    rdfs:comment 'Reference to the parent storage location in a hierarchical storage structure. Enables nested location modeling such as freezer containing shelves containing racks.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageLocation .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Machine-readable barcode identifier affixed to the physical storage location. Used for automated inventory scanning and LIMS integration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Identifier for the specific building within the facility where the storage location is situated. Supports multi-building campus environments.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityOccupiedUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Occupied Units' ;
    rdfs:comment 'Current number of storage units occupied in this location. Updated by LIMS during inventory transactions to track utilization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityTotalUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Total Units' ;
    rdfs:comment 'Maximum number of storage units (e.g., boxes, vials, plates) that can be accommodated in this location. Used for capacity planning and space optimization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for capacity tracking. Defines what constitutes one storage unit for capacity calculations. [ENUM-REF-CANDIDATE: box|vial|plate|tube|bottle|bag|container — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitor Device Code' ;
    rdfs:comment 'Identifier for the temperature/humidity monitoring device or sensor linked to this storage location. Enables traceability to environmental monitoring records.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fefoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fefo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FEFO inventory management rules are enforced for this storage location. When true, LIMS will prioritize inventory with nearest expiry dates for picking.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforcement Flag' ;
    rdfs:comment 'Indicates whether FIFO inventory management rules are enforced for this storage location. When true, LIMS will prioritize oldest inventory for picking.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gmp Qualification Status' ;
    rdfs:comment 'GMP qualification state of the storage location. Indicates whether the location has passed Installation Qualification (IQ), Operational Qualification (OQ), and Performance Qualification (PQ) protocols.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Approved Flag' ;
    rdfs:comment 'Indicates whether this storage location is approved for storing hazardous or flammable reagents. Requires special safety equipment and ventilation per Safety Data Sheet (SDS) requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name or label for the storage location, used for identification and reporting purposes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location based on environmental control and physical characteristics. Determines applicable storage protocols and monitoring requirements.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Requalification Date' ;
    rdfs:comment 'Scheduled date for the next periodic requalification of the storage location. Supports proactive compliance management and maintenance planning.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roomNumber rdf:type rdf:Property ;
    rdfs:label 'Room Number' ;
    rdfs:comment 'Room or area identifier within the building where the storage location is positioned. Used for physical navigation and access control.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfPosition rdf:type rdf:Property ;
    rdfs:label 'Shelf Position' ;
    rdfs:comment 'Granular position identifier within the storage unit, such as shelf level, rack number, or drawer position. Enables precise inventory localization.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Location Status' ;
    rdfs:comment 'Current operational status of the storage location. Controls whether the location can accept new inventory assignments and reflects qualification state.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetHumidityMaxPct rdf:type rdf:Property ;
    rdfs:label 'Target Humidity Max Pct' ;
    rdfs:comment 'Upper bound of the acceptable relative humidity range for this storage location as a percentage. Applicable for humidity-sensitive reagent storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetHumidityMinPct rdf:type rdf:Property ;
    rdfs:label 'Target Humidity Min Pct' ;
    rdfs:comment 'Lower bound of the acceptable relative humidity range for this storage location as a percentage. Applicable for humidity-sensitive reagent storage.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max C' ;
    rdfs:comment 'Upper bound of the acceptable temperature range for this storage location in degrees Celsius. Used for environmental monitoring and alarm thresholds.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min C' ;
    rdfs:comment 'Lower bound of the acceptable temperature range for this storage location in degrees Celsius. Used for environmental monitoring and alarm thresholds.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Designated temperature control zone for the storage location. Determines which reagent types can be stored and monitoring requirements per GMP guidelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Unit Identifier' ;
    rdfs:comment 'Specific equipment unit identifier such as freezer serial number, refrigerator asset tag, or shelf unit code. Links to equipment master for maintenance tracking.' ;
    rdfs:domain ind:StorageLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acmgClassificationRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification Rule Status' ;
    rdfs:comment 'Current lifecycle status of this evidence code specification. Active rules are used in production variant interpretation; deprecated rules are retained for historical audit but not applied to new cases.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allelicDataRequirement rdf:type rdf:Property ;
    rdfs:label 'Allelic Data Requirement' ;
    rdfs:comment 'Description of requirements related to allelic phase, compound heterozygosity, or trans configuration for this evidence code. Applicable to PM3, BP2 criteria.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGeneContexts rdf:type rdf:Property ;
    rdfs:label 'Applicable Gene Contexts' ;
    rdfs:comment 'Description of gene or disease mechanism contexts where this evidence code is applicable (e.g., \'genes where loss-of-function is a known disease mechanism\', \'genes with established functional domains\'). May reference specific gene lists or disease categories.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableVariantTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Variant Types' ;
    rdfs:comment 'Comma-separated list or description of variant types to which this evidence code applies (e.g., \'nonsense, frameshift, canonical splice site\', \'missense\', \'in-frame indel\'). Defines the molecular consequence scope.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoritativeSource rdf:type rdf:Property ;
    rdfs:label 'Authoritative Source' ;
    rdfs:comment 'The authoritative body or publication that defines this evidence code (e.g., \'ACMG/AMP 2015 Guidelines\', \'ClinGen Hearing Loss Expert Panel\', \'ClinGen CDH1 Variant Curation Expert Panel\').' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationFlag rdf:type rdf:Property ;
    rdfs:label 'Automation Flag' ;
    rdfs:comment 'Indicates whether this evidence code can be fully or partially automated in computational variant annotation pipelines (True) or requires manual expert review (False).' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clingenRefinementSpecification rdf:type rdf:Property ;
    rdfs:label 'Clingen Refinement Specification' ;
    rdfs:comment 'Reference to ClinGen-specific refinements, gene-disease-specific adaptations, or expert panel recommendations that modify or clarify the application of this evidence code for particular contexts.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationalPredictionRequirement rdf:type rdf:Property ;
    rdfs:label 'Computational Prediction Requirement' ;
    rdfs:comment 'Description of in silico prediction tool requirements and consensus thresholds for this evidence code (e.g., \'multiple lines of computational evidence support deleterious effect\'). Applicable to PP3, BP4 criteria.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceRequirements rdf:type rdf:Property ;
    rdfs:label 'Data Source Requirements' ;
    rdfs:comment 'List or description of required reference databases, population frequency datasets, functional assay repositories, or literature sources needed to apply this evidence code (e.g., \'gnomAD, ClinVar, HGMD, functional studies\').' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deNovoRequirement rdf:type rdf:Property ;
    rdfs:label 'De Novo Requirement' ;
    rdfs:comment 'Description of de novo variant occurrence requirements for this evidence code, including maternity/paternity confirmation standards. Applicable to PS2, PM6 criteria.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCategory rdf:type rdf:Property ;
    rdfs:label 'Evidence Category' ;
    rdfs:comment 'High-level classification of whether this evidence code supports pathogenic or benign interpretation of variants.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCode rdf:type rdf:Property ;
    rdfs:label 'Evidence Code' ;
    rdfs:comment 'The standardized ACMG/AMP evidence code identifier (e.g., PVS1, PS1, PM1, PP1, BA1, BS1, BP1). Defines the specific criterion used for variant pathogenicity assessment. [ENUM-REF-CANDIDATE: PVS1|PS1|PS2|PS3|PS4|PM1|PM2|PM3|PM4|PM5|PM6|PP1|PP2|PP3|PP4|PP5|BA1|BS1|BS2|BS3|BS4|BP1|BP2|BP3|BP4|BP5|BP6|BP7 — 28 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Detailed textual description of the evidence criterion, including the biological or clinical rationale, applicability conditions, and interpretation guidance.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceName rdf:type rdf:Property ;
    rdfs:label 'Evidence Name' ;
    rdfs:comment 'Human-readable short name or title of the evidence criterion (e.g., \'Null variant in a gene where LOF is a known mechanism\', \'Same amino acid change as established pathogenic variant\').' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyThreshold rdf:type rdf:Property ;
    rdfs:label 'Frequency Threshold' ;
    rdfs:comment 'Numeric threshold for population allele frequency (MAF) used in applying this evidence code, if applicable. For example, BA1 uses a threshold of >5% in population databases. Null if not frequency-based.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalAssayRequirement rdf:type rdf:Property ;
    rdfs:label 'Functional Assay Requirement' ;
    rdfs:comment 'Description of functional or experimental evidence requirements for this criterion (e.g., \'well-established functional studies showing damaging effect\', \'validated assay demonstrating normal function\'). Applicable to PS3, BS3, and related codes.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationLogic rdf:type rdf:Property ;
    rdfs:label 'Implementation Logic' ;
    rdfs:comment 'Structured or semi-structured description of the computational or manual logic required to evaluate this evidence code. May include decision trees, data source requirements, thresholds, or algorithmic steps for automated variant annotation pipelines.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Manual Review Required' ;
    rdfs:comment 'Indicates whether application of this evidence code mandates manual review by a clinical molecular geneticist or variant scientist, even if computational pre-screening is performed.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phenotypeSpecificityRequirement rdf:type rdf:Property ;
    rdfs:label 'Phenotype Specificity Requirement' ;
    rdfs:comment 'Description of patient phenotype matching requirements for this evidence code, including specificity of clinical features to the gene-disease association. Applicable to PP4 criterion.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Citation or PubMed identifier (PMID) for the primary publication or guideline document that defines this evidence code.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reputableSourceRequirement rdf:type rdf:Property ;
    rdfs:label 'Reputable Source Requirement' ;
    rdfs:comment 'Description of requirements for reputable source reporting of this variant as pathogenic or benign, including acceptable databases and curation standards. Applicable to PP5, BP6 criteria.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationRequirement rdf:type rdf:Property ;
    rdfs:label 'Segregation Requirement' ;
    rdfs:comment 'Description of family segregation analysis requirements for this evidence code, including minimum number of affected family members or LOD score thresholds. Applicable to PP1 and related criteria.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthLevel rdf:type rdf:Property ;
    rdfs:label 'Strength Level' ;
    rdfs:comment 'The weight or strength tier assigned to this evidence code (very strong, strong, moderate, supporting, or stand-alone for benign criteria). Determines the contribution of this criterion to the final pathogenicity classification.' ;
    rdfs:domain ind:AcmgClassificationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTrackGeneAnnotationTrackId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Track Gene Annotation Track Id' ;
    rdfs:comment 'Reference to the gene_annotation_track_id of the newer annotation track that supersedes this one, if deprecated.' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneAnnotationTrack .

ind:annotationMethod rdf:type rdf:Property ;
    rdfs:label 'Annotation Method' ;
    rdfs:comment 'Description of the computational or manual method used to generate the annotation track (e.g., GENCODE manual curation, Ensembl automated pipeline).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationSource rdf:type rdf:Property ;
    rdfs:label 'Annotation Source' ;
    rdfs:comment 'The authoritative source or provider of the gene annotation track (e.g., GENCODE, RefSeq, Ensembl, UCSC, or Custom internal models).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biotypeClassifications rdf:type rdf:Property ;
    rdfs:label 'Biotype Classifications' ;
    rdfs:comment 'Comma-separated list of gene biotype categories included in this track (e.g., protein_coding, lncRNA, miRNA, pseudogene, snRNA, snoRNA).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'The primary publication or citation reference for this annotation track (e.g., PubMed ID, DOI).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatiblePipelines rdf:type rdf:Property ;
    rdfs:label 'Compatible Pipelines' ;
    rdfs:comment 'Comma-separated list of internal bioinformatics pipeline names or identifiers that are compatible with this annotation track.' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'The coordinate system convention used in this annotation track (0-based half-open for BED, 1-based closed for GTF/GFF3).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'The file format of the annotation track (e.g., GTF, GFF3, BED, GenBank).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneAnnotationTrackStatus rdf:type rdf:Property ;
    rdfs:label 'Gene Annotation Track Status' ;
    rdfs:comment 'Current lifecycle status of the annotation track (active for production use, deprecated for superseded versions, archived for historical reference, under_review for validation in progress).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneCount rdf:type rdf:Property ;
    rdfs:label 'Gene Count' ;
    rdfs:comment 'Total number of gene features annotated in this track.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lncrnaGeneCount rdf:type rdf:Property ;
    rdfs:label 'Lncrna Gene Count' ;
    rdfs:comment 'Number of long non-coding RNA genes annotated in this track.' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proteinCodingGeneCount rdf:type rdf:Property ;
    rdfs:label 'Protein Coding Gene Count' ;
    rdfs:comment 'Number of protein-coding genes in this annotation track.' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pseudogeneCount rdf:type rdf:Property ;
    rdfs:label 'Pseudogene Count' ;
    rdfs:comment 'Number of pseudogenes annotated in this track.' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseVersion rdf:type rdf:Property ;
    rdfs:label 'Release Version' ;
    rdfs:comment 'The specific release or version number of the annotation track (e.g., v38, Release 109, 2021-07).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'The official URL or FTP location from which the annotation track was downloaded (e.g., ftp://ftp.ebi.ac.uk/pub/databases/gencode/).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandConvention rdf:type rdf:Property ;
    rdfs:label 'Strand Convention' ;
    rdfs:comment 'Indicates whether the annotation track includes strand information (forward, reverse, both, or unstranded).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackName rdf:type rdf:Property ;
    rdfs:label 'Track Name' ;
    rdfs:comment 'Human-readable name of the gene annotation track (e.g., GENCODE v38, RefSeq GRCh38.p13, Ensembl 104).' ;
    rdfs:domain ind:GeneAnnotationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcriptCount rdf:type rdf:Property ;
    rdfs:label 'Transcript Count' ;
    rdfs:comment 'Total number of transcript isoforms annotated in this track.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Intended usage scope of the annotation track: RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), or Internal (internal research and development).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acmgSecondaryFindingsFlag rdf:type rdf:Property ;
    rdfs:label 'Acmg Secondary Findings Flag' ;
    rdfs:comment 'Indicates whether the gene is on the ACMG list of genes recommended for reporting of secondary findings in clinical sequencing. Critical for clinical laboratory compliance and incidental findings workflows.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:associatedDiseasePhenotypes rdf:type rdf:Property ;
    rdfs:label 'Associated Disease Phenotypes' ;
    rdfs:comment 'Comma-separated list of disease phenotypes or clinical conditions associated with variants in this gene. Supports clinical assay design and variant prioritization workflows.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancerGeneCensusFlag rdf:type rdf:Property ;
    rdfs:label 'Cancer Gene Census Flag' ;
    rdfs:comment 'Indicates whether the gene is catalogued in the Cancer Gene Census as a known cancer driver gene. Critical for oncology assay design and somatic variant interpretation.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constraintMetricLoeuf rdf:type rdf:Property ;
    rdfs:label 'Constraint Metric Loeuf' ;
    rdfs:comment 'Loss-of-Function Observed/Expected Upper Bound Fraction from gnomAD, a continuous measure of gene constraint. Lower LOEUF scores indicate greater intolerance to loss-of-function variants.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintMetricPli rdf:type rdf:Property ;
    rdfs:label 'Constraint Metric Pli' ;
    rdfs:comment 'Probability of Loss-of-Function Intolerance score from gnomAD, indicating the gene\'s tolerance to inactivating variants. High pLI (>0.9) suggests the gene is intolerant to loss-of-function variants.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curatorNotes rdf:type rdf:Property ;
    rdfs:label 'Curator Notes' ;
    rdfs:comment 'Free-text notes from the data curation team documenting special considerations, known issues, or manual overrides applied to this gene model. Supports knowledge transfer and audit trails.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ensemblGeneAccession rdf:type rdf:Property ;
    rdfs:label 'Ensembl Gene Accession' ;
    rdfs:comment 'Stable Ensembl gene identifier used for cross-referencing with Ensembl genome browser and annotation databases.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entrezGeneNumber rdf:type rdf:Property ;
    rdfs:label 'Entrez Gene Number' ;
    rdfs:comment 'NCBI Entrez Gene ID, the primary identifier used in NCBI databases including Gene, PubMed, and ClinVar for gene-level cross-referencing.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:essentialGeneFlag rdf:type rdf:Property ;
    rdfs:label 'Essential Gene Flag' ;
    rdfs:comment 'Indicates whether the gene is essential for cell viability or organism survival based on functional genomics studies. Used in CRISPR screen analysis and drug target prioritization.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geneBiotype rdf:type rdf:Property ;
    rdfs:label 'Gene Biotype' ;
    rdfs:comment 'Functional classification of the gene based on its molecular product type. Determines the gene\'s role in cellular processes and influences analysis pipelines. [ENUM-REF-CANDIDATE: protein_coding|lncRNA|miRNA|snRNA|snoRNA|rRNA|pseudogene — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneDescription rdf:type rdf:Property ;
    rdfs:label 'Gene Description' ;
    rdfs:comment 'Free-text description of the gene\'s known or predicted function, biological role, and clinical significance. Supports manual curation and knowledge base enrichment.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneFamily rdf:type rdf:Property ;
    rdfs:label 'Gene Family' ;
    rdfs:comment 'Gene family or superfamily to which this gene belongs (e.g., \'kinase\', \'G-protein coupled receptor\', \'immunoglobulin\'). Supports functional enrichment analysis and pathway mapping.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneLengthBp rdf:type rdf:Property ;
    rdfs:label 'Gene Length Bp' ;
    rdfs:comment 'Total length of the gene in base pairs from start to end position. Used for coverage depth normalization and sequencing quality metrics.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geneName rdf:type rdf:Property ;
    rdfs:label 'Gene Name' ;
    rdfs:comment 'Full descriptive name of the gene, providing human-readable context for the gene symbol (e.g., \'tumor protein p53\' for TP53).' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneStatus rdf:type rdf:Property ;
    rdfs:label 'Gene Status' ;
    rdfs:comment 'Current curation status of the gene record in the reference catalog. Active genes are approved for use in production pipelines; retired or withdrawn genes require remapping.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneSynonymList rdf:type rdf:Property ;
    rdfs:label 'Gene Synonym List' ;
    rdfs:comment 'Comma-separated list of alternative names and synonyms for the gene. Enhances search and cross-referencing capabilities across literature and databases.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneVersion rdf:type rdf:Property ;
    rdfs:label 'Gene Version' ;
    rdfs:comment 'Version identifier for this gene model record, tracking updates to gene coordinates, annotations, or metadata over time. Ensures reproducibility and audit trail for regulatory compliance.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haploinsufficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Haploinsufficiency Score' ;
    rdfs:comment 'Quantitative score indicating the likelihood that loss of one gene copy (haploinsufficiency) causes disease. Used for copy number variant interpretation and dosage sensitivity analysis.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hgncGeneSymbol rdf:type rdf:Property ;
    rdfs:label 'Hgnc Gene Symbol' ;
    rdfs:comment 'Official gene symbol assigned by HGNC, the authoritative naming body for human genes. This is the primary human-readable identifier for the gene.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCuratedDate rdf:type rdf:Property ;
    rdfs:label 'Last Curated Date' ;
    rdfs:comment 'Date when this gene model record was last reviewed and curated by the bioinformatics or clinical genomics team. Supports data quality monitoring and refresh scheduling.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locusGroup rdf:type rdf:Property ;
    rdfs:label 'Locus Group' ;
    rdfs:comment 'High-level classification of the locus type as defined by HGNC. Groups genes by their primary molecular function category.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locusType rdf:type rdf:Property ;
    rdfs:label 'Locus Type' ;
    rdfs:comment 'Detailed locus type classification providing finer granularity than locus group (e.g., \'gene with protein product\', \'RNA, long non-coding\').' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maneSelectTranscriptTranscriptModelId rdf:type rdf:Property ;
    rdfs:label 'Mane Select Transcript Transcript Model Id' ;
    rdfs:comment 'MANE Select transcript identifier representing the gold-standard transcript for clinical reporting, jointly curated by NCBI and Ensembl.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omimNumber rdf:type rdf:Property ;
    rdfs:label 'Omim Number' ;
    rdfs:comment 'OMIM identifier linking the gene to known genetic disorders and phenotypes. Used for clinical variant interpretation and disease association reporting.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacogenomicsRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomics Relevance Flag' ;
    rdfs:comment 'Indicates whether the gene has known pharmacogenomic associations affecting drug metabolism, efficacy, or toxicity. Used for precision medicine and clinical decision support.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousGeneSymbols rdf:type rdf:Property ;
    rdfs:label 'Previous Gene Symbols' ;
    rdfs:comment 'Comma-separated list of previous or alias gene symbols for this gene. Supports legacy data migration and cross-reference mapping.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triplosensitivityScore rdf:type rdf:Property ;
    rdfs:label 'Triplosensitivity Score' ;
    rdfs:comment 'Quantitative score indicating the likelihood that gain of one gene copy (triplosensitivity) causes disease. Used for copy number variant interpretation and dosage sensitivity analysis.' ;
    rdfs:domain ind:GeneModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genePathwayLinkId rdf:type rdf:Property ;
    rdfs:label 'Gene Pathway Link Id' ;
    rdfs:comment 'Primary key for gene_pathway_link' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pathwayId rdf:type rdf:Property ;
    rdfs:label 'Pathway Id' ;
    rdfs:comment 'Unique identifier for the biological pathway from the source database (e.g., KEGG pathway ID hsa04110, Reactome ID R-HSA-168256, GO term GO:0006915). Serves as the primary key for pathway reference and enables cross-database pathway enrichment analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pathway .

ind:crossReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Code' ;
    rdfs:comment 'Semicolon-separated list of equivalent pathway identifiers from other databases (e.g., GO:0006915; R-HSA-109581; hsa04210), enabling cross-database pathway mapping and integration of multi-source pathway annotations in bioinformatics pipelines.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curationDate rdf:type rdf:Property ;
    rdfs:label 'Curation Date' ;
    rdfs:comment 'Date on which the gene-pathway association was curated, validated, or last reviewed by the source database or internal bioinformatics team. Supports data versioning, audit trails for regulatory submissions (FDA 21 CFR Part 11, ISO 13485), and enables time-based filtering to exclude outdated annotations.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Data Source Version' ;
    rdfs:comment 'Version or release identifier of the external reference database from which this record was ingested (e.g., KEGG 2024-01, Reactome v83, GO 2023-11-01). Critical for reproducibility, regulatory audit trails, and managing reference data updates in clinical genomics pipelines.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSourcePmid rdf:type rdf:Property ;
    rdfs:label 'Evidence Source Pmid' ;
    rdfs:comment 'PubMed identifier (PMID) of the peer-reviewed publication providing experimental or computational evidence for the gene-pathway association. Enables traceability to primary literature for regulatory submissions (FDA, EMA) and supports reproducibility requirements under NIH Genomic Data Sharing Policy.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneRoleInPathway rdf:type rdf:Property ;
    rdfs:label 'Gene Role In Pathway' ;
    rdfs:comment 'Functional role or mechanism by which the gene participates in the pathway (e.g., enzyme, receptor, transcription factor, structural component, regulator, inhibitor, activator). Provides mechanistic context for variant effect prediction and drug target prioritization.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDiseaseAssociated rdf:type rdf:Property ;
    rdfs:label 'Is Disease Associated' ;
    rdfs:comment 'Boolean flag indicating whether the pathway is directly associated with a disease phenotype or clinical condition (e.g., cancer pathways, metabolic disorder pathways, immune deficiency pathways). Used to prioritize pathways in clinical variant interpretation and to filter gene sets for disease-focused enrichment analysis.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:membershipConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Membership Confidence Score' ;
    rdfs:comment 'Quantitative confidence score (0.0000 to 1.0000) representing the strength of evidence supporting the gene-pathway association. Derived from evidence code, publication impact factor, replication count, and cross-database concordance. Used to filter low-confidence associations in clinical variant interpretation pipelines and to prioritize gene sets for functional enrichment analysis.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'Classification of how the gene participates in the pathway. Direct indicates experimentally validated membership; inferred indicates computational prediction based on homology or network analysis; predicted indicates machine learning or statistical inference; curated indicates expert manual review. Influences confidence scoring in pathway enrichment analysis.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwaySourceDatabase rdf:type rdf:Property ;
    rdfs:label 'Pathway Source Database' ;
    rdfs:comment 'Name of the authoritative pathway database from which this gene-pathway association was derived. Critical for data provenance, citation requirements, and resolving conflicts when the same gene-pathway pair appears in multiple databases with different evidence levels. [ENUM-REF-CANDIDATE: KEGG|Reactome|GO|BioCarta|WikiPathways|PANTHER|MSigDB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Flag' ;
    rdfs:comment 'Data quality classification for the gene-pathway association. Validated indicates high-confidence, multi-source concordance; provisional indicates single-source or low-evidence; deprecated indicates retracted or superseded; conflicting indicates contradictory evidence across databases. Used to filter associations for clinical-grade vs research-use-only (RUO) pipelines.' ;
    rdfs:domain ind:GenePathwayLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAssemblyGenomeAssemblyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assembly Genome Assembly Id' ;
    rdfs:comment 'Foreign key reference to the genome_assembly_id of the newer assembly that supersedes this one. Null if this assembly is current or has not been superseded.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomeAssembly .

ind:annotationVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Version' ;
    rdfs:comment 'Version identifier of the gene annotation track associated with this assembly (e.g., GENCODE v42, Ensembl 109). Gene annotations are versioned independently of the assembly.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyAccession rdf:type rdf:Property ;
    rdfs:label 'Assembly Accession' ;
    rdfs:comment 'Official accession identifier assigned by the source authority (NCBI/INSDC format: GCA_ for GenBank, GCF_ for RefSeq). Serves as the globally unique external identifier for this assembly build.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyAlias rdf:type rdf:Property ;
    rdfs:label 'Assembly Alias' ;
    rdfs:comment 'Alternative or legacy name for the assembly (e.g., hg38 for GRCh38, mm10 for GRCm38). Used for cross-referencing with external tools and historical datasets.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyLevel rdf:type rdf:Property ;
    rdfs:label 'Assembly Level' ;
    rdfs:comment 'Degree of completeness and contiguity of the assembly. Chromosome = fully assembled chromosomes; Scaffold = ordered contigs with gaps; Contig = unordered contiguous sequences; Complete Genome = fully closed, telomere-to-telomere.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyMethod rdf:type rdf:Property ;
    rdfs:label 'Assembly Method' ;
    rdfs:comment 'Bioinformatics software and algorithm used to assemble the genome (e.g., FALCON, Canu, DISCOVAR, SPAdes). Important for reproducibility and quality assessment.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyName rdf:type rdf:Property ;
    rdfs:label 'Assembly Name' ;
    rdfs:comment 'Human-readable name of the genome assembly (e.g., GRCh38, T2T-CHM13v2.0, GRCm39). This is the canonical label used across all bioinformatics pipelines and publications.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assemblyStatus rdf:type rdf:Property ;
    rdfs:label 'Assembly Status' ;
    rdfs:comment 'Lifecycle status of the assembly. Active = currently used in production pipelines; deprecated = no longer recommended but still accessible; superseded = replaced by a newer version; archived = retained for historical reproducibility only.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bowtie2IndexPath rdf:type rdf:Property ;
    rdfs:label 'Bowtie2 Index Path' ;
    rdfs:comment 'Path to the Bowtie2 index files for this assembly. Alternative aligner index used in some RNA-seq and ChIP-seq pipelines.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bwaIndexPath rdf:type rdf:Property ;
    rdfs:label 'Bwa Index Path' ;
    rdfs:comment 'Path to the BWA (Burrows-Wheeler Aligner) index files for this assembly. Required for read alignment in NGS pipelines.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromosomeCount rdf:type rdf:Property ;
    rdfs:label 'Chromosome Count' ;
    rdfs:comment 'Total number of chromosomes represented in the assembly, including autosomes, sex chromosomes, and mitochondrial DNA where applicable.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contigCount rdf:type rdf:Property ;
    rdfs:label 'Contig Count' ;
    rdfs:comment 'Total number of contiguous sequences (contigs) in the assembly. Lower contig count indicates higher assembly contiguity and quality.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contigN50Bp rdf:type rdf:Property ;
    rdfs:label 'Contig N50 Bp' ;
    rdfs:comment 'N50 statistic for contigs: the length at which 50% of the total assembly length is contained in contigs of this size or larger. Key quality metric for assembly contiguity.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cytobandFilePath rdf:type rdf:Property ;
    rdfs:label 'Cytoband File Path' ;
    rdfs:comment 'Path to the cytoband file defining chromosome banding patterns (Giemsa staining regions). Used for cytogenetic coordinate mapping and visualization.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedDate rdf:type rdf:Property ;
    rdfs:label 'Deprecated Date' ;
    rdfs:comment 'Date on which this assembly was officially deprecated by the source authority or by Genomics Biotech internal policy. Null if the assembly is still active.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fastaFilePath rdf:type rdf:Property ;
    rdfs:label 'Fasta File Path' ;
    rdfs:comment 'Cloud storage or file system path to the primary FASTA file containing the assembly sequences. This is the authoritative artifact used by all downstream pipelines.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastaMd5Checksum rdf:type rdf:Property ;
    rdfs:label 'Fasta Md5 Checksum' ;
    rdfs:comment 'MD5 hash of the FASTA file for integrity verification. Ensures the file has not been corrupted or tampered with during transfer or storage.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcContentPercent rdf:type rdf:Property ;
    rdfs:label 'Gc Content Percent' ;
    rdfs:comment 'Percentage of guanine (G) and cytosine (C) bases in the total assembly sequence. Species-specific characteristic used for quality control and comparative genomics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gffFilePath rdf:type rdf:Property ;
    rdfs:label 'Gff File Path' ;
    rdfs:comment 'Path to the GFF3 file containing genomic features and annotations. Alternative to GTF, used by some annotation pipelines and genome browsers.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtfFilePath rdf:type rdf:Property ;
    rdfs:label 'Gtf File Path' ;
    rdfs:comment 'Path to the GTF file containing gene annotations (exons, transcripts, genes) for this assembly. Used by RNA-seq and variant annotation pipelines.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexFilePath rdf:type rdf:Property ;
    rdfs:label 'Index File Path' ;
    rdfs:comment 'Path to the FASTA index file (.fai) used by bioinformatics tools (e.g., samtools, GATK) for rapid random access to sequences.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryAssembly rdf:type rdf:Property ;
    rdfs:label 'Is Primary Assembly' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary/default assembly for the organism. True = primary assembly used by default in all pipelines; False = alternate or legacy assembly.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReferenceStandard rdf:type rdf:Property ;
    rdfs:label 'Is Reference Standard' ;
    rdfs:comment 'Boolean flag indicating whether this assembly is recognized as a community reference standard (e.g., GRCh38 for human). True = reference standard; False = non-standard or custom assembly.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organismCommonName rdf:type rdf:Property ;
    rdfs:label 'Organism Common Name' ;
    rdfs:comment 'Common or vernacular name of the organism (e.g., human, mouse, thale cress). Used for user-facing displays and non-technical reporting.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organismName rdf:type rdf:Property ;
    rdfs:label 'Organism Name' ;
    rdfs:comment 'Scientific name of the organism for which this genome assembly was built (e.g., Homo sapiens, Mus musculus, Arabidopsis thaliana).' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchVersion rdf:type rdf:Property ;
    rdfs:label 'Patch Version' ;
    rdfs:comment 'Incremental patch or update number applied to the base assembly (e.g., p13 for GRCh38.p13). Patches correct errors or add alternate loci without changing the primary coordinate system.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ploidy rdf:type rdf:Property ;
    rdfs:label 'Ploidy' ;
    rdfs:comment 'Number of complete sets of chromosomes in the organism. Haploid = one set (e.g., bacteria, haploid yeast); diploid = two sets (e.g., human, mouse); polyploid = more than two sets (e.g., wheat, some plants).' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaffoldCount rdf:type rdf:Property ;
    rdfs:label 'Scaffold Count' ;
    rdfs:comment 'Total number of scaffolds in the assembly. Scaffolds are ordered and oriented contigs connected by gaps of estimated size.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaffoldN50Bp rdf:type rdf:Property ;
    rdfs:label 'Scaffold N50 Bp' ;
    rdfs:comment 'N50 statistic for scaffolds: the length at which 50% of the total assembly length is contained in scaffolds of this size or larger. Higher values indicate better long-range contiguity.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceDictionaryPath rdf:type rdf:Property ;
    rdfs:label 'Sequence Dictionary Path' ;
    rdfs:comment 'Path to the sequence dictionary file (.dict) required by GATK and Picard tools. Contains metadata about each sequence (chromosome) in the assembly.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingTechnology rdf:type rdf:Property ;
    rdfs:label 'Sequencing Technology' ;
    rdfs:comment 'Primary sequencing platform(s) used to generate the assembly (e.g., Illumina HiSeq, PacBio HiFi, Oxford Nanopore, Sanger). Relevant for understanding assembly characteristics and error profiles.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAuthority rdf:type rdf:Property ;
    rdfs:label 'Source Authority' ;
    rdfs:comment 'Organization or consortium responsible for generating and maintaining this assembly (e.g., GRC = Genome Reference Consortium, T2T = Telomere-to-Telomere Consortium).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterOrganization rdf:type rdf:Property ;
    rdfs:label 'Submitter Organization' ;
    rdfs:comment 'Name of the organization or consortium that submitted the assembly to the public database (e.g., Genome Reference Consortium, Broad Institute, Sanger Institute).' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonNumber rdf:type rdf:Property ;
    rdfs:label 'Taxon Number' ;
    rdfs:comment 'NCBI Taxonomy database identifier for the organism. Enables linkage to external biological databases and phylogenetic classification.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSequenceLengthBp rdf:type rdf:Property ;
    rdfs:label 'Total Sequence Length Bp' ;
    rdfs:comment 'Total number of base pairs across all sequences in the assembly, including chromosomes, scaffolds, contigs, and unplaced sequences. Measured in base pairs (bp).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ungappedLengthBp rdf:type rdf:Property ;
    rdfs:label 'Ungapped Length Bp' ;
    rdfs:comment 'Total number of base pairs excluding gaps (N-runs). Represents the actual sequenced and assembled nucleotide content.' ;
    rdfs:domain ind:GenomeAssembly ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomeAssemblyVersionId rdf:type rdf:Property ;
    rdfs:label 'Genome Assembly Version Id' ;
    rdfs:comment 'Unique identifier for each versioned release of a reference genome assembly. Primary key. Inferred role: MASTER_RESOURCE (reference genome assembly as a managed resource). Canonical categories present: IDENTITY_LABEL (version_tag), BUSINESS_IDENTIFIER (assembly_accession), CLASSIFICATION_OR_TYPE (assembly_type), LIFECYCLE_STATUS (status), MEASUREMENT_OR_VALUE (total_sequence_length_bp).' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedSequencesSummary rdf:type rdf:Property ;
    rdfs:label 'Added Sequences Summary' ;
    rdfs:comment 'Summary of sequences added in this assembly version (e.g., new ALT loci, novel patches, additional scaffolds). Null if no sequences were added.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:altLociCount rdf:type rdf:Property ;
    rdfs:label 'Alt Loci Count' ;
    rdfs:comment 'Number of alternate loci sequences included in the assembly. ALT loci represent regions of high variability or structural variation in the population.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checksumValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Checksum Validation Status' ;
    rdfs:comment 'Status of checksum validation performed upon internal ingestion of the assembly file: validated (checksums match), failed (checksums do not match), pending (validation in progress), not_performed (validation skipped).' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decoySequenceIncluded rdf:type rdf:Property ;
    rdfs:label 'Decoy Sequence Included' ;
    rdfs:comment 'Indicates whether decoy sequences (e.g., hs38d1 decoy for GRCh38) are included in this assembly version. Decoy sequences reduce false-positive alignments by capturing reads that do not belong to the primary assembly.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decoySequenceName rdf:type rdf:Property ;
    rdfs:label 'Decoy Sequence Name' ;
    rdfs:comment 'Name or identifier of the decoy sequence set included (e.g., hs38d1, hs38DH). Null if no decoy sequences are included.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebvSequenceIncluded rdf:type rdf:Property ;
    rdfs:label 'Ebv Sequence Included' ;
    rdfs:comment 'Indicates whether Epstein-Barr Virus (EBV) reference sequence (chrEBV) is included. EBV is commonly present in immortalized cell lines used for sequencing.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastaFileChecksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Fasta File Checksum Md5' ;
    rdfs:comment 'MD5 checksum hash of the primary FASTA file for this assembly version. Used to validate file integrity and ensure reproducibility.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastaFileChecksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Fasta File Checksum Sha256' ;
    rdfs:comment 'SHA-256 checksum hash of the primary FASTA file for this assembly version. Provides stronger integrity validation than MD5.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapCount rdf:type rdf:Property ;
    rdfs:label 'Gap Count' ;
    rdfs:comment 'Total number of gaps (regions of unknown sequence, typically represented by Ns) in the assembly. Lower gap counts indicate more complete assemblies.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomeAssemblyVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Genome Assembly Version Status' ;
    rdfs:comment 'Current lifecycle status of this genome assembly version: active (currently used in production pipelines), deprecated (superseded but still available), retired (no longer available for new analyses), under_review (being evaluated for adoption).' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAdoptionDate rdf:type rdf:Property ;
    rdfs:label 'Internal Adoption Date' ;
    rdfs:comment 'Date on which this genome assembly version was officially adopted for use in internal bioinformatics pipelines and analysis workflows. Critical for audit trails and reproducibility.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitochondrialGenomeIncluded rdf:type rdf:Property ;
    rdfs:label 'Mitochondrial Genome Included' ;
    rdfs:comment 'Indicates whether the mitochondrial genome (chrM) is included in this assembly version. Critical for mitochondrial variant calling and analysis.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patchNotes rdf:type rdf:Property ;
    rdfs:label 'Patch Notes' ;
    rdfs:comment 'Detailed release notes describing changes, additions, and corrections in this assembly version compared to the previous version. Includes information on added/removed sequences, ALT loci changes, and bug fixes.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patchNumber rdf:type rdf:Property ;
    rdfs:label 'Patch Number' ;
    rdfs:comment 'Sequential patch release number for this assembly version (e.g., 14 in GRCh38.p14). Null for base releases without patches.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patchType rdf:type rdf:Property ;
    rdfs:label 'Patch Type' ;
    rdfs:comment 'Type of patch applied: fix (corrects errors in the primary assembly) or novel (adds new alternate loci or sequences without altering primary assembly). Null if not a patch release.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Indicates whether this genome assembly version meets regulatory requirements for use in Clinical Laboratory Improvement Amendments (CLIA) and College of American Pathologists (CAP) accredited clinical genomic testing. Compliant assemblies have been validated for regulatory-grade variant interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedSequencesSummary rdf:type rdf:Property ;
    rdfs:label 'Removed Sequences Summary' ;
    rdfs:comment 'Summary of sequences removed or deprecated in this assembly version (e.g., retired ALT loci, corrected errors). Null if no sequences were removed.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOrganization rdf:type rdf:Property ;
    rdfs:label 'Source Organization' ;
    rdfs:comment 'Organization or consortium responsible for producing and releasing this genome assembly (e.g., Genome Reference Consortium, Telomere-to-Telomere Consortium, NCBI).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReleaseUrl rdf:type rdf:Property ;
    rdfs:label 'Source Release Url' ;
    rdfs:comment 'URL to the official release page or FTP directory where this assembly version can be downloaded. Ensures traceability to the authoritative source.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStudyPerformed rdf:type rdf:Property ;
    rdfs:label 'Validation Study Performed' ;
    rdfs:comment 'Indicates whether an internal analytical validation study was performed to qualify this assembly version for clinical or Research Use Only (RUO) use. Required for Clinical Laboratory Improvement Amendments (CLIA) and College of American Pathologists (CAP) compliance.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionTag rdf:type rdf:Property ;
    rdfs:label 'Version Tag' ;
    rdfs:comment 'Human-readable version identifier for the genome assembly release, such as GRCh38.p14, hg38, T2T-CHM13v2.0. This is the canonical label used in bioinformatics pipelines and publications.' ;
    rdfs:domain ind:GenomeAssemblyVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRegionGenomicRegionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Region Genomic Region Id' ;
    rdfs:comment 'Identifier of the genomic region record that supersedes this record, if this record has been deprecated or replaced.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicRegion .

ind:artifactFlag rdf:type rdf:Property ;
    rdfs:label 'Artifact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this region is known to produce sequencing artifacts or false-positive variant calls (True if artifact region, False otherwise).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assayDesignPurpose rdf:type rdf:Property ;
    rdfs:label 'Assay Design Purpose' ;
    rdfs:comment 'Intended use or purpose of this genomic region in assay design (e.g., variant detection, copy number analysis, quality control, artifact exclusion).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bedFilePath rdf:type rdf:Property ;
    rdfs:label 'Bed File Path' ;
    rdfs:comment 'File system or cloud storage path to the BED format file containing the detailed coordinates for this region or region set.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappabilityScore rdf:type rdf:Property ;
    rdfs:label 'Mappability Score' ;
    rdfs:comment 'Mappability score (0.00 to 1.00) indicating how uniquely sequencing reads can be aligned to this region; higher scores indicate better mappability.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionDescription rdf:type rdf:Property ;
    rdfs:label 'Region Description' ;
    rdfs:comment 'Detailed textual description of the genomic region, including its biological function, clinical relevance, or technical purpose.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Region Identifier' ;
    rdfs:comment 'Externally-known unique identifier or accession number for the region (e.g., vendor catalog number, ENCODE identifier, dbSNP rsID for SNP regions).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionLengthBp rdf:type rdf:Property ;
    rdfs:label 'Region Length Bp' ;
    rdfs:comment 'Length of the genomic region in base pairs, calculated as end_position minus start_position.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Human-readable name or label for the genomic region (e.g., BRCA1_exon2, chr1_centromere, ACMG_SF_v3.2_gene_panel).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionSetName rdf:type rdf:Property ;
    rdfs:label 'Region Set Name' ;
    rdfs:comment 'Name of the parent region set or collection to which this region belongs (e.g., Agilent SureSelect v8, ACMG SF v3.2, ENCODE Blacklist v2).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionSetVersion rdf:type rdf:Property ;
    rdfs:label 'Region Set Version' ;
    rdfs:comment 'Version identifier of the parent region set (e.g., v8, v3.2, 2023-Q1).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionStatus rdf:type rdf:Property ;
    rdfs:label 'Region Status' ;
    rdfs:comment 'Current lifecycle status of the genomic region record indicating whether it is approved for use in production pipelines.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionType rdf:type rdf:Property ;
    rdfs:label 'Region Type' ;
    rdfs:comment 'Classification of the genomic region by its biological, clinical, or technical function. [ENUM-REF-CANDIDATE: exome_capture_target|gene_panel|blacklist_region|artifact_region|segmental_duplication|repeat_masked_region|centromere|telomere|coding_exon|regulatory_element|structural_variant|copy_number_variant — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatMaskedFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Masked Flag' ;
    rdfs:comment 'Boolean flag indicating whether this region is masked due to repetitive DNA sequences (True if repeat-masked, False otherwise).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourcePublication rdf:type rdf:Property ;
    rdfs:label 'Source Publication' ;
    rdfs:comment 'PubMed ID (PMID) or DOI of the scientific publication that describes or validates this genomic region.' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceVendor rdf:type rdf:Property ;
    rdfs:label 'Source Vendor' ;
    rdfs:comment 'Name of the vendor or manufacturer that provided the region definition (e.g., Agilent, Illumina, Twist Bioscience, Roche).' ;
    rdfs:domain ind:GenomicRegion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontologyTermId rdf:type rdf:Property ;
    rdfs:label 'Ontology Term Id' ;
    rdfs:comment 'Unique identifier for the ontology term record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntologyTerm .

ind:parentTermOntologyTermId rdf:type rdf:Property ;
    rdfs:label 'Parent Term Ontology Term Id' ;
    rdfs:comment 'The term identifier of the immediate parent term in the ontology hierarchy (e.g., for HP:0001250 \'Seizure\', the parent might be HP:0012638 \'Abnormality of nervous system physiology\'). Supports hierarchical navigation and subsumption reasoning. May be null for root terms.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntologyTerm .

ind:primaryReplacementTermOntologyTermId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Term Ontology Term Id' ;
    rdfs:comment 'The term identifier of the replacement or successor term if this term has been deprecated. Null if not deprecated or if no replacement is specified.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OntologyTerm .

ind:childTermCount rdf:type rdf:Property ;
    rdfs:label 'Child Term Count' ;
    rdfs:comment 'The number of immediate child terms (direct descendants) of this term in the ontology hierarchy. Supports navigation and ontology structure analysis.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-text editorial comment or note about the term, its usage, or its relationship to other terms. May include curator notes, usage warnings, or clarifications.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'The date when this term was first introduced into the source ontology (format: yyyy-MM-dd). Supports temporal analysis and version tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossReferences rdf:type rdf:Property ;
    rdfs:label 'Cross References' ;
    rdfs:comment 'Pipe-separated list of equivalent or related term identifiers in other ontologies or coding systems (e.g., \'UMLS:C0036572|SNOMEDCT:91175000|MeSH:D012640\'). Enables interoperability and cross-ontology mapping.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curationStatus rdf:type rdf:Property ;
    rdfs:label 'Curation Status' ;
    rdfs:comment 'The internal curation or review status of this term within the enterprise reference data governance workflow. Indicates whether the term has been validated for use in production genomics pipelines.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRootTerm rdf:type rdf:Property ;
    rdfs:label 'Is Root Term' ;
    rdfs:comment 'Boolean flag indicating whether this term is a root or top-level term in the ontology hierarchy (i.e., has no parent term). True if root, False otherwise.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'The date when this term was last updated or modified in the source ontology (format: yyyy-MM-dd). Critical for change tracking and data lineage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The most recent date when this term was used in a production annotation, variant interpretation, or clinical report (format: yyyy-MM-dd). Supports term lifecycle management and archival decisions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namespace rdf:type rdf:Property ;
    rdfs:label 'Namespace' ;
    rdfs:comment 'The namespace or sub-ontology within the source ontology to which this term belongs (e.g., \'biological_process\', \'molecular_function\', \'cellular_component\' for GO terms). Provides additional categorization within large ontologies.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontologySource rdf:type rdf:Property ;
    rdfs:label 'Ontology Source' ;
    rdfs:comment 'The source ontology or terminology system from which this term originates (e.g., HPO for Human Phenotype Ontology, OMIM for Online Mendelian Inheritance in Man, SNOMED CT for Systematized Nomenclature of Medicine Clinical Terms, SO for Sequence Ontology). [ENUM-REF-CANDIDATE: HPO|OMIM|MedGen|SNOMED CT|ICD-10|ICD-11|LOINC|SO|GO|MONDO|ORDO|GARD|NCIT|UBERON|CL|CHEBI|RxNorm|CPT|HGNC — 19 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ontologyVersion rdf:type rdf:Property ;
    rdfs:label 'Ontology Version' ;
    rdfs:comment 'The version or release identifier of the source ontology from which this term was extracted (e.g., \'2023-10-09\', \'v2023.4\', \'Release 20231101\'). Critical for reproducibility and regulatory traceability.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApplicability rdf:type rdf:Property ;
    rdfs:label 'Regulatory Applicability' ;
    rdfs:comment 'Pipe-separated list of regulatory contexts or jurisdictions for which this term is applicable or required (e.g., \'FDA|EMA|CLIA|CAP\'). Supports compliance-driven term selection for clinical reporting.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsetMembership rdf:type rdf:Property ;
    rdfs:label 'Subset Membership' ;
    rdfs:comment 'Pipe-separated list of subset or slim identifiers to which this term belongs (e.g., \'goslim_generic|goslim_plant\' for GO terms, \'hpo_slim\' for HPO). Subsets are curated collections of terms for specific use cases or communities.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termAccession rdf:type rdf:Property ;
    rdfs:label 'Term Accession' ;
    rdfs:comment 'The canonical identifier for the ontology term as assigned by the source ontology (e.g., HP:0001250 for HPO, OMIM:600354, SNOMED:73211009). Format is typically prefix:numeric_code.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termDefinition rdf:type rdf:Property ;
    rdfs:label 'Term Definition' ;
    rdfs:comment 'The formal textual definition of the ontology term as provided by the source ontology. Describes the precise meaning, scope, and usage of the term.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'The current lifecycle status of the ontology term within the reference data governance framework. Active terms are approved for use in production workflows; deprecated terms are retained for historical traceability but should not be used for new annotations.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'The ontological type or role of this term within the ontology structure (e.g., class for concepts, property for relationships, individual for instances). Supports ontology reasoning and semantic validation.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageFrequency rdf:type rdf:Property ;
    rdfs:label 'Usage Frequency' ;
    rdfs:comment 'The count of how many times this term has been used in annotations, variant interpretations, or clinical reports within the enterprise. Supports term prioritization and quality metrics.' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useCaseCategory rdf:type rdf:Property ;
    rdfs:label 'Use Case Category' ;
    rdfs:comment 'The primary domain or use case category for which this term is applicable (e.g., phenotype for HPO terms, disease for OMIM/MONDO, variant for SO terms, observation for LOINC). Supports filtering and context-specific term selection. [ENUM-REF-CANDIDATE: phenotype|disease|variant|sequence|gene|pathway|drug|procedure|observation|specimen — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OntologyTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPathwayId rdf:type rdf:Property ;
    rdfs:label 'Parent Pathway Id' ;
    rdfs:comment 'Reference to the parent pathway in hierarchical pathway databases (e.g., Reactome, GO). Enables navigation of pathway hierarchies from specific sub-pathways to broader biological processes. Null for top-level pathways.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pathway .

ind:pathwayDatabaseId rdf:type rdf:Property ;
    rdfs:label 'Pathway Database Id' ;
    rdfs:comment 'Foreign key linking to reference.pathway_database. Business justification: Pathways are sourced from specific pathway databases (KEGG, Reactome, etc.). Each pathway should reference its source database for provenance tracking. The pathway_source string attribute should be re' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PathwayDatabase .

ind:clinicalRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Relevance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this pathway has established clinical relevance for disease diagnosis, prognosis, or treatment selection. True indicates the pathway is used in clinical genomics interpretation workflows.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossReferenceIds rdf:type rdf:Property ;
    rdfs:label 'Cross Reference Ids' ;
    rdfs:comment 'Pipe-separated list of equivalent pathway identifiers in other databases (e.g., \'Reactome:R-HSA-168256|GO:0006915|WikiPathways:WP254\'). Enables cross-database pathway mapping and integration of multi-source pathway annotations in bioinformatics pipelines.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseAssociationCount rdf:type rdf:Property ;
    rdfs:label 'Disease Association Count' ;
    rdfs:comment 'The number of diseases or clinical phenotypes associated with this pathway in curated disease-pathway databases (e.g., KEGG Disease, DisGeNET, OMIM). Used to prioritize pathways in clinical variant interpretation and disease gene discovery.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugTargetCount rdf:type rdf:Property ;
    rdfs:label 'Drug Target Count' ;
    rdfs:comment 'The number of FDA-approved or investigational drugs that target genes or proteins in this pathway. Used for drug repurposing analysis, precision medicine target identification, and pharmacogenomics workflows.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'The externally-known unique identifier from the source pathway database (e.g., KEGG pathway ID \'hsa04010\', Reactome ID \'R-HSA-168256\', GO ID \'GO:0006915\'). This is the canonical identifier used in scientific literature and bioinformatics pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneMemberCount rdf:type rdf:Property ;
    rdfs:label 'Gene Member Count' ;
    rdfs:comment 'The total number of genes that are members of this pathway. Used for statistical power calculations in gene-set enrichment analysis (GSEA) and pathway over-representation analysis.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oncologyRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Oncology Relevance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this pathway is relevant to cancer biology, tumor progression, or oncology therapeutics. True indicates the pathway is used in oncology genomics analysis and precision oncology workflows.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organism rdf:type rdf:Property ;
    rdfs:label 'Organism' ;
    rdfs:comment 'The organism or species for which this pathway is defined (e.g., \'Homo sapiens\', \'Mus musculus\', \'Pan-species\'). Critical for species-specific genomic analysis and cross-species comparative genomics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organismCode rdf:type rdf:Property ;
    rdfs:label 'Organism Code' ;
    rdfs:comment 'The standardized three-letter organism code (e.g., \'hsa\' for Homo sapiens, \'mmu\' for Mus musculus) used in pathway databases for compact representation and cross-referencing.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayCategory rdf:type rdf:Property ;
    rdfs:label 'Pathway Category' ;
    rdfs:comment 'High-level functional classification of the pathway (e.g., metabolic, signaling, disease, immune response, cell cycle, DNA repair, apoptosis, development, transport). Used for filtering and grouping pathways in enrichment analysis and variant interpretation workflows. [ENUM-REF-CANDIDATE: metabolic|signaling|disease|immune|cell_cycle|dna_repair|apoptosis|development|transport|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayDescription rdf:type rdf:Property ;
    rdfs:label 'Pathway Description' ;
    rdfs:comment 'Detailed textual description of the biological pathway, including its function, key molecular interactions, regulatory mechanisms, and biological significance. Used for pathway interpretation and reporting in clinical genomics workflows.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayName rdf:type rdf:Property ;
    rdfs:label 'Pathway Name' ;
    rdfs:comment 'The human-readable name of the biological pathway (e.g., \'MAPK signaling pathway\', \'Apoptosis\', \'Cell cycle\'). This is the primary label used by researchers and clinicians.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Direct hyperlink to the pathway record in the source database (e.g., \'https://www.kegg.jp/pathway/hsa04010\', \'https://reactome.org/content/detail/R-HSA-168256\'). Enables one-click access to authoritative pathway diagrams and detailed annotations for researchers and clinical scientists.' ;
    rdfs:domain ind:Pathway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationFieldSchema rdf:type rdf:Property ;
    rdfs:label 'Annotation Field Schema' ;
    rdfs:comment 'Description or reference to the data schema and field structure used in the pathway database annotation files (e.g., GMT format, OBO format, JSON schema). Enables automated parsing and integration.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForClinicalUse rdf:type rdf:Property ;
    rdfs:label 'Approved For Clinical Use' ;
    rdfs:comment 'Indicates whether this pathway database version is approved for use in Clinical Laboratory Improvement Amendments (CLIA)-certified or In Vitro Diagnostic (IVD) clinical assays. Critical for regulatory compliance.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedForResearchUse rdf:type rdf:Property ;
    rdfs:label 'Approved For Research Use' ;
    rdfs:comment 'Indicates whether this pathway database version is approved for Research Use Only (RUO) applications and non-clinical bioinformatics workflows.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataAccessTier rdf:type rdf:Property ;
    rdfs:label 'Data Access Tier' ;
    rdfs:comment 'Access control tier for the pathway database: public (open access), licensed (commercial license required), restricted (institutional agreement), internal (proprietary curation).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseCode rdf:type rdf:Property ;
    rdfs:label 'Database Code' ;
    rdfs:comment 'Short standardized code or abbreviation for the pathway database used in bioinformatics pipelines and annotation workflows (e.g., KEGG, GO, REACTOME).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseName rdf:type rdf:Property ;
    rdfs:label 'Database Name' ;
    rdfs:comment 'Official name of the biological pathway or gene ontology database (e.g., KEGG, Reactome, Gene Ontology, MSigDB, WikiPathways, BioCarta).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseType rdf:type rdf:Property ;
    rdfs:label 'Database Type' ;
    rdfs:comment 'Classification of the pathway database by its primary biological focus (pathway, gene ontology, molecular signature, disease ontology, drug target, metabolic, signaling, regulatory). [ENUM-REF-CANDIDATE: pathway|gene_ontology|molecular_signature|disease_ontology|drug_target|metabolic|signaling|regulatory — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadUrl rdf:type rdf:Property ;
    rdfs:label 'Download Url' ;
    rdfs:comment 'Official URL or repository location from which this pathway database version can be downloaded or accessed. Supports reproducibility and audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Total file size of the pathway database distribution in megabytes. Used for storage planning and download time estimation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genomeBuildCompatibility rdf:type rdf:Property ;
    rdfs:label 'Genome Build Compatibility' ;
    rdfs:comment 'Reference genome assembly versions compatible with this pathway database (e.g., GRCh38/hg38, GRCh37/hg19, T2T-CHM13). Critical for coordinate-based annotation alignment.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationPipelineCount rdf:type rdf:Property ;
    rdfs:label 'Integration Pipeline Count' ;
    rdfs:comment 'Number of active bioinformatics pipelines currently using this pathway database version. Indicates usage footprint and impact of deprecation.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organismScope rdf:type rdf:Property ;
    rdfs:label 'Organism Scope' ;
    rdfs:comment 'Taxonomic scope of the pathway database (e.g., Homo sapiens, multi-species, pan-vertebrate). Defines applicability to genomic analysis workflows.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayCount rdf:type rdf:Property ;
    rdfs:label 'Pathway Count' ;
    rdfs:comment 'Total number of biological pathways or gene sets contained in this database version. Used for coverage assessment and quality validation.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pathwayDatabaseStatus rdf:type rdf:Property ;
    rdfs:label 'Pathway Database Status' ;
    rdfs:comment 'Current lifecycle status of the pathway database reference: active (approved for use), deprecated (superseded by newer version), archived (retained for historical traceability), under_review (validation in progress), pending_approval (awaiting governance approval).' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerOrganization rdf:type rdf:Property ;
    rdfs:label 'Provider Organization' ;
    rdfs:comment 'Organization or consortium responsible for curating and maintaining the pathway database (e.g., KEGG Organization, Reactome Consortium, Gene Ontology Consortium).' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByVersion rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version' ;
    rdfs:comment 'Version identifier of the pathway database release that supersedes this version. Used to track version lineage and migration paths.' ;
    rdfs:domain ind:PathwayDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'Expected frequency of new releases or updates for the pathway database. Informs refresh schedules for bioinformatics pipelines and reference data governance.' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedDrugs rdf:type rdf:Property ;
    rdfs:label 'Associated Drugs' ;
    rdfs:comment 'Comma-separated list of drugs for which this PGx marker has documented gene-drug interactions and clinical actionability (e.g., codeine, tamoxifen, clopidogrel, warfarin, fluorouracil). Enables drug-specific PGx reporting.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalActionabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Clinical Actionability Status' ;
    rdfs:comment 'Current clinical actionability classification: actionable (guideline-supported dosing or therapy change), informative (known association but no specific guideline), research_only (insufficient evidence for clinical use), or uncertain (conflicting evidence). Lifecycle status field for PGx marker.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalAnnotation rdf:type rdf:Property ;
    rdfs:label 'Clinical Annotation' ;
    rdfs:comment 'Free-text clinical interpretation and actionability guidance for the marker, including dosing recommendations, contraindications, or alternative therapy suggestions (e.g., Consider 50% dose reduction for CYP2D6 poor metabolizers on codeine; avoid fluorouracil in DPYD deficiency).' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinvarVariationNumber rdf:type rdf:Property ;
    rdfs:label 'Clinvar Variation Number' ;
    rdfs:comment 'ClinVar variation ID for the variant, if the variant has clinical significance annotation in ClinVar (e.g., 12345). Null if not present in ClinVar.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diplotype rdf:type rdf:Property ;
    rdfs:label 'Diplotype' ;
    rdfs:comment 'Two-allele genotype combination representing the diplotype (e.g., *1/*4, *2/*3A). Captures the paired allele configuration that determines metabolizer phenotype. Null for single-variant markers.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaPgxLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Ema Pgx Label Flag' ;
    rdfs:comment 'Boolean flag indicating whether this marker is referenced in EMA-approved drug labeling with pharmacogenomic information (True) or not (False). Supports EU regulatory compliance.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fdaPgxLabelFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Pgx Label Flag' ;
    rdfs:comment 'Boolean flag indicating whether this marker is referenced in FDA-approved drug labeling with pharmacogenomic information (True) or not (False). Supports regulatory-grade PGx reporting.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalImpact rdf:type rdf:Property ;
    rdfs:label 'Functional Impact' ;
    rdfs:comment 'Predicted or experimentally validated functional impact of the variant on gene/protein function: no_function (null allele), decreased_function, normal_function, increased_function, or uncertain_function. Drives phenotype prediction.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineSource rdf:type rdf:Property ;
    rdfs:label 'Guideline Source' ;
    rdfs:comment 'Primary authoritative source for the PGx guideline or recommendation: CPIC (Clinical Pharmacogenetics Implementation Consortium), DPWG (Dutch Pharmacogenetics Working Group), PharmGKB, FDA (U.S. Food and Drug Administration), EMA (European Medicines Agency), or other.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hgvsNotation rdf:type rdf:Property ;
    rdfs:label 'Hgvs Notation' ;
    rdfs:comment 'Standardized HGVS nomenclature for the variant (e.g., NC_000022.11:g.42130692G>A, NM_000546.5:c.215C>G, NP_000537.3:p.Arg72Pro). Supports genomic (g.), coding (c.), and protein (p.) representations.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerCode rdf:type rdf:Property ;
    rdfs:label 'Marker Code' ;
    rdfs:comment 'Externally-known unique business identifier for the PGx marker, typically combining gene symbol and variant notation (e.g., CYP2D6_rs1065852, DPYD_c.1905+1G>A). Used for cross-reference with PharmGKB, CPIC, and FDA labeling.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markerName rdf:type rdf:Property ;
    rdfs:label 'Marker Name' ;
    rdfs:comment 'Human-readable name or label for the pharmacogenomics marker, often including gene symbol and variant designation (e.g., CYP2D6*4, TPMT c.719A>G).' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacogenomicsMarkerStatus rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomics Marker Status' ;
    rdfs:comment 'Lifecycle status of the PGx marker record: active (current and approved for use), deprecated (superseded by newer version), under_review (pending curation or validation), or retired (no longer clinically relevant). Ensures data quality and governance.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmgkbAccession rdf:type rdf:Property ;
    rdfs:label 'Pharmgkb Accession' ;
    rdfs:comment 'PharmGKB accession identifier for the variant, gene, or drug-gene interaction (e.g., PA166153631). Enables cross-reference to the PharmGKB knowledge base.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictedPhenotype rdf:type rdf:Property ;
    rdfs:label 'Predicted Phenotype' ;
    rdfs:comment 'Predicted metabolizer or functional phenotype associated with the marker or diplotype (e.g., Poor Metabolizer, Intermediate Metabolizer, Normal Metabolizer, Rapid Metabolizer, Ultrarapid Metabolizer; or Decreased Function, Normal Function, Increased Function). Core clinical actionability field.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starAlleleDesignation rdf:type rdf:Property ;
    rdfs:label 'Star Allele Designation' ;
    rdfs:comment 'Named star allele designation for pharmacogenes with established allele nomenclature (e.g., *1, *2, *4, *17 for CYP2D6; *2, *3A for TPMT). Null for variants not part of a star allele system.' ;
    rdfs:domain ind:PharmacogenomicsMarker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationAlleleFrequencyId rdf:type rdf:Property ;
    rdfs:label 'Population Allele Frequency Id' ;
    rdfs:comment 'Unique identifier for the population allele frequency record. Primary key for this reference data product.' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consequence rdf:type rdf:Property ;
    rdfs:label 'Consequence' ;
    rdfs:comment 'Predicted functional consequence of the variant on the transcript using Sequence Ontology terms (e.g., missense_variant, synonymous_variant, frameshift_variant, splice_donor_variant).' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Data Source Url' ;
    rdfs:comment 'URL or persistent identifier linking to the original source record in the external database (e.g., gnomAD browser link, dbSNP link). Supports audit trail and regulatory traceability.' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hemizygoteCount rdf:type rdf:Property ;
    rdfs:label 'Hemizygote Count' ;
    rdfs:comment 'Number of individuals hemizygous for the alternate allele. Applicable to X and Y chromosome variants in males and mitochondrial variants.' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homozygoteCount rdf:type rdf:Property ;
    rdfs:label 'Homozygote Count' ;
    rdfs:comment 'Number of individuals in the population cohort who are homozygous for the alternate allele (carry two copies).' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this reference data record. Active records are current and approved for use in analysis pipelines; deprecated or superseded records are retained for historical traceability.' ;
    rdfs:domain ind:PopulationAlleleFrequency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apprisAnnotation rdf:type rdf:Property ;
    rdfs:label 'Appris Annotation' ;
    rdfs:comment 'APPRIS annotation classifying the transcript as principal (most functionally important isoform) or alternative, with confidence levels 1-5 for principal isoforms. Principal1 is the highest confidence. Used to prioritize functionally relevant isoforms in variant interpretation. [ENUM-REF-CANDIDATE: principal1|principal2|principal3|principal4|principal5|alternative1|alternative2 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biotype rdf:type rdf:Property ;
    rdfs:label 'Biotype' ;
    rdfs:comment 'Functional classification of the transcript indicating its biological role: protein_coding (translates to protein), lncRNA (long non-coding RNA), miRNA (microRNA), snRNA (small nuclear RNA), snoRNA (small nucleolar RNA), rRNA (ribosomal RNA), pseudogene (non-functional gene copy), processed_transcript (non-coding transcript without clear classification), retained_intron (transcript with retained intron), nonsense_mediated_decay (transcript subject to NMD pathway). Critical for filtering coding vs non-coding variants in clinical pipelines. [ENUM-REF-CANDIDATE: protein_coding|lncRNA|miRNA|snRNA|snoRNA|rRNA|pseudogene|processed_transcript|retained_intron|nonsense_mediated_decay — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccdsAccession rdf:type rdf:Property ;
    rdfs:label 'Ccds Accession' ;
    rdfs:comment 'Consensus CDS identifier for transcripts that are identically annotated across multiple annotation sources (Ensembl, RefSeq, UCSC). Null if not part of CCDS. High-confidence coding transcripts used in clinical reporting.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdsEndPosition rdf:type rdf:Property ;
    rdfs:label 'Cds End Position' ;
    rdfs:comment 'Genomic coordinate (1-based) of the coding sequence end position (translation termination site, typically stop codon). Null for non-coding transcripts. Essential for determining whether a variant falls in the coding region or 3\' UTR.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdsStartPosition rdf:type rdf:Property ;
    rdfs:label 'Cds Start Position' ;
    rdfs:comment 'Genomic coordinate (1-based) of the coding sequence start position (translation initiation site, typically ATG start codon). Null for non-coding transcripts. Essential for determining whether a variant falls in the 5\' UTR, coding region, or 3\' UTR.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codingLengthBp rdf:type rdf:Property ;
    rdfs:label 'Coding Length Bp' ;
    rdfs:comment 'Length of the coding sequence (CDS) in base pairs, from start codon to stop codon. Null for non-coding transcripts. Used for protein length calculation (coding_length_bp / 3) and frameshift variant impact assessment.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ensemblTranscriptAccession rdf:type rdf:Property ;
    rdfs:label 'Ensembl Transcript Accession' ;
    rdfs:comment 'Ensembl stable transcript identifier with optional version suffix (e.g., ENST00000456328.2). Primary external reference for Ensembl-based annotation pipelines.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exonCount rdf:type rdf:Property ;
    rdfs:label 'Exon Count' ;
    rdfs:comment 'Total number of exons in this transcript model. Used for splice site analysis, exon-level variant annotation, and transcript structure validation.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gencodeTag rdf:type rdf:Property ;
    rdfs:label 'Gencode Tag' ;
    rdfs:comment 'Comma-separated list of GENCODE tags providing additional transcript metadata (e.g., basic, CCDS, appris_principal, MANE_Select, exp_conf). Used for advanced filtering and quality assessment in annotation pipelines.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCanonical rdf:type rdf:Property ;
    rdfs:label 'Is Canonical' ;
    rdfs:comment 'Boolean flag indicating whether this transcript is designated as the canonical (representative) transcript for the gene. Canonical transcripts are typically the longest coding transcript or the most biologically relevant isoform, used as the default for variant annotation when multiple isoforms exist.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManePlusClinical rdf:type rdf:Property ;
    rdfs:label 'Is Mane Plus Clinical' ;
    rdfs:comment 'Boolean flag indicating whether this transcript is designated as a MANE Plus Clinical transcript. MANE Plus Clinical includes additional clinically relevant transcripts beyond MANE Select that are important for clinical variant interpretation, particularly for genes with multiple clinically significant isoforms.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManeSelect rdf:type rdf:Property ;
    rdfs:label 'Is Mane Select' ;
    rdfs:comment 'Boolean flag indicating whether this transcript is designated as the MANE Select transcript. MANE Select represents the single agreed-upon transcript per gene between RefSeq and Ensembl/GENCODE, providing a gold-standard reference for clinical reporting and variant interpretation. Critical for regulatory-grade IVD/LDT assays.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proteinAccession rdf:type rdf:Property ;
    rdfs:label 'Protein Accession' ;
    rdfs:comment 'Ensembl protein identifier (ENSP) or RefSeq protein accession (NP_ for reviewed, XP_ for predicted) associated with this transcript. Null for non-coding transcripts. Used for protein-level variant annotation and functional impact prediction.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refseqAccession rdf:type rdf:Property ;
    rdfs:label 'Refseq Accession' ;
    rdfs:comment 'NCBI RefSeq transcript accession (NM_ for protein-coding mRNA, NR_ for non-coding RNA, XM_/XR_ for predicted models) with optional version. Used for clinical variant reporting and cross-reference to NCBI databases.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcriptEndPosition rdf:type rdf:Property ;
    rdfs:label 'Transcript End Position' ;
    rdfs:comment 'Genomic coordinate (1-based) of the transcript end position (transcription termination site). Used for genomic range queries and variant overlap detection.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcriptLengthBp rdf:type rdf:Property ;
    rdfs:label 'Transcript Length Bp' ;
    rdfs:comment 'Total length of the transcript in base pairs, including all exons from transcription start to transcription end. Used for transcript size filtering and coverage depth calculations in sequencing QC.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcriptName rdf:type rdf:Property ;
    rdfs:label 'Transcript Name' ;
    rdfs:comment 'Human-readable name or symbol for the transcript, often derived from the gene symbol with a transcript-specific suffix (e.g., BRCA1-201, TP53-001).' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcriptStartPosition rdf:type rdf:Property ;
    rdfs:label 'Transcript Start Position' ;
    rdfs:comment 'Genomic coordinate (1-based) of the transcript start position (transcription start site). Used for genomic range queries and variant overlap detection.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transcriptSupportLevel rdf:type rdf:Property ;
    rdfs:label 'Transcript Support Level' ;
    rdfs:comment 'Ensembl Transcript Support Level (1-5) indicating the quality of experimental evidence supporting the transcript structure: 1 (all splice junctions supported by at least one non-suspect mRNA), 2 (best supporting mRNA is flagged as suspect or support from multiple ESTs), 3 (only support is from single EST), 4 (best supporting EST is flagged as suspect), 5 (no single transcript supports the model structure). Lower values indicate higher confidence. Used for transcript filtering in clinical pipelines.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utr3PrimeEnd rdf:type rdf:Property ;
    rdfs:label 'Utr 3 Prime End' ;
    rdfs:comment 'Genomic coordinate (1-based) of the 3\' UTR end position (transcript end). Null for non-coding transcripts or transcripts without annotated 3\' UTR. Used for regulatory variant analysis and polyadenylation signal assessment.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utr3PrimeStart rdf:type rdf:Property ;
    rdfs:label 'Utr 3 Prime Start' ;
    rdfs:comment 'Genomic coordinate (1-based) of the 3\' UTR start position (immediately after CDS end). Null for non-coding transcripts or transcripts without annotated 3\' UTR. Used for regulatory variant analysis and polyadenylation signal assessment.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utr5PrimeEnd rdf:type rdf:Property ;
    rdfs:label 'Utr 5 Prime End' ;
    rdfs:comment 'Genomic coordinate (1-based) of the 5\' UTR end position (immediately before CDS start). Null for non-coding transcripts or transcripts without annotated 5\' UTR. Used for regulatory variant analysis.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utr5PrimeStart rdf:type rdf:Property ;
    rdfs:label 'Utr 5 Prime Start' ;
    rdfs:comment 'Genomic coordinate (1-based) of the 5\' UTR start position (transcript start before the CDS). Null for non-coding transcripts or transcripts without annotated 5\' UTR. Used for regulatory variant analysis.' ;
    rdfs:domain ind:TranscriptModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementDatabaseVariantDatabaseId rdf:type rdf:Property ;
    rdfs:label 'Replacement Database Variant Database Id' ;
    rdfs:comment 'Reference to the variant_database_id of the newer version that replaces this deprecated database.' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantDatabase .

ind:annotationFields rdf:type rdf:Property ;
    rdfs:label 'Annotation Fields' ;
    rdfs:comment 'Comma-separated list of annotation fields or INFO tags provided by this database (e.g., CLNSIG, AF, CADD, SIFT, PolyPhen).' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citation rdf:type rdf:Property ;
    rdfs:label 'Citation' ;
    rdfs:comment 'Full bibliographic citation or DOI for the primary publication describing this variant database, required for regulatory documentation.' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Clinical Validation Status' ;
    rdfs:comment 'Indicates whether this database has been validated for use in clinical reporting workflows per regulatory requirements.' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeGb rdf:type rdf:Property ;
    rdfs:label 'File Size Gb' ;
    rdfs:comment 'Total size of the database files in gigabytes, used for storage planning and download estimation.' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationCoverage rdf:type rdf:Property ;
    rdfs:label 'Population Coverage' ;
    rdfs:comment 'Description of the populations or ancestries represented in the database (e.g., global, European, African, East Asian, admixed).' ;
    rdfs:domain ind:Reference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDatabaseStatus rdf:type rdf:Property ;
    rdfs:label 'Variant Database Status' ;
    rdfs:comment 'Current lifecycle status of the variant database in the annotation pipeline registry.' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vcfSchemaVersion rdf:type rdf:Property ;
    rdfs:label 'Vcf Schema Version' ;
    rdfs:comment 'Version of the VCF specification that the database files conform to (e.g., VCFv4.2, VCFv4.3).' ;
    rdfs:domain ind:VariantDatabase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'Date when this database version was officially adopted for use in production annotation pipelines. Marks the start of active use.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annotationPipelineCompatibility rdf:type rdf:Property ;
    rdfs:label 'Annotation Pipeline Compatibility' ;
    rdfs:comment 'Comma-separated list of internal annotation pipeline versions or tools compatible with this database version (e.g., VEP 105, SnpEff 5.1). Supports pipeline configuration management.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalUseApproved rdf:type rdf:Property ;
    rdfs:label 'Clinical Use Approved' ;
    rdfs:comment 'Boolean flag indicating whether this database version is approved for use in clinical diagnostic workflows (True) or restricted to research use only (False). Critical for CLIA/CAP compliance.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Data Format Version' ;
    rdfs:comment 'Version of the data format specification used (e.g., VCF 4.2, VCF 4.3). Ensures parser compatibility and data structure understanding.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:md5Checksum rdf:type rdf:Property ;
    rdfs:label 'Md5 Checksum' ;
    rdfs:comment 'MD5 hash of the VCF file for integrity verification. Ensures file has not been corrupted or tampered with during transfer or storage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPathogenicCount rdf:type rdf:Property ;
    rdfs:label 'New Pathogenic Count' ;
    rdfs:comment 'Number of newly classified pathogenic or likely pathogenic variants in this release. Critical for clinical variant interpretation updates.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reclassifiedCount rdf:type rdf:Property ;
    rdfs:label 'Reclassified Count' ;
    rdfs:comment 'Number of variants with updated clinical significance classifications (e.g., VUS to pathogenic, pathogenic to benign). Tracks curation quality and knowledge evolution.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retractedCount rdf:type rdf:Property ;
    rdfs:label 'Retracted Count' ;
    rdfs:comment 'Number of variant entries retracted or deprecated in this release due to errors, duplicates, or updated evidence. Important for data quality auditing.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sha256Checksum rdf:type rdf:Property ;
    rdfs:label 'Sha256 Checksum' ;
    rdfs:comment 'SHA-256 cryptographic hash of the VCF file for enhanced integrity verification. Provides stronger security than MD5 for regulatory-grade data validation.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text notes documenting validation findings, issues identified, or special considerations for this database version. Supports audit trail and troubleshooting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCountDelta rdf:type rdf:Property ;
    rdfs:label 'Variant Count Delta' ;
    rdfs:comment 'Net change in variant count compared to the previous version (positive for additions, negative for removals). Tracks database growth or curation changes.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vcfFilePath rdf:type rdf:Property ;
    rdfs:label 'Vcf File Path' ;
    rdfs:comment 'Storage location or URI of the VCF file containing the variant database content for this version. Enables reproducible annotation pipeline execution.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vcfFileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Vcf File Size Bytes' ;
    rdfs:comment 'Size of the VCF file in bytes. Used for storage planning and data transfer validation.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Version Identifier' ;
    rdfs:comment 'Specific version identifier or build number of the database release (e.g., b156 for dbSNP, 2024-03 for ClinVar). Uniquely identifies the snapshot used in annotation pipelines.' ;
    rdfs:domain ind:VariantDatabaseVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedMarkets rdf:type rdf:Property ;
    rdfs:label 'Affected Markets' ;
    rdfs:comment 'Comma-separated list of geographic markets or jurisdictions affected by the adverse event or corrective action (e.g., USA, DEU, GBR, FRA).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgment Date' ;
    rdfs:comment 'Date when the regulatory agency acknowledged receipt of the adverse event report.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Reference Number' ;
    rdfs:comment 'Reference number or tracking identifier assigned by the regulatory agency (FDA, EMA, competent authority) upon receipt of the report.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionType rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Type' ;
    rdfs:comment 'Type of corrective action taken in response to the adverse event. Recall, FSCA (Field Safety Corrective Action), FSN (Field Safety Notice), product modification, labeling change, or no action required.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceLotNumber rdf:type rdf:Property ;
    rdfs:label 'Device Lot Number' ;
    rdfs:comment 'Lot number or batch number of the device involved in the adverse event. Critical for traceability and recall scope determination.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceProductCode rdf:type rdf:Property ;
    rdfs:label 'Device Product Code' ;
    rdfs:comment 'Product code or SKU (Stock Keeping Unit) of the device involved in the adverse event. Links to product master for device identification.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Serial number of the specific device unit involved in the adverse event, if applicable. Enables unit-level traceability.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date when the adverse event or serious incident occurred. Principal business event timestamp for post-market surveillance.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the adverse event, serious incident, or field safety issue. Includes patient/user impact, device behavior, and circumstances of the event.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientImpact rdf:type rdf:Property ;
    rdfs:label 'Patient Impact' ;
    rdfs:comment 'Severity classification of the impact on the patient or user. Death, serious injury, malfunction with no injury, or no impact. Determines reportability and urgency.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Reportability Determination' ;
    rdfs:comment 'Assessment of whether the event meets regulatory criteria for mandatory reporting to health authorities (FDA, EMA, competent authorities).' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportabilityRationale rdf:type rdf:Property ;
    rdfs:label 'Reportability Rationale' ;
    rdfs:comment 'Business justification for the reportability determination. Documents the regulatory assessment and decision-making process.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterContact rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact' ;
    rdfs:comment 'Contact information (email or phone) for the individual who reported the adverse event. Used for follow-up inquiries.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Name of the individual or organization who reported the adverse event. May be confidential depending on jurisdiction.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterType rdf:type rdf:Property ;
    rdfs:label 'Reporter Type' ;
    rdfs:comment 'Classification of the party who reported the adverse event. Customer, field service engineer, internal QA, regulatory authority, or healthcare provider.' ;
    rdfs:domain ind:AdverseEventReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified root cause of the adverse event based on investigation. Links to quality investigation and CAPA processes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the adverse event report was submitted to the regulatory agency (FDA, EMA, competent authority).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method used to submit the report to the regulatory agency. Electronic (e.g., FDA eSubmitter), paper, or agency portal.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Agency Correspondence Id' ;
    rdfs:comment 'Unique identifier for the regulatory agency correspondence record. Primary key.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Agency correspondence must be assigned to specific regulatory affairs employees for action tracking, response management, and workload planning. Critical for managing FDA/EMA interactions, meeting res' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Email address of the agency contact for follow-up and correspondence tracking.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the primary agency representative or reviewer handling the correspondence.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Phone' ;
    rdfs:comment 'Phone number of the agency contact for direct communication.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyDivision rdf:type rdf:Property ;
    rdfs:label 'Agency Division' ;
    rdfs:comment 'Specific division, office, or department within the regulatory agency handling the correspondence (e.g., FDA CDRH Office of In Vitro Diagnostics and Radiological Health, EMA CHMP).' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyFeedbackReceived rdf:type rdf:Property ;
    rdfs:label 'Agency Feedback Received' ;
    rdfs:comment 'Summary of the feedback, guidance, or recommendations provided by the regulatory agency in response to the correspondence or meeting.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'The regulatory agency or body involved in the correspondence (e.g., FDA, EMA, Notified Body, CLIA, CAP, Health Canada, TGA, PMDA, NMPA, ANVISA). [ENUM-REF-CANDIDATE: fda|ema|notified_body|clia|cap|health_canada|tga|pmda|nmpa|anvisa|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaTopics rdf:type rdf:Property ;
    rdfs:label 'Agenda Topics' ;
    rdfs:comment 'List or description of topics covered in the meeting agenda or correspondence discussion points.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceDate rdf:type rdf:Property ;
    rdfs:label 'Correspondence Date' ;
    rdfs:comment 'The official date the correspondence was sent or received, as indicated on the document or communication.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Number' ;
    rdfs:comment 'Business identifier for the correspondence record, often assigned by the agency or internal tracking system (e.g., FDA Q-Sub number, EMA procedure number).' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceStatus rdf:type rdf:Property ;
    rdfs:label 'Correspondence Status' ;
    rdfs:comment 'Current lifecycle status of the correspondence record, indicating whether it is open, awaiting response, closed, or archived.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceType rdf:type rdf:Property ;
    rdfs:label 'Correspondence Type' ;
    rdfs:comment 'Classification of the correspondence based on its purpose and stage in the regulatory lifecycle. [ENUM-REF-CANDIDATE: pre_submission|deficiency_letter|additional_information_request|interactive_review_meeting|agency_question|agency_response|scientific_advice|notified_body_query|post_approval_correspondence|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the correspondence was received from the agency (inbound) or sent to the agency (outbound).' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or link to the controlled document in the document management system (e.g., Veeva Vault document ID) containing the full correspondence text or meeting minutes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnSubmissionStrategy rdf:type rdf:Property ;
    rdfs:label 'Impact On Submission Strategy' ;
    rdfs:comment 'Assessment of how the agency feedback or correspondence outcome affects the overall regulatory submission strategy, timelines, or approach.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSubtype rdf:type rdf:Property ;
    rdfs:label 'Interaction Subtype' ;
    rdfs:comment 'Detailed subtype of the interaction, providing granular classification (e.g., FDA Q-Sub for quality questions, Pre-Sub for pre-submission meetings, AIR for Additional Information Request). [ENUM-REF-CANDIDATE: q_sub|pre_sub|pre_application_consultation|deficiency_response|air_response|meeting_request|meeting_minutes|clarification_request|withdrawal_notice|approval_letter|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyQuestionsPosed rdf:type rdf:Property ;
    rdfs:label 'Key Questions Posed' ;
    rdfs:comment 'Summary of the primary questions or issues raised by the sponsor or agency during the correspondence or meeting.' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Date of the regulatory meeting or teleconference, if the correspondence relates to a scheduled interaction (e.g., Pre-Sub meeting, EMA scientific advice session).' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the meeting format (e.g., FDA Type A/B/C meeting, EMA scientific advice, notified body pre-application consultation). [ENUM-REF-CANDIDATE: pre_submission|interactive_review|type_c|type_b|scientific_advice|pre_application|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AgencyCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalEvidenceId rdf:type rdf:Property ;
    rdfs:label 'Clinical Evidence Id' ;
    rdfs:comment 'Unique identifier for the clinical evidence record. Primary key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEvidence .

ind:analyticalSensitivityLod rdf:type rdf:Property ;
    rdfs:label 'Analytical Sensitivity Lod' ;
    rdfs:comment 'Limit of detection (LOD) value demonstrating the lowest concentration or quantity of analyte that can be reliably detected.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSensitivityPercent rdf:type rdf:Property ;
    rdfs:label 'Clinical Sensitivity Percent' ;
    rdfs:comment 'Clinical sensitivity (true positive rate) expressed as a percentage, demonstrating the ability to correctly identify positive cases.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalSpecificityPercent rdf:type rdf:Property ;
    rdfs:label 'Clinical Specificity Percent' ;
    rdfs:comment 'Clinical specificity (true negative rate) expressed as a percentage, demonstrating the ability to correctly identify negative cases.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalUtilityStatement rdf:type rdf:Property ;
    rdfs:label 'Clinical Utility Statement' ;
    rdfs:comment 'Summary of the clinical utility demonstrated by this evidence, describing how the test result informs clinical decision-making or patient management.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceNumber rdf:type rdf:Property ;
    rdfs:label 'Evidence Number' ;
    rdfs:comment 'Business identifier for the clinical evidence package, formatted as CE-NNNNNN.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Status' ;
    rdfs:comment 'Current lifecycle status of the clinical evidence package: draft, in review, approved, submitted to regulatory authority, archived, or superseded.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceTitle rdf:type rdf:Property ;
    rdfs:label 'Evidence Title' ;
    rdfs:comment 'Descriptive title of the clinical or performance evidence package.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceType rdf:type rdf:Property ;
    rdfs:label 'Evidence Type' ;
    rdfs:comment 'Category of clinical evidence: clinical evaluation report (CER), performance evaluation report (PER), analytical validation study, clinical utility study, literature review summary, or post-market clinical follow-up (PMCF).' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:informedConsentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether informed consent was obtained from study participants (True/False).' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negativePredictiveValuePercent rdf:type rdf:Property ;
    rdfs:label 'Negative Predictive Value Percent' ;
    rdfs:comment 'Negative predictive value (NPV) expressed as a percentage, indicating the probability that a negative test result is a true negative.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positivePredictiveValuePercent rdf:type rdf:Property ;
    rdfs:label 'Positive Predictive Value Percent' ;
    rdfs:comment 'Positive predictive value (PPV) expressed as a percentage, indicating the probability that a positive test result is a true positive.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reproducibility rdf:type rdf:Property ;
    rdfs:label 'Reproducibility' ;
    rdfs:comment 'Description of reproducibility metrics across different operators, instruments, sites, or time points.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesign rdf:type rdf:Property ;
    rdfs:label 'Study Design' ;
    rdfs:comment 'Methodological design of the study or evidence generation activity. [ENUM-REF-CANDIDATE: prospective_cohort|retrospective_cohort|case_control|randomized_controlled_trial|observational|meta_analysis|systematic_review|bench_study|not_applicable — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studySite rdf:type rdf:Property ;
    rdfs:label 'Study Site' ;
    rdfs:comment 'Name and location of the clinical or laboratory site where the study was conducted.' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Description of the patient or sample population for which the evidence applies (e.g., adult oncology patients, prenatal screening cohort).' ;
    rdfs:domain ind:ClinicalEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Conformity Assessment Id' ;
    rdfs:comment 'Unique identifier for the conformity assessment activity. Primary key for the conformity assessment record.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalAssessmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Internal Assessment Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal owner for conformity assessments coordinates notified body interactions, audit preparation, and CAPA responses. Links assessments to qualified employees responsible for ISO 13485 compliance a' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:notifiedBodyId rdf:type rdf:Property ;
    rdfs:label 'Notified Body Id' ;
    rdfs:comment 'Foreign key linking to regulatory.notified_body. Business justification: conformity_assessment records audits conducted by notified bodies. Each assessment is performed by one notified_body. Adding notified_body_id FK normalizes notified_body_name and notified_body_number ' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotifiedBody .

ind:assessmentCost rdf:type rdf:Property ;
    rdfs:label 'Assessment Cost' ;
    rdfs:comment 'Total cost incurred for the conformity assessment, including notified body fees, travel expenses, and internal resource costs.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Assessment Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the assessment cost (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the conformity assessment, typically assigned by the notified body or internal quality system. Used for external reference and tracking.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportReference rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Reference' ;
    rdfs:comment 'Reference identifier or document number for the formal conformity assessment report issued by the notified body or audit team.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of days allocated for the audit phase of the conformity assessment.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'Date when the on-site or remote audit phase of the conformity assessment concludes.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditStartDate rdf:type rdf:Property ;
    rdfs:label 'Audit Start Date' ;
    rdfs:comment 'Date when the on-site or remote audit phase of the conformity assessment begins.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of audit team members participating in the conformity assessment, including technical experts and observers.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Acceptance Status' ;
    rdfs:comment 'Status of the notified body or auditor review and acceptance of submitted CAPA responses.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Response Due Date' ;
    rdfs:comment 'Deadline by which the organization must submit CAPA responses to address findings from the conformity assessment.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaResponseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Capa Response Submitted Date' ;
    rdfs:comment 'Date when the organization submitted CAPA responses to the notified body or auditor.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the issued conformity assessment certificate expires and requires renewal or re-assessment.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date when the conformity assessment certificate was officially issued by the notified body.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOutcome rdf:type rdf:Property ;
    rdfs:label 'Certificate Outcome' ;
    rdfs:comment 'Final outcome of the conformity assessment in terms of certification or approval status.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateValidityYears rdf:type rdf:Property ;
    rdfs:label 'Certificate Validity Years' ;
    rdfs:comment 'Number of years for which the conformity assessment certificate is valid before requiring renewal.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of findings, observations, or non-conformities identified during the conformity assessment.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of key findings, non-conformities, and observations identified during the conformity assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Name of the lead auditor or assessor responsible for conducting the conformity assessment.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Major Nonconformities Count' ;
    rdfs:comment 'Number of major non-conformities identified that represent significant deviations from requirements and may impact product safety or regulatory compliance.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nonconformities Count' ;
    rdfs:comment 'Number of minor non-conformities identified that represent less significant deviations from requirements.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextSurveillanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Surveillance Due Date' ;
    rdfs:comment 'Scheduled date for the next surveillance audit required to maintain the conformity assessment certificate.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the assessment that do not constitute non-conformities.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategoryCovered rdf:type rdf:Property ;
    rdfs:label 'Product Category Covered' ;
    rdfs:comment 'Product categories or device classifications covered by this conformity assessment (e.g., Class A, Class B, Class C, Class D IVDs, NGS instruments, reagent kits).' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Qms Standard Version' ;
    rdfs:comment 'Version of the Quality Management System standard against which the assessment is conducted (e.g., ISO 13485:2016).' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Surveillance Frequency Months' ;
    rdfs:comment 'Frequency in months at which surveillance audits must be conducted to maintain the conformity assessment certificate.' ;
    rdfs:domain ind:ConformityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gudidSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Gudid Submission Id' ;
    rdfs:comment 'The unique submission identifier assigned by FDA GUDID when the device identifier record was submitted to the FDA database.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:basicUdiDi rdf:type rdf:Property ;
    rdfs:label 'Basic Udi Di' ;
    rdfs:comment 'The primary identifier of a device model that groups all device versions or models having the same intended purpose, design, and risk classification. Used for regulatory database queries.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsLatexFlag rdf:type rdf:Property ;
    rdfs:label 'Contains Latex Flag' ;
    rdfs:comment 'Indicates whether the device or its packaging contains natural rubber latex, requiring allergen labeling.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceClassification rdf:type rdf:Property ;
    rdfs:label 'Device Classification' ;
    rdfs:comment 'The risk-based classification of the device under FDA or EU IVDR regulations. FDA uses Class I/II/III; EU IVDR uses Class A/B/C/D for IVDs. [ENUM-REF-CANDIDATE: class_i|class_iia|class_iib|class_iii|class_a|class_b|class_c|class_d — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceDescription rdf:type rdf:Property ;
    rdfs:label 'Device Description' ;
    rdfs:comment 'A detailed description of the device including its intended use, technology, and key features for regulatory database publication.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceName rdf:type rdf:Property ;
    rdfs:label 'Device Name' ;
    rdfs:comment 'The proprietary or trade name of the device as it appears on the label and in regulatory submissions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Registration Number' ;
    rdfs:comment 'The Single Registration Number (SRN) assigned to the manufacturer or authorized representative in EUDAMED for economic operator identification.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudamedDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Eudamed Device Identifier' ;
    rdfs:comment 'The unique device identifier assigned by EUDAMED for EU IVDR compliance. Links to the EU device registration and economic operator records.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudamedRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Eudamed Registration Date' ;
    rdfs:comment 'The date the device was registered in EUDAMED by the manufacturer or authorized representative.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eudamedRegistrationStatus rdf:type rdf:Property ;
    rdfs:label 'Eudamed Registration Status' ;
    rdfs:comment 'The current registration status of the device in the European Database on Medical Devices under EU IVDR Article 26.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gudidStatus rdf:type rdf:Property ;
    rdfs:label 'Gudid Status' ;
    rdfs:comment 'The current status of the device identifier record in the FDA GUDID system.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gudidSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Gudid Submission Date' ;
    rdfs:comment 'The date the UDI-DI record was submitted to the FDA Global Unique Device Identification Database.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'The FDA-accredited issuing agency that assigned the UDI-DI code. GS1 (Global Standards 1), HIBCC (Health Industry Business Communications Council), or ICCBBA (International Council for Commonality in Blood Banking Automation).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Labeling Effective Date' ;
    rdfs:comment 'The date on which the current UDI labeling became effective and must appear on all newly manufactured devices.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelingStorageConditions rdf:type rdf:Property ;
    rdfs:label 'Labeling Storage Conditions' ;
    rdfs:comment 'The storage temperature and environmental conditions specified on the device label (e.g., 2-8°C, room temperature, protect from light).' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mriSafetyStatus rdf:type rdf:Property ;
    rdfs:label 'Mri Safety Status' ;
    rdfs:comment 'The MRI safety classification of the device indicating whether it is safe, conditionally safe, or unsafe in an MRI environment.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageQuantity rdf:type rdf:Property ;
    rdfs:label 'Package Quantity' ;
    rdfs:comment 'The number of individual device units contained in the labeled package.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The type of packaging used for the device (e.g., box, vial, tube, cartridge, flow cell).' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'The email address of the regulatory affairs contact for UDI-related inquiries and submissions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'The name of the regulatory affairs contact responsible for this UDI assignment and database submissions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruoIvdDesignation rdf:type rdf:Property ;
    rdfs:label 'Ruo Ivd Designation' ;
    rdfs:comment 'Indicates whether the device is marketed for Research Use Only, as an In Vitro Diagnostic, or as a Laboratory Developed Test.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleUseFlag rdf:type rdf:Property ;
    rdfs:label 'Single Use Flag' ;
    rdfs:comment 'Indicates whether the device is intended for single use only and must not be reprocessed or reused.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterileFlag rdf:type rdf:Property ;
    rdfs:label 'Sterile Flag' ;
    rdfs:comment 'Indicates whether the device is provided in a sterile state and requires sterile labeling and handling.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:udiAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Udi Assignment Status' ;
    rdfs:comment 'The current lifecycle status of this UDI assignment record indicating whether it is actively used on device labels.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiCarrierType rdf:type rdf:Property ;
    rdfs:label 'Udi Carrier Type' ;
    rdfs:comment 'The form of automatic identification and data capture (AIDC) technology or human-readable interpretation used to convey the UDI on the device label.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiDiCode rdf:type rdf:Property ;
    rdfs:label 'Udi Di Code' ;
    rdfs:comment 'The Device Identifier portion of the UDI that identifies the labeler and specific version or model of a device. Globally unique and assigned by an FDA-accredited issuing agency.' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiPiFormat rdf:type rdf:Property ;
    rdfs:label 'Udi Pi Format' ;
    rdfs:comment 'The format of the Production Identifier portion of the UDI that identifies one or more production-specific attributes (lot, serial, manufacturing date, expiration date) for traceability. [ENUM-REF-CANDIDATE: lot_number|serial_number|manufacturing_date|expiration_date|lot_and_serial|lot_and_expiration|serial_and_expiration — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeviceIdentifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contact Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Establishment registration contact must be an internal employee for FDA establishment registration, annual updates, and regulatory correspondence. Links registration to qualified employees responsible' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Due Date' ;
    rdfs:comment 'Date by which the annual establishment registration update or report must be submitted to the regulatory authority. Format yyyy-MM-dd.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedRepresentativeAddress rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Address' ;
    rdfs:comment 'Full address of the authorized representative. Must be located within the jurisdiction where representation is required.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Name' ;
    rdfs:comment 'Name of the authorized representative in the EU or other jurisdiction acting on behalf of the manufacturer. Required for non-EU manufacturers under IVDR.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Person Title' ;
    rdfs:comment 'Job title or role of the primary regulatory contact person. Typically Regulatory Affairs Manager, Quality Director, or similar.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceClassificationScope rdf:type rdf:Property ;
    rdfs:label 'Device Classification Scope' ;
    rdfs:comment 'Regulatory device classifications covered by this establishment registration. For FDA: Class I, II, III. For EU: Class A, B, C, D per IVDR. May include multiple classifications.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTypesManufactured rdf:type rdf:Property ;
    rdfs:label 'Device Types Manufactured' ;
    rdfs:comment 'Comma-separated list or description of the types of medical devices or IVD products manufactured, imported, or distributed by this establishment. Includes product categories such as NGS sequencers, array platforms, reagent kits, consumables.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDbaName rdf:type rdf:Property ;
    rdfs:label 'Establishment Dba Name' ;
    rdfs:comment 'Trade name or doing business as name if different from legal establishment name. Used for facilities operating under alternate brand names.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentName rdf:type rdf:Property ;
    rdfs:label 'Establishment Name' ;
    rdfs:comment 'Legal name of the facility or establishment as registered with the regulatory authority. Must match official business registration documents.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Facility Address Line1' ;
    rdfs:comment 'Primary street address line of the registered establishment facility. Includes street number, street name, and building identifier.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Facility Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, department, or other location details within the facility.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCity rdf:type rdf:Property ;
    rdfs:label 'Facility City' ;
    rdfs:comment 'City or municipality where the registered establishment is physically located.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the country where the establishment is physically located.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPostalCode rdf:type rdf:Property ;
    rdfs:label 'Facility Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the facility address. Format varies by country jurisdiction.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStateProvince rdf:type rdf:Property ;
    rdfs:label 'Facility State Province' ;
    rdfs:comment 'State, province, or administrative region where the facility is located. Use standard postal abbreviations where applicable.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified Flag' ;
    rdfs:comment 'Indicates whether the establishment holds valid GMP certification. True if certified under applicable GMP regulations, false otherwise.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso13485CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Certificate Number' ;
    rdfs:comment 'Certificate number for the establishments ISO 13485 certification if applicable. Issued by notified body or certification authority.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso13485CertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Certified Flag' ;
    rdfs:comment 'Indicates whether the establishment holds valid ISO 13485 quality management system certification for medical devices.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the regulatory jurisdiction under which this registration is filed. May differ from facility country for authorized representative registrations.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Regional or sub-national jurisdiction if applicable. Used for countries with state-level or provincial regulatory requirements.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date when the most recent renewal was completed and accepted by the regulatory authority. Format yyyy-MM-dd.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'Target date for the next registration renewal submission. Used for proactive compliance tracking. Format yyyy-MM-dd.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Name' ;
    rdfs:comment 'Name of the legal entity or individual that owns or operates the establishment. May differ from establishment name for contract facilities.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Name of the parent company or corporate entity if the establishment is part of a larger organization. Used for corporate hierarchy tracking.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Type of establishment registration indicating the role of the facility in the supply chain. Manufacturer produces devices, importer brings devices into jurisdiction, distributor handles logistics, authorized representative acts on behalf of non-EU manufacturer, contract manufacturer produces under contract, sterilizer provides sterilization services.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this registration requires periodic renewal. True for jurisdictions requiring annual or periodic renewal, false for indefinite registrations.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usAgentAddress rdf:type rdf:Property ;
    rdfs:label 'Us Agent Address' ;
    rdfs:comment 'Full address of the designated US agent. Must be a physical US address, not a post office box.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usAgentName rdf:type rdf:Property ;
    rdfs:label 'Us Agent Name' ;
    rdfs:comment 'Name of the US agent designated by foreign establishments for FDA registration per 21 CFR 807.40. Required for non-US manufacturers marketing devices in the United States.' ;
    rdfs:domain ind:EstablishmentRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudamedRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Eudamed Registration Id' ;
    rdfs:comment 'Unique identifier for the EUDAMED registration record. Primary key for this entity.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companionDiagnosticFlag rdf:type rdf:Property ;
    rdfs:label 'Companion Diagnostic Flag' ;
    rdfs:comment 'Indicates whether the device is a companion diagnostic essential for the safe and effective use of a corresponding medicinal product. Requires coordination with EMA.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conformityAssessmentRoute rdf:type rdf:Property ;
    rdfs:label 'Conformity Assessment Route' ;
    rdfs:comment 'The specific conformity assessment procedure followed under EU IVDR: Annex IX (full quality assurance), Annex X (type examination), or Annex XI (product conformity verification).' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceModel rdf:type rdf:Property ;
    rdfs:label 'Device Model' ;
    rdfs:comment 'The specific model or version identifier of the IVD device, distinguishing it from other variants within the same product family.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorAddress rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Address' ;
    rdfs:comment 'The registered address of the economic operator responsible for the device. Required for EUDAMED registration and regulatory correspondence.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorCountryCode rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the economic operator is registered.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorName rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Name' ;
    rdfs:comment 'The legal name of the economic operator (manufacturer, authorized representative, importer, or distributor) responsible for this EUDAMED registration.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorSrn rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Srn' ;
    rdfs:comment 'The unique Single Registration Number assigned to the economic operator upon registration in EUDAMED. Format: country code followed by alphanumeric identifier.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicOperatorType rdf:type rdf:Property ;
    rdfs:label 'Economic Operator Type' ;
    rdfs:comment 'The role of the economic operator registering the device in EUDAMED: manufacturer, authorized representative, importer, or distributor.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmdnTerm rdf:type rdf:Property ;
    rdfs:label 'Gmdn Term' ;
    rdfs:comment 'The descriptive term associated with the GMDN code, providing a standardized name for the device category.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedPurpose rdf:type rdf:Property ;
    rdfs:label 'Intended Purpose' ;
    rdfs:comment 'The intended use of the IVD device as defined by the manufacturer, describing the medical condition, disease, or physiological process it is designed to detect, diagnose, or monitor.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingEntity rdf:type rdf:Property ;
    rdfs:label 'Issuing Entity' ;
    rdfs:comment 'The organization that issued the UDI-DI under an FDA or EU-recognized UDI system. Common entities include GS1, HIBCC, ICCBBA, and IFA.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Update Date' ;
    rdfs:comment 'The date on which the EUDAMED registration was last updated with new information or status changes.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notifiedBodyName rdf:type rdf:Property ;
    rdfs:label 'Notified Body Name' ;
    rdfs:comment 'The name of the notified body that conducted the conformity assessment for this device, if applicable. Required for Class B, C, and D devices.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceEvaluationReportReference rdf:type rdf:Property ;
    rdfs:label 'Performance Evaluation Report Reference' ;
    rdfs:comment 'Reference identifier for the performance evaluation report demonstrating the device meets its intended purpose. Required under IVDR Annex XIII.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillancePlanReference rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Plan Reference' ;
    rdfs:comment 'Reference identifier for the post-market surveillance plan required under IVDR Article 78. Tracks ongoing safety and performance monitoring.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusableDeviceFlag rdf:type rdf:Property ;
    rdfs:label 'Reusable Device Flag' ;
    rdfs:comment 'Indicates whether the device is intended for reuse after reprocessing. Affects validation and labeling requirements.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selfTestFlag rdf:type rdf:Property ;
    rdfs:label 'Self Test Flag' ;
    rdfs:comment 'Indicates whether the device is intended for self-testing by lay persons. Affects classification and labeling requirements.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sterileDeviceFlag rdf:type rdf:Property ;
    rdfs:label 'Sterile Device Flag' ;
    rdfs:comment 'Indicates whether the device is supplied in a sterile condition. Affects labeling and conformity assessment requirements.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Technical Documentation Reference' ;
    rdfs:comment 'Reference identifier for the technical documentation package maintained per IVDR Annex II. Links to document management system.' ;
    rdfs:domain ind:EudamedRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Action Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Field safety actions must have an accountable employee owner for execution tracking, FDA recall management, and regulatory compliance. Links FSA to qualified employees responsible for corrective actio' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the field safety action, typically formatted as FSA-NNNNNN for external tracking and regulatory reporting.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the field safety action indicating progress through investigation, notification, recovery, and closure phases.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the field safety action: recall (product return), market withdrawal (removal from market), safety alert (hazard notification), field correction (on-site fix), customer notification (informational), or product removal (permanent discontinuation).' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductCode rdf:type rdf:Property ;
    rdfs:label 'Affected Product Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) or catalog number of the affected product for precise identification in supply chain and inventory systems.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductName rdf:type rdf:Property ;
    rdfs:label 'Affected Product Name' ;
    rdfs:comment 'Commercial name of the product affected by the field safety action, captured for reporting and customer communication purposes.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSerialNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Serial Numbers' ;
    rdfs:comment 'Comma-separated list or range of device serial numbers affected by the field safety action, used for instrument-level traceability.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentAuthorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Competent Authority Notification Date' ;
    rdfs:comment 'Date when national competent authorities in affected EU member states were notified of the field safety action via the European Database on Medical Devices (EUDAMED).' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Method' ;
    rdfs:comment 'Primary method used to notify affected customers of the field safety action: email, postal mail, phone, fax, web portal, field representative visit, or multiple channels. [ENUM-REF-CANDIDATE: email|postal_mail|phone|fax|web_portal|field_representative|multiple — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customersNotifiedCount rdf:type rdf:Property ;
    rdfs:label 'Customers Notified Count' ;
    rdfs:comment 'Total number of customers who have been successfully notified of the field safety action, tracked for regulatory reporting and effectiveness monitoring.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectivenessCheckOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Outcome' ;
    rdfs:comment 'Result of the effectiveness check assessment: effective (corrective action successful), partially effective (additional actions needed), ineffective (corrective action failed), or pending (check not yet completed).' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Projected date for completing all field safety action activities including customer notification, product recovery, and regulatory reporting, used for planning and regulatory commitment tracking.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Fda Notification Date' ;
    rdfs:comment 'Date when the U.S. Food and Drug Administration (FDA) was formally notified of the field safety action, as required under 21 CFR 806 for medical device recalls.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaRecallNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Recall Number' ;
    rdfs:comment 'Official FDA-assigned recall number for tracking in the FDA recall database, typically formatted as Z-YYYY-NNNN where Z is the recall class.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated total financial impact of the field safety action including product recovery costs, customer credits, regulatory penalties, and operational expenses, captured in the company\'s reporting currency.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fsn Reference Number' ;
    rdfs:comment 'Reference number of the Field Safety Notice document issued to customers and regulatory authorities, used for cross-referencing in regulatory correspondence.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedBodyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Notified Body Notification Date' ;
    rdfs:comment 'Date when the EU Notified Body was notified of the field safety action, as required under IVDR Article 83 for CE-marked in vitro diagnostic devices.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Recovery Completion Percentage' ;
    rdfs:comment 'Percentage of affected units successfully recovered or corrected, calculated as (units_recovered / units_distributed) * 100, used to track field safety action effectiveness.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsDistributedCount rdf:type rdf:Property ;
    rdfs:label 'Units Distributed Count' ;
    rdfs:comment 'Total number of affected product units that were distributed to customers and are subject to the field safety action.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsRecoveredCount rdf:type rdf:Property ;
    rdfs:label 'Units Recovered Count' ;
    rdfs:comment 'Number of affected product units that have been successfully recovered, returned, or corrected as part of the field safety action.' ;
    rdfs:domain ind:FieldSafetyAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ivdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Ivd Registration Id' ;
    rdfs:comment 'Unique identifier for the IVD registration record. Primary key for the ivd_registration product.' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedRepresentativeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the authorized representative location. [ENUM-REF-CANDIDATE: USA|CAN|AUS|BRA|CHN|JPN|IND|DEU|FRA|GBR|ITA|ESP|NLD|BEL|SWE|CHE|AUT|POL|DNK|NOR|FIN|IRL|PRT|CZE|HUN|ROU|GRC|BGR|HRV|SVK|SVN|LTU|LVA|EST|CYP|LUX|MLT|MEX|ARG|CHL|COL|PER|ZAF|KOR|TWN|SGP|MYS|THA|IDN|PHL|VNM|NZL|ISR|TUR|SAU|ARE|EGY|NGA|KEN|MAR|TUN|DZA|GHA|UGA|TZA|ETH|SEN|CIV|CMR|ZWE|ZMB|MOZ|AGO|RWA|UKR|RUS|BLR|KAZ|UZB|GEO|ARM|AZE|MDA|SRB|BIH|MKD|ALB|MNE|XKX — 89 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceListingNumbers rdf:type rdf:Property ;
    rdfs:label 'Device Listing Numbers' ;
    rdfs:comment 'Comma-separated list of device listing numbers or product listing numbers associated with this registration (e.g., FDA device listing numbers). Applicable for jurisdictions requiring device listing in addition to establishment registration.' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the manufacturer location. [ENUM-REF-CANDIDATE: USA|CAN|AUS|BRA|CHN|JPN|IND|DEU|FRA|GBR|ITA|ESP|NLD|BEL|SWE|CHE|AUT|POL|DNK|NOR|FIN|IRL|PRT|CZE|HUN|ROU|GRC|BGR|HRV|SVK|SVN|LTU|LVA|EST|CYP|LUX|MLT|MEX|ARG|CHL|COL|PER|ZAF|KOR|TWN|SGP|MYS|THA|IDN|PHL|VNM|NZL|ISR|TUR|SAU|ARE|EGY|NGA|KEN|MAR|TUN|DZA|GHA|UGA|TZA|ETH|SEN|CIV|CMR|ZWE|ZMB|MOZ|AGO|RWA|UKR|RUS|BLR|KAZ|UZB|GEO|ARM|AZE|MDA|SRB|BIH|MKD|ALB|MNE|XKX — 89 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Registration Certificate Reference' ;
    rdfs:comment 'Document reference, file path, or vault identifier for the official registration certificate or approval letter issued by the regulatory authority.' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationScope rdf:type rdf:Property ;
    rdfs:label 'Registration Scope' ;
    rdfs:comment 'Description of the scope of the registration: which products, device types, or activities are covered by this registration. May list multiple products or device families if the registration covers a portfolio.' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority or competent authority that issued the registration (e.g., U.S. Food and Drug Administration, Health Canada, Therapeutic Goods Administration, ANVISA, NMPA, PMDA, CDSCO, national competent authority in EU member states).' ;
    rdfs:domain ind:IvdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Phone' ;
    rdfs:comment 'Phone number of the primary regulatory contact person. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentative rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative' ;
    rdfs:comment 'Name and address of the authorized representative in the European Union, if applicable. Required for non-EU manufacturers marketing IVD products in the EU under IVDR.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeType rdf:type rdf:Property ;
    rdfs:label 'Barcode Type' ;
    rdfs:comment 'Type of barcode or machine-readable identifier printed on the labeling. Supports supply chain automation and inventory management.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceMarkRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Mark Required' ;
    rdfs:comment 'Indicates whether this labeling must display the CE-IVD mark for European market distribution. True for IVD products marketed in the EU under IVDR; false for RUO or non-EU products.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeClassification rdf:type rdf:Property ;
    rdfs:label 'Change Classification' ;
    rdfs:comment 'Classification of the change that resulted in this labeling version. Major changes typically require regulatory notification or re-approval; minor changes may be implemented under quality system authority; administrative changes are non-substantive corrections.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'High-level summary of the specific changes made in this labeling version compared to the previous version. Supports regulatory submission documentation and internal change tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSupportContact rdf:type rdf:Property ;
    rdfs:label 'Customer Support Contact' ;
    rdfs:comment 'Customer support phone number, email, or website URL printed on the labeling for technical assistance and inquiries.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaEstablishmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Fda Establishment Identifier' ;
    rdfs:comment 'FDA Establishment Identifier (FEI) or registration number that must appear on the labeling for US-marketed products. Required for IVD products under FDA jurisdiction.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardSymbols rdf:type rdf:Property ;
    rdfs:label 'Hazard Symbols' ;
    rdfs:comment 'Comma-separated list of hazard symbols or pictograms that must appear on the labeling. Supports chemical safety and regulatory compliance for reagents and consumables.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedMarkets rdf:type rdf:Property ;
    rdfs:label 'Impacted Markets' ;
    rdfs:comment 'Comma-separated list of market regions or countries affected by this labeling change. Used to coordinate multi-market labeling updates and regulatory notifications.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingType rdf:type rdf:Property ;
    rdfs:label 'Labeling Type' ;
    rdfs:comment 'Classification of the labeling asset. Distinguishes between physical labels, package inserts, Instructions for Use (IFU) documents, carton artwork, digital labeling content, and Safety Data Sheets (SDS).' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumberFormat rdf:type rdf:Property ;
    rdfs:label 'Lot Number Format' ;
    rdfs:comment 'Specification for the lot number format that will be printed on this labeling. Defines the structure and content of lot identifiers for traceability and quality control.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this labeling change requires formal notification to regulatory authorities (FDA, Notified Body, or other competent authority). True for major changes; false for minor or administrative changes.' ;
    rdfs:domain ind:Labeling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the national accreditation body that accredited the notified body to ISO 17065 and relevant standards (e.g., DAkkS, UKAS, COFRAC).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the accreditation body confirming the notified body\'s accreditation to perform conformity assessments.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the notified body\'s current accreditation certificate expires and requires renewal or reassessment.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationIssueDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Issue Date' ;
    rdfs:comment 'Date when the notified body\'s accreditation certificate was originally issued by the accreditation body.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageTurnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Turnaround Time Days' ;
    rdfs:comment 'Average number of days the notified body takes to complete conformity assessment activities from submission to certificate issuance, based on historical performance.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateScope rdf:type rdf:Property ;
    rdfs:label 'Certificate Scope' ;
    rdfs:comment 'Description of the products, product families, or quality management system scope covered by the current certificate issued by the notified body.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competentAuthority rdf:type rdf:Property ;
    rdfs:label 'Competent Authority' ;
    rdfs:comment 'Name of the national competent authority that designated and oversees the notified body (e.g., BfArM in Germany, ANSM in France).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedCountries rdf:type rdf:Property ;
    rdfs:label 'Designated Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the EU member states and EEA countries where the notified body is designated to operate (e.g., DEU, FRA, ITA).' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationDate rdf:type rdf:Property ;
    rdfs:label 'Designation Date' ;
    rdfs:comment 'Date when the notified body was officially designated by the competent authority to perform conformity assessments under IVDR.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current regulatory status of the notified body\'s designation by the competent authority.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceClassCoverage rdf:type rdf:Property ;
    rdfs:label 'Device Class Coverage' ;
    rdfs:comment 'Pipe-separated list of IVD device classes that the notified body is designated to assess (Class A, Class B, Class C, Class D) under IVDR classification rules.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the notified body\'s headquarters or principal place of business.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Audit Outcome' ;
    rdfs:comment 'Summary outcome of the most recent audit conducted by the notified body, indicating compliance status and any findings.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nandoDatabaseUrl rdf:type rdf:Property ;
    rdfs:label 'Nando Database Url' ;
    rdfs:comment 'Direct link to the notified body\'s profile in the European Commission\'s NANDO database for verification and public transparency.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'Planned date for the next surveillance audit or conformity assessment activity by the notified body.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openNonconformitiesCount rdf:type rdf:Property ;
    rdfs:label 'Open Nonconformities Count' ;
    rdfs:comment 'Current number of open non-conformities or corrective action requests issued by the notified body that are pending resolution.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean flag indicating whether this notified body is designated as a preferred vendor for Genomics Biotech\'s conformity assessment needs based on performance, cost, and relationship quality.' ;
    rdfs:domain ind:NotifiedBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postMarketSurveillanceId rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Id' ;
    rdfs:comment 'Unique identifier for the post-market surveillance plan or report record.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitRiskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Assessment Summary' ;
    rdfs:comment 'Summary of the benefit-risk analysis conducted as part of the PMS evaluation, documenting whether the product continues to meet safety and performance requirements.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalFollowUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether post-market clinical follow-up (PMCF) or post-market performance follow-up (PMPF) studies are required as part of this PMS plan.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintDataIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Complaint Data Included Flag' ;
    rdfs:comment 'Indicates whether customer complaint data is included as a data source in this PMS plan.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'Comma-separated list or description of data sources used for PMS data collection: complaint data, adverse event reports, scientific literature, clinical registries, post-market clinical follow-up studies, customer feedback, field performance data.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldSafetyNoticeIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Field Safety Notice Issued Flag' ;
    rdfs:comment 'Indicates whether a Field Safety Notice (FSN) or Field Safety Corrective Action (FSCA) has been issued for this product during the PMS period.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date when the most recent PMS report was submitted to the regulatory authority.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:literatureReviewIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Literature Review Included Flag' ;
    rdfs:comment 'Indicates whether systematic scientific literature review is included as a data source in this PMS plan.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'Date when the next periodic PMS report (PSUR, PMPF, or post-approval study report) is due for submission to the regulatory authority.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'Date when this PMS plan version became effective and data collection activities commenced.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiry Date' ;
    rdfs:comment 'Date when this PMS plan version expires or is scheduled for review and renewal. Null for ongoing plans without fixed end date.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version number or identifier of the PMS plan document, used to track revisions and updates over time.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmpfStudyProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Pmpf Study Protocol Reference' ;
    rdfs:comment 'Document reference or identifier for the PMPF study protocol associated with this PMS plan, if applicable.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsPlanNumber rdf:type rdf:Property ;
    rdfs:label 'Pms Plan Number' ;
    rdfs:comment 'Business identifier for the PMS plan or report, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsStatus rdf:type rdf:Property ;
    rdfs:label 'Pms Status' ;
    rdfs:comment 'Current lifecycle status of the PMS plan or report: draft (in preparation), active (ongoing data collection), under review (internal QA), approved (ready for submission), submitted (filed with authority), closed (completed), suspended (temporarily halted). [ENUM-REF-CANDIDATE: draft|active|under_review|approved|submitted|closed|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmsType rdf:type rdf:Property ;
    rdfs:label 'Pms Type' ;
    rdfs:comment 'Type of post-market surveillance activity: PMS plan (IVDR general plan), PSUR (Periodic Safety Update Report), PMPF plan (Post-Market Performance Follow-up), post-approval study (FDA commitment), vigilance report, or field safety corrective action.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Initiated Flag' ;
    rdfs:comment 'Indicates whether a product recall or market withdrawal was initiated during the PMS period.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryDataIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Registry Data Included Flag' ;
    rdfs:comment 'Indicates whether clinical registry or real-world evidence registry data is included in this PMS plan.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which PMS reports (PSUR, PMPF updates) must be generated and submitted to regulatory authorities. [ENUM-REF-CANDIDATE: monthly|quarterly|semi_annual|annual|biennial|event_driven|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or functional unit responsible for managing this PMS plan (e.g., Regulatory Affairs, Quality Assurance, Post-Market Surveillance).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskManagementFileReference rdf:type rdf:Property ;
    rdfs:label 'Risk Management File Reference' ;
    rdfs:comment 'Reference to the risk management file (per ISO 14971) that this PMS plan supports and updates with post-market data.' ;
    rdfs:domain ind:PostMarketSurveillance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousAdverseEventCount rdf:type rdf:Property ;
    rdfs:label 'Serious Adverse Event Count' ;
    rdfs:comment 'Number of serious adverse events (death, serious injury, or serious public health threat) reported during the current PMS reporting period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalFileReference rdf:type rdf:Property ;
    rdfs:label 'Technical File Reference' ;
    rdfs:comment 'Reference to the technical documentation or technical file that includes this PMS plan as a required component.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Official approval, clearance, or registration number issued by the regulatory authority. Examples: FDA 510(k) number (K123456), PMA number (P123456), CE certificate number, IVDR certificate number, EMA authorization number.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Type of regulatory approval or clearance granted. Indicates the regulatory pathway used for market authorization. [ENUM-REF-CANDIDATE: 510k_clearance|pma_approval|ce_ivd_certificate|ivdr_certificate|ema_marketing_authorization|country_registration|de_novo_classification|humanitarian_device_exemption — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedIndications rdf:type rdf:Property ;
    rdfs:label 'Approved Indications' ;
    rdfs:comment 'Specific clinical indications, disease states, or genetic markers that the product is approved to detect, diagnose, or analyze.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Approval' ;
    rdfs:comment 'Special conditions, restrictions, or post-market requirements imposed by the regulatory authority as part of the approval. Examples: post-market surveillance studies, labeling restrictions, distribution limitations.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderAddress rdf:type rdf:Property ;
    rdfs:label 'Holder Address' ;
    rdfs:comment 'Registered business address of the approval holder as recorded with the regulatory authority.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderName rdf:type rdf:Property ;
    rdfs:label 'Holder Name' ;
    rdfs:comment 'Legal name of the organization or entity that holds the regulatory approval. The manufacturer or sponsor responsible for the product.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingRequirements rdf:type rdf:Property ;
    rdfs:label 'Labeling Requirements' ;
    rdfs:comment 'Specific labeling, instructions for use (IFU), or package insert requirements mandated by the regulatory authority.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predicateDevice rdf:type rdf:Property ;
    rdfs:label 'Predicate Device' ;
    rdfs:comment 'For 510(k) clearances, the legally marketed device to which substantial equivalence was demonstrated. Includes predicate device name and 510(k) number.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentId rdf:type rdf:Property ;
    rdfs:label 'Commitment Id' ;
    rdfs:comment 'Unique identifier for the regulatory commitment record. Primary key.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory commitments require designated employee owners for accountability and execution tracking. Links commitments to qualified employees responsible for deliverable completion, essential for FDA/' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Acceptance Status' ;
    rdfs:comment 'Status of the regulatory authority\'s review and acceptance of the submitted deliverable. Tracks whether the commitment has been formally closed by the agency.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyFeedback rdf:type rdf:Property ;
    rdfs:label 'Agency Feedback' ;
    rdfs:comment 'Summary of feedback, comments, or additional requirements communicated by the regulatory authority in response to the submitted deliverable.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Commitment Description' ;
    rdfs:comment 'Detailed description of the commitment requirements, scope, deliverables, and any specific conditions or milestones imposed by the regulatory authority or notified body.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business identifier for the commitment, often assigned by the regulatory authority or internally tracked. May reference FDA post-approval study numbers, PMA condition identifiers, or notified body audit reference codes.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the commitment. Tracks whether the obligation is pending initiation, actively being fulfilled, completed, overdue, waived by the authority, or cancelled.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the regulatory commitment. Indicates the nature of the obligation imposed by the regulatory authority or notified body. [ENUM-REF-CANDIDATE: post_approval_study|pma_condition|notified_body_audit|post_market_surveillance|annual_report|periodic_safety_update|labeling_update — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Deliverable Document Reference' ;
    rdfs:comment 'Reference identifier or Veeva Vault document ID for the deliverable submitted to fulfill the commitment. Links to the regulatory_document product.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Type of deliverable required to fulfill the commitment. Specifies the format and content expected by the regulatory authority. [ENUM-REF-CANDIDATE: study_protocol|interim_report|final_report|annual_report|audit_response|labeling_change|safety_update — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfFulfillment rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Fulfillment' ;
    rdfs:comment 'Description or reference to evidence demonstrating that the commitment has been fulfilled. May include study completion certificates, audit reports, or agency acceptance letters.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Revised due date if an extension was granted by the regulatory authority. Null if no extension granted.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether the regulatory authority granted an extension to the commitment due date. True if granted, False otherwise.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Requested Flag' ;
    rdfs:comment 'Indicates whether an extension of the commitment due date has been requested from the regulatory authority. True if extension requested, False otherwise.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imposedDate rdf:type rdf:Property ;
    rdfs:label 'Imposed Date' ;
    rdfs:comment 'Date on which the commitment was formally imposed by the regulatory authority or notified body, typically the approval date or a subsequent correspondence date.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of actions planned or taken to mitigate risks and ensure timely fulfillment of the commitment. May include resource reallocation, vendor engagement, or protocol amendments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingAuthority rdf:type rdf:Property ;
    rdfs:label 'Originating Authority' ;
    rdfs:comment 'Name of the regulatory authority or notified body that imposed the commitment. Examples: FDA CDRH, EMA, Notified Body 0123, Health Canada.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Summary of the regulatory and business risks associated with non-fulfillment or delayed fulfillment of the commitment. Informs prioritization and mitigation strategies.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number provided by the regulatory authority upon receipt of the commitment deliverable. Used for audit trail and verification.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the regulatory document record. Primary key.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Document Id' ;
    rdfs:comment 'Identifier of the previous document version that this current version replaces. Maintains document lineage and version history.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or electronic location where the document is archived after it becomes obsolete (e.g., Veeva Vault archive folder, offsite storage facility).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Summary' ;
    rdfs:comment 'High-level summary of key audit events for this document (creation, approvals, revisions, access) maintained in Veeva Vault for compliance traceability.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the individual who authored or prepared the current version of the document.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'SHA-256 cryptographic hash of the document file, ensuring integrity and detecting unauthorized modifications.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relatedDocumentReferences rdf:type rdf:Property ;
    rdfs:label 'Related Document References' ;
    rdfs:comment 'Comma-separated list of document numbers or identifiers for related or cross-referenced regulatory documents (e.g., supporting SOPs, risk assessments, test reports).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDescription rdf:type rdf:Property ;
    rdfs:label 'Revision Description' ;
    rdfs:comment 'Summary of changes made in the current version compared to the previous version. Documents the nature and scope of revisions.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity within the document type (e.g., IFU-Professional, IFU-Patient, CER-Initial, CER-Update).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'Unique document identifier assigned by Veeva Vault system of record. External system key for document control integration.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceId rdf:type rdf:Property ;
    rdfs:label 'Intelligence Id' ;
    rdfs:comment 'Unique identifier for the regulatory intelligence item. Primary key.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Affected Submission Id' ;
    rdfs:comment 'Identifier of a specific regulatory submission that is directly impacted by this intelligence item, if applicable.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:assignedRegulatoryAffairsOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Regulatory Affairs Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory intelligence items must be assigned to specific RA employees for action, impact assessment, and response planning. Critical for managing regulatory horizon scanning, compliance obligations,' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByIntelligenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Intelligence Id' ;
    rdfs:comment 'Identifier of the newer regulatory intelligence item that supersedes or replaces this item, if applicable.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Intelligence .

ind:affectedJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Affected Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction or region affected by this regulatory intelligence (e.g., USA, European Union, specific country codes). Multiple jurisdictions may be comma-separated.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProductCategory rdf:type rdf:Property ;
    rdfs:label 'Affected Product Category' ;
    rdfs:comment 'Product category or product line affected by this regulatory intelligence (e.g., NGS sequencing instruments, IVD assays, gene editing tools, array-based products).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRegulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Affected Regulatory Framework' ;
    rdfs:comment 'Regulatory framework or regulation impacted by this intelligence item (e.g., IVDR, FDA 510(k), ISO 13485, CLIA, HIPAA, GDPR).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Comment Deadline Date' ;
    rdfs:comment 'Deadline date for submitting public comments or feedback on proposed rules or draft guidance documents.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceObligationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Flag' ;
    rdfs:comment 'Indicates whether this intelligence item creates a new or modified compliance obligation that the organization must address (True/False).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:horizonScanningPriority rdf:type rdf:Property ;
    rdfs:label 'Horizon Scanning Priority' ;
    rdfs:comment 'Priority level assigned for horizon scanning and proactive regulatory strategy planning (urgent, high, medium, low).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Severity' ;
    rdfs:comment 'Assessed severity level of the impact this intelligence item has on the organization\'s regulatory compliance, product submissions, or market access (critical, high, medium, low, informational).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Summary' ;
    rdfs:comment 'Brief summary describing the potential impact of this regulatory intelligence on the organization\'s operations, compliance obligations, or strategic plans.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceNumber rdf:type rdf:Property ;
    rdfs:label 'Intelligence Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this regulatory intelligence item for tracking and citation purposes.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Intelligence Status' ;
    rdfs:comment 'Lifecycle status of the regulatory intelligence item within the organization\'s tracking system (active, archived, superseded, under review).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceType rdf:type rdf:Property ;
    rdfs:label 'Intelligence Type' ;
    rdfs:comment 'Classification of the regulatory intelligence item type (e.g., guidance document, proposed rule, final rule, draft guidance, notified body technical note, legislative change, standards update). [ENUM-REF-CANDIDATE: guidance_document|proposed_rule|final_rule|draft_guidance|technical_note|legislative_change|standard_update — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Code' ;
    rdfs:comment 'Standardized code or abbreviation for the issuing agency (e.g., FDA, EMA, ISO, IEC, CAP, CLIA).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketAccessImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Market Access Impact Flag' ;
    rdfs:comment 'Indicates whether this intelligence item may impact the organization\'s ability to access or maintain market presence in affected jurisdictions (True/False).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the regulatory intelligence item was officially published or released by the issuing agency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedIntelligenceReferences rdf:type rdf:Property ;
    rdfs:label 'Related Intelligence References' ;
    rdfs:comment 'Comma-separated list of related regulatory intelligence item identifiers or reference numbers that are contextually linked to this item.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseActionPlan rdf:type rdf:Property ;
    rdfs:label 'Response Action Plan' ;
    rdfs:comment 'Detailed action plan outlining the organization\'s response strategy, required actions, and deliverables related to this intelligence item.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Internal deadline by which the organization must complete its response or action plan related to this intelligence item.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Standard Reference Number' ;
    rdfs:comment 'Reference number of the standard (ISO, IEC, or other) if this intelligence item pertains to a standards update or revision.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Unique identifier for the regulatory strategy plan record.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory strategy requires a designated lead regulatory affairs employee for strategy execution, submission planning, and cross-functional coordination. Critical for product development planning and' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalTimelineTarget rdf:type rdf:Property ;
    rdfs:label 'Approval Timeline Target' ;
    rdfs:comment 'Target date for regulatory approval or clearance based on the strategy plan.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalEvidenceStrategy rdf:type rdf:Property ;
    rdfs:label 'Clinical Evidence Strategy' ;
    rdfs:comment 'Strategy for generating and presenting clinical evidence to support regulatory submissions, including clinical trial design, performance studies, and literature review approach.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalStudyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Study Required Flag' ;
    rdfs:comment 'Indicates whether a clinical study is required as part of the regulatory strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercializationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Commercialization Target Date' ;
    rdfs:comment 'Planned date for product commercialization and market launch following regulatory approval.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crossFunctionalTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Cross Functional Team Members' ;
    rdfs:comment 'List of key cross-functional team members involved in the regulatory strategy (e.g., R&D (Research and Development), clinical, quality, manufacturing), stored as comma-separated names or roles.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRegulatoryRisks rdf:type rdf:Property ;
    rdfs:label 'Key Regulatory Risks' ;
    rdfs:comment 'Summary of key regulatory risks identified for the product and strategy, including technical, clinical, and compliance risks.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingStrategy rdf:type rdf:Property ;
    rdfs:label 'Labeling Strategy' ;
    rdfs:comment 'Strategy for product labeling and instructions for use (IFU (Instructions For Use)), ensuring compliance with regulatory requirements.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedBodySelection rdf:type rdf:Property ;
    rdfs:label 'Notified Body Selection' ;
    rdfs:comment 'Name and number of the notified body selected for CE-IVD (Conformité Européenne In Vitro Diagnostic) or IVDR (In Vitro Diagnostic Regulation) conformity assessment, if applicable.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStudyType rdf:type rdf:Property ;
    rdfs:label 'Performance Study Type' ;
    rdfs:comment 'Type of performance study planned or completed (e.g., analytical validation, clinical validation, usability study).' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketSurveillancePlan rdf:type rdf:Property ;
    rdfs:label 'Post Market Surveillance Plan' ;
    rdfs:comment 'High-level description of the post-market surveillance plan required for the product, including adverse event monitoring and periodic reporting.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predicateDevice510kNumber rdf:type rdf:Property ;
    rdfs:label 'Predicate Device 510k Number' ;
    rdfs:comment 'The 510(k) clearance number of the predicate device.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predicateDeviceName rdf:type rdf:Property ;
    rdfs:label 'Predicate Device Name' ;
    rdfs:comment 'Name of the predicate device being referenced for substantial equivalence in 510(k) pathway.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predicateDeviceStrategy rdf:type rdf:Property ;
    rdfs:label 'Predicate Device Strategy' ;
    rdfs:comment 'Description of the predicate device strategy for 510(k) submissions, including identification of comparable legally marketed devices and substantial equivalence rationale.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Pathway' ;
    rdfs:comment 'The intended primary regulatory pathway for product approval or clearance. FDA (U.S. Food and Drug Administration) pathways include 510(k) premarket notification, PMA (Premarket Approval), and De Novo classification. EU pathways include CE-IVD (Conformité Européenne In Vitro Diagnostic) and IVDR (In Vitro Diagnostic Regulation) classifications. [ENUM-REF-CANDIDATE: 510k|pma|de_novo|ce_ivd|ivdr_class_a|ivdr_class_b|ivdr_class_c|ivdr_class_d — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDevelopmentMilestoneLinkage rdf:type rdf:Property ;
    rdfs:label 'Product Development Milestone Linkage' ;
    rdfs:comment 'References to key product development milestones that are aligned with or dependent on this regulatory strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDocumentReferences rdf:type rdf:Property ;
    rdfs:label 'Regulatory Document References' ;
    rdfs:comment 'References to key regulatory documents supporting this strategy, such as technical files, design dossiers, and submission templates.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryIntelligenceSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Intelligence Summary' ;
    rdfs:comment 'Summary of relevant regulatory intelligence, including recent guidance updates, competitor approvals, and regulatory landscape changes that inform the strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskManagementApproach rdf:type rdf:Property ;
    rdfs:label 'Risk Management Approach' ;
    rdfs:comment 'Description of the risk management approach and framework applied to the product, typically following ISO 14971 for medical devices.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'High-level plan for mitigating identified regulatory risks.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryRegulatoryPathways rdf:type rdf:Property ;
    rdfs:label 'Secondary Regulatory Pathways' ;
    rdfs:comment 'Additional or alternative regulatory pathways being considered or pursued in parallel, stored as comma-separated list.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyNumber rdf:type rdf:Property ;
    rdfs:label 'Strategy Number' ;
    rdfs:comment 'Business identifier for the regulatory strategy plan, used for external reference and tracking.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory strategy plan.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimelineTarget rdf:type rdf:Property ;
    rdfs:label 'Submission Timeline Target' ;
    rdfs:comment 'Target date for regulatory submission based on the strategy plan.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMarkets rdf:type rdf:Property ;
    rdfs:label 'Target Markets' ;
    rdfs:comment 'Geographic markets and jurisdictions where regulatory approval is being sought, stored as comma-separated list of ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadRegulatoryAffairsOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Regulatory Affairs Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Every regulatory submission requires an accountable regulatory affairs professional as lead. Critical for submission strategy execution, agency interactions, workload planning, and regulatory affairs ' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adverseEventReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether post-market adverse event reporting obligations apply to this submission. True if MDR, vigilance, or adverse event reporting is required, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalDataRequired rdf:type rdf:Property ;
    rdfs:label 'Clinical Data Required' ;
    rdfs:comment 'Boolean flag indicating whether clinical performance data or clinical evidence is required as part of the submission. True if clinical studies or clinical performance evaluation is mandatory, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalStudyReference rdf:type rdf:Property ;
    rdfs:label 'Clinical Study Reference' ;
    rdfs:comment 'Reference identifier(s) for the clinical studies or clinical performance evaluations included in the submission. May include ClinicalTrials.gov NCT numbers, internal study codes, or published literature references.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceLogReference rdf:type rdf:Property ;
    rdfs:label 'Correspondence Log Reference' ;
    rdfs:comment 'Reference identifier or link to the log of all correspondence exchanged with the regulatory authority regarding this submission (e.g., information requests, deficiency letters, responses, meeting minutes). Typically managed in Veeva Vault or document control system.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierReference rdf:type rdf:Property ;
    rdfs:label 'Dossier Reference' ;
    rdfs:comment 'The internal or external reference number for the regulatory dossier or technical file associated with this submission. Links to the controlled document set in Veeva Vault or other document management system.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReviewGranted rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Granted' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory authority granted expedited, priority, or breakthrough designation review status. True if granted, False if denied or not applicable.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedReviewRequested rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Requested' ;
    rdfs:comment 'Boolean flag indicating whether expedited, priority, or breakthrough designation review was requested from the regulatory authority. True if expedited review was requested, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The regulatory submission fee amount paid or payable to the regulatory authority for processing the submission. Expressed in the currency of the target jurisdiction.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the submission fee amount (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Gmp Certification Required' ;
    rdfs:comment 'Boolean flag indicating whether GMP or ISO 13485 certification is required as part of the submission. True if quality system certification must be demonstrated, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelingComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Labeling Compliance Verified' ;
    rdfs:comment 'Boolean flag indicating whether product labeling (IFU, package insert, device labels) has been verified for compliance with target jurisdiction requirements. True if labeling review is complete and compliant, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Local Representative Name' ;
    rdfs:comment 'The name of the authorized representative or legal manufacturer representative appointed in the target jurisdiction, if required. Null if no representative is required or not yet appointed.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localRepresentativeRequired rdf:type rdf:Property ;
    rdfs:label 'Local Representative Required' ;
    rdfs:comment 'Boolean flag indicating whether the target jurisdiction requires the appointment of a local authorized representative or legal manufacturer representative for the submission. True if required, False otherwise.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'The externally-known regulatory submission number or dossier reference assigned by the submitting organization or regulatory authority (e.g., FDA 510(k) number K123456, PMA number P210001, CE-IVD technical file reference).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory submission in the approval workflow. Tracks progression from initial draft through regulatory authority review to final decision (draft, submitted, under review, additional information requested, approved, cleared, denied, withdrawn). [ENUM-REF-CANDIDATE: draft|submitted|under_review|additional_info_requested|approved|cleared|denied|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'The regulatory pathway classification for the submission. Indicates the type of regulatory filing made to the health authority (e.g., FDA 510(k) premarket notification, PMA premarket approval, De Novo classification request, CE-IVD technical file, IVDR registration, EMA dossier, ICH CTD).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgency rdf:type rdf:Property ;
    rdfs:label 'Target Agency' ;
    rdfs:comment 'The primary health authority or regulatory agency to which the submission is directed (e.g., FDA, EMA, Health Canada, TGA, PMDA, ANVISA, NMPA). Identifies the competent authority responsible for reviewing and approving the submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Target Decision Date' ;
    rdfs:comment 'The planned or regulatory-mandated target date by which the authority is expected to issue a decision on the submission. Used for tracking review timelines and SLA compliance.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Target Jurisdiction' ;
    rdfs:comment 'The country, region, or trading bloc for which regulatory approval is sought (e.g., USA, European Union, Canada, Australia, Japan, Brazil, China). Defines the geographic scope of the regulatory submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionEventId rdf:type rdf:Property ;
    rdfs:label 'Submission Event Id' ;
    rdfs:comment 'Unique identifier for each discrete regulatory submission event. Primary key for the submission event record.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submission Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Submission contact must be a real employee for agency correspondence, deficiency responses, and accountability. Links submission events to qualified regulatory affairs personnel with appropriate train' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Decision Date' ;
    rdfs:comment 'Actual date when the regulatory agency issued a final decision (approval, rejection, or other disposition) on this submission. Nullable if decision is pending.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyReceiptConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Receipt Confirmation Number' ;
    rdfs:comment 'Unique confirmation or tracking number issued by the regulatory agency upon receipt of the submission. Provides proof of delivery and agency acknowledgment.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Agency Receipt Date' ;
    rdfs:comment 'Date when the regulatory agency officially acknowledged receipt of the submission. Used to establish filing date and review clock start.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionLetterReference rdf:type rdf:Property ;
    rdfs:label 'Decision Letter Reference' ;
    rdfs:comment 'Reference identifier or document link to the official agency decision letter or notification. Links to controlled document repository.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficiencyLetterDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Letter Date' ;
    rdfs:comment 'Date when the regulatory agency issued a deficiency letter or additional information request for this submission. Nullable if no deficiency was issued.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deficiencyLetterReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Deficiency Letter Received Flag' ;
    rdfs:comment 'Boolean indicator of whether a deficiency letter or additional information request was received from the agency in response to this submission.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deficiencyResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Deficiency Response Due Date' ;
    rdfs:comment 'Deadline date by which the sponsor must respond to the agency deficiency letter. Nullable if no deficiency was issued.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ectdSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ectd Sequence Number' ;
    rdfs:comment 'Sequential number assigned to each eCTD submission within a regulatory application. Used to maintain chronological order of submissions per ICH eCTD specification.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'Date when the regulatory user fee was paid to the agency. Required for establishing submission acceptance and review clock start.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Status' ;
    rdfs:comment 'Current status of the regulatory user fee payment associated with this submission event.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCorrespondentName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondent Name' ;
    rdfs:comment 'Name of the official regulatory correspondent or authorized representative designated for agency communications regarding this submission.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewClockDays rdf:type rdf:Property ;
    rdfs:label 'Review Clock Days' ;
    rdfs:comment 'Number of calendar days allocated by the agency for review of this submission under applicable regulatory timelines (e.g., 90 days for FDA 510(k), 180 days for PMA).' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Amount' ;
    rdfs:comment 'Regulatory user fee amount charged by the agency for processing this submission. Amount in the currency specified by submission_fee_currency_code.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the submission fee (e.g., USD, EUR, GBP, JPY).' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Technical format or standard used to structure the submission package (e.g., eCTD, NeeS-R, paper, PDF, XML).' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, special circumstances, or internal notes related to this submission event.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPackageReference rdf:type rdf:Property ;
    rdfs:label 'Submission Package Reference' ;
    rdfs:comment 'Reference identifier or file path to the complete dossier package associated with this submission event. Links to the controlled document repository (e.g., Veeva Vault document ID).' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionVersion rdf:type rdf:Property ;
    rdfs:label 'Submission Version' ;
    rdfs:comment 'Version identifier for this submission event within the dossier lifecycle. Tracks sequential revisions and amendments (e.g., v1.0, v1.1, v2.0).' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionVolumeCount rdf:type rdf:Property ;
    rdfs:label 'Submission Volume Count' ;
    rdfs:comment 'Number of physical or logical volumes comprising the submission package. Used for large submissions split across multiple files or binders.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Total Document Count' ;
    rdfs:comment 'Total number of individual documents included in this submission event. Provides a measure of submission complexity and completeness.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPageCount rdf:type rdf:Property ;
    rdfs:label 'Total Page Count' ;
    rdfs:comment 'Total number of pages across all documents in the submission package. Used for resource planning and review estimation.' ;
    rdfs:domain ind:SubmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assayCode rdf:type rdf:Property ;
    rdfs:label 'Assay Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the assay for internal tracking and reference.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercializationDate rdf:type rdf:Property ;
    rdfs:label 'Commercialization Date' ;
    rdfs:comment 'The date on which the assay was launched for commercial sale or clinical use.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageDepthTarget rdf:type rdf:Property ;
    rdfs:label 'Coverage Depth Target' ;
    rdfs:comment 'The target sequencing coverage depth (number of reads per base) required for the assay to achieve specified performance (applicable for NGS assays).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:developmentPhase rdf:type rdf:Property ;
    rdfs:label 'Development Phase' ;
    rdfs:comment 'The current stage of the assay development lifecycle (feasibility, optimization, pre-validation, analytical validation, clinical validation, commercialization).' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Development Start Date' ;
    rdfs:comment 'The date on which the assay development project officially commenced.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:developmentStatus rdf:type rdf:Property ;
    rdfs:label 'Development Status' ;
    rdfs:comment 'The current operational status of the assay development project.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCogs rdf:type rdf:Property ;
    rdfs:label 'Estimated Cogs' ;
    rdfs:comment 'The estimated per-test cost of goods sold for the assay, including reagents, consumables, and direct labor.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feasibilityCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Feasibility Completion Date' ;
    rdfs:comment 'The date on which the feasibility phase of the assay development was completed.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Status' ;
    rdfs:comment 'The intellectual property protection status for the assay (e.g., patent pending, patent granted, trade secret, no IP, licensed).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loqUnit rdf:type rdf:Property ;
    rdfs:label 'Loq Unit' ;
    rdfs:comment 'The unit of measure for the LOQ value (e.g., copies/mL, ng/mL, percentage).' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loqValue rdf:type rdf:Property ;
    rdfs:label 'Loq Value' ;
    rdfs:comment 'The lowest quantity of target analyte that can be reliably quantified with acceptable precision and accuracy.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelSize rdf:type rdf:Property ;
    rdfs:label 'Panel Size' ;
    rdfs:comment 'The number of genes, variants, or targets included in the assay panel (applicable for NGS panels and genotyping arrays).' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patentNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Number' ;
    rdfs:comment 'The patent number(s) associated with the assay technology or methodology, if applicable.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Name' ;
    rdfs:comment 'The name of the principal investigator or lead scientist responsible for the assay development project.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdBudgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Rd Budget Allocated' ;
    rdfs:comment 'The total budget allocated for the assay development project.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rdSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Rd Spend To Date' ;
    rdfs:comment 'The cumulative R&D expenditure on the assay development project as of the current date.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reproducibilityAssessment rdf:type rdf:Property ;
    rdfs:label 'Reproducibility Assessment' ;
    rdfs:comment 'Qualitative or quantitative assessment of the assay\'s ability to produce consistent results across different operators, instruments, reagent lots, and time points.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAnalyte rdf:type rdf:Property ;
    rdfs:label 'Target Analyte' ;
    rdfs:comment 'The specific genetic variant, gene, biomarker, or molecular target that the assay is designed to detect or measure.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAsp rdf:type rdf:Property ;
    rdfs:label 'Target Asp' ;
    rdfs:comment 'The target average selling price per test for the assay upon commercialization.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTatHours rdf:type rdf:Property ;
    rdfs:label 'Target Tat Hours' ;
    rdfs:comment 'The intended turnaround time from sample receipt to result reporting, measured in hours.' ;
    rdfs:domain ind:AssayDevelopment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technologyReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Technology Readiness Level' ;
    rdfs:comment 'The technology readiness level of the assay on a scale of 1-9, indicating maturity from basic research (1) to full commercial deployment (9).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collaborationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Collaboration Agreement Id' ;
    rdfs:comment 'Unique identifier for the R&D collaboration agreement record. Primary key.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollaborationAgreement .

ind:benchlingProjectId rdf:type rdf:Property ;
    rdfs:label 'Benchling Project Id' ;
    rdfs:comment 'Identifier linking to the associated R&D project in Benchling electronic lab notebook system where collaboration research activities are documented.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:grantId rdf:type rdf:Property ;
    rdfs:label 'Grant Id' ;
    rdfs:comment 'Foreign key linking to research.grant. Business justification: Collaboration agreements may be funded by external grants (NIH, NSF, etc.). Currently collaboration_agreement has grant_number (STRING) and grant_funding_source (STRING) but no FK. Adding grant_id FK ' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grant .

ind:veevaDocumentId rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Id' ;
    rdfs:comment 'Identifier linking to the executed agreement document stored in Veeva Vault document management system.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Full descriptive title of the collaboration agreement as stated in the contract document.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collaborationAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Collaboration Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the collaboration agreement. Draft: initial preparation. Under negotiation: terms being discussed. Pending approval: awaiting internal or partner sign-off. Active: in force and operational. Suspended: temporarily paused. Terminated: ended before expiration. Completed: successfully concluded. Expired: reached end date. [ENUM-REF-CANDIDATE: draft|under_negotiation|pending_approval|active|suspended|terminated|completed|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityTier rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Tier' ;
    rdfs:comment 'Classification of confidentiality requirements for the collaboration. Standard: typical NDA protections. High: enhanced confidentiality with limited disclosure. Critical: highly sensitive strategic partnership with strict access controls.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingObligation rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Obligation' ;
    rdfs:comment 'Defines data sharing requirements between parties. Full sharing: all research data exchanged. Limited sharing: only specified datasets or summary data. No sharing: data remains with generating party. Upon request: data shared on case-by-case basis.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseRestrictions rdf:type rdf:Property ;
    rdfs:label 'Data Use Restrictions' ;
    rdfs:comment 'Specific limitations on how shared data may be used, including permitted research purposes, prohibited uses, and requirements for data security and privacy compliance.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Defines exclusivity terms. Exclusive: only Genomics Biotech has rights in defined field/territory. Non-exclusive: partner may grant rights to others. Co-exclusive: limited number of licensees. Field-limited exclusive: exclusive within specific application area.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantFundingSource rdf:type rdf:Property ;
    rdfs:label 'Grant Funding Source' ;
    rdfs:comment 'Name of government or foundation grant program funding the collaboration, if applicable (e.g., NIH R01, BARDA contract, DARPA program, Gates Foundation grant).' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpApplicable rdf:type rdf:Property ;
    rdfs:label 'Gxp Applicable' ;
    rdfs:comment 'Indicates whether the collaboration activities must comply with GxP regulations (GMP, GLP, GCP) due to regulatory intent.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Model' ;
    rdfs:comment 'Framework governing ownership of intellectual property generated under the collaboration. Genomics Biotech owns: all IP vests in Genomics Biotech. Partner owns: all IP vests in partner. Joint ownership: co-ownership with defined exploitation rights. Background-foreground split: each party retains background IP, foreground IP allocated per agreement. Case-by-case: determined per invention.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Required' ;
    rdfs:comment 'Indicates whether the collaboration involves human subjects research requiring IRB approval and oversight.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licensingRights rdf:type rdf:Property ;
    rdfs:label 'Licensing Rights' ;
    rdfs:comment 'Description of licensing rights granted to Genomics Biotech or partner, including field of use, territory, exclusivity, and sublicensing permissions.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'Financial payment model for the agreement. Lump sum: single upfront payment. Milestone-based: payments tied to achievement of defined milestones. Periodic: regular installments (monthly, quarterly). Cost reimbursement: actual costs plus overhead. Hybrid: combination of structures.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiInvolved rdf:type rdf:Property ;
    rdfs:label 'Phi Involved' ;
    rdfs:comment 'Indicates whether the collaboration involves exchange or use of protected health information subject to HIPAA regulations.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationEmbargoDays rdf:type rdf:Property ;
    rdfs:label 'Publication Embargo Days' ;
    rdfs:comment 'Number of days that publication must be delayed to allow for patent application filing or confidential information review. Typically 30-90 days.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionPlanned rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Planned' ;
    rdfs:comment 'Indicates whether the collaboration is intended to generate data for regulatory submission (FDA, EMA, etc.) for product approval.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Contract number in SAP S/4HANA system for financial tracking and procurement integration.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Business Unit' ;
    rdfs:comment 'Genomics Biotech business unit or division sponsoring and funding the collaboration (e.g., Research Instruments, Clinical Genomics, Agricultural Solutions).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIndication rdf:type rdf:Property ;
    rdfs:label 'Target Indication' ;
    rdfs:comment 'Specific disease, condition, or application area targeted by the collaboration research (e.g., breast cancer, cystic fibrosis, crop yield improvement).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundingAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Funding Amount Usd' ;
    rdfs:comment 'Total financial commitment from Genomics Biotech to the partner under this agreement, expressed in USD. Includes sponsored research funding, milestone payments, and upfront fees.' ;
    rdfs:domain ind:CollaborationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchlingEntityReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Entity Reference' ;
    rdfs:comment 'Unique entity identifier in Benchling electronic lab notebook system linking to the molecular design record and sequence data.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casProteinVariant rdf:type rdf:Property ;
    rdfs:label 'Cas Protein Variant' ;
    rdfs:comment 'Specific Cas protein variant used in the construct (e.g., Cas9, Cas12a, Cas13, dCas9, base editor variant). Identifies the nuclease or effector protein component.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellType rdf:type rdf:Property ;
    rdfs:label 'Cell Type' ;
    rdfs:comment 'Specific cell type or tissue targeted by the construct. Defines the cellular context for editing or expression.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructCode rdf:type rdf:Property ;
    rdfs:label 'Construct Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier assigned to the construct for tracking and cataloging purposes within the R&D system.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructLengthBp rdf:type rdf:Property ;
    rdfs:label 'Construct Length Bp' ;
    rdfs:comment 'Total length of the construct sequence measured in base pairs. Defines the size of the molecular construct.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constructName rdf:type rdf:Property ;
    rdfs:label 'Construct Name' ;
    rdfs:comment 'Human-readable name or designation assigned to the CRISPR construct for identification and reference in laboratory workflows and publications.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructType rdf:type rdf:Property ;
    rdfs:label 'Construct Type' ;
    rdfs:comment 'Classification of the molecular construct type. Defines the category of the construct within the molecular biology design framework.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designRationale rdf:type rdf:Property ;
    rdfs:label 'Design Rationale' ;
    rdfs:comment 'Scientific justification and reasoning behind the construct design choices. Documents the strategic approach and expected outcomes.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designStatus rdf:type rdf:Property ;
    rdfs:label 'Design Status' ;
    rdfs:comment 'Current lifecycle status of the construct design. Tracks progression through design review and approval workflow.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designTool rdf:type rdf:Property ;
    rdfs:label 'Design Tool' ;
    rdfs:comment 'Software tool or algorithm used to design the construct (e.g., Benchling, CRISPOR, Cas-OFFinder). Documents the computational design methodology.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentStage rdf:type rdf:Property ;
    rdfs:label 'Development Stage' ;
    rdfs:comment 'Current stage of the construct in the R&D pipeline. Tracks progression from discovery through commercialization.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editingModality rdf:type rdf:Property ;
    rdfs:label 'Editing Modality' ;
    rdfs:comment 'Type of genomic editing or modulation intended by the CRISPR construct. Defines the functional outcome of the gene editing strategy.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicCoordinates rdf:type rdf:Property ;
    rdfs:label 'Genomic Coordinates' ;
    rdfs:comment 'Precise genomic coordinates in standard format (chromosome:start-end) based on reference genome assembly GRCh38/hg38.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grnaSequence rdf:type rdf:Property ;
    rdfs:label 'Grna Sequence' ;
    rdfs:comment 'Nucleotide sequence of the guide RNA component that directs Cas protein to the target genomic locus. Proprietary sequence data for CRISPR targeting.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offTargetScore rdf:type rdf:Property ;
    rdfs:label 'Off Target Score' ;
    rdfs:comment 'Computational prediction score for off-target binding potential. Lower scores indicate higher specificity and reduced off-target risk.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTargetEfficiencyScore rdf:type rdf:Property ;
    rdfs:label 'On Target Efficiency Score' ;
    rdfs:comment 'Predicted or measured efficiency of the construct at the intended target site. Higher scores indicate greater editing efficiency.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pamSequence rdf:type rdf:Property ;
    rdfs:label 'Pam Sequence' ;
    rdfs:comment 'PAM sequence required for Cas protein recognition and binding adjacent to the target site. Critical for CRISPR targeting specificity.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentReference rdf:type rdf:Property ;
    rdfs:label 'Patent Reference' ;
    rdfs:comment 'Patent application or grant number associated with the construct if applicable. Links to formal IP protection filings.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plasmidBackbone rdf:type rdf:Property ;
    rdfs:label 'Plasmid Backbone' ;
    rdfs:comment 'Name or identifier of the plasmid backbone vector used for construct assembly. Defines the vector framework for cloning and expression.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoterElement rdf:type rdf:Property ;
    rdfs:label 'Promoter Element' ;
    rdfs:comment 'Promoter sequence or element driving expression of the construct components. Defines transcriptional regulation of the construct.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'Quality control verification status for the synthesized construct. Indicates whether sequence verification and purity checks were successful.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionMarker rdf:type rdf:Property ;
    rdfs:label 'Selection Marker' ;
    rdfs:comment 'Antibiotic resistance or fluorescent marker gene included for selection and identification of successfully transformed cells.' ;
    rdfs:domain ind:CrisprConstruct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceDataReference rdf:type rdf:Property ;
    rdfs:label 'Sequence Data Reference' ;
    rdfs:comment 'Reference identifier linking to the full sequence data stored in Benchling or other molecular design system. Typically a Benchling entity ID or accession number.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:synthesisDate rdf:type rdf:Property ;
    rdfs:label 'Synthesis Date' ;
    rdfs:comment 'Date when the construct was physically synthesized or assembled. Tracks manufacturing timeline.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:synthesisVendor rdf:type rdf:Property ;
    rdfs:label 'Synthesis Vendor' ;
    rdfs:comment 'Name of the external vendor or internal facility that synthesized the construct. Tracks manufacturing source.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLocus rdf:type rdf:Property ;
    rdfs:label 'Target Locus' ;
    rdfs:comment 'Genomic coordinates or locus identifier for the target region. Specifies the precise genomic location targeted by the construct.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSampleBatchId rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Batch Id' ;
    rdfs:comment 'The batch or worklist identifier from LabVantage LIMS linking this experiment to the set of samples processed. Enables bidirectional traceability between the ELN experiment record and the LIMS sample tracking workflow.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:reagentSkuId rdf:type rdf:Property ;
    rdfs:label 'Reagent Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Experiments consume specific reagent SKUs (kits, consumables, controls). Lab managers track SKU usage for cost accounting, inventory planning, protocol optimization, and reagent performance evaluation' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:benchlingElnEntryReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Eln Entry Reference' ;
    rdfs:comment 'The unique identifier of the corresponding Electronic Lab Notebook (ELN) entry in Benchling. Provides direct traceability from the data product to the authoritative scientific record in the system of record for R&D documentation.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisprGuideRnaSequence rdf:type rdf:Property ;
    rdfs:label 'Crispr Guide Rna Sequence' ;
    rdfs:comment 'The nucleotide sequence of the guide RNA (gRNA) used in CRISPR gene-editing experiments. Captured for IP prosecution, reproducibility, and molecular design traceability. Applicable only to CRISPR experiment types; null for non-CRISPR experiments. Classified as confidential due to IP sensitivity.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegritySignature rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Signature' ;
    rdfs:comment 'Cryptographic hash or electronic signature value applied to the experiment record at the time of ELN entry finalization. Ensures data integrity and non-repudiation of the scientific record as required by 21 CFR Part 11 and GxP data integrity guidelines.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'The statistical or methodological design framework applied to the experiment (e.g., controlled, factorial, dose-response, observational, screening, comparative). Informs data analysis approach and statistical power assessment.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elnEntryType rdf:type rdf:Property ;
    rdfs:label 'Eln Entry Type' ;
    rdfs:comment 'Categorizes the nature of the ELN entry associated with this experiment record (observation, result, protocol execution, data analysis). Drives downstream data routing and review workflows in Benchling.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentCode rdf:type rdf:Property ;
    rdfs:label 'Experiment Code' ;
    rdfs:comment 'Human-readable, externally-known alphanumeric code uniquely identifying the experiment within the organization (e.g., EXP-CRISPR0042). Used in lab notebooks, reports, IP filings, and cross-system references.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current workflow state of the experiment in its lifecycle (planned, in-progress, completed, failed, cancelled, on-hold). Drives operational dashboards, resource planning, and milestone reporting.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentType rdf:type rdf:Property ;
    rdfs:label 'Experiment Type' ;
    rdfs:comment 'Classification of the experiment by scientific domain or workflow category (e.g., CRISPR editing efficiency assay, library preparation optimization, sequencing chemistry validation, reagent formulation trial, custom assay development, dose-response). [ENUM-REF-CANDIDATE: crispr_editing|library_prep_optimization|sequencing_chemistry_validation|reagent_formulation|assay_development|dose_response|other — promote to reference product]' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The scientific hypothesis or research question that the experiment is designed to test. Captured as free text from the ELN entry. Critical for IP prosecution documentation and scientific reproducibility.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisclosureFiled rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Filed' ;
    rdfs:comment 'Indicates whether an Intellectual Property (IP) invention disclosure has been filed based on the findings of this experiment. Triggers IP prosecution workflows and ensures novel discoveries are protected prior to publication.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labLocationCode rdf:type rdf:Property ;
    rdfs:label 'Lab Location Code' ;
    rdfs:comment 'Reference to the physical laboratory facility or room where the experiment is conducted. Supports environmental monitoring, equipment qualification traceability, and site-level compliance reporting.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeSummary rdf:type rdf:Property ;
    rdfs:label 'Outcome Summary' ;
    rdfs:comment 'Free-text narrative summarizing the scientific outcome, key findings, and conclusions of the experiment. Captured from the ELN entry and used for IP documentation, publication preparation, and knowledge management.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResultMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Result Metric' ;
    rdfs:comment 'The name of the principal quantitative or qualitative metric used to evaluate the experiment outcome (e.g., CRISPR editing efficiency percentage, Phred Score threshold, library yield ng/uL, LOD value). Enables structured result comparison across experiments.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResultUnit rdf:type rdf:Property ;
    rdfs:label 'Primary Result Unit' ;
    rdfs:comment 'The unit of measure for the primary result value (e.g., percent, ng/uL, copies/mL, Phred score, fold-change). Ensures dimensional correctness in analytics and cross-experiment comparisons.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResultValue rdf:type rdf:Property ;
    rdfs:label 'Primary Result Value' ;
    rdfs:comment 'The numeric value of the primary result metric for this experiment (e.g., 87.5 for 87.5% editing efficiency, 35.2 for Phred Score). Paired with primary_result_unit for dimensional analysis and cross-experiment benchmarking.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rAndDCostCenter rdf:type rdf:Property ;
    rdfs:label 'R And D Cost Center' ;
    rdfs:comment 'The SAP cost center code to which R&D expenditure for this experiment is charged. Enables R&D spend tracking, budget vs. actual analysis, and EBITDA reporting at the project and portfolio level.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetGeneSymbol rdf:type rdf:Property ;
    rdfs:label 'Target Gene Symbol' ;
    rdfs:comment 'The HGNC-approved gene symbol for the primary gene targeted or studied in this experiment (e.g., BRCA1, TP53, EGFR). Links the experiment to reference genomics data and enables gene-centric analytics across the research portfolio.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grant Employee Id' ;
    rdfs:comment 'Unique identifier of the Principal Investigator (PI) responsible for the scientific and technical direction of the grant. Links to workforce or researcher master data.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grantPrincipalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grant Principal Investigator Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Cumulative actual expenditures charged to the grant to date, in United States Dollars (USD). Sourced from SAP Financial Accounting (FI) module.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Application Submission Date' ;
    rdfs:comment 'Date the grant application was submitted to the funding agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associatedRdProjectIds rdf:type rdf:Property ;
    rdfs:label 'Associated Rd Project Ids' ;
    rdfs:comment 'Comma-separated list of internal R&D project IDs that are funded or supported by this grant. Links grant funding to specific research initiatives tracked in Benchling and the research.project data product.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date the grant was officially awarded by the funding agency. This is the principal business event timestamp for the grant lifecycle.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Classification of the grant mechanism (e.g., R01 Research Project Grant, R21 Exploratory/Developmental Research Grant, R43/R44 Small Business Innovation Research (SBIR), U01 Research Project Cooperative Agreement, contract, philanthropic grant). [ENUM-REF-CANDIDATE: R01|R21|R43|R44|U01|U54|P01|P50|contract|cooperative_agreement|philanthropic — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coInvestigatorNames rdf:type rdf:Property ;
    rdfs:label 'Co Investigator Names' ;
    rdfs:comment 'Comma-separated list of co-investigator names contributing to the grant project.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligations rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligations' ;
    rdfs:comment 'Summary of key compliance requirements attached to this grant (e.g., NIH Genomic Data Sharing Policy, HIPAA compliance, IRB oversight, animal welfare assurance, export control restrictions).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBudgetPeriodAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period Amount Usd' ;
    rdfs:comment 'Funding amount for the current budget period in United States Dollars (USD).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBudgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period End Date' ;
    rdfs:comment 'End date of the current budget period. Triggers annual progress reporting and continuation application requirements.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBudgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Budget Period Start Date' ;
    rdfs:comment 'Start date of the current budget period (typically one year for multi-year grants). Used for annual funding increments.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Required' ;
    rdfs:comment 'Indicates whether the grant requires submission of research data to public repositories per NIH Genomic Data Sharing Policy or other funder mandates. True if data sharing is required, False otherwise.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Direct Costs Usd' ;
    rdfs:comment 'Total direct costs portion of the grant award in United States Dollars (USD). Excludes indirect costs (Facilities and Administrative costs).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Report Due Date' ;
    rdfs:comment 'Due date for the final technical and financial report, typically 90 days after project period end date.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundingAgency rdf:type rdf:Property ;
    rdfs:label 'Funding Agency' ;
    rdfs:comment 'Name of the organization providing the grant funding (e.g., National Institutes of Health, Biomedical Advanced Research and Development Authority, National Science Foundation, European Commission, Bill & Melinda Gates Foundation).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAgencyDivision rdf:type rdf:Property ;
    rdfs:label 'Funding Agency Division' ;
    rdfs:comment 'Specific division, institute, or program within the funding agency (e.g., National Human Genome Research Institute (NHGRI), National Cancer Institute (NCI), NSF Division of Biological Infrastructure).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of the grant. Pending: application submitted, awaiting decision. Active: grant awarded and project period is current. Suspended: temporarily halted by agency or institution. Closed: project period completed, final reporting submitted. Terminated: grant ended prematurely.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iacucApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Iacuc Approval Number' ;
    rdfs:comment 'IACUC approval number if the grant involves animal research. Required for compliance with Animal Welfare Act and PHS Policy.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indirectCostRatePercent rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Rate Percent' ;
    rdfs:comment 'Negotiated indirect cost rate (Facilities and Administrative rate) applied to the grant, expressed as a percentage of direct costs.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Indirect Costs Usd' ;
    rdfs:comment 'Total indirect costs (Facilities and Administrative costs) portion of the grant award in United States Dollars (USD).' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentCount rdf:type rdf:Property ;
    rdfs:label 'Patent Count' ;
    rdfs:comment 'Number of patent applications or issued patents resulting from this grant. Required for Intellectual Property (IP) reporting to federal funders under Bayh-Dole Act.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Program Officer Email' ;
    rdfs:comment 'Email address of the program officer for grant-related communications.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOfficerName rdf:type rdf:Property ;
    rdfs:label 'Program Officer Name' ;
    rdfs:comment 'Name of the program officer or grants management specialist assigned to oversee this grant at the funding agency.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Project Period End Date' ;
    rdfs:comment 'End date of the total project period for which funding is approved. Marks the effective-until date of the grant agreement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Period Start Date' ;
    rdfs:comment 'Start date of the total project period for which funding is approved. Marks the effective-from date of the grant agreement.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationCount rdf:type rdf:Property ;
    rdfs:label 'Publication Count' ;
    rdfs:comment 'Number of peer-reviewed publications resulting from this grant. Used for impact assessment and reporting to funding agency.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingBalanceUsd rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Usd' ;
    rdfs:comment 'Remaining unspent balance of the grant award in United States Dollars (USD). Calculated as total_award_amount_usd minus actual_spend_usd.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingSchedule rdf:type rdf:Property ;
    rdfs:label 'Reporting Schedule' ;
    rdfs:comment 'Frequency of required progress reports to the funding agency (e.g., annual Research Performance Progress Report (RPPR), semi-annual technical reports, quarterly financial reports).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapGrantFundCode rdf:type rdf:Property ;
    rdfs:label 'Sap Grant Fund Code' ;
    rdfs:comment 'SAP fund code or grant account code used to segregate grant financial transactions in the general ledger.' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP Project System (PS) Work Breakdown Structure (WBS) element code used for financial tracking and cost allocation of grant expenditures.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAwardAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Award Amount Usd' ;
    rdfs:comment 'Total funding amount awarded for the entire project period, including direct and indirect costs, in United States Dollars (USD).' ;
    rdfs:domain ind:Grant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:veevaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Reference' ;
    rdfs:comment 'Reference to the grant agreement document, award notice, and related regulatory documents stored in Veeva Vault Quality Management System.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantReportId rdf:type rdf:Property ;
    rdfs:label 'Grant Report Id' ;
    rdfs:comment 'Unique identifier for the grant report submission record.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualExpenditureUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure Usd' ;
    rdfs:comment 'The actual amount of grant funds expended during the reporting period in US dollars.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'The actual date on which the grant report was submitted to the funding agency.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyAcknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgment Reference' ;
    rdfs:comment 'The reference number or confirmation code provided by the funding agency upon acknowledgment of the report submission.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyProgramOfficer rdf:type rdf:Property ;
    rdfs:label 'Agency Program Officer' ;
    rdfs:comment 'The name of the program officer or grants management specialist at the funding agency responsible for this grant.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReady rdf:type rdf:Property ;
    rdfs:label 'Audit Ready' ;
    rdfs:comment 'Indicates whether all supporting documentation and records are complete and organized for potential agency audit.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetExpenditureSummary rdf:type rdf:Property ;
    rdfs:label 'Budget Expenditure Summary' ;
    rdfs:comment 'A narrative summary of how grant funds were expended during the reporting period, including major cost categories and variances from the approved budget.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Usd' ;
    rdfs:comment 'The difference between allocated budget and actual expenditure for the reporting period (positive = under budget, negative = over budget).' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceIssuesDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Issues Description' ;
    rdfs:comment 'Detailed description of any compliance issues identified, including corrective actions taken or planned.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIssuesIdentified rdf:type rdf:Property ;
    rdfs:label 'Compliance Issues Identified' ;
    rdfs:comment 'Indicates whether any compliance issues (regulatory, financial, or ethical) were identified during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Compliance' ;
    rdfs:comment 'Status of compliance with NIH Genomic Data Sharing Policy and other data sharing requirements specified in the grant terms.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Equipment Costs Usd' ;
    rdfs:comment 'Total equipment and capital expenditure costs charged to the grant during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irbApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Status' ;
    rdfs:comment 'Current status of IRB approval for human subjects research conducted under this grant during the reporting period.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'A narrative summary of the key scientific findings, discoveries, and accomplishments achieved during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneAchievementStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Achievement Status' ;
    rdfs:comment 'Overall status of milestone achievement relative to the grant proposal timeline and objectives.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestonesCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Completed Count' ;
    rdfs:comment 'The number of planned milestones that were successfully completed during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesPlannedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Planned Count' ;
    rdfs:comment 'The total number of milestones that were planned for completion during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otherDirectCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Other Direct Costs Usd' ;
    rdfs:comment 'Total other direct costs (travel, publication fees, consultant fees, etc.) charged to the grant during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patentApplicationsCount rdf:type rdf:Property ;
    rdfs:label 'Patent Applications Count' ;
    rdfs:comment 'The number of patent applications filed based on intellectual property generated during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personnelCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Personnel Costs Usd' ;
    rdfs:comment 'Total personnel costs (salaries, wages, fringe benefits) charged to the grant during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationsCount rdf:type rdf:Property ;
    rdfs:label 'Publications Count' ;
    rdfs:comment 'The number of peer-reviewed publications resulting from the grant-funded research during the reporting period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Report Approved By' ;
    rdfs:comment 'The name of the individual who reviewed and approved the grant report for submission (typically PI or authorized institutional official).' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparedBy rdf:type rdf:Property ;
    rdfs:label 'Report Prepared By' ;
    rdfs:comment 'The name of the individual who prepared the grant report (may be PI, project manager, or grants administrator).' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'The end date of the reporting period covered by this grant report.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'The start date of the reporting period covered by this grant report.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'The deadline by which the grant report must be submitted to the funding agency.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppliesCostsUsd rdf:type rdf:Property ;
    rdfs:label 'Supplies Costs Usd' ;
    rdfs:comment 'Total costs for laboratory supplies, reagents, and consumables charged to the grant during the reporting period.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'Total Budget Allocated Usd' ;
    rdfs:comment 'The total grant budget amount allocated for the reporting period in US dollars.' ;
    rdfs:domain ind:GrantReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Id' ;
    rdfs:comment 'Unique identifier for the intellectual property disclosure record. Primary key.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpDisclosure .

ind:assignedIpCounsel rdf:type rdf:Property ;
    rdfs:label 'Assigned Ip Counsel' ;
    rdfs:comment 'Name of the internal or external IP attorney or patent agent assigned to manage the disclosure and any subsequent patent prosecution.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialPotential rdf:type rdf:Property ;
    rdfs:label 'Commercial Potential' ;
    rdfs:comment 'Assessment of the invention\'s potential commercial value and market impact, used to prioritize IP investment decisions.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveAdvantage rdf:type rdf:Property ;
    rdfs:label 'Competitive Advantage' ;
    rdfs:comment 'Description of how the invention provides competitive advantage over existing solutions or competitor offerings in the genomics-biotechnology market.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureCode rdf:type rdf:Property ;
    rdfs:label 'Disclosure Code' ;
    rdfs:comment 'Business identifier for the IP disclosure, typically formatted as IPD-XXXXXX for external reference and tracking.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'Date on which the invention was formally disclosed to the IP management office. Critical for establishing priority date and patent filing deadlines.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Current lifecycle status of the IP disclosure in the evaluation and decision workflow. [ENUM-REF-CANDIDATE: submitted|under_review|novelty_assessment|prior_art_search|decision_pending|approved_for_filing|abandoned|trade_secret — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFilingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Filing Cost Usd' ;
    rdfs:comment 'Estimated cost in USD for patent filing, prosecution, and maintenance over the patent lifecycle. Used for IP budget planning and ROI analysis.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Filing Decision Date' ;
    rdfs:comment 'Date when the patent filing decision was made by the IP committee or executive leadership.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Filing Decision Rationale' ;
    rdfs:comment 'Business and technical justification for the patent filing decision, including strategic value, competitive landscape, and cost-benefit analysis.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governmentInterestStatement rdf:type rdf:Property ;
    rdfs:label 'Government Interest Statement' ;
    rdfs:comment 'Statement acknowledging government funding and rights in the invention, required for patent applications when research was federally funded.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionDescription rdf:type rdf:Property ;
    rdfs:label 'Invention Description' ;
    rdfs:comment 'Detailed technical description of the invention, including the problem solved, novel aspects, and potential applications. Confidential business information.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventionType rdf:type rdf:Property ;
    rdfs:label 'Invention Type' ;
    rdfs:comment 'Classification of the invention according to patent law categories: composition of matter (e.g., novel sequencing chemistry, CRISPR construct), method (e.g., assay protocol), process (e.g., manufacturing workflow), software (e.g., bioinformatics algorithm), apparatus (e.g., instrument component), or design.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventors rdf:type rdf:Property ;
    rdfs:label 'Inventors' ;
    rdfs:comment 'Comma-separated list of full names of all inventors who contributed to the conception of the invention. Required for patent applications and inventor recognition.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCounselFirm rdf:type rdf:Property ;
    rdfs:label 'Ip Counsel Firm' ;
    rdfs:comment 'Name of the external law firm providing IP counsel services, if applicable.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jointOwnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Joint Ownership Flag' ;
    rdfs:comment 'Indicates whether the IP is jointly owned with an external party due to collaborative research or co-invention.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noveltyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment Date' ;
    rdfs:comment 'Date when the novelty assessment was completed by the IP review committee or external counsel.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noveltyAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Novelty Assessment Status' ;
    rdfs:comment 'Status and outcome of the internal novelty assessment to determine if the invention is sufficiently novel and non-obvious for patent protection.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noveltyRationale rdf:type rdf:Property ;
    rdfs:label 'Novelty Rationale' ;
    rdfs:comment 'Summary of the novelty assessment findings, including key differentiators from prior art and justification for novelty determination.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Patent Application Number' ;
    rdfs:comment 'Official patent application number assigned by the patent office (USPTO, EPO, etc.) upon filing. Null if not yet filed or if filing decision was to abandon or maintain as trade secret.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentFilingDate rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Date' ;
    rdfs:comment 'Date on which the patent application was officially filed with the patent office. Establishes the priority date for patent rights.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentFilingDecision rdf:type rdf:Property ;
    rdfs:label 'Patent Filing Decision' ;
    rdfs:comment 'Strategic decision on how to protect the invention: file a patent application, abandon (no protection), maintain as trade secret, or publish defensively to prevent others from patenting.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Patent Jurisdiction' ;
    rdfs:comment 'Primary patent jurisdiction or filing route: USA (United States Patent and Trademark Office), EPO (European Patent Office), PCT (Patent Cooperation Treaty for international filing), or specific country codes. [ENUM-REF-CANDIDATE: USA|EPO|PCT|JPN|CHN|KOR|CAN|AUS|BRA|IND — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtReferences rdf:type rdf:Property ;
    rdfs:label 'Prior Art References' ;
    rdfs:comment 'List of relevant prior art references identified during the search, including patent numbers, publication citations, and public disclosures.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorArtSearchDate rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Date' ;
    rdfs:comment 'Date when the prior art search was completed.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorArtSearchStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Art Search Status' ;
    rdfs:comment 'Status and outcome of the prior art search conducted to identify existing patents, publications, or public disclosures that may affect patentability.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date of any public disclosure of the invention (publication, presentation, product launch, etc.). Triggers one-year grace period for US patent filing and may bar foreign patent rights.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Assessment of the invention\'s strategic importance to the company\'s competitive position, product roadmap, and long-term R&D goals.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductApplication rdf:type rdf:Property ;
    rdfs:label 'Target Product Application' ;
    rdfs:comment 'Description of the intended product or service application for the invention, linking IP to commercialization strategy.' ;
    rdfs:domain ind:IpDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryIrbEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Irb Employee Id' ;
    rdfs:comment 'Foreign key reference to the workforce record of the Principal Investigator.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of protocol amendments submitted and approved since initial IRB approval. Tracks protocol evolution.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalTrialRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registration Number' ;
    rdfs:comment 'ClinicalTrials.gov registration number (NCT number) if the study is a clinical trial requiring public registration. Format: NCT########.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Form Version' ;
    rdfs:comment 'Version identifier of the informed consent form approved by the IRB for this submission.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Continuing Review Due Date' ;
    rdfs:comment 'Date by which continuing review submission is due to maintain active IRB approval. Typically 30-60 days before expiration.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyImpactAssessmentCompleted rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Impact Assessment Completed' ;
    rdfs:comment 'Boolean flag indicating whether a Data Privacy Impact Assessment has been completed for this study, as required by GDPR for high-risk processing.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRepositoryName rdf:type rdf:Property ;
    rdfs:label 'Data Repository Name' ;
    rdfs:comment 'Name of the public genomic data repository where study data will be deposited (e.g., \'dbGaP\', \'EGA\', \'AnVIL\'). Null if data sharing not required.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Estimated Enrollment' ;
    rdfs:comment 'Estimated total number of human subjects to be enrolled in the research study.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Boolean flag indicating whether the study involves EU subjects or data, making GDPR compliance requirements applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genomicDataSharingRequired rdf:type rdf:Property ;
    rdfs:label 'Genomic Data Sharing Required' ;
    rdfs:comment 'Boolean flag indicating whether the study is subject to NIH Genomic Data Sharing (GDS) Policy requirements for depositing genomic data into public repositories.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaWaiverStatus rdf:type rdf:Property ;
    rdfs:label 'Hipaa Waiver Status' ;
    rdfs:comment 'Status of HIPAA authorization waiver or alteration request for use of Protected Health Information (PHI) in the research study.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbBoardName rdf:type rdf:Property ;
    rdfs:label 'Irb Board Name' ;
    rdfs:comment 'Name of the Institutional Review Board that reviews this submission (e.g., \'Stanford IRB\', \'Western IRB\', \'Internal Genomics Biotech IRB\').' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbBoardRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Board Registration Number' ;
    rdfs:comment 'Federal registration number (IORG or IRB registration) assigned by OHRP or FDA for the reviewing IRB board.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContinuingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Continuing Review Date' ;
    rdfs:comment 'Date of the most recent continuing review approval by the IRB. Null if no continuing review has occurred.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiHandlingClassification rdf:type rdf:Property ;
    rdfs:label 'Phi Handling Classification' ;
    rdfs:comment 'Classification of how Protected Health Information is handled in the study. Determines HIPAA compliance requirements.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTitle rdf:type rdf:Property ;
    rdfs:label 'Protocol Title' ;
    rdfs:comment 'Full title of the research protocol submitted for IRB review. Describes the study purpose and scope.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of IRB review process applied to this submission based on risk and study characteristics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'IRB-assigned risk level for human subjects participating in the study. Determines review pathway and oversight requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Study Coordinator Name' ;
    rdfs:comment 'Full name of the study coordinator or research manager responsible for operational execution of the protocol.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerablePopulationInvolved rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Involved' ;
    rdfs:comment 'Boolean flag indicating whether the study involves vulnerable populations (children, prisoners, pregnant women, cognitively impaired) requiring additional IRB protections.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerablePopulationType rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Type' ;
    rdfs:comment 'Specific type of vulnerable population involved in the study (e.g., \'children\', \'prisoners\', \'pregnant_women\', \'cognitively_impaired\'). Null if not applicable.' ;
    rdfs:domain ind:IrbSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequestId rdf:type rdf:Property ;
    rdfs:label 'Material Request Id' ;
    rdfs:comment 'Primary key for material_request' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaterialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Employee Id' ;
    rdfs:comment 'Identifier of the R&D scientist or staff member who initiated the request.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Date when the requester physically received the material and confirmed receipt.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Verification Status' ;
    rdfs:comment 'Status indicating whether informed consent has been verified for human-derived biological samples or patient materials.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentSource rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Source' ;
    rdfs:comment 'Source from which the material will be obtained to fulfill the request (internal stock, biobank, external vendor, custom synthesis, etc.).' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedExperimentDescription rdf:type rdf:Property ;
    rdfs:label 'Intended Experiment Description' ;
    rdfs:comment 'Brief description of the experiment or research activity for which the material is being requested.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSampleReference rdf:type rdf:Property ;
    rdfs:label 'Lims Sample Reference' ;
    rdfs:comment 'Identifier of the sample or material in the LabVantage LIMS system, if the material is tracked as a sample.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Classification of the requested material. [ENUM-REF-CANDIDATE: reagent|consumable|biological_sample|cell_line|reference_standard|oligonucleotide|gene_synthesis|crispr_reagent|antibody|organoid|environmental_sample|agricultural_specimen|other — promote to reference product]' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'Actual quantity of material delivered to fulfill the request, which may differ from the quantity requested.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Numeric quantity of the material requested by the scientist.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationDetails rdf:type rdf:Property ;
    rdfs:label 'Specification Details' ;
    rdfs:comment 'Detailed technical specifications, purity requirements, concentration, sequence information, or other attributes defining the requested material.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority classification indicating how quickly the material is needed for the experiment or project.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneId rdf:type rdf:Property ;
    rdfs:label 'Milestone Id' ;
    rdfs:comment 'Primary key for milestone' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewBoardId rdf:type rdf:Property ;
    rdfs:label 'Review Board Id' ;
    rdfs:comment 'Reference to the scientific or stage-gate review board responsible for evaluating and approving the milestone outcome. Applicable to decision_gate and trl_assessment milestone types.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewBoard .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the milestone was formally completed and outcome recorded. Null if the milestone has not yet been completed. Used to calculate schedule variance (actual vs. planned) for R&D performance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advancementCriteria rdf:type rdf:Property ;
    rdfs:label 'Advancement Criteria' ;
    rdfs:comment 'Predefined criteria that must be met to advance to the next TRL level or stage gate. Captures the forward-looking requirements established at the time of assessment (e.g., \'Demonstrate analytical sensitivity in clinical matrix to advance from TRL 4 to TRL 5\'). Applicable primarily to trl_assessment and decision_gate milestone types.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assessment Rationale' ;
    rdfs:comment 'Narrative explanation of the outcome determination, including scientific justification, data interpretation, and any deviations from the original success criteria. Required for TRL assessments and go/no-go decision gates. Stored as free text aligned with Benchling ELN entries.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedDeliverable rdf:type rdf:Property ;
    rdfs:label 'Associated Deliverable' ;
    rdfs:comment 'Name or description of the primary tangible deliverable produced at this milestone (e.g., \'IND Module 2 Toxicology Summary Report\', \'CRISPR Off-Target Analysis Dataset\', \'Assay Validation Protocol v1.0\'). Links the milestone to its output artifact for portfolio tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'Planned budget (in spend_currency_code) allocated to achieve this milestone as defined in the R&D project financial plan. Used for budget vs. actual variance analysis and R&D portfolio financial management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative justification for the go/no-go decision recorded at a decision_gate milestone. Documents the scientific, commercial, and regulatory factors considered by the review board. Required for GxP-compliant stage-gate documentation.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceArtifactReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Artifact Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the supporting evidence artifacts stored in Benchling ELN, Veeva Vault, or MasterControl (e.g., experiment IDs, document control numbers, study report references). Enables traceability from milestone outcome to underlying scientific data.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Formal decision recorded at a decision_gate milestone: go (proceed to next phase), no_go (terminate or pivot program), conditional_go (proceed with defined conditions), or hold (decision deferred pending additional data). Null for non-decision-gate milestone types.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGxpRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Gxp Relevant' ;
    rdfs:comment 'Indicates whether this milestone involves GxP-regulated activities (True) — including GMP, GLP, or GCP — requiring formal documentation, audit trails, and quality system controls per applicable regulations. Drives quality oversight and Veeva Vault document control requirements.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIpGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Ip Generating' ;
    rdfs:comment 'Indicates whether achievement of this milestone is expected to generate patentable intellectual property or trade secrets (True) or not (False). Triggers IP disclosure workflows and patent filing timelines in the R&D IP management process.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCritical rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Critical' ;
    rdfs:comment 'Indicates whether this milestone lies on the critical regulatory submission path (True), meaning its delay would directly impact an FDA, EMA, or IVDR submission timeline. Used for regulatory affairs prioritization and risk management.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the milestone within the R&D portfolio management system (e.g., Benchling or SAP PS). Used in project plans, stage-gate reports, and regulatory submissions.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the milestone (e.g., \'IND-Enabling Toxicology Study Completion\', \'Proof-of-Concept CRISPR Readout\', \'TRL-4 Assessment\'). Used in portfolio dashboards and stage-gate presentations.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current workflow state of the milestone: planned (scheduled but not started), in_progress (active work underway), met (successfully completed against success criteria), missed (not completed by planned date), deferred (rescheduled to a future date), or cancelled (removed from scope).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Categorical classification of the milestone: decision_gate (go/no-go stage gate), deliverable (tangible output such as a report or prototype), trl_assessment (Technology Readiness Level evaluation), or regulatory_checkpoint (pre-submission meeting, IND filing, FDA/EMA interaction).' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally scheduled date by which the milestone was expected to be achieved, as defined in the R&D project plan. Used for schedule variance analysis and portfolio stage-gate tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorTrlScore rdf:type rdf:Property ;
    rdfs:label 'Prior Trl Score' ;
    rdfs:comment 'TRL score recorded at the immediately preceding TRL assessment milestone for the same project. Enables calculation of TRL advancement delta and tracking of technology maturation velocity across the R&D portfolio.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rdSpendRecognized rdf:type rdf:Property ;
    rdfs:label 'Rd Spend Recognized' ;
    rdfs:comment 'Cumulative R&D expenditure (in USD) formally recognized upon achievement of this milestone for financial reporting purposes. Supports milestone-based R&D spend recognition per ASC 730 (R&D accounting) and SOX-compliant financial controls. Null if milestone has not been met.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Regulatory authority associated with a regulatory_checkpoint milestone (e.g., FDA = U.S. Food and Drug Administration, EMA = European Medicines Agency, PMDA = Japan Pharmaceuticals and Medical Devices Agency). Null for non-regulatory milestone types. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|Health_Canada|TGA|ANVISA|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedTargetDate rdf:type rdf:Property ;
    rdfs:label 'Revised Target Date' ;
    rdfs:comment 'Updated target completion date when the original planned date has been formally revised due to scope changes, resource constraints, or scientific findings. Null if no revision has occurred. Supports deferred milestone tracking.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Calculated difference in calendar days between actual_completion_date and planned_date (positive = late, negative = early). Populated upon milestone completion. Used for R&D portfolio schedule performance reporting and KPI dashboards. Note: derived field retained as a persisted business metric for reporting efficiency.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Spend Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the rd_spend_recognized amount (e.g., USD, EUR, GBP). Supports multi-currency R&D portfolio financial reporting.' ;
    rdfs:domain ind:Milestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trlScore rdf:type rdf:Property ;
    rdfs:label 'Trl Score' ;
    rdfs:comment 'Numeric Technology Readiness Level score on the 1–9 scale assigned at the time of a trl_assessment milestone. TRL 1 = basic principles observed; TRL 9 = system proven in operational environment. Null for non-TRL milestone types. Enables portfolio stage-gating from basic research through product development readiness.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMolecularEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Molecular Employee Id' ;
    rdfs:comment 'Foreign key reference to the principal investigator or lead scientist responsible for this molecular design.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:designAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Design Algorithm Version' ;
    rdfs:comment 'Version number of the design tool or algorithm used, enabling reproducibility and traceability of design methodology.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCode rdf:type rdf:Property ;
    rdfs:label 'Design Code' ;
    rdfs:comment 'Unique alphanumeric code or identifier assigned to the molecular design for tracking and cataloging purposes.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designName rdf:type rdf:Property ;
    rdfs:label 'Design Name' ;
    rdfs:comment 'Human-readable name assigned to the molecular design artifact for identification and reference purposes.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Ip Disclosure Date' ;
    rdfs:comment 'Date when the intellectual property disclosure was filed for this molecular design.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meltingTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Melting Temperature Celsius' ;
    rdfs:comment 'Calculated melting temperature (Tm) of the oligonucleotide or primer in degrees Celsius, critical for PCR and hybridization protocols.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organismStrain rdf:type rdf:Property ;
    rdfs:label 'Organism Strain' ;
    rdfs:comment 'Specific strain, cell line, or variant of the target organism for which this design is optimized.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMethod rdf:type rdf:Property ;
    rdfs:label 'Qc Method' ;
    rdfs:comment 'Analytical method used for quality control verification, such as Sanger sequencing, NGS verification, or mass spectrometry.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceLengthBp rdf:type rdf:Property ;
    rdfs:label 'Sequence Length Bp' ;
    rdfs:comment 'Total length of the molecular design sequence measured in base pairs for DNA/RNA constructs.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Celsius' ;
    rdfs:comment 'Recommended or actual storage temperature for the molecular construct in degrees Celsius to maintain stability.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synthesisMethod rdf:type rdf:Property ;
    rdfs:label 'Synthesis Method' ;
    rdfs:comment 'Technical method or platform used for synthesizing the molecular construct, such as solid-phase synthesis, gene synthesis, or PCR amplification.' ;
    rdfs:domain ind:MolecularDesign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notebookEntryId rdf:type rdf:Property ;
    rdfs:label 'Notebook Entry Id' ;
    rdfs:comment 'Unique identifier for the electronic lab notebook entry. Primary key for the notebook_entry product.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extractionId rdf:type rdf:Property ;
    rdfs:label 'Extraction Id' ;
    rdfs:comment 'Foreign key linking to sample.extraction. Business justification: ELN entries document extraction procedures, observations, and results. Linking entries to extractions provides complete experimental provenance, supports GxP data integrity requirements, enables extra' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Extraction .

ind:primaryNotebookEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Notebook Employee Id' ;
    rdfs:comment 'Reference to the scientist or researcher who created this notebook entry. Primary author responsible for the scientific content.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:collaborationPartner rdf:type rdf:Property ;
    rdfs:label 'Collaboration Partner' ;
    rdfs:comment 'Name of the external research institution, academic partner, or contract research organization (CRO) involved in the work documented in this entry.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSummary rdf:type rdf:Property ;
    rdfs:label 'Content Summary' ;
    rdfs:comment 'Brief summary or abstract of the scientific content documented in this notebook entry, providing context for search and discovery.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataArtifactReference rdf:type rdf:Property ;
    rdfs:label 'Data Artifact Reference' ;
    rdfs:comment 'Reference to associated data files, images, sequencing data (FASTQ, BAM, VCF), or other digital artifacts linked to this notebook entry.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryCode rdf:type rdf:Property ;
    rdfs:label 'Entry Code' ;
    rdfs:comment 'Human-readable business identifier for the notebook entry, often following a lab-specific numbering convention.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the notebook entry indicating the nature of the scientific record: observation, experimental result, protocol execution, data analysis, hypothesis formulation, or conclusion.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labLocation rdf:type rdf:Property ;
    rdfs:label 'Lab Location' ;
    rdfs:comment 'Physical laboratory or facility location where the documented experimental work was performed.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationText rdf:type rdf:Property ;
    rdfs:label 'Observation Text' ;
    rdfs:comment 'Detailed narrative text of the scientific observation, experimental procedure, or data interpretation recorded by the scientist.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Numbers' ;
    rdfs:comment 'Comma-separated list of reagent and consumable lot numbers used in the documented experimental work, critical for reproducibility and quality investigations.' ;
    rdfs:domain ind:NotebookEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the result value, ensuring proper interpretation of quantitative findings.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'Reference to the employee record of the Project Manager responsible for schedule, budget, and milestone tracking for the R&D project. Distinct from the Principal Investigator who holds scientific accountability.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectPrincipalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Principal Investigator Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benchlingProjectReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Project Reference' ;
    rdfs:comment 'External identifier linking this R&D project to its corresponding project workspace in Benchling, the electronic lab notebook (ELN) and molecular biology platform. Enables cross-system navigation to experimental protocols, sequences, and notebook entries.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Usd' ;
    rdfs:comment 'Total approved budget allocated to the R&D project in US Dollars, as recorded in SAP CO internal order or WBS element. Represents the authorized spend ceiling for the project lifecycle. Used for R&D spend tracking and EBITDA impact analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of defined project milestones registered for this R&D project in the project management system. Used for portfolio progress tracking and gate review scheduling. Not a calculated metric — represents the registered count at the time of record update.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestonesAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Milestones Achieved Count' ;
    rdfs:comment 'Number of project milestones that have been formally completed and signed off as of the last record update. Used alongside milestone_count for portfolio progress reporting and earned value analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The principal quantitative or qualitative Key Performance Indicator (KPI) used to determine project success (e.g., LOD ≤ 1% VAF, sensitivity ≥ 99%, on-target editing efficiency ≥ 80%). Defined at project initiation and used for go/no-go gate decisions.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the R&D project, used across Benchling ELN, SAP CO cost objects, and internal communications (e.g., CRISPR-20240001, ASSAY-20230042). Serves as the cross-system reference key.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Free-text narrative description of the R&D project objectives, scientific rationale, and expected outcomes. Provides context for portfolio reviews, regulatory submissions, and cross-functional stakeholder communication.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the R&D project record: active (in progress), on_hold (paused), completed (objectives met), cancelled (terminated), or pending_approval (awaiting gate sign-off). Drives portfolio dashboards and resource planning.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the R&D project by its scientific and business purpose: discovery (early-stage hypothesis), development (product/tool build), validation (clinical or analytical validation), feasibility (proof-of-concept), or translational (bench-to-clinic). Drives workflow routing and milestone templates.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Business-assigned strategic priority level of the R&D project relative to the corporate portfolio. Drives resource allocation decisions, executive review cadence, and budget protection during planning cycles.' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetProductProfile rdf:type rdf:Property ;
    rdfs:label 'Target Product Profile' ;
    rdfs:comment 'Free-text or structured description of the Target Product Profile (TPP) defining the desired performance characteristics, intended use, and clinical/analytical claims for the product or technology being developed. Guides experimental design and success criteria.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trl rdf:type rdf:Property ;
    rdfs:label 'Trl' ;
    rdfs:comment 'Technology Readiness Level (TRL) score on the 1–9 scale indicating the maturity of the technology being developed. TRL 1 = basic principles observed; TRL 9 = proven in operational environment. Used for portfolio prioritization and commercialization readiness assessment.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableInstruments rdf:type rdf:Property ;
    rdfs:label 'Applicable Instruments' ;
    rdfs:comment 'Comma-separated list of instrument platforms or models for which this protocol is validated and applicable (e.g., \'NovaSeq 6000, NextSeq 2000, MiSeq\'). Critical for ensuring protocol-instrument compatibility in sequencing and assay workflows.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSampleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Sample Types' ;
    rdfs:comment 'Comma-separated list of biological sample types for which this protocol is validated (e.g., \'FFPE tissue, whole blood, saliva, cell line, cfDNA\'). Ensures protocol is applied only to compatible sample matrices.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoredBy rdf:type rdf:Property ;
    rdfs:label 'Authored By' ;
    rdfs:comment 'Name or employee identifier of the primary author who drafted the protocol. Captured as a display name string for audit trail and document control purposes. Supports accountability and traceability per GxP requirements.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchlingProtocolReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Protocol Reference' ;
    rdfs:comment 'External identifier assigned by Benchling (Electronic Lab Notebook / ELN) to the corresponding protocol entry. Enables bidirectional traceability between the lakehouse catalog and the Benchling R&D system of record.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaApplicable rdf:type rdf:Property ;
    rdfs:label 'Clia Applicable' ;
    rdfs:comment 'Indicates whether this protocol is subject to CLIA (Clinical Laboratory Improvement Amendments) requirements, applicable when the protocol is used in a clinical laboratory setting for patient testing.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceStandard rdf:type rdf:Property ;
    rdfs:label 'External Reference Standard' ;
    rdfs:comment 'Citation or identifier of the external compendial, regulatory, or industry standard that this protocol is based on or aligned with (e.g., \'CLSI EP17-A2\', \'ISO 20166-1\', \'FDA Guidance for NGS-Based IVDs\', \'ACMG/AMP Variant Classification Guidelines\'). Supports regulatory submission traceability.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpCompliant rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant' ;
    rdfs:comment 'Indicates whether this protocol has been designed and validated to comply with Good Laboratory Practice (GLP) regulations. True = GLP-compliant protocol; False = not GLP-compliant. Relevant for non-clinical safety studies submitted to regulatory agencies.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipGenerating rdf:type rdf:Property ;
    rdfs:label 'Ip Generating' ;
    rdfs:comment 'Indicates whether this protocol is associated with or has generated Intellectual Property (IP) such as a patent application, trade secret, or proprietary method. True = IP-generating; False = no IP association. Classified as confidential to protect competitive information.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lod rdf:type rdf:Property ;
    rdfs:label 'Lod' ;
    rdfs:comment 'Limit of Detection (LOD) for the assay or method described by this protocol, expressed as a value with units (e.g., \'0.1% VAF\', \'1 ng/µL\', \'10 copies/mL\'). Stored as a string to accommodate varied units across protocol types. Key analytical performance characteristic.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolDocReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Doc Reference' ;
    rdfs:comment 'Document control identifier assigned by MasterControl, the enterprise document control and training management system. Used to cross-reference the approved controlled document record for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Name of the organizational department or team responsible for maintaining and updating the protocol (e.g., \'Molecular Biology R&D\', \'Genomics Assay Development\', \'Quality Assurance\'). Determines accountability for periodic review.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalScientist rdf:type rdf:Property ;
    rdfs:label 'Principal Scientist' ;
    rdfs:comment 'Name or employee identifier of the principal scientist or subject matter expert (SME) who is the scientific owner of the protocol. Responsible for technical accuracy and scientific validity of the procedure.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolCategory rdf:type rdf:Property ;
    rdfs:label 'Protocol Category' ;
    rdfs:comment 'Scientific or operational category of the protocol describing the laboratory discipline it covers (e.g., \'Library Preparation\', \'CRISPR Gene Editing\', \'PCR/qPCR\', \'Cell Transfection\', \'Sequencing Run Setup\', \'Nucleic Acid Extraction\', \'Variant Calling\'). [ENUM-REF-CANDIDATE: library_preparation|crispr_gene_editing|pcr_qpcr|cell_transfection|sequencing_run_setup|nucleic_acid_extraction|variant_calling|array_hybridization|cell_culture|bioinformatics_pipeline — promote to reference product]' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Number' ;
    rdfs:comment 'Externally-known, human-readable unique document number assigned under the document numbering scheme (e.g., RD-SOP-001234). Used in regulatory submissions, audit trails, and cross-referencing in publications and SOPs.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolType rdf:type rdf:Property ;
    rdfs:label 'Protocol Type' ;
    rdfs:comment 'Classification of the protocol by document type. SOP = Standard Operating Procedure; method = analytical or experimental method; assay_protocol = specific assay procedure; work_instruction = step-level task instruction; reference_method = compendial or regulatory reference method; study_plan = experimental study design document.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredReagentSkus rdf:type rdf:Property ;
    rdfs:label 'Required Reagent Skus' ;
    rdfs:comment 'Comma-separated list of reagent and consumable SKU (Stock Keeping Unit) codes required to execute this protocol. Enables Bill of Materials (BOM) linkage, inventory planning, and reagent lot tracking in SAP MM and LabVantage LIMS.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'Biosafety Level (BSL) classification of the protocol indicating the containment level required for safe execution. BSL1–BSL4 per CDC/NIH biosafety guidelines. Non_hazardous for protocols involving no biological risk agents. Drives laboratory safety requirements and access controls.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Version Number' ;
    rdfs:comment 'Version number of the immediately preceding protocol version that this record replaces. Enables forward and backward traceability across the protocol version history chain. Null for the initial version.' ;
    rdfs:domain ind:ResearchProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationId rdf:type rdf:Property ;
    rdfs:label 'Publication Id' ;
    rdfs:comment 'Unique identifier for the scientific publication record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publication .

ind:abstract rdf:type rdf:Property ;
    rdfs:label 'Abstract' ;
    rdfs:comment 'Full text of the publication abstract summarizing the research objectives, methods, results, and conclusions.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authors rdf:type rdf:Property ;
    rdfs:label 'Authors' ;
    rdfs:comment 'Comma-separated list of all authors in publication order, including Genomics Biotech staff and external collaborators.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationCount rdf:type rdf:Property ;
    rdfs:label 'Citation Count' ;
    rdfs:comment 'Number of times the publication has been cited by other scientific works, as tracked by citation databases (e.g., Google Scholar, Web of Science).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correspondingAuthorEmail rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Email' ;
    rdfs:comment 'Email address of the corresponding author for publication inquiries.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondingAuthorName rdf:type rdf:Property ;
    rdfs:label 'Corresponding Author Name' ;
    rdfs:comment 'Name of the corresponding author responsible for communication regarding the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doi rdf:type rdf:Property ;
    rdfs:label 'Doi' ;
    rdfs:comment 'Unique Digital Object Identifier assigned to the publication for permanent citation and retrieval.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoEndDate rdf:type rdf:Property ;
    rdfs:label 'Embargo End Date' ;
    rdfs:comment 'Date when the embargo restrictions are lifted and the publication can be publicly disclosed. Null if no embargo applies.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether the publication is under embargo restrictions that prevent public disclosure until a specified date (True) or not (False).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAuthorCount rdf:type rdf:Property ;
    rdfs:label 'External Author Count' ;
    rdfs:comment 'Number of external collaborators (non-Genomics Biotech) listed as authors on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstAuthorName rdf:type rdf:Property ;
    rdfs:label 'First Author Name' ;
    rdfs:comment 'Name of the first author listed on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactFactor rdf:type rdf:Property ;
    rdfs:label 'Impact Factor' ;
    rdfs:comment 'Journal Impact Factor (JIF) of the journal at the time of publication, reflecting the average number of citations to recent articles. Null for conferences and preprints.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalAuthorCount rdf:type rdf:Property ;
    rdfs:label 'Internal Author Count' ;
    rdfs:comment 'Number of Genomics Biotech employees or contractors listed as authors on the publication.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Date' ;
    rdfs:comment 'Date when the IP clearance review was completed and the publication was approved for submission.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ipClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Clearance Status' ;
    rdfs:comment 'Status of intellectual property review and clearance for the publication: pending (under review), cleared (approved for publication), restricted (requires redaction), or blocked (cannot be published).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalName rdf:type rdf:Property ;
    rdfs:label 'Journal Name' ;
    rdfs:comment 'Name of the peer-reviewed journal where the article was published (e.g., Nature, Science, Cell). Null for conference presentations and preprints.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAccessClassification rdf:type rdf:Property ;
    rdfs:label 'Open Access Classification' ;
    rdfs:comment 'Classification of the publication\'s open access status: gold (fully open access journal), green (self-archived), hybrid (open access option in subscription journal), bronze (free to read without license), or closed (subscription-only).' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preprintServer rdf:type rdf:Property ;
    rdfs:label 'Preprint Server' ;
    rdfs:comment 'Name of the preprint server where the manuscript was posted (e.g., bioRxiv, medRxiv). Null for published articles and conference presentations.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationCode rdf:type rdf:Property ;
    rdfs:label 'Publication Code' ;
    rdfs:comment 'Business-assigned unique code for tracking and referencing the publication internally.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Current lifecycle status of the publication: draft (in preparation), submitted, under review, accepted, published, rejected, or withdrawn. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|published|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationType rdf:type rdf:Property ;
    rdfs:label 'Publication Type' ;
    rdfs:comment 'Classification of the publication format: peer-reviewed journal article, conference abstract, conference presentation, preprint (bioRxiv/medRxiv), review article, or book chapter.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pubmedIdentifier rdf:type rdf:Property ;
    rdfs:label 'Pubmed Identifier' ;
    rdfs:comment 'PubMed unique identifier for the publication in the National Library of Medicine database. Null for non-indexed publications.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchBudgetId rdf:type rdf:Property ;
    rdfs:label 'Research Budget Id' ;
    rdfs:comment 'Unique identifier for the R&D budget record. Primary key.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryResearchEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Research Employee Id' ;
    rdfs:comment 'Reference to the employee or executive who approved this budget allocation, supporting audit trail and accountability.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'Budget amount converted to USD using the exchange rate at the time of budget approval, enabling consolidated reporting and cross-currency comparison.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Level' ;
    rdfs:comment 'Organizational level of the approving authority, reflecting the governance tier required for this budget allocation based on amount and strategic importance.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known unique code identifying this budget allocation, used for cross-system reference and financial reporting.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable name or title of the budget allocation, typically reflecting the project or program name and fiscal period.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current approval and lifecycle status of the budget allocation, controlling whether the budget is editable or locked for actuals comparison.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Capitalization Rate Percent' ;
    rdfs:comment 'Percentage of the budget amount that is planned to be capitalized as an intangible asset, based on the project phase and accounting policy.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level classification of the budget allocation by type of expenditure: personnel (FTE salaries and benefits), external services (CRO, consulting), materials (reagents, consumables), equipment (instruments, lab hardware), compute (cloud HPC, bioinformatics infrastructure), facilities (lab space, utilities), travel (conferences, site visits), or other. [ENUM-REF-CANDIDATE: personnel|external_services|materials|equipment|compute|facilities|travel|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Research ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPartnerName rdf:type rdf:Property ;
    rdfs:label 'External Partner Name' ;
    rdfs:comment 'Name of the external partner organization (academic institution, biotech company, CRO) if this budget supports a collaborative R&D effort.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Acceptable variance threshold as an absolute amount in the budget currency, providing an alternative or complementary control to the percentage threshold.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percent' ;
    rdfs:comment 'Acceptable variance threshold as a percentage of the budget amount, beyond which budget overruns or underruns trigger alerts and require management review.' ;
    rdfs:domain ind:ResearchBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Sample Request Id' ;
    rdfs:comment 'Primary key for sample_request' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySampleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sample Employee Id' ;
    rdfs:comment 'Identifier of the R&D scientist, researcher, or staff member who submitted the sample request.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Biobank Location Id' ;
    rdfs:comment 'Identifier of the biobank or storage location from which the samples are being requested and retrieved.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:tertiarySampleHandoffRecipientEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Sample Handoff Recipient Employee Id' ;
    rdfs:comment 'Identifier of the individual who received the samples during the chain of custody handoff.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:chainOfCustodyHandoffDate rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Handoff Date' ;
    rdfs:comment 'Timestamp when the chain of custody for the samples was formally transferred from the sample management domain to the requester, ensuring traceability and compliance.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of the physical fulfillment process for the sample request, tracking whether samples have been pulled, prepared, and delivered.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoffRecipientName rdf:type rdf:Property ;
    rdfs:label 'Handoff Recipient Name' ;
    rdfs:comment 'Full name of the individual who received the samples during the chain of custody handoff.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRequestReference rdf:type rdf:Property ;
    rdfs:label 'Lims Request Reference' ;
    rdfs:comment 'External identifier from the Laboratory Information Management System (LabVantage LIMS) linking this request to the source system record.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSubtype rdf:type rdf:Property ;
    rdfs:label 'Sample Subtype' ;
    rdfs:comment 'More granular classification or variant of the sample type, providing additional specificity about the requested material.' ;
    rdfs:domain ind:SampleRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendId rdf:type rdf:Property ;
    rdfs:label 'Spend Id' ;
    rdfs:comment 'Primary key for spend' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountLocal rdf:type rdf:Property ;
    rdfs:label 'Amount Local' ;
    rdfs:comment 'The spend amount converted to the local reporting currency of the business unit or legal entity.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetLineItemCode rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Code' ;
    rdfs:comment 'Reference to the budget line item against which this spend is tracked, enabling budget vs. actuals variance analysis.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'The proportion of an employee\'s time allocated to this R&D project, expressed as a decimal (e.g., 0.50 for 50% allocation, 1.00 for full-time).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The date on which the R&D expenditure was incurred or posted to the general ledger.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spendDescription rdf:type rdf:Property ;
    rdfs:label 'Spend Description' ;
    rdfs:comment 'Free-text description of the R&D spend transaction, providing additional context about the nature of the expenditure.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendNumber rdf:type rdf:Property ;
    rdfs:label 'Spend Number' ;
    rdfs:comment 'Business identifier for the spend transaction, typically sourced from the ERP system (e.g., SAP document number).' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the external vendor or service provider associated with this R&D spend.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaCount rdf:type rdf:Property ;
    rdfs:label 'Capa Count' ;
    rdfs:comment 'Number of Corrective and Preventive Actions (CAPAs) initiated during the transfer process to address issues or risks.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingSite rdf:type rdf:Property ;
    rdfs:label 'Originating Site' ;
    rdfs:comment 'Physical location or facility where the technology was originally developed, important for traceability and regulatory compliance.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingTeam rdf:type rdf:Property ;
    rdfs:label 'Originating Team' ;
    rdfs:comment 'Name or identifier of the R&D team or department that developed the technology being transferred.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for completing all transfer activities including validation and acceptance, used for project planning and milestone tracking.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Count' ;
    rdfs:comment 'Number of Standard Operating Procedures (SOPs) or protocols included in the transfer package.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Quality Approval Date' ;
    rdfs:comment 'Date when Quality Assurance formally approved the technology transfer for implementation at the receiving site.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingFunction rdf:type rdf:Property ;
    rdfs:label 'Receiving Function' ;
    rdfs:comment 'Business function or operational area receiving the technology, indicating the downstream application context. [ENUM-REF-CANDIDATE: gmp_manufacturing|clinical_development|clia_lab|commercial_operations|quality_assurance|regulatory_affairs|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingSite rdf:type rdf:Property ;
    rdfs:label 'Receiving Site' ;
    rdfs:comment 'Physical location or facility where the technology will be implemented, such as GMP manufacturing site or CLIA-certified laboratory.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingTeam rdf:type rdf:Property ;
    rdfs:label 'Receiving Team' ;
    rdfs:comment 'Name or identifier of the downstream team or department receiving the technology for implementation or commercialization.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProjectNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Project Number' ;
    rdfs:comment 'SAP project or Work Breakdown Structure (WBS) element number for tracking transfer costs and resource allocation.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTrl rdf:type rdf:Property ;
    rdfs:label 'Target Trl' ;
    rdfs:comment 'Target Technology Readiness Level to be achieved upon successful transfer completion, indicating manufacturing or operational readiness.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingMaterialsIncluded rdf:type rdf:Property ;
    rdfs:label 'Training Materials Included' ;
    rdfs:comment 'Indicates whether training materials and documentation are included in the transfer package for receiving team onboarding.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Business identifier for the technology transfer, used for external reference and tracking across systems. Typically follows format TT-NNNNNN.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferPackageContents rdf:type rdf:Property ;
    rdfs:label 'Transfer Package Contents' ;
    rdfs:comment 'Comprehensive description of all materials included in the transfer package: protocols, SOPs, specifications, training materials, validation data, and supporting documentation.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the technology transfer process, tracking progression from initiation through completion. [ENUM-REF-CANDIDATE: initiated|planning|in_progress|validation|qualification|completed|on_hold|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTitle rdf:type rdf:Property ;
    rdfs:label 'Transfer Title' ;
    rdfs:comment 'Descriptive title of the technology or process being transferred, providing clear identification of the transfer scope.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the technology being transferred, indicating the nature of the intellectual property or process. [ENUM-REF-CANDIDATE: sequencing_chemistry|crispr_construct|assay_method|manufacturing_process|analytical_method|library_prep_protocol|bioinformatics_pipeline|instrument_method|quality_control_method|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trlAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Trl At Transfer' ;
    rdfs:comment 'Technology Readiness Level score at the time of transfer initiation, typically TRL 6-9 for manufacturing readiness and commercialization.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationDataIncluded rdf:type rdf:Property ;
    rdfs:label 'Validation Data Included' ;
    rdfs:comment 'Indicates whether validation study data and results are included in the transfer package to support qualification activities.' ;
    rdfs:domain ind:TechnologyTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trlAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Trl Assessment Id' ;
    rdfs:comment 'Unique identifier for the TRL assessment record. Primary key for the TRL assessment entity.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrlEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Trl Employee Id' ;
    rdfs:comment 'Foreign key reference to the individual who conducted the TRL assessment. Typically a senior scientist, technical lead, or R&D manager with expertise in the technology domain.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentCode rdf:type rdf:Property ;
    rdfs:label 'Assessment Code' ;
    rdfs:comment 'Business identifier for the TRL assessment. Typically follows a pattern such as TRL-PROJ123-2024Q1 to indicate project and assessment period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'The organizational role or title of the assessor at the time of assessment (e.g., Principal Scientist, R&D Director, Technology Lead).' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCommercializationDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Commercialization Date' ;
    rdfs:comment 'Projected date when this technology is expected to reach commercial launch readiness (TRL 9). Subject to revision based on development progress and gate review outcomes.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceArtifacts rdf:type rdf:Property ;
    rdfs:label 'Evidence Artifacts' ;
    rdfs:comment 'Comma-separated list or structured reference to supporting evidence documents, experimental results, validation reports, or other artifacts that substantiate the TRL score. May include Benchling ELN entry IDs, Veeva document IDs, or file paths.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Gate Decision Rationale' ;
    rdfs:comment 'Narrative explanation of the gate review decision. Captures the strategic, technical, and business reasoning behind the proceed/hold/terminate decision.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Gate Review Outcome' ;
    rdfs:comment 'The formal decision outcome from the stage-gate review associated with this TRL assessment. Proceed indicates approval to continue, conditional proceed requires specific actions before continuation, hold pauses the project, terminate ends the project, and pivot indicates a strategic redirection.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Planned Date' ;
    rdfs:comment 'The scheduled date for the next TRL assessment of this technology. Enables proactive portfolio management and stage-gate planning.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTrlTarget rdf:type rdf:Property ;
    rdfs:label 'Next Trl Target' ;
    rdfs:comment 'The target TRL score for the next assessment cycle or milestone. Represents the planned maturation trajectory for the technology.' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'The intended commercial market segment for this technology. Defines the primary customer base and application domain. [ENUM-REF-CANDIDATE: clinical_diagnostics|research_genomics|agricultural_genomics|pharma_drug_discovery|precision_medicine|population_health|forensics|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrlAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionId rdf:type rdf:Property ;
    rdfs:label 'Accession Id' ;
    rdfs:comment 'Unique surrogate identifier for the accession record in the Databricks Silver Layer. Primary key for this entity. TRANSACTION_HEADER role — represents the formal intake event of a specimen into laboratory custody.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labSiteId rdf:type rdf:Property ;
    rdfs:label 'Lab Site Id' ;
    rdfs:comment 'Reference to the laboratory site that physically received and accessioned the specimen. Supports multi-site operations, routing logic, and site-level compliance reporting under CLIA and CAP.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabSite .

ind:limsWorkflowAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Lims Workflow Assignment Id' ;
    rdfs:comment 'Identifier of the LabVantage workflow instance assigned to this accession for processing routing. Links the accession to the specific laboratory workflow queue (e.g., DNA extraction, library preparation, sequencing run setup) activated upon acceptance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LimsWorkflowAssignment .

ind:accessionStatus rdf:type rdf:Property ;
    rdfs:label 'Accession Status' ;
    rdfs:comment 'Current workflow lifecycle state of the accession record within LabVantage. Drives downstream routing: \'received\' = physically in lab but not yet reviewed; \'in_review\' = condition assessment underway; \'accepted\' = cleared for processing; \'rejected\' = specimen rejected and not processed; \'on_hold\' = pending additional information or consent; \'cancelled\' = order cancelled prior to processing.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessioningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accessioning Timestamp' ;
    rdfs:comment 'Date and time the specimen was formally registered and accessioned into the LIMS by the receiving technician. May differ from receipt_timestamp if there is a delay between physical receipt and system registration. Used for TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalCondition rdf:type rdf:Property ;
    rdfs:label 'Arrival Condition' ;
    rdfs:comment 'Assessment of the physical condition of the specimen upon arrival at the laboratory. \'acceptable\' = meets pre-analytical quality criteria; \'compromised\' = degraded but may still be processable with notation; \'rejected\' = fails minimum quality criteria and cannot be processed. Triggers rejection workflows and recollection requests when set to \'rejected\'.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayPanelCode rdf:type rdf:Property ;
    rdfs:label 'Assay Panel Code' ;
    rdfs:comment 'Code identifying the genomic assay panel or test menu requested for this specimen (e.g., WGS, WES, NGS gene panel, SNP array, CRISPR screen). Drives workflow routing to the appropriate laboratory workstation and bioinformatics pipeline in LabVantage.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'Name of the phlebotomist, nurse, or clinician who collected the specimen from the patient. Required for chain-of-custody documentation and pre-analytical error investigation. Classified as confidential business data.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNotes rdf:type rdf:Property ;
    rdfs:label 'Condition Notes' ;
    rdfs:comment 'Free-text description of observed pre-analytical issues or anomalies noted at specimen receipt (e.g., hemolysis, lipemia, insufficient volume, broken container, temperature excursion, clotted sample). Supports root cause analysis and pre-analytical QC reporting.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courierName rdf:type rdf:Property ;
    rdfs:label 'Courier Name' ;
    rdfs:comment 'Name of the courier or logistics provider that transported the specimen to the laboratory (e.g., FedEx, World Courier, BioMatik, internal courier). Used for vendor performance tracking and temperature excursion investigations.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRequisitionNumber rdf:type rdf:Property ;
    rdfs:label 'External Requisition Number' ;
    rdfs:comment 'Test requisition number assigned by the ordering facility\'s own system (e.g., hospital LIS, EHR order number). Enables bidirectional reconciliation between the external ordering system and the internal LIMS accession record.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDeidentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentified Flag' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) associated with this accession has been de-identified per HIPAA Safe Harbor or Expert Determination methods. True = PHI has been de-identified and the record may be used in downstream analytics without PHI restrictions; False = PHI is present and full access controls apply.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time the specimen was physically received at the laboratory, marking the transition from external courier custody to laboratory custody. This is the principal business event timestamp for the accession transaction. Recorded in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recollectionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Recollection Requested Flag' ;
    rdfs:comment 'Indicates whether a recollection request has been issued to the ordering provider or collection site due to specimen rejection or insufficient quality. True = recollection has been requested; False = no recollection required.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier from the LabVantage LIMS source system for this accession. Used for data lineage traceability between the Databricks Silver Layer and the operational system of record, supporting reconciliation and re-ingestion workflows.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtReceiptC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Receipt C' ;
    rdfs:comment 'Measured temperature of the specimen or shipping container at the time of receipt, expressed in degrees Celsius. Used to assess cold-chain compliance and flag potential temperature excursions that may affect specimen integrity and downstream assay validity.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportTemperatureCode rdf:type rdf:Property ;
    rdfs:label 'Transport Temperature Code' ;
    rdfs:comment 'Required transport temperature condition under which the specimen was shipped to the laboratory. Used to verify compliance with specimen stability requirements and to flag potential temperature excursions during transit.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tubeLabelCode rdf:type rdf:Property ;
    rdfs:label 'Tube Label Code' ;
    rdfs:comment 'Barcode or label identifier physically affixed to the specimen container at the time of collection or receipt. Used for physical specimen tracking, label verification at accessioning, and reconciliation against the LIMS accession number.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeReceivedMl rdf:type rdf:Property ;
    rdfs:label 'Volume Received Ml' ;
    rdfs:comment 'Measured volume of the specimen received at the laboratory, expressed in millilitres. Used to assess adequacy for requested assays, trigger insufficient volume rejection flags, and support aliquoting planning. Represents the principal quantitative measurement of the accession transaction.' ;
    rdfs:domain ind:Accession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for the volume_received_ml field. Typically mL for liquid specimens; mg or g for solid tissue specimens. Allows the schema to accommodate non-liquid specimen types without type conversion.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotId rdf:type rdf:Property ;
    rdfs:label 'Aliquot Id' ;
    rdfs:comment 'Unique surrogate identifier for the aliquot record in the Databricks Silver Layer. Primary key for the aliquot data product within the sample domain. Entity role: MASTER_RESOURCE — represents a physical sub-divided specimen unit managed as an independent trackable resource in LabVantage LIMS.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aliquot .

ind:containerId rdf:type rdf:Property ;
    rdfs:label 'Container Id' ;
    rdfs:comment 'FK to sample.container' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Container .

ind:parentAliquotId rdf:type rdf:Property ;
    rdfs:label 'Parent Aliquot Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent aliquot when this record represents a secondary or tertiary sub-division (aliquot-of-aliquot). Null for first-generation aliquots derived directly from the specimen. Enables multi-level aliquot hierarchy traversal.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aliquot .

ind:preparationReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Preparation Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Aliquots are prepared using specific reagent types (extraction kits, normalization buffers, stabilization reagents). Needed for protocol compliance verification, method validation studies, and ensurin' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:reagentKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Aliquots are created using specific reagent kits (extraction, library prep). Business need: protocol compliance verification, batch effect analysis in sequencing QC, reagent lot traceability for faile' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:sampleConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Sample Consent Record Id' ;
    rdfs:comment 'Reference to the Institutional Review Board (IRB) consent record governing the permissible uses of this aliquot. Ensures that downstream workflows (sequencing, research, clinical) are authorized under the applicable consent scope. Critical for HIPAA, GDPR, and NIH Genomic Data Sharing Policy compliance.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleConsentRecord .

ind:aliquotType rdf:type rdf:Property ;
    rdfs:label 'Aliquot Type' ;
    rdfs:comment 'Classification of the aliquot within the sub-division hierarchy. \'primary\' indicates first-generation aliquot from specimen; \'secondary\' and \'tertiary\' indicate downstream sub-divisions; \'pooled\' indicates a combined aliquot from multiple sources; \'reference\' indicates a reference material aliquot.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aliquoting Timestamp' ;
    rdfs:comment 'Date and time at which this aliquot was physically created from the parent specimen or parent aliquot. Represents the principal real-world business event timestamp for this entity. Used for pre-analytical variable tracking, stability calculations, and chain-of-custody documentation.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the concentration value recorded in the concentration field. Common units include ng/µL (nanograms per microliter) for DNA/RNA quantification, nM (nanomolar) for library quantification, and copies/µL for digital Polymerase Chain Reaction (PCR) applications.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStatus rdf:type rdf:Property ;
    rdfs:label 'Container Status' ;
    rdfs:comment 'Current operational status of the physical container holding the aliquot. \'in_use\' indicates container holds active aliquot material; \'empty\' indicates container has been emptied; \'discarded\' indicates container has been disposed of; \'pre_registered\' indicates container registered in LabVantage LIMS prior to receiving material (empty container inventory management).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnaIntegrityNumber rdf:type rdf:Property ;
    rdfs:label 'Dna Integrity Number' ;
    rdfs:comment 'DNA Integrity Number (DIN) score measured by TapeStation, ranging from 1 (fully degraded) to 10 (fully intact). Applicable to genomic DNA aliquots. Used to assess suitability for Whole Genome Sequencing (WGS) and Whole Exome Sequencing (WES) library preparation. Null for non-DNA aliquots.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freezeThawCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Count' ;
    rdfs:comment 'Number of freeze-thaw cycles the aliquot has undergone since creation. Excessive freeze-thaw cycles degrade nucleic acid integrity and protein activity. Used to enforce maximum freeze-thaw limits per Standard Operating Procedure (SOP) and to flag aliquots that may be unsuitable for sensitive assays.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Initial Volume Ul' ;
    rdfs:comment 'Original volume of biological material dispensed into the aliquot container at the time of aliquoting, expressed in microliters (µL). Provides the baseline for volume consumption tracking and yield calculations.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPhiDeidentified rdf:type rdf:Property ;
    rdfs:label 'Is Phi Deidentified' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) associated with this aliquot has been de-identified in accordance with HIPAA Safe Harbor or Expert Determination methods. True indicates de-identified; False indicates PHI is present and access controls apply. Governs data sharing eligibility for research and external collaborations.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label or name assigned to the aliquot for identification in laboratory workflows, reports, and LIMS displays. May include specimen accession number, aliquot sequence suffix, or study-specific naming conventions.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsAliquotCode rdf:type rdf:Property ;
    rdfs:label 'Lims Aliquot Code' ;
    rdfs:comment 'The native aliquot identifier assigned by LabVantage LIMS at the time of accessioning or aliquoting. Used as the operational cross-reference key between the lakehouse Silver Layer and the LIMS source system.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purityRatio260230 rdf:type rdf:Property ;
    rdfs:label 'Purity Ratio 260 230' ;
    rdfs:comment 'Absorbance ratio at 260nm to 230nm measured by spectrophotometry. Indicates contamination by chaotropic salts, EDTA, or carbohydrates. Acceptable range is typically 2.0–2.2. Complements the A260/A280 ratio for comprehensive nucleic acid Quality Control (QC) assessment.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purityRatio260280 rdf:type rdf:Property ;
    rdfs:label 'Purity Ratio 260 280' ;
    rdfs:comment 'Absorbance ratio at 260nm to 280nm measured by spectrophotometry (e.g., NanoDrop). Indicates nucleic acid purity; acceptable DNA purity is typically 1.8–2.0 and RNA purity 2.0–2.2. Values outside range may indicate protein or solvent contamination affecting downstream Next-Generation Sequencing (NGS) performance.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Intended downstream use of the aliquot. Drives workflow routing in LabVantage LIMS and determines which bioinformatics pipelines or Quality Control (QC) processes the aliquot will enter. Values include sequencing (Next-Generation Sequencing/NGS workflows), qc (Quality Control testing), archive (long-term storage), backup (redundancy), assay_validation (Clinical Assay Validation), and research (Research and Development).' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Free-text notes recorded by laboratory personnel during Quality Control (QC) assessment. Documents observations, deviations, conditional pass justifications, or remediation actions taken. Supports audit trail requirements under Good Practice Regulations (GxP) and CLIA.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier of the storage rack, plate, or box within the storage unit where this aliquot is positioned. Combined with well_position provides the precise physical location for robotic retrieval and manual locating in biobank operations.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinScore rdf:type rdf:Property ;
    rdfs:label 'Rin Score' ;
    rdfs:comment 'RNA Integrity Number (RIN) score measured by Bioanalyzer or TapeStation, ranging from 1 (fully degraded) to 10 (fully intact). Applicable to RNA aliquots only. Minimum RIN thresholds are defined per assay type (e.g., RIN ≥ 7 for RNA-seq library preparation). Null for non-RNA aliquots.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Use Restriction Code' ;
    rdfs:comment 'Standardized data use restriction code governing permissible downstream uses of this aliquot and its derived data. Codes follow GA4GH/dbGaP conventions: GRU (General Research Use), HMB (Health/Medical/Biomedical), DS (Disease-Specific), POA (Population Origins/Ancestry), NPU (Non-Profit Use Only), RUO (Research Use Only). Enforced during data access governance reviews.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeUl rdf:type rdf:Property ;
    rdfs:label 'Volume Ul' ;
    rdfs:comment 'Current measured volume of biological material in the aliquot container, expressed in microliters (µL). Decremented as material is consumed in workflows. Critical for determining aliquot sufficiency for downstream assays such as Next-Generation Sequencing (NGS) library preparation.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellPosition rdf:type rdf:Property ;
    rdfs:label 'Well Position' ;
    rdfs:comment 'Alphanumeric position identifier within the storage rack, plate, or box (e.g., A01, B12, H08 for a 96-well plate layout). Used for precise physical localization of the aliquot within its storage container for robotic liquid handling and manual retrieval.' ;
    rdfs:domain ind:Aliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Biobank Location Id' ;
    rdfs:comment 'Unique surrogate identifier for a physical storage location within the biorepository hierarchy. Primary key for this master resource entity.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentLocationBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Parent Location Biobank Location Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent location in the biorepository hierarchy (e.g., a box\'s parent is a rack, a rack\'s parent is a shelf). Enables recursive hierarchy traversal for chain-of-custody and retrieval workflows.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:accessRestrictionLevel rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Level' ;
    rdfs:comment 'Physical and logical access control classification for this storage location. Governs who may retrieve specimens from this location. \'restricted\' and above require role-based authorization in LabVantage LIMS and physical access badge control. Relevant for PHI-linked specimens and BSL-classified materials.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupPowerProtected rdf:type rdf:Property ;
    rdfs:label 'Backup Power Protected' ;
    rdfs:comment 'Indicates whether this storage unit is connected to an uninterruptible power supply (UPS) or emergency generator backup. Critical for specimen integrity risk assessment and business continuity planning for irreplaceable biobank specimens.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which this storage location was formally commissioned and made available for specimen storage following successful IQ/OQ/PQ qualification. Marks the start of the location\'s operational lifecycle.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date on which this storage location was permanently decommissioned and removed from active service. Null for locations still in service. Required for equipment lifecycle tracking and regulatory audit trails.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentManufacturer rdf:type rdf:Property ;
    rdfs:label 'Equipment Manufacturer' ;
    rdfs:comment 'Name of the manufacturer of the physical storage equipment (e.g., \'Thermo Fisher Scientific\', \'Panasonic\', \'Chart Industries\'). Required for vendor qualification records and regulatory equipment documentation.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentModel rdf:type rdf:Property ;
    rdfs:label 'Equipment Model' ;
    rdfs:comment 'Manufacturer model designation of the physical storage equipment at this location (e.g., \'Thermo Scientific TSX Series -80°C Freezer\'). Used for equipment qualification documentation, spare parts management, and maintenance scheduling.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number of the physical storage equipment. Required for equipment qualification (IQ/OQ/PQ) documentation, warranty tracking, and regulatory audit trails per ISO 13485 and GxP requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitySiteCode rdf:type rdf:Property ;
    rdfs:label 'Facility Site Code' ;
    rdfs:comment 'Code identifying the physical facility or campus where this storage location resides (e.g., \'SDCA\' for San Diego Campus A). Links to the enterprise site master for regulatory site registration and GxP compliance reporting.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCryogenic rdf:type rdf:Property ;
    rdfs:label 'Is Cryogenic' ;
    rdfs:comment 'Indicates whether this storage location uses cryogenic conditions (liquid nitrogen vapor or immersion, or mechanical ultra-low temperature ≤ -130°C). Drives safety protocol assignment, PPE requirements, and cryogenic handling SOP routing.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpControlled rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Controlled' ;
    rdfs:comment 'Indicates whether this storage location is subject to GMP regulations (e.g., for clinical trial specimens, IVD reagent intermediates, or GMP-grade biological materials). GMP-controlled locations require enhanced documentation, change control, and audit trail requirements.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPhiSegregated rdf:type rdf:Property ;
    rdfs:label 'Is Phi Segregated' ;
    rdfs:comment 'Indicates whether specimens stored at this location are physically segregated due to PHI linkage, requiring enhanced access controls and HIPAA-compliant chain-of-custody documentation. Supports de-identification workflow management.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Lims Location Code' ;
    rdfs:comment 'Native location identifier assigned by LabVantage LIMS for this storage position. Used for system-of-record cross-referencing, data lineage tracing, and integration reconciliation between the Silver Layer and the operational LIMS.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSensorCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Sensor Code' ;
    rdfs:comment 'Identifier of the continuous temperature/humidity monitoring sensor assigned to this storage location. Links to the environmental monitoring system (EMS) for real-time excursion alerting and 21 CFR Part 11-compliant audit trails.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupiedPositions rdf:type rdf:Property ;
    rdfs:label 'Occupied Positions' ;
    rdfs:comment 'Current number of specimen positions occupied at this storage location as tracked by LabVantage LIMS. Enables real-time utilization monitoring and triggers capacity alerts when approaching full occupancy.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionColumn rdf:type rdf:Property ;
    rdfs:label 'Position Column' ;
    rdfs:comment 'Numeric column designator for a specific well or slot position within a box or rack (e.g., \'1\', \'12\'). Applicable at the position/well hierarchy level. Combined with position_row to form the full position address.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionRow rdf:type rdf:Property ;
    rdfs:label 'Position Row' ;
    rdfs:comment 'Alphanumeric row designator for a specific well or slot position within a box or rack (e.g., \'A\', \'B\', \'H\'). Applicable at the position/well hierarchy level. Combined with position_column to form the full position address.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCustodian rdf:type rdf:Property ;
    rdfs:label 'Responsible Custodian' ;
    rdfs:comment 'Name or employee identifier of the designated biorepository custodian or laboratory manager responsible for this storage location. Accountable for specimen integrity, access authorization, and regulatory compliance at this location.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier assigned to this storage unit for automated inventory scanning and real-time location tracking within the biorepository. Supports high-throughput specimen management workflows.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomIdentifier rdf:type rdf:Property ;
    rdfs:label 'Room Identifier' ;
    rdfs:comment 'Identifier of the laboratory or storage room within the facility where this location physically resides. Used for access control, environmental monitoring zone assignment, and GxP area classification.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenTypeCompatibility rdf:type rdf:Property ;
    rdfs:label 'Specimen Type Compatibility' ;
    rdfs:comment 'Comma-delimited list of specimen types approved for storage at this location (e.g., \'whole_blood,plasma,FFPE,DNA,RNA,cell_line\'). Enforced during specimen accessioning in LabVantage LIMS to prevent storage condition mismatches. [ENUM-REF-CANDIDATE: whole_blood|plasma|serum|FFPE|DNA|RNA|cell_line|tissue|urine|saliva — promote to reference product]' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageMedium rdf:type rdf:Property ;
    rdfs:label 'Storage Medium' ;
    rdfs:comment 'Physical medium used for cryogenic or ambient storage at this location. Distinguishes mechanical freezer cooling from liquid nitrogen (LN2) vapor-phase or immersion-phase storage, which affects specimen viability protocols and safety requirements.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUnitType rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Type' ;
    rdfs:comment 'Classification of the physical storage unit at this location level (e.g., freezer, refrigerator, liquid nitrogen tank, ambient cabinet). Drives temperature monitoring SOP assignment and equipment maintenance scheduling.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSetpointC rdf:type rdf:Property ;
    rdfs:label 'Temperature Setpoint C' ;
    rdfs:comment 'Nominal target storage temperature in degrees Celsius for this location (e.g., -80.00 for ultra-low freezer, -196.00 for liquid nitrogen, 4.00 for refrigerator, 22.00 for room temperature). Critical for specimen integrity and regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCapacityPositions rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Positions' ;
    rdfs:comment 'Maximum number of specimen positions (wells, slots, or tubes) this storage location can physically accommodate. Used for capacity planning, utilization reporting, and biorepository space management.' ;
    rdfs:domain ind:BiobankLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionEventId rdf:type rdf:Property ;
    rdfs:label 'Collection Event Id' ;
    rdfs:comment 'Unique surrogate identifier for the specimen collection event record in the Databricks Silver Layer. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionKitCatalogId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Collection events use specific collection kit products (PAXgene, Tempus, saliva kits). Critical for tracking kit performance across collection sites, supplier quality monitoring, and correlating pre-a' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:collectionKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Collection events use specific collection kit products. Currently denormalized as collection_kit_sku. Business need: kit lot traceability for regulatory compliance, collection protocol compliance veri' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:subjectId rdf:type rdf:Property ;
    rdfs:label 'Subject Id' ;
    rdfs:comment 'Reference to the human subject, patient, or research participant from whom the specimen was collected. Links to the subject/patient master record. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category. Classified restricted/pii_identifier as it directly identifies a research or clinical participant.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subject .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Reference to the clinical or research study visit during which this collection event occurred. Supports longitudinal sample tracking and time-point-based genomic analysis (e.g., baseline vs. post-treatment comparisons).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Visit .

ind:anatomicalSite rdf:type rdf:Property ;
    rdfs:label 'Anatomical Site' ;
    rdfs:comment 'Standardized anatomical location from which the specimen was collected (e.g., left antecubital vein, right breast core, nasopharynx). Encoded using SNOMED CT or ICD-10 topography codes where applicable. Critical for oncology and clinical genomics interpretation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country where the specimen was collected. Required for international regulatory compliance (GDPR, IVDR), cross-border data transfer governance, and geographic cohort stratification.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Event Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the collection event, assigned by LabVantage LIMS at accessioning. Used for chain-of-custody documentation, deviation reports, and cross-system traceability. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionKitLotNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Lot Number' ;
    rdfs:comment 'Lot number of the collection kit (e.g., blood draw tube, biopsy kit, saliva collection kit, liquid biopsy tube) used during the collection event. Critical for pre-analytical QC, reagent traceability, and recall management. Sourced from SAP S/4HANA MM lot tracking.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Standardized method used to obtain the biological specimen. Drives pre-analytical QC interpretation and NGS library preparation protocol selection. Values: venipuncture (blood draw), biopsy (tissue), swab (mucosal/surface), saliva_kit (self-collected saliva), liquid_biopsy (cell-free DNA from blood), fine_needle_aspiration (FNA cytology).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionNotes rdf:type rdf:Property ;
    rdfs:label 'Collection Notes' ;
    rdfs:comment 'Free-text field for additional collector observations, special circumstances, or contextual notes recorded at the time of collection that do not fit into structured fields. Supports clinical interpretation and deviation investigation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Order Number' ;
    rdfs:comment 'External order or requisition number from the ordering system (e.g., SAP SD sales order, clinical order management system) that triggered this collection event. Enables end-to-end traceability from customer order to specimen collection.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCode rdf:type rdf:Property ;
    rdfs:label 'Collection Site Code' ;
    rdfs:comment 'Reference to the clinical, research, or environmental site where the specimen was collected (e.g., hospital phlebotomy unit, field sampling location, clinical trial site). Links to the site/location master record.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSopVersion rdf:type rdf:Property ;
    rdfs:label 'Collection Sop Version' ;
    rdfs:comment 'Version number of the SOP document used at the time of collection (e.g., v1.2, v3.0). Stored alongside the SOP ID to capture the exact approved version in effect, as SOP versions change over time.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Collection Temperature C' ;
    rdfs:comment 'Ambient or transport temperature in degrees Celsius at the time of or immediately following specimen collection. Used to assess cold-chain compliance and pre-analytical stability. Critical for cfDNA liquid biopsy and RNA specimens.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone offset) at which the physical specimen was collected from the subject or environment. This is the principal real-world event time and is critical for pre-analytical time calculations (e.g., time-to-processing, cold-chain compliance). Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionTubeCount rdf:type rdf:Property ;
    rdfs:label 'Collection Tube Count' ;
    rdfs:comment 'Number of collection tubes or containers used during the collection event. Relevant for blood draw events with multiple tube types (EDTA, SST, Streck cfDNA). Supports aliquot planning and chain-of-custody reconciliation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionUrgency rdf:type rdf:Property ;
    rdfs:label 'Collection Urgency' ;
    rdfs:comment 'Priority classification of the collection event that governs Turnaround Time (TAT) expectations and workflow prioritization in LabVantage LIMS. \'stat\' = immediate priority; \'urgent\' = same-day; \'routine\' = standard TAT.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Collection Volume Ml' ;
    rdfs:comment 'Volume of specimen collected, expressed in millilitres (mL). Used for pre-analytical QC assessment (e.g., short draw detection), yield estimation, and aliquot planning. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category (non-monetary transaction).' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Collection Volume Unit' ;
    rdfs:comment 'Unit of measure for the collection volume field. Typically mL for liquid specimens; mg or g for solid tissue specimens; uL for micro-volume collections.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Collector Certification Number' ;
    rdfs:comment 'Professional certification or license number of the individual who performed the collection (e.g., phlebotomy certification, nursing license). Required for CLIA and CAP compliance documentation and chain-of-custody integrity.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingStatus rdf:type rdf:Property ;
    rdfs:label 'Fasting Status' ;
    rdfs:comment 'Pre-analytical fasting status of the subject at the time of collection. Relevant for metabolomics, lipid panels, and certain genomic assays where fasting state affects analyte stability and downstream data quality interpretation.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hemolysisIndex rdf:type rdf:Property ;
    rdfs:label 'Hemolysis Index' ;
    rdfs:comment 'Semi-quantitative assessment of hemolysis in the collected blood specimen, graded on a standardized scale (none, 1+ to 4+). Hemolysis is a key pre-analytical variable that degrades DNA/RNA quality and affects NGS library preparation success rates.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Accession Number' ;
    rdfs:comment 'Accession number assigned by LabVantage LIMS at the time of specimen receipt and registration. Serves as the primary LIMS-side identifier for chain-of-custody tracking and workflow assignment.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiDeidentified rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentified' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) associated with this collection event has been de-identified per HIPAA Safe Harbor or Expert Determination method. True = de-identified; False = identifiable PHI present. Governs data access controls and downstream sharing permissions.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Collection Date' ;
    rdfs:comment 'Planned calendar date for the collection event as defined in the study protocol or clinical order. Compared against collection_date to calculate collection compliance and protocol adherence metrics.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToProcessingMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Processing Minutes' ;
    rdfs:comment 'Elapsed time in minutes between specimen collection timestamp and the start of primary processing (e.g., centrifugation, nucleic acid extraction). A critical pre-analytical variable for NGS data quality; exceeding thresholds may trigger QC flags or deviation records.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transportCondition rdf:type rdf:Property ;
    rdfs:label 'Transport Condition' ;
    rdfs:comment 'Required transport temperature condition for the collected specimen from collection site to processing laboratory. Drives cold-chain logistics and is compared against actual temperature readings for pre-analytical QC.' ;
    rdfs:domain ind:CollectionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accessioned Timestamp' ;
    rdfs:comment 'Date and time when the container was first registered and accessioned into the LabVantage LIMS system. Marks the start of the container lifecycle and chain-of-custody record. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capColor rdf:type rdf:Property ;
    rdfs:label 'Cap Color' ;
    rdfs:comment 'Color of the container cap or closure used for visual specimen type identification per laboratory SOP (e.g., red = serum, purple = EDTA whole blood, yellow = SST). Supports pre-analytical sorting and specimen type verification at accessioning.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current integrity status of the chain-of-custody record for this container. Intact = unbroken custody from collection to current location; Broken = a custody gap or anomaly has been detected; Under Review = custody discrepancy under investigation; Verified = custody independently confirmed.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationNgUl rdf:type rdf:Property ;
    rdfs:label 'Concentration Ng Ul' ;
    rdfs:comment 'Measured concentration of the nucleic acid or analyte within the container expressed in nanograms per microliter (ng/µL). Captured at accessioning or post-QC measurement. Used for library preparation input normalization and downstream NGS workflow eligibility.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Current Volume Ul' ;
    rdfs:comment 'Current volume of specimen or reagent held within the container expressed in microliters (µL). Updated by LabVantage LIMS upon each aliquoting, dispensing, or consumption event. Enables remaining volume tracking for sample sufficiency checks.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discardedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discarded Timestamp' ;
    rdfs:comment 'Date and time when the container was formally discarded or destroyed in LabVantage LIMS. Null if the container has not been discarded. Required for chain-of-custody closure, biohazardous waste disposal documentation, and regulatory audit trails.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isDnaseRnaseFree rdf:type rdf:Property ;
    rdfs:label 'Is Dnase Rnase Free' ;
    rdfs:comment 'Indicates whether the container is certified DNase- and RNase-free (True), ensuring nucleic acid integrity for genomic and transcriptomic applications. Critical for NGS library preparation, RNA sequencing, and qPCR workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLowBind rdf:type rdf:Property ;
    rdfs:label 'Is Low Bind' ;
    rdfs:comment 'Indicates whether the container has a low-binding surface treatment (True) to minimize nucleic acid or protein adsorption to container walls. Important for low-input NGS library preparation and single-cell genomics workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSterile rdf:type rdf:Property ;
    rdfs:label 'Is Sterile' ;
    rdfs:comment 'Indicates whether the container was manufactured and certified as sterile (True) or is non-sterile (False). Determines eligibility for clinical specimen collection, cell culture applications, and GMP manufacturing workflows.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsContainerCode rdf:type rdf:Property ;
    rdfs:label 'Lims Container Code' ;
    rdfs:comment 'Native container identifier assigned by the LabVantage LIMS source system. Preserved for bidirectional reconciliation between the Databricks Silver layer and the operational LIMS. Distinct from the surrogate container_id.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:material rdf:type rdf:Property ;
    rdfs:label 'Material' ;
    rdfs:comment 'Primary material composition of the container (e.g., polypropylene, glass, polystyrene). Determines chemical compatibility with specimen types, sterilization method eligibility, and storage temperature range.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFreezeThawCycles rdf:type rdf:Property ;
    rdfs:label 'Max Freeze Thaw Cycles' ;
    rdfs:comment 'Maximum number of freeze-thaw cycles permitted for the specimen type held in this container before the sample is considered compromised per laboratory SOP. Drives automated QC alerts in LabVantage when freeze_thaw_count is exceeded.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platePosition rdf:type rdf:Property ;
    rdfs:label 'Plate Position' ;
    rdfs:comment 'Alphanumeric well position identifier for containers that are wells within a microplate or array plate (e.g., A01, H12, P24). Null for standalone tubes and vials. Enables plate-map tracking and automated liquid handling coordination.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruoFlag rdf:type rdf:Property ;
    rdfs:label 'Ruo Flag' ;
    rdfs:comment 'Indicates whether the container is designated for Research Use Only (RUO) and is not intended for use in clinical diagnostic procedures. True = RUO; False = clinical or IVD use. Required for FDA regulatory compliance labeling and downstream workflow routing.' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tubeFormat rdf:type rdf:Property ;
    rdfs:label 'Tube Format' ;
    rdfs:comment 'Standardized format designation of the container (e.g., 1.5 mL Eppendorf, 96-well plate, 384-well plate). Determines compatibility with automated liquid handling instruments, centrifuge rotors, and storage rack configurations. [ENUM-REF-CANDIDATE: 0.2ml|0.5ml|1.5ml|2.0ml|5.0ml|15ml|50ml|96_well|384_well — promote to reference product]' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityUl rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Ul' ;
    rdfs:comment 'Maximum volumetric capacity of the container expressed in microliters (µL). Used for liquid handling automation, aliquot volume validation, and storage planning. Typical values range from 0.2 µL (PCR strip tube) to 50,000 µL (50 mL conical).' ;
    rdfs:domain ind:Container ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalEventId rdf:type rdf:Property ;
    rdfs:label 'Disposal Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each specimen or aliquot disposal event record in the Sample Management domain. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprErasureRequestId rdf:type rdf:Property ;
    rdfs:label 'Gdpr Erasure Request Id' ;
    rdfs:comment 'Reference identifier of the GDPR Article 17 right-to-erasure request that mandated this disposal event. Applicable for EU subject samples. Supports GDPR compliance documentation and data subject rights management.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessRequest .

ind:primaryDisposalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disposal Employee Id' ;
    rdfs:comment 'Reference to the qualified personnel (scientist, lab manager, or compliance officer) who formally authorized the disposal event. Required for GxP and CLIA chain-of-custody documentation. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisposalWitnessPersonnelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disposal Witness Personnel Employee Id' ;
    rdfs:comment 'Reference to the qualified witness who observed and attested to the disposal procedure. Required for controlled substance or high-value specimen disposals under GxP and certain IRB protocols.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoclaveCycleCode rdf:type rdf:Property ;
    rdfs:label 'Autoclave Cycle Code' ;
    rdfs:comment 'Identifier of the autoclave sterilization cycle used for disposal when disposal_method is autoclave. Links to autoclave validation and equipment qualification records for GxP compliance.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfDestructionNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Destruction Number' ;
    rdfs:comment 'Unique identifier of the Certificate of Destruction (COD) issued upon confirmed disposal. Serves as the primary regulatory evidence document for GxP, CLIA, and IRB protocol closure audits.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawalRef rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawal Ref' ;
    rdfs:comment 'Reference number or identifier of the subject consent withdrawal request that triggered this disposal event. Applicable when reason_code is consent_withdrawal. Supports GDPR Article 17 (right to erasure) and HIPAA compliance documentation.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Destruction Confirmed' ;
    rdfs:comment 'Indicates whether physical destruction of the specimen/aliquot has been formally confirmed by the authorizing personnel. Required for GxP, CLIA, and IRB protocol closure documentation. True = destruction confirmed; False = pending confirmation.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalEventNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the disposal event, used in GxP documentation, IRB protocol closure records, and chain-of-custody audit trails. Format: DSP-{YYYY}-{NNNNNN}. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbClosureNotified rdf:type rdf:Property ;
    rdfs:label 'Irb Closure Notified' ;
    rdfs:comment 'Indicates whether the Institutional Review Board (IRB) has been formally notified of the disposal event for protocol closure purposes. True = notification sent; False = notification pending. Required for IRB protocol closure compliance.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsDisposalTaskCode rdf:type rdf:Property ;
    rdfs:label 'Lims Disposal Task Code' ;
    rdfs:comment 'Native task or workflow identifier assigned by LabVantage LIMS for this disposal event. Enables bidirectional traceability between the Silver Layer data product and the operational LIMS system of record.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the business or regulatory reason triggering the disposal event. Drives IRB protocol closure, consent management workflows, and GxP deviation reporting. [ENUM-REF-CANDIDATE: consent_withdrawal|expiry|volume_exhausted|contamination|protocol_completion|regulatory_hold_release — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or justification for the disposal event beyond the standardized reason code. Supports GxP deviation documentation and IRB protocol closure notes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Reference' ;
    rdfs:comment 'Citation of the specific regulatory requirement, SOP number, or governing standard under which this disposal event is being executed (e.g., SOP-LAB-0042, 21 CFR Part 11, ISO 15189:2022 Section 5.7). Supports regulatory submission and audit readiness.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Remaining Volume Ul' ;
    rdfs:comment 'Volume of biological material remaining in the specimen/aliquot container after partial disposal, expressed in microliters (µL). Zero indicates complete disposal. Supports inventory reconciliation and chain-of-custody documentation.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleUseType rdf:type rdf:Property ;
    rdfs:label 'Sample Use Type' ;
    rdfs:comment 'Classification of the intended use of the specimen being disposed: Clinical (IVD/LDT), Research (RUO), or Quality Control (QC). Determines applicable regulatory framework (CLIA, FDA IVD, IRB) for disposal documentation requirements.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtDisposalC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Disposal C' ;
    rdfs:comment 'Ambient or process temperature (in degrees Celsius) recorded at the time of disposal. Relevant for autoclave validation, chemical inactivation efficacy, and cold-chain break documentation.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDisposedUl rdf:type rdf:Property ;
    rdfs:label 'Volume Disposed Ul' ;
    rdfs:comment 'Volume of biological material disposed of, expressed in microliters (µL). Used for inventory reconciliation, chain-of-custody completeness verification, and QC audit trails confirming full or partial disposal.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteContractorName rdf:type rdf:Property ;
    rdfs:label 'Waste Contractor Name' ;
    rdfs:comment 'Name of the licensed third-party waste disposal contractor responsible for off-site incineration or biohazardous waste processing. Required for EPA chain-of-custody and vendor qualification records.' ;
    rdfs:domain ind:DisposalEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Extraction uses specific kit products. Currently denormalized as extraction_kit_name. Business need: kit lot traceability for regulatory audits, cost-per-extraction calculation for pricing models, inv' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:kitLotId rdf:type rdf:Property ;
    rdfs:label 'Kit Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Extraction uses specific reagent kit lots. Essential for correlating extraction yield/quality with reagent lot performance, investigating out-of-specification results, and maintaining GxP traceability' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:a260A230Ratio rdf:type rdf:Property ;
    rdfs:label 'A260 A230 Ratio' ;
    rdfs:comment 'Absorbance ratio at 260nm and 230nm wavelengths, indicating contamination by organic compounds or chaotropic salts. Expected range is 2.0-2.2 for pure nucleic acid.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:a260A280Ratio rdf:type rdf:Property ;
    rdfs:label 'A260 A280 Ratio' ;
    rdfs:comment 'Absorbance ratio at 260nm and 280nm wavelengths, indicating nucleic acid purity. Pure DNA typically has ratio ~1.8, pure RNA ~2.0. Lower values indicate protein contamination.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:concentrationNgPerUl rdf:type rdf:Property ;
    rdfs:label 'Concentration Ng Per Ul' ;
    rdfs:comment 'Concentration of extracted nucleic acid measured in nanograms per microliter (ng/µL), typically measured by spectrophotometry or fluorometry.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Boolean flag indicating whether contamination was detected during or after extraction (True = contamination detected, False = no contamination).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dv200Percentage rdf:type rdf:Property ;
    rdfs:label 'Dv200 Percentage' ;
    rdfs:comment 'Percentage of RNA fragments greater than 200 nucleotides, used as quality metric for degraded RNA samples (e.g., FFPE). Values >30% are typically acceptable for NGS.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elutionVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Elution Volume Ul' ;
    rdfs:comment 'Final elution volume of the extracted nucleic acid, measured in microliters (µL).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionDate rdf:type rdf:Property ;
    rdfs:label 'Extraction Date' ;
    rdfs:comment 'Date when the nucleic acid extraction was performed, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extractionMethod rdf:type rdf:Property ;
    rdfs:label 'Extraction Method' ;
    rdfs:comment 'The nucleic acid extraction methodology applied to the specimen (e.g., column-based, magnetic bead, phenol-chloroform, manual, automated, salting-out).' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Extraction Timestamp' ;
    rdfs:comment 'Precise timestamp when the extraction process was completed, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inputMassMg rdf:type rdf:Property ;
    rdfs:label 'Input Mass Mg' ;
    rdfs:comment 'Mass of input material used for extraction (applicable for solid tissue specimens), measured in milligrams (mg).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputMaterialType rdf:type rdf:Property ;
    rdfs:label 'Input Material Type' ;
    rdfs:comment 'Type of biological specimen used as input for extraction (e.g., whole blood, plasma, serum, tissue, saliva, buccal swab, urine, cerebrospinal fluid, FFPE, fresh frozen). [ENUM-REF-CANDIDATE: whole_blood|plasma|serum|tissue|saliva|buccal_swab|urine|csf|ffpe|fresh_frozen — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Input Volume Ul' ;
    rdfs:comment 'Volume of input material used for extraction, measured in microliters (µL).' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nucleicAcidType rdf:type rdf:Property ;
    rdfs:label 'Nucleic Acid Type' ;
    rdfs:comment 'Type of nucleic acid extracted: DNA (deoxyribonucleic acid), RNA (ribonucleic acid), cfDNA (cell-free DNA), gDNA (genomic DNA), total nucleic acid, or mRNA (messenger RNA).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantificationMethod rdf:type rdf:Property ;
    rdfs:label 'Quantification Method' ;
    rdfs:comment 'Method used to quantify the extracted nucleic acid (e.g., NanoDrop spectrophotometry, Qubit fluorometry, Bioanalyzer, TapeStation, qPCR, PicoGreen).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Identifier for the batch or run in which this extraction was performed, linking multiple extractions processed together.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalYieldNg rdf:type rdf:Property ;
    rdfs:label 'Total Yield Ng' ;
    rdfs:comment 'Total yield of extracted nucleic acid in nanograms (ng), calculated as concentration multiplied by elution volume.' ;
    rdfs:domain ind:Extraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Assay Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Workflows consume specific assay kits (sequencing reagents, array chips, library prep kits). Business need: protocol compliance verification, cost allocation per sample, inventory consumption tracking' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:nextWorkflowAssignmentLimsWorkflowAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Next Workflow Assignment Lims Workflow Assignment Id' ;
    rdfs:comment 'Reference to the subsequent workflow assignment in a multi-step processing chain. Enables tracking of sequential workflow dependencies where completion of this assignment triggers the next step.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LimsWorkflowAssignment .

ind:primaryLimsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lims Employee Id' ;
    rdfs:comment 'Reference to the laboratory technician or scientist assigned to perform this workflow. Links to workforce record for accountability and workload tracking.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLimsLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Lims Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that last modified this workflow assignment record. System-generated audit field for accountability and compliance tracking.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLimsCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lims Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person or system account that created this workflow assignment record. System-generated audit field for accountability and compliance tracking.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workflowCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Workflow Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Workflow assignments consume labor, reagents, and instrument time charged to specific cost centers. Critical for activity-based costing, variance analysis, and operational expense tracking. Existing c' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:workflowId rdf:type rdf:Property ;
    rdfs:label 'Workflow Id' ;
    rdfs:comment 'Reference to the laboratory workflow or assay protocol definition. Links to the workflow master record defining the procedure steps and requirements.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LimsWorkflow .

ind:workflowReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Workflow Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Workflows (sequencing runs, array processing, qPCR assays) consume specific reagent lots. Critical for cost accounting, correlating assay performance with reagent lot quality, protocol validation stud' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business identifier for the workflow assignment. Format: WFA-YYYYMMDD-XXXXXX where YYYYMMDD is assignment date and XXXXXX is sequential counter.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Expected Duration Hours' ;
    rdfs:comment 'Standard processing time in hours for this workflow type based on Standard Operating Procedure (SOP) specifications. Used for capacity planning and bottleneck identification.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Standardized code indicating why workflow is on-hold. Populated only when workflow_status is on_hold. Enables root cause analysis of processing delays and bottleneck identification.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSection rdf:type rdf:Property ;
    rdfs:label 'Lab Section' ;
    rdfs:comment 'Organizational unit or department within the laboratory responsible for executing this workflow. Enables workload distribution and resource allocation tracking.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Present Flag' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) is associated with this workflow assignment. True for identifiable clinical samples, false for de-identified or Research Use Only (RUO) samples. Drives Health Insurance Portability and Accountability Act (HIPAA) compliance controls.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcComments rdf:type rdf:Property ;
    rdfs:label 'Qc Comments' ;
    rdfs:comment 'Free-text notes from Quality Control (QC) reviewer documenting review findings, deviations, or conditional pass justifications. Required for failed or conditional_pass QC status.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Due Timestamp' ;
    rdfs:comment 'Date and time by which workflow must be completed to meet Service Level Agreement (SLA) commitments. Calculated based on priority level and workflow type Turnaround Time (TAT) standards.' ;
    rdfs:domain ind:LimsWorkflowAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Qc Measurement Id' ;
    rdfs:comment 'Unique identifier for the quality control measurement record. Primary key for the qc_measurement data product.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Measurement Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: QC measurements (Qubit quantification, Bioanalyzer sizing, qPCR validation) use specific reagent/standard lots. Essential for assessing measurement validity, investigating out-of-specification results' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:originalMeasurementQcMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Original Measurement Qc Measurement Id' ;
    rdfs:comment 'Reference to the original QC measurement record if this is a repeat measurement. Enables traceability of repeat testing and comparison of results.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcMeasurement .

ind:qcReagentCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Qc Reagent Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: QC measurements use specific reagent products (Qubit assays, Bioanalyzer chips, TapeStation reagents). Business need: measurement validity verification, reagent lot correlation with QC failures, regul' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:controlSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Control Sample Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement was performed on a control sample (positive control, negative control, or reference standard) rather than a patient or research specimen. True indicates control.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dinScore rdf:type rdf:Property ;
    rdfs:label 'Din Score' ;
    rdfs:comment 'DNA Integrity Number (DIN) score ranging from 1 (highly degraded) to 10 (highly intact). Measured via TapeStation electrophoresis. Assesses genomic DNA fragmentation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentSizeBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Bp' ;
    rdfs:comment 'Average or modal fragment size of nucleic acid measured in base pairs. Determined via electrophoresis (Bioanalyzer, TapeStation, or Fragment Analyzer). Critical for library prep QC.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fragmentSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Distribution' ;
    rdfs:comment 'Textual or encoded representation of the fragment size distribution profile. May include peak positions, distribution shape, or reference to an electropherogram file.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Lims Record Code' ;
    rdfs:comment 'External identifier for this measurement in the source Laboratory Information Management System (LabVantage LIMS). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodFlag rdf:type rdf:Property ;
    rdfs:label 'Lod Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value is below the Limit of Detection (LOD) for the assay. True indicates below LOD. Critical for clinical and research interpretation.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the operator regarding the measurement. May include observations about sample quality, instrument behavior, or deviations from SOP (Standard Operating Procedure).' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle status of the QC measurement. Tracks the measurement from initiation through completion or failure.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'Date and time when the QC measurement was performed. Critical for traceability and TAT (Turnaround Time) tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Type of quality control measurement performed on the specimen. Defines the analytical method used for quality assessment. [ENUM-REF-CANDIDATE: qubit_fluorometry|nanodrop_spectrophotometry|bioanalyzer_electrophoresis|tapestation_electrophoresis|din_score|rin_score|fragment_analyzer|qpcr_quantification|gel_electrophoresis — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Flag' ;
    rdfs:comment 'Boolean indicator of whether the measured value falls within the acceptable reference range. True indicates pass, False indicates fail. Drives pre-analytical QC gating decisions.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatMeasurementFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Measurement Flag' ;
    rdfs:comment 'Boolean indicator of whether this measurement is a repeat or retest of a previous measurement. True indicates repeat. Used for tracking measurement reproducibility and troubleshooting.' ;
    rdfs:domain ind:QcMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assentObtained rdf:type rdf:Property ;
    rdfs:label 'Assent Obtained' ;
    rdfs:comment 'Indicates whether assent was obtained from a minor subject in addition to parental/guardian consent. Applicable for pediatric genomics studies. Required for IRB compliance in pediatric research protocols.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biobankConsent rdf:type rdf:Property ;
    rdfs:label 'Biobank Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to long-term biobanking and storage of their specimen for future unspecified research use. Governs specimen retention policies in LabVantage LIMS.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Method' ;
    rdfs:comment 'Method by which informed consent was obtained and documented. \'paper\' — wet ink signature; \'electronic\' — eConsent platform; \'verbal_with_waiver\' — IRB-approved verbal consent with waiver of written documentation; \'remote_electronic\' — remote eConsent; \'delegated\' — consent delegated to authorized representative.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCollectionSite rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Site' ;
    rdfs:comment 'Name or code of the clinical or research site where informed consent was obtained (e.g., hospital, clinic, research center). Supports multi-site study management and site-level compliance reporting.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNotes rdf:type rdf:Property ;
    rdfs:label 'Consent Notes' ;
    rdfs:comment 'Free-text field for documenting special circumstances, subject questions, deviations from standard consent process, or other relevant observations recorded during the consent encounter. Confidential — not for general access.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationStatus rdf:type rdf:Property ;
    rdfs:label 'Deidentification Status' ;
    rdfs:comment 'Current PHI de-identification status of the specimen and associated data. \'identified\' — PHI present; \'de_identified\' — HIPAA Safe Harbor or Expert Determination method applied; \'limited_dataset\' — HIPAA limited dataset with DUA; \'pseudonymized\' — GDPR pseudonymization applied; \'anonymized\' — irreversibly anonymized.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futureContactConsent rdf:type rdf:Property ;
    rdfs:label 'Future Contact Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to being contacted for future research studies or re-consent requests. Governs subject outreach activities in Salesforce CRM.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentalFindingsConsent rdf:type rdf:Property ;
    rdfs:label 'Incidental Findings Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to disclosure of incidental or secondary genomic findings identified during sequencing or analysis (e.g., ACMG secondary findings). Distinct from primary study results.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterUsed rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used' ;
    rdfs:comment 'Indicates whether a language interpreter was used during the consent process. When true, additional interpreter documentation is required per GCP guidelines.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legallyAuthorizedRepresentative rdf:type rdf:Property ;
    rdfs:label 'Legally Authorized Representative' ;
    rdfs:comment 'Indicates whether consent was obtained from a Legally Authorized Representative (LAR) rather than the subject directly (e.g., for incapacitated adults or minors). Triggers additional documentation requirements.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsConsentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Lims Consent Record Code' ;
    rdfs:comment 'The native consent record identifier assigned by LabVantage LIMS. Enables bidirectional traceability between the Databricks Silver Layer data product and the operational LIMS system of record.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedUseClinical rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Clinical' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen for clinical diagnostic purposes, including In Vitro Diagnostic (IVD) assay validation and Laboratory Developed Test (LDT) workflows under CLIA/CAP.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseCommercial rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Commercial' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen and genomic data for commercial product development, including reagent validation, instrument development, and product commercialization activities.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseDataSharing rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Data Sharing' ;
    rdfs:comment 'Indicates whether the subject has authorized sharing of their de-identified genomic data with external parties, including public genomic databases (e.g., dbGaP, GEO), research consortia, or partner institutions under the NIH Genomic Data Sharing Policy.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUseResearch rdf:type rdf:Property ;
    rdfs:label 'Permitted Use Research' ;
    rdfs:comment 'Indicates whether the subject has authorized use of their specimen and associated genomic data for internal Research and Development (R&D) purposes. Governs bioinformatics pipeline processing and variant analysis workflows.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phiAuthorization rdf:type rdf:Property ;
    rdfs:label 'Phi Authorization' ;
    rdfs:comment 'Indicates whether the subject has provided explicit HIPAA authorization for use and disclosure of their Protected Health Information (PHI) in conjunction with specimen and genomic data processing.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reConsentDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Consent Due Date' ;
    rdfs:comment 'Target date by which re-consent must be obtained from the subject. Null if re-consent is not required. Used to manage compliance timelines and subject outreach scheduling.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required' ;
    rdfs:comment 'Indicates whether a re-consent is required from the subject due to protocol amendments, expanded data use scope, or consent expiry. Triggers re-consent workflow in LabVantage LIMS and MasterControl.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnOfResultsConsent rdf:type rdf:Property ;
    rdfs:label 'Return Of Results Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to receive individual genomic research results or incidental findings. Governs clinical reporting workflows and genetic counseling referral processes.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Code' ;
    rdfs:comment 'The document identifier in Veeva Vault for the executed consent form document. Provides a direct link to the regulatory document management system for audit and inspection readiness.' ;
    rdfs:domain ind:SampleConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSpecimenSampleSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Parent Specimen Sample Specimen Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent specimen from which this specimen was derived (e.g., an aliquot derived from a primary blood draw, or an extracted DNA specimen derived from a tissue biopsy). Enables hierarchical specimen lineage and chain-of-custody traceability.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSpecimen .

ind:processingReagentLotId rdf:type rdf:Property ;
    rdfs:label 'Processing Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Specimens are processed using specific reagent lots for nucleic acid extraction, library preparation, and quality control. Critical for batch effect analysis, regulatory traceability (21 CFR Part 11),' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:aliquotNumber rdf:type rdf:Property ;
    rdfs:label 'Aliquot Number' ;
    rdfs:comment 'Sequential number identifying this specimen as a specific aliquot derived from a parent specimen (e.g., aliquot 3 of 8 from a primary blood draw). Used for inventory management, depletion tracking, and ensuring equitable distribution of limited specimens across assays.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSpecimenCode rdf:type rdf:Property ;
    rdfs:label 'External Specimen Code' ;
    rdfs:comment 'Specimen identifier assigned by the submitting institution, clinic, or partner laboratory prior to receipt at Genomics Biotech. Used for cross-referencing with external Laboratory Information Systems (LIS) and Electronic Medical Records (EMR). May differ from the internal LIMS accession number.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massMg rdf:type rdf:Property ;
    rdfs:label 'Mass Mg' ;
    rdfs:comment 'Mass of the specimen in milligrams (mg) at the time of accessioning or most recent measurement. Applicable to solid specimens (tissue biopsies, FFPE blocks, dried blood spots). Null for liquid specimens where volume_ul is used instead.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Physical matrix or medium in which the specimen is preserved or suspended (e.g., aqueous buffer, FFPE paraffin block, dried blood spot, frozen tissue). Determines storage temperature requirements, extraction chemistry, and analytical method compatibility. [ENUM-REF-CANDIDATE: aqueous|solid|semi-solid|dried|fixed|frozen|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passageCount rdf:type rdf:Property ;
    rdfs:label 'Passage Count' ;
    rdfs:comment 'Number of times the specimen or derived cell line has been sub-cultured or passaged. Relevant for cell-based specimens and primary cultures. Higher passage counts may indicate genomic drift and affect assay validity.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phiDeidentificationTier rdf:type rdf:Property ;
    rdfs:label 'Phi Deidentification Tier' ;
    rdfs:comment 'Specifies the de-identification method applied to this specimen record per HIPAA standards: Safe Harbor (removal of 18 identifiers), Expert Determination (statistical certification), Pseudonymisation (GDPR Article 4(5)), or Identified (PHI present). Drives data access tier controls and downstream sharing permissions.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tumorContentPct rdf:type rdf:Property ;
    rdfs:label 'Tumor Content Pct' ;
    rdfs:comment 'Estimated percentage of tumor cells (neoplastic cellularity) in the specimen as assessed by pathology review. Critical for somatic variant calling sensitivity, LOD (Limit of Detection) calculations, and clinical oncology reporting. Null for non-oncology specimens.' ;
    rdfs:domain ind:SampleSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentManifestId rdf:type rdf:Property ;
    rdfs:label 'Shipment Manifest Id' ;
    rdfs:comment 'Unique surrogate identifier for the shipment manifest record in the Databricks Silver Layer. Primary key. Entity Role: TRANSACTION_HEADER — represents a discrete business event (inter-site or inter-partner specimen transfer) with a clear lifecycle.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Lims Shipment Id' ;
    rdfs:comment 'Native shipment record identifier from LabVantage LIMS, the system of record for sample tracking and laboratory workflow. Enables bidirectional traceability between the Silver Layer data product and the operational LIMS source system.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:originAccountId rdf:type rdf:Property ;
    rdfs:label 'Origin Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Shipments originate from customer sites (return shipments, inter-site transfers). Critical for chain-of-custody documentation, logistics coordination, regulatory compliance, and temperature excursion ' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory chain-of-custody for specimen shipments requires tracking the qualified employee who prepared the manifest. GxP audits and FDA inspections verify personnel qualifications for specimen handl' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Timestamp' ;
    rdfs:comment 'Date and time at which the destination site confirmed physical receipt of the shipment. Closes the chain-of-custody loop and triggers downstream LIMS accessioning workflows. Null until receipt is confirmed.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationSiteCode rdf:type rdf:Property ;
    rdfs:label 'Destination Site Code' ;
    rdfs:comment 'Identifier of the site, laboratory, clinical site, CRO, or biobank that is the intended recipient of the shipment. References the internal site/facility master.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dryIceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dry Ice Weight Kg' ;
    rdfs:comment 'Weight of dry ice (solid CO2) in kilograms included in the shipment packaging. Required for IATA Dangerous Goods Regulations compliance declarations when dry ice is used as a refrigerant (UN 1845). Applicable only when packaging_type = \'dry_ice\'.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned calendar date by which the shipment is expected to arrive at the destination site. Used for SLA monitoring, lab scheduling, and proactive exception management when shipments are delayed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:importExportPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Export Permit Number' ;
    rdfs:comment 'Government-issued permit or license number required for cross-border shipment of biological specimens, GMOs, or controlled substances. Supports regulatory compliance for international transfers under CITES, CDC/USDA select agent regulations, or national biosafety authorities.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-known, human-readable manifest reference number assigned at the time of shipment creation (e.g., SM-2024-000123). Used for chain-of-custody documentation, regulatory submissions, and cross-site reconciliation. Sourced from LabVantage LIMS shipment module. BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle state of the shipment manifest. \'draft\' = manifest created but not yet dispatched; \'in_transit\' = carrier has collected and shipment is en route; \'delivered\' = receipt confirmed at destination; \'cancelled\' = shipment voided before dispatch; \'exception\' = shipment flagged for temperature deviation, loss, or damage. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country from which the shipment originates (e.g., USA, GBR, DEU). Required for import/export regulatory compliance and customs documentation.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSiteCode rdf:type rdf:Property ;
    rdfs:label 'Origin Site Code' ;
    rdfs:comment 'Identifier of the site, laboratory, or facility from which the specimens are dispatched. References the internal site/facility master. Used for inter-site chain-of-custody and import/export compliance.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptCondition rdf:type rdf:Property ;
    rdfs:label 'Receipt Condition' ;
    rdfs:comment 'Assessment of the shipment condition recorded by the receiving laboratory upon physical receipt. \'acceptable\' = specimens received in satisfactory condition; \'compromised\' = packaging or specimen integrity concerns noted; \'rejected\' = shipment rejected and returned; \'pending_review\' = condition under investigation. Drives specimen disposition workflow in LabVantage LIMS.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Notes' ;
    rdfs:comment 'Free-text notes recorded by the receiving laboratory at the time of receipt, documenting any observed discrepancies, packaging damage, specimen count mismatches, or temperature excursion details. Supports non-conformance investigation and regulatory reporting.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedBy rdf:type rdf:Property ;
    rdfs:label 'Received By' ;
    rdfs:comment 'Name or employee identifier of the laboratory staff member who confirmed receipt of the shipment at the destination site. Required for chain-of-custody documentation and GxP audit trails.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDirection rdf:type rdf:Property ;
    rdfs:label 'Shipment Direction' ;
    rdfs:comment 'Indicates whether the shipment is outbound (specimens leaving the originating site) or inbound (specimens arriving at the receiving site). Drives chain-of-custody workflow and import/export regulatory compliance checks.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classifies the purpose of the shipment. \'clinical\' = patient specimens for diagnostic or clinical trial use; \'research\' = RUO specimens; \'qc\' = Quality Control reference materials; \'biobank_transfer\' = long-term storage transfer; \'cro_transfer\' = transfer to/from a Contract Research Organization. Drives regulatory handling requirements and IRB consent validation.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Calendar date on which the shipment was physically dispatched by the originating site and collected by the carrier. BUSINESS_EVENT_TIMESTAMP category (date-level precision for manifest planning and SLA tracking).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the shipment was handed over to the carrier. Provides exact chain-of-custody event time for regulatory audit trails and temperature excursion analysis.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specimenCount rdf:type rdf:Property ;
    rdfs:label 'Specimen Count' ;
    rdfs:comment 'Total number of individual specimens or aliquots included in this shipment manifest. Used for receipt reconciliation and chain-of-custody verification at the destination site. QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tempExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temp Excursion Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion (deviation outside the validated acceptable range) was detected during transit. True = excursion detected; False = no excursion. Triggers specimen integrity review and potential quarantine workflow in LabVantage LIMS.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tempMaxC rdf:type rdf:Property ;
    rdfs:label 'Temp Max C' ;
    rdfs:comment 'Maximum temperature recorded by the temperature monitoring device during transit, in degrees Celsius. Used to assess cold-chain integrity and determine whether specimens experienced a temperature excursion above the acceptable range.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMinC rdf:type rdf:Property ;
    rdfs:label 'Temp Min C' ;
    rdfs:comment 'Minimum temperature recorded by the temperature monitoring device during transit, in degrees Celsius. Used to assess cold-chain integrity and determine whether specimens experienced a temperature excursion below the acceptable range.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tempMonitorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Temp Monitor Device Code' ;
    rdfs:comment 'Unique identifier of the temperature monitoring device (e.g., data logger, indicator strip, or IoT sensor) placed inside the shipment packaging. Used to retrieve temperature excursion records and validate specimen integrity upon receipt.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageEventId rdf:type rdf:Property ;
    rdfs:label 'Storage Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each storage state change or custody transfer event record in the chain-of-custody audit trail. Primary key of the storage_event product.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Biobank Location Id' ;
    rdfs:comment 'Reference to the storage location (freezer, rack, shelf, box, or position) to which the specimen or aliquot was moved or placed. Null for disposal or external transfer events where no internal destination exists.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:primaryStorageBiobankLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Biobank Location Id' ;
    rdfs:comment 'Reference to the storage location (freezer, rack, shelf, box, or position) from which the specimen or aliquot was retrieved or transferred. Null for initial placement events where no prior location exists.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BiobankLocation .

ind:primaryStorageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Storage Employee Id' ;
    rdfs:comment 'Reference to the laboratory operator or technician who physically performed the storage event (placement, retrieval, relocation, or transfer). Sourced from Oracle Cloud HCM workforce records and LabVantage LIMS user registry.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryStorageAcknowledgedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Storage Acknowledged By Employee Id' ;
    rdfs:comment 'Reference to the user who provided the electronic acknowledgment or e-signature for this storage event. May differ from the operator who performed the physical action, supporting dual-control and supervisory sign-off workflows required under GxP.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Timestamp' ;
    rdfs:comment 'Date and time at which the electronic acknowledgment or e-signature was applied to this storage event record. Distinct from the event_timestamp (when the physical action occurred). Required for FDA 21 CFR Part 11 audit trail completeness.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chainOfCustodySequence rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Sequence' ;
    rdfs:comment 'Monotonically increasing integer representing the ordinal position of this storage event within the complete chain-of-custody history for the specimen or aliquot. Enables ordered reconstruction of the full custody timeline for forensic genomics, legal, and regulatory audit purposes.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerBarcode rdf:type rdf:Property ;
    rdfs:label 'Container Barcode' ;
    rdfs:comment 'The barcode or 2D matrix code printed on the physical container (tube, vial, plate, cryovial) holding the specimen or aliquot at the time of this storage event. Scanned by the operator during the event to confirm physical identity and prevent sample mix-up errors.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the storage event has received a valid electronic acknowledgment (e-signature) from the responsible operator or custodian in compliance with FDA 21 CFR Part 11 electronic records requirements. True confirms the event is electronically signed and locked.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this storage event, formatted as SE-{YYYY}-{YYYYMMDD}-{sequence}. Used in audit reports, chain-of-custody documentation, and regulatory submissions to uniquely reference a specific custody transfer or placement event.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSiteName rdf:type rdf:Property ;
    rdfs:label 'External Site Name' ;
    rdfs:comment 'Name of the external facility, partner laboratory, or clinical site to which the specimen or aliquot was transferred during an inter-site or external transfer event. Populated only for event_type = external_transfer. Supports chain-of-custody documentation for multi-site genomics studies.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTransferTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'External Transfer Tracking Number' ;
    rdfs:comment 'Shipping or courier tracking number associated with an external specimen transfer event. Enables end-to-end shipment traceability for specimens transferred to external sites, partner labs, or clinical collaborators. Populated only for event_type = external_transfer.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCycleCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Cycle Count' ;
    rdfs:comment 'Cumulative number of freeze-thaw cycles the specimen or aliquot has undergone up to and including this storage event. Excessive freeze-thaw cycles degrade nucleic acid and protein integrity; this count is critical for sample quality assessment in genomic and clinical workflows.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isImmutable rdf:type rdf:Property ;
    rdfs:label 'Is Immutable' ;
    rdfs:comment 'Indicates whether this storage event record has been locked and made immutable following electronic acknowledgment and audit finalization. Immutable records cannot be modified or deleted, satisfying FDA 21 CFR Part 11 and GxP requirements for tamper-evident audit trails.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsEventReference rdf:type rdf:Property ;
    rdfs:label 'Lims Event Reference' ;
    rdfs:comment 'The native event or transaction identifier assigned by LabVantage LIMS for this storage event. Enables bidirectional traceability between the Databricks Silver Layer data product and the operational LIMS system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Max C' ;
    rdfs:comment 'The maximum acceptable storage temperature in degrees Celsius for the specimen or aliquot type involved in this event, as defined by the applicable SOP or specimen handling protocol. Used in conjunction with required_temp_min_c to define the acceptable temperature window.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredTempMinC rdf:type rdf:Property ;
    rdfs:label 'Required Temp Min C' ;
    rdfs:comment 'The minimum acceptable storage temperature in degrees Celsius for the specimen or aliquot type involved in this event, as defined by the applicable SOP or specimen handling protocol. Used to evaluate whether a temperature excursion occurred.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specimenVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Specimen Volume Ul' ;
    rdfs:comment 'Volume of the specimen or aliquot in microliters (µL) at the time of this storage event. Captured to track volume consumption across retrieval events and to flag low-volume specimens that may be insufficient for planned assays.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureAtEventC rdf:type rdf:Property ;
    rdfs:label 'Temperature At Event C' ;
    rdfs:comment 'Recorded ambient or storage unit temperature in degrees Celsius at the time of the storage event. Captured from connected monitoring systems or manually entered by the operator. Used to assess sample integrity and document temperature excursion conditions.' ;
    rdfs:domain ind:StorageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageAtEnrollment rdf:type rdf:Property ;
    rdfs:label 'Age At Enrollment' ;
    rdfs:comment 'Age of the subject in whole years at the time of study enrollment, derived from year_of_birth and enrollment_date at data ingestion. Stored as a pre-computed integer to support cohort age-stratification queries without requiring DOB. Enables pediatric vs. adult cohort segmentation and age-related genomic analyses.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancestryGroup rdf:type rdf:Property ;
    rdfs:label 'Ancestry Group' ;
    rdfs:comment 'Self-reported or genetically inferred ancestry/ethnicity group of the subject, used for population genomics stratification, Minor Allele Frequency (MAF) reference panel selection, and pharmacogenomics analyses. Stored as a controlled vocabulary term aligned with gnomAD and 1000 Genomes Project population labels. [ENUM-REF-CANDIDATE: AFR|AMR|EAS|EUR|MID|SAS|ASH|LAT|OTH — promote to reference product]' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCountry rdf:type rdf:Property ;
    rdfs:label 'Collection Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the subject\'s specimens were collected. Drives GDPR data residency requirements, export control compliance for genomic data, and population genomics geographic stratification.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRecordId rdf:type rdf:Property ;
    rdfs:label 'Consent Record Id' ;
    rdfs:comment 'Reference to the IRB-approved informed consent record governing the permissible uses of this subject\'s biological specimens and genomic data. Managed in the access-controlled consent management system (separate from this de-identified record). Enables traceability of data use to specific consent scope without embedding PHI in this product.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deidentificationTier rdf:type rdf:Property ;
    rdfs:label 'Deidentification Tier' ;
    rdfs:comment 'Classification of the subject record\'s de-identification level per HIPAA and GDPR frameworks. Fully de-identified records have no re-identification pathway; pseudonymized records retain a coded linkage to PHI managed separately; limited dataset records retain certain geographic and date information under a data use agreement (DUA). Governs permissible downstream data uses and sharing.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseIndication rdf:type rdf:Property ;
    rdfs:label 'Disease Indication' ;
    rdfs:comment 'Primary disease indication or phenotype associated with the subject, encoded using a standardized ontology term (e.g., ICD-10, OMIM, HPO). Drives cohort assembly for clinical genomics studies, variant interpretation in clinical assay workflows, and regulatory submission stratification. Free-text or ontology code depending on study protocol.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseIndicationOntology rdf:type rdf:Property ;
    rdfs:label 'Disease Indication Ontology' ;
    rdfs:comment 'Ontology or coding system used to encode the disease_indication field (e.g., ICD-10, OMIM, HPO, SNOMED-CT). Enables interoperability across clinical, research, and regulatory systems and ensures consistent variant interpretation and cohort queries.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyRelationship rdf:type rdf:Property ;
    rdfs:label 'Family Relationship' ;
    rdfs:comment 'Role of this subject within the family pedigree identified by family_id. Used for trio-based variant calling, de novo mutation detection, and inheritance pattern analysis in WGS/WES (Whole Exome Sequencing) workflows. Null for unrelated subjects.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicDataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Genomic Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the subject has provided explicit consent for their genomic data to be shared with external repositories (e.g., dbGaP, EGA, UK Biobank). Required for NIH Genomic Data Sharing Policy compliance and international data sharing agreements. When False, data must not be submitted to public or controlled-access repositories.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable' ;
    rdfs:comment 'Indicates whether HIPAA Privacy Rule applies to this subject\'s data, based on whether the subject is a US patient or the data is held by a HIPAA-covered entity or business associate. When True, PHI handling, minimum necessary standard, and de-identification requirements apply.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsSubjectCode rdf:type rdf:Property ;
    rdfs:label 'Lims Subject Code' ;
    rdfs:comment 'Native subject identifier assigned by LabVantage LIMS at the time of accessioning. Used for cross-system traceability between the Databricks Silver Layer data product and the operational LIMS workflow. Enables reconciliation and lineage tracking back to the system of record.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiLinkageAvailable rdf:type rdf:Property ;
    rdfs:label 'Phi Linkage Available' ;
    rdfs:comment 'Indicates whether a PHI linkage record exists for this subject in the access-controlled consent and identity management system. When True, the subject_code can be re-linked to direct PHI by authorized personnel only. When False, the record is fully de-identified with no re-linkage pathway. Supports HIPAA Safe Harbor compliance auditing.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAssayType rdf:type rdf:Property ;
    rdfs:label 'Primary Assay Type' ;
    rdfs:comment 'The primary genomic assay type intended or performed for this subject\'s specimens. Drives bioinformatics pipeline selection, QC (Quality Control) metric thresholds, and data product routing. WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), targeted panel, SNP (Single Nucleotide Polymorphism) array, RNA-seq, and methylation array are the principal assay categories. [ENUM-REF-CANDIDATE: WGS|WES|targeted_panel|SNP_array|RNA_seq|methylation_array|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recontactConsent rdf:type rdf:Property ;
    rdfs:label 'Recontact Consent' ;
    rdfs:comment 'Indicates whether the subject has consented to being re-contacted for additional studies, incidental findings disclosure, or updated consent. Relevant for longitudinal genomics studies and return-of-results workflows. When False, no re-contact is permitted without a new consent process.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Monotonically incrementing version number for the subject record, incremented on each update. Supports optimistic concurrency control, SCD Type 2 history tracking, and GxP audit trail requirements for regulated genomics data. Version 1 represents the initial record creation.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reidentificationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Reidentification Risk Level' ;
    rdfs:comment 'Assessed risk level that the subject record could be re-linked to a specific individual, based on the de-identification method applied and residual quasi-identifiers present (e.g., rare disease, small geographic area, unusual ancestry). Determined by the privacy officer or expert determination process. Drives data access controls, sharing restrictions, and consent re-contact requirements.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCode rdf:type rdf:Property ;
    rdfs:label 'Subject Code' ;
    rdfs:comment 'Externally-known, de-identified alphanumeric code assigned to the subject at accessioning or enrollment. Used as the operational identifier across LIMS, bioinformatics pipelines, and clinical reports without exposing direct PHI. Equivalent to the participant ID or pseudonym in study documentation.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the biological source individual by their role in the study or clinical workflow. Drives consent requirements, regulatory handling, and data access controls. Research participants and patients require IRB/ethics board oversight; animal models require IACUC approval.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearOfBirth rdf:type rdf:Property ;
    rdfs:label 'Year Of Birth' ;
    rdfs:comment 'Four-digit birth year of the subject. Stored instead of full date of birth (DOB) to comply with HIPAA Safe Harbor de-identification requirements (45 CFR §164.514(b)(2)(i)), which prohibit retention of specific birth dates. Enables age-range calculations and cohort age-stratification for population genomics without re-identification risk.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureExcursionId rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Id' ;
    rdfs:comment 'Unique surrogate identifier for each temperature excursion event record in the Genomics Biotech cold-chain monitoring system. Primary key for this entity. Entity role: TRANSACTION_HEADER — a discrete GxP cold-chain compliance event with a clear lifecycle (detected, assessed, dispositioned, closed).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Disposition Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Temperature excursion disposition decisions (use/quarantine/discard specimens) require documented approval by qualified personnel with appropriate training and authority. Critical for GxP compliance, ' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedSampleType rdf:type rdf:Property ;
    rdfs:label 'Affected Sample Type' ;
    rdfs:comment 'Predominant biological specimen type(s) affected by the excursion (e.g., whole blood, plasma, FFPE tissue, DNA extract, RNA extract, cell line). Informs the biological stability risk assessment since different specimen types have different thermal sensitivity profiles. Free text to accommodate diverse specimen types. [ENUM-REF-CANDIDATE: whole_blood|plasma|serum|dna_extract|rna_extract|ffpe_tissue|cell_line|urine|csf — promote to reference product]' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSpecimenCount rdf:type rdf:Property ;
    rdfs:label 'Affected Specimen Count' ;
    rdfs:comment 'Total number of individual biological specimens (samples, aliquots, tubes) present in the affected storage location or shipment at the time of the excursion. Used for impact scope assessment, risk quantification, and regulatory reporting. Populated during impact assessment phase.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Notification Timestamp' ;
    rdfs:comment 'Timestamp at which the automated alert notification was sent to responsible personnel (lab manager, QA, on-call staff) following excursion detection. Used to measure response time and assess SLA compliance for cold-chain incident response. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Timestamp at which the temperature excursion record was formally closed in the quality management system, indicating all required actions (impact assessment, disposition, CAPA initiation if required) have been completed and reviewed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the immediate corrective action taken in response to the excursion (e.g., specimens transferred to backup freezer, equipment serviced, power restored, dry ice added). Distinct from the formal CAPA; captures the real-time remediation steps.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'The real-world timestamp at which the temperature excursion was first detected by the monitoring device or alert system. This is the principal business event time for the excursion. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationReportNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Report Number' ;
    rdfs:comment 'Reference number of the formal deviation report filed in the quality management system (Veeva Vault or MasterControl) documenting this temperature excursion. Required for GxP compliance, regulatory inspection readiness, and quality trending.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionRationale rdf:type rdf:Property ;
    rdfs:label 'Disposition Rationale' ;
    rdfs:comment 'Scientific and regulatory justification for the disposition decision, including reference to stability data, specimen type thermal sensitivity, excursion magnitude, and duration. Required for GxP audit trail and regulatory submission support.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Timestamp at which the formal disposition decision was made and recorded by the authorized reviewer. Establishes the timeline for regulatory audit purposes and tracks TAT (Turnaround Time) for excursion resolution. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionCategory rdf:type rdf:Property ;
    rdfs:label 'Excursion Category' ;
    rdfs:comment 'Severity classification of the excursion based on magnitude and duration relative to defined thresholds. Drives escalation protocols, CAPA requirements, and regulatory notification obligations. Minor: within acceptable tolerance; Critical: significant risk to specimen integrity.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion End Timestamp' ;
    rdfs:comment 'Timestamp at which the temperature returned within the acceptable range, marking the end of the excursion event. Null if the excursion is still ongoing. Used together with excursion_start_timestamp to determine total duration. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionNumber rdf:type rdf:Property ;
    rdfs:label 'Excursion Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the excursion event (e.g., EXC-2024-000123). Used in deviation reports, CAPA records, regulatory submissions, and customer communications. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionSource rdf:type rdf:Property ;
    rdfs:label 'Excursion Source' ;
    rdfs:comment 'The source or mechanism by which the temperature excursion was detected. Automated monitor: continuous monitoring system alarm; Manual check: discovered during routine temperature log review; Shipment logger: data logger downloaded upon receipt; IoT sensor: real-time IoT platform alert; Third-party courier: reported by logistics provider.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion Start Timestamp' ;
    rdfs:comment 'Timestamp at which the temperature first breached the defined alert threshold, marking the beginning of the excursion event. Used to calculate excursion duration and assess cumulative thermal exposure. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionStatus rdf:type rdf:Property ;
    rdfs:label 'Excursion Status' ;
    rdfs:comment 'Current lifecycle state of the temperature excursion event workflow. Progresses from initial detection through impact assessment and disposition decision to closure. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionType rdf:type rdf:Property ;
    rdfs:label 'Excursion Type' ;
    rdfs:comment 'Classification of the excursion by the nature of the temperature deviation. High temperature indicates warming above upper threshold; low temperature indicates cooling below lower threshold; freeze-thaw indicates unintended freeze/thaw cycle; rapid change indicates rate-of-change violation; prolonged drift indicates slow sustained deviation.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsExcursionRef rdf:type rdf:Property ;
    rdfs:label 'Lims Excursion Ref' ;
    rdfs:comment 'The source system reference identifier for this excursion record as assigned by LabVantage LIMS. Enables bidirectional traceability between the Databricks Silver Layer analytical record and the operational LIMS source of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerThresholdC rdf:type rdf:Property ;
    rdfs:label 'Lower Threshold C' ;
    rdfs:comment 'The lower temperature alert threshold configured on the monitoring device at the time of the excursion, expressed in degrees Celsius. Documents the threshold that was breached to trigger the excursion alert. Essential for audit trail and regulatory review.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Max Temperature C' ;
    rdfs:comment 'The highest temperature value recorded by the monitoring device during the excursion event, expressed in degrees Celsius. Critical for assessing heat degradation risk for biological specimens, nucleic acids, and reagents. Used in impact assessment and disposition decision logic. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Mean Temperature C' ;
    rdfs:comment 'The mean kinetic temperature (MKT) recorded during the excursion period, expressed in degrees Celsius. MKT is the single calculated temperature that, if maintained constantly, would produce the same thermal degradation as the actual variable temperature conditions experienced. Used in pharmaceutical and biological specimen stability assessments per ICH Q1A.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Min Temperature C' ;
    rdfs:comment 'The lowest temperature value recorded by the monitoring device during the excursion event, expressed in degrees Celsius. Critical for assessing freeze risk for biological specimens and reagents. Used in impact assessment and disposition decision logic.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Device Code' ;
    rdfs:comment 'Unique identifier of the temperature monitoring device (data logger, IoT sensor, continuous monitoring system) that recorded the excursion. Used for equipment traceability, calibration verification, and audit trail. Maps to the instrument/device asset register.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorExcursionNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Excursion Number' ;
    rdfs:comment 'The excursion_number of the most recent prior excursion at the same location or device, populated when recurrence_flag is True. Enables trend analysis and supports CAPA root cause investigation by linking related excursion events.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this excursion is a recurrence of a previously documented excursion at the same storage location or on the same monitoring device within a defined lookback period. Recurrent excursions trigger mandatory CAPA escalation and may indicate systemic equipment or process failure.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditionRequired rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Required' ;
    rdfs:comment 'The required storage temperature condition for the affected specimens or materials at the time of the excursion. Provides context for assessing the severity of the deviation relative to the required storage specification.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Threshold Breached' ;
    rdfs:comment 'Indicates which configured alert threshold was breached during the excursion: upper threshold (overheating), lower threshold (overcooling/freeze), or both (e.g., during a freeze-thaw cycle). Drives the type of impact assessment required.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperThresholdC rdf:type rdf:Property ;
    rdfs:label 'Upper Threshold C' ;
    rdfs:comment 'The upper temperature alert threshold configured on the monitoring device at the time of the excursion, expressed in degrees Celsius. Documents the threshold that was breached to trigger the excursion alert. Essential for audit trail and regulatory review.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrayCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Array Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Array chips are catalog items with SKUs, lot numbers, and regulatory classifications. Critical for procurement, cost-per-sample tracking, regulatory traceability, and compatibility validation with sca' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:arrayTypeId rdf:type rdf:Property ;
    rdfs:label 'Array Type Id' ;
    rdfs:comment 'Reference to the specific array product type used in this hybridization run (SNP array, methylation array, CGH array, expression array).' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArrayType .

ind:analysisSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Analysis Software Version' ;
    rdfs:comment 'Version of the bioinformatics software used for initial quality control and genotype calling from raw intensity data.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrayBarcode rdf:type rdf:Property ;
    rdfs:label 'Array Barcode' ;
    rdfs:comment 'Unique barcode or serial number printed on the physical array chip used in this hybridization run.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrayPosition rdf:type rdf:Property ;
    rdfs:label 'Array Position' ;
    rdfs:comment 'Position or well location on the array plate or chip where the sample was loaded (e.g., R01C01 for row 1 column 1).' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundIntensity rdf:type rdf:Property ;
    rdfs:label 'Background Intensity' ;
    rdfs:comment 'Average background fluorescence intensity measured in non-probe regions of the array, used to assess signal-to-noise ratio.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callRatePercent rdf:type rdf:Property ;
    rdfs:label 'Call Rate Percent' ;
    rdfs:comment 'Percentage of probes on the array that produced a valid genotype or methylation call, indicating data completeness.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hybridizationDurationHours rdf:type rdf:Property ;
    rdfs:label 'Hybridization Duration Hours' ;
    rdfs:comment 'Total duration in hours that the sample was incubated on the array during the hybridization process.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hybridizationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hybridization End Timestamp' ;
    rdfs:comment 'Date and time when the array hybridization process was completed and the array was ready for scanning.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hybridizationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hybridization Start Timestamp' ;
    rdfs:comment 'Date and time when the array hybridization process was initiated in the laboratory.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hybridizationStatus rdf:type rdf:Property ;
    rdfs:label 'Hybridization Status' ;
    rdfs:comment 'Current lifecycle status of the array hybridization run in the laboratory workflow. [ENUM-REF-CANDIDATE: pending|in_progress|completed|failed|aborted|qc_review|approved|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hybridizationTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Hybridization Temperature C' ;
    rdfs:comment 'Temperature in degrees Celsius at which the array hybridization was performed, critical for assay reproducibility.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputDnaMassNg rdf:type rdf:Property ;
    rdfs:label 'Input Dna Mass Ng' ;
    rdfs:comment 'Total mass of DNA in nanograms used as input for the array hybridization reaction.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsRunCode rdf:type rdf:Property ;
    rdfs:label 'Lims Run Code' ;
    rdfs:comment 'External identifier for this array hybridization run in the Laboratory Information Management System (LIMS) for cross-system traceability.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanSignalIntensity rdf:type rdf:Property ;
    rdfs:label 'Mean Signal Intensity' ;
    rdfs:comment 'Average fluorescence signal intensity across all probes on the array, used as a quality metric.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:probeCount rdf:type rdf:Property ;
    rdfs:label 'Probe Count' ;
    rdfs:comment 'Total number of probes present on the array chip used in this hybridization run.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rawDataFileFormat rdf:type rdf:Property ;
    rdfs:label 'Raw Data File Format' ;
    rdfs:comment 'File format of the raw intensity data output from the array scanner (e.g., IDAT for Illumina, CEL for Affymetrix).' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawDataFilePath rdf:type rdf:Property ;
    rdfs:label 'Raw Data File Path' ;
    rdfs:comment 'File system path or cloud storage location where the raw intensity data (IDAT or CEL files) from the array scan is stored.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawDataFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Raw Data File Size Mb' ;
    rdfs:comment 'Size of the raw intensity data file in megabytes, used for storage planning and data transfer tracking.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runName rdf:type rdf:Property ;
    rdfs:label 'Run Name' ;
    rdfs:comment 'Descriptive name assigned to the array hybridization run for easy identification and reporting purposes.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleConcentrationNgUl rdf:type rdf:Property ;
    rdfs:label 'Sample Concentration Ng Ul' ;
    rdfs:comment 'Concentration of nucleic acid sample in nanograms per microliter prior to loading on the array.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Ul' ;
    rdfs:comment 'Volume of sample in microliters loaded onto the array for hybridization.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'Date and time when the hybridized array was scanned to capture raw intensity data.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scannerSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Scanner Software Version' ;
    rdfs:comment 'Version of the scanner control software used to capture the array image and generate raw intensity data.' ;
    rdfs:domain ind:ArrayHybridization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basecallModelId rdf:type rdf:Property ;
    rdfs:label 'Basecall Model Id' ;
    rdfs:comment 'Unique identifier for the basecalling algorithm model record. Primary key.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BasecallModel .

ind:softwareCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Software Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Basecalling software is a licensable product catalog item. Needed for license entitlement management, version control, regulatory validation documentation, and tracking which software SKU/version is a' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:supersededByModelBasecallModelId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Model Basecall Model Id' ;
    rdfs:comment 'Reference to the newer basecalling model that supersedes this version.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BasecallModel .

ind:algorithmType rdf:type rdf:Property ;
    rdfs:label 'Algorithm Type' ;
    rdfs:comment 'Classification of the underlying algorithm approach used for basecalling (e.g., neural network, machine learning, statistical).' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceIvdCertified rdf:type rdf:Property ;
    rdfs:label 'Ce Ivd Certified' ;
    rdfs:comment 'Indicates whether the basecalling model has received CE-IVD certification for use in the European Union.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compatibleChemistryVersions rdf:type rdf:Property ;
    rdfs:label 'Compatible Chemistry Versions' ;
    rdfs:comment 'Comma-separated list of sequencing chemistry versions supported by this basecalling model.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleInstrumentPlatforms rdf:type rdf:Property ;
    rdfs:label 'Compatible Instrument Platforms' ;
    rdfs:comment 'Comma-separated list of sequencing instrument platforms compatible with this basecalling model (e.g., NovaSeq, MiSeq, NextSeq).' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationalRequirements rdf:type rdf:Property ;
    rdfs:label 'Computational Requirements' ;
    rdfs:comment 'Description of computational resources required to run this basecalling model (CPU, GPU, memory, storage).' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developerOrganization rdf:type rdf:Property ;
    rdfs:label 'Developer Organization' ;
    rdfs:comment 'Name of the organization or company that developed the basecalling model.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaCleared rdf:type rdf:Property ;
    rdfs:label 'Fda Cleared' ;
    rdfs:comment 'Indicates whether the basecalling model has received FDA clearance or approval for clinical use in the United States.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpuAccelerated rdf:type rdf:Property ;
    rdfs:label 'Gpu Accelerated' ;
    rdfs:comment 'Indicates whether the basecalling model utilizes GPU acceleration for improved processing speed.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gxp Compliant' ;
    rdfs:comment 'Indicates whether the basecalling model has been developed and validated under Good Practice regulations (GMP, GLP, GCP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanPhredScore rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score' ;
    rdfs:comment 'Average Phred quality score produced by this basecalling model, indicating the confidence level of base calls.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Unique business identifier code for the basecalling model used in operational systems and documentation.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name of the basecalling algorithm model.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingSpeedGbPerHour rdf:type rdf:Property ;
    rdfs:label 'Processing Speed Gb Per Hour' ;
    rdfs:comment 'Throughput speed of the basecalling model measured in gigabases processed per hour.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:q30Percent rdf:type rdf:Property ;
    rdfs:label 'Q30 Percent' ;
    rdfs:comment 'Percentage of bases called with Phred quality score of 30 or higher (99.9% accuracy) by this model.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportsRealTimeBasecalling rdf:type rdf:Property ;
    rdfs:label 'Supports Real Time Basecalling' ;
    rdfs:comment 'Indicates whether the basecalling model can perform real-time basecalling during sequencing runs.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDatasetDescription rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Description' ;
    rdfs:comment 'Description of the dataset used to train the basecalling model, including sample types and sequencing conditions.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDatasetSizeGb rdf:type rdf:Property ;
    rdfs:label 'Training Dataset Size Gb' ;
    rdfs:comment 'Size of the training dataset in gigabytes used to develop the basecalling model.' ;
    rdfs:domain ind:BasecallModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStatId rdf:type rdf:Property ;
    rdfs:label 'Coverage Stat Id' ;
    rdfs:comment 'Unique surrogate identifier for each coverage statistic record computed post-demultiplexing for a sequencing library. Primary key for the coverage_stat data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedForAnalysis rdf:type rdf:Property ;
    rdfs:label 'Approved For Analysis' ;
    rdfs:comment 'Indicates whether this library\'s coverage statistics have been reviewed and approved for downstream bioinformatics analysis (variant calling, annotation). Set to True only when qc_status is Pass and any required manual review has been completed.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computed Timestamp' ;
    rdfs:comment 'Date and time when the coverage statistics were computed by the bioinformatics pipeline post-demultiplexing. Represents the principal business event timestamp for this record. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:duplicationRatePct rdf:type rdf:Property ;
    rdfs:label 'Duplication Rate Pct' ;
    rdfs:comment 'Percentage of mapped reads identified as PCR or optical duplicates. High duplication rates reduce effective coverage depth and can introduce variant calling artifacts. Computed by duplicate-marking tools (e.g., Picard MarkDuplicates) during bioinformatics processing.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcBiasMetric rdf:type rdf:Property ;
    rdfs:label 'Gc Bias Metric' ;
    rdfs:comment 'Quantitative measure of GC content bias in coverage distribution, typically expressed as the normalized coverage deviation across GC content bins. Values near zero indicate minimal GC bias; large deviations indicate systematic under- or over-representation of GC-rich or GC-poor regions.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertSizeMeanBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Mean Bp' ;
    rdfs:comment 'Mean insert size of the sequencing library in base pairs (bp). Reflects the average length of the DNA fragment between adapter sequences. Deviations from expected insert size indicate library preparation issues affecting coverage uniformity and read alignment.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Median Coverage Depth' ;
    rdfs:comment 'Median number of times each base in the target region is sequenced, expressed in fold-coverage (X). Less sensitive to outlier regions than mean coverage; used alongside mean to assess coverage distribution skewness.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCoverageThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Coverage Threshold' ;
    rdfs:comment 'Assay-specific minimum mean coverage depth threshold (in X) that must be met for the library to pass QC. Defined in the assay specification and used to evaluate the qc_status determination. Varies by assay type (e.g., 30X for clinical WGS, 100X for somatic oncology panels).' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPctBasesThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Pct Bases Threshold' ;
    rdfs:comment 'Assay-specific minimum percentage of target bases that must achieve the defined coverage depth threshold (e.g., ≥95% of bases at ≥20X) for the library to pass QC. Defined in the assay specification document.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTargetRatePct rdf:type rdf:Property ;
    rdfs:label 'On Target Rate Pct' ;
    rdfs:comment 'Percentage of aligned reads that map to the intended target region (capture panel or amplicon targets). Applicable for WES and targeted sequencing assays. Low on-target rate indicates poor hybridization capture efficiency or library quality issues.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt100x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 100x' ;
    rdfs:comment 'Fraction of target bases (expressed as a percentage) achieving a minimum coverage depth of 100X. Relevant for somatic variant calling in oncology panels where high depth is required to detect low-frequency variants (low LOD applications).' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt10x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 10x' ;
    rdfs:comment 'Fraction of target bases (expressed as a percentage) achieving a minimum coverage depth of 10X. Standard threshold for variant calling sensitivity in WES and targeted sequencing panels.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt20x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 20x' ;
    rdfs:comment 'Fraction of target bases (expressed as a percentage) achieving a minimum coverage depth of 20X. Common minimum threshold for clinical-grade variant calling in WES and targeted panels per CAP and CLIA guidelines.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAt30x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases At 30x' ;
    rdfs:comment 'Fraction of target bases (expressed as a percentage) achieving a minimum coverage depth of 30X. Recommended threshold for high-confidence germline variant calling in clinical WGS and WES workflows.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceGenomeVersion rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Version' ;
    rdfs:comment 'Version of the reference genome used for read alignment and coverage computation (e.g., GRCh38, GRCh37/hg19, GRCm39). Critical for reproducibility and cross-sample comparability of coverage statistics. Must match the reference used in downstream variant calling pipelines.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resequencingRequired rdf:type rdf:Property ;
    rdfs:label 'Resequencing Required' ;
    rdfs:comment 'Indicates whether this library has been flagged for resequencing due to insufficient coverage or QC failure. When True, the library must be re-run on the sequencer before downstream bioinformatics analysis can proceed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statIdentifier rdf:type rdf:Property ;
    rdfs:label 'Stat Identifier' ;
    rdfs:comment 'Human-readable business identifier for this coverage statistic record, following the COVSTAT-{alphanumeric} naming convention. Used for cross-system referencing and audit trail purposes in LIMS and BaseSpace.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegionSizeBp rdf:type rdf:Property ;
    rdfs:label 'Target Region Size Bp' ;
    rdfs:comment 'Total size of the target genomic region in base pairs as defined by the BED file. Used as the denominator for coverage depth calculations. For WGS, this represents the effective genome size used in analysis.' ;
    rdfs:domain ind:CoverageStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalDemuxResultId rdf:type rdf:Property ;
    rdfs:label 'Original Demux Result Id' ;
    rdfs:comment 'Reference to the original demux_result record when this record represents a reprocessing event (reprocessing_flag = True). Enables full lineage tracing from reprocessed results back to the original demultiplexing output. Null when reprocessing_flag = False.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemuxResult .

ind:runLaneId rdf:type rdf:Property ;
    rdfs:label 'Run Lane Id' ;
    rdfs:comment 'Foreign key linking to sequencing.run_lane. Business justification: Demultiplexing results are generated per lane within a sequencing run. demux_result currently has run_id (to sequencing_run) and lane_number (integer), but no formal FK to the run_lane master record. ' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RunLane .

ind:assignedReadCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Count' ;
    rdfs:comment 'Total number of sequencing reads assigned to this library after demultiplexing. Primary quantitative outcome of the demux process. Used to assess library representation and coverage depth adequacy for downstream analysis.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedReadPct rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Pct' ;
    rdfs:comment 'Percentage of total reads in the lane assigned to this library (assigned_read_count / total lane reads × 100). Indicates library balance within the pool. Values significantly deviating from expected multiplexing ratio trigger QC review.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Data Release Flag' ;
    rdfs:comment 'Indicates whether the FASTQ files produced by this demux result have been formally released for downstream bioinformatics processing or delivery to the customer/requester. True = released; False = held (pending QC review or approval). Supports data governance and release management workflows.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demuxCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Demux Completion Timestamp' ;
    rdfs:comment 'The date and time at which the demultiplexing process completed for this library within the sequencing run. Principal business event timestamp. Used for turnaround time (TAT) calculation and SLA monitoring.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demuxRunIdentifier rdf:type rdf:Property ;
    rdfs:label 'Demux Run Identifier' ;
    rdfs:comment 'Externally-known business identifier for the demultiplexing execution job, as assigned by the demux software (e.g., bcl2fastq job ID or DRAGEN BCL Convert run name). Used for cross-referencing with Illumina BaseSpace Sequence Hub and bioinformatics pipeline logs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demuxSoftware rdf:type rdf:Property ;
    rdfs:label 'Demux Software' ;
    rdfs:comment 'Name of the software tool used to perform demultiplexing (e.g., bcl2fastq, DRAGEN BCL Convert). Critical for reproducibility, audit trails, and bioinformatics pipeline compatibility validation.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demuxSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Demux Software Version' ;
    rdfs:comment 'Version number of the demultiplexing software used (e.g., \'2.20.0\' for bcl2fastq or \'3.9.3\' for DRAGEN BCL Convert). Required for GxP software validation records, reproducibility documentation, and regulatory submissions.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demuxStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Demux Start Timestamp' ;
    rdfs:comment 'The date and time at which the demultiplexing process was initiated for this run. Used in conjunction with demux_completion_timestamp to calculate demux processing duration for performance monitoring.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demuxStatus rdf:type rdf:Property ;
    rdfs:label 'Demux Status' ;
    rdfs:comment 'Current lifecycle status of the demultiplexing job for this library-run combination. \'completed\' indicates successful assignment; \'partial\' indicates some reads assigned but below threshold; \'failed\' indicates job error or no reads assigned.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqI1Path rdf:type rdf:Property ;
    rdfs:label 'Fastq I1 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Index Read 1 (i7 index) sequences. Generated when index reads are retained in FASTQ format. Used for index QC validation and troubleshooting demultiplexing failures.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqR1Path rdf:type rdf:Property ;
    rdfs:label 'Fastq R1 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Read 1 (forward reads) generated for this library after demultiplexing. Provides the authoritative link between the demux result and the resulting FASTQ output file for downstream bioinformatics pipeline ingestion.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastqR2Path rdf:type rdf:Property ;
    rdfs:label 'Fastq R2 Path' ;
    rdfs:comment 'Storage path or URI to the FASTQ file containing Read 2 (reverse reads) generated for this library after demultiplexing. Populated only for paired-end sequencing runs. Null for single-end runs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexMismatchCount rdf:type rdf:Property ;
    rdfs:label 'Index Mismatch Count' ;
    rdfs:comment 'Number of reads assigned to this library that contained one or more base mismatches in the index sequence relative to the expected index, within the allowed mismatch tolerance. Elevated counts may indicate index synthesis errors or library contamination.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexSequence rdf:type rdf:Property ;
    rdfs:label 'Index Sequence' ;
    rdfs:comment 'The nucleotide index sequence (i7 and optionally i5 dual-index) matched to assign reads to this library during demultiplexing. Supports single-index (e.g., ACGTACGT) and dual-index (e.g., ACGTACGT+TTGGCCAA) formats. Critical for multiplexing validation and index collision analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentPlatform rdf:type rdf:Property ;
    rdfs:label 'Instrument Platform' ;
    rdfs:comment 'The sequencing instrument platform model used for the run (e.g., NovaSeq 6000, NovaSeq X, NextSeq 2000, MiSeq). Determines flow cell format, lane count, and applicable demux parameters. [ENUM-REF-CANDIDATE: NovaSeq_6000|NovaSeq_X|NextSeq_2000|MiSeq|HiSeq_4000|PromethION|other — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanPhredScoreR1 rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score R1' ;
    rdfs:comment 'Mean Phred quality score across all bases in Read 1 for this library. Phred score (Q score) represents base call accuracy (Q30 = 99.9% accuracy). A key NGS QC metric; values below Q30 threshold may trigger QC failure.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanPhredScoreR2 rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Score R2' ;
    rdfs:comment 'Mean Phred quality score across all bases in Read 2 for this library. Typically lower than R1 due to signal degradation in paired-end sequencing. Null for single-end runs.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minReadCountThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Read Count Threshold' ;
    rdfs:comment 'The minimum number of assigned reads required for this library to pass QC, as defined by the applicable assay protocol or SOP. Stored at the record level to capture the threshold in effect at the time of demultiplexing, supporting historical QC audits.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mismatchTolerance rdf:type rdf:Property ;
    rdfs:label 'Mismatch Tolerance' ;
    rdfs:comment 'Number of allowable base mismatches permitted when matching a read\'s index sequence to the expected library index during demultiplexing. Typically 0 or 1. Higher values increase assignment rate but risk index cross-contamination between libraries.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctQ30R1 rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 R1' ;
    rdfs:comment 'Percentage of Read 1 bases with a Phred quality score of 30 or higher (≥Q30). Industry-standard NGS QC threshold; Illumina specifies ≥75–80% Q30 as passing for most platforms. Used in run-level and library-level QC reporting.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctQ30R2 rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 R2' ;
    rdfs:comment 'Percentage of Read 2 bases with a Phred quality score of 30 or higher (≥Q30). Null for single-end runs. Compared against run-specific QC thresholds for paired-end quality assessment.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readLengthR1 rdf:type rdf:Property ;
    rdfs:label 'Read Length R1' ;
    rdfs:comment 'Length in base pairs (bp) of Read 1 sequences produced for this library. Determined by the sequencing run configuration. Critical for downstream alignment and variant calling pipeline compatibility.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readLengthR2 rdf:type rdf:Property ;
    rdfs:label 'Read Length R2' ;
    rdfs:comment 'Length in base pairs (bp) of Read 2 sequences produced for this library. Null for single-end runs. Used to confirm paired-end symmetry and pipeline input validation.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runUseType rdf:type rdf:Property ;
    rdfs:label 'Run Use Type' ;
    rdfs:comment 'Intended use classification of the sequencing run from which this demux result originates. RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), clinical_validation, or research. Governs applicable regulatory requirements and data handling obligations.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetVersion rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Version' ;
    rdfs:comment 'Version identifier of the sample sheet used to configure the demultiplexing run. The sample sheet defines library-to-index mappings and run parameters. Versioning ensures traceability and supports reprocessing with corrected configurations.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLaneReadCount rdf:type rdf:Property ;
    rdfs:label 'Total Lane Read Count' ;
    rdfs:comment 'Total number of reads generated in the flow cell lane from which this library was demultiplexed. Used as the denominator for calculating assigned_read_pct and undetermined_read_pct. Enables per-lane yield assessment.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undeterminedReadCount rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Count' ;
    rdfs:comment 'Number of reads in the lane that could not be assigned to any library due to index mismatch or ambiguity. High undetermined counts indicate index contamination, library preparation issues, or incorrect sample sheet configuration.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:undeterminedReadPct rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Pct' ;
    rdfs:comment 'Percentage of total lane reads that were unassigned (undetermined_read_count / total lane reads × 100). A key QC metric; values exceeding the defined threshold (typically >5%) trigger run-level QC failure investigation.' ;
    rdfs:domain ind:DemuxResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fastqFileId rdf:type rdf:Property ;
    rdfs:label 'Fastq File Id' ;
    rdfs:comment 'Unique surrogate identifier for the FASTQ file record in the sequencing data inventory. Primary key for this master resource entity representing a raw sequencing output file.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FastqFile .

ind:adapterTrimmingFlag rdf:type rdf:Property ;
    rdfs:label 'Adapter Trimming Flag' ;
    rdfs:comment 'Indicates whether adapter sequences were trimmed from reads during or after demultiplexing. Adapter trimming affects downstream alignment and variant calling accuracy. Relevant for pipeline configuration validation.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basespaceDatasetCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Dataset Code' ;
    rdfs:comment 'The unique dataset identifier assigned by Illumina BaseSpace Sequence Hub to the dataset object containing this FASTQ file. Used for cross-referencing and API retrieval from BaseSpace.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceFileCode rdf:type rdf:Property ;
    rdfs:label 'Basespace File Code' ;
    rdfs:comment 'The unique file-level identifier assigned by Illumina BaseSpace Sequence Hub to this specific FASTQ file object. Enables direct file-level API operations and provenance tracking within BaseSpace.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionStatus rdf:type rdf:Property ;
    rdfs:label 'Encryption Status' ;
    rdfs:comment 'Indicates whether this FASTQ file is encrypted at rest in cloud storage. Encryption is mandatory for PHI-containing files under HIPAA Security Rule and for GxP-regulated data. Supports security compliance auditing.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'The full file name of the FASTQ output file including extension (e.g., SampleA_S1_L001_R1_001.fastq.gz). Follows Illumina naming conventions encoding sample, lane, read number, and index.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current lifecycle status of the FASTQ file in the sequencing data inventory. Pending = demultiplexing in progress, Available = ready for pipeline consumption, Archived = moved to cold storage, Deleted = purged per retention policy, Failed = generation error, Quarantined = held for QC investigation.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'The date and time when this FASTQ file was generated by the demultiplexing process. Represents the principal business event timestamp — the moment raw sequencing data became available as a FASTQ artifact. Used for TAT (Turnaround Time) calculations and data lineage.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intendedUseClass rdf:type rdf:Property ;
    rdfs:label 'Intended Use Class' ;
    rdfs:comment 'Regulatory classification of the intended use of this sequencing data. RUO = Research Use Only, IVD = In Vitro Diagnostic (FDA-cleared/approved), LDT = Laboratory Developed Test (CLIA-regulated). Governs data handling, access controls, and regulatory reporting obligations.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanReadLengthBp rdf:type rdf:Property ;
    rdfs:label 'Mean Read Length Bp' ;
    rdfs:comment 'The mean length of sequencing reads in this FASTQ file measured in base pairs (bp). Reflects the sequencing chemistry and run configuration. Relevant for alignment pipeline parameter selection and quality benchmarking.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pctBasesQ30 rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Q30' ;
    rdfs:comment 'The percentage of bases in this FASTQ file with a Phred quality score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. Industry-standard QC threshold for NGS data quality; typically ≥80% Q30 is required for clinical-grade sequencing.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctReadsPassingFilter rdf:type rdf:Property ;
    rdfs:label 'Pct Reads Passing Filter' ;
    rdfs:comment 'The percentage of reads in this FASTQ file that passed the Illumina chastity filter (PF reads). Reads failing the filter are excluded from analysis. A key indicator of cluster quality and flow cell performance.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Pipeline Ready Flag' ;
    rdfs:comment 'Indicates whether this FASTQ file has passed all QC checks and is cleared for ingestion into bioinformatics analysis pipelines. When True, the file is eligible for alignment, variant calling, and downstream processing. Prevents failed or quarantined files from entering production pipelines.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'The cloud storage tier in which this FASTQ file currently resides. Hot = frequently accessed (active analysis), Warm = infrequent access, Cold = rare access, Archive = long-term retention (e.g., AWS Glacier). Drives storage cost management and retrieval SLA expectations.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'The date and time when this FASTQ file was successfully uploaded to cloud storage (BaseSpace or S3). Distinct from generation_timestamp; captures the transfer completion event for data availability tracking and SLA monitoring.' ;
    rdfs:domain ind:FastqFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturingProductionBatchId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Production Batch Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_batch. Business justification: Vertically-integrated genomics companies manufacturing flow cells in-house require full batch traceability for regulatory compliance (ISO 13485, FDA QSR). Flow cell performance issues (low cluster den' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:basespaceFlowCellCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Flow Cell Code' ;
    rdfs:comment 'External identifier assigned to this flow cell within the Illumina BaseSpace Sequence Hub system. Enables cross-system reconciliation between the internal lakehouse record and the BaseSpace sequencing data management platform. Used for data lineage and run data retrieval.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDensitySpecMm2 rdf:type rdf:Property ;
    rdfs:label 'Cluster Density Spec Mm2' ;
    rdfs:comment 'Manufacturer-specified target cluster density in clusters per square millimeter (K/mm²) for optimal sequencing performance. Used to evaluate loading concentration and diagnose under- or over-clustering quality failures. Critical QC parameter tracked in LabVantage LIMS.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Breach Flag' ;
    rdfs:comment 'Indicates whether a temperature excursion or cold chain breach was detected during shipping or storage of this flow cell (True = breach detected). Triggers quarantine workflow and quality investigation in LabVantage LIMS and Veeva Vault. A breached flow cell must not be used until cleared by QA.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumed Timestamp' ;
    rdfs:comment 'Date and time when the sequencing run was completed and the flow cell was fully consumed or removed from the instrument. Marks the end of the flow cell\'s active lifecycle. Used for TAT reporting, instrument utilization metrics, and inventory depletion tracking.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flowCellStatus rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Status' ;
    rdfs:comment 'Current lifecycle status of the physical flow cell consumable. Tracks the operational state from receipt through consumption or disposal. \'in_stock\' = received and available; \'reserved\' = allocated to a planned run; \'loaded\' = currently on instrument; \'consumed\' = run completed; \'failed\' = quality failure; \'expired\' = past expiry date; \'quarantined\' = held for investigation. [ENUM-REF-CANDIDATE: in_stock|reserved|loaded|consumed|failed|expired|quarantined — promote to reference product]' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSingleUse rdf:type rdf:Property ;
    rdfs:label 'Is Single Use' ;
    rdfs:comment 'Indicates whether the flow cell is designed for single use only (True) or supports multiple sequencing runs (False). Governs reuse policies, disposal procedures, and run scheduling logic. Most modern Illumina flow cells are single-use; this flag supports future platform compatibility.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCount rdf:type rdf:Property ;
    rdfs:label 'Lane Count' ;
    rdfs:comment 'Number of independent sequencing lanes on the flow cell (e.g., 1, 2, or 4 lanes for NovaSeq S1/S2/S4). Each lane can be loaded with a separate library pool, enabling multiplexing strategies. Drives capacity planning for sample batching and run scheduling.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limsBarcode rdf:type rdf:Property ;
    rdfs:label 'Lims Barcode' ;
    rdfs:comment 'Barcode label scanned into LabVantage LIMS at receipt to register the flow cell in the laboratory inventory system. Used for physical tracking, chain-of-custody documentation, and automated workflow triggering in the LIMS. May differ from the manufacturer serial number.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when the flow cell was physically loaded onto the sequencing instrument, marking the transition from \'reserved\' to \'loaded\' status. Recorded in Illumina BaseSpace Sequence Hub and LabVantage LIMS. Used for run scheduling, instrument utilization analysis, and TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxOutputGb rdf:type rdf:Property ;
    rdfs:label 'Max Output Gb' ;
    rdfs:comment 'Manufacturer-specified maximum sequencing output in gigabases (Gb) achievable under optimal conditions for this flow cell type. Used for capacity planning, run design, and cost-per-sample calculations. Represents the principal quantitative performance specification of the flow cell resource.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Inspection Status' ;
    rdfs:comment 'Result of the incoming quality control inspection performed upon receipt of the flow cell. \'pending\' = inspection not yet completed; \'passed\' = meets acceptance criteria; \'failed\' = does not meet criteria, quarantined; \'waived\' = inspection waived per approved SOP (e.g., for pre-qualified lots). Managed in SAP S/4HANA QM and LabVantage LIMS.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLengthSpec rdf:type rdf:Property ;
    rdfs:label 'Read Length Spec' ;
    rdfs:comment 'Maximum supported read length in base pairs (bp) for this flow cell type as specified by the manufacturer (e.g., 150 bp, 250 bp, 300 bp). Determines compatibility with library preparation protocols for WGS, WES, or targeted sequencing applications.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reagentKitLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Kit Lot Number' ;
    rdfs:comment 'Lot number of the sequencing reagent kit used in conjunction with this flow cell. Enables paired traceability between the flow cell consumable and its associated reagent kit for quality investigations, recall management, and GMP compliance. Sourced from LabVantage LIMS run setup records.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLotCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Lot Certificate Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (COA) issued by the supplier for this specific lot. The COA documents manufacturer QC test results confirming the flow cell meets specification. Stored in Veeva Vault for regulatory document management and GMP compliance.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the external supplier or manufacturer who supplied this flow cell (e.g., Illumina, Inc.). Used for procurement lineage, supplier qualification tracking, and quality management. Linked to the reagent and consumable domain for full procurement traceability.' ;
    rdfs:domain ind:FlowCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexSetId rdf:type rdf:Property ;
    rdfs:label 'Index Set Id' ;
    rdfs:comment 'Unique surrogate identifier for the sequencing index set record in the Genomics Biotech lakehouse. Primary key for the index_set master resource.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndexSet .

ind:adapterSequenceRead1 rdf:type rdf:Property ;
    rdfs:label 'Adapter Sequence Read1' ;
    rdfs:comment 'Full adapter sequence flanking the i7 index on the Read 1 side, used for adapter trimming in bioinformatics preprocessing pipelines. Stored in 5\'→3\' orientation per IUPAC convention.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adapterSequenceRead2 rdf:type rdf:Property ;
    rdfs:label 'Adapter Sequence Read2' ;
    rdfs:comment 'Full adapter sequence flanking the i5 index on the Read 2 side, used for adapter trimming in paired-end bioinformatics preprocessing pipelines. Null for single-end or single-index configurations.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceIndexSetCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Index Set Code' ;
    rdfs:comment 'The unique identifier assigned to this index set within Illumina BaseSpace Sequence Hub. Enables direct cross-reference between the Genomics Biotech lakehouse master record and the operational sequencing data management platform for run configuration and demultiplexing.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorBalanceStatus rdf:type rdf:Property ;
    rdfs:label 'Color Balance Status' ;
    rdfs:comment 'Indicates whether the index set provides adequate color (fluorescence channel) balance across all sequencing cycles on two-channel or four-channel chemistry instruments. \'balanced\' = no spike-in required; \'unbalanced\' = color imbalance detected; \'requires_spike_in\' = PhiX or other spike-in control is mandatory. Prevents base-calling failures on patterned flow cells.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleLibraryPrepKits rdf:type rdf:Property ;
    rdfs:label 'Compatible Library Prep Kits' ;
    rdfs:comment 'Comma-separated list of library preparation kit names or catalogue numbers validated for use with this index set (e.g., \'TruSeq DNA PCR-Free, TruSeq Stranded mRNA, Nextera DNA Flex\'). Managed by sequencing operations to prevent incompatible kit-index pairings during run setup.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gmp Compliant' ;
    rdfs:comment 'Indicates whether the index set was manufactured under Good Manufacturing Practice (GMP) conditions as required for IVD or clinical use. True = GMP-manufactured; False = non-GMP (RUO grade). Drives quality management and supplier qualification requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:i5Sequence rdf:type rdf:Property ;
    rdfs:label 'I5 Sequence' ;
    rdfs:comment 'Nucleotide sequence of the i5 (read 2 side) index used in dual-index configurations. Null or empty for single-index sets. Stored as a representative or consensus sequence; individual per-sample i5 sequences are tracked at the library level.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i7Sequence rdf:type rdf:Property ;
    rdfs:label 'I7 Sequence' ;
    rdfs:comment 'Nucleotide sequence of the i7 (read 1 side) index used for sample identification during demultiplexing. Stored as a representative or consensus sequence for the set; individual per-sample i7 sequences are tracked at the library level. Validated against IUPAC nucleotide codes.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCount rdf:type rdf:Property ;
    rdfs:label 'Index Count' ;
    rdfs:comment 'Total number of unique index sequences (barcodes) available in the set. Determines the maximum multiplexing capacity — i.e., the maximum number of samples that can be pooled in a single sequencing run using this index set.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexLengthBp rdf:type rdf:Property ;
    rdfs:label 'Index Length Bp' ;
    rdfs:comment 'Length of the index sequence in base pairs (bp), typically 6, 8, 10, or 12 bp. Determines the read cycle configuration on the sequencer and affects the number of unique indices available in the set. Must match the sequencing run setup parameters.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'Classification of the indexing strategy used in the set. \'single\' = single-end index (i7 only); \'dual\' = dual-index (i7 + i5, may be combinatorial); \'UDI\' = Unique Dual Index (each sample has a unique i7+i5 pair, preventing index hopping); \'combinatorial\' = combinatorial dual index (i7 and i5 drawn from independent pools). Critical for demultiplexing configuration and index-hopping risk assessment.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsIndexSetCode rdf:type rdf:Property ;
    rdfs:label 'Lims Index Set Code' ;
    rdfs:comment 'The unique identifier for this index set in LabVantage LIMS, the system of record for sample tracking and laboratory workflow management. Enables traceability between the lakehouse master record and LIMS-managed library preparation and pool design workflows.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxMultiplexSamples rdf:type rdf:Property ;
    rdfs:label 'Max Multiplex Samples' ;
    rdfs:comment 'Maximum number of samples that can be pooled (multiplexed) in a single sequencing run using this index set while maintaining the minimum Hamming distance threshold. Derived from the validated index set design; used in pool design planning and run capacity management.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minHammingDistance rdf:type rdf:Property ;
    rdfs:label 'Min Hamming Distance' ;
    rdfs:comment 'The minimum Hamming distance between any two index sequences within the set. A higher value (typically ≥3) reduces the risk of index misassignment during demultiplexing. Critical quality parameter for pool design validation and collision prevention.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phixSpikeInPct rdf:type rdf:Property ;
    rdfs:label 'Phix Spike In Pct' ;
    rdfs:comment 'Recommended percentage of PhiX control library to spike into the pool when using this index set, to correct for color imbalance or low-diversity libraries. Expressed as a percentage of total library pool volume (e.g., 1.00, 5.00, 20.00). Zero if no spike-in is required.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readOrientation rdf:type rdf:Property ;
    rdfs:label 'Read Orientation' ;
    rdfs:comment 'Specifies the orientation in which the i5 index is read on the sequencer. Critical for correct demultiplexing on instruments with different flow cell orientations (e.g., NovaSeq v1.5 flow cells require reverse complement of i5 vs. standard orientation). [ENUM-REF-CANDIDATE: forward|reverse_complement|forward_reverse|reverse_complement_forward — promote to reference product]' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClearanceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Clearance Number' ;
    rdfs:comment 'FDA 510(k) clearance number, CE-IVD certificate number, or equivalent regulatory authorization number if the index set is part of a cleared or approved IVD product. Null for RUO-only index sets. Required for regulatory submissions and audit trails.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setCode rdf:type rdf:Property ;
    rdfs:label 'Set Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code or catalogue number assigned to the index set by the manufacturer or internally by sequencing operations. Used as the business key for cross-system lookups and BOM references in SAP S/4HANA MM.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setName rdf:type rdf:Property ;
    rdfs:label 'Set Name' ;
    rdfs:comment 'Human-readable name of the sequencing index set as defined by the manufacturer or sequencing operations team (e.g., \'Illumina TruSeq CD Index Set A\', \'IDT xGen UDI-UMI Adapters\'). Used as the primary display label in library preparation workflows and pool design tools.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededBySetCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Set Code' ;
    rdfs:comment 'Set code of the newer index set that replaces this one when it is deprecated. Enables migration guidance for sequencing operations teams transitioning from legacy to current index chemistries. Null if not superseded.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:umiIncluded rdf:type rdf:Property ;
    rdfs:label 'Umi Included' ;
    rdfs:comment 'Indicates whether the index set includes Unique Molecular Identifiers (UMIs) integrated into the adapter design. UMIs enable PCR duplicate removal and error correction in downstream bioinformatics pipelines, critical for low-input and cfDNA applications.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:umiLengthBp rdf:type rdf:Property ;
    rdfs:label 'Umi Length Bp' ;
    rdfs:comment 'Length of the UMI sequence in base pairs when UMIs are included in the index set design (e.g., 8, 12 bp). Null if umi_included is False. Required for configuring UMI extraction steps in bioinformatics pipelines.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validatedBy rdf:type rdf:Property ;
    rdfs:label 'Validated By' ;
    rdfs:comment 'Name or employee identifier of the sequencing operations scientist or engineer who performed and signed off on the internal technical validation of this index set. Supports GxP audit trail requirements.' ;
    rdfs:domain ind:IndexSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPrepRunId rdf:type rdf:Property ;
    rdfs:label 'Library Prep Run Id' ;
    rdfs:comment 'Foreign key linking to sequencing.library_prep_run. Business justification: Each library is produced by a specific library preparation run. This is a standard parent-child relationship where library_prep_run is the batch execution entity and library is the output product. Cur' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LibraryPrepRun .

ind:multiplexingPoolId rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Pool Id' ;
    rdfs:comment 'Identifier of the multiplexing pool to which this library has been assigned for co-loading onto a flow cell. Enables tracking of pooled libraries, demultiplexing yield analysis, and per-library coverage attribution within a pooled run.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:originalLibraryId rdf:type rdf:Property ;
    rdfs:label 'Original Library Id' ;
    rdfs:comment 'Reference to the original library record when this library is a resequencing attempt (resequencing_flag = True). Enables lineage tracking across preparation attempts and supports failure analysis workflows. Null for original preparations.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Library .

ind:prepKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Prep Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Library prep kits are commercial catalog items. Labs track which kit SKU was used for cost allocation, protocol validation, regulatory compliance, and troubleshooting quality issues. Essential for GxP' ;
    rdfs:domain ind:Library ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:targetPanelId rdf:type rdf:Property ;
    rdfs:label 'Target Panel Id' ;
    rdfs:comment 'Identifier of the capture or amplicon panel used for targeted sequencing libraries (e.g., Illumina TruSight Oncology 500, custom gene panel). Null for WGS/WES libraries. Links to panel design specifications for bioinformatics pipeline configuration.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TargetPanel .

ind:basespaceLibraryCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Library Code' ;
    rdfs:comment 'External identifier assigned to this library within Illumina BaseSpace Sequence Hub. Enables cross-system traceability between the internal LIMS record and the BaseSpace sequencing data management platform for FASTQ retrieval and run association.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationNm rdf:type rdf:Property ;
    rdfs:label 'Concentration Nm' ;
    rdfs:comment 'Measured molar concentration of the library in nanomolar (nM) units. Used for accurate loading onto flow cells and pooling calculations during multiplexing. Sourced from quantification instrument output.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether valid informed consent has been obtained for the use of the source sample in sequencing and data sharing (True = consent confirmed; False = consent not confirmed or withdrawn). Required for HIPAA, GDPR, and NIH Genomic Data Sharing Policy compliance.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingRestricted rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Restricted' ;
    rdfs:comment 'Indicates whether genomic data derived from this library is subject to data sharing restrictions (True = restricted; False = unrestricted). Restrictions may arise from consent limitations, IRB conditions, contractual obligations, or GDPR/HIPAA data subject rights. Governs downstream data product access controls.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Bp' ;
    rdfs:comment 'Target or measured average insert size of the library fragments in base pairs (bp). A key MEASUREMENT_OR_VALUE (MASTER_RESOURCE category) for library quality assessment. Impacts read alignment efficiency, coverage uniformity, and variant calling accuracy. Typically 150–500 bp for WGS/WES.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPcrFree rdf:type rdf:Property ;
    rdfs:label 'Is Pcr Free' ;
    rdfs:comment 'Indicates whether the library was prepared using a PCR-free protocol (True) or a PCR-amplified protocol (False). PCR-free libraries have lower duplicate rates and reduced GC bias, preferred for high-accuracy WGS applications.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libraryCode rdf:type rdf:Property ;
    rdfs:label 'Library Code' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the sequencing library, used in LIMS, BaseSpace, and laboratory documentation. Follows the internal naming convention LIB-{alphanumeric}. This is the BUSINESS_IDENTIFIER (MASTER_RESOURCE category) used across operational systems.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryName rdf:type rdf:Property ;
    rdfs:label 'Library Name' ;
    rdfs:comment 'Human-readable descriptive name assigned to the sequencing library, typically incorporating sample identifier, preparation date, and assay type. Used as the IDENTITY_LABEL (MASTER_RESOURCE category) for display in LIMS dashboards, BaseSpace projects, and laboratory reports.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryType rdf:type rdf:Property ;
    rdfs:label 'Library Type' ;
    rdfs:comment 'Classification of the sequencing library by assay strategy. Drives downstream bioinformatics pipeline selection, coverage expectations, and reporting templates. CLASSIFICATION_OR_TYPE (MASTER_RESOURCE category). [ENUM-REF-CANDIDATE: WGS|WES|amplicon|RNA-seq|targeted_panel|methylation|ChIP-seq|ATAC-seq|single_cell — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsLibraryCode rdf:type rdf:Property ;
    rdfs:label 'Lims Library Code' ;
    rdfs:comment 'Native identifier for this library record within LabVantage LIMS. Supports bidirectional reconciliation between the Silver Layer data product and the operational LIMS system of record for audit and data lineage purposes.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolingProportionPct rdf:type rdf:Property ;
    rdfs:label 'Pooling Proportion Pct' ;
    rdfs:comment 'Percentage contribution of this library to the total multiplexing pool by molar concentration. Used to balance per-library coverage in multiplexed sequencing runs and to investigate coverage imbalance post-sequencing.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepDate rdf:type rdf:Property ;
    rdfs:label 'Prep Date' ;
    rdfs:comment 'Calendar date on which the library preparation protocol was completed. Used for lot traceability, reagent expiry correlation, and turnaround time (TAT) calculations. Aligns with GxP batch record requirements.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resequencingFlag rdf:type rdf:Property ;
    rdfs:label 'Resequencing Flag' ;
    rdfs:comment 'Indicates whether this library was prepared as a resequencing attempt for a previously failed or insufficient-coverage library (True = resequencing; False = original preparation). Supports TAT tracking, cost analysis, and failure rate reporting.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageWellPosition rdf:type rdf:Property ;
    rdfs:label 'Storage Well Position' ;
    rdfs:comment 'Well position (e.g., A01, H12) within the storage plate where the library aliquot is located. Combined with storage_plate_id, provides precise physical location for laboratory retrieval and inventory audits.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandSpecificity rdf:type rdf:Property ;
    rdfs:label 'Strand Specificity' ;
    rdfs:comment 'Indicates whether the library preserves strand-of-origin information for RNA-seq or other strand-aware assays. Values: unstranded — no strand information retained; forward — read 1 maps to sense strand; reverse — read 1 maps to antisense strand. Required for correct transcript quantification in RNA-seq pipelines.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiPlateCode rdf:type rdf:Property ;
    rdfs:label 'Udi Plate Code' ;
    rdfs:comment 'Identifier of the unique dual index (UDI) plate from which the index pair was assigned. Enables traceability of index assignments across batches and supports investigation of index hopping or cross-contamination events.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:udiWellPosition rdf:type rdf:Property ;
    rdfs:label 'Udi Well Position' ;
    rdfs:comment 'Well position (e.g., A01, B12) on the UDI plate from which the index pair was drawn. Together with udi_plate_id, uniquely identifies the index assignment for demultiplexing and audit purposes.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRemainingUl rdf:type rdf:Property ;
    rdfs:label 'Volume Remaining Ul' ;
    rdfs:comment 'Current volume of library material remaining in storage, measured in microliters (µL). Tracks consumable inventory for re-sequencing eligibility and storage management. Updated after each aliquot event.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturingWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Work Order Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.work_order. Business justification: Library prep kits manufactured in-house require full traceability from prep run to manufacturing work order. When library prep QC fails (adapter dimer >5%, wrong insert size), manufacturing must inves' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryLibraryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Library Employee Id' ;
    rdfs:comment 'Identifier of the laboratory scientist or technician who executed the library preparation run. Links to the workforce/personnel master for GxP operator qualification tracking and audit trail. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adapterDimerPct rdf:type rdf:Property ;
    rdfs:label 'Adapter Dimer Pct' ;
    rdfs:comment 'Percentage of adapter dimer contamination detected in the final library by electrophoresis (Bioanalyzer/TapeStation). High adapter dimer content reduces effective sequencing yield and is a key QC failure indicator. Typically must be below 5% for pass disposition.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adapterLigationMethod rdf:type rdf:Property ;
    rdfs:label 'Adapter Ligation Method' ;
    rdfs:comment 'Method used to ligate sequencing adapters to the end-repaired DNA fragments. Tagmentation (Nextera) combines fragmentation and adapter ligation in a single step. Affects ligation efficiency, adapter dimer formation rate, and overall library yield.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceRunCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Run Code' ;
    rdfs:comment 'Run identifier assigned by Illumina BaseSpace Sequence Hub for the downstream sequencing run associated with this library preparation batch. Enables end-to-end traceability from library preparation through raw data generation and FASTQ output.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchQcOutcome rdf:type rdf:Property ;
    rdfs:label 'Batch Qc Outcome' ;
    rdfs:comment 'Overall quality control disposition for the library preparation run batch. Determines whether the batch is approved for sequencing submission. A conditional pass may require additional review or re-quantification before proceeding.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endRepairPerformed rdf:type rdf:Property ;
    rdfs:label 'End Repair Performed' ;
    rdfs:comment 'Indicates whether an end-repair and A-tailing step was performed on the fragmented DNA prior to adapter ligation. End repair is required for blunt-end ligation protocols but may be skipped in tagmentation-based workflows.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalLibraryConcentrationNm rdf:type rdf:Property ;
    rdfs:label 'Final Library Concentration Nm' ;
    rdfs:comment 'Measured concentration of the final pooled library in nanomolar (nM), typically quantified by qPCR or fluorometric assay (e.g., Qubit). Used to calculate the dilution factor for optimal flow cell loading and to assess library yield.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPoolingVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Final Pooling Volume Ul' ;
    rdfs:comment 'Total volume in microliters (µL) of the final pooled library submitted for sequencing. Used to calculate loading concentration for the flow cell and to assess library yield sufficiency for sequencing.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fragmentationMethod rdf:type rdf:Property ;
    rdfs:label 'Fragmentation Method' ;
    rdfs:comment 'DNA/RNA fragmentation approach applied during library preparation. Enzymatic fragmentation uses restriction enzymes or transposases (e.g., Nextera); mechanical fragmentation uses sonication or acoustic shearing (e.g., Covaris). Affects insert size distribution and library quality metrics.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCollisionCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Index Collision Check Passed' ;
    rdfs:comment 'Indicates whether the selected multiplexing index combinations were verified to have sufficient Hamming distance to prevent index hopping or misassignment during demultiplexing. A failed check requires index reassignment before sequencing.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputDnaAmountNg rdf:type rdf:Property ;
    rdfs:label 'Input Dna Amount Ng' ;
    rdfs:comment 'Total mass of input DNA or RNA (in nanograms) used per sample in this library preparation run. Critical QC parameter — insufficient input material is a leading cause of library preparation failure and low-complexity libraries.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanFragmentSizeBp rdf:type rdf:Property ;
    rdfs:label 'Mean Fragment Size Bp' ;
    rdfs:comment 'Measured mean fragment size in base pairs (bp) of the final library as determined by Bioanalyzer, TapeStation, or equivalent electrophoresis instrument. Compared against target_insert_size_bp to assess size selection success and protocol adherence.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplexingIndexSet rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Index Set' ;
    rdfs:comment 'Name or identifier of the index/barcode set used for sample multiplexing in this library preparation run (e.g., Illumina TruSeq CD Index Set A, IDT for Illumina 10 bp UDI). Enables demultiplexing of pooled samples post-sequencing and prevents index collision errors.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcrAmplificationCycles rdf:type rdf:Property ;
    rdfs:label 'Pcr Amplification Cycles' ;
    rdfs:comment 'Number of PCR amplification cycles applied during library preparation. Excessive PCR cycles introduce duplicate reads and GC bias, reducing library complexity. Zero cycles indicates a PCR-free protocol. Key parameter for library quality assessment and protocol compliance.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runNotes rdf:type rdf:Property ;
    rdfs:label 'Run Notes' ;
    rdfs:comment 'Free-text field for operator observations, troubleshooting notes, or contextual comments recorded during or after the library preparation run. Supplements structured deviation documentation and supports root cause analysis.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeSelectionMethod rdf:type rdf:Property ;
    rdfs:label 'Size Selection Method' ;
    rdfs:comment 'Method used to select the target insert size range from the library pool (e.g., SPRI bead-based cleanup, gel excision, Pippin Prep automated electrophoresis). Size selection removes adapter dimers and off-target fragments, improving sequencing efficiency.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Deviation Flag' ;
    rdfs:comment 'Indicates whether any deviation from the approved standard operating procedure (SOP) was recorded during this library preparation run. A True value triggers mandatory deviation documentation and review per GxP requirements.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Target Insert Size Bp' ;
    rdfs:comment 'Intended DNA insert size in base pairs (bp) for the prepared library, as specified by the protocol. Insert size directly impacts sequencing read overlap, coverage uniformity, and variant calling accuracy. Typical ranges: 150–400 bp for short-read NGS.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workgroupCode rdf:type rdf:Property ;
    rdfs:label 'Workgroup Code' ;
    rdfs:comment 'Identifier of the laboratory workgroup or team responsible for executing this library preparation run. Supports capacity planning, workload balancing, and team-level performance reporting.' ;
    rdfs:domain ind:LibraryPrepRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolId rdf:type rdf:Property ;
    rdfs:label 'Pool Id' ;
    rdfs:comment 'Unique system-generated identifier for the multiplexed library pool record. Primary key for the pool entity in the sequencing domain.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:parentPoolId rdf:type rdf:Property ;
    rdfs:label 'Parent Pool Id' ;
    rdfs:comment 'Reference to the original pool from which this re-pool was derived, when is_repool is True. Enables lineage tracking and root cause analysis for failed pools.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:reagentCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Reagent Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Pooling operations use reagents/normalization kits that are catalog items. Needed for cost accounting, protocol compliance, and tracking which commercial products were used for library normalization a' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:basespacePoolCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Pool Code' ;
    rdfs:comment 'External identifier assigned to this pool within Illumina BaseSpace Sequence Hub. Used for cross-system traceability between the internal LIMS and the BaseSpace sequencing data management platform.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationMethod rdf:type rdf:Property ;
    rdfs:label 'Concentration Method' ;
    rdfs:comment 'Analytical method used to measure the pool concentration. Qubit and qPCR are preferred for accurate molar quantification; Bioanalyzer and TapeStation provide both concentration and fragment size data.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalConcentrationNm rdf:type rdf:Property ;
    rdfs:label 'Final Concentration Nm' ;
    rdfs:comment 'Measured molar concentration of the pool in nanomolar (nM) after pooling, as determined by Qubit fluorometry or qPCR quantification. Used to calculate dilution for loading concentration.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowCellLane rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Lane' ;
    rdfs:comment 'Specific lane(s) on the flow cell to which this pool is assigned for loading. A pool may occupy a single lane or the entire flow cell depending on the instrument type and run design.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragmentSizeLowerBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Lower Bp' ;
    rdfs:comment 'Lower bound of the acceptable fragment size distribution range in base pairs (bp) for this pool, as defined by the QC specification. Fragments below this threshold indicate adapter contamination or over-fragmentation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fragmentSizeMethod rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Method' ;
    rdfs:comment 'Instrument or method used to assess the fragment size distribution of the pool (e.g., Agilent Bioanalyzer, Agilent TapeStation, Advanced Analytical Fragment Analyzer, or gel electrophoresis).' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fragmentSizeUpperBp rdf:type rdf:Property ;
    rdfs:label 'Fragment Size Upper Bp' ;
    rdfs:comment 'Upper bound of the acceptable fragment size distribution range in base pairs (bp) for this pool. Fragments above this threshold may indicate incomplete fragmentation or genomic DNA contamination.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexCollisionRisk rdf:type rdf:Property ;
    rdfs:label 'Index Collision Risk' ;
    rdfs:comment 'Assessed risk level of index sequence collision (cross-contamination between demultiplexed samples) within this pool, based on Hamming distance analysis of the index set. Low risk indicates sufficient edit distance between all index pairs.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepool rdf:type rdf:Property ;
    rdfs:label 'Is Repool' ;
    rdfs:comment 'Indicates whether this pool is a re-pool created to replace or supplement a previously failed or underperforming pool (True = re-pool, False = original pool). Used for tracking remediation events.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:libraryCount rdf:type rdf:Property ;
    rdfs:label 'Library Count' ;
    rdfs:comment 'Total number of individually indexed libraries combined into this pool. Determines the degree of multiplexing and directly impacts per-library read depth allocation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limsPoolCode rdf:type rdf:Property ;
    rdfs:label 'Lims Pool Code' ;
    rdfs:comment 'Native pool identifier from LabVantage LIMS, used for cross-system reconciliation between the enterprise data lakehouse and the operational LIMS source system.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingConcentrationPm rdf:type rdf:Property ;
    rdfs:label 'Loading Concentration Pm' ;
    rdfs:comment 'Target loading concentration of the diluted pool in picomolar (pM) for the specific instrument and flow cell type. Directly impacts cluster density and sequencing quality.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Human-readable, externally-known unique alphanumeric code assigned to the pool for tracking across LIMS, BaseSpace, and laboratory worksheets. Used as the business identifier on COAs and run manifests.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Descriptive human-readable name assigned to the pool, typically encoding project, date, and cohort information for easy identification in run planning and reporting.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the pool. Tracks progression from initial creation through QC verification, loading onto the sequencer, sequencing completion, or expiry. [ENUM-REF-CANDIDATE: pending|qc_in_progress|qc_passed|qc_failed|loaded|sequenced|expired — promote to reference product]' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolingDate rdf:type rdf:Property ;
    rdfs:label 'Pooling Date' ;
    rdfs:comment 'Calendar date on which the individual libraries were combined to form this pool. Used for traceability, stability window calculation, and laboratory scheduling.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poolingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pooling Strategy' ;
    rdfs:comment 'Method used to combine individual indexed libraries into the pool. Equimolar pools combine equal molar quantities; custom ratio pools use user-defined proportions; normalized pools use concentration normalization prior to combining; volume-based pools combine equal volumes.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcConcentrationPassed rdf:type rdf:Property ;
    rdfs:label 'Qc Concentration Passed' ;
    rdfs:comment 'Indicates whether the pool passed the concentration QC threshold check (True = passed, False = failed). A pool must pass concentration QC before it is eligible for loading onto the sequencer.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcDate rdf:type rdf:Property ;
    rdfs:label 'Qc Date' ;
    rdfs:comment 'Date on which QC measurements (concentration and fragment size) were performed on the pool. May differ from pooling date if QC is conducted on a subsequent day.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcFragmentSizePassed rdf:type rdf:Property ;
    rdfs:label 'Qc Fragment Size Passed' ;
    rdfs:comment 'Indicates whether the pool passed the fragment size distribution QC check (True = passed, False = failed). Ensures the pool\'s insert size profile is within acceptable bounds for the target sequencing application.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcOverallPassed rdf:type rdf:Property ;
    rdfs:label 'Qc Overall Passed' ;
    rdfs:comment 'Composite QC pass/fail flag indicating whether the pool has passed all required QC checks (concentration and fragment size) and is approved for sequencer loading. True = all QC checks passed.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequencingApplication rdf:type rdf:Property ;
    rdfs:label 'Sequencing Application' ;
    rdfs:comment 'Genomic sequencing application type for which this pool was prepared. Determines bioinformatics pipeline routing, QC thresholds, and coverage requirements. [ENUM-REF-CANDIDATE: wgs|wes|targeted_panel|amplicon|rna_seq|chip_seq|atac_seq|methyl_seq — promote to reference product]' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetReadDepth rdf:type rdf:Property ;
    rdfs:label 'Target Read Depth' ;
    rdfs:comment 'Expected average sequencing read depth (coverage depth) per library within the pool, expressed as number of reads. Used for run planning, yield allocation, and per-sample coverage estimation.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeUl rdf:type rdf:Property ;
    rdfs:label 'Total Volume Ul' ;
    rdfs:comment 'Total volume of the combined pool in microlitres (µL) after all libraries have been pooled. Used to assess whether sufficient material exists for loading and archival.' ;
    rdfs:domain ind:Pool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolLibraryId rdf:type rdf:Property ;
    rdfs:label 'Pool Library Id' ;
    rdfs:comment 'Unique surrogate identifier for the pool-library association record. Primary key for this junction entity linking a sequencing library to a pool.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualMolarFractionPct rdf:type rdf:Property ;
    rdfs:label 'Actual Molar Fraction Pct' ;
    rdfs:comment 'The measured proportion (%) of this library\'s molar contribution in the final pool, determined by qPCR or fluorometric quantification. Deviations from expected fraction indicate pipetting or quantification errors.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedReadFractionPct rdf:type rdf:Property ;
    rdfs:label 'Assigned Read Fraction Pct' ;
    rdfs:comment 'Percentage of total pool reads assigned to this library after demultiplexing. Compared against expected molar fraction to assess pooling balance and identify over- or under-represented libraries.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone) when this library was assigned to the pool in the LIMS or BaseSpace Sequence Hub. Serves as the primary business event timestamp for this junction record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:demultiplexMismatchAllowed rdf:type rdf:Property ;
    rdfs:label 'Demultiplex Mismatch Allowed' ;
    rdfs:comment 'Number of base mismatches permitted during demultiplexing for this library\'s index sequence. Typically 0 or 1. Higher values increase sensitivity but risk misassignment between similar indexes.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedMolarFractionPct rdf:type rdf:Property ;
    rdfs:label 'Expected Molar Fraction Pct' ;
    rdfs:comment 'The theoretical proportion (%) of this library\'s molar contribution relative to the total pool. Used to balance sequencing depth across libraries in a multiplexed run. Sum across all libraries in a pool should equal 100%.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:i5IndexSequence rdf:type rdf:Property ;
    rdfs:label 'I5 Index Sequence' ;
    rdfs:comment 'The i5 (read 2 side) barcode index nucleotide sequence assigned to this library for dual-index multiplexing. Required for dual-indexed library pools to prevent index hopping. Typically 6–10 bases.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i7IndexSequence rdf:type rdf:Property ;
    rdfs:label 'I7 Index Sequence' ;
    rdfs:comment 'The i7 (read 1 side) barcode index nucleotide sequence assigned to this library for multiplexing identification. Used during demultiplexing to assign reads back to the originating library. Typically 6–10 bases.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexCollisionFlag rdf:type rdf:Property ;
    rdfs:label 'Index Collision Flag' ;
    rdfs:comment 'Indicates whether this library\'s index sequence conflicts (collides) with another library\'s index in the same pool, which would impair demultiplexing accuracy. True = collision detected; False = no collision. Populated by index compatibility checking tools.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indexDistance rdf:type rdf:Property ;
    rdfs:label 'Index Distance' ;
    rdfs:comment 'Minimum Hamming distance between this library\'s index sequence and all other index sequences in the same pool. A distance of ≥2 is typically required for reliable demultiplexing with 1 mismatch tolerance. Low values indicate collision risk.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Human-readable name or catalog designation of the index pair (e.g., \'IDT-10nt-UDI-0001\', \'TruSeq-D701-D501\'). Corresponds to the index kit nomenclature used during library preparation.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneAssignment rdf:type rdf:Property ;
    rdfs:label 'Lane Assignment' ;
    rdfs:comment 'The specific flow cell lane(s) to which this library-pool combination is assigned for sequencing (e.g., \'1\', \'1,2\', \'all\'). Relevant for patterned flow cells with lane-level loading (e.g., Illumina NovaSeq S4 flow cell).' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsPoolLibraryRef rdf:type rdf:Property ;
    rdfs:label 'Lims Pool Library Ref' ;
    rdfs:comment 'External reference identifier for this pool-library association record as recorded in LabVantage LIMS. Enables cross-system traceability between the lakehouse silver layer and the operational LIMS source of record.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingRatio rdf:type rdf:Property ;
    rdfs:label 'Loading Ratio' ;
    rdfs:comment 'The ratio of this library\'s contribution relative to the total pool volume or molar amount at the time of flow cell loading. Used to normalize read depth expectations and assess pooling balance post-sequencing.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalizationTool rdf:type rdf:Property ;
    rdfs:label 'Normalization Tool' ;
    rdfs:comment 'Name of the instrument or software tool used to quantify and normalize this library prior to pooling (e.g., \'Qubit 4 Fluorometer\', \'Agilent Bioanalyzer 2100\', \'Agilent TapeStation 4200\', \'KAPA Library Quantification qPCR\'). Supports reagent and instrument traceability.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phredQ30Pct rdf:type rdf:Property ;
    rdfs:label 'Phred Q30 Pct' ;
    rdfs:comment 'Percentage of bases in reads assigned to this library that meet or exceed Phred quality score Q30 (≥99.9% base call accuracy). Key NGS quality metric; typically ≥80% Q30 is required for clinical-grade sequencing.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolingMethod rdf:type rdf:Property ;
    rdfs:label 'Pooling Method' ;
    rdfs:comment 'Method used to determine the volume of this library added to the pool. Options include equimolar normalization, volume-based, mass-based, qPCR-normalized, or fluorometric quantification-based pooling.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Name of the research or clinical project to which this library belongs within the pool. Used for downstream FASTQ file organization, billing allocation, and project-level reporting in BaseSpace Sequence Hub.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason code explaining why this library was removed from the pool. Populated only when assignment_status is \'removed\' or \'failed\'. Supports root cause analysis and CAPA (Corrective and Preventive Action) workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removed Timestamp' ;
    rdfs:comment 'Date and time when this library was removed or disqualified from the pool, if applicable. Null if the library remains active in the pool. Supports lifecycle tracking and investigation of failed runs.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleSheetPosition rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Position' ;
    rdfs:comment 'Row position of this library entry in the Illumina sample sheet (SampleSheet.csv) used to configure the sequencing run and demultiplexing. Ensures correct index-to-sample mapping during BCL conversion.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spikeInFlag rdf:type rdf:Property ;
    rdfs:label 'Spike In Flag' ;
    rdfs:comment 'Indicates whether this library entry represents a spike-in control (e.g., PhiX, synthetic spike-in) rather than a biological sample library. True = spike-in control; False = biological sample. Spike-ins are used for sequencing quality calibration and are excluded from biological analysis.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undeterminedReadFlag rdf:type rdf:Property ;
    rdfs:label 'Undetermined Read Flag' ;
    rdfs:comment 'Indicates whether this library contributed a disproportionate number of reads to the undetermined (unassigned) category during demultiplexing, suggesting index sequence issues or contamination. True = flagged; False = within acceptable threshold.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeAddedUl rdf:type rdf:Property ;
    rdfs:label 'Volume Added Ul' ;
    rdfs:comment 'Actual volume in microliters (µL) of this library pipetted into the pool. Critical for molar balance calculations and audit of physical pooling operations.' ;
    rdfs:domain ind:PoolLibrary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runFailureEventId rdf:type rdf:Property ;
    rdfs:label 'Run Failure Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each sequencing run failure or abort event record in the Silver layer lakehouse. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySequencingRunId rdf:type rdf:Property ;
    rdfs:label 'Primary Sequencing Run Id' ;
    rdfs:comment 'Reference to the sequencing run that experienced the failure or abort event. Links this failure record to the parent run entity for traceability and root-cause analysis.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SequencingRun .

ind:affectedLanes rdf:type rdf:Property ;
    rdfs:label 'Affected Lanes' ;
    rdfs:comment 'Comma-separated list or range notation of flow cell lane numbers affected by the failure event (e.g., \'1,2,3\' or \'1-4\' or \'ALL\'). Enables partial-lane failure analysis and assessment of sample impact scope. Null if failure affected the entire flow cell uniformly.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSampleCount rdf:type rdf:Property ;
    rdfs:label 'Affected Sample Count' ;
    rdfs:comment 'Number of samples whose sequencing data was lost or compromised as a result of this failure event. Drives impact assessment, customer notification decisions, and rerun prioritization. Sourced from the pool/library manifest associated with the failed run.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clusterDensityAtFailure rdf:type rdf:Property ;
    rdfs:label 'Cluster Density At Failure' ;
    rdfs:comment 'Flow cell cluster density (in thousands of clusters per mm²) measured at or near the time of failure. Abnormal cluster density (too high or too low) is a key diagnostic indicator for library preparation issues, loading concentration errors, or flow cell defects.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time at which the customer or project owner was formally notified of the failure event. Used to measure notification turnaround time (TAT) against SLA commitments and regulatory reporting timelines.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotified rdf:type rdf:Property ;
    rdfs:label 'Customer Notified' ;
    rdfs:comment 'Indicates whether the customer or project owner was formally notified of the sequencing run failure and its impact on their samples or data deliverables. Supports SLA compliance tracking and customer communication audit trails.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeDurationMin rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Min' ;
    rdfs:comment 'Total duration of instrument downtime in minutes attributable to this failure event, from failure detection to instrument return-to-service. Key input for instrument availability KPI calculation, OEE (Overall Equipment Effectiveness) reporting, and maintenance cost analysis.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDataLossGb rdf:type rdf:Property ;
    rdfs:label 'Estimated Data Loss Gb' ;
    rdfs:comment 'Estimated volume of sequencing data (in gigabases, Gb) lost as a result of the failure event. Calculated based on cycles completed, affected lanes, and expected yield per lane. Key metric for assessing business impact and prioritizing rerun decisions. Serves as the QUANTITATIVE_RESULT for this non-monetary transaction.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'High-level classification of the root cause category for the sequencing run failure. Used for trend analysis, quality KPI reporting, and directing corrective action. Categories align with standard GxP deviation classification taxonomy.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Structured alphanumeric code identifying the specific failure mode within the failure category. Sourced from the instrument error code library or quality management system codebook (e.g., INS-00142, REA-00031). Enables precise failure mode trending and FMEA alignment.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCycle rdf:type rdf:Property ;
    rdfs:label 'Failure Cycle' ;
    rdfs:comment 'The sequencing cycle number at which the failure or abort event occurred during the run. Critical for diagnosing instrument or chemistry issues at specific cycle positions (e.g., early cycles vs. late cycles). Null if failure occurred before sequencing commenced.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Free-text narrative description of the sequencing run failure event, including observed symptoms, error messages, and contextual details captured at the time of detection. Supports root-cause investigation and deviation report authoring.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failure Detected Timestamp' ;
    rdfs:comment 'The precise date and time at which the sequencing run failure or abort event was detected or reported. This is the principal real-world business event timestamp (BUSINESS_EVENT_TIMESTAMP) for this transaction, distinct from record audit timestamps.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureEventCode rdf:type rdf:Property ;
    rdfs:label 'Failure Event Code' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this failure event, used in deviation reports, CAPA references, and quality management system cross-references (e.g., RFE-20240315-0042). Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Status' ;
    rdfs:comment 'Current lifecycle status of the failure event record within the quality management workflow. Tracks progression from initial detection through investigation, resolution, and closure. Serves as the LIFECYCLE_STATUS for this transaction.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpImpacting rdf:type rdf:Property ;
    rdfs:label 'Gxp Impacting' ;
    rdfs:comment 'Indicates whether this failure event occurred in a GxP-regulated context (e.g., GMP, GLP, GCP) and therefore requires formal deviation management, CAPA, and regulatory documentation per applicable GxP guidelines. Drives regulatory reporting workflow routing.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Instrument Error Message' ;
    rdfs:comment 'Verbatim error message or fault code string reported by the sequencing instrument at the time of failure. Sourced directly from instrument logs or Illumina BaseSpace Sequence Hub run diagnostics. Essential for instrument engineering root-cause analysis.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ivdRun rdf:type rdf:Property ;
    rdfs:label 'Ivd Run' ;
    rdfs:comment 'Indicates whether the failed sequencing run was performed as part of an In Vitro Diagnostic (IVD) or Clinical Laboratory Developed Test (LDT) workflow, as opposed to a Research Use Only (RUO) application. Determines applicable regulatory reporting obligations (FDA, IVDR, CLIA).' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsEventCode rdf:type rdf:Property ;
    rdfs:label 'Lims Event Code' ;
    rdfs:comment 'The event or non-conformance record identifier from LabVantage LIMS corresponding to this failure event. Supports bidirectional traceability between the lakehouse Silver layer and the operational LIMS system of record.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phredScoreAtFailure rdf:type rdf:Property ;
    rdfs:label 'Phred Score At Failure' ;
    rdfs:comment 'The mean Phred base quality score (Q-score) recorded at the cycle of failure or at the last completed quality checkpoint before failure. Provides quantitative evidence of data quality degradation leading up to the failure event. Null if failure occurred before quality metrics were generated.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Number' ;
    rdfs:comment 'Lot number of the sequencing reagent kit used during the failed run. Critical for reagent failure root-cause analysis, lot-level quality investigations, and supplier corrective action requests. Aligns with GMP lot traceability requirements.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerunRequired rdf:type rdf:Property ;
    rdfs:label 'Rerun Required' ;
    rdfs:comment 'Indicates whether the failed sequencing run must be repeated to recover the lost data or meet the required coverage depth and quality thresholds. Drives rerun scheduling, resource allocation, and customer communication workflows.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleQualityIssue rdf:type rdf:Property ;
    rdfs:label 'Sample Quality Issue' ;
    rdfs:comment 'Indicates whether a sample quality problem (e.g., degraded DNA, low input concentration, contamination) was identified as a contributing factor to the run failure. Supports sample management quality trending and upstream LIMS feedback.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicenowTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Servicenow Ticket Number' ;
    rdfs:comment 'Reference to the ServiceNow incident or field service ticket created to manage the instrument repair or technical support response associated with this failure event. Enables cross-system traceability between quality events and IT/field service workflows.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCyclesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Cycles Planned' ;
    rdfs:comment 'The total number of sequencing cycles that were planned for the run at the time of setup. Used in conjunction with failure_cycle to calculate the proportion of the run completed before failure, informing data loss estimation.' ;
    rdfs:domain ind:RunFailureEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:libraryPoolId rdf:type rdf:Property ;
    rdfs:label 'Library Pool Id' ;
    rdfs:comment 'Reference to the multiplexed library pool or individual library loaded onto this lane. Enables traceability from lane-level sequencing output back to the sample preparation and library construction records in the LIMS.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pool .

ind:basecallingSoftware rdf:type rdf:Property ;
    rdfs:label 'Basecalling Software' ;
    rdfs:comment 'Name and version of the base calling software used to convert raw intensity signals to nucleotide sequences (FASTQ) for this lane (e.g., Illumina RTA 3.4.4, DRAGEN). Critical for data provenance, reproducibility, and regulatory traceability of genomic data.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basecallingSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Basecalling Software Version' ;
    rdfs:comment 'Version identifier of the base calling software used for this lane. Required for GxP audit trails and bioinformatics reproducibility; version changes may affect base quality scores and downstream variant calling results.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basespaceLaneCode rdf:type rdf:Property ;
    rdfs:label 'Basespace Lane Code' ;
    rdfs:comment 'Unique identifier for this lane as recorded in Illumina BaseSpace Sequence Hub, the primary system of record for sequencing data management. Enables direct linkage between the enterprise data lakehouse and the BaseSpace platform for data retrieval and audit.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clustersPassingFilterPct rdf:type rdf:Property ;
    rdfs:label 'Clusters Passing Filter Pct' ;
    rdfs:comment 'Percentage of clusters on this lane that pass the Illumina chastity filter, indicating the proportion of high-quality reads retained for downstream analysis. Industry benchmark is typically ≥75–80%. Low values indicate poor library quality, phasing issues, or flow cell defects.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demultiplexingStatus rdf:type rdf:Property ;
    rdfs:label 'Demultiplexing Status' ;
    rdfs:comment 'Current status of the demultiplexing process for this lane, which separates pooled sample reads by index barcode to generate per-sample FASTQ files. Tracks whether the bioinformatics demultiplexing step has been initiated, completed, or encountered errors.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorRatePct rdf:type rdf:Property ;
    rdfs:label 'Error Rate Pct' ;
    rdfs:comment 'Sequencing error rate for this lane, expressed as a percentage, calculated from PhiX alignment. Reflects the per-base mismatch rate against the PhiX reference and is a key indicator of instrument and reagent performance. Typical acceptable threshold is <1%.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fastqOutputPath rdf:type rdf:Property ;
    rdfs:label 'Fastq Output Path' ;
    rdfs:comment 'File system or cloud storage path (e.g., AWS S3 URI or BaseSpace project path) where the demultiplexed FASTQ files for this lane are stored. Enables downstream bioinformatics pipelines to locate and consume the raw sequencing data output.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReadLengthI1 rdf:type rdf:Property ;
    rdfs:label 'Index Read Length I1' ;
    rdfs:comment 'Length of Index Read 1 (i7 index) in base pairs used for demultiplexing samples on this lane. Defines the barcode length for sample identification in multiplexed sequencing runs.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexReadLengthI2 rdf:type rdf:Property ;
    rdfs:label 'Index Read Length I2' ;
    rdfs:comment 'Length of Index Read 2 (i5 index) in base pairs used for dual-index demultiplexing on this lane. Null for single-index runs. Dual indexing reduces index hopping and improves sample assignment accuracy in high-multiplex runs.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laneEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lane End Timestamp' ;
    rdfs:comment 'Date and time when sequencing completed on this lane. Together with lane_start_timestamp, enables calculation of lane-level sequencing duration and instrument cycle time for operational efficiency reporting.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laneFailureReason rdf:type rdf:Property ;
    rdfs:label 'Lane Failure Reason' ;
    rdfs:comment 'Free-text or coded description of the root cause when a lane fails QC (lane_qc_status = \'fail\'). Captures failure categories such as low cluster density, high error rate, low Q30, PhiX misalignment, or reagent lot issues. Used for root cause analysis, CAPA, and instrument troubleshooting.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneQcStatus rdf:type rdf:Property ;
    rdfs:label 'Lane Qc Status' ;
    rdfs:comment 'Overall Quality Control (QC) disposition for this lane based on cluster density, clusters passing filter, PhiX alignment, and yield thresholds. Drives downstream bioinformatics pipeline gating and sample release decisions. Satisfies TRANSACTION_LINE category: LINE_VALUE_OR_RESULT. [ENUM-REF-CANDIDATE: pass|fail|warning|pending|under_review|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lane Start Timestamp' ;
    rdfs:comment 'Date and time when sequencing commenced on this lane. Used for Turnaround Time (TAT) calculation, instrument utilization reporting, and scheduling of downstream bioinformatics processing. Satisfies TRANSACTION_LINE category: BUSINESS_EVENT_TIMESTAMP.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:laneYieldGb rdf:type rdf:Property ;
    rdfs:label 'Lane Yield Gb' ;
    rdfs:comment 'Total sequencing output (data yield) generated from this lane, expressed in gigabases (Gb). Primary throughput metric for lane-level performance assessment and SLA compliance. Satisfies TRANSACTION_LINE category: LINE_QUANTITY.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limsLaneReference rdf:type rdf:Property ;
    rdfs:label 'Lims Lane Reference' ;
    rdfs:comment 'External identifier for this lane record as assigned by the Laboratory Information Management System (LIMS), such as LabVantage. Enables cross-system traceability between the Databricks Silver Layer analytical record and the operational LIMS source of record.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanPhredQ30Pct rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Q30 Pct' ;
    rdfs:comment 'Percentage of bases on this lane with a Phred quality score ≥30 (Q30), indicating a base call accuracy of 99.9% or higher. Industry-standard quality threshold for NGS data; Illumina specifies Q30 ≥75–80% as a minimum acceptance criterion for most applications.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numSamplesMultiplexed rdf:type rdf:Property ;
    rdfs:label 'Num Samples Multiplexed' ;
    rdfs:comment 'Count of individual samples multiplexed (pooled) and loaded onto this lane. Determines the expected per-sample read depth after demultiplexing and is a key parameter for capacity planning and SLA compliance per sample.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phixAlignmentPct rdf:type rdf:Property ;
    rdfs:label 'Phix Alignment Pct' ;
    rdfs:comment 'Percentage of reads on this lane that aligned to the PhiX reference genome. Used to validate the PhiX spike-in and assess lane-level sequencing error rate. Significant deviation from the expected PhiX spike-in percentage indicates a lane-level quality issue.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewed By' ;
    rdfs:comment 'Reference to the Quality Control (QC) scientist or analyst who reviewed and approved or rejected the lane QC results. Required for GxP electronic signature compliance and audit trail integrity under FDA 21 CFR Part 11.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readsPassingFilter rdf:type rdf:Property ;
    rdfs:label 'Reads Passing Filter' ;
    rdfs:comment 'Number of reads on this lane that passed the Illumina chastity filter and are available for downstream bioinformatics processing. Directly determines the effective sequencing depth available for variant calling and genomic analysis.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requeueCount rdf:type rdf:Property ;
    rdfs:label 'Requeue Count' ;
    rdfs:comment 'Number of times this lane has been requeued for resequencing due to QC failure or insufficient yield. Tracks repeat failure patterns for root cause analysis and supports escalation decisions when a lane repeatedly fails.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requeueRequired rdf:type rdf:Property ;
    rdfs:label 'Requeue Required' ;
    rdfs:comment 'Indicates whether this lane requires resequencing (requeue) due to QC failure or insufficient yield. Triggers downstream sample management and scheduling workflows in the LIMS to prioritize reruns and maintain customer SLA commitments.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetClusterDensityKPerMm2 rdf:type rdf:Property ;
    rdfs:label 'Target Cluster Density K Per Mm2' ;
    rdfs:comment 'Instrument- and flow-cell-specific target cluster density in thousands per square millimeter (K/mm²) for this lane, as defined in the sequencing SOP. Used to assess whether the actual cluster density (cluster_density_k_per_mm2) is within the acceptable operating range.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetYieldGb rdf:type rdf:Property ;
    rdfs:label 'Target Yield Gb' ;
    rdfs:comment 'Expected or contracted sequencing yield in gigabases (Gb) for this lane, as defined by the run plan or customer SLA. Used to assess whether the actual lane yield (lane_yield_gb) meets the planned output and to trigger reruns or escalations when yield is insufficient.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:undeterminedReadsPct rdf:type rdf:Property ;
    rdfs:label 'Undetermined Reads Pct' ;
    rdfs:comment 'Percentage of reads on this lane that could not be assigned to a sample index during demultiplexing. High undetermined read rates indicate index contamination, index hopping, or sample sheet errors. Typically acceptable threshold is <5–10%.' ;
    rdfs:domain ind:RunLane ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runQcMetricId rdf:type rdf:Property ;
    rdfs:label 'Run Qc Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each run QC metric record. Serves as the primary key for this transactional entity capturing quantitative quality measurements at run, lane, or library granularity. Entity role: TRANSACTION_HEADER — stores discrete QC measurement events with a clear lifecycle and multiple metric dimensions sourced from Illumina InterOp, BaseSpace, bcl2fastq, Picard, and samtools.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alignmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Alignment Rate Percent' ;
    rdfs:comment 'Percentage of reads that successfully aligned to the reference genome. Low alignment rates may indicate sample contamination, wrong species, or library preparation failures. Sourced from samtools flagstat or DRAGEN alignment metrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clustersPassingFilterPercent rdf:type rdf:Property ;
    rdfs:label 'Clusters Passing Filter Percent' ;
    rdfs:comment 'Percentage of clusters that pass Illumina\'s chastity filter, indicating the proportion of high-quality reads retained after filtering. A key run-level QC metric; typically ≥75–85% is expected for acceptable run quality. Sourced from Illumina InterOp.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duplication Rate Percent' ;
    rdfs:comment 'Percentage of reads identified as PCR or optical duplicates, which are removed prior to variant calling. High duplication rates reduce effective coverage and indicate over-amplification during library preparation. Sourced from Picard MarkDuplicates.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcBiasIndex rdf:type rdf:Property ;
    rdfs:label 'Gc Bias Index' ;
    rdfs:comment 'Quantitative measure of GC content bias in sequencing coverage, indicating the degree to which GC-rich or GC-poor regions are over- or under-represented relative to expected coverage. Values near 0 indicate minimal bias. Sourced from Picard CollectGcBiasMetrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Mean Insert Size Bp' ;
    rdfs:comment 'Average size of the DNA fragment inserted between sequencing adapters, in base pairs. Reflects library preparation quality; deviations from expected insert size indicate degradation, over-fragmentation, or adapter contamination. Sourced from Picard CollectInsertSizeMetrics.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricGranularityLevel rdf:type rdf:Property ;
    rdfs:label 'Metric Granularity Level' ;
    rdfs:comment 'Indicates the level of aggregation at which this QC metric record applies: \'run\' for instrument-wide metrics, \'lane\' for per-lane flow cell metrics, or \'library\' for per-library/per-sample coverage metrics. Determines which metric fields are populated and how the record is used in QC workflows.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Metric Source System' ;
    rdfs:comment 'Identifies the upstream tool or system from which this QC metric record was derived: Illumina InterOp files, BaseSpace, bcl2fastq demultiplexing stats, Picard alignment tools, samtools, DRAGEN, or other. Supports data lineage tracking and metric reproducibility audits. [ENUM-REF-CANDIDATE: InterOp|BaseSpace|bcl2fastq|Picard|samtools|DRAGEN|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfReads rdf:type rdf:Property ;
    rdfs:label 'Pf Reads' ;
    rdfs:comment 'Number of reads passing Illumina\'s chastity filter (PF reads), representing high-quality reads used in downstream alignment and variant calling. Distinct from total_reads which includes all raw clusters. Sourced from Illumina InterOp or bcl2fastq.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phixAlignmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Phix Alignment Rate Percent' ;
    rdfs:comment 'Percentage of reads that align to the PhiX bacteriophage control genome, which is spiked into sequencing runs as an internal quality control standard. Used to validate sequencing chemistry performance and calibrate error rate measurements.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phixErrorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Phix Error Rate Percent' ;
    rdfs:comment 'Sequencing error rate calculated from PhiX control reads, providing an unbiased measure of instrument and chemistry accuracy independent of sample biology. Sourced from Illumina InterOp. Used for instrument performance trending and GxP compliance.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the QC review and sign-off was completed for this metric record. Supports GxP audit trail, turnaround time (TAT) tracking, and regulatory submission documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readType rdf:type rdf:Property ;
    rdfs:label 'Read Type' ;
    rdfs:comment 'Indicates whether the sequencing run used single-end or paired-end read chemistry. Paired-end reads provide improved alignment accuracy and structural variant detection. Affects coverage calculation and bioinformatics pipeline configuration.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:undeterminedIndexRatePercent rdf:type rdf:Property ;
    rdfs:label 'Undetermined Index Rate Percent' ;
    rdfs:comment 'Percentage of reads that could not be assigned to a sample index during demultiplexing, indicating index hopping, contamination, or library preparation issues. High undetermined rates may trigger run failure or sample reprocessing. Sourced from bcl2fastq demultiplexing stats.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldGb rdf:type rdf:Property ;
    rdfs:label 'Yield Gb' ;
    rdfs:comment 'Total sequencing output in gigabases (Gb) for the run, lane, or library. Represents the volume of sequence data generated and is used to assess whether sufficient data was produced to meet coverage requirements for the assay type. Sourced from Illumina BaseSpace or bcl2fastq.' ;
    rdfs:domain ind:RunQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runSampleSheetId rdf:type rdf:Property ;
    rdfs:label 'Run Sample Sheet Id' ;
    rdfs:comment 'Unique surrogate identifier for the run sample sheet record in the Databricks Silver Layer. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adapterRead1 rdf:type rdf:Property ;
    rdfs:label 'Adapter Read1' ;
    rdfs:comment 'The adapter sequence to be trimmed from the 3\' end of Read 1 during BCLConvert processing (e.g., AGATCGGAAGAGCACACGTCTGAACTCCAGTCA for TruSeq). Correct adapter specification is critical for accurate read trimming and downstream alignment quality.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adapterRead2 rdf:type rdf:Property ;
    rdfs:label 'Adapter Read2' ;
    rdfs:comment 'The adapter sequence to be trimmed from the 3\' end of Read 2 in paired-end runs (e.g., AGATCGGAAGAGCGTCGTGTAGGGAAAGAGTGT for TruSeq). Null for single-end runs. Must match the library preparation kit adapter chemistry.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demultiplexingSoftware rdf:type rdf:Property ;
    rdfs:label 'Demultiplexing Software' ;
    rdfs:comment 'The software tool configured to process this sample sheet for demultiplexing BCL files into per-sample FASTQ files. Options include BCLConvert (current Illumina standard), bcl2fastq (legacy), or DRAGEN (on-instrument or cloud). Determines compatible sample sheet sections and parameter keys.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demultiplexingSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Demultiplexing Software Version' ;
    rdfs:comment 'Version string of the demultiplexing software (BCLConvert, bcl2fastq, or DRAGEN) specified in the sample sheet settings. Critical for reproducibility, pipeline validation, and regulatory submission documentation.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'The experiment identifier or label captured in the [Header] section of the Illumina sample sheet. Provides a human-readable label for the run experiment, used for BaseSpace project organization and LIMS cross-referencing.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:index1Cycles rdf:type rdf:Property ;
    rdfs:label 'Index1 Cycles' ;
    rdfs:comment 'Number of cycles for Index 1 (i7 index read) used in multiplexed library demultiplexing. Typically 8 or 10 cycles. Determines the length of the i7 barcode sequence read during the indexing phase.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:index2Cycles rdf:type rdf:Property ;
    rdfs:label 'Index2 Cycles' ;
    rdfs:comment 'Number of cycles for Index 2 (i5 index read) used in dual-indexed multiplexed library demultiplexing. Typically 8 or 10 cycles. Null for single-indexed runs. Required for dual-index demultiplexing workflows.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexAdapterKit rdf:type rdf:Property ;
    rdfs:label 'Index Adapter Kit' ;
    rdfs:comment 'The specific index adapter kit used for multiplexing (e.g., IDT for Illumina DNA/RNA UD Indexes, Nextera DNA CD Indexes). Defines the index sequence set and ensures correct barcode assignment during demultiplexing.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Name of the principal investigator or study lead responsible for the samples in this run. Captured in the [Header] section of the Illumina sample sheet. Used for accountability, reporting, and GxP traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPrepKit rdf:type rdf:Property ;
    rdfs:label 'Library Prep Kit' ;
    rdfs:comment 'The name and version of the library preparation kit used to prepare samples for sequencing (e.g., Illumina DNA Prep, TruSeq DNA PCR-Free, Nextera DNA Flex). Determines adapter sequences, index compatibility, and recommended run parameters.' ;
    rdfs:domain ind:Sequencing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsRequestCode rdf:type rdf:Property ;
    rdfs:label 'Lims Request Code' ;
    rdfs:comment 'The work order or sequencing request identifier from LabVantage LIMS that initiated this sample sheet. Provides bidirectional traceability between the sample sheet and the originating laboratory workflow request.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maskShortReads rdf:type rdf:Property ;
    rdfs:label 'Mask Short Reads' ;
    rdfs:comment 'The MaskShortReads BCLConvert setting specifying the read length threshold below which reads are masked (replaced with Ns) rather than discarded. Complements minimum_trimmed_read_length to control short-read handling behavior in FASTQ output.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumTrimmedReadLength rdf:type rdf:Property ;
    rdfs:label 'Minimum Trimmed Read Length' ;
    rdfs:comment 'The MinimumTrimmedReadLength BCLConvert setting specifying the minimum acceptable read length (in base pairs) after adapter trimming. Reads shorter than this threshold are discarded. Impacts FASTQ output quality and downstream alignment performance.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideCyclesString rdf:type rdf:Property ;
    rdfs:label 'Override Cycles String' ;
    rdfs:comment 'The OverrideCycles parameter string in Illumina sample sheet v2 format (e.g., \'Y151;I8;I8;Y151\') that explicitly defines the cycle allocation for each read and index segment. Overrides default cycle settings and is used by BCLConvert for precise demultiplexing configuration.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:read1Cycles rdf:type rdf:Property ;
    rdfs:label 'Read1 Cycles' ;
    rdfs:comment 'Number of sequencing cycles for Read 1 (forward read). Directly determines the read length in base pairs for the primary read. Typical values range from 50 to 300 cycles depending on application and instrument platform.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:read2Cycles rdf:type rdf:Property ;
    rdfs:label 'Read2 Cycles' ;
    rdfs:comment 'Number of sequencing cycles for Read 2 (reverse read) in paired-end runs. Null for single-end runs. Must match Read 1 cycles for symmetric paired-end configurations or may differ for asymmetric designs.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runSampleSheetDescription rdf:type rdf:Property ;
    rdfs:label 'Run Sample Sheet Description' ;
    rdfs:comment 'Free-text description field from the [Header] section of the Illumina sample sheet. May include run purpose, special instructions, or notes relevant to the sequencing configuration. Supports operational context for lab staff.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetFormatVersion rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Format Version' ;
    rdfs:comment 'Version of the Illumina sample sheet format used (v1 or v2). v2 supports multi-section configuration including [Header], [Reads], [BCLConvert_Settings], and [BCLConvert_Data] sections. Determines downstream demultiplexing compatibility and parser behavior.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSheetName rdf:type rdf:Property ;
    rdfs:label 'Sample Sheet Name' ;
    rdfs:comment 'Human-readable name or title assigned to the sample sheet file, typically following the Illumina naming convention (e.g., SampleSheet_RunID_YYYYMMDD). Serves as the externally-known business identifier for this document. Aligns with Illumina BaseSpace Sequence Hub sample sheet naming standards.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorSummary rdf:type rdf:Property ;
    rdfs:label 'Validation Error Summary' ;
    rdfs:comment 'Free-text summary of validation errors or warnings identified during automated sample sheet validation (e.g., index collision detected, invalid cycle count, missing required fields). Populated when validation_status is \'failed_validation\'. Supports rapid troubleshooting by lab operators.' ;
    rdfs:domain ind:RunSampleSheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedKitCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Approved Kit Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Validated sequencing protocols specify approved/compatible kit catalog items. Essential for SOP compliance, regulatory submissions (FDA/IVDR), quality system requirements, and ensuring only validated ' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:approvedLibraryPrepKits rdf:type rdf:Property ;
    rdfs:label 'Approved Library Prep Kits' ;
    rdfs:comment 'Comma-separated list of approved library preparation kit names and catalog numbers validated for use with this sequencing protocol (e.g., \'Illumina DNA Prep (20018704), TruSeq DNA PCR-Free (20015963)\'). Only kits on this list may be used in GxP-regulated runs. Validated in Benchling and controlled in MasterControl.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccredited rdf:type rdf:Property ;
    rdfs:label 'Cap Accredited' ;
    rdfs:comment 'Indicates whether this protocol is covered under a CAP-accredited laboratory\'s scope of accreditation. True = included in CAP accreditation scope; False = not within CAP scope. Relevant for clinical genomics laboratories reporting patient results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaValidated rdf:type rdf:Property ;
    rdfs:label 'Clia Validated' ;
    rdfs:comment 'Indicates whether this protocol has been validated under CLIA requirements for clinical laboratory use. True = CLIA validation completed and documented; False = not CLIA validated (RUO or research only). Required for protocols used in LDT or clinical reporting contexts.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demultiplexingTool rdf:type rdf:Property ;
    rdfs:label 'Demultiplexing Tool' ;
    rdfs:comment 'Approved software tool used to demultiplex raw BCL files into per-sample FASTQ files for this protocol. Governs the bioinformatics pipeline entry point. BCL Convert is the current Illumina-recommended tool; DRAGEN provides accelerated on-instrument demultiplexing.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:index1CycleCount rdf:type rdf:Property ;
    rdfs:label 'Index1 Cycle Count' ;
    rdfs:comment 'Number of cycles for the Index 1 (i7) read used in multiplexing to demultiplex samples on a shared flow cell. Typically 8 or 10 cycles. Required for all multiplexed library pools. Null for non-indexed single-sample runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:index2CycleCount rdf:type rdf:Property ;
    rdfs:label 'Index2 Cycle Count' ;
    rdfs:comment 'Number of cycles for the Index 2 (i5) read used in dual-index multiplexing schemes. Typically 8 or 10 cycles. Null for single-index or non-indexed protocols. Dual indexing reduces index-hopping artifacts in high-multiplex runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxClusterDensity rdf:type rdf:Property ;
    rdfs:label 'Max Cluster Density' ;
    rdfs:comment 'Maximum acceptable cluster density on the flow cell surface in K/mm². Exceeding this threshold causes cluster overlap (over-clustering), degrading base call quality and Q30 scores. Paired with min_cluster_density to define the acceptable loading range.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Max Insert Size Bp' ;
    rdfs:comment 'Maximum acceptable DNA insert size in base pairs for library fragments. Inserts exceeding this threshold may indicate insufficient fragmentation, leading to reduced cluster density and read-through artifacts. Paired with min_insert_size_bp to define the acceptable library size range.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minClusterDensity rdf:type rdf:Property ;
    rdfs:label 'Min Cluster Density' ;
    rdfs:comment 'Minimum acceptable cluster density on the flow cell surface, expressed in thousands of clusters per square millimeter (K/mm²). Below this threshold, insufficient data yield is expected. Used as a pre-run and mid-run QC gate in Illumina BaseSpace.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Min Insert Size Bp' ;
    rdfs:comment 'Minimum acceptable DNA insert size in base pairs for library fragments sequenced under this protocol. Insert sizes below this threshold indicate over-fragmentation and may degrade paired-end alignment quality. Used as a library QC acceptance criterion in LabVantage LIMS.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minQ30ThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Min Q30 Threshold Pct' ;
    rdfs:comment 'Minimum acceptable percentage of bases with a Phred quality score of 30 or higher (Q30), indicating ≥99.9% base call accuracy. Industry-standard QC gate for sequencing run acceptance. Runs falling below this threshold are flagged for investigation or resequencing. Typically ≥75% for most NGS applications.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minYieldGb rdf:type rdf:Property ;
    rdfs:label 'Min Yield Gb' ;
    rdfs:comment 'Minimum acceptable total sequencing data yield in gigabases (Gb) per run or per sample lane, as required to achieve the target coverage depth. Runs not meeting this threshold trigger a QC failure and potential resequencing. Derived from target coverage, genome size, and read length.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiplexingMaxSamples rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Max Samples' ;
    rdfs:comment 'Maximum number of samples that can be pooled and multiplexed on a single flow cell lane under this protocol while maintaining the target coverage depth per sample. Governs library pooling decisions in LabVantage LIMS and run planning in BaseSpace.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phiDataGenerated rdf:type rdf:Property ;
    rdfs:label 'Phi Data Generated' ;
    rdfs:comment 'Indicates whether sequencing runs executed under this protocol generate Protected Health Information (PHI) as defined by HIPAA. True = PHI is generated (clinical patient samples); False = no PHI (research/RUO samples). Governs data handling, storage, and access control requirements for resulting FASTQ and downstream files.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolCode rdf:type rdf:Property ;
    rdfs:label 'Protocol Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this protocol and version (e.g., WGS-PCR-v2.1). Used as the business identifier across LIMS, BaseSpace, and regulatory submissions. Serves as the BUSINESS_IDENTIFIER category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:r1CycleCount rdf:type rdf:Property ;
    rdfs:label 'R1 Cycle Count' ;
    rdfs:comment 'Number of sequencing cycles for Read 1 (R1), determining the read length in base pairs for the forward read. Common values include 75, 100, 150, 250 cycles. Directly impacts data quality, coverage, and FASTQ file size. Serves as the MEASUREMENT_OR_VALUE category for MASTER_RESOURCE role.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:r2CycleCount rdf:type rdf:Property ;
    rdfs:label 'R2 Cycle Count' ;
    rdfs:comment 'Number of sequencing cycles for Read 2 (R2) in paired-end configurations. Null for single-end protocols. Must match R1 cycle count for symmetric paired-end runs or may differ for asymmetric configurations. Governs reverse read length in base pairs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequencingApplicationType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Application Type' ;
    rdfs:comment 'Classification of the genomic sequencing application this protocol supports. Serves as the CLASSIFICATION_OR_TYPE category for MASTER_RESOURCE role. Drives downstream bioinformatics pipeline selection and QC thresholds. WGS = Whole Genome Sequencing; WES = Whole Exome Sequencing; RNA-seq = RNA Sequencing.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingProtocolDescription rdf:type rdf:Property ;
    rdfs:label 'Sequencing Protocol Description' ;
    rdfs:comment 'Free-text narrative description of the sequencing protocol, including its scientific rationale, key distinguishing parameters, intended sample types, and any special handling requirements. Authored by the protocol owner and reviewed during the GxP approval process.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByProtocolCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Protocol Code' ;
    rdfs:comment 'Protocol code of the newer version that replaces this protocol upon retirement. Null for the current active version. Enables forward navigation in the protocol version chain for change control traceability and migration of active runs.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPanelBedFile rdf:type rdf:Property ;
    rdfs:label 'Target Panel Bed File' ;
    rdfs:comment 'File path or artifact identifier for the BED (Browser Extensible Data) file defining the genomic target regions for targeted panel or WES protocols. Null for WGS protocols. Used by bioinformatics pipelines for on-target coverage calculation and variant calling region restriction. Stored in genomic artifact repository.' ;
    rdfs:domain ind:SequencingProtocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentAssetId rdf:type rdf:Property ;
    rdfs:label 'Instrument Asset Id' ;
    rdfs:comment 'FK to instrument.instrument_asset.instrument_asset_id — Sequencing runs must reference the physical instrument they executed on for instrument utilization tracking, maintenance correlation, and performance trending.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primarySequencingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sequencing Employee Id' ;
    rdfs:comment 'Reference to the laboratory operator or scientist who initiated and is responsible for this sequencing run. Supports GxP audit trail and operator accountability requirements.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clusterPfPct rdf:type rdf:Property ;
    rdfs:label 'Cluster Pf Pct' ;
    rdfs:comment 'Percentage of clusters that pass the Illumina chastity filter (PF = Passing Filter), indicating the proportion of reads with sufficient signal purity for reliable base calling. A key run-level QC metric; typically expected to be >75-80% for a passing run.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRetentionCategory rdf:type rdf:Property ;
    rdfs:label 'Data Retention Category' ;
    rdfs:comment 'Data retention classification for this sequencing run record and its associated FASTQ/BAM/VCF outputs, determining the minimum retention period per applicable regulations. \'standard\' = 2 years (RUO); \'extended\' = 10+ years (clinical/GxP); \'permanent\' = indefinite (regulatory submission data); \'restricted_deletion\' = deletion requires regulatory approval.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:folderName rdf:type rdf:Property ;
    rdfs:label 'Folder Name' ;
    rdfs:comment 'The instrument-generated run folder name following Illumina naming convention (e.g., \'240115_A00001_0001_AHXXXXXX\'). Contains date, instrument serial, run number, and flow cell ID. Used for data traceability between instrument output and enterprise data systems.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexReadLength rdf:type rdf:Property ;
    rdfs:label 'Index Read Length' ;
    rdfs:comment 'Number of base pairs sequenced for the index (barcode) reads used in multiplexing/demultiplexing. Typically 6, 8, or 10 bp per index. Determines the number of samples that can be multiplexed on a single flow cell and the accuracy of demultiplexing.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputYieldGb rdf:type rdf:Property ;
    rdfs:label 'Output Yield Gb' ;
    rdfs:comment 'Total sequencing data output generated by this run measured in gigabases (Gb). Represents the QUANTITATIVE_RESULT for this non-monetary TRANSACTION_HEADER. Used for run performance benchmarking, storage capacity planning, and comparison against instrument specifications.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedSampleCount rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Count' ;
    rdfs:comment 'Number of samples planned to be multiplexed and sequenced in this run as defined in the sample sheet at run setup. Used for capacity planning, reagent consumption estimation, and comparison against actual demultiplexed sample count.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:q30Pct rdf:type rdf:Property ;
    rdfs:label 'Q30 Pct' ;
    rdfs:comment 'Percentage of bases with a Phred quality score of 30 or higher (Q30), indicating ≥99.9% base call accuracy. The primary industry-standard run quality metric. Typically required to be >75-80% for a run to pass QC. Directly impacts variant calling accuracy and clinical reporting confidence.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Externally-known business identifier for the sequencing run, assigned by the LIMS or laboratory operations system. Used for cross-system referencing, customer reporting, and regulatory traceability. Serves as the BUSINESS_IDENTIFIER for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCycles rdf:type rdf:Property ;
    rdfs:label 'Total Cycles' ;
    rdfs:comment 'Total number of sequencing chemistry cycles executed in this run. For paired-end runs, this includes both read 1, index reads, and read 2 cycles (e.g., 2×150 bp = 300 cycles + index cycles). Used for run cost accounting, reagent consumption tracking, and run configuration validation.' ;
    rdfs:domain ind:SequencingRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plantId rdf:type rdf:Property ;
    rdfs:label 'Plant Id' ;
    rdfs:comment 'Reference to the manufacturing plant or facility where the batch was produced. Links to the facility master in the supply or manufacturing domain.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Reference to the production order under which this batch was manufactured. Null for procured batches. Links to manufacturing domain.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity from this batch that is blocked for quality or compliance reasons and cannot be used or shipped until released.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Source of the batch indicating whether it was produced internally, procured from an external supplier, manufactured by a contract manufacturer, reworked from a previous batch, or is a sample batch.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qc Release Date' ;
    rdfs:comment 'Date on which the batch was officially released by Quality Assurance for use or distribution. Null if batch is not yet released.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date on which the recall was initiated for this batch. Null if no recall has been issued.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch is subject to a product recall. True triggers immediate inventory blocking and customer notification workflows.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Detailed explanation of why the batch was recalled. Includes quality defect description, safety concern, or regulatory non-compliance issue.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeQuantity rdf:type rdf:Property ;
    rdfs:label 'Size Quantity' ;
    rdfs:comment 'Total quantity produced or procured in this batch. Expressed in the base unit of measure for the material.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeUom rdf:type rdf:Property ;
    rdfs:label 'Size Uom' ;
    rdfs:comment 'Unit of measure for the batch size quantity. Examples: EA (each), KG (kilogram), L (liter), ML (milliliter).' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Batch Number' ;
    rdfs:comment 'Original batch or lot number assigned by the supplier for externally procured materials. Used for supplier traceability and quality investigations.' ;
    rdfs:domain ind:Batch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandPlanId rdf:type rdf:Property ;
    rdfs:label 'Demand Plan Id' ;
    rdfs:comment 'Unique identifier for the demand plan record. Primary key for the demand plan entity.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousPlanDemandPlanId rdf:type rdf:Property ;
    rdfs:label 'Previous Plan Demand Plan Id' ;
    rdfs:comment 'Reference to the prior version of this demand plan, enabling revision history tracking and audit trail.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemandPlan .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the confidence interval for the forecasted quantity. Represents the minimum expected demand under normal variability.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the confidence interval for the forecasted quantity. Represents the maximum expected demand under normal variability.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevelPercentage rdf:type rdf:Property ;
    rdfs:label 'Confidence Level Percentage' ;
    rdfs:comment 'Statistical confidence level associated with the forecast interval, typically 90%, 95%, or 99%. Indicates the probability that actual demand will fall within the confidence interval.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerOrderBacklogQuantity rdf:type rdf:Property ;
    rdfs:label 'Customer Order Backlog Quantity' ;
    rdfs:comment 'Quantity of confirmed customer orders not yet fulfilled. Represents committed demand that must be satisfied in the planning period.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandCategory rdf:type rdf:Property ;
    rdfs:label 'Demand Category' ;
    rdfs:comment 'Classification of demand type. Independent demand is driven by customer orders (finished goods), dependent demand is driven by production schedules (components), and service parts demand is driven by maintenance and support needs.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandSignalSource rdf:type rdf:Property ;
    rdfs:label 'Demand Signal Source' ;
    rdfs:comment 'Origin of the demand signal driving the forecast. Indicates whether demand is driven by sales forecasts, production schedules, safety stock replenishment needs, confirmed customer orders, promotional campaigns, or new product launches.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Historical accuracy of the forecast method for this material and plant combination, expressed as a percentage. Used to assess forecast reliability and adjust safety stock levels.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'Methodology used to generate the demand forecast. Indicates whether the forecast was derived from statistical models, consensus planning sessions, MRP net requirements, manual planner input, machine learning algorithms, or historical averages.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedQuantity rdf:type rdf:Property ;
    rdfs:label 'Forecasted Quantity' ;
    rdfs:comment 'Predicted demand quantity for the material during the planning period. Represents units of reagent kits, flow cells, instruments, or other genomics products required to meet anticipated customer orders and production schedules.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpElementType rdf:type rdf:Property ;
    rdfs:label 'Mrp Element Type' ;
    rdfs:comment 'Type of MRP element generated or influenced by this demand plan. Indicates whether the plan drives planned orders, purchase requisitions, production orders, or stock transfers.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the demand plan. Tracks whether the plan is in draft, approved for execution, actively driving procurement, superseded by a newer version, or archived.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerName rdf:type rdf:Property ;
    rdfs:label 'Planner Name' ;
    rdfs:comment 'Name of the demand planner or supply chain analyst responsible for creating and maintaining this demand plan.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannerNotes rdf:type rdf:Property ;
    rdfs:label 'Planner Notes' ;
    rdfs:comment 'Free-text notes and comments from the demand planner. May include assumptions, market intelligence, customer feedback, or adjustments made to statistical forecasts.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time granularity of the demand plan. Indicates whether the plan is weekly, monthly, quarterly, or annual.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period for which demand is forecasted.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period for which demand is forecasted. Typically aligned with monthly, quarterly, or weekly planning cycles.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procurementTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Procurement Trigger Flag' ;
    rdfs:comment 'Indicates whether the demand plan has triggered a procurement action. True when forecasted demand exceeds available inventory and requires purchase order creation.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionPlanQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Plan Quantity' ;
    rdfs:comment 'Demand quantity derived from production schedules and manufacturing plans. Represents materials required to support planned production runs of reagent kits, library prep kits, or instrument assembly.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalImpactQuantity rdf:type rdf:Property ;
    rdfs:label 'Promotional Impact Quantity' ;
    rdfs:comment 'Additional demand quantity expected due to promotional campaigns, product launches, or marketing initiatives.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'Inventory level at which procurement or production should be triggered to replenish stock. Calculated based on lead time demand and safety stock requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number tracking changes to the demand plan over time. Incremented each time the plan is updated.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer inventory quantity maintained to protect against demand variability and supply disruptions. Critical for high-value genomics consumables with long lead times.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesForecastQuantity rdf:type rdf:Property ;
    rdfs:label 'Sales Forecast Quantity' ;
    rdfs:comment 'Demand quantity derived from sales team forecasts and customer pipeline analysis. Represents anticipated customer orders for NGS kits, microarray products, or CRISPR tools.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplier applied to baseline forecast to account for seasonal demand patterns. Values greater than 1.0 indicate peak seasons, values less than 1.0 indicate off-peak periods.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierCapacityReservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Supplier Capacity Reserved Quantity' ;
    rdfs:comment 'Quantity of supplier production capacity reserved based on this demand plan. Ensures critical raw materials and components for genomics products are available when needed.' ;
    rdfs:domain ind:DemandPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Primary key for goods_receipt' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Received By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GMP/GxP regulations require personnel accountability for all material receipts. Enables training qualification verification (only qualified personnel can receive GMP materials), audit trails, and pers' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:coldChainLogReference rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Log Reference' ;
    rdfs:comment 'Reference to the cold chain temperature monitoring log for temperature-sensitive genomics reagents and biologics. Critical for ensuring material integrity and regulatory compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Company Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the company code currency used in consolidated reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpBatchRecordReference rdf:type rdf:Property ;
    rdfs:label 'Gmp Batch Record Reference' ;
    rdfs:comment 'Reference to the GMP batch manufacturing record for materials issued to or received from production. Mandatory for FDA-regulated manufacturing operations.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Material Document Line Item' ;
    rdfs:comment 'Line item number within the material document. Enables tracking of individual material movements within a single document.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialDocumentYear rdf:type rdf:Property ;
    rdfs:label 'Material Document Year' ;
    rdfs:comment 'Fiscal year in which the material document was posted. Part of the composite key in SAP MM along with material document number.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Movement Type Description' ;
    rdfs:comment 'Human-readable description of the movement type for reporting and user interfaces.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementValueCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Movement Value Company Currency' ;
    rdfs:comment 'Total value of the goods movement in company code currency for consolidated financial reporting. Confidential for competitive pricing protection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:movementValueLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Movement Value Local Currency' ;
    rdfs:comment 'Total value of the goods movement in local plant currency. Used for inventory valuation, COGS calculation, and financial reporting. Confidential for competitive pricing protection.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Production Order Number' ;
    rdfs:comment 'Reference to the production order for goods issues to manufacturing (movement type 261) or finished goods receipts from production. Critical for manufacturing cost allocation and work-in-process tracking.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Stock Indicator' ;
    rdfs:comment 'SAP special stock type: E (sales order stock), K (consignment stock), O (project stock), Q (quality inspection stock), W (blocked stock). Critical for inventory segregation and financial reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Split valuation type for materials with multiple valuation classes (e.g., RUO vs IVD grade reagents). Enables separate inventory valuation for materials with different quality grades or regulatory classifications.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'SAP vendor account number. Retained for cross-system reconciliation and legacy reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment physically arrived at the receiving dock. Critical for TAT (Turnaround Time) measurement and SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Carrier-issued document serving as receipt of goods and contract of carriage. Required for international shipments and freight claims.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Device Code' ;
    rdfs:comment 'Identifier of the temperature monitoring device attached to the shipment. Essential for reagent and consumable shipments requiring temperature control per GMP (Good Manufacturing Practice).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Commercial Invoice Number' ;
    rdfs:comment 'Supplier invoice number associated with this delivery. Used for three-way match in accounts payable (invoice, PO, goods receipt).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'Date when customs clearance was completed for international shipments. Impacts delivery lead time and TAT (Turnaround Time).' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Status of customs clearance process for international shipments. Critical for cross-border deliveries of reagents, instruments, and consumables.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteText rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Text' ;
    rdfs:comment 'Free-text notes or special instructions related to the inbound delivery. Captures handling requirements, supplier communications, or receiving observations.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known business identifier for the inbound delivery document. Used for tracking and communication with suppliers.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'Date when goods receipt was posted in the system, triggering inventory update and invoice verification. Key event for COGS (Cost of Goods Sold) recognition.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Max Temperature Celsius' ;
    rdfs:comment 'Highest temperature recorded during shipment transit in degrees Celsius. Used for cold-chain validation and quality assessment.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Min Temperature Celsius' ;
    rdfs:comment 'Lowest temperature recorded during shipment transit in degrees Celsius. Used for cold-chain validation and quality assessment.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDeliveryDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Document Url' ;
    rdfs:comment 'URL or file path to the signed proof of delivery document. Used for dispute resolution and freight claim processing.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDockLocation rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock Location' ;
    rdfs:comment 'Specific dock, bay, or receiving area within the facility where the delivery was unloaded. Used for warehouse operations and material flow tracking.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'Total volume of the inbound delivery in cubic meters. Used for warehouse space allocation and freight cost calculation.' ;
    rdfs:domain ind:InboundDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStockId rdf:type rdf:Property ;
    rdfs:label 'Inventory Stock Id' ;
    rdfs:comment 'Unique identifier for the inventory stock record. Primary key for the inventory stock data product.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management. A = high-value/critical, B = moderate, C = low-value/non-critical. Used for prioritization and cycle counting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Stock Quantity' ;
    rdfs:comment 'Calculated available quantity: unrestricted stock minus reserved stock. Represents stock available for new commitments.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Stock Quantity' ;
    rdfs:comment 'Quantity of material blocked for use due to quality issues, regulatory hold, or other restrictions. Requires disposition decision.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Certificate of Analysis document number provided by the vendor for this batch. Contains quality test results and specifications.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainStorageZone rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Storage Zone' ;
    rdfs:comment 'Temperature-controlled storage zone assignment for materials requiring cold-chain handling. Critical for reagent stability and GMP compliance.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consignmentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Consignment Stock Quantity' ;
    rdfs:comment 'Quantity of material held on consignment from a vendor. Ownership transfers only upon consumption.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count for this stock record. Used to ensure inventory accuracy.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Controlled Flag' ;
    rdfs:comment 'Indicates whether this material is subject to GMP controls requiring batch-level traceability, quality documentation, and regulatory compliance.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inTransitStockQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Stock Quantity' ;
    rdfs:comment 'Quantity of material currently in transit between plants or storage locations. Not yet available at the destination.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGoodsMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Goods Movement Date' ;
    rdfs:comment 'Date of the most recent goods movement (receipt, issue, transfer) for this stock record. Used to identify slow-moving or obsolete inventory.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum stock level allowed at this location. Used to prevent overstocking and optimize working capital.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrpControllerCode rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller Code' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for managing replenishment of this material.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Stock Quantity' ;
    rdfs:comment 'Quantity of material currently under quality inspection or Quality Control (QC) testing. Cannot be used until QC release.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Stock Quantity' ;
    rdfs:comment 'Quantity of unrestricted stock reserved for specific production orders, sales orders, or projects. Committed but not yet issued.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Timestamp when this stock position snapshot was captured. Supports historical stock analysis and trend reporting.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Current operational status of the stock record. Indicates availability, alerts, or restrictions. [ENUM-REF-CANDIDATE: AVAILABLE|LOW_STOCK|OUT_OF_STOCK|EXPIRING_SOON|EXPIRED|BLOCKED|QUARANTINE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of stock ownership and purpose. Distinguishes between own stock, consignment, project-specific stock, and other special stock types.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockValueAmount rdf:type rdf:Property ;
    rdfs:label 'Stock Value Amount' ;
    rdfs:comment 'Total monetary value of the stock at this location, calculated using the material valuation price. Critical for Cost of Goods Sold (COGS) visibility.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrestrictedStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Unrestricted Stock Quantity' ;
    rdfs:comment 'Quantity of material available for unrestricted use. This stock can be issued for production, sales orders, or other consumption without restrictions.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Valuation Price Per Unit' ;
    rdfs:comment 'Standard or moving average price per unit used for inventory valuation. Basis for COGS calculation.' ;
    rdfs:domain ind:InventoryStock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchManagementRequired rdf:type rdf:Property ;
    rdfs:label 'Batch Management Required' ;
    rdfs:comment 'Indicates whether the material requires batch/lot number tracking for traceability and quality control. True for reagents, consumables, and materials subject to expiration or quality testing. Sourced from SAP MM Material Master (MARA-XCHPF).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bomRelevance rdf:type rdf:Property ;
    rdfs:label 'Bom Relevance' ;
    rdfs:comment 'Indicates whether this material is relevant for BOM (Bill of Materials) explosion and production planning. True if material is a component or assembly used in manufacturing.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coaRequired rdf:type rdf:Property ;
    rdfs:label 'Coa Required' ;
    rdfs:comment 'Indicates whether a Certificate of Analysis must be provided by the supplier for each lot/batch of this material. True for reagents, chemicals, and biological materials.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Classification of material hazard level per GHS (Globally Harmonized System) for chemical safety and handling (e.g., Flammable Liquid Category 2, Acute Toxicity Category 3, Corrosive). Required for SDS (Safety Data Sheet) compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Industry sector classification for the material (e.g., P=Pharmaceuticals, C=Chemicals, M=Mechanical Engineering). Sourced from SAP MM Material Master (MARA-MBRSH).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeProcedure rdf:type rdf:Property ;
    rdfs:label 'Lot Size Procedure' ;
    rdfs:comment 'Procedure for calculating lot size in procurement and production (e.g., EX=Lot-for-lot, FX=Fixed lot size, HB=Replenishment to maximum stock level). Sourced from SAP MM Material Master (MARC-DISLS).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material master record. ACTIVE=Available for use, INACTIVE=Temporarily unavailable, BLOCKED=Blocked for procurement/production, OBSOLETE=Phased out, PENDING_APPROVAL=Awaiting approval for release.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpType rdf:type rdf:Property ;
    rdfs:label 'Mrp Type' ;
    rdfs:comment 'MRP procedure used for planning this material (e.g., PD=MRP, VB=Manual reorder point, ND=No planning). Sourced from SAP MM Material Master (MARC-DISMM).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Indicates whether incoming goods of this material must undergo quality inspection before release to unrestricted stock. True for GMP-critical materials and reagents. Sourced from SAP QM Quality Management (MARC-QMATV).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainingShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Shelf Life Days' ;
    rdfs:comment 'Minimum remaining shelf life in days required at goods receipt. Materials with shorter remaining shelf life are rejected. Sourced from SAP MM Material Master (MARA-MHDRZ).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for cold-chain and temperature-sensitive materials. Critical for reagent stability and quality assurance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for cold-chain and temperature-sensitive materials. Critical for reagent stability and quality assurance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Line-level requisitioner tracking enables cost center accountability, budget variance analysis by personnel, and audit trail for split POs. Replaces denormalized \'requisitioner_name\' with FK for perso' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'Defines how the procurement cost is assigned in financial accounting, such as cost center, internal order, project, or asset.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Flag indicating whether this line item has been marked for deletion or cancellation, preventing further processing while preserving audit history.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether a goods receipt is required for this line item before invoice processing can occur, enforcing three-way match controls.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous, requiring special handling, storage, and shipping procedures per safety regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Flag indicating whether an invoice is expected for this line item, controlling accounts payable processing workflows.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The negotiated price per unit of measure for the material, excluding taxes and additional charges.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the supplier may exceed the ordered quantity without requiring approval, supporting flexible receiving processes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity unit to which the net price applies. For example, if price_unit is 100 and net_price is 50.00, the price is 50.00 per 100 units.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'The date by which the material must be used or disposed of, critical for managing reagent and consumable inventory in genomics laboratories.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Additional free-form text providing supplementary information or special instructions for this purchase order line item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underdeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the supplier may deliver less than the ordered quantity without triggering a shortage alert or requiring follow-up.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Relevant Flag' ;
    rdfs:comment 'Indicates whether this purchase order is subject to Good Manufacturing Practice (GMP) regulations. True for materials used in In Vitro Diagnostic (IVD) or Clinical Laboratory Improvement Amendments (CLIA) products.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Pct' ;
    rdfs:comment 'Permitted percentage by which the supplier may exceed the ordered quantity without requiring approval. Accommodates supplier packaging constraints.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the purchase order was created and issued to the supplier. Principal business event timestamp for procurement commitment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'Buyer or purchasing group responsible for this purchase order. Identifies the procurement specialist managing supplier relationships.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'Organizational unit responsible for procurement activities. Defines procurement authority and supplier relationships.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Cumulative quantity received to date via goods receipt transactions. Tracks fulfillment progress.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underdeliveryTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Pct' ;
    rdfs:comment 'Permitted percentage by which the supplier may deliver less than the ordered quantity without penalty. Manages supply risk for critical materials.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Unique identifier for the replenishment order record. Primary key for this entity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Converted Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.purchase_order. Business justification: Replenishment orders (planned orders from MRP) are converted to purchase orders when released. The replenishment_order table has converted_document_number (STRING) and converted_document_type (STRING)' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:sourcePlantId rdf:type rdf:Property ;
    rdfs:label 'Source Plant Id' ;
    rdfs:comment 'Reference to the source plant from which material will be transferred. Applicable when source type is internal plant or distribution center. Links to the supplying organizational unit.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plant .

ind:batchManaged rdf:type rdf:Property ;
    rdfs:label 'Batch Managed' ;
    rdfs:comment 'Flag indicating whether the material is batch-managed requiring lot number tracking and Certificate of Analysis (COA) documentation. True for reagents, consumables, and controlled materials.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:convertedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Document Number' ;
    rdfs:comment 'Business identifier of the execution document created from this replenishment order. Purchase order number, stock transfer order number, or production order number. Null if not yet converted.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDocumentType rdf:type rdf:Property ;
    rdfs:label 'Converted Document Type' ;
    rdfs:comment 'Type of execution document created from this replenishment order. Indicates the downstream procurement or manufacturing process triggered.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total cost for fulfilling this replenishment order. Calculated based on material standard cost, last purchase price, or contract price. Used for budget planning and Cost of Goods Sold (COGS) forecasting.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpIndicator rdf:type rdf:Property ;
    rdfs:label 'Gmp Indicator' ;
    rdfs:comment 'Flag indicating whether this replenishment order is for Good Manufacturing Practice (GMP) controlled materials requiring enhanced quality and compliance tracking. Critical for regulated genomics products.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrpController rdf:type rdf:Property ;
    rdfs:label 'Mrp Controller' ;
    rdfs:comment 'Code identifying the MRP controller or planner responsible for this material and replenishment order. Links to the person or team managing material availability.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrpRunDate rdf:type rdf:Property ;
    rdfs:label 'Mrp Run Date' ;
    rdfs:comment 'Date when the MRP calculation was executed that generated this replenishment order. Provides traceability to the planning cycle.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Planned Order Number' ;
    rdfs:comment 'Business identifier for the planned order generated by Material Requirements Planning (MRP) or demand planning system. Externally visible order number used for tracking and reference.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointIndicator rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Indicator' ;
    rdfs:comment 'Flag indicating whether this replenishment order was triggered by reaching the reorder point threshold. True if reorder point logic initiated the order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredDate rdf:type rdf:Property ;
    rdfs:label 'Required Date' ;
    rdfs:comment 'Date by which the material must be available at the destination plant or storage location to meet production or customer demand. Drives procurement lead time calculations.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyStockIndicator rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Indicator' ;
    rdfs:comment 'Flag indicating whether this replenishment order was triggered to maintain safety stock levels. True if the order is for safety stock replenishment, false if for normal demand.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the source from which the material will be procured or transferred. Determines whether the order triggers external procurement or internal stock transfer.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProcurementType rdf:type rdf:Property ;
    rdfs:label 'Special Procurement Type' ;
    rdfs:comment 'Classification of special procurement logic applied to this replenishment order. Indicates non-standard procurement scenarios such as consignment, subcontracting, or pipeline materials.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement log.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Movement Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Material movement audit trail requires employee linkage for GxP compliance, training qualification verification, and investigation of inventory discrepancies. Replaces text \'user_name\' with FK to enab' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amountInCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Company Currency' ;
    rdfs:comment 'The total value of the stock movement converted to the company code\'s reporting currency. Used for consolidated financial reporting and Profit and Loss (P&L) analysis.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount In Local Currency' ;
    rdfs:comment 'The total value of the stock movement in the plant\'s local currency. Used for inventory valuation and COGS (Cost of Goods Sold) calculation. Derived from material price and quantity.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The exact date and time when the material document was created in the system. Used for audit trail and Turnaround Time (TAT) analysis.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Entry Unit Of Measure' ;
    rdfs:comment 'The unit of measure used during transaction entry. Supports multi-unit scenarios (e.g., ordering in cases but stocking in units).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementIndicator rdf:type rdf:Property ;
    rdfs:label 'Movement Indicator' ;
    rdfs:comment 'High-level classification of the movement direction: receipt (inbound), issue (outbound), or transfer (location-to-location).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInEntryUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Entry Unit' ;
    rdfs:comment 'The quantity in the unit of measure used during data entry (e.g., purchase order unit). May differ from base unit for conversion tracking.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservationLineItem rdf:type rdf:Property ;
    rdfs:label 'Reservation Line Item' ;
    rdfs:comment 'Line item number within the reservation document.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesOrderLineItem rdf:type rdf:Property ;
    rdfs:label 'Sales Order Line Item' ;
    rdfs:comment 'Line item number within the sales order. Identifies the specific material line being shipped.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedForPurchasing rdf:type rdf:Property ;
    rdfs:label 'Blocked For Purchasing' ;
    rdfs:comment 'Indicates whether new purchase orders are blocked for this supplier due to quality issues, compliance violations, or financial concerns.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Business reason for blocking purchasing activity with this supplier (e.g., quality hold, financial distress, regulatory non-compliance, contract dispute).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Business classification tier indicating the supplier\'s qualification status and procurement priority. GMP (Good Manufacturing Practice)-qualified suppliers meet regulatory standards for genomics manufacturing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCapable rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the supplier has validated cold-chain logistics capabilities required for temperature-sensitive reagents and biological materials used in genomics workflows.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Supplier diversity program classification (e.g., minority-owned, women-owned, veteran-owned, small business). [ENUM-REF-CANDIDATE: minority_owned|women_owned|veteran_owned|small_business|disadvantaged_business|lgbtq_owned|disability_owned|none — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the supplier holds valid GMP (Good Manufacturing Practice) certification required for supplying materials used in regulated genomics products.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso13485Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds ISO 13485 certification for medical device quality management systems, required for suppliers of IVD (In Vitro Diagnostic) components.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the supplier holds ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered name of the supplier entity as it appears on contracts and regulatory filings.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next supplier quality audit based on risk tier and audit frequency policy.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryPercentage rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Percentage' ;
    rdfs:comment 'Rolling 12-month percentage of purchase orders delivered on or before the requested delivery date. Key performance indicator (KPI) for supplier performance management.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Current quality performance rating based on QC (Quality Control) results, COA (Certificate of Analysis) compliance, and nonconformance history.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Supply chain risk classification based on business continuity impact, single-source dependency, geographic risk, and financial stability. Critical tier indicates suppliers of materials with no qualified alternative source.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Single Source Flag' ;
    rdfs:comment 'Indicates whether this supplier is the sole qualified source for one or more critical materials or components, representing elevated supply chain risk.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Lead Time Days' ;
    rdfs:comment 'Typical number of calendar days from purchase order placement to delivery for standard items from this supplier. Used for demand planning and inventory management.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Primary category of goods or services provided by the supplier. OEM (Original Equipment Manufacturer) indicates suppliers of sequencing instruments and genomics equipment. [ENUM-REF-CANDIDATE: raw_material|reagent|consumable|component|equipment|service|contract_manufacturer|distributor|oem — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Commercial or doing-business-as name used by the supplier in day-to-day operations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'External business identifier for the supplier as maintained in SAP MM vendor master. Used across procurement and supply chain operations.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:gmpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Required Flag' ;
    rdfs:comment 'Indicates whether materials supplied under this contract must comply with GMP regulations for pharmaceutical and biotechnology manufacturing. True if GMP compliance is mandatory.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAdjustmentClause rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Clause' ;
    rdfs:comment 'Description of the price adjustment mechanism or escalation clause agreed in the contract (e.g., annual CPI adjustment, raw material index-linked pricing).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the quality agreement or quality technical agreement (QTA) associated with this contract, defining quality specifications, testing requirements, and acceptance criteria.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStrategy rdf:type rdf:Property ;
    rdfs:label 'Release Strategy' ;
    rdfs:comment 'Strategy for releasing purchase orders or delivery schedules against this contract: automatic (system-triggered), manual (buyer-initiated), scheduled (time-based), forecast-based (demand-driven), or JIT (Just-In-Time).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether this contract is eligible for automatic renewal upon expiry. True if renewal is enabled.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaOnTimeDeliveryTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Target Pct' ;
    rdfs:comment 'Target percentage for on-time delivery performance agreed in the SLA. Expressed as a percentage (e.g., 95.00 for 95%).' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Time Hours' ;
    rdfs:comment 'Maximum turnaround time in hours committed by the supplier for order fulfillment or service delivery under this contract. Key SLA metric for performance monitoring.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Id' ;
    rdfs:comment 'Unique identifier for the supplier performance scorecard record.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'Most recent supplier audit score (0-100) from quality or regulatory audit conducted during or prior to the evaluation period.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Avg Response Time Hours' ;
    rdfs:comment 'Average time in hours for the supplier to respond to quality notifications and technical inquiries during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coaComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Coa Compliance Rate Pct' ;
    rdfs:comment 'Percentage of shipments accompanied by complete and accurate Certificate of Analysis documentation meeting GMP requirements.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliance Rate Pct' ;
    rdfs:comment 'Percentage of temperature-sensitive shipments that maintained required cold chain conditions throughout transit, critical for reagent integrity.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionClosureRatePct rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Closure Rate Pct' ;
    rdfs:comment 'Percentage of corrective actions from quality notifications that were closed on time with effective root cause analysis and preventive measures.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deviation Count' ;
    rdfs:comment 'Number of critical or major quality deviations that posed significant risk to product quality or regulatory compliance.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationCompletenessRatePct rdf:type rdf:Property ;
    rdfs:label 'Documentation Completeness Rate Pct' ;
    rdfs:comment 'Percentage of shipments accompanied by complete regulatory and quality documentation including COA, SDS, and compliance certificates.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period for this scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluatorEmail rdf:type rdf:Property ;
    rdfs:label 'Evaluator Email' ;
    rdfs:comment 'Email address of the evaluator responsible for this scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorName rdf:type rdf:Property ;
    rdfs:label 'Evaluator Name' ;
    rdfs:comment 'Name of the procurement or quality professional who prepared and approved this performance scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementActionDescription rdf:type rdf:Property ;
    rdfs:label 'Improvement Action Description' ;
    rdfs:comment 'Description of required improvement actions, development programs, or corrective measures to be implemented with the supplier.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Improvement Action Required Flag' ;
    rdfs:comment 'Indicates whether formal supplier improvement actions or development programs are required based on scorecard results.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inFullDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'In Full Delivery Rate Pct' ;
    rdfs:comment 'Percentage of purchase orders delivered with complete quantities as ordered during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomingQualityAcceptanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Incoming Quality Acceptance Rate Pct' ;
    rdfs:comment 'Percentage of received lots that passed incoming quality inspection on first attempt without rejection or rework.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:innovationContributionScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Contribution Score' ;
    rdfs:comment 'Qualitative score (0-100) assessing the suppliers contribution to product innovation, process improvements, and technical collaboration during the period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Count' ;
    rdfs:comment 'Number of purchase order line items delivered after the committed delivery date.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeAdherenceRatePct rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Rate Pct' ;
    rdfs:comment 'Percentage of orders delivered within the contracted standard lead time window.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRatePct rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Pct' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the committed delivery date during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otifRatePct rdf:type rdf:Property ;
    rdfs:label 'Otif Rate Pct' ;
    rdfs:comment 'Combined metric representing the percentage of orders delivered both on time and in full, a key supply chain KPI for genomics materials.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Partial Delivery Count' ;
    rdfs:comment 'Number of purchase order line items delivered with incomplete quantities requiring follow-up shipments.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Overall performance classification tier assigned to the supplier based on scorecard results, driving sourcing strategy and supplier development programs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariancePct rdf:type rdf:Property ;
    rdfs:label 'Price Variance Pct' ;
    rdfs:comment 'Percentage variance between contracted prices and actual invoiced prices during the evaluation period, indicating pricing stability.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedLotCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Lot Count' ;
    rdfs:comment 'Number of material lots rejected during incoming inspection due to quality failures.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle status of the supplier performance scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRatePct rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Rate Pct' ;
    rdfs:comment 'Overall percentage of contracted SLA metrics met during the evaluation period across delivery, quality, and service dimensions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoCount rdf:type rdf:Property ;
    rdfs:label 'Total Po Count' ;
    rdfs:comment 'Total number of purchase orders issued to this supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of all purchase orders issued to this supplier during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Qualification Id' ;
    rdfs:comment 'Unique identifier for the supplier qualification record. Primary key.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedMaterialScope rdf:type rdf:Property ;
    rdfs:label 'Approved Material Scope' ;
    rdfs:comment 'Description of the material categories, product families, or specific Stock Keeping Units (SKUs) for which the supplier is qualified. May reference material groups, reagent types, consumable categories, or instrument components.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'Date of the most recent supplier audit (on-site or remote) that contributed to this qualification decision. Nullable if qualification was not audit-based.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Summary' ;
    rdfs:comment 'Summary of key findings from the supplier audit, including observations, non-conformances, and areas of concern. May reference detailed audit report stored in Veeva Vault.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaRegistered rdf:type rdf:Property ;
    rdfs:label 'Fda Registered' ;
    rdfs:comment 'Indicates whether the supplier is registered with the U.S. Food and Drug Administration (FDA) as required for suppliers of medical device components or In Vitro Diagnostic (IVD) materials.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpScope rdf:type rdf:Property ;
    rdfs:label 'Gmp Scope' ;
    rdfs:comment 'Indicates whether the supplier qualification covers Good Manufacturing Practice (GMP) controlled supply: full (all materials under GMP), partial (specific materials or processes under GMP), or not_applicable (non-GMP materials).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major non-conformances identified during the audit. Major findings require corrective action within a defined timeframe.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor non-conformances or observations identified during the audit. Minor findings are tracked for continuous improvement.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationOwner rdf:type rdf:Property ;
    rdfs:label 'Qualification Owner' ;
    rdfs:comment 'Name or identifier of the Quality Assurance (QA) or procurement professional responsible for managing this supplier qualification record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numerical score assigned to the supplier based on qualification assessment criteria (e.g., audit results, documentation completeness, certifications, past performance). Scale typically 0-100.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryBodyAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Alignment' ;
    rdfs:comment 'Comma-separated list of regulatory bodies and standards to which this supplier qualification aligns (e.g., FDA, EMA, ISO 13485, ISO 9001, CLIA, CAP). Indicates the regulatory frameworks under which the supplier is qualified.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date on which a previously suspended supplier qualification was reinstated following successful corrective actions. Nullable if never suspended or not yet reinstated.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the supplier qualification was suspended or revoked. Nullable if never suspended.' ;
    rdfs:domain ind:SupplierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for suspension or disqualification of the supplier, if applicable. May include quality issues, audit failures, regulatory non-compliance, or business reasons. Nullable if status is not suspended or disqualified.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Reference to the parent warehouse or distribution center facility where this storage location resides.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:aisleNumber rdf:type rdf:Property ;
    rdfs:label 'Aisle Number' ;
    rdfs:comment 'Aisle identifier within the warehouse where this storage location resides. Used for warehouse navigation and picking route optimization.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagedIndicator rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Indicator' ;
    rdfs:comment 'Flag indicating whether inventory stored in this location requires batch or lot number tracking. True if batch management is enforced for traceability and quality control. Critical for reagents, flow cells, and consumables subject to Certificate of Analysis (COA) requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, or pallet position within the storage section. Represents the most granular physical address for inventory placement (e.g., A12-R03-B05).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedIndicator rdf:type rdf:Property ;
    rdfs:label 'Blocked Indicator' ;
    rdfs:comment 'Flag indicating whether the storage location is currently blocked for use due to maintenance, damage, temperature excursion, or other operational issues. True if location is unavailable for inventory placement or retrieval.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Free-text explanation for why the storage location is blocked (e.g., \'Temperature excursion detected\', \'Structural damage\', \'Scheduled maintenance\'). Populated only when blocked_indicator is True.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Capacity Volume M3' ;
    rdfs:comment 'Maximum volumetric capacity of the storage location in cubic meters. Used for space utilization planning and warehouse optimization.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Kg' ;
    rdfs:comment 'Maximum weight capacity of the storage location in kilograms. Used for load planning and safety compliance to prevent structural overload.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Current Utilization Percent' ;
    rdfs:comment 'Current utilization of the storage location as a percentage of total capacity (weight or volume). Calculated based on inventory currently stored. Used for warehouse efficiency KPIs and replenishment planning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountIndicator rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Indicator' ;
    rdfs:comment 'Flag indicating whether this storage location is included in regular cycle counting programs for inventory accuracy verification. True if location is subject to periodic physical counts.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fefoEnforcement rdf:type rdf:Property ;
    rdfs:label 'Fefo Enforcement' ;
    rdfs:comment 'Flag indicating whether First Expired First Out (FEFO) inventory rotation is enforced for this storage location. True if the WMS must prioritize inventory with the earliest expiration date for picking. Used for biological reagents, enzymes, and flow cells with strict shelf-life requirements.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fifoEnforcement rdf:type rdf:Property ;
    rdfs:label 'Fifo Enforcement' ;
    rdfs:comment 'Flag indicating whether First In First Out (FIFO) inventory rotation is enforced for this storage location. True if the warehouse management system (WMS) must prioritize oldest inventory for picking. Critical for reagents and consumables with limited shelf life.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmpZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Gmp Zone Classification' ;
    rdfs:comment 'GMP cleanliness classification for the storage location. Grade A (highest sterility) for aseptic operations, Grade B for background environment for Grade A, Grade C and D for less critical manufacturing steps, non_gmp for non-regulated storage. Required for IVD and RUO product manufacturing compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent cycle count performed for this storage location. Used to schedule next cycle count and monitor inventory accuracy compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Vertical level or shelf position within the rack (e.g., 1 for ground level, 2 for first shelf above ground). Used for ergonomic picking optimization and safety compliance.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational status of the storage location. Active for normal use, inactive for temporarily unused, blocked for operational issues, quarantine for QC hold, maintenance for scheduled work, decommissioned for permanently retired locations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixedStorageIndicator rdf:type rdf:Property ;
    rdfs:label 'Mixed Storage Indicator' ;
    rdfs:comment 'Flag indicating whether this storage location allows multiple Stock Keeping Units (SKUs) to be stored simultaneously. True if mixed SKU storage is permitted, False if location is dedicated to a single SKU.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingIndicator rdf:type rdf:Property ;
    rdfs:label 'Picking Indicator' ;
    rdfs:comment 'Flag indicating whether this storage location is designated for active picking operations (order fulfillment). True if location is in the pick zone, False if it is a reserve or bulk storage location.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickingStrategy rdf:type rdf:Property ;
    rdfs:label 'Picking Strategy' ;
    rdfs:comment 'WMS strategy for selecting inventory from this storage location during order fulfillment. FIFO for oldest first, FEFO for earliest expiration first, LIFO for last in first out, nearest_location for travel optimization, highest_stock for inventory balancing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Warehouse management system (WMS) strategy for directing incoming inventory to this storage location. Fixed_bin for dedicated SKU locations, next_empty_bin for dynamic allocation, bulk_storage for pallet-level storage, high_rack for vertical storage systems, floor_storage for oversized items.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineIndicator rdf:type rdf:Property ;
    rdfs:label 'Quarantine Indicator' ;
    rdfs:comment 'Flag indicating whether this storage location is designated for quarantined inventory pending quality control (QC) release or investigation. True if location is restricted for quarantine use only.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rackNumber rdf:type rdf:Property ;
    rdfs:label 'Rack Number' ;
    rdfs:comment 'Rack or shelving unit identifier within the aisle. Used for precise physical location addressing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Replenishment Indicator' ;
    rdfs:comment 'Flag indicating whether this storage location requires automatic replenishment from reserve storage when inventory falls below a threshold. True if location is part of an automated replenishment strategy.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumberManagedIndicator rdf:type rdf:Property ;
    rdfs:label 'Serial Number Managed Indicator' ;
    rdfs:comment 'Flag indicating whether inventory stored in this location requires serial number tracking at the individual unit level. True if serial number management is enforced. Used for high-value instruments, flow cells, and components requiring unit-level traceability.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageIncompatibilities rdf:type rdf:Property ;
    rdfs:label 'Storage Incompatibilities' ;
    rdfs:comment 'Comma-separated list of hazard classes or material types that must NOT be stored in proximity to this location due to chemical incompatibility (e.g., \'acids,oxidizers\'). Used to enforce segregation rules and prevent dangerous reactions.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageSection rdf:type rdf:Property ;
    rdfs:label 'Storage Section' ;
    rdfs:comment 'Logical subdivision within the warehouse (e.g., aisle, zone, or area designation) used to organize storage locations by product category, temperature zone, or operational workflow.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Classification of the storage environment based on temperature control and regulatory requirements. Ambient for room temperature, refrigerated for 2–8°C, frozen for −20°C or −80°C, ultra_cold for liquid nitrogen storage, hazmat for hazardous materials, gmp_controlled for Good Manufacturing Practice (GMP) zones.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'X-axis coordinate of the storage location within the warehouse floor plan (in meters). Used for automated guided vehicle (AGV) navigation and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Y-axis coordinate of the storage location within the warehouse floor plan (in meters). Used for AGV navigation and warehouse mapping.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zCoordinate rdf:type rdf:Property ;
    rdfs:label 'Z Coordinate' ;
    rdfs:comment 'Z-axis (height) coordinate of the storage location within the warehouse (in meters). Used for vertical storage systems and automated retrieval systems.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the absence record. Primary key.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absencePlanId rdf:type rdf:Property ;
    rdfs:label 'Absence Plan Id' ;
    rdfs:comment 'Reference to the absence plan or policy under which this absence is recorded (e.g., annual Paid Time Off (PTO) plan, sick leave plan, Family and Medical Leave Act (FMLA) plan). Links to absence plan configuration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbsencePlan .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Reference to the employee who is absent. Links to the employee master record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceReason rdf:type rdf:Property ;
    rdfs:label 'Absence Reason' ;
    rdfs:comment 'Detailed reason or description for the absence event. May include medical condition category, family care reason, or other contextual information.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Status' ;
    rdfs:comment 'Current lifecycle status of the absence request. Tracks workflow from submission through approval and completion.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Absence Type Code' ;
    rdfs:comment 'Classification of the absence event. Includes planned leave (Paid Time Off (PTO), vacation, parental leave, sabbatical) and unplanned absences (sick leave, Family and Medical Leave Act (FMLA), disability leave, bereavement). [ENUM-REF-CANDIDATE: PTO|VACATION|SICK|FMLA|PARENTAL|BEREAVEMENT|DISABILITY — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance After' ;
    rdfs:comment 'Employee\'s absence accrual balance (in hours or days) after this absence was deducted. Used for audit trail and balance reconciliation.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accrualBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Accrual Balance Before' ;
    rdfs:comment 'Employee\'s absence accrual balance (in hours or days) before this absence was taken. Used for audit trail and balance reconciliation.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disabilityLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Disability Leave Flag' ;
    rdfs:comment 'Indicates whether this absence is classified as short-term or long-term disability leave.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system identifier for this absence record (e.g., Oracle Cloud Human Capital Management (HCM) absence ID, third-party leave management system case number). Used for cross-system reconciliation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmlaDesignatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fmla Designated Flag' ;
    rdfs:comment 'Indicates whether this absence qualifies for and is designated as Family and Medical Leave Act (FMLA) protected leave under U.S. federal law.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmlaHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Fmla Hours Used' ;
    rdfs:comment 'Number of Family and Medical Leave Act (FMLA) hours consumed by this absence event. Tracked against the employee\'s 12-week (480-hour) annual Family and Medical Leave Act (FMLA) entitlement.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpQualificationImpactNotes rdf:type rdf:Property ;
    rdfs:label 'Gxp Qualification Impact Notes' ;
    rdfs:comment 'Free-text notes documenting the impact of the absence on the employee\'s Good Practice Regulations (GxP) qualification status, including specific training or requalification activities required before resuming Good Manufacturing Practice (GMP) or Clinical Laboratory Improvement Amendments (CLIA) duties.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpRequalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Requalification Required Flag' ;
    rdfs:comment 'Indicates whether the employee requires Good Practice Regulations (GxP) requalification or retraining upon return to work due to extended absence from Good Manufacturing Practice (GMP) or Clinical Laboratory Improvement Amendments (CLIA) regulated environment. Triggered when absence exceeds regulatory qualification maintenance thresholds.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intermittentLeaveFlag rdf:type rdf:Property ;
    rdfs:label 'Intermittent Leave Flag' ;
    rdfs:comment 'Indicates whether this absence is part of an intermittent leave pattern (e.g., recurring medical appointments, reduced work schedule under Family and Medical Leave Act (FMLA)).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Date' ;
    rdfs:comment 'Date when medical certification or documentation was received by Human Resources (HR).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Received Flag' ;
    rdfs:comment 'Indicates whether required medical certification or documentation has been received and validated by Human Resources (HR).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certification Required Flag' ;
    rdfs:comment 'Indicates whether medical certification or documentation is required for this absence (e.g., doctor\'s note for extended sick leave, Family and Medical Leave Act (FMLA) certification).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Flag' ;
    rdfs:comment 'Indicates whether the absence is paid or unpaid. True for paid leave (Paid Time Off (PTO), vacation, paid sick leave), false for unpaid leave (unpaid Family and Medical Leave Act (FMLA), leave without pay).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Impact Flag' ;
    rdfs:comment 'Indicates whether this absence has an impact on payroll processing (e.g., unpaid leave deduction, paid time off usage).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Indicates whether the payroll impact of this absence has been processed in the payroll system.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The actual date the employee returned to work following the absence. May differ from planned end date if absence is extended or shortened.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workersCompensationFlag rdf:type rdf:Property ;
    rdfs:label 'Workers Compensation Flag' ;
    rdfs:comment 'Indicates whether this absence is related to a workers compensation claim due to work-related injury or illness.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bargainingUnitId rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Id' ;
    rdfs:comment 'Reference to the collective bargaining unit or labor union to which this assignment belongs, if applicable. Relevant for unionized manufacturing and laboratory staff.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BargainingUnit .

ind:gradeId rdf:type rdf:Property ;
    rdfs:label 'Grade Id' ;
    rdfs:comment 'Reference to the salary grade or job grade assigned to this position. Used for compensation benchmarking and career progression planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grade .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Reference to the job profile or job classification for this assignment. Defines the nature of work, responsibilities, and competencies required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Reference to the physical or virtual work location where the employee performs their duties under this assignment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Reference to the position to which the employee is assigned. Represents the specific role within the organizational structure.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:primaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Employee Id' ;
    rdfs:comment 'Reference to the employee who holds this assignment. Links to the employee master record.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workScheduleId rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Id' ;
    rdfs:comment 'Reference to the work schedule pattern assigned to this employee, defining standard working hours, shift patterns, and work calendar.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkSchedule .

ind:actualTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Termination Date' ;
    rdfs:comment 'The actual date on which the assignment was terminated, if different from the planned end date. Captures the real-world termination event.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Assignment Category' ;
    rdfs:comment 'Employment category for this assignment indicating full-time, part-time, temporary, contract, or intern status.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentName rdf:type rdf:Property ;
    rdfs:label 'Assignment Name' ;
    rdfs:comment 'A descriptive name for the assignment, typically combining the job title and organizational unit for easy identification in reports and dashboards.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Qualified Flag' ;
    rdfs:comment 'Boolean flag indicating whether the employee in this assignment holds CLIA qualification for performing clinical laboratory testing. Required for clinical genomics and IVD operations.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'The type of employment relationship for this assignment, distinguishing between employees, contractors, consultants, temporary workers, and interns.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The percentage of full-time equivalent effort allocated to this assignment. 100.00 represents full-time; values below 100 indicate part-time or fractional assignments. Used for workforce planning and capacity analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Critical Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment is in a GxP-critical role requiring enhanced training, qualification, and compliance tracking per FDA, EMA, and ISO 13485 regulations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payBasis rdf:type rdf:Property ;
    rdfs:label 'Pay Basis' ;
    rdfs:comment 'The basis on which the employee is compensated for this assignment: salary, hourly wage, commission, or piece rate.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency with which the employee is paid for this assignment: weekly, biweekly, semimonthly, or monthly.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this is the employee\'s primary assignment. An employee may have multiple assignments, but only one can be primary.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probationEndDate rdf:type rdf:Property ;
    rdfs:label 'Probation End Date' ;
    rdfs:comment 'The date on which the probationary period for this assignment ends. Used for tracking new hire performance evaluation milestones.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'The business reason for creating or modifying this assignment: new hire, promotion, transfer, demotion, reorganization, project assignment, or return from leave. [ENUM-REF-CANDIDATE: new_hire|promotion|transfer|demotion|reorganization|project|return_from_leave — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment is eligible for remote or hybrid work arrangements. Relevant for bioinformatics, corporate, and field application specialist roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'The shift pattern for this assignment indicating day shift, evening shift, night shift, rotating shifts, flexible schedule, or on-call status. Critical for manufacturing and laboratory operations.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'The standard number of hours per week the employee is expected to work under this assignment. Used for time tracking, payroll, and capacity planning.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Training Qualification Status' ;
    rdfs:comment 'Current status of the employee\'s training and qualification for this assignment. Tracks whether the employee is fully qualified, undergoing training, has expired qualifications, or does not require qualification.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequiredPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Required Percentage' ;
    rdfs:comment 'The percentage of time this assignment requires business travel. Critical for field application specialists, sales, and customer support roles.' ;
    rdfs:domain ind:WorkforceAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record. Primary key for the benefit enrollment entity.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan in which the employee is enrolled. Links to the benefit plan catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Full legal name of the primary beneficiary designated by the employee to receive benefits in the event of the employees death. Applicable to life insurance and retirement plans. Nullable if no beneficiary is designated.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryPercentage rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Percentage' ;
    rdfs:comment 'Percentage of benefit proceeds allocated to the primary beneficiary. Must sum to 100 across all beneficiaries for a given enrollment. Nullable if no beneficiary is designated.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'Relationship of the beneficiary to the employee, such as spouse, child, parent, sibling, or other. Nullable if no beneficiary is designated.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitProviderName rdf:type rdf:Property ;
    rdfs:label 'Benefit Provider Name' ;
    rdfs:comment 'Name of the insurance carrier or third-party administrator providing the benefit coverage, such as Aetna, Blue Cross Blue Shield, Fidelity, or Principal Financial.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitProviderPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Benefit Provider Policy Number' ;
    rdfs:comment 'Policy or group number assigned by the benefit provider to identify the employer group plan. Used for claims processing and provider coordination.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraElectionDeadline rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Deadline' ;
    rdfs:comment 'Date by which the employee must elect COBRA continuation coverage. Typically 60 days from the qualifying event or notice date. Nullable if COBRA is not applicable.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the employee is eligible for COBRA continuation coverage upon termination of employment or loss of eligibility. True if eligible; false otherwise. Applicable to health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Sent Date' ;
    rdfs:comment 'Date on which the enrollment confirmation was sent to the employee via email or mail. Used to track communication and compliance with notification requirements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are deducted and remitted. Aligns with payroll cycle.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'Total dollar value of coverage provided by the benefit plan, such as life insurance face value, disability benefit maximum, or annual FSA/HSA contribution limit. Nullable for plans without a defined coverage amount.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected by the employee. Employee only covers the employee; employee+spouse covers employee and spouse/domestic partner; employee+children covers employee and dependent children; family covers employee, spouse, and children.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this enrollment. Applicable to family coverage tiers. Zero for employee-only coverage.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Dollar amount the employee contributes per pay period toward the benefit premium or plan cost. Deducted from employee paycheck.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Dollar amount the employer contributes per pay period toward the benefit premium or plan cost. Represents employer-funded portion of benefit.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment confirmation number provided to the employee upon successful enrollment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentReason rdf:type rdf:Property ;
    rdfs:label 'Enrollment Reason' ;
    rdfs:comment 'Business reason or trigger for the enrollment. Open enrollment is the annual election period; new hire is initial enrollment upon employment; qualifying life event includes marriage, birth, adoption, divorce; annual renewal is automatic continuation; plan change is mid-year modification; rehire is re-enrollment after termination and return.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Channel or method through which the enrollment was submitted. Employee self-service indicates online portal; HR administrator indicates manual entry by HR staff; benefits broker indicates third-party enrollment; call center indicates phone enrollment; paper form indicates scanned document; automated import indicates system integration.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Certification Date' ;
    rdfs:comment 'Date on which the employee completed HIPAA privacy and security training as required for enrollment in health-related benefits. Ensures compliance with Protected Health Information (PHI) regulations.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum annual amount the employee will pay out-of-pocket for covered services before the plan pays 100 percent. Applicable to health insurance plans. Nullable for plans without out-of-pocket maximums.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Category of benefit plan. Health includes medical insurance; dental includes dental insurance; vision includes vision insurance; life includes life insurance; disability includes short-term and long-term disability; retirement includes 401(k) and pension plans; FSA is Flexible Spending Account; HSA is Health Savings Account. [ENUM-REF-CANDIDATE: health|dental|vision|life|disability|retirement|fsa|hsa — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Provider Enrollment Date' ;
    rdfs:comment 'Date on which the enrollment was transmitted to and confirmed by the benefit provider. May differ from internal enrollment date due to processing lag.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'Date on which the qualifying life event occurred. Used to validate enrollment timing and eligibility. Nullable if enrollment is not due to a qualifying event.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'Specific type of qualifying life event that triggered mid-year enrollment or change, such as marriage, divorce, birth, adoption, loss of other coverage, or change in employment status. Nullable if enrollment is not due to a qualifying event.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverIndicator rdf:type rdf:Property ;
    rdfs:label 'Waiver Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the employee explicitly waived (declined) this benefit. True if waived; false if enrolled. Used to track opt-out decisions for compliance and reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation provided by the employee for waiving the benefit, such as coverage through spouse, other employer coverage, cost, or personal preference. Nullable if benefit is not waived.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateId rdf:type rdf:Property ;
    rdfs:label 'Candidate Id' ;
    rdfs:comment 'Unique identifier for the candidate record in the talent acquisition pipeline. Primary key.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Employee Id' ;
    rdfs:comment 'Identifier of the employee record created upon hire. Links the candidate record to the employee master record.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Hiring Manager Employee Id' ;
    rdfs:comment 'Identifier of the hiring manager responsible for the position to which the candidate applied.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Recruiter Employee Id' ;
    rdfs:comment 'Identifier of the recruiter or talent acquisition specialist managing this candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:candidateReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Candidate Referral Employee Id' ;
    rdfs:comment 'Identifier of the employee who referred this candidate, if the source channel was employee referral.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Identifier of the job requisition to which the candidate applied.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the candidate submitted their application for the position.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Completion Date' ;
    rdfs:comment 'Date when the background check was completed.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the background check process for the candidate (not initiated, in progress, completed, cleared, flagged).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateNumber rdf:type rdf:Property ;
    rdfs:label 'Candidate Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the candidate for tracking and reference purposes across recruiting workflows.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current status of the candidate in the recruiting pipeline (applied, screened, interviewed, offered, hired, rejected, withdrawn). [ENUM-REF-CANDIDATE: applied|screened|interviewed|offered|hired|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterFilePath rdf:type rdf:Property ;
    rdfs:label 'Cover Letter File Path' ;
    rdfs:comment 'File path or storage location reference for the candidate\'s cover letter document, if provided.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the candidate\'s current or most recent employer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Job title or role the candidate currently holds or most recently held.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoDisabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eeo Disability Status' ;
    rdfs:comment 'Self-reported disability status for Equal Employment Opportunity (EEO) reporting purposes. Collected voluntarily and stored separately for compliance.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoEthnicity rdf:type rdf:Property ;
    rdfs:label 'Eeo Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity for Equal Employment Opportunity (EEO) reporting purposes. Collected voluntarily and stored separately for compliance.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoGender rdf:type rdf:Property ;
    rdfs:label 'Eeo Gender' ;
    rdfs:comment 'Self-reported gender for Equal Employment Opportunity (EEO) reporting purposes. Collected voluntarily and stored separately for compliance.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeoVeteranStatus rdf:type rdf:Property ;
    rdfs:label 'Eeo Veteran Status' ;
    rdfs:comment 'Self-reported veteran status for Equal Employment Opportunity (EEO) reporting purposes. Collected voluntarily and stored separately for compliance.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Expected or agreed-upon start date for the candidate if hired.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest level of education attained by the candidate (e.g., high school, bachelor\'s degree, master\'s degree, PhD).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Actual date when the candidate was hired and transitioned to employee status.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewStage rdf:type rdf:Property ;
    rdfs:label 'Interview Stage' ;
    rdfs:comment 'Current interview stage or phase the candidate is in (e.g., phone screen, technical interview, panel interview, final interview).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationPreference rdf:type rdf:Property ;
    rdfs:label 'Location Preference' ;
    rdfs:comment 'Geographic location or site preference indicated by the candidate for the position.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Offer Acceptance Date' ;
    rdfs:comment 'Date when the candidate accepted the job offer.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerAmount rdf:type rdf:Property ;
    rdfs:label 'Offer Amount' ;
    rdfs:comment 'Total compensation amount offered to the candidate (base salary or total package value).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Offer Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the offer amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when a formal job offer was extended to the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resumeFilePath rdf:type rdf:Property ;
    rdfs:label 'Resume File Path' ;
    rdfs:comment 'File path or storage location reference for the candidate\'s resume or curriculum vitae document.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the candidate was sourced or applied (e.g., LinkedIn, employee referral, job board, campus recruiting, career site, recruiting agency).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Candidate\'s work authorization status in the hiring country (e.g., citizen, permanent resident, requires sponsorship).' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant professional experience reported by the candidate.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationId rdf:type rdf:Property ;
    rdfs:label 'Compensation Id' ;
    rdfs:comment 'Unique identifier for the compensation record. Primary key.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Approved By Employee Id' ;
    rdfs:comment 'Employee ID of the manager or HR representative who approved this compensation change. Null if not yet approved. Supports audit and compliance requirements.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compensationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compensation Employee Id' ;
    rdfs:comment 'Reference to the employee receiving this compensation. Links to the employee master record in Oracle Cloud HCM.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'Annual base salary amount for salaried employees or hourly rate for hourly employees. Restricted due to salary sensitivity and personal financial information.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Reason code for the compensation change (promotion, merit increase, market adjustment, equity refresh, new_hire, transfer, demotion, cost_of_living adjustment, retention, correction). Supports compensation analytics and audit trails. [ENUM-REF-CANDIDATE: promotion|merit|market_adjustment|equity_refresh|new_hire|transfer|demotion|cost_of_living|retention|correction — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed description or notes explaining the compensation change. Provides additional context beyond the change reason code.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compaRatio rdf:type rdf:Property ;
    rdfs:label 'Compa Ratio' ;
    rdfs:comment 'Comparative ratio expressing the employees compensation as a percentage of the midpoint of the pay grade range (e.g., 95.00 means 95% of midpoint). Used for compensation equity analysis. Confidential business metric.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Type of compensation component (base_salary for salaried employees, hourly_wage for manufacturing staff, variable_pay for performance-based pay, equity_grant for RSUs/options, shift_differential for GMP manufacturing staff, field_allowance for field application specialists, bonus, commission). [ENUM-REF-CANDIDATE: base_salary|hourly_wage|variable_pay|equity_grant|shift_differential|field_allowance|bonus|commission — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityGrantQuantity rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Quantity' ;
    rdfs:comment 'Number of equity units granted (shares for RSUs, options for stock options). Null if no equity grant. Restricted due to personal financial information.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equityGrantType rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Type' ;
    rdfs:comment 'Type of equity compensation granted (RSU for Restricted Stock Units, stock_option for stock options, ESPP for Employee Stock Purchase Plan, none if no equity). Confidential compensation data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityGrantValue rdf:type rdf:Property ;
    rdfs:label 'Equity Grant Value' ;
    rdfs:comment 'Fair market value of the equity grant at the time of grant. Calculated as quantity multiplied by grant price. Restricted due to salary sensitivity.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Field Allowance Amount' ;
    rdfs:comment 'Monthly or annual allowance for field application specialists covering travel, mobile devices, and customer site expenses. Null if not applicable. Confidential compensation data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Code identifying the job role associated with this compensation record (e.g., SCI_GENOMICS, ENG_BIOINFO, MFG_TECH, FSE_CLINICAL). Links compensation to job classification and organizational structure.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Pay grade or salary band assigned to this compensation record (e.g., E1, E2, M3, S5, T7). Determines the salary range and eligibility for benefits. Confidential business classification data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Identifier for the compensation review cycle or merit cycle during which this compensation was set or adjusted (e.g., 2024_ANNUAL_MERIT, 2024_Q2_PROMO). Supports compensation planning and analytics.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional hourly rate paid for non-standard shifts (night shift, weekend shift) for GMP (Good Manufacturing Practice) manufacturing staff. Null if not applicable. Confidential compensation data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variablePayAmount rdf:type rdf:Property ;
    rdfs:label 'Variable Pay Amount' ;
    rdfs:comment 'Target variable pay amount (annual bonus, commission, or performance-based incentive). Null if not applicable to this compensation record. Restricted due to salary sensitivity.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variablePayPercentage rdf:type rdf:Property ;
    rdfs:label 'Variable Pay Percentage' ;
    rdfs:comment 'Variable pay as a percentage of base salary (e.g., 15.00 for 15% target bonus). Used for executive and sales roles. Confidential business data.' ;
    rdfs:domain ind:Compensation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cliaQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Clia Qualification Status' ;
    rdfs:comment 'Current qualification status for CLIA personnel. Qualified indicates documented education, training, and competency assessment per 42 CFR 493. Pending indicates qualification in progress. Expired requires requalification. Not applicable for non-CLIA roles.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'Salary grade or band assigned to the employee. Determines compensation range, bonus eligibility, and equity participation. Used for pay equity analysis and market benchmarking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Name of the organizational department to which the employee is assigned. Reflects functional reporting structure. Examples: Sequencing Operations, Reagent Manufacturing, Clinical Genomics, Bioinformatics.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person to contact in case of employee emergency. Required for workplace safety and incident response.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact. Required for workplace safety and incident response.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Human-readable employee number assigned by HR. Externally visible identifier used on badges, timesheets, and HR documents. Distinct from system ID.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle status of the employment relationship. Active employees have system access and payroll processing. Leave and suspended statuses retain benefits. Terminated employees are historical records.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCliaPersonnel rdf:type rdf:Property ;
    rdfs:label 'Is Clia Personnel' ;
    rdfs:comment 'Indicates whether the employee performs testing or supervision in a CLIA-regulated laboratory. True for laboratory directors, technical supervisors, and testing personnel in clinical genomics. Requires documented qualifications per CLIA personnel standards.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFieldApplicationSpecialist rdf:type rdf:Property ;
    rdfs:label 'Is Field Application Specialist' ;
    rdfs:comment 'Indicates whether the employee is a Field Application Specialist providing on-site customer technical support, training, and application guidance for sequencing instruments and assays.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGxpRole rdf:type rdf:Property ;
    rdfs:label 'Is Gxp Role' ;
    rdfs:comment 'Indicates whether the employee\'s role is subject to Good Practice regulations (GMP, GLP, GCP). True for manufacturing, quality, clinical, and regulatory roles requiring documented training and qualification.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad occupational category grouping similar roles. Examples: Research and Development (R&D), Manufacturing, Quality Assurance (QA), Bioinformatics, Field Application Specialist (FAS), Corporate Functions. Used for talent management and succession planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'Date of the most recent completed performance review. Used to track review cycles and ensure timely performance management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTrainingUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Update Date' ;
    rdfs:comment 'Date of the most recent training record update. Used to monitor training currency and trigger requalification workflows.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Employee\'s legal first name as recorded in government-issued identification. Required for payroll, benefits, and regulatory compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Employee\'s legal last name as recorded in government-issued identification. Required for payroll, benefits, and regulatory compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the employee prefers to be called in workplace communications. May differ from legal name. Used in email signatures, badges, and internal systems.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Level of security clearance granted to the employee for access to sensitive data, facilities, or projects. Determines access to Protected Health Information (PHI), intellectual property (IP), and restricted areas.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Training Compliance Status' ;
    rdfs:comment 'Aggregate status of required training completion. Compliant indicates all mandatory training (GxP, safety, compliance, role-specific) is current. Overdue indicates expired or incomplete training. Critical for GxP audit readiness and regulatory compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. Determines applicability of collective bargaining agreements, grievance procedures, and labor relations policies.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Visa Expiration Date' ;
    rdfs:comment 'Expiration date of the employee\'s work authorization or visa. Null for citizens and permanent residents. Used to trigger renewal processes and ensure continuous work authorization.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visaStatus rdf:type rdf:Property ;
    rdfs:label 'Visa Status' ;
    rdfs:comment 'Immigration and work authorization status. Determines eligibility for employment, travel restrictions, and visa sponsorship requirements. Critical for compliance with immigration laws. [ENUM-REF-CANDIDATE: citizen|permanent_resident|h1b|l1|opt|ead|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the employee\'s primary work location. Determines applicable labor laws, tax jurisdiction, and regulatory compliance requirements (GDPR, HIPAA, local labor codes).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Work Email Address' ;
    rdfs:comment 'Corporate email address assigned to the employee. Primary channel for business communication and system authentication.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary physical work location. Examples: headquarters, manufacturing site, regional office, laboratory facility. Used for space planning, emergency response, and compliance reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationName rdf:type rdf:Property ;
    rdfs:label 'Work Location Name' ;
    rdfs:comment 'Human-readable name of the primary work location. Examples: San Diego Headquarters, Singapore Manufacturing, Cambridge R&D Lab.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Work Phone Number' ;
    rdfs:comment 'Primary business phone number for the employee. May be desk phone, mobile, or extension depending on role.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalId rdf:type rdf:Property ;
    rdfs:label 'Goal Id' ;
    rdfs:comment 'Unique identifier for the performance goal record. Primary key.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically a manager or executive) who approved this goal for inclusion in the performance plan.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Employee Id' ;
    rdfs:comment 'Reference to the employee who owns this goal. For individual goals, this is the goal owner. For team goals, this may reference the team lead or be null.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Goal Manager Employee Id' ;
    rdfs:comment 'Reference to the manager who approved or is responsible for overseeing this goal.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:achievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Achievement Percentage' ;
    rdfs:comment 'Percentage of goal achievement calculated as (actual_value / target_value) * 100. Values over 100% indicate over-achievement; values under 100% indicate partial achievement.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'Starting or baseline value of the metric at the beginning of the goal period. Used to calculate improvement or delta against the target.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Employee Self Assessment' ;
    rdfs:comment 'Self-assessment comments provided by the employee regarding their own progress, challenges, and achievements toward the goal.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalCategory rdf:type rdf:Property ;
    rdfs:label 'Goal Category' ;
    rdfs:comment 'Functional category of the goal. Operational goals relate to day-to-day performance; strategic goals align to long-term business objectives; development goals focus on skill-building; compliance goals ensure regulatory adherence; innovation goals drive R&D and new capabilities; quality goals target process improvement and defect reduction.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalCode rdf:type rdf:Property ;
    rdfs:label 'Goal Code' ;
    rdfs:comment 'Business identifier or code for the goal, often used for tracking and reporting purposes. May follow organizational naming conventions such as FY24-NGS-001.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalDescription rdf:type rdf:Property ;
    rdfs:label 'Goal Description' ;
    rdfs:comment 'Detailed description of the goal, including context, rationale, and any specific deliverables or milestones.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalStatus rdf:type rdf:Property ;
    rdfs:label 'Goal Status' ;
    rdfs:comment 'Current lifecycle status of the goal. Draft goals are being defined; active goals are approved and in effect; in_progress goals have begun execution; completed goals have been achieved and closed; cancelled goals were terminated before completion; deferred goals are postponed to a future period.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalType rdf:type rdf:Property ;
    rdfs:label 'Goal Type' ;
    rdfs:comment 'Classification of the goal by scope and ownership. Individual goals are owned by a single employee; team goals are shared across a team; departmental goals align to an organizational unit; corporate goals cascade from executive strategy; stretch goals are aspirational targets beyond standard expectations.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Related Flag' ;
    rdfs:comment 'Indicates whether this goal is related to Good Practice (GxP) compliance activities such as Good Manufacturing Practice (GMP), Good Laboratory Practice (GLP), or Good Clinical Practice (GCP). True if the goal involves GxP-regulated processes or deliverables.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the goal was last reviewed or assessed by the manager or employee during a check-in or formal review.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managerComments rdf:type rdf:Property ;
    rdfs:label 'Manager Comments' ;
    rdfs:comment 'Qualitative feedback and comments provided by the manager regarding goal progress, achievement, or challenges. Used during performance reviews and mid-cycle check-ins.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the target metric. Examples: gigabases per day (Gb/day), percentage (%), count, score (0-100), days, USD, FTE (Full-Time Equivalent).' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:okrAlignment rdf:type rdf:Property ;
    rdfs:label 'Okr Alignment' ;
    rdfs:comment 'Reference to the corporate or departmental Objective and Key Result (OKR) to which this goal is aligned. Ensures cascading alignment from strategic objectives to individual performance.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rdCapitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Eligible Flag' ;
    rdfs:comment 'Indicates whether work performed toward this goal is eligible for Research and Development (R&D) capitalization under accounting standards. True if the goal involves development of capitalizable intellectual property or product enhancements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Flag' ;
    rdfs:comment 'Indicates whether this goal represents a regulatory submission or approval milestone, such as FDA (Food and Drug Administration) submission, EMA (European Medicines Agency) approval, CE-IVD (Conformité Européenne In Vitro Diagnostic) certification, or CLIA (Clinical Laboratory Improvement Amendments) accreditation.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance review period. Goals are typically evaluated and closed at or before this date.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance review period during which this goal is active and measured.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategicPillar rdf:type rdf:Property ;
    rdfs:label 'Strategic Pillar' ;
    rdfs:comment 'High-level strategic pillar or theme to which this goal contributes. Examples: Innovation Leadership, Operational Excellence, Customer Success, Regulatory Compliance, Talent Development.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretchTargetValue rdf:type rdf:Property ;
    rdfs:label 'Stretch Target Value' ;
    rdfs:comment 'Optional aspirational target value beyond the standard target, used for stretch goals or exceptional performance recognition.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or target date by which the goal should be achieved. May differ from review_period_end_date for milestone-based goals.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'The specific metric or Key Performance Indicator (KPI) being measured. Examples: NGS Throughput (Gb/day), Reagent Yield (%), Regulatory Submission Count, Net Promoter Score (NPS), Time to Market (days), Cost of Goods Sold (COGS) per unit.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Defines who can view this goal. Private goals are visible only to the employee and manager; manager-visible goals are shared with the reporting chain; team-visible goals are shared with team members; department-visible goals are shared across the organizational unit; public goals are visible company-wide.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'Relative weight or importance of this goal in the employee\'s overall performance evaluation, expressed as a percentage. Typically sums to 100% across all goals for an individual in a review cycle.' ;
    rdfs:domain ind:Goal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Record Id' ;
    rdfs:comment 'Unique identifier for the GxP training record. Primary key for the training record entity.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5GxpLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Gxp Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified this training record. Part of the audit trail for regulatory compliance.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryGxpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Gxp Employee Id' ;
    rdfs:comment 'Identifier of the employee who completed or is assigned this training. Links to the employee master record in Oracle Cloud HCM.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryGxpWaiverApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Gxp Waiver Approved By Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the training waiver. Links to the employee master record. Required for audit trail when training is waived.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryGxpCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Gxp Created By User Employee Id' ;
    rdfs:comment 'User identifier of the person who created this training record. Part of the audit trail for regulatory compliance.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryGxpAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Gxp Assessor Employee Id' ;
    rdfs:comment 'Identifier of the employee who assessed or evaluated the training completion. Links to the employee master record. May be different from the trainer for independent assessment.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingItemId rdf:type rdf:Property ;
    rdfs:label 'Training Item Id' ;
    rdfs:comment 'Identifier of the specific training item or course completed. Links to the training item master that defines the training content, version, and requirements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingItem .

ind:workforceTrainingCurriculumId rdf:type rdf:Property ;
    rdfs:label 'Workforce Training Curriculum Id' ;
    rdfs:comment 'Identifier of the training curriculum to which this training record belongs. Links to the curriculum definition that specifies required training items, sequencing, and regulatory basis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceTrainingCurriculum .

ind:cliaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Required Flag' ;
    rdfs:comment 'Indicates whether this training is required for CLIA compliance. True for training that qualifies personnel to perform clinical laboratory testing under CLIA regulations (42 CFR 493).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the employee passed or failed the training assessment. Values: pass (assessment passed), fail (assessment failed), not_assessed (training completed but no assessment required), pending (assessment not yet completed).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Requalification Due Date' ;
    rdfs:comment 'Date by which requalification training must be completed to maintain continuous qualification status. Typically set before the qualification expiry date to allow time for completion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requalificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Requalification Frequency Months' ;
    rdfs:comment 'Number of months between required requalification training cycles. Defined by the curriculum and regulatory requirements. Common values include 12 (annual), 24 (biennial), or 36 (triennial) months.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingItemCode rdf:type rdf:Property ;
    rdfs:label 'Training Item Code' ;
    rdfs:comment 'Business code or catalog number for the training item. Examples include NGS-OPS-101 for Next-Generation Sequencing Operator Qualification, GMP-MFG-201 for Good Manufacturing Practice Manufacturing Technician Curriculum, CLIA-LAB-301 for Clinical Laboratory Improvement Amendments Testing Personnel Qualification.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingItemTitle rdf:type rdf:Property ;
    rdfs:label 'Training Item Title' ;
    rdfs:comment 'Full title or name of the training item or course. Examples include NGS Operator Qualification, GMP Manufacturing Technician Curriculum, CLIA Testing Personnel Qualification, CRISPR Lab Safety Program.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingVersion rdf:type rdf:Property ;
    rdfs:label 'Training Version' ;
    rdfs:comment 'Version number or revision identifier of the training item completed. Critical for GxP compliance to ensure personnel are trained on the current version of Standard Operating Procedures (SOPs) and work instructions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the training waiver was approved. Required for audit trail when training is waived.' ;
    rdfs:domain ind:GxpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Unique identifier for the headcount plan record. Primary key for the headcount planning entity.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHeadcountApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Headcount Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this headcount plan record. Supports audit trail and governance requirements.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryHeadcountLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Headcount Last Modified By User Employee Id' ;
    rdfs:comment 'The user identifier of the person who last modified this headcount plan record. Supports audit trail and data governance.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFilledHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Filled Headcount' ;
    rdfs:comment 'The actual number of Full-Time Equivalent (FTE) positions filled as of the reporting date. Sourced from Oracle Cloud HCM active assignments.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'The approved number of Full-Time Equivalent (FTE) positions after budget review and executive approval. May differ from planned_headcount due to budget constraints or strategic adjustments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Amount' ;
    rdfs:comment 'The total budget amount allocated for this headcount plan entry, including salary, benefits, and overhead. Used for Full-Time Equivalent (FTE) spend vs. budget variance reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'The three-letter International Organization for Standardization (ISO) 4217 currency code for the budget allocation amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'The business unit code for this headcount plan entry. Aligns with corporate organizational structure and Profit and Loss (P&L) reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Certified Flag' ;
    rdfs:comment 'Indicates whether the headcount in this plan entry requires Clinical Laboratory Improvement Amendments (CLIA) certification or qualification. Relevant for clinical genomics and In Vitro Diagnostic (IVD) laboratory personnel.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorFteEquivalent rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Equivalent' ;
    rdfs:comment 'The Full-Time Equivalent (FTE) count of contractors and contingent workers supporting this org unit and job family. Enables total workforce capacity analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Regulated Flag' ;
    rdfs:comment 'Indicates whether the headcount in this plan entry is subject to Good Practice Regulations (GxP) (Good Manufacturing Practice (GMP), Good Laboratory Practice (GLP), Good Clinical Practice (GCP)) compliance requirements. Drives training and qualification planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'The job level or grade for this headcount plan entry (e.g., Individual Contributor, Senior, Lead, Manager, Director, Vice President (VP), Executive). Used for workforce stratification and compensation planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openRequisitionCount rdf:type rdf:Property ;
    rdfs:label 'Open Requisition Count' ;
    rdfs:comment 'The number of open job requisitions for this org unit, job family, and fiscal period. Indicates active recruiting efforts to close the headcount gap.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective End Date' ;
    rdfs:comment 'The date when this headcount plan record ceases to be effective. Null indicates an open-ended plan. Supports temporal workforce planning and historical analysis.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Start Date' ;
    rdfs:comment 'The date when this headcount plan record becomes effective. Supports temporal workforce planning and historical analysis.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this headcount plan entry. Captures business context, assumptions, or special considerations.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'The planned number of Full-Time Equivalent (FTE) positions for this org unit, job family, and fiscal period. Represents the initial workforce plan target.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPlan rdf:type rdf:Property ;
    rdfs:label 'Variance To Plan' ;
    rdfs:comment 'The variance between approved_headcount and actual_filled_headcount (calculated as actual_filled_headcount minus approved_headcount). Negative values indicate understaffing; positive values indicate overstaffing.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cliaPersonnelCategory rdf:type rdf:Property ;
    rdfs:label 'Clia Personnel Category' ;
    rdfs:comment 'CLIA-defined personnel category for laboratory roles performing or supervising clinical testing activities. Required for clinical genomics and diagnostic laboratory positions. [ENUM-REF-CANDIDATE: testing_personnel|technical_consultant|technical_supervisor|clinical_consultant|general_supervisor|laboratory_director|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreCompetencies rdf:type rdf:Property ;
    rdfs:label 'Core Competencies' ;
    rdfs:comment 'Comma-separated list of essential technical and behavioral competencies required for success in this job profile (e.g., NGS data analysis, CRISPR design, PCR optimization, regulatory submission, quality systems, leadership, communication).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under the U.S. Fair Labor Standards Act determining overtime eligibility and wage-hour requirements.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePlanningCategory rdf:type rdf:Property ;
    rdfs:label 'Fte Planning Category' ;
    rdfs:comment 'FTE planning and budgeting category for workforce analytics and financial reporting. Aligns with cost accounting and P&L allocation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Role Flag' ;
    rdfs:comment 'Indicates whether this job profile performs GxP-regulated activities requiring documented training, qualification, and ongoing competency assessment under GMP, GLP, or GCP regulations.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gxpTrainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Requirements' ;
    rdfs:comment 'Comma-separated list of mandatory GxP training courses and qualification activities required for personnel in this job profile (e.g., GMP fundamentals, aseptic technique, data integrity, 21 CFR Part 11, deviation management).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this job profile as defined by organizational standards and regulatory requirements. [ENUM-REF-CANDIDATE: high_school|associate_degree|bachelor_degree|master_degree|doctoral_degree|postdoctoral|medical_degree|not_specified — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this job profile.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceManagementTemplate rdf:type rdf:Property ;
    rdfs:label 'Performance Management Template' ;
    rdfs:comment 'Reference to the performance management template and goal-setting framework used for employees in this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands and working conditions for this job profile (e.g., laboratory work, cleanroom environment, extended computer use, lifting requirements, standing duration).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCertifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Certifications' ;
    rdfs:comment 'Comma-separated list of professional certifications, licenses, or credentials that are preferred but not mandatory for this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEducationField rdf:type rdf:Property ;
    rdfs:label 'Preferred Education Field' ;
    rdfs:comment 'Preferred academic discipline or field of study for candidates in this job profile (e.g., molecular biology, bioinformatics, biochemistry, genetics, computer science, engineering).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Unique business identifier code for the job profile used across HR systems and organizational documentation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileDescription rdf:type rdf:Property ;
    rdfs:label 'Profile Description' ;
    rdfs:comment 'Comprehensive description of the job profile including purpose, scope, key responsibilities, and organizational impact.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Official name of the job profile as recognized in the organization\'s job architecture and compensation structure.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile indicating whether it is available for position creation and talent management activities.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryQualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Regulatory Qualification Criteria' ;
    rdfs:comment 'Specific qualification requirements mandated by regulatory bodies such as FDA, CAP, ISO 15189, or EMA for personnel performing regulated activities in this job profile.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligibility rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligibility' ;
    rdfs:comment 'Indicates whether this job profile is eligible for remote or hybrid work arrangements based on role requirements and organizational policy.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTrainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Training Requirements' ;
    rdfs:comment 'Comma-separated list of mandatory safety training courses required for this job profile (e.g., biosafety level 2, chemical hygiene, bloodborne pathogens, laser safety, ergonomics).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionPlanningTier rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Tier' ;
    rdfs:comment 'Priority tier for succession planning and talent pipeline development based on business criticality and talent scarcity.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Role Flag' ;
    rdfs:comment 'Indicates whether this job profile has direct supervisory or people management responsibilities.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalSkills rdf:type rdf:Property ;
    rdfs:label 'Technical Skills' ;
    rdfs:comment 'Comma-separated list of specific technical skills, tools, platforms, or methodologies required for this job profile (e.g., Illumina BaseSpace, Benchling, Python, R, FASTQ analysis, variant calling pipelines, SAP, LIMS).' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Expected percentage of work time requiring business travel. Particularly relevant for field application scientists, sales, and customer support roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labQualificationId rdf:type rdf:Property ;
    rdfs:label 'Lab Qualification Id' ;
    rdfs:comment 'Unique identifier for the laboratory qualification record. Primary key for the lab_qualification product.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLabEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Employee Id' ;
    rdfs:comment 'Reference to the employee who holds this laboratory qualification. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessorTitle rdf:type rdf:Property ;
    rdfs:label 'Assessor Title' ;
    rdfs:comment 'Job title or role of the assessor at the time of qualification. Examples: Senior Scientist, Lab Manager, Technical Director, Quality Assurance Manager.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccreditationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Accreditation Required Flag' ;
    rdfs:comment 'Indicates whether this qualification is required for CAP laboratory accreditation. True for qualifications mandated by CAP inspection checklists; false otherwise.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleanroomClass rdf:type rdf:Property ;
    rdfs:label 'Cleanroom Class' ;
    rdfs:comment 'ISO cleanroom classification for which the individual is qualified. ISO 5 (Class 100) through ISO 8 (Class 100,000) per ISO 14644-1. Not applicable for non-cleanroom qualifications.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyAssessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Competency Assessment Method' ;
    rdfs:comment 'Method used to assess competency for this qualification. Practical demonstration for hands-on skills; written exam for knowledge; observation for supervised performance; simulation for controlled scenarios; combination for multi-method assessment.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentRunsRequired rdf:type rdf:Property ;
    rdfs:label 'Independent Runs Required' ;
    rdfs:comment 'Number of successful independent runs required to demonstrate competency. Null for non-operational qualifications.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso13485RequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 13485 Required Flag' ;
    rdfs:comment 'Indicates whether this qualification is required for ISO 13485 medical device quality management system compliance. True for qualifications mandated by ISO 13485 personnel competency requirements; false otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labScope rdf:type rdf:Property ;
    rdfs:label 'Lab Scope' ;
    rdfs:comment 'Laboratory area, facility, or functional scope to which this qualification applies. Examples: NGS Production Lab, qPCR Lab, Gene Editing Suite, BSL-2 Containment Area, Cleanroom Zone A.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRequalificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Requalification Date' ;
    rdfs:comment 'Date of the most recent requalification assessment. Null if the individual has not yet been requalified since initial qualification.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Certificate Number' ;
    rdfs:comment 'Unique certificate or credential number issued upon successful qualification. Used for audit trail and verification purposes.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Standardized code identifying the specific qualification. Examples: NGS-NOVASEQ-OPR, QPCR-OPR, CRISPR-EDIT-L2, BSL2-AUTH, CR-GOWN-A.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Human-readable name of the laboratory qualification. Examples: NovaSeq 6000 Instrument Operator, qPCR Operator Qualification, CRISPR Gene Editing Lab Level 2, Biosafety Level 2 Authorization, Cleanroom Gowning Class A.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Requalification Status' ;
    rdfs:comment 'Current status of requalification requirement. Not required for permanent qualifications; upcoming when approaching expiry; overdue when past expiry; in progress during reassessment; completed when renewed.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the qualification was revoked due to performance issues, safety violations, or other disqualifying events. Null for qualifications that have not been revoked.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation for why the qualification was revoked. Examples: Failed requalification assessment, safety violation, quality incident, extended absence, role change. Null for qualifications that have not been revoked.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisedRunsCompleted rdf:type rdf:Property ;
    rdfs:label 'Supervised Runs Completed' ;
    rdfs:comment 'Number of supervised instrument runs, assays, or procedures completed during the qualification process. Null for non-operational qualifications.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Date on which the qualification suspension was lifted and authorization was reinstated. Null for qualifications that are currently suspended or have not been suspended.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date on which the qualification was temporarily suspended. Null for qualifications that have not been suspended.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Total number of training hours completed as part of the qualification process. Includes classroom instruction, hands-on practice, and supervised operation.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the HR lifecycle event record. Primary key.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alt5LifecycleFinalApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Lifecycle Final Approver Employee Id' ;
    rdfs:comment 'Reference to the employee who provided final approval for this lifecycle event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:newLocationId rdf:type rdf:Property ;
    rdfs:label 'New Location Id' ;
    rdfs:comment 'Reference to the work location after this lifecycle event. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:primaryLifecycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Employee Id' ;
    rdfs:comment 'Reference to the employee who is the subject of this lifecycle event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLifecyclePriorJobProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Prior Job Profile Id' ;
    rdfs:comment 'Reference to the job profile assigned to the employee before this event. Null for new hire events.' ;
