ind:primaryLifecyclePriorOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Prior Org Unit Id' ;
    rdfs:comment 'Reference to the organizational unit the employee belonged to before this event. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryLifecyclePriorPositionId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Prior Position Id' ;
    rdfs:comment 'Reference to the employee\'s position before this lifecycle event. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:priorLocationId rdf:type rdf:Property ;
    rdfs:label 'Prior Location Id' ;
    rdfs:comment 'Reference to the work location before this lifecycle event. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:quaternaryLifecycleInitiatingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Lifecycle Initiating Manager Employee Id' ;
    rdfs:comment 'Reference to the manager who initiated this lifecycle event. Critical for SOX compliance audit trail.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryLifecycleHrBusinessPartnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Lifecycle Hr Business Partner Employee Id' ;
    rdfs:comment 'Reference to the HR business partner responsible for processing this lifecycle event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLifecycleNewManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lifecycle New Manager Employee Id' ;
    rdfs:comment 'Reference to the employee\'s direct manager after this lifecycle event. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:eventComments rdf:type rdf:Property ;
    rdfs:label 'Event Comments' ;
    rdfs:comment 'Free-text field for additional notes, context, or special instructions related to this lifecycle event.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Event Effective Date' ;
    rdfs:comment 'The date when this lifecycle event becomes effective for the employee. This is the business event date, distinct from system processing timestamps. Critical for SOX compliance and GxP personnel qualification continuity per 21 CFR Part 211.25.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventReasonCode rdf:type rdf:Property ;
    rdfs:label 'Event Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the lifecycle event. Maps to Oracle Cloud HCM action reason lookup values.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Event Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for the lifecycle event. Provides context beyond the standardized reason code.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCliaQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'New Clia Qualified Flag' ;
    rdfs:comment 'Indicates whether the employee requires CLIA personnel qualification in their new role. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newEmploymentType rdf:type rdf:Property ;
    rdfs:label 'New Employment Type' ;
    rdfs:comment 'Employment classification after this lifecycle event. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFtePercentage rdf:type rdf:Property ;
    rdfs:label 'New Fte Percentage' ;
    rdfs:comment 'Full-time equivalent allocation percentage after this event. 100.00 represents full-time. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newGxpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'New Gxp Critical Flag' ;
    rdfs:comment 'Indicates whether the employee\'s new role is designated as GxP-critical requiring regulatory qualification per 21 CFR Part 211.25. Null for termination events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorCliaQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Clia Qualified Flag' ;
    rdfs:comment 'Indicates whether the employee held CLIA personnel qualification in their prior role. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Prior Employment Type' ;
    rdfs:comment 'Employment classification before this lifecycle event. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFtePercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Fte Percentage' ;
    rdfs:comment 'Full-time equivalent allocation percentage before this event. 100.00 represents full-time. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorGxpCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Gxp Critical Flag' ;
    rdfs:comment 'Indicates whether the employee\'s prior role was designated as GxP-critical requiring regulatory qualification per 21 CFR Part 211.25. Null for new hire events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemEventCode rdf:type rdf:Property ;
    rdfs:label 'Source System Event Code' ;
    rdfs:comment 'Native event identifier from the source system (Oracle Cloud HCM action ID) for traceability and reconciliation.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlEventFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Event Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event is subject to SOX personnel change control requirements due to financial system access or authority changes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemAccessChangeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'System Access Change Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event requires changes to system access permissions and roles. Critical for SOX IT general controls.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingRequalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Requalification Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event triggers mandatory GxP training requalification per 21 CFR Part 211.25.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy, enabling traversal of the organizational tree structure. Null for top-level units.' ;
