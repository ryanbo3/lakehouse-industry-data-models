ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Full official name of the conference, trade show, symposium, or industry event (e.g., American Society of Human Genetics Annual Meeting, Advances in Genome Biology and Technology).' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Event Owner Email' ;
    rdfs:comment 'Corporate email address of the event owner for coordination and communication.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOwnerName rdf:type rdf:Property ;
    rdfs:label 'Event Owner Name' ;
    rdfs:comment 'Full name of the Genomics Biotech employee who is the primary owner and coordinator for this event participation.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Event Website Url' ;
    rdfs:comment 'Official website URL for the event, providing access to event details, agenda, registration, and logistics information.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Expected Attendee Count' ;
    rdfs:comment 'Estimated total number of attendees expected at the event, provided by the organizer or based on historical data. Used for market reach assessment.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedLeadVolume rdf:type rdf:Property ;
    rdfs:label 'Expected Lead Volume' ;
    rdfs:comment 'Projected number of qualified leads expected to be generated from this event, used for pre-event planning and post-event ROI (Return on Investment) measurement.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizerName rdf:type rdf:Property ;
    rdfs:label 'Organizer Name' ;
    rdfs:comment 'Name of the organization or entity organizing the event (e.g., American Society of Human Genetics, European Society of Human Genetics, Cambridge Healthtech Institute).' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'Nature of Genomics Biotech\'s participation in the event: exhibitor (booth presence), sponsor (financial or in-kind sponsorship), speaker (presenting scientific or commercial content), attendee (passive attendance), organizer (co-organizing or hosting), virtual_participant (online-only engagement).' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationCount rdf:type rdf:Property ;
    rdfs:label 'Presentation Count' ;
    rdfs:comment 'Number of scientific or commercial presentations, posters, or talks delivered by Genomics Biotech representatives at this event.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productFocus rdf:type rdf:Property ;
    rdfs:label 'Product Focus' ;
    rdfs:comment 'Primary Genomics Biotech product family or solution being promoted at this event (e.g., NGS (Next-Generation Sequencing) platforms, array-based solutions, CRISPR gene editing tools, bioinformatics software, clinical assays).' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Registration Deadline Date' ;
    rdfs:comment 'Deadline date for event registration, booth reservation, or sponsorship commitment. Used for internal planning and coordination.' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'Level of sponsorship commitment if Genomics Biotech is a sponsor: platinum (highest tier with maximum visibility), gold, silver, bronze, exhibitor_only (booth without sponsorship), none (no sponsorship).' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical venue or facility hosting the event (e.g., Walter E. Washington Convention Center, Moscone Center, virtual platform name for online events).' ;
    rdfs:domain ind:ConferenceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountApprovalId rdf:type rdf:Property ;
    rdfs:label 'Discount Approval Id' ;
    rdfs:comment 'Unique identifier for the discount approval record. Primary key for the discount approval transaction.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceBookEntryId rdf:type rdf:Property ;
    rdfs:label 'Price Book Entry Id' ;
    rdfs:comment 'Foreign key linking to commercial.price_book_entry. Business justification: Discount approvals are for specific product pricing entries in a price book. Adding price_book_entry_id FK links the approval to the specific price book entry being discounted, enabling variance analy' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBookEntry .

ind:primaryDiscountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Discount Employee Id' ;
    rdfs:comment 'Identifier of the sales representative who submitted the discount approval request. Links to the employee or user record of the requestor.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quotationId rdf:type rdf:Property ;
    rdfs:label 'Quotation Id' ;
    rdfs:comment 'Reference to the specific quote or proposal document associated with this discount request. May be null if discount is requested before formal quote generation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Quotation .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Comments or notes provided by the approver explaining the decision rationale, conditions, or guidance for the sales team.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecision rdf:type rdf:Property ;
    rdfs:label 'Approval Decision' ;
    rdfs:comment 'Final decision made by the approver on the discount request: approved as requested, rejected, or counter-offered with alternative terms.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date by which the approved discount must be used in a closed transaction. After this date, the approval becomes invalid and a new request must be submitted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the discount approval request, formatted as DA-YYYYMMDD sequence for traceability and reference in communications.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTierRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Tier Required' ;
    rdfs:comment 'The organizational level required to approve this discount request based on the variance from standard thresholds and deal size, as defined by discount governance policy.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Approved Discount Percentage' ;
    rdfs:comment 'The final discount percentage approved by the decision maker. May differ from the requested percentage if a counter-offer was made. Null if request was rejected.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedNetPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Net Price Amount' ;
    rdfs:comment 'The final approved net price after applying the approved discount percentage. This is the price authorized for the sales transaction. Null if request was rejected.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the manager or executive who made the approval decision, included for audit trail and governance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverTitle rdf:type rdf:Property ;
    rdfs:label 'Approver Title' ;
    rdfs:comment 'Job title or role of the approver at the time of decision, documenting the organizational authority level that approved the discount.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation provided by the requesting sales representative describing the business rationale for the discount request, including competitive situation, strategic value, or customer circumstances.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveSituation rdf:type rdf:Property ;
    rdfs:label 'Competitive Situation' ;
    rdfs:comment 'Description of the competitive dynamics influencing the discount request, such as competing vendor offers, price pressure, or market positioning considerations.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOfferTerms rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Terms' ;
    rdfs:comment 'Alternative discount terms or conditions proposed by the approver when the original request cannot be approved as submitted. Populated only when approval_decision is counter_offered.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Market segment classification of the customer account, used to evaluate discount requests against segment-specific pricing strategies and discount policies.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealClosedFlag rdf:type rdf:Property ;
    rdfs:label 'Deal Closed Flag' ;
    rdfs:comment 'Indicator of whether the opportunity associated with this discount approval was successfully closed and converted to a booking. Used to measure discount approval effectiveness.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealSizeAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Size Amount' ;
    rdfs:comment 'Total value of the opportunity or deal for which the discount is being requested. Used to assess discount impact on revenue and margin.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Variance Percentage' ;
    rdfs:comment 'The difference between the requested discount and the standard threshold, representing the magnitude of the exception being requested. Calculated as requested discount minus standard threshold.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'High-level categorization of the product type for which discount is requested, enabling analysis of discount patterns by product line. [ENUM-REF-CANDIDATE: sequencing_instrument|reagent_kit|consumable|bioinformatics_service|array_product|gene_editing_tool|clinical_assay|support_service — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the genomics product or service for which the discount is being requested, such as sequencing platform model, assay kit name, or service package.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Stock Keeping Unit identifier for the genomics product or service for which the discount is requested. May represent sequencing instruments, reagent kits, consumables, or bioinformatics services.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current state of the discount approval request in the workflow, tracking progression from submission through final decision. [ENUM-REF-CANDIDATE: pending|under_review|approved|rejected|counter_offered|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the discount approval request was submitted by the sales representative. Serves as the starting point for approval turnaround time (TAT) measurement.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Requested Discount Percentage' ;
    rdfs:comment 'The discount percentage requested by the sales representative, expressed as a percentage of list price. This is the discount level requiring approval.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedNetPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Requested Net Price Amount' ;
    rdfs:comment 'The proposed net price after applying the requested discount percentage. Calculated as list price minus discount for deal evaluation.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingSalesRepName rdf:type rdf:Property ;
    rdfs:label 'Requesting Sales Rep Name' ;
    rdfs:comment 'Full name of the sales representative who submitted the discount approval request for audit trail and reporting purposes.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDiscountThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Standard Discount Threshold Percentage' ;
    rdfs:comment 'The maximum discount percentage that can be applied without requiring special approval, as defined by commercial policy for this product category and customer segment.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicValueFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Value Flag' ;
    rdfs:comment 'Indicator of whether this deal has strategic importance beyond immediate revenue, such as market entry, reference customer, or long-term partnership potential.' ;
    rdfs:domain ind:DiscountApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fasEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fas Employee Id' ;
    rdfs:comment 'Identifier of the field application scientist or application specialist who performed the activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the field application activity was performed or scheduled to be performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity End Timestamp' ;
    rdfs:comment 'Precise timestamp when the field application activity concluded.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business identifier for the field application activity, formatted as FAS- followed by 8 digits. Used for external reference and tracking.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the field application activity began.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the field application activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the field application activity performed by the FAS or application specialist.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Qualitative feedback provided by the customer regarding the field application activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Customer satisfaction rating provided after the field application activity, typically on a scale of 1 to 5.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the field application activity measured in hours.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementPhase rdf:type rdf:Property ;
    rdfs:label 'Engagement Phase' ;
    rdfs:comment 'Phase of customer engagement during which this field application activity occurred.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fasName rdf:type rdf:Property ;
    rdfs:label 'Fas Name' ;
    rdfs:comment 'Full name of the field application scientist or application specialist who performed the activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAction rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action' ;
    rdfs:comment 'Description of the follow-up action required or planned after the field application activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up action should be completed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether follow-up action is required after this field application activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User or system identifier that last modified this field application activity record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall outcome or result of the field application activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Detailed notes describing the outcome, findings, or results of the field application activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productPlatform rdf:type rdf:Property ;
    rdfs:label 'Product Platform' ;
    rdfs:comment 'Genomics product platform or instrument that was demonstrated, supported, or trained during the activity (e.g., NextSeq, NovaSeq, MiSeq).' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolName rdf:type rdf:Property ;
    rdfs:label 'Protocol Name' ;
    rdfs:comment 'Name of the sequencing or laboratory protocol optimized or demonstrated during the activity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Full street address of the customer site or facility where the activity was performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCity rdf:type rdf:Property ;
    rdfs:label 'Site City' ;
    rdfs:comment 'City where the field application activity was performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the field application activity was performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocation rdf:type rdf:Property ;
    rdfs:label 'Site Location' ;
    rdfs:comment 'Physical or virtual location where the field application activity was performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStateProvince rdf:type rdf:Property ;
    rdfs:label 'Site State Province' ;
    rdfs:comment 'State or province where the field application activity was performed.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Travel Distance Km' ;
    rdfs:comment 'Total travel distance in kilometers for the field application scientist to reach the activity site.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelRequired rdf:type rdf:Property ;
    rdfs:label 'Travel Required' ;
    rdfs:comment 'Indicates whether the field application scientist was required to travel to perform this activity.' ;
    rdfs:domain ind:FieldApplicationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User or system identifier that created this field application activity record.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Fair Assessment Id' ;
    rdfs:comment 'Foreign key linking to data.fair_assessment. Business justification: KOL collaborations (beta testing, co-development, reference publications) generate datasets requiring FAIR compliance for publication and data sharing per NIH/funding agency mandates. Engagement contr' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FairAssessment .

ind:kolId rdf:type rdf:Property ;
    rdfs:label 'Kol Id' ;
    rdfs:comment 'Reference to the master KOL person record. Links to the individual researcher or clinician being engaged.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KeyOpinionLeader .

ind:primaryKolEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Kol Employee Id' ;
    rdfs:comment 'Reference to the Genomics Biotech employee (typically a commercial or scientific affairs representative) who owns and manages the KOL relationship.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeProgramCount rdf:type rdf:Property ;
    rdfs:label 'Active Program Count' ;
    rdfs:comment 'Number of currently active engagement programs or initiatives in which the KOL is participating.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advisoryBoardParticipation rdf:type rdf:Property ;
    rdfs:label 'Advisory Board Participation' ;
    rdfs:comment 'Indicates whether the KOL currently serves on a Genomics Biotech advisory board (scientific, clinical, or commercial).' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualHonorariumAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Honorarium Amount' ;
    rdfs:comment 'Total annual honorarium or consulting fees paid to the KOL. Used for budget tracking and Sunshine Act reporting compliance.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:betaTesterParticipation rdf:type rdf:Property ;
    rdfs:label 'Beta Tester Participation' ;
    rdfs:comment 'Indicates whether the KOL is currently participating in beta testing or early access programs for new Genomics Biotech products or platforms.' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Completed' ;
    rdfs:comment 'Indicates whether the KOL has completed required compliance training (e.g., anti-bribery, data privacy, conflict of interest disclosure).' ;
    rdfs:domain ind:KolEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceTrainingDate rdf:type rdf:Property ;
