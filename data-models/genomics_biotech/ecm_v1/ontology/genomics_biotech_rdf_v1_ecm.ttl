    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:unitHeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Unit Head Employee Id' ;
    rdfs:comment 'Reference to the employee who leads this organizational unit (department head, director, VP, etc.).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Annual operating budget allocated to this organizational unit for the current fiscal year, in USD.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center Code' ;
    rdfs:comment 'General Ledger (GL) cost center code used for financial accounting and Profit and Loss (P&L) reporting in SAP S/4HANA.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual Full-Time Equivalent (FTE) headcount assigned to this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned Full-Time Equivalent (FTE) headcount for this organizational unit, used for workforce planning and capacity analysis.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s mission, scope, and responsibilities within Genomics Biotech.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric business identifier for the organizational unit, used in reporting and system integrations (e.g., NGS-OPS, BIO-ENG, GMP-MFG).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., NGS Operations, Bioinformatics Engineering, GMP Manufacturing, Clinical Assay Development, Regulatory Affairs, Field Applications).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit indicating whether it is operational, planned for future activation, or closed.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit by its hierarchical level and purpose within the enterprise structure. [ENUM-REF-CANDIDATE: department|division|lab|cost_center|business_unit|function|team — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollResultId rdf:type rdf:Property ;
    rdfs:label 'Payroll Result Id' ;
    rdfs:comment 'Unique identifier for the payroll result record. Primary key for this entity representing a single employee\'s processed payroll for a specific pay period.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Reference to the payroll run batch that generated this result. Links to the payroll run header record.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus payments included in this pay period. May include annual bonuses, spot awards, or incentive compensation.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Sales commission earnings for field application specialists and commercial staff. Calculated based on revenue attainment and commission plans.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dentalInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Dental Insurance Deduction Amount' ;
    rdfs:comment 'Employee portion of dental insurance premiums deducted from pay. Typically pre-tax under cafeteria plan.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Tax Withheld Amount' ;
    rdfs:comment 'Federal income tax withheld from gross pay per IRS regulations and employee W-4 elections. Required for SOX financial controls and tax reporting.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fsaContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Fsa Contribution Amount' ;
    rdfs:comment 'Employee pre-tax contributions to healthcare or dependent care FSA. Subject to IRS annual limits and use-it-or-lose-it rules.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPayAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Pay Amount' ;
    rdfs:comment 'Total earnings before any deductions or withholdings. Includes regular pay, overtime, shift differentials, bonuses, and other earnings components.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Deduction Amount' ;
    rdfs:comment 'Employee portion of health insurance premiums deducted from pay. May be pre-tax under Section 125 cafeteria plan.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total hours worked during the pay period including regular and overtime hours. Used for labor productivity analysis and FTE calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsaContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Hsa Contribution Amount' ;
    rdfs:comment 'Employee pre-tax contributions to HSA for high-deductible health plan participants. Subject to IRS annual limits.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Local Tax Withheld Amount' ;
    rdfs:comment 'Local or municipal income tax withheld where applicable. Includes city, county, or district taxes based on work or residence location.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Amount' ;
    rdfs:comment 'Employee portion of FICA Medicare tax withheld. Includes additional Medicare tax for high earners per ACA regulations.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPayAmount rdf:type rdf:Property ;
    rdfs:label 'Net Pay Amount' ;
    rdfs:comment 'Take-home pay after all deductions and withholdings. The amount disbursed to the employee via direct deposit or check.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Other Deductions Amount' ;
    rdfs:comment 'Sum of miscellaneous deductions not captured in standard categories. May include garnishments, union dues, charitable contributions, or loan repayments.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Hours worked beyond standard schedule at premium pay rates. Subject to FLSA regulations and company overtime policy.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePayAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Amount' ;
    rdfs:comment 'Additional earnings for hours worked beyond standard schedule. Calculated at premium rates per labor regulations and company policy.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last day of the pay period covered by this payroll result. Defines the earnings and deductions calculation window.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first day of the pay period covered by this payroll result. Used for period-based reporting and labor cost allocation.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this payroll result. Typically USD for US operations.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollFrequency rdf:type rdf:Property ;
    rdfs:label 'Payroll Frequency' ;
    rdfs:comment 'Pay cycle frequency for this employee. Determines pay period duration and payment schedule.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Status' ;
    rdfs:comment 'Current lifecycle status of this payroll result. Tracks progression from calculation through payment and supports audit trail for SOX compliance.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when this payroll result was calculated and finalized. Critical for audit trail and SOX compliance.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ptoHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Pto Hours Used' ;
    rdfs:comment 'Paid time off hours taken during this pay period. Reduces available PTO balance and is included in gross pay calculation.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rdCapitalizationAmount rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Amount' ;
    rdfs:comment 'Portion of labor cost eligible for R&D capitalization per accounting standards. Used for financial statement preparation and tax credits.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rdCapitalizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Percentage' ;
    rdfs:comment 'Percentage of gross pay allocated to R&D capitalization. Determined by employee role, project assignment, and accounting policy.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Standard hours worked at base pay rate. Excludes overtime and premium hours.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPayAmount rdf:type rdf:Property ;
    rdfs:label 'Regular Pay Amount' ;
    rdfs:comment 'Base earnings for standard hours worked during the pay period. Excludes overtime, bonuses, and other supplemental pay.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Retirement Contribution Amount' ;
    rdfs:comment 'Employee pre-tax or Roth contributions to 401(k) retirement plan. Voluntary deduction subject to IRS annual limits.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Amount' ;
    rdfs:comment 'Premium pay for GMP manufacturing staff working non-standard shifts (evening, night, weekend). Critical for labor cost analysis in regulated manufacturing operations.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Amount' ;
    rdfs:comment 'Employee portion of FICA Social Security tax withheld. Calculated at statutory rate up to annual wage base limit.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateTaxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'State Tax Withheld Amount' ;
    rdfs:comment 'State income tax withheld based on employee work location and state tax regulations. Varies by jurisdiction.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Total Deductions Amount' ;
    rdfs:comment 'Sum of all tax withholdings and voluntary deductions subtracted from gross pay. Used to calculate net pay.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsuranceDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Vision Insurance Deduction Amount' ;
    rdfs:comment 'Employee portion of vision insurance premiums deducted from pay. Typically pre-tax under cafeteria plan.' ;
    rdfs:domain ind:PayrollResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key for the performance review entity.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to the employee master record in Oracle Cloud HCM.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewCycleId rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Id' ;
    rdfs:comment 'Identifier of the performance review cycle (e.g., FY2024 Annual Review, Q2 2024 Mid-Year Review). Links to the review cycle configuration.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCycle .

ind:bonusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for performance bonus based on review results. True if performance meets bonus criteria, False otherwise. Used for incentive compensation planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Collaboration Competency Rating' ;
    rdfs:comment 'Rating for collaboration and teamwork competencies including cross-functional collaboration, communication effectiveness, and stakeholder engagement.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Development Areas Summary' ;
    rdfs:comment 'Summary of areas where the employee needs development or improvement. Informs individual development plans and training recommendations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date when the employee acknowledged receipt and review of their performance evaluation. Required for review cycle closure and compliance.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'Flight Risk Indicator' ;
    rdfs:comment 'Assessment of the employee\'s risk of voluntary turnover based on performance review discussions, engagement signals, and manager assessment. Values: low (low risk of departure), medium (moderate risk), high (high risk), critical (imminent risk of departure). Used for retention planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAchievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Goal Achievement Percentage' ;
    rdfs:comment 'Percentage of goals achieved by the employee during the review period. Calculated as (goals_achieved_count / goals_total_count) * 100. Key metric for performance evaluation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goalsAchievedCount rdf:type rdf:Property ;
    rdfs:label 'Goals Achieved Count' ;
    rdfs:comment 'Number of goals fully achieved by the employee during the review period. Used to calculate goal achievement rate and inform overall performance rating.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalsTotalCount rdf:type rdf:Property ;
    rdfs:label 'Goals Total Count' ;
    rdfs:comment 'Total number of goals assigned to the employee for the review period. Used to calculate goal achievement rate.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highPotentialFlag rdf:type rdf:Property ;
    rdfs:label 'High Potential Flag' ;
    rdfs:comment 'Indicates whether the employee is identified as high potential talent based on performance, competencies, and leadership potential. True if designated as HiPo, False otherwise. Used for talent development and retention strategies.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hrApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hr Approval Date' ;
    rdfs:comment 'Date when the performance review was approved by HR. Final step in the review workflow before archival.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:innovationCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Innovation Competency Rating' ;
    rdfs:comment 'Rating for innovation and continuous improvement competencies including process optimization, creative problem-solving, and contribution to R&D initiatives.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Competency Rating' ;
    rdfs:comment 'Rating for leadership competencies including people management, strategic thinking, decision-making, and team development. Applicable to managers and individual contributors demonstrating leadership.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerNarrative rdf:type rdf:Property ;
    rdfs:label 'Manager Narrative' ;
    rdfs:comment 'Detailed narrative feedback provided by the manager summarizing the employee\'s performance, accomplishments, areas for improvement, and development recommendations. Supports the overall rating and competency assessments.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for merit-based salary increase based on performance rating. True if performance meets merit increase criteria, False otherwise. Used for compensation planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'Recommended merit increase percentage based on performance rating and calibration. Used by compensation team for salary adjustment decisions. Confidential business data.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned to the employee for the review period. Values: exceeds_expectations (consistently exceeds performance expectations), meets_expectations (meets all performance expectations), needs_improvement (performance below expectations, improvement required), unsatisfactory (performance significantly below expectations), outstanding (exceptional performance, far exceeds expectations).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall performance rating. Typically on a scale of 1.0 to 5.0, where higher scores indicate better performance. Used for merit increase calculations and talent analytics.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Pip Recommended Flag' ;
    rdfs:comment 'Indicates whether a Performance Improvement Plan is recommended for the employee due to unsatisfactory performance. True if PIP is recommended, False otherwise. Triggers HR intervention and formal improvement process.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preCalibrationRating rdf:type rdf:Property ;
    rdfs:label 'Pre Calibration Rating' ;
    rdfs:comment 'Original overall performance rating assigned by the manager before calibration session. Retained for audit trail and calibration analysis.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for promotion based on performance review results. True if performance meets or exceeds promotion criteria, False otherwise. Used for talent review and succession planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Summary of the employee\'s key strengths and areas of excellence identified during the review. Used for talent development and succession planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successionReadinessLevel rdf:type rdf:Property ;
    rdfs:label 'Succession Readiness Level' ;
    rdfs:comment 'Assessment of the employee\'s readiness for succession to higher-level roles. Values: ready_now (ready for immediate promotion), ready_1_year (ready within 1 year with development), ready_2_3_years (ready within 2-3 years with development), not_ready (not ready for advancement), not_applicable (role not in succession planning scope). Used for talent pipeline and succession planning.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Rating for technical competencies specific to the employee\'s role (e.g., NGS sequencing expertise, bioinformatics pipeline development, GMP manufacturing knowledge, regulatory submission proficiency). Evaluates domain-specific technical skills.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedGoalScore rdf:type rdf:Property ;
    rdfs:label 'Weighted Goal Score' ;
    rdfs:comment 'Weighted average score of all goals based on goal weights and achievement levels. Calculated by summing (goal_weight * goal_achievement_score) for all goals. Used in overall performance rating calculation.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the supervisory position to which this position reports, enabling organizational hierarchy traversal.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:actualFilledCount rdf:type rdf:Property ;
    rdfs:label 'Actual Filled Count' ;
    rdfs:comment 'Current actual FTE count for this position reflecting whether it is filled, partially filled, or vacant.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cliaDirectorFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Director Flag' ;
    rdfs:comment 'Indicates whether the position is designated as a CLIA laboratory director responsible for overall operation and administration of the laboratory.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaSupervisorFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Supervisor Flag' ;
    rdfs:comment 'Indicates whether the position is designated as a CLIA technical supervisor or clinical consultant responsible for day-to-day supervision of testing personnel.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'Classification of the position as exempt or non-exempt from overtime pay requirements under labor law.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpDesignatedFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Designated Flag' ;
    rdfs:comment 'Indicates whether the position requires GxP training and qualification due to involvement in regulated activities (GMP, GLP, GCP). Critical for compliance tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Business identifier for the position used in workforce planning and reporting. Externally-known unique code for the position.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position responsibilities, qualifications, and key accountabilities used for recruitment and performance management.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the position indicating whether it is filled, vacant, frozen for budget reasons, or eliminated.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Flag' ;
    rdfs:comment 'Indicates whether the position is designated as safety-sensitive requiring additional screening and compliance measures for GMP manufacturing or laboratory operations.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requisitionCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Created By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who created this requisition record. Typically the hiring manager or recruiter initiating the hiring request.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Hiring Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the hiring manager responsible for candidate selection and final hiring decision.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Last Modified By Employee Id' ;
    rdfs:comment 'Employee identifier of the user who last updated this requisition record. Supports change tracking and audit compliance.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requisitionRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requisition Recruiter Employee Id' ;
    rdfs:comment 'Employee identifier of the talent acquisition specialist or recruiter assigned to manage the candidate pipeline for this requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'EEO-1 job category classification for regulatory reporting to the U.S. Equal Employment Opportunity Commission. Required for diversity and inclusion compliance reporting. [ENUM-REF-CANDIDATE: executive|manager|professional|technician|sales|administrative|craft|operative|laborer|service — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Posting Flag' ;
    rdfs:comment 'Indicates whether this requisition is posted internally for current employee applications before external posting. Supports internal mobility and career development programs.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date the requisition was opened and made available for candidate applications. Start point for time-to-fill KPI calculation.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingDescription rdf:type rdf:Property ;
    rdfs:label 'Posting Description' ;
    rdfs:comment 'Detailed job description published to external candidates, including responsibilities, qualifications, required skills, and company overview. Optimized for candidate attraction and employer branding.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Posting Location Description' ;
    rdfs:comment 'Geographic location description displayed in job postings. May include city, state, country, or remote designation. Used for candidate filtering and location-based search.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'External-facing job title displayed on career sites, job boards, and recruiting channels. May differ from internal position title for market competitiveness.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Channel' ;
    rdfs:comment 'Primary recruitment channel or platform used to source candidates for this requisition: LinkedIn, Indeed, Glassdoor, employee referral, campus recruiting, staffing agency, company career site, or professional network (e.g., scientific societies). [ENUM-REF-CANDIDATE: linkedin|indeed|glassdoor|referral|campus|agency|career_site|professional_network — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the requisition: draft (being prepared), pending approval (awaiting headcount authorization), approved (authorized but not yet posted), open (actively recruiting), on hold (temporarily paused), filled (candidate hired), cancelled (no longer needed), or closed (completed process). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|open|on_hold|filled|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition purpose: new headcount creation, replacement for departed employee, backfill for leave, contractor-to-FTE conversion, intern program, or temporary assignment.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for salary range (e.g., USD, EUR, GBP). Supports global recruiting operations across multiple countries.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMaximum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Maximum' ;
    rdfs:comment 'Maximum annual base salary for the position in the specified currency. Represents top of compensation band for highly experienced candidates.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMinimum rdf:type rdf:Property ;
    rdfs:label 'Salary Range Minimum' ;
    rdfs:comment 'Minimum annual base salary for the position in the specified currency. Used for budget planning and candidate offer preparation. May be disclosed in jurisdictions with pay transparency laws.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired start date for the new hire. Used for workforce planning, onboarding preparation, and time-to-fill metrics.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Number of calendar days from requisition open date to requisition close date (hire completion). Key recruiting efficiency KPI and talent acquisition performance metric.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalApplicants rdf:type rdf:Property ;
    rdfs:label 'Total Applicants' ;
    rdfs:comment 'Total number of candidates who applied to this requisition. Used for recruiting funnel analytics and sourcing effectiveness measurement.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalHires rdf:type rdf:Property ;
    rdfs:label 'Total Hires' ;
    rdfs:comment 'Number of candidates who accepted offers and were successfully hired under this requisition. Final funnel conversion metric.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInterviewed rdf:type rdf:Property ;
    rdfs:label 'Total Interviewed' ;
    rdfs:comment 'Number of candidates who participated in formal interviews (phone screen, video, or onsite). Key recruiting funnel stage metric.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOffersExtended rdf:type rdf:Property ;
    rdfs:label 'Total Offers Extended' ;
    rdfs:comment 'Number of formal employment offers extended to candidates for this requisition. Used to calculate offer acceptance rate and hiring efficiency.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalScreened rdf:type rdf:Property ;
    rdfs:label 'Total Screened' ;
    rdfs:comment 'Number of candidates who passed initial resume screening and were advanced to recruiter or hiring manager review. Funnel conversion metric.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:talentProfileId rdf:type rdf:Property ;
    rdfs:label 'Talent Profile Id' ;
    rdfs:comment 'Unique identifier for the talent profile record. Primary key.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abmggCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Abmgg Certified Flag' ;
    rdfs:comment 'Indicates whether the employee holds ABMGG certification in clinical genetics or genomics, required for genetic counselors and clinical geneticists.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:additionalLanguages rdf:type rdf:Property ;
    rdfs:label 'Additional Languages' ;
    rdfs:comment 'Comma-separated list of additional languages the employee is proficient in, supporting international operations and field application support.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ascpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Ascp Certified Flag' ;
    rdfs:comment 'Indicates whether the employee holds ASCP certification (e.g., MLS, MT, MB), a recognized credential for clinical laboratory professionals.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bioinformaticsPipelineProficiency rdf:type rdf:Property ;
    rdfs:label 'Bioinformatics Pipeline Proficiency' ;
    rdfs:comment 'Employee\'s skill level in developing and maintaining bioinformatics pipelines for genomic data processing, variant calling, and annotation.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerAspiration rdf:type rdf:Property ;
    rdfs:label 'Career Aspiration' ;
    rdfs:comment 'Free-text description of the employee\'s stated career goals and aspirations, used for development planning and succession management.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalAssayValidationProficiency rdf:type rdf:Property ;
    rdfs:label 'Clinical Assay Validation Proficiency' ;
    rdfs:comment 'Employee\'s skill level in clinical assay validation processes, essential for IVD and LDT development under CLIA and FDA regulations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crisprEditingProficiency rdf:type rdf:Property ;
    rdfs:label 'Crispr Editing Proficiency' ;
    rdfs:comment 'Employee\'s skill level in CRISPR gene editing techniques, critical for gene editing tool development and research applications.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalTalentFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Talent Flag' ;
    rdfs:comment 'Indicates whether the employee possesses rare or mission-critical skills that are difficult to replace, requiring retention focus.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:developmentPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Development Plan Status' ;
    rdfs:comment 'Current status of the employee\'s individual development plan, tracking progress toward skill and competency goals.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationField rdf:type rdf:Property ;
    rdfs:label 'Education Field' ;
    rdfs:comment 'Primary field or discipline of the employee\'s highest degree (e.g., Molecular Biology, Bioinformatics, Biochemistry, Mechanical Engineering, Computer Science). Essential for matching talent to genomics-specific roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMobilityPreference rdf:type rdf:Property ;
    rdfs:label 'Geographic Mobility Preference' ;
    rdfs:comment 'Employee\'s stated willingness to relocate for career opportunities, critical for succession planning and internal mobility programs.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpExperienceFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Experience Flag' ;
    rdfs:comment 'Indicates whether the employee has hands-on experience working in GMP-regulated manufacturing environments, required for reagent and consumable production roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:graduationYear rdf:type rdf:Property ;
    rdfs:label 'Graduation Year' ;
    rdfs:comment 'Year the employee completed their highest degree, used for experience calculation and career progression analysis.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gxpTrainingCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Gxp Training Current Flag' ;
    rdfs:comment 'Indicates whether the employee\'s GxP training qualifications (GMP, GLP, GCP) are current and up-to-date, mandatory for regulated roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Level' ;
    rdfs:comment 'Overall language proficiency level for additional languages, used to assess readiness for international assignments and customer interactions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompetencyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Competency Assessment Date' ;
    rdfs:comment 'Date of the most recent formal competency assessment, ensuring skills and qualifications are current for GxP and regulatory compliance.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limsProficiency rdf:type rdf:Property ;
    rdfs:label 'Lims Proficiency' ;
    rdfs:comment 'Employee\'s skill level in using LIMS platforms (e.g., LabVantage) for sample tracking, workflow management, and laboratory operations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCompetencyAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Competency Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next competency assessment, ensuring ongoing qualification for regulated roles and continuous skill validation.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ngsLibraryPrepProficiency rdf:type rdf:Property ;
    rdfs:label 'Ngs Library Prep Proficiency' ;
    rdfs:comment 'Employee\'s skill level in NGS library preparation techniques, a core competency for laboratory scientists in genomics sequencing operations.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patentsCount rdf:type rdf:Property ;
    rdfs:label 'Patents Count' ;
    rdfs:comment 'Number of patents filed or granted with the employee as inventor, indicating innovation contribution and intellectual property generation.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmpCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Pmp Certified Flag' ;
    rdfs:comment 'Indicates whether the employee holds PMP certification, valuable for project managers overseeing product development and commercialization initiatives.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCareerPath rdf:type rdf:Property ;
    rdfs:label 'Preferred Career Path' ;
    rdfs:comment 'The employee\'s preferred career trajectory (technical vs. managerial), informing development and succession planning decisions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Primary Language' ;
    rdfs:comment 'The employee\'s primary working language, important for global collaboration and customer-facing roles.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalCertifications rdf:type rdf:Property ;
    rdfs:label 'Professional Certifications' ;
    rdfs:comment 'Comma-separated list of additional professional certifications held by the employee (e.g., Six Sigma, Lean, AWS Certified Solutions Architect, Certified Quality Engineer).' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Profile Last Updated Date' ;
    rdfs:comment 'Date when the talent profile was last updated by the employee or HR, ensuring data currency for talent decisions.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qpcrProficiency rdf:type rdf:Property ;
    rdfs:label 'Qpcr Proficiency' ;
    rdfs:comment 'Employee\'s skill level in qPCR techniques, a foundational molecular biology competency for genomics research and quality control.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Relocation Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is currently eligible for company-sponsored relocation based on tenure, performance, and business need.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillsGapAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Skills Gap Analysis Date' ;
    rdfs:comment 'Date of the most recent skills gap analysis conducted for this employee, used to track development needs and training effectiveness.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successionPlanningReadiness rdf:type rdf:Property ;
    rdfs:label 'Succession Planning Readiness' ;
    rdfs:comment 'Assessment of the employee\'s readiness to assume higher-level or critical roles, used for talent pipeline and succession planning.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCallingProficiency rdf:type rdf:Property ;
    rdfs:label 'Variant Calling Proficiency' ;
    rdfs:comment 'Employee\'s skill level in variant calling and interpretation from sequencing data, critical for clinical genomics and research applications.' ;
    rdfs:domain ind:TalentProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry data product.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Reference to the employee who recorded this time entry. Links to the employee master data.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Specific activity or task performed during this time period. Supports detailed labor cost analysis and R&D capitalization eligibility determination.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capitalization Percentage' ;
    rdfs:comment 'Percentage of labor cost from this time entry that should be capitalized as R&D asset. Supports partial capitalization scenarios.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cliaQualifiedActivityFlag rdf:type rdf:Property ;
    rdfs:label 'Clia Qualified Activity Flag' ;
    rdfs:comment 'Indicates whether this time was spent on CLIA-regulated clinical laboratory activities requiring personnel qualification. Critical for CAP accreditation and CLIA compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Posted Flag' ;
    rdfs:comment 'Indicates whether labor cost from this time entry has been posted to the general ledger. Critical for financial close and SOX compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when labor cost was posted to the general ledger. Used for period-end close and financial reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpProductionFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Production Flag' ;
    rdfs:comment 'Indicates whether this time was spent on GMP-regulated manufacturing activities. Used for regulatory compliance reporting and labor cost allocation to production batches.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this time entry including base pay, overtime premium, and shift differential. Used for cost accounting and R&D capitalization.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Shift identifier for manufacturing and laboratory operations. Used for shift differential calculation and 24/7 operations management.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeTypeCode rdf:type rdf:Property ;
    rdfs:label 'Time Type Code' ;
    rdfs:comment 'Classification of the time worked. Determines pay rate multiplier and labor cost treatment. Critical for GMP manufacturing staff overtime tracking and SOX-compliant labor reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumOwnerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Curriculum Owner Org Unit Id' ;
    rdfs:comment 'Organizational unit responsible for this curriculum (e.g., Quality Assurance, Training Department, Manufacturing Operations).' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:mastercontrolDocumentId rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Document Id' ;
    rdfs:comment 'Reference identifier to the source curriculum document in MasterControl document management system.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:primaryWorkforceCurriculumOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Curriculum Owner Employee Id' ;
    rdfs:comment 'Employee responsible for maintaining and updating this curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableJobProfiles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Profiles' ;
    rdfs:comment 'Comma-separated list or structured description of job profiles, roles, or position codes for which this curriculum is required (e.g., NGS Operator, Manufacturing Technician II, Clinical Lab Director).' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Required Flag' ;
    rdfs:comment 'Indicates whether this curriculum is mandatory for CAP-accredited laboratory personnel.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Name of the certification or qualification awarded upon curriculum completion. Null if no certification is issued.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumStatus rdf:type rdf:Property ;
    rdfs:label 'Curriculum Status' ;
    rdfs:comment 'Current lifecycle status of the training curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Hours' ;
    rdfs:comment 'Estimated total time in hours required to complete all training items in this curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Required Flag' ;
    rdfs:comment 'Indicates whether this curriculum is mandatory for Good Clinical Practice compliance.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Required Flag' ;
    rdfs:comment 'Indicates whether this curriculum is mandatory for Good Laboratory Practice compliance.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryItemsCount rdf:type rdf:Property ;
    rdfs:label 'Mandatory Items Count' ;
    rdfs:comment 'Number of training items within this curriculum that are mandatory for completion.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPassingScorePercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score Percent' ;
    rdfs:comment 'Minimum percentage score required to pass curriculum assessments. Null if no assessment is required.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practicalDemonstrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Practical Demonstration Required Flag' ;
    rdfs:comment 'Indicates whether hands-on practical demonstration of skills is required as part of this curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prerequisites rdf:type rdf:Property ;
    rdfs:label 'Prerequisites' ;
    rdfs:comment 'Description of any prerequisite qualifications, experience, or prior training required before enrolling in this curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requalificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Requalification Required Flag' ;
    rdfs:comment 'Indicates whether periodic requalification is required after initial curriculum completion.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequencingRules rdf:type rdf:Property ;
    rdfs:label 'Sequencing Rules' ;
    rdfs:comment 'Structured description of the order and dependencies in which training items must be completed (e.g., prerequisite requirements, parallel vs sequential completion).' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceDescription rdf:type rdf:Property ;
    rdfs:label 'Target Audience Description' ;
    rdfs:comment 'Detailed description of the intended audience for this curriculum, including role characteristics, experience level, and functional area.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTrainingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Total Training Items Count' ;
    rdfs:comment 'Total number of individual training items (courses, modules, assessments) included in this curriculum.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workforceTrainingCurriculumDescription rdf:type rdf:Property ;
    rdfs:label 'Workforce Training Curriculum Description' ;
    rdfs:comment 'Comprehensive description of the curriculum purpose, scope, learning objectives, and business context.' ;
    rdfs:domain ind:WorkforceTrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Agreement Id' ;
    rdfs:comment 'Unique identifier for this sourcing agreement record. Primary key.' ;
    rdfs:domain ind:SourcingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPurchasePrice rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price' ;
    rdfs:comment 'Actual unit price paid on the most recent purchase order for this supplier-material combination. Used for price variance analysis and negotiation benchmarking.' ;
    rdfs:domain ind:SourcingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the preferred source for this material based on quality, price, reliability, or strategic relationship. Used by MRP and procurement to prioritize sourcing decisions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'End date of the current negotiated price validity period. After this date, the price must be renegotiated or the agreement becomes inactive.' ;
    rdfs:domain ind:SourcingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'Start date of the current negotiated price validity period for this supplier-material agreement. Prices are time-bound and require renegotiation after expiry.' ;
    rdfs:domain ind:SourcingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Clinical Enrollment Id' ;
    rdfs:comment 'Primary key for clinical_enrollment' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollingInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Enrolling Investigator Employee Id' ;
    rdfs:comment 'Reference to the employee record of the investigator or research coordinator who enrolled this patient into the study. Used for enrollment attribution and audit trail.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:participantPatientId rdf:type rdf:Property ;
    rdfs:label 'Participant Patient Id' ;
    rdfs:comment 'De-identified study-specific participant identifier assigned to the patient for this research project. Used to protect patient identity in research datasets while maintaining linkage to clinical records.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patient .

ind:biospecimenCollectionFlag rdf:type rdf:Property ;
    rdfs:label 'Biospecimen Collection Flag' ;
    rdfs:comment 'Boolean flag indicating whether the patient has consented to biospecimen collection and storage for this research project. Distinct from clinical specimen consent.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cohortAssignment rdf:type rdf:Property ;
    rdfs:label 'Cohort Assignment' ;
    rdfs:comment 'The specific cohort, arm, or subgroup within the research project to which this patient is assigned. Used for stratified enrollment tracking and analysis group management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Data Use Authorization Flag' ;
    rdfs:comment 'Boolean flag indicating whether the patient has authorized use of their clinical genomic data for this specific research project beyond the primary clinical indication. Required for secondary use compliance.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Irb Protocol Version' ;
    rdfs:comment 'Version of the IRB-approved protocol under which this patient was enrolled. Used to track protocol amendments and ensure patients are enrolled under current approved version.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationArm rdf:type rdf:Property ;
    rdfs:label 'Randomization Arm' ;
    rdfs:comment 'The randomization arm or treatment group assigned to this patient in interventional studies. Null for observational studies. Used for blinded trial management.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:site rdf:type rdf:Property ;
    rdfs:label 'Site' ;
    rdfs:comment 'The clinical site or research center where this patient was enrolled into the study. Used for multi-site study management and site-level enrollment tracking.' ;
    rdfs:domain ind:ClinicalEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Project Investigator Id' ;
    rdfs:comment 'Unique surrogate identifier for the project investigator assignment record' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Co Investigator Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment represents a Co-Investigator (co-I) role with shared scientific responsibility. Multiple co-investigators may exist per project.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationLogReference rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Reference' ;
    rdfs:comment 'Reference identifier or document number linking to the formal delegation of authority log that documents which specific study tasks and responsibilities have been delegated to this investigator. Required for GCP compliance and regulatory inspections.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effortPercent rdf:type rdf:Property ;
    rdfs:label 'Effort Percent' ;
    rdfs:comment 'Percentage of the investigator\'s professional effort allocated to this research project, expressed as a decimal (e.g., 15.00 for 15% effort). Required for NIH effort reporting, institutional conflict of interest monitoring, and project resource planning. Must sum to ≤100% across all concurrent project assignments for the investigator.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fda1572SignedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda 1572 Signed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this investigator has signed FDA Form 1572 (Statement of Investigator) for this project. Required for clinical investigations subject to FDA IND or IDE regulations.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorRole rdf:type rdf:Property ;
    rdfs:label 'Investigator Role' ;
    rdfs:comment 'The specific investigator role assigned to the authorized orderer on this project. Determines regulatory responsibilities, signature authority, and reporting requirements. Values: principal_investigator (PI with overall scientific and regulatory responsibility), co_investigator (co-I with shared scientific responsibility), sub_investigator (sub-I delegated specific tasks), site_investigator (multi-site trial site lead), consulting_investigator (advisory role without regulatory responsibility).' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbListedFlag rdf:type rdf:Property ;
    rdfs:label 'Irb Listed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this investigator is formally listed on the IRB protocol submission for this project. IRB-listed investigators have specific training and compliance obligations.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:principalInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment represents the Principal Investigator (PI) role with ultimate scientific and regulatory responsibility for the project. Only one investigator per project should have this flag set to true at any given time.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Authority Flag' ;
    rdfs:comment 'Boolean flag indicating whether this investigator has been granted signature authority for regulatory documents, protocol amendments, or study reports associated with this project. Typically true for PI and selected co-investigators.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subInvestigatorFlag rdf:type rdf:Property ;
    rdfs:label 'Sub Investigator Flag' ;
    rdfs:comment 'Boolean flag indicating whether this assignment represents a Sub-Investigator (sub-I) role with delegated specific tasks under PI supervision. Multiple sub-investigators may exist per project.' ;
    rdfs:domain ind:ProjectInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runSampleId rdf:type rdf:Property ;
    rdfs:label 'Run Sample Id' ;
    rdfs:comment 'Unique surrogate identifier for this specimen-run assignment record. Primary key for the run_sample association.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcReviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewed By Employee Id' ;
    rdfs:comment 'Reference to the laboratory scientist or bioinformatician who reviewed the QC metrics and assigned the run_qc_status for this specimen-run pairing.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Actual Coverage Depth' ;
    rdfs:comment 'Actual average sequencing coverage depth achieved for this specimen in this run, calculated from actual_reads_generated and reference genome size. Compared against target_coverage_depth to assess run success.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReadsGenerated rdf:type rdf:Property ;
    rdfs:label 'Actual Reads Generated' ;
    rdfs:comment 'Total number of sequencing reads (or read pairs for paired-end) generated for this specimen in this run, as determined by demultiplexing. Used to calculate actual coverage and assess run balance. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demultiplexedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Demultiplexed Timestamp' ;
    rdfs:comment 'Date and time when demultiplexing completed for this specimen, producing specimen-specific FASTQ files. Marks when per-specimen data became available.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:duplicateRate rdf:type rdf:Property ;
    rdfs:label 'Duplicate Rate' ;
    rdfs:comment 'Percentage of reads identified as PCR duplicates for this specimen. High duplicate rates indicate over-amplification during library prep or low library complexity.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fastqFilePath rdf:type rdf:Property ;
    rdfs:label 'Fastq File Path' ;
    rdfs:comment 'File system path or cloud storage URI to the demultiplexed FASTQ files for this specimen from this run. Links sequencing data to downstream bioinformatics pipelines.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadingConcentrationNm rdf:type rdf:Property ;
    rdfs:label 'Loading Concentration Nm' ;
    rdfs:comment 'Molar concentration (nanomolar, nM) of this specimen\'s library at the time of loading into the sequencing run. Influences cluster density and read balance across multiplexed specimens. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanInsertSize rdf:type rdf:Property ;
    rdfs:label 'Mean Insert Size' ;
    rdfs:comment 'Average insert size (distance between paired-end reads) for this specimen\'s library in base pairs. Used to assess library preparation quality and detect size selection issues.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentAligned rdf:type rdf:Property ;
    rdfs:label 'Percent Aligned' ;
    rdfs:comment 'Percentage of this specimen\'s reads that successfully aligned to the reference genome. Low alignment rates indicate contamination, adapter issues, or sample quality problems.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolPosition rdf:type rdf:Property ;
    rdfs:label 'Pool Position' ;
    rdfs:comment 'Position or slot number of this specimen within the multiplexed pool loaded into the lane. Used for tracking specimen order during library pooling. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runQcStatus rdf:type rdf:Property ;
    rdfs:label 'Run Qc Status' ;
    rdfs:comment 'Quality control status for this specimen in this run: pass (meets quality thresholds), fail (requires re-sequencing), warning (marginal quality), pending (QC not yet complete). Drives re-sequencing decisions. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:RunSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this supply agreement record. Primary key.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Rank' ;
    rdfs:comment 'Ranking of this supplier for this catalog item (1=primary, 2=secondary, etc.). Used in procurement decision logic and automated sourcing workflows.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantityPurchased rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Purchased' ;
    rdfs:comment 'Cumulative quantity of this catalog item purchased from this supplier across all purchase orders. Supports volume-based pricing negotiations and supplier performance analysis.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessControlDpiaAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Access Control Dpia Assessment Id' ;
    rdfs:comment 'Primary key for the access_control_dpia_assessment association' ;
    rdfs:domain ind:AccessControlDpiaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'The formal outcome of the DPIA assessment for this specific access control policy. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AccessControlDpiaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Actions Required' ;
    rdfs:comment 'Specific remediation actions required for this access control policy as determined by the DPIA assessment. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AccessControlDpiaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevelAssigned rdf:type rdf:Property ;
    rdfs:label 'Risk Level Assigned' ;
    rdfs:comment 'Risk level assigned to this specific access control policy during the DPIA evaluation, reflecting the assessed risk to data subject rights and freedoms. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AccessControlDpiaAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactTagAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Artifact Tag Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each artifact-tag assignment record' ;
    rdfs:domain ind:ArtifactTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or identifier of the data steward who approved this tag assignment, if approval was required' ;
    rdfs:domain ind:ArtifactTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedByUser rdf:type rdf:Property ;
    rdfs:label 'Assigned By User' ;
    rdfs:comment 'Username or identifier of the user or system that assigned this tag to the artifact' ;
    rdfs:domain ind:ArtifactTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketAgreementId rdf:type rdf:Property ;
    rdfs:label 'Blanket Agreement Id' ;
    rdfs:comment 'Unique identifier for this instrument-specific blanket agreement record. Primary key for the association.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compatibleReagentFamilies rdf:type rdf:Property ;
    rdfs:label 'Compatible Reagent Families' ;
    rdfs:comment 'Comma-separated list of reagent kit families or SKU groups covered for this instrument model under the blanket agreement. Defines the scope of products eligible for call-off releases.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelAgreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Model Agreement End Date' ;
    rdfs:comment 'Expiration date when this instrument model coverage terminates under the blanket order. May differ from overall agreement end date if models are phased out or replaced.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelAgreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Model Agreement Start Date' ;
    rdfs:comment 'Effective start date when this instrument model was added to the blanket order agreement. May differ from the overall blanket order start date if models are added mid-term.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modelCommittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Model Committed Quantity' ;
    rdfs:comment 'Total quantity of reagent kits or consumables committed for this specific instrument model under the blanket order. Represents the model-level volume commitment within the overall agreement.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelConsumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Model Consumed Quantity' ;
    rdfs:comment 'Cumulative quantity that has been released and consumed for this specific instrument model against the blanket order. Tracked separately per model to monitor consumption rates and trigger replenishment.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Model Lead Time Days' ;
    rdfs:comment 'Standard lead time in days from release request to delivery for reagents specific to this instrument model. Varies by model due to manufacturing complexity and reagent shelf life.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelMinimumReleaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Model Minimum Release Quantity' ;
    rdfs:comment 'Minimum quantity that must be requested in each call-off release for this specific instrument model. Ensures economical batch sizes for model-specific reagents.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelRemainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Model Remaining Quantity' ;
    rdfs:comment 'Quantity remaining available for future call-off releases for this specific instrument model. Calculated as model_committed_quantity minus model_consumed_quantity.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelSpecificDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Model Specific Discount Percentage' ;
    rdfs:comment 'Negotiated discount percentage applied to list price for reagents and consumables for this specific instrument model. Discounts vary by model based on volume commitments and strategic importance.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelSpecificPricingTier rdf:type rdf:Property ;
    rdfs:label 'Model Specific Pricing Tier' ;
    rdfs:comment 'Volume-based pricing tier locked for this specific instrument model within the blanket order. Different models may have different tier structures based on consumption patterns and reagent costs.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelSpecificUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Model Specific Unit Price' ;
    rdfs:comment 'Pre-negotiated unit price for reagent kits, consumables, or services specific to this instrument model under this blanket order. Prices vary by model due to different chemistries, throughput requirements, and reagent compatibility.' ;
    rdfs:domain ind:BlanketAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Contracted Material Id' ;
    rdfs:comment 'Unique identifier for this contracted material pricing record. Primary key.' ;
    rdfs:domain ind:ContractedMaterial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Contracted Unit Price' ;
    rdfs:comment 'Negotiated unit price for this material under this specific service agreement. Price per base unit of measure.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparePartsSupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Supply Agreement Id' ;
    rdfs:comment 'Unique identifier for this spare parts supply agreement line within the blanket order framework. Primary key.' ;
    rdfs:domain ind:SparePartsSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'Total quantity of this specific spare part committed under the blanket order agreement over its full term. Part of the overall blanket order volume commitment.' ;
    rdfs:domain ind:SparePartsSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date of the most recent call-off release for this spare part under this blanket order. Used for consumption pattern analysis and replenishment planning.' ;
    rdfs:domain ind:SparePartsSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockingLocation rdf:type rdf:Property ;
    rdfs:label 'Stocking Location' ;
    rdfs:comment 'Designated warehouse or distribution center where inventory for this spare part is maintained to support this blanket order agreement. Enables rapid fulfillment of call-off releases.' ;
    rdfs:domain ind:SparePartsSupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Unique identifier for this contract line item record. Primary key.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractLineNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Line Number' ;
    rdfs:comment 'Business-visible line item number within the contract. Typically a sequential number (00010, 00020, etc.) used in SAP MM contract line items.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedQuantity rdf:type rdf:Property ;
    rdfs:label 'Contracted Quantity' ;
    rdfs:comment 'Total quantity of this specific reagent committed under this contract line. For quantity contracts, this represents the target quantity to be released over the contract validity period.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceConditionType rdf:type rdf:Property ;
    rdfs:label 'Price Condition Type' ;
    rdfs:comment 'SAP pricing condition type code defining how the contracted price is applied (e.g., PB00 for gross price, RA01 for discount). Used for invoice verification.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReleasedToDate rdf:type rdf:Property ;
    rdfs:label 'Quantity Released To Date' ;
    rdfs:comment 'Cumulative quantity released against this contract line via purchase orders. Used to track contract utilization and remaining quantity available.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueReleasedToDate rdf:type rdf:Property ;
    rdfs:label 'Value Released To Date' ;
    rdfs:comment 'Cumulative monetary value released against this contract line. Calculated as sum of (quantity × unit_price) across all purchase order releases.' ;
    rdfs:domain ind:ContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierReagentQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Reagent Qualification Id' ;
    rdfs:comment 'Unique identifier for this supplier-reagent qualification association record. Primary key.' ;
    rdfs:domain ind:SupplierReagentQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplySupplierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Supply Supplier Qualification Id' ;
    rdfs:comment 'Foreign key linking to the supplier qualification record that establishes the supplier\'s overall qualification status and audit history' ;
    rdfs:domain ind:SupplierReagentQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierQualification .

ind:batchQualityTestId rdf:type rdf:Property ;
    rdfs:label 'Batch Quality Test Id' ;
    rdfs:comment 'Unique identifier for this specific test execution. Primary key for the batch quality test association.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retestRequired rdf:type rdf:Property ;
    rdfs:label 'Retest Required' ;
    rdfs:comment 'Indicates whether this test must be repeated due to inconclusive results, equipment failure, or approaching retest date. Triggers retest workflow.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the specific test method, SOP, or analytical procedure used to execute this test. May vary by laboratory or equipment.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-text notes from the analyst regarding test execution, observations, or contextual information relevant to interpreting the result.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultValue rdf:type rdf:Property ;
    rdfs:label 'Test Result Value' ;
    rdfs:comment 'The actual measured or observed value from executing this quality rule test on the batch. May be numeric, categorical, or descriptive depending on the rule type.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testedBy rdf:type rdf:Property ;
    rdfs:label 'Tested By' ;
    rdfs:comment 'Identifier of the QA analyst, laboratory technician, or automated system that performed this test. Required for GxP compliance and audit trail.' ;
    rdfs:domain ind:BatchQualityTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterQualificationId rdf:type rdf:Property ;
    rdfs:label 'Work Center Qualification Id' ;
    rdfs:comment 'Unique identifier for this work center qualification record. Primary key.' ;
    rdfs:domain ind:WorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastProductionRunDate rdf:type rdf:Property ;
    rdfs:label 'Last Production Run Date' ;
    rdfs:comment 'Date of the most recent production run for this catalog item at this work center. Used to track active qualifications and identify dormant product-work center combinations.' ;
    rdfs:domain ind:WorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionVolumeCapacity rdf:type rdf:Property ;
    rdfs:label 'Production Volume Capacity' ;
    rdfs:comment 'Maximum production volume capacity for this catalog item at this work center, expressed in the catalog item\'s unit of measure. Used for production planning and capacity allocation.' ;
    rdfs:domain ind:WorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldRatePercent rdf:type rdf:Property ;
    rdfs:label 'Yield Rate Percent' ;
    rdfs:comment 'Expected production yield rate as a percentage for this catalog item when manufactured at this work center. Reflects product-specific performance metrics used for material planning and cost estimation.' ;
    rdfs:domain ind:WorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genomicAccessGrantId rdf:type rdf:Property ;
    rdfs:label 'Genomic Access Grant Id' ;
    rdfs:comment 'Unique identifier for this access grant record. Primary key.' ;
    rdfs:domain ind:GenomicAccessGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditLogReference rdf:type rdf:Property ;
    rdfs:label 'Audit Log Reference' ;
    rdfs:comment 'Reference identifier linking this access grant to the audit logging system tracking all data access events by this employee for this dataset. Explicitly identified in detection phase.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseAgreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Data Use Agreement Signed Date' ;
    rdfs:comment 'Date on which the employee signed the Data Use Agreement acknowledging their responsibilities and limitations for accessing this genomic dataset.' ;
    rdfs:domain ind:GenomicAccessGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Grant Expiry Date' ;
    rdfs:comment 'Date on which the employee\'s access to the genomic dataset expires and must be renewed or revoked. Explicitly identified in detection phase as access_grant_expiry_date.' ;
    rdfs:domain ind:GenomicAccessGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantStartDate rdf:type rdf:Property ;
    rdfs:label 'Grant Start Date' ;
    rdfs:comment 'Date on which the employee\'s access to the genomic dataset becomes effective. Explicitly identified in detection phase as access_grant_start_date.' ;
    rdfs:domain ind:GenomicAccessGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date on which the employee completed required training on genomic data handling, privacy protection, and ethical use before being granted access.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geneTagAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Gene Tag Assignment Id' ;
    rdfs:comment 'Unique identifier for this gene-tag assignment record. Primary key.' ;
    rdfs:domain ind:GeneTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Username or system identifier of the user or automated process that created this tag assignment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSource rdf:type rdf:Property ;
    rdfs:label 'Evidence Source' ;
    rdfs:comment 'Reference to the external database, publication, or internal analysis that provides evidence for this tag assignment. Examples: PMID:12345678, ClinVar, internal_variant_analysis.' ;
    rdfs:domain ind:GeneTagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testQualificationId rdf:type rdf:Property ;
    rdfs:label 'Test Qualification Id' ;
    rdfs:comment 'Unique identifier for the instrument-test qualification record. Primary key.' ;
    rdfs:domain ind:TestQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Validation Approved By' ;
    rdfs:comment 'Username or identifier of the laboratory director or quality manager who approved the validation results. Required for regulatory compliance.' ;
    rdfs:domain ind:TestQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Validation Performed By' ;
    rdfs:comment 'Username or identifier of the qualified laboratory personnel who performed the validation protocol. Required for CAP accreditation audit trails.' ;
    rdfs:domain ind:TestQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchTestId rdf:type rdf:Property ;
    rdfs:label 'Batch Test Id' ;
    rdfs:comment 'Unique identifier for this instrument batch test record. Primary key for the association.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Reference to the QC analyst or operator who performed this test on this instrument. Required for 21 CFR Part 11 electronic signature and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test is a retest of a previous inconclusive or failed result. Important for deviation tracking and batch release timeline. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:samplesTested rdf:type rdf:Property ;
    rdfs:label 'Samples Tested' ;
    rdfs:comment 'Number of samples from this batch tested on this instrument during this test event. Required for statistical validity and CoA documentation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specificationMax rdf:type rdf:Property ;
    rdfs:label 'Specification Max' ;
    rdfs:comment 'Maximum acceptable value per product specification for this test type. Used to determine pass/fail status.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationMin rdf:type rdf:Property ;
    rdfs:label 'Specification Min' ;
    rdfs:comment 'Minimum acceptable value per product specification for this test type. Used to determine pass/fail status.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Testing End Timestamp' ;
    rdfs:comment 'Date and time when testing completed on this instrument for this batch. Used to calculate test duration and instrument availability. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Testing Start Timestamp' ;
    rdfs:comment 'Date and time when testing commenced on this instrument for this batch. Critical for GMP audit trail and instrument utilization tracking. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:BatchTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Part Consumption Id' ;
    rdfs:comment 'Unique identifier for this part consumption transaction record. Primary key.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumptionNotes rdf:type rdf:Property ;
    rdfs:label 'Consumption Notes' ;
    rdfs:comment 'Free-text notes about this specific part consumption: installation observations, compatibility issues, configuration changes, or special handling requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Timestamp' ;
    rdfs:comment 'Date and time when this part was installed or consumed during the maintenance event. Used for warranty start date calculation and maintenance timeline tracking.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Part Serial Number' ;
    rdfs:comment 'Serial number of the specific part unit installed during this maintenance event. Required for serialized parts to support warranty tracking and field failure analysis.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsConsumedCount rdf:type rdf:Property ;
    rdfs:label 'Parts Consumed Count' ;
    rdfs:comment 'Number of distinct parts or components replaced or consumed during the maintenance event. [Moved from maintenance_event: This is an aggregate count that can be derived from the part_consumption association table by counting distinct spare_part_id records for each maintenance_event_id. It does not belong as a stored attribute in maintenance_event.]' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Quantity of this spare part consumed during the maintenance event, in the part\'s unit of measure. Supports fractional quantities for consumables.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removedPartSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Removed Part Serial Number' ;
    rdfs:comment 'Serial number of the failed or replaced part that was removed during this maintenance event. Supports failure analysis and warranty claims for defective parts.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPartsCost rdf:type rdf:Property ;
    rdfs:label 'Total Parts Cost' ;
    rdfs:comment 'Total cost of all parts and consumables used in the maintenance event, in USD. [Moved from maintenance_event: This is an aggregate sum that can be derived from the part_consumption association table by summing (quantity_consumed * unit_cost) for each maintenance_event_id. It does not belong as a stored attribute in maintenance_event.]' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimEligible rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Eligible' ;
    rdfs:comment 'Indicates whether this part consumption is eligible for warranty claim or vendor reimbursement based on failure analysis and warranty terms.' ;
    rdfs:domain ind:PartConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialQualificationId rdf:type rdf:Property ;
    rdfs:label 'Material Qualification Id' ;
    rdfs:comment 'Unique identifier for the material qualification record. Primary key.' ;
    rdfs:domain ind:MaterialQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Employee ID of the qualified assessor who conducted the competency evaluation and granted the qualification. Required for GMP audit trail.' ;
    rdfs:domain ind:MaterialQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'Level of competency achieved for handling this material. Basic=supervised use only, Intermediate=independent use, Advanced=complex procedures, Expert=troubleshooting, Trainer=can qualify others.' ;
    rdfs:domain ind:MaterialQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Date' ;
    rdfs:comment 'Date of the most recent competency reassessment or proficiency check for this material. Used to track ongoing competency maintenance.' ;
    rdfs:domain ind:MaterialQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'Total hours of training completed for this specific material qualification. Used for compliance reporting and competency documentation.' ;
    rdfs:domain ind:MaterialQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Authorization Id' ;
    rdfs:comment 'Unique surrogate identifier for each pipeline authorization record linking a customer account to a specific pipeline version' ;
    rdfs:domain ind:PipelineAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-text notes capturing special conditions, restrictions, or context for this customer-pipeline authorization. Examples: customer-specific validation protocol references, usage restrictions, or renewal conditions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSpecificParameters rdf:type rdf:Property ;
    rdfs:label 'Customer Specific Parameters' ;
    rdfs:comment 'JSON-serialized configuration document capturing customer-specific parameter overrides or constraints for this pipeline version. Identified in detection phase as relationship-specific data. Examples: custom coverage thresholds, customer-mandated quality filters, or restricted output formats per customer contract.' ;
    rdfs:domain ind:PipelineAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageTier rdf:type rdf:Property ;
    rdfs:label 'Usage Tier' ;
    rdfs:comment 'Tier of usage authorized for this customer-pipeline combination. Identified in detection phase as relationship-specific data. Values: RUO (research use only), IVD (in vitro diagnostic), clinical_validated, research_only, full_production. Governs regulatory compliance and liability.' ;
    rdfs:domain ind:PipelineAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Research Assignment Id' ;
    rdfs:comment 'Primary key for research_assignment' ;
    rdfs:domain ind:ResearchAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for the project assignment record. Primary key for the assignment association.' ;
    rdfs:domain ind:ResearchAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceAssignment .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the employee\'s total work time allocated to this specific project assignment. Used for resource planning and capacity management. Range 0.00 to 100.00. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effortHours rdf:type rdf:Property ;
    rdfs:label 'Effort Hours' ;
    rdfs:comment 'Total planned or budgeted hours for this employee\'s work on the project assignment. Used for project planning, resource forecasting, and comparing planned vs. actual effort. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:ResearchAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roleOnProject rdf:type rdf:Property ;
    rdfs:label 'Role On Project' ;
    rdfs:comment 'The functional role or capacity in which the employee is assigned to the R&D project. Defines responsibilities and authority level within the project team structure. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:ResearchAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Tag Assignment Id' ;
    rdfs:comment 'Unique identifier for this reagent-tag assignment record. Primary key for the association.' ;
    rdfs:domain ind:TagAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuWorkCenterQualificationId rdf:type rdf:Property ;
    rdfs:label 'Sku Work Center Qualification Id' ;
    rdfs:comment 'Unique identifier for this SKU-work center qualification record. Primary key.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualified By Employee Id' ;
    rdfs:comment 'Reference to the manufacturing engineer or quality engineer who performed and approved the qualification of this SKU at this work center.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityUnitsPerShift rdf:type rdf:Property ;
    rdfs:label 'Capacity Units Per Shift' ;
    rdfs:comment 'Maximum production capacity in units of this SKU that this work center can produce per shift under standard operating conditions, used for production scheduling and capacity planning. This is relationship-specific because capacity depends on both SKU processing requirements and work center throughput capabilities.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPreferredWorkCenter rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Work Center' ;
    rdfs:comment 'Indicates whether this work center is the preferred/primary production location for this SKU when multiple qualified work centers exist. Used by production scheduling to prioritize work center selection for optimal efficiency and quality.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastProductionDate rdf:type rdf:Property ;
    rdfs:label 'Last Production Date' ;
    rdfs:comment 'Date when this SKU was last produced at this work center, used to identify dormant qualifications that may require revalidation before next use.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Batch Size' ;
    rdfs:comment 'Maximum batch size for producing this SKU at this work center, constrained by equipment capacity, GMP batch size limits, or process validation parameters. This is relationship-specific because maximum batch size depends on both SKU process requirements and work center physical constraints.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBatchSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Batch Size' ;
    rdfs:comment 'Minimum economical batch size for producing this SKU at this work center, driven by setup time economics and work center characteristics. This is relationship-specific because minimum batch size depends on both SKU economics and work center setup costs.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualified Date' ;
    rdfs:comment 'Date when this SKU was qualified for production at this work center through process validation, equipment qualification, and quality approval. Tracks when the SKU-work center combination was approved for GMP production.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardCycleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Cycle Time Minutes' ;
    rdfs:comment 'Standard production cycle time in minutes to produce one unit of this SKU at this specific work center, used for production scheduling and capacity planning. This is SKU-work center specific because different SKUs have different processing requirements and different work centers have different equipment capabilities.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Yield Target Percent' ;
    rdfs:comment 'Target production yield percentage for this SKU when manufactured at this work center, representing the expected ratio of good units to total units started. This is relationship-specific because yield varies by SKU complexity and work center capability/maturity.' ;
    rdfs:domain ind:SkuWorkCenterQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Sample Enrollment Id' ;
    rdfs:comment 'Primary key for sample_enrollment' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for this subject-project enrollment record' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEnrollment .

ind:principalInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Employee Id' ;
    rdfs:comment 'Reference to the employee record of the Principal Investigator responsible for this subject\'s enrollment at the enrolling site' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Study Enrollment Id' ;
    rdfs:comment 'Reference to the external study enrollment record linking this subject to a specific clinical or research study cohort. Supports cohort membership tracking, multi-study subject participation, and study-level analytics without duplicating study metadata in this product. [Moved from subject: This attribute in the subject product is a reference to an external study enrollment record. Since we are now modeling enrollment as an explicit association between subject and project, this attribute becomes redundant and should be replaced by the enrollment association itself. The enrollment association IS the study enrollment record.]' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalEnrollment .

ind:eligibilityConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Confirmed Date' ;
    rdfs:comment 'Date on which the subject\'s eligibility for this project was confirmed against inclusion/exclusion criteria' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'Projected date for this subject to complete all protocol-required activities for this project enrollment' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:randomizationCode rdf:type rdf:Property ;
    rdfs:label 'Randomization Code' ;
    rdfs:comment 'Blinded randomization code assigned to this subject for this project enrollment, used in randomized controlled trials. Access restricted per study blinding protocol.' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Sample Enrollment Date' ;
    rdfs:comment 'Date on which the subject was formally enrolled into this specific research project, as recorded in the study enrollment system' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this subject\'s enrollment in this project: active (currently enrolled), withdrawn (subject withdrew consent), completed (subject completed study protocol), screen_failed (did not meet eligibility), lost_to_followup (contact lost)' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Identifier for the clinical or research site where this subject was enrolled into this project, supporting multi-site study tracking' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyArm rdf:type rdf:Property ;
    rdfs:label 'Study Arm' ;
    rdfs:comment 'The study arm or treatment group assignment for this subject within this project, particularly relevant for interventional or comparative studies (e.g., \'Arm 1: CRISPR Treatment\', \'Arm 2: Standard of Care\')' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectStatus rdf:type rdf:Property ;
    rdfs:label 'Subject Status' ;
    rdfs:comment 'Current lifecycle status of the subject record within the study or clinical program. Active subjects are eligible for ongoing specimen collection and data use. Withdrawn subjects have revoked consent and data use must be restricted per IRB protocol. Deceased and lost-to-follow-up statuses affect cohort completeness reporting and TAT (Turnaround Time) analytics. [Moved from subject: If subject_status represents enrollment lifecycle status (active, withdrawn, completed), it is specific to each project enrollment, not a universal subject property. A subject can be \'active\' in one project and \'completed\' in another simultaneously. This should move to the enrollment association as \'status\'.]' ;
    rdfs:domain ind:SampleEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Test Service Agreement Id' ;
    rdfs:comment 'Unique identifier for this test service agreement record. Primary key.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoReflexEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Reflex Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic reflex testing rules are enabled for this account-test combination. Some accounts may opt out of reflex testing for cost control or workflow reasons. True=reflex rules apply, False=reflex testing disabled for this account.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCodeOverride rdf:type rdf:Property ;
    rdfs:label 'Billing Code Override' ;
    rdfs:comment 'Account-specific billing code or reference number to use for this test instead of standard CPT code. Used when account requires custom billing identifiers for their internal systems. Null if standard CPT code applies.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when this test service agreement became active and the contracted terms took effect. Used for contract lifecycle management and historical pricing queries. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date when this test service agreement expires or is scheduled for renewal. Null indicates evergreen agreement. Used for contract renewal workflows and revenue forecasting. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractOwnerUser rdf:type rdf:Property ;
    rdfs:label 'Contract Owner User' ;
    rdfs:comment 'Username or identifier of the sales or account management user responsible for managing this test service agreement. Used for contract renewal notifications and escalations.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Contracted Price Usd' ;
    rdfs:comment 'Account-specific negotiated price for this test in USD. May differ from catalog list price based on volume commitments, strategic relationship, or competitive factors. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAnnualVolume rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Volume' ;
    rdfs:comment 'Minimum number of test orders per year committed by the account to qualify for contracted pricing. Used for volume commitment tracking and pricing tier enforcement. Null if no minimum commitment.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSpecimenType rdf:type rdf:Property ;
    rdfs:label 'Preferred Specimen Type' ;
    rdfs:comment 'Account-specific preferred specimen type for this test (e.g., whole blood, saliva, buccal swab). May be a subset of accepted specimen types in the catalog based on account laboratory capabilities or workflow preferences. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Hours' ;
    rdfs:comment 'Account-specific committed turnaround time from specimen receipt to report delivery for this test, measured in hours. May differ from catalog standard TAT based on account tier or negotiated service levels. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:TestServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliquotConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Aliquot Consumption Id' ;
    rdfs:comment 'Unique surrogate identifier for each aliquot consumption record' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Consumed By Employee Id' ;
    rdfs:comment 'Reference to the laboratory technician or scientist who physically consumed/used the aliquot in the experiment. Required for GxP audit trail and accountability.' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'Date and time when the aliquot was consumed or added to the experiment. Used for material traceability, experimental timeline documentation, and GxP compliance.' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:experimentRole rdf:type rdf:Property ;
    rdfs:label 'Experiment Role' ;
    rdfs:comment 'The functional role this aliquot plays in the experimental design (e.g., sample, control, calibrator, blank, standard, qc_reference). Critical for understanding experimental setup and data interpretation.' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Lims Transaction Code' ;
    rdfs:comment 'The native transaction identifier from LabVantage LIMS that recorded this consumption event. Enables traceability back to source system for audit purposes.' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeConsumedUl rdf:type rdf:Property ;
    rdfs:label 'Volume Consumed Ul' ;
    rdfs:comment 'Volume of biological material consumed from the aliquot for this specific experiment, measured in microliters. Critical for inventory depletion tracking and experimental documentation.' ;
    rdfs:domain ind:AliquotConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ordererAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Orderer Authorization Id' ;
    rdfs:comment 'Unique identifier for this physician authorization record. Primary key.' ;
    rdfs:domain ind:OrdererAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:institutionalCredentialVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Institutional Credential Verified Date' ;
    rdfs:comment 'Date when the physician\'s credentials were verified specifically for this institutional service agreement. Separate from the physician\'s general credentialing_verification_date, as institutional agreements may require additional verification steps.' ;
    rdfs:domain ind:OrdererAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderingLimitPerMonth rdf:type rdf:Property ;
    rdfs:label 'Ordering Limit Per Month' ;
    rdfs:comment 'Maximum number of test orders this physician may submit per month under this service agreement. Used for evaluation agreements, beta programs, or volume-capped institutional contracts. Null indicates no limit. Captured from detection phase relationship data.' ;
    rdfs:domain ind:OrdererAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testMenuAccessScope rdf:type rdf:Property ;
    rdfs:label 'Test Menu Access Scope' ;
    rdfs:comment 'Specific test menu access level or scope granted to this physician under this service agreement. May differ from the physician\'s general test_menu_access_level based on institutional agreement terms (e.g., \'oncology_panel_only\', \'full_clinical_menu\', \'hereditary_cancer_tests\'). Captured from detection phase relationship data.' ;
    rdfs:domain ind:OrdererAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ordererTerritoryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Orderer Territory Assignment Id' ;
    rdfs:comment 'Unique identifier for this orderer-territory assignment record. Primary key.' ;
    rdfs:domain ind:OrdererTerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when this orderer-territory assignment ended or will end. Null for currently active assignments. Used to track historical territory coverage changes.' ;
    rdfs:domain ind:OrdererTerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when this orderer-territory assignment became effective. Used to track when an orderer began practicing in locations covered by this territory.' ;
    rdfs:domain ind:OrdererTerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'Classification of the territory assignment priority: primary (main practice location), secondary (additional practice location), tertiary (occasional coverage). Used for sales resource prioritization and account ownership determination.' ;
    rdfs:domain ind:OrdererTerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStrengthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Strength Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the strength of the commercial relationship between this orderer and the territory sales team. Based on ordering volume, engagement frequency, and strategic account value. Used for account planning and territory performance analysis.' ;
    rdfs:domain ind:OrdererTerritoryAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Retention Assignment Id' ;
    rdfs:comment 'Unique identifier for this product-policy assignment record. Primary key for the association.' ;
    rdfs:domain ind:RetentionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Business justification for assigning a non-standard retention policy to this catalog item, such as extended retention for ongoing litigation, clinical trial requirements, or customer contractual obligations. Nullable when standard policy assignment applies. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RetentionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersionAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Policy Version At Assignment' ;
    rdfs:comment 'Version identifier of the retention policy at the time of assignment to this catalog item. Critical for audit trail and regulatory compliance to demonstrate which policy rules were in effect when data was generated. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RetentionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTrigger rdf:type rdf:Property ;
    rdfs:label 'Regulatory Trigger' ;
    rdfs:comment 'Specific regulatory event or change that triggered this policy assignment or reassignment, such as \'FDA 510k clearance\', \'CE-IVD certification\', \'CLIA compliance requirement\', or \'GDPR applicability determination\'.' ;
    rdfs:domain ind:RetentionAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationId rdf:type rdf:Property ;
    rdfs:label 'Validation Id' ;
    rdfs:comment 'Unique identifier for this product-validation coverage record. Primary key for the association.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the employee who last modified this product-validation coverage record.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lotRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Lot Range End' ;
    rdfs:comment 'Ending lot number or batch identifier for reagent/consumable catalog items covered by this validation. Defines the upper bound of lot coverage. Null if validation applies to all future lots.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotRangeStart rdf:type rdf:Property ;
    rdfs:label 'Lot Range Start' ;
    rdfs:comment 'Starting lot number or batch identifier for reagent/consumable catalog items covered by this validation. Applicable when validation is performed on representative lots and coverage extends to a defined lot range.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productConfigurationTested rdf:type rdf:Property ;
    rdfs:label 'Product Configuration Tested' ;
    rdfs:comment 'Specific product configuration, version, or SKU variant tested in this validation study. Critical for products with multiple configurations (e.g., NovaSeq 6000 with different flow cell types, reagent kit lot ranges, software version ranges). Defines the exact product specification covered by validation evidence.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClaimSupported rdf:type rdf:Property ;
    rdfs:label 'Regulatory Claim Supported' ;
    rdfs:comment 'Specific regulatory claim or intended use statement that this validation evidence supports for this catalog item (e.g., \'RUO use only\', \'IVD for detection of BRCA1/2 variants\', \'CE-IVD marked for EU\'). Links validation evidence to marketing claims and labeling.' ;
    rdfs:domain ind:Validation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationId rdf:type rdf:Property ;
    rdfs:label 'Citation Id' ;
    rdfs:comment 'Unique identifier for this product citation relationship. Primary key.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Date when this product-publication citation relationship was identified and recorded in the system. Supports tracking of citation discovery and marketing response timing.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:context rdf:type rdf:Property ;
    rdfs:label 'Context' ;
    rdfs:comment 'Section of the publication where the product is cited or mentioned (e.g., methods section for sequencing platforms, results for performance data, acknowledgments for reagent donations). Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Approval Date' ;
    rdfs:comment 'Date when marketing approved this citation for promotional use. Nullable if not yet reviewed or not approved.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingApproved rdf:type rdf:Property ;
    rdfs:label 'Marketing Approved' ;
    rdfs:comment 'Indicates whether this citation has been approved by marketing for use in promotional materials, sales presentations, and customer-facing content. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceDataIncluded rdf:type rdf:Property ;
    rdfs:label 'Performance Data Included' ;
    rdfs:comment 'Indicates whether the publication includes quantitative performance data, benchmarks, or comparative analysis of the product. Critical for marketing use and competitive intelligence. Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productRole rdf:type rdf:Property ;
    rdfs:label 'Product Role' ;
    rdfs:comment 'Role the product played in the research study (e.g., primary sequencing platform, reagent used in sample prep, analysis software, comparison benchmark against competitor). Identified in detection phase as relationship-specific data.' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Verified Flag' ;
    rdfs:comment 'Indicates whether the citation has been manually verified by a reviewer (to confirm the product was actually used and cited correctly, not just mentioned in passing).' ;
    rdfs:domain ind:Citation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerGenomicAccessAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Partner Genomic Access Authorization Id' ;
    rdfs:comment 'Unique identifier for the partner genomic access authorization record. Primary key.' ;
    rdfs:domain ind:PartnerGenomicAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessTierGranted rdf:type rdf:Property ;
    rdfs:label 'Access Tier Granted' ;
    rdfs:comment 'Specific access tier granted to this partner for this dataset. May be more restrictive than the dataset\'s maximum tier based on partner agreement and training level. Values: open, registered, controlled, restricted.' ;
    rdfs:domain ind:PartnerGenomicAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Status' ;
    rdfs:comment 'Current compliance audit status for this partner-dataset authorization. Tracks whether the partner is meeting data handling and security requirements. Values: compliant, non_compliant, pending_review, audit_required.' ;
    rdfs:domain ind:PartnerGenomicAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignAllocationId rdf:type rdf:Property ;
    rdfs:label 'Campaign Allocation Id' ;
    rdfs:comment 'Unique identifier for this cost center-campaign allocation record. Primary key.' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Actual amount spent by this cost center on this campaign to date, tracked for budget variance analysis.' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'Effective end date for this cost center allocation. Null if allocation is active through campaign completion.' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes explaining the rationale for this allocation split or any special considerations.' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Start Date' ;
    rdfs:comment 'Effective start date for this cost center allocation. Supports time-phased budget allocations where cost center participation changes during campaign lifecycle.' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current status of this allocation: planned (budget reserved), active (spending in progress), completed (campaign ended), cancelled (allocation removed).' ;
    rdfs:domain ind:CampaignAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignParticipationId rdf:type rdf:Property ;
    rdfs:label 'Campaign Participation Id' ;
    rdfs:comment 'Unique identifier for the campaign participation record. Primary key.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'Percentage of the employee\'s time/cost allocated to this campaign for financial tracking and cost center allocation purposes. Supports the business need for cost allocation mentioned in detection reasoning.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Hours Allocated' ;
    rdfs:comment 'Number of hours allocated for this employee\'s participation in the campaign. Used for resource planning and cost allocation. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of this participation assignment. Tracks whether the participation is planned, confirmed, actively in progress, completed, or cancelled.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'The specific role the employee fulfills in this campaign (e.g., presenter at conference, booth staff, technical expert for product demos, KOL liaison). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CampaignParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityTeamMemberId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Team Member Id' ;
    rdfs:comment 'Unique identifier for this opportunity team member assignment record. Primary key for the association.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'The percentage of credit this team member receives for this opportunity, used for commission splits and performance attribution. Must sum to 100% across all team members for a given opportunity. Account Executive typically receives 60-80%, with remaining split among supporting roles.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:involvementStage rdf:type rdf:Property ;
    rdfs:label 'Involvement Stage' ;
    rdfs:comment 'The sales stage at which this team member became involved in the opportunity. Used to track when different roles engage (e.g., FAS typically joins at Solution Design stage, Sales Manager at Negotiation stage).' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryOwner rdf:type rdf:Property ;
    rdfs:label 'Is Primary Owner' ;
    rdfs:comment 'Indicates whether this team member is the primary owner of the opportunity (typically the Account Executive). Each opportunity must have exactly one primary owner at any time. Primary owner has ultimate responsibility for advancing the opportunity and receives largest commission split.' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamRole rdf:type rdf:Property ;
    rdfs:label 'Team Role' ;
    rdfs:comment 'The specific role this employee plays on the opportunity team. Determines responsibilities, approval authority, and commission eligibility. Examples: Account Executive (relationship owner), Field Application Scientist (technical validation), Sales Engineer (integration design), Sales Manager (approval authority).' ;
    rdfs:domain ind:OpportunityTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomeQualificationId rdf:type rdf:Property ;
    rdfs:label 'Genome Qualification Id' ;
    rdfs:comment 'Primary key for the genome_qualification association' ;
    rdfs:domain ind:GenomeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certifying Authority' ;
    rdfs:comment 'Name or identifier of the person or body that certified this qualification (e.g., training manager, CLIA director). Required for audit trail.' ;
    rdfs:domain ind:GenomeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Assessed proficiency level of the employee working with this specific genome assembly. Used for project staffing decisions and training needs assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDatabaseQualificationId rdf:type rdf:Property ;
    rdfs:label 'Variant Database Qualification Id' ;
    rdfs:comment 'Primary key for the variant_database_qualification association' ;
    rdfs:domain ind:VariantDatabaseQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the qualification certification. Active certifications allow work assignment; expired or suspended certifications require retraining. Values: Active, Expired, Suspended, Pending Renewal.' ;
    rdfs:domain ind:VariantDatabaseQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationParticipationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Participation Id' ;
    rdfs:comment 'Unique identifier for this participation record. Primary key.' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Level of approval authority exercised by this employee in this qualification (Execute, Review, Approve, None). Determines regulatory accountability.' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationDate rdf:type rdf:Property ;
    rdfs:label 'Participation Date' ;
    rdfs:comment 'Date when this employee performed their role in the qualification activity. May differ from overall qualification completion date.' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPhase rdf:type rdf:Property ;
    rdfs:label 'Qualification Phase' ;
    rdfs:comment 'The phase of qualification during which this participation occurred (IQ, OQ, PQ, Review, Approval). Allows tracking personnel involvement across different qualification stages.' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name or identifier of the engineer responsible for executing and documenting the qualification activity. [Moved from equipment_qualification: This is a STRING name field that represents ONE specific employee\'s role. However, the FK employee_id already captures the responsible engineer relationship. This STRING field is redundant with the FK and should be deprecated in favor of the FK relationship. Not moving to association because it represents a single 1:N relationship, not M:N participation data.]' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInQualification rdf:type rdf:Property ;
    rdfs:label 'Role In Qualification' ;
    rdfs:comment 'The specific role this employee performed in the qualification activity (e.g., Responsible Engineer, QA Reviewer, QA Approver, Technical SME, Witness, Test Executor). Determines signature authority and responsibility level.' ;
    rdfs:domain ind:QualificationParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Experiment Analysis Id' ;
    rdfs:comment 'Unique surrogate identifier for each experiment-pipeline analysis execution record' ;
    rdfs:domain ind:ExperimentAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Id' ;
    rdfs:comment 'External identifier of the computational pipeline run in the HPC or cloud execution environment (e.g., Cromwell workflow ID, Nextflow run name). Links this association record to the operational execution log.' ;
    rdfs:domain ind:ExperimentAnalysis ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioinformaticsPipelineRun .

ind:actualRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Runtime Hours' ;
    rdfs:comment 'Actual wall-clock execution time in hours for this specific analysis run. Compared against pipeline_version.estimated_runtime_hours for performance monitoring.' ;
    rdfs:domain ind:ExperimentAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisPurpose rdf:type rdf:Property ;
    rdfs:label 'Analysis Purpose' ;
    rdfs:comment 'Scientific or operational purpose of this analysis execution (initial_processing, reanalysis, method_comparison, validation_study, troubleshooting). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:ExperimentAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFilePath rdf:type rdf:Property ;
    rdfs:label 'Output File Path' ;
    rdfs:comment 'File system path or object storage URI where the output files (VCF, BAM, QC reports) from this analysis execution are stored.' ;
    rdfs:domain ind:ExperimentAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileQualityEvaluationId rdf:type rdf:Property ;
    rdfs:label 'File Quality Evaluation Id' ;
    rdfs:comment 'Unique surrogate identifier for this quality evaluation execution record. Primary key for the association.' ;
    rdfs:domain ind:FileQualityEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatedBy rdf:type rdf:Property ;
    rdfs:label 'Evaluated By' ;
    rdfs:comment 'Identifier of the system, service, or user that executed this quality evaluation. Typically an automated pipeline service account, but may be a bioinformatician for manual QC review.' ;
    rdfs:domain ind:FileQualityEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Taken' ;
    rdfs:comment 'Description of any automated or manual remediation action taken in response to this rule failure. Examples: file re-sequenced, sample flagged for review, data excluded from analysis.' ;
    rdfs:domain ind:FileQualityEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExecutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rule Execution Timestamp' ;
    rdfs:comment 'The date and time when this quality rule was executed against this FASTQ file. Tracks when the evaluation occurred in the pipeline workflow.' ;
    rdfs:domain ind:FileQualityEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ruleResult rdf:type rdf:Property ;
    rdfs:label 'Rule Result' ;
    rdfs:comment 'The outcome of this quality rule evaluation. PASS = rule criteria met, FAIL = rule criteria not met, WARNING = borderline result, ERROR = execution error, SKIPPED = rule not applicable to this file type.' ;
    rdfs:domain ind:FileQualityEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalId rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Id' ;
    rdfs:comment 'Reference to the Institutional Review Board approval record.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:studyId rdf:type rdf:Property ;
    rdfs:label 'Study Id' ;
    rdfs:comment 'Identifier of the study associated with the cohort.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:ageRangeMax rdf:type rdf:Property ;
    rdfs:label 'Age Range Max' ;
    rdfs:comment 'Maximum age (in years) of participants in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRangeMin rdf:type rdf:Property ;
    rdfs:label 'Age Range Min' ;
    rdfs:comment 'Minimum age (in years) of participants in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cohortCode rdf:type rdf:Property ;
    rdfs:label 'Cohort Code' ;
    rdfs:comment 'Business identifier code for the cohort used in study documentation.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortName rdf:type rdf:Property ;
    rdfs:label 'Cohort Name' ;
    rdfs:comment 'Human readable name of the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortType rdf:type rdf:Property ;
    rdfs:label 'Cohort Type' ;
    rdfs:comment 'Category of cohort based on study design.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether informed consent is required for samples in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Data Access Level' ;
    rdfs:comment 'Level of access permitted for cohort data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deidentificationFlag rdf:type rdf:Property ;
    rdfs:label 'Deidentification Flag' ;
    rdfs:comment 'Indicates whether samples are de-identified for privacy.' ;
    rdfs:domain ind:Sample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the cohort purpose and composition.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseFocus rdf:type rdf:Property ;
    rdfs:label 'Disease Focus' ;
    rdfs:comment 'Primary disease or condition the cohort targets.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicityInclusion rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Inclusion' ;
    rdfs:comment 'Ethnicity groups included in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Text describing criteria for sample exclusion from the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderInclusion rdf:type rdf:Property ;
    rdfs:label 'Gender Inclusion' ;
    rdfs:comment 'Gender categories included in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Text describing criteria for sample inclusion in the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDataUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Data Update Date' ;
    rdfs:comment 'Date of the most recent data refresh for the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phenotype rdf:type rdf:Property ;
    rdfs:label 'Phenotype' ;
    rdfs:comment 'Phenotypic characteristic(s) defining the cohort.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyTier rdf:type rdf:Property ;
    rdfs:label 'Privacy Tier' ;
    rdfs:comment 'Privacy classification tier for the cohort data.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle status of the cohort.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date the cohort record was first created.' ;
    rdfs:domain ind:Cohort ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalValidity rdf:type rdf:Property ;
    rdfs:label 'Analytical Validity' ;
    rdfs:comment 'Evidence level supporting the analytical performance of the assay.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayCategory rdf:type rdf:Property ;
    rdfs:label 'Assay Category' ;
    rdfs:comment 'High-level clinical domain the assay serves.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayDevelopmentPhase rdf:type rdf:Property ;
    rdfs:label 'Assay Development Phase' ;
    rdfs:comment 'Current stage of the assay in the product lifecycle.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayOwner rdf:type rdf:Property ;
    rdfs:label 'Assay Owner' ;
    rdfs:comment 'Internal team or department responsible for assay maintenance.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assaySubcategory rdf:type rdf:Property ;
    rdfs:label 'Assay Subcategory' ;
    rdfs:comment 'More granular classification within the primary assay category.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCptCode rdf:type rdf:Property ;
    rdfs:label 'Billing Cpt Code' ;
    rdfs:comment 'Current CPT code used for billing the assay to insurers.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaCapability rdf:type rdf:Property ;
    rdfs:label 'Clia Capability' ;
    rdfs:comment 'CLIA classification indicating the complexity level of the assay.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalValidity rdf:type rdf:Property ;
    rdfs:label 'Clinical Validity' ;
    rdfs:comment 'Evidence level supporting the clinical relevance of the assay results.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpretationGuidelines rdf:type rdf:Property ;
    rdfs:label 'Interpretation Guidelines' ;
    rdfs:comment 'Standardized rules for interpreting assay results and reporting.' ;
    rdfs:domain ind:ClinicalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isApproved rdf:type rdf:Property ;
    rdfs:label 'Is Approved' ;
