# --- Attribute Properties ---
ind:alignmentResultId rdf:type rdf:Property ;
    rdfs:label 'Alignment Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each BAM/CRAM alignment result record produced by a bioinformatics pipeline run. Primary key for this entity. Role: TRANSACTION_HEADER — this entity represents a discrete computational event (alignment job output) with its own lifecycle, QC status, and lineage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlignmentResult .

ind:bioinformaticsPipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Bioinformatics Pipeline Run Id' ;
    rdfs:comment 'Reference to the bioinformatics pipeline run that produced this alignment result. Links the alignment output back to the specific pipeline execution context, enabling full data lineage from raw FASTQ input to aligned output. Satisfies PARTY_REFERENCE / RESOURCE_REFERENCE category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioinformaticsPipelineRun .

ind:flowCellId rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Id' ;
    rdfs:comment 'Identifier of the sequencing Flow Cell used to generate the raw reads for this alignment. The Flow Cell is the consumable cartridge on which sequencing chemistry occurs. Traceability to the flow cell enables investigation of batch-level sequencing failures, reagent lot issues, and instrument performance trends.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlowCell .

ind:genomeAssemblyId rdf:type rdf:Property ;
    rdfs:label 'Genome Assembly Id' ;
    rdfs:comment 'Reference to the reference genome assembly used for alignment (e.g., GRCh38/hg38, T2T-CHM13). The choice of reference genome directly impacts variant calling accuracy and clinical interpretation; this linkage is mandatory for reproducibility and regulatory traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomeAssembly .

ind:genomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Genomic Artifact Id' ;
    rdfs:comment 'Foreign key linking to bioinformatics.genomic_artifact. Business justification: alignment_result is METADATA about an alignment (QC metrics, statistics). The actual BAM/CRAM file is a genomic_artifact. alignment_result currently has output_file_path, output_file_format, output_fi' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:libraryId rdf:type rdf:Property ;
    rdfs:label 'Library Id' ;
    rdfs:comment 'Foreign key linking to sequencing.library. Business justification: Alignment results are library-specific outputs required for library QC, coverage analysis, and prep troubleshooting. Labs use this to identify failed libraries, optimize prep protocols, and determine ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Library .

ind:libraryPrepReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Library Prep Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Alignment QC metrics (duplicate rate, insert size distribution, GC bias) are library prep chemistry-dependent. Troubleshooting workflow: when coverage uniformity degrades, correlate to library prep re' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:qcResultId rdf:type rdf:Property ;
    rdfs:label 'Qc Result Id' ;
    rdfs:comment 'Foreign key linking to quality.qc_result. Business justification: Alignment results depend on upstream sample QC (DNA integrity, concentration, purity) performed in laboratory. Poor alignment metrics often trace to failed sample QC. Enables integrated quality invest' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QcResult .

ind:reviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Alignment QC results require qualified bioinformatician review before downstream variant calling, especially for clinical/GxP pipelines. Required for quality gate enforcement, personnel qualification ' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sampleSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Sample Specimen Id' ;
    rdfs:comment 'Reference to the biological sample that was sequenced and aligned. Establishes traceability from the alignment result back to the originating sample, supporting clinical reporting, regulatory audit, and downstream variant analysis workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSpecimen .

ind:sequencingRunId rdf:type rdf:Property ;
    rdfs:label 'Sequencing Run Id' ;
    rdfs:comment 'Foreign key linking to sequencing.sequencing_run. Business justification: Alignment results must trace to originating sequencing run for quality control, coverage analysis, and reprocessing decisions. Essential for clinical laboratories to validate alignment quality against' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SequencingRun .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Alignment QC metrics (coverage depth, mapping rate) establish analytical validity in regulatory submissions for NGS-based IVDs. New attribute links alignment results to submissions for performance cla' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:alignerTool rdf:type rdf:Property ;
    rdfs:label 'Aligner Tool' ;
    rdfs:comment 'Name of the alignment software tool used to produce this result (e.g., BWA-MEM, BWA-MEM2, DRAGEN, STAR, Bowtie2, minimap2). The choice of aligner affects sensitivity, specificity, and computational cost. Required for reproducibility and regulatory method validation documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignerVersion rdf:type rdf:Property ;
    rdfs:label 'Aligner Version' ;
    rdfs:comment 'Semantic version string of the aligner tool used (e.g., 0.7.17, 2.2.1). Version tracking is mandatory for bioinformatics method validation, regulatory submissions (FDA, EMA), and reproducibility of clinical genomic results. A version change may require re-validation under ISO 15189 and CLIA.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alignment Timestamp' ;
    rdfs:comment 'The date and time at which the alignment job completed and the BAM/CRAM output file was finalized. Represents the principal real-world business event time for this record. Used for Turnaround Time (TAT) calculations, SLA monitoring, and pipeline performance analytics. Satisfies BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chimericReadRatePct rdf:type rdf:Property ;
    rdfs:label 'Chimeric Read Rate Pct' ;
    rdfs:comment 'Percentage of reads flagged as chimeric (reads where the two ends map to different chromosomes or distant genomic locations). Elevated chimeric rates indicate library preparation artifacts, structural variant signals, or sequencing errors. Monitored as a QC metric in clinical WGS and structural variant detection workflows.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computePlatform rdf:type rdf:Property ;
    rdfs:label 'Compute Platform' ;
    rdfs:comment 'Compute infrastructure platform on which the alignment job was executed: AWS (Amazon Web Services), on-premise High-Performance Computing (HPC) cluster, Azure, GCP, or Illumina DRAGEN server. Required for cost allocation, performance benchmarking, and infrastructure capacity planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeRuntimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Compute Runtime Seconds' ;
    rdfs:comment 'Wall-clock time in seconds taken to complete the alignment job from job start to job completion. Used for pipeline performance monitoring, SLA compliance tracking, HPC/cloud resource optimization, and cost modeling. Enables identification of performance regressions across aligner versions or reference genome builds.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageUniformityPct rdf:type rdf:Property ;
    rdfs:label 'Coverage Uniformity Pct' ;
    rdfs:comment 'Percentage of target bases covered at ≥20% of the mean coverage depth, measuring the uniformity of sequencing coverage across the target region. High uniformity indicates consistent library preparation and sequencing performance. Low uniformity may indicate GC bias or capture inefficiency in WES/panel assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpuCoresUsed rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Used' ;
    rdfs:comment 'Number of CPU cores allocated and used for the alignment job. Together with compute_runtime_seconds and memory_used_gb, enables accurate cloud compute cost attribution per alignment result and supports capacity planning for HPC/AWS infrastructure.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The date and time when this alignment result record was first ingested into the Silver Layer data lakehouse. Distinct from alignment_timestamp (job completion time). Used for data lineage, audit trails, and ETL monitoring. Satisfies RECORD_AUDIT_CREATED category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:duplicateRatePct rdf:type rdf:Property ;
    rdfs:label 'Duplicate Rate Pct' ;
    rdfs:comment 'Percentage of mapped reads flagged as PCR or optical duplicates (duplicate_reads / mapped_reads × 100). High duplicate rates reduce effective coverage depth and can introduce variant calling bias. Typically assessed using Picard MarkDuplicates or equivalent. Threshold violations trigger QC warning or failure.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcContentPct rdf:type rdf:Property ;
    rdfs:label 'Gc Content Pct' ;
    rdfs:comment 'Percentage of guanine (G) and cytosine (C) bases in the aligned reads. GC content deviating significantly from the expected genomic average (~41% for human) indicates GC bias in library preparation or PCR amplification, which can cause uneven coverage and affect Copy Number Variation (CNV) analysis accuracy.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insertSizeStdDevBp rdf:type rdf:Property ;
    rdfs:label 'Insert Size Std Dev Bp' ;
    rdfs:comment 'Standard deviation of the insert size distribution in base pairs. A narrow distribution indicates consistent library preparation; a wide distribution may indicate mixed fragment populations or library quality issues. Used alongside median_insert_size_bp for comprehensive library QC assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intendedUse rdf:type rdf:Property ;
    rdfs:label 'Intended Use' ;
    rdfs:comment 'Regulatory intended use classification for this alignment result: Research Use Only (RUO), In Vitro Diagnostic (IVD), Laboratory Developed Test (LDT), clinical research, agricultural genomics, or companion diagnostic. Determines applicable regulatory framework (FDA, IVDR, CLIA) and data handling requirements including PHI/HIPAA obligations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReanalysis rdf:type rdf:Property ;
    rdfs:label 'Is Reanalysis' ;
    rdfs:comment 'Boolean flag indicating whether this alignment result is a reanalysis of a previously aligned sample (True) or an original first-pass alignment (False). Reanalyses may be triggered by reference genome updates, aligner version upgrades, QC failures, or clinical reinterpretation requests. Supports data lineage and version management.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappedReads rdf:type rdf:Property ;
    rdfs:label 'Mapped Reads' ;
    rdfs:comment 'Number of sequencing reads that successfully mapped to the reference genome. Together with total_reads, this is used to compute the mapping rate. Low mapped read counts may indicate sample contamination, library preparation failure, or reference genome mismatch.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mappingRatePct rdf:type rdf:Property ;
    rdfs:label 'Mapping Rate Pct' ;
    rdfs:comment 'Percentage of total reads that successfully mapped to the reference genome (mapped_reads / total_reads × 100). A primary alignment QC metric; typical acceptable thresholds are ≥90% for human WGS. Values below threshold trigger QC failure and potential re-sequencing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanBaseQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Base Quality Score' ;
    rdfs:comment 'Mean Phred Score across all bases in the aligned reads. The Phred Score is a logarithmic measure of base call accuracy (Q30 = 99.9% accuracy). A key sequencing run quality metric; Q30 ≥ 80% is a standard threshold for clinical-grade sequencing. Directly impacts variant calling sensitivity and specificity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Mean Coverage Depth' ;
    rdfs:comment 'Average number of sequencing reads covering each base position in the target region or genome (Coverage Depth). Expressed as a fold value (e.g., 30×, 100×). A fundamental QC metric determining the statistical power for variant detection; minimum thresholds vary by application (e.g., 30× for WGS, 100× for somatic panels).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianInsertSizeBp rdf:type rdf:Property ;
    rdfs:label 'Median Insert Size Bp' ;
    rdfs:comment 'Median length of the DNA fragment insert in base pairs (bp) as measured from the aligned paired-end reads. Insert size distribution is a key library preparation QC metric; unexpected values indicate library degradation, adapter contamination, or incorrect size selection. Affects read overlap and variant calling accuracy.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memoryUsedGb rdf:type rdf:Property ;
    rdfs:label 'Memory Used Gb' ;
    rdfs:comment 'Peak memory (RAM) consumed in gigabytes during the alignment job execution. Memory usage varies significantly by aligner (e.g., BWA-MEM2 requires ~60 GB for human WGS). Used for cloud instance type selection, cost optimization, and pipeline resource configuration management.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAbove10x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 10x' ;
    rdfs:comment 'Percentage of target bases covered at a minimum depth of 10× reads. A standard coverage adequacy metric used in clinical genomics reporting to confirm that the majority of the target region has sufficient depth for reliable variant calling. Commonly reported in clinical assay validation and CAP/CLIA compliance.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAbove30x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 30x' ;
    rdfs:comment 'Percentage of target bases covered at a minimum depth of 30× reads. The 30× threshold is the standard minimum for clinical Whole Genome Sequencing (WGS) and is required by many regulatory and accreditation bodies. Distinct from pct_bases_above_10x as it represents a higher stringency clinical threshold.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctQ30Bases rdf:type rdf:Property ;
    rdfs:label 'Pct Q30 Bases' ;
    rdfs:comment 'Percentage of sequenced bases with a Phred Score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. The Q30 percentage is the primary sequencing run quality KPI reported by Illumina instruments and BaseSpace. Minimum thresholds (typically ≥75–80%) are defined in clinical assay SOPs and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:properlyPairedRatePct rdf:type rdf:Property ;
    rdfs:label 'Properly Paired Rate Pct' ;
    rdfs:comment 'Percentage of read pairs where both reads mapped to the reference genome in the expected orientation and within the expected insert size range. Low properly paired rates indicate library preparation issues, adapter contamination, or reference genome incompatibility. A standard SAMtools flagstat metric.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Review Notes' ;
    rdfs:comment 'Free-text notes entered by a bioinformatics scientist or QC reviewer during manual review of this alignment result. Captures the rationale for QC status overrides, observations about anomalous metrics, or instructions for downstream processing. Required for GxP audit trail and CLIA/CAP documentation.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Overall Quality Control (QC) pass/fail/warning determination for this alignment result based on evaluation of all QC metrics against defined thresholds. Drives downstream workflow routing: pass results proceed to variant calling; fail results trigger re-sequencing or sample rejection. Satisfies LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLengthBp rdf:type rdf:Property ;
    rdfs:label 'Read Length Bp' ;
    rdfs:comment 'Length of sequencing reads in base pairs (e.g., 150 bp for standard Illumina short-read, 10,000+ bp for long-read platforms). Read length affects alignment accuracy, variant detection capability (especially for structural variants and repeat regions), and computational resource requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceGenomeBuild rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Build' ;
    rdfs:comment 'Human-readable label of the reference genome assembly build used for alignment (e.g., GRCh38/hg38, T2T-CHM13). Stored denormalized here for rapid querying and reporting without joining to the reference genome dimension. Critical for clinical interpretation — variant coordinates are build-specific.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultIdentifier rdf:type rdf:Property ;
    rdfs:label 'Result Identifier' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for this alignment result (e.g., ALN-2024-00123456). Used in LIMS reports, bioinformatics dashboards, and regulatory submissions to uniquely identify an alignment output without exposing surrogate keys. Satisfies BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingPlatform rdf:type rdf:Property ;
    rdfs:label 'Sequencing Platform' ;
    rdfs:comment 'Sequencing instrument platform used to generate the raw reads (e.g., Illumina NovaSeq, PacBio Revio, Oxford Nanopore PromethION). Platform determines read characteristics (length, error profile), applicable alignment tools, and QC thresholds. Required for method validation documentation and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Type' ;
    rdfs:comment 'Classification of the sequencing assay type for which this alignment was performed: Whole Genome Sequencing (WGS), Whole Exome Sequencing (WES), targeted panel, RNA-seq, amplicon, or metagenomics. Determines applicable QC thresholds, coverage requirements, and downstream analysis workflows. Satisfies CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strandBalanceRatio rdf:type rdf:Property ;
    rdfs:label 'Strand Balance Ratio' ;
    rdfs:comment 'Ratio of reads mapping to the forward strand versus the reverse strand (forward_reads / total_mapped_reads). Expected value is approximately 0.5 for unstranded libraries. Significant deviation indicates strand bias, which can introduce systematic variant calling errors, particularly for SNP and indel detection.' ;
    rdfs:domain ind:AlignmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReads rdf:type rdf:Property ;
    rdfs:label 'Total Reads' ;
    rdfs:comment 'Total number of sequencing reads in the input FASTQ file(s) submitted for alignment. Reflects sequencing depth and library complexity. Used to assess whether sufficient input data was provided for the intended application (e.g., WGS, WES, targeted panel). Key QC input metric.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The date and time when this alignment result record was last modified, such as when QC status was updated after manual review or when supplementary metrics were appended. Supports audit trail and data governance requirements. Satisfies RECORD_AUDIT_UPDATED category.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cnvResultId rdf:type rdf:Property ;
    rdfs:label 'Cnv Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each CNV detection result record in the Databricks Silver Layer. Entity role: TRANSACTION_LINE — represents a single CNV call output line produced by a bioinformatics pipeline run for a given sample.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:computeJobId rdf:type rdf:Property ;
    rdfs:label 'Compute Job Id' ;
    rdfs:comment 'Identifier of the HPC cluster or AWS cloud compute job that executed the CNV calling step. Enables compute resource traceability, cost attribution, and job re-execution for reproducibility. Sourced from AWS Batch, Databricks Jobs, or on-premise HPC scheduler.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComputeJob .

ind:geneModelId rdf:type rdf:Property ;
    rdfs:label 'Gene Model Id' ;
    rdfs:comment 'Foreign key linking to reference.gene_model. Business justification: CNV clinical interpretation requires identifying which genes overlap the CNV region for pathogenicity assessment per ACMG CNV guidelines, clinical reporting, and haploinsufficiency/triplosensitivity s' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneModel .

ind:validationStudyId rdf:type rdf:Property ;
    rdfs:label 'Validation Study Id' ;
    rdfs:comment 'Foreign key linking to quality.validation_study. Business justification: CNV calling algorithms require validation studies establishing LOD, sensitivity, specificity, and precision for clinical use. Links CNV result to the validation study demonstrating fitness-for-purpose' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValidationStudy .

ind:annotationPipelineVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Pipeline Version' ;
    rdfs:comment 'Version of the annotation pipeline used to enrich this CNV result with gene overlaps, population frequencies, and disease associations. Distinct from the CNV caller version; required for data lineage and regulatory traceability.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayType rdf:type rdf:Property ;
    rdfs:label 'Assay Type' ;
    rdfs:comment 'Type of genomic assay used to generate the underlying data for CNV calling: Whole Genome Sequencing (WGS), Whole Exome Sequencing (WES), SNP array, Comparative Genomic Hybridization (CGH) array, or targeted panel. Affects CNV resolution and calling methodology.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bafValue rdf:type rdf:Property ;
    rdfs:label 'Baf Value' ;
    rdfs:comment 'B-Allele Frequency (BAF) of heterozygous SNPs within the CNV segment. Used to distinguish copy-neutral LOH from true deletions and to assess allelic imbalance. Key metric in SNP array and WGS-based CNV analysis.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chromosome rdf:type rdf:Property ;
    rdfs:label 'Chromosome' ;
    rdfs:comment 'Chromosome on which the CNV is located (e.g., chr1, chrX, chrY, chr22). Follows UCSC/GRCh38 chromosome naming convention. [ENUM-REF-CANDIDATE: chr1|chr2|chr3|chr4|chr5|chr6|chr7|chr8|chr9|chr10|chr11|chr12|chr13|chr14|chr15|chr16|chr17|chr18|chr19|chr20|chr21|chr22|chrX|chrY|chrM — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSignificance rdf:type rdf:Property ;
    rdfs:label 'Clinical Significance' ;
    rdfs:comment 'Clinical interpretation of the CNV per ACMG/AMP classification guidelines: pathogenic, likely pathogenic, variant of uncertain significance (VUS), likely benign, or benign. Used in clinical genomics reporting and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvCallerTool rdf:type rdf:Property ;
    rdfs:label 'Cnv Caller Tool' ;
    rdfs:comment 'Name of the bioinformatics tool used to call this CNV (e.g., CNVkit, GATK gCNV, Canvas, PennCNV, Lumpy). Enables reproducibility tracking and algorithm comparison across pipeline versions.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvCallerVersion rdf:type rdf:Property ;
    rdfs:label 'Cnv Caller Version' ;
    rdfs:comment 'Software version of the CNV caller tool used to produce this result (e.g., 0.9.10, 4.2.6.1). Required for regulatory submissions, audit trails, and pipeline reproducibility under GxP and CLIA.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvType rdf:type rdf:Property ;
    rdfs:label 'Cnv Type' ;
    rdfs:comment 'Classification of the CNV event type: amplification (gain of copies), deletion (loss of copies), LOH (Loss of Heterozygosity), duplication, or copy-neutral. Critical for oncology, rare disease, and pharmacogenomics interpretation.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Caller-specific confidence or quality score for the CNV call (e.g., posterior probability, Q-score, or tool-specific metric). Higher values indicate greater algorithmic certainty. Thresholds for clinical reporting are defined per SOP.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copyNumberEstimate rdf:type rdf:Property ;
    rdfs:label 'Copy Number Estimate' ;
    rdfs:comment 'Estimated absolute copy number of the genomic segment as computed by the CNV caller (e.g., 0 = homozygous deletion, 1 = hemizygous, 2 = diploid normal, 3+ = amplification). Principal quantitative result for this CNV line.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cytobandLocation rdf:type rdf:Property ;
    rdfs:label 'Cytoband Location' ;
    rdfs:comment 'Cytogenetic band notation for the CNV location (e.g., 17q12, 22q11.2). Derived from reference genome cytogenetic map. Used in clinical reports and karyotype-based communication with clinicians.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endPosition rdf:type rdf:Property ;
    rdfs:label 'End Position' ;
    rdfs:comment '1-based genomic end coordinate (base pair position) of the CNV segment on the reference genome. Together with start_position defines the full genomic interval of the CNV.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filterReason rdf:type rdf:Property ;
    rdfs:label 'Filter Reason' ;
    rdfs:comment 'Coded or free-text reason why this CNV result was filtered (e.g., common_population_variant, blacklist_region, low_probe_count, size_below_threshold). Populated only when is_filtered is True.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inheritancePattern rdf:type rdf:Property ;
    rdfs:label 'Inheritance Pattern' ;
    rdfs:comment 'Inheritance pattern of the CNV as determined by trio or family analysis: de novo (not present in parents), inherited maternal, inherited paternal, unknown, or not applicable (no family data available). Critical for rare disease and prenatal workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFiltered rdf:type rdf:Property ;
    rdfs:label 'Is Filtered' ;
    rdfs:comment 'Indicates whether this CNV result was filtered out by post-calling filters (e.g., common variant filter, size filter, blacklist region filter). True = filtered/excluded from primary analysis; False = retained for reporting.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:log2Ratio rdf:type rdf:Property ;
    rdfs:label 'Log2 Ratio' ;
    rdfs:comment 'Log2 ratio of observed read depth or probe intensity relative to the expected diploid baseline. Negative values indicate deletion; positive values indicate amplification. Core metric for CNV calling algorithms.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:omimDiseaseAssociation rdf:type rdf:Property ;
    rdfs:label 'Omim Disease Association' ;
    rdfs:comment 'Online Mendelian Inheritance in Man (OMIM) disease identifiers associated with genes overlapping this CNV (e.g., OMIM:143100). Supports rare disease and clinical genomics interpretation workflows.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ploidyEstimate rdf:type rdf:Property ;
    rdfs:label 'Ploidy Estimate' ;
    rdfs:comment 'Estimated overall ploidy of the sample genome (e.g., 2.0 for diploid, 3.0 for triploid). Used to normalize copy number estimates in aneuploid tumor samples. Relevant for somatic oncology CNV interpretation.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationFrequency rdf:type rdf:Property ;
    rdfs:label 'Population Frequency' ;
    rdfs:comment 'Frequency of this CNV in reference population databases (e.g., gnomAD-SV, DGV). Low population frequency supports pathogenicity; high frequency suggests benign polymorphism. Expressed as a proportion (0.0 to 1.0).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcFailureReason rdf:type rdf:Property ;
    rdfs:label 'Qc Failure Reason' ;
    rdfs:comment 'Free-text or coded description of the reason(s) for QC failure or flagging (e.g., low probe coverage, high noise ratio, insufficient supporting bins). Populated only when qc_status is fail or flagged. Required for CLIA/CAP audit trails.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Current status of this CNV result in the clinical reporting workflow: pending (awaiting review), reported (included in issued clinical report), amended (result updated after initial report), cancelled (result voided), not_reportable (below reporting threshold). Lifecycle status for CLIA/CAP compliance.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Generated Timestamp' ;
    rdfs:comment 'Timestamp when the CNV caller tool produced this result during pipeline execution. Represents the principal business event time — distinct from the record ingestion timestamp. Used for TAT (Turnaround Time) calculations and pipeline performance monitoring.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentLengthBp rdf:type rdf:Property ;
    rdfs:label 'Segment Length Bp' ;
    rdfs:comment 'Length of the CNV segment in base pairs, computed as end_position minus start_position. Used for size-based clinical classification (e.g., large CNVs >1 Mb have higher pathogenicity likelihood).' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Segmentation Algorithm' ;
    rdfs:comment 'Statistical segmentation algorithm applied to partition the genome into CNV segments (e.g., CBS = Circular Binary Segmentation, HMM = Hidden Markov Model, GISTIC). Affects sensitivity and specificity of CNV boundaries. [ENUM-REF-CANDIDATE: CBS|HMM|GISTIC|DNAcopy|circular_binary_segmentation|penalized_regression|other — promote to reference product if list grows]' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somaticGermlineOrigin rdf:type rdf:Property ;
    rdfs:label 'Somatic Germline Origin' ;
    rdfs:comment 'Classification of the CNV as somatic (acquired, tumor-specific) or germline (constitutional, present in all cells). Determines clinical interpretation pathway, reporting requirements, and applicable regulatory guidelines.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startPosition rdf:type rdf:Property ;
    rdfs:label 'Start Position' ;
    rdfs:comment '1-based genomic start coordinate (base pair position) of the CNV segment on the reference genome. Used for genomic interval queries, overlap analysis, and variant annotation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingProbeCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Probe Count' ;
    rdfs:comment 'Number of probes (array-based) or genomic bins (sequencing-based) that support the CNV call within the defined segment. Higher counts indicate greater statistical confidence in the call.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tumorFractionEstimate rdf:type rdf:Property ;
    rdfs:label 'Tumor Fraction Estimate' ;
    rdfs:comment 'Estimated fraction of tumor cells (tumor purity) in the sample, expressed as a proportion (0.0 to 1.0). Used to adjust copy number estimates in somatic oncology workflows. Null for germline-only analyses.' ;
    rdfs:domain ind:CnvResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:useClassification rdf:type rdf:Property ;
    rdfs:label 'Use Classification' ;
    rdfs:comment 'Regulatory intended use classification of the assay that produced this CNV result: RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), or CE-IVD (EU Conformité Européenne IVD). Determines applicable regulatory framework and reporting obligations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Clinical or research workflow context in which this CNV result was generated. Determines applicable interpretation guidelines, reporting thresholds, and regulatory requirements (e.g., oncology somatic vs. rare disease germline).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Compute jobs represent billable HPC/cloud resource consumption that finance tracks against departmental budgets via cost centers. Enables accurate cost allocation, budget monitoring, and showback/char' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:deviationId rdf:type rdf:Property ;
    rdfs:label 'Deviation Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_deviation. Business justification: Compute infrastructure failures (spot instance preemption, storage corruption, network errors) in GxP environments trigger quality deviations. Required for data integrity investigations and CAPA when ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deviation .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: HPC compute jobs are submitted by bioinformaticians/computational scientists. Required for resource usage reports by employee, cost center attribution, HPC quota management, and GxP audit trails track' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:internalOrderId rdf:type rdf:Property ;
    rdfs:label 'Internal Order Id' ;
    rdfs:comment 'Foreign key linking to finance.internal_order. Business justification: Compute resources for R&D projects are charged to internal orders for proper cost allocation, enabling capitalization tracking and settlement to fixed assets or expense accounts based on project outco' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InternalOrder .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the organizational team or department that owns this compute job. Used for resource quota enforcement, capacity planning, and chargeback allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:pipelineRunStepId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Run Step Id' ;
    rdfs:comment 'Foreign key linking to bioinformatics.pipeline_run_step. Business justification: Compute jobs are spawned at the pipeline STEP level, not just the run level. A compute job executes a specific step (alignment, variant calling, etc.) within a pipeline run. compute_job currently has ' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineRunStep .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Reference to the research or clinical project under which this compute job is executed. Used for chargeback reporting, budget tracking, and resource quota allocation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:algorithmName rdf:type rdf:Property ;
    rdfs:label 'Algorithm Name' ;
    rdfs:comment 'The name of the primary bioinformatics algorithm or tool executed by this job (e.g., BWA-MEM, GATK HaplotypeCaller, DeepVariant, CNVkit, STAR). Used for method traceability and regulatory documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'The version of the bioinformatics algorithm or tool used in this job (e.g., BWA 0.7.17, GATK 4.3.0). Required for reproducibility, method validation, and regulatory submission traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awsRegion rdf:type rdf:Property ;
    rdfs:label 'Aws Region' ;
    rdfs:comment 'The AWS geographic region where this cloud compute job was executed (e.g., us-east-1, eu-west-1). Used for data residency compliance, latency analysis, and regional cost optimization.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeEnvironment rdf:type rdf:Property ;
    rdfs:label 'Compute Environment' ;
    rdfs:comment 'The compute infrastructure platform on which this job was executed. Distinguishes between on-premises HPC schedulers (SLURM, LSF, PBS) and cloud batch services (AWS Batch, GCE, Azure). Critical for cost governance and capacity planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImage rdf:type rdf:Property ;
    rdfs:label 'Container Image' ;
    rdfs:comment 'The Docker or Singularity container image URI used to execute this job (e.g., registry/bwa:0.7.17). Ensures software environment reproducibility and supports GxP validation of computational methods.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpuCoresActual rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Actual' ;
    rdfs:comment 'The actual number of CPU cores consumed by the job during execution as reported by the scheduler or cloud monitoring service. Used for resource utilization analysis and right-sizing recommendations.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cpuCoresRequested rdf:type rdf:Property ;
    rdfs:label 'Cpu Cores Requested' ;
    rdfs:comment 'The number of CPU cores requested by the job at submission time. Compared against actual CPU usage to identify over-provisioning and optimize resource requests for future runs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time when the compute job completed, failed, or was terminated. Used to calculate wall-clock duration and measure pipeline turnaround time (TAT).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'The primary error message or exception captured from the job\'s standard error output upon failure. Used for root cause analysis, pipeline debugging, and incident reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'The estimated monetary cost in US dollars for this compute job, calculated based on instance type, pricing model, and wall-clock duration. Used for cloud cost governance, chargeback reporting, and budget tracking against project allocations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitCode rdf:type rdf:Property ;
    rdfs:label 'Exit Code' ;
    rdfs:comment 'The numeric exit code returned by the job process upon termination. Exit code 0 indicates successful completion; non-zero codes indicate specific failure modes. Used for automated failure classification and retry logic.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpuCountRequested rdf:type rdf:Property ;
    rdfs:label 'Gpu Count Requested' ;
    rdfs:comment 'The number of GPU accelerators requested by the job at submission time. Relevant for deep learning-based variant calling, structural variant analysis, and AI/ML genomics workloads.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hpcNodeName rdf:type rdf:Property ;
    rdfs:label 'Hpc Node Name' ;
    rdfs:comment 'The hostname or identifier of the HPC compute node on which this job executed. Used for hardware failure correlation, node performance analysis, and infrastructure capacity planning.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDataPath rdf:type rdf:Property ;
    rdfs:label 'Input Data Path' ;
    rdfs:comment 'The storage path or URI of the primary input data consumed by this job (e.g., S3 bucket path to FASTQ files, BAM files). Used for data lineage tracking from raw FASTQ to interpreted genomic results.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instanceType rdf:type rdf:Property ;
    rdfs:label 'Instance Type' ;
    rdfs:comment 'The specific compute instance or node type used for job execution (e.g., EC2 instance type such as r5.4xlarge, or HPC node class such as highmem_node). Used for cost estimation and resource optimization analysis.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSpotPreempted rdf:type rdf:Property ;
    rdfs:label 'Is Spot Preempted' ;
    rdfs:comment 'Indicates whether this job was interrupted due to spot instance reclamation by the cloud provider. Used to measure spot preemption rates, assess cost-reliability trade-offs, and inform spot usage policies.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobName rdf:type rdf:Property ;
    rdfs:label 'Job Name' ;
    rdfs:comment 'Human-readable name assigned to the compute job, typically reflecting the pipeline step or algorithm being executed (e.g., bwa_alignment, gatk_variant_calling, cnv_analysis).' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle state of the compute job within the scheduler or cloud batch system. Drives operational monitoring, SLA tracking, and pipeline retry logic. [ENUM-REF-CANDIDATE: pending|queued|running|completed|failed|cancelled|timeout|preempted — promote to reference product]' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobType rdf:type rdf:Property ;
    rdfs:label 'Job Type' ;
    rdfs:comment 'Classification of the bioinformatics workload executed by this job. Drives resource profiling and cost allocation by workload category. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|qc|demultiplexing|assembly|other — promote to reference product]' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memoryActualGb rdf:type rdf:Property ;
    rdfs:label 'Memory Actual Gb' ;
    rdfs:comment 'The peak RAM consumption in gigabytes recorded during job execution. Used for right-sizing analysis, out-of-memory root cause investigation, and capacity planning.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memoryRequestedGb rdf:type rdf:Property ;
    rdfs:label 'Memory Requested Gb' ;
    rdfs:comment 'The amount of RAM in gigabytes requested by the job at submission time. Compared against actual memory usage to detect over-provisioning and prevent out-of-memory failures in future runs.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputDataPath rdf:type rdf:Property ;
    rdfs:label 'Output Data Path' ;
    rdfs:comment 'The storage path or URI where this job\'s primary output data was written (e.g., S3 path to BAM, VCF, or annotation files). Used for downstream pipeline step chaining and data lineage documentation.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineVersion rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version' ;
    rdfs:comment 'The semantic version identifier of the bioinformatics pipeline that spawned this compute job (e.g., v2.4.1). Essential for reproducibility, audit trails, and regulatory submission documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'The pricing or allocation model under which the compute instance was provisioned. Spot instances offer cost savings but risk preemption; on-demand and reserved instances provide reliability. Drives cloud cost governance and budget forecasting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'The business priority tier assigned to this compute job, governing scheduling precedence within the queue. Clinical and regulatory jobs typically receive critical or high priority; exploratory R&D jobs receive standard or low.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueName rdf:type rdf:Property ;
    rdfs:label 'Queue Name' ;
    rdfs:comment 'The name of the HPC job queue or cloud batch queue to which this job was submitted (e.g., high_priority, standard, low_priority, gpu_queue). Used for capacity planning and queue performance analysis.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotaCpuCoreHoursConsumed rdf:type rdf:Property ;
    rdfs:label 'Quota Cpu Core Hours Consumed' ;
    rdfs:comment 'The number of CPU core-hours consumed by this job, counted against the team or project\'s allocated compute quota. Used for quota enforcement, capacity planning, and fair-share scheduling.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'The number of times this compute job has been retried following a failure or preemption. Used to identify unstable pipeline steps, spot instance preemption rates, and resource contention patterns.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulerJobReference rdf:type rdf:Property ;
    rdfs:label 'Scheduler Job Reference' ;
    rdfs:comment 'The native job identifier assigned by the HPC job scheduler or cloud batch service (e.g., SLURM job ID, LSF job ID, PBS job ID, AWS Batch job ID). Used to cross-reference with scheduler logs and cloud billing records.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The date and time when the compute job began actual execution on the assigned compute resource. Used to calculate queue wait time (start minus submission) and actual wall-clock duration.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageIopsRequested rdf:type rdf:Property ;
    rdfs:label 'Storage Iops Requested' ;
    rdfs:comment 'The number of storage input/output operations per second (IOPS) requested by the job. Critical for I/O-intensive genomics workloads such as BAM sorting, FASTQ processing, and large VCF annotation.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageReadGb rdf:type rdf:Property ;
    rdfs:label 'Storage Read Gb' ;
    rdfs:comment 'Total data volume in gigabytes read from storage during job execution. Used for data egress cost estimation, storage performance analysis, and pipeline I/O profiling.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageWriteGb rdf:type rdf:Property ;
    rdfs:label 'Storage Write Gb' ;
    rdfs:comment 'Total data volume in gigabytes written to storage during job execution. Used for storage capacity planning, data lifecycle management, and pipeline output sizing.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when the compute job was submitted to the scheduler or cloud batch service. Used to calculate queue wait time and measure scheduling latency.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wallClockSeconds rdf:type rdf:Property ;
    rdfs:label 'Wall Clock Seconds' ;
    rdfs:comment 'The actual elapsed real-world time in seconds from job start to job end. Distinct from CPU time; used for SLA compliance, pipeline TAT reporting, and resource efficiency analysis.' ;
    rdfs:domain ind:ComputeJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowEngine rdf:type rdf:Property ;
    rdfs:label 'Workflow Engine' ;
    rdfs:comment 'The workflow orchestration engine that submitted and manages this compute job (e.g., Nextflow, Snakemake, CWL, WDL, Apache Airflow). Used for pipeline provenance and reproducibility documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLineageEventId rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each data lineage event record in the bioinformatics processing chain. Primary key for this table. Entity role: EVENT_LOG — captures immutable transformation events across the genomic data processing pipeline from raw FASTQ ingestion to clinical report generation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demuxResultId rdf:type rdf:Property ;
    rdfs:label 'Demux Result Id' ;
    rdfs:comment 'Foreign key linking to sequencing.demux_result. Business justification: Lineage events capture demultiplexing as a transformation step in data processing workflows. This link enables tracking FASTQ file generation and subsequent processing, required for GxP-compliant data' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DemuxResult .

ind:parentLineageEventDataLineageEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Lineage Event Data Lineage Event Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding lineage event in the processing chain. Enables construction of a directed acyclic graph (DAG) of transformation events for end-to-end data lineage traversal from raw FASTQ to clinical report.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataLineageEvent .

ind:primaryDataGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Primary Data Genomic Artifact Id' ;
    rdfs:comment 'Reference to the genomic data artifact (e.g., FASTQ, BAM, VCF, gVCF, annotation file) that served as the input to this transformation event. Supports forward and backward data lineage tracing.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:targetArtifactGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Genomic Artifact Id' ;
    rdfs:comment 'Reference to the genomic data artifact produced as the output of this transformation event (e.g., aligned BAM, called VCF, annotated VCF, clinical report). Enables downstream lineage traversal.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:algorithmParameters rdf:type rdf:Property ;
    rdfs:label 'Algorithm Parameters' ;
    rdfs:comment 'Serialized string (JSON or key=value pairs) of the runtime parameters passed to the bioinformatics tool for this transformation event (e.g., minimum base quality score, minimum mapping quality, ploidy setting). Critical for reproducibility and regulatory audit trails.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Structured error or exception code returned by the bioinformatics tool or pipeline orchestrator when a transformation event fails (e.g., TOOL_EXIT_NONZERO, INSUFFICIENT_COVERAGE, CHECKSUM_MISMATCH, TIMEOUT). Used for failure root-cause analysis and automated alerting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Externally-known business identifier for this lineage event, formatted as LIN- followed by an alphanumeric code. Used for cross-system referencing, audit log correlation, and regulatory submission traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the data transformation event. Indicates whether the transformation is pending execution, actively running, successfully completed, failed with error, skipped due to conditional logic, or retried after a prior failure. Used for pipeline monitoring and failure root-cause analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time (ISO 8601 with timezone offset) at which the data transformation event occurred in the bioinformatics pipeline. This is the principal real-world event time, distinct from record audit timestamps. Critical for GxP audit trails and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorical discriminator identifying the kind of data transformation that occurred in the bioinformatics pipeline. Values: ingest (raw FASTQ ingestion), transform (alignment/variant calling), filter (QC filtering), merge (combining artifacts), split (demultiplexing), annotate (variant annotation), export (clinical report generation), archive (long-term storage). [ENUM-REF-CANDIDATE: ingest|transform|filter|merge|split|annotate|export|archive — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'Wall-clock elapsed time in seconds for the transformation event to complete, from job start to job end. Used for pipeline performance benchmarking, Turnaround Time (TAT) analysis, and SLA monitoring.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gxpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Gxp Audit Required' ;
    rdfs:comment 'Indicates whether this transformation event is subject to GxP (Good Practice Regulations including GMP, GLP, GCP) audit trail requirements (True = GxP-regulated event, False = non-regulated event). Used to filter events for regulatory audit reporting and inspection readiness.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaPhiInvolved rdf:type rdf:Property ;
    rdfs:label 'Hipaa Phi Involved' ;
    rdfs:comment 'Indicates whether this transformation event processed or produced data containing Protected Health Information (PHI) as defined under HIPAA (True = PHI involved, False = no PHI). Used for HIPAA compliance reporting, data access controls, and breach risk assessment.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inputRecordCount rdf:type rdf:Property ;
    rdfs:label 'Input Record Count' ;
    rdfs:comment 'Number of input records, reads, or variants consumed by this transformation event (e.g., number of FASTQ reads ingested, number of variants in input VCF). Used for data volume tracking, QC validation, and pipeline performance analysis.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorIdentity rdf:type rdf:Property ;
    rdfs:label 'Operator Identity' ;
    rdfs:comment 'Username, service account name, or system identity (human user or automated pipeline agent) that initiated or executed this transformation event. Required for GxP audit trails, 21 CFR Part 11 electronic signature traceability, and HIPAA access accountability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Categorizes whether the transformation event was initiated by a human user, an automated bioinformatics pipeline, a system service account, or a scheduled job. Supports audit trail differentiation and compliance reporting under 21 CFR Part 11.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputRecordCount rdf:type rdf:Property ;
    rdfs:label 'Output Record Count' ;
    rdfs:comment 'Number of output records, reads, or variants produced by this transformation event (e.g., number of aligned reads in output BAM, number of variants in output VCF). Used for data volume tracking, QC validation, and yield analysis.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'High-level stage of the bioinformatics processing pipeline in which this transformation event occurred. Values: ingestion (raw FASTQ intake), preprocessing (trimming/QC), alignment (BAM/CRAM generation), variant_calling (VCF/gVCF), annotation (variant annotation), qc_filtering (QC-based filtering), reporting (clinical report generation), archival (long-term storage). [ENUM-REF-CANDIDATE: ingestion|preprocessing|alignment|variant_calling|annotation|qc_filtering|reporting|archival — promote to reference product]' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMetricName rdf:type rdf:Property ;
    rdfs:label 'Qc Metric Name' ;
    rdfs:comment 'Name of the primary Quality Control (QC) metric evaluated at this transformation step (e.g., mean_coverage_depth, percent_mapped_reads, phred_score_q30_percent, ts_tv_ratio, variant_call_rate). Provides context for the QC pass/fail determination.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMetricValue rdf:type rdf:Property ;
    rdfs:label 'Qc Metric Value' ;
    rdfs:comment 'Numeric value of the primary Quality Control (QC) metric evaluated at this transformation step (e.g., 45.7 for mean coverage depth, 98.3 for percent mapped reads). Used for QC trending, threshold monitoring, and regulatory compliance reporting.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcPassFlag rdf:type rdf:Property ;
    rdfs:label 'Qc Pass Flag' ;
    rdfs:comment 'Indicates whether the output artifact of this transformation event passed Quality Control (QC) criteria (True = QC passed, False = QC failed). Used for pipeline gating, clinical report eligibility, and regulatory compliance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceArtifactChecksum rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the input genomic data artifact at the time of consumption. Used to verify data integrity, detect corruption, and confirm that the correct artifact version was used. Required for 21 CFR Part 11 and GxP data integrity compliance.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceArtifactFormat rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Format' ;
    rdfs:comment 'File format of the input genomic data artifact consumed by this transformation event (e.g., FASTQ for raw reads, BAM/CRAM for aligned reads, VCF/gVCF for variant calls). Enables format-aware lineage queries and pipeline validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|FASTA|TSV|CSV|JSON|HTML|PDF — promote to reference product]' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Source Artifact Path' ;
    rdfs:comment 'Cloud or network storage path (e.g., S3 URI, ADLS path) of the input genomic data artifact consumed by this transformation event. Confidential as it may reveal internal infrastructure topology and data organization. Required for data recovery, re-processing, and audit traceability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactChecksum rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Checksum' ;
    rdfs:comment 'Cryptographic hash (MD5, SHA-256, or SHA-512) of the output genomic data artifact produced by this transformation event. Used to verify data integrity, detect corruption, and confirm artifact authenticity for downstream steps. Required for 21 CFR Part 11 and GxP data integrity compliance.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactFormat rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Format' ;
    rdfs:comment 'File format of the output genomic data artifact produced by this transformation event (e.g., BAM for alignment output, VCF for variant calling output, annotated VCF for annotation output). Enables format-aware lineage queries and downstream pipeline validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|FASTA|TSV|CSV|JSON|HTML|PDF — promote to reference product]' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetArtifactPath rdf:type rdf:Property ;
    rdfs:label 'Target Artifact Path' ;
    rdfs:comment 'Cloud or network storage path (e.g., S3 URI, ADLS path) of the output genomic data artifact produced by this transformation event. Confidential as it may reveal internal infrastructure topology. Required for downstream pipeline steps, data recovery, and audit traceability.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolContainerImage rdf:type rdf:Property ;
    rdfs:label 'Tool Container Image' ;
    rdfs:comment 'Docker or container image URI (including registry, repository, and digest/tag) used to execute the bioinformatics tool, ensuring exact computational environment reproducibility. Example: docker.io/broadinstitute/gatk:4.2.6.1. Supports GxP validation and 21 CFR Part 11 audit requirements.' ;
    rdfs:domain ind:DataLineageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolName rdf:type rdf:Property ;
    rdfs:label 'Tool Name' ;
    rdfs:comment 'Name of the bioinformatics software tool or algorithm used to perform the data transformation (e.g., BWA-MEM, GATK HaplotypeCaller, STAR, Trimmomatic, SnpEff, VEP). Essential for reproducibility and regulatory validation documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolVersion rdf:type rdf:Property ;
    rdfs:label 'Tool Version' ;
    rdfs:comment 'Semantic version string of the bioinformatics tool used for the transformation (e.g., 4.2.6.1 for GATK, 0.7.17 for BWA). Required for reproducibility, pipeline validation, and regulatory submission documentation under GxP and 21 CFR Part 11.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Genomic data files (BAMs, VCFs, analysis reports) generated for customer accounts in commercial service or collaborative research contexts. Essential for data delivery tracking, customer portal access' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:catalogItemId rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Reference datasets, genome assemblies, annotation databases are sold as catalog items (e.g., Illumina BaseSpace datasets, GATK resource bundles). Business need: product sales tracking, licensing enfor' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Genomic data files (BAM, VCF, FASTQ) require creation attribution for 21 CFR Part 11 electronic records compliance, data lineage tracking, and GxP audit trails. Critical for regulatory submissions and' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:demuxBatchId rdf:type rdf:Property ;
    rdfs:label 'Demux Batch Id' ;
    rdfs:comment 'Identifier of the demultiplexing batch job that separated this sample\'s reads from the pooled sequencing run output. Provides provenance linkage to the specific demultiplexing parameters, software version, and mismatches-allowed settings used.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:genomicAccessControlId rdf:type rdf:Property ;
    rdfs:label 'Genomic Access Control Id' ;
    rdfs:comment 'Foreign key linking to data.genomic_access_control. Business justification: Genomic data access is governed by informed consent, IRB approvals, data use agreements (dbGaP, EGA accessions), and data use limitations. Links artifacts to access control policies enforcing authoriz' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicAccessControl .

ind:instrumentRunId rdf:type rdf:Property ;
    rdfs:label 'Instrument Run Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_run. Business justification: Raw sequencing files (FASTQ, BCL) are generated by instrument runs. This link establishes data provenance from file creation through analysis pipeline, required for regulatory submissions (FDA/CLIA), ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstrumentRun .

ind:metadataSchemaId rdf:type rdf:Property ;
    rdfs:label 'Metadata Schema Id' ;
    rdfs:comment 'Foreign key linking to data.metadata_schema. Business justification: Genomic data files require standardized metadata schemas (GA4GH, CRAM, VCF standards) for FAIR Findable/Interoperable principles, repository submission (dbGaP, EGA), and cross-study data integration. ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetadataSchema .

ind:opportunityId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Id' ;
    rdfs:comment 'Foreign key linking to commercial.opportunity. Business justification: Genomic artifacts (analysis reports, VCF files, BAM files) are deliverables in service-based business models and proof-of-concept engagements. Sales operations track which data artifacts were generate' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:parentArtifactGenomicArtifactId rdf:type rdf:Property ;
    rdfs:label 'Parent Artifact Genomic Artifact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate upstream artifact from which this artifact was derived (e.g., a BAM artifact\'s parent is the FASTQ artifact; a VCF artifact\'s parent is the BAM artifact). Enables reconstruction of the full data lineage chain from raw to interpreted results.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicArtifact .

ind:qualityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Quality Assessment Id' ;
    rdfs:comment 'Foreign key linking to data.quality_assessment. Business justification: Genomic artifacts (FASTQ, BAM, VCF files) are primary targets of quality assessment in genomics operations. Tracks completeness, accuracy, validity scores for regulatory compliance, data sharing agree' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityAssessment .

ind:retentionPolicyId rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Id' ;
    rdfs:comment 'Foreign key linking to data.retention_policy. Business justification: Genomic data retention is governed by consent duration, IRB approval periods, regulatory requirements (21 CFR Part 11), and storage cost optimization. Links artifacts to retention policies determining' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionPolicy .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when this artifact was moved to archival storage (e.g., AWS S3 Glacier), in ISO 8601 format with timezone offset. Null if the artifact has not been archived. Used for storage cost tracking, retrieval SLA management, and compliance with data lifecycle policies.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:artifactExternalReference rdf:type rdf:Property ;
    rdfs:label 'Artifact External Reference' ;
    rdfs:comment 'Externally-known unique identifier for the artifact as assigned by the originating system of record (e.g., Illumina BaseSpace file ID, LabVantage LIMS artifact accession number, or cloud storage object key). Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactName rdf:type rdf:Property ;
    rdfs:label 'Artifact Name' ;
    rdfs:comment 'Human-readable name or label assigned to the genomic artifact, typically derived from the sample identifier, run identifier, and artifact type (e.g., \'SampleA_WGS_R1.fastq.gz\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactStatus rdf:type rdf:Property ;
    rdfs:label 'Artifact Status' ;
    rdfs:comment 'Current lifecycle state of the genomic artifact within the bioinformatics pipeline ecosystem. \'pending\' indicates awaiting generation; \'available\' indicates ready for downstream consumption; \'processing\' indicates actively being transformed; \'failed\' indicates a pipeline error; \'archived\' indicates moved to cold storage; \'deleted\' indicates purged per retention policy. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactType rdf:type rdf:Property ;
    rdfs:label 'Artifact Type' ;
    rdfs:comment 'Classification of the genomic data artifact by its file format and biological content type. Drives downstream pipeline routing, storage tier assignment, and retention policy application. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|gVCF|BED|ANNOTATION|REPORT|INDEX|QC_METRICS — promote to reference product]' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeSequence rdf:type rdf:Property ;
    rdfs:label 'Barcode Sequence' ;
    rdfs:comment 'Index/barcode nucleotide sequence used to identify this sample within a multiplexed sequencing pool during demultiplexing. Enables traceability of the artifact to its specific library preparation and sample assignment in a pooled run.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumMd5 rdf:type rdf:Property ;
    rdfs:label 'Checksum Md5' ;
    rdfs:comment 'MD5 hash digest of the artifact file content used for data integrity verification during transfer, storage, and retrieval. Enables detection of file corruption or unauthorized modification. Widely used in genomics data exchange protocols.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumSha256 rdf:type rdf:Property ;
    rdfs:label 'Checksum Sha256' ;
    rdfs:comment 'SHA-256 cryptographic hash of the artifact file content providing stronger integrity assurance than MD5. Required for regulatory-grade data integrity verification under GxP and HIPAA security rule compliance. Preferred checksum for clinical and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compressionFormat rdf:type rdf:Property ;
    rdfs:label 'Compression Format' ;
    rdfs:comment 'Compression algorithm applied to the artifact file. BGZF (Blocked GNU Zip Format) is standard for BAM/CRAM/VCF files enabling random access; GZIP is standard for FASTQ files. Determines decompression requirements for downstream pipeline steps and storage cost calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsPhi rdf:type rdf:Property ;
    rdfs:label 'Contains Phi' ;
    rdfs:comment 'Boolean flag indicating whether this artifact contains Protected Health Information (PHI) as defined under HIPAA. Drives access control enforcement, audit logging requirements, and data handling procedures. Must be set to True for any artifact linked to an identified clinical sample.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Privacy and regulatory classification of the genomic data contained in this artifact. \'PHI\' (Protected Health Information) indicates data subject to HIPAA; \'de_identified\' indicates PHI has been removed per HIPAA Safe Harbor or Expert Determination; \'research\' indicates IRB-governed research data; \'restricted\' indicates controlled-access data (e.g., dbGaP); \'public\' indicates open-access data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'File Generation Timestamp' ;
    rdfs:comment 'Timestamp when the physical artifact file was generated by the pipeline or instrument, in ISO 8601 format with timezone offset. Distinct from the registry record creation timestamp — represents the actual file creation time as reported by the pipeline or storage system. Used for data freshness assessment and TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Physical size of the genomic artifact file in bytes at the time of creation or last verification. Used for storage capacity planning, cost allocation, and data transfer monitoring. Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomeBuild rdf:type rdf:Property ;
    rdfs:label 'Genome Build' ;
    rdfs:comment 'Specific reference genome assembly build used during alignment or variant calling (e.g., GRCh38, GRCh37/hg19). Stored directly on the artifact for rapid querying without joining to the reference genome table. Critical for variant interpretation and cross-cohort comparability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStorageUri rdf:type rdf:Property ;
    rdfs:label 'Index Storage Uri' ;
    rdfs:comment 'Full URI path to the index file associated with this artifact (e.g., \'.bai\' for BAM, \'.tbi\' for VCF). Stored alongside the artifact URI to enable direct access by pipeline tools without requiring a separate lookup.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIndexed rdf:type rdf:Property ;
    rdfs:label 'Is Indexed' ;
    rdfs:comment 'Boolean flag indicating whether a corresponding index file exists for this artifact (e.g., BAI index for BAM, TBI/CSI index for VCF). Indexed artifacts support random-access queries by genomic coordinate, which is required for most downstream analysis tools.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPairedEnd rdf:type rdf:Property ;
    rdfs:label 'Is Paired End' ;
    rdfs:comment 'Boolean flag indicating whether the sequencing reads in this artifact were generated using paired-end sequencing chemistry (True) or single-end (False). Paired-end reads improve alignment accuracy and structural variant detection. Determines applicable alignment and QC parameters.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'Lane number on the sequencing flow cell from which the reads in this artifact were generated. Used for per-lane QC analysis, demultiplexing traceability, and identification of lane-specific sequencing artifacts or failures.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meanPhredQualityScore rdf:type rdf:Property ;
    rdfs:label 'Mean Phred Quality Score' ;
    rdfs:comment 'Mean Phred base quality score across all reads in the artifact. Phred score (Q) represents the probability of an incorrect base call (Q30 = 99.9% accuracy). A primary QC metric for sequencing run quality assessment per CLIA and CAP standards.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentQ30 rdf:type rdf:Property ;
    rdfs:label 'Percent Q30' ;
    rdfs:comment 'Percentage of bases in the artifact with a Phred quality score of 30 or higher (≥Q30), indicating ≥99.9% base call accuracy. Industry-standard QC threshold metric for NGS data quality acceptance. Typically required to be ≥80% for clinical-grade sequencing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date on which this artifact becomes eligible for archival or deletion per the assigned retention policy. Calculated from the artifact creation date and the applicable retention period. Used by automated data lifecycle management processes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Retention policy classification governing how long this artifact must be retained before it is eligible for archival or deletion. \'short_term\' (e.g., 90 days for intermediate files); \'standard\' (e.g., 2 years); \'long_term\' (e.g., 7 years for clinical); \'permanent\' (e.g., reference datasets); \'regulatory_hold\' (litigation or regulatory investigation hold).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencingAssayType rdf:type rdf:Property ;
    rdfs:label 'Sequencing Assay Type' ;
    rdfs:comment 'Type of genomic sequencing or array assay that generated the raw data underlying this artifact. Determines applicable QC thresholds, coverage expectations, and downstream analysis pipelines. [ENUM-REF-CANDIDATE: WGS|WES|RNA_SEQ|AMPLICON|TARGETED_PANEL|ARRAY|CHIP_SEQ|METHYL_SEQ|ATAC_SEQ|SINGLE_CELL — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePlatform rdf:type rdf:Property ;
    rdfs:label 'Storage Platform' ;
    rdfs:comment 'Cloud or on-premises storage platform where the artifact is physically stored. Drives data access patterns, cost allocation, and egress fee tracking. Supports multi-cloud and hybrid storage architecture management.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full URI path to the artifact file in the storage backend (e.g., S3 bucket path \'s3://genomics-biotech-prod/artifacts/sample123/output.bam\', HDFS path, or NFS mount path). Used by pipeline orchestration and data access layers to locate and retrieve the file.' ;
    rdfs:domain ind:GenomicArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReadCount rdf:type rdf:Property ;
    rdfs:label 'Total Read Count' ;
    rdfs:comment 'Total number of sequencing reads contained in this artifact. For FASTQ files, represents raw read count; for BAM/CRAM files, represents total aligned and unaligned reads. Used for QC assessment, yield reporting, and billing calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variantCount rdf:type rdf:Property ;
    rdfs:label 'Variant Count' ;
    rdfs:comment 'Total number of genomic variants (SNPs, indels, CNVs, SVs) recorded in this artifact for VCF and gVCF file types. Provides a high-level QC indicator and enables rapid assessment of variant calling yield without parsing the full VCF file.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mafRecordId rdf:type rdf:Property ;
    rdfs:label 'Maf Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each Minor Allele Frequency (MAF) calculation record in the Databricks Silver Layer. Entity role: TRANSACTION_HEADER — represents a discrete computational event (MAF calculation) with its own lifecycle, inputs, outputs, and audit trail.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cohortId rdf:type rdf:Property ;
    rdfs:label 'Cohort Id' ;
    rdfs:comment 'Reference to the cohort or study population over which this MAF was calculated, supporting population genomics, pharmacogenomics, and clinical interpretation workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cohort .

ind:supersededByMafRecordId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Maf Record Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer MAF record that supersedes this one, enabling data lineage chains and ensuring consumers can navigate to the current authoritative MAF value.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MafRecord .

ind:variantCallResultId rdf:type rdf:Property ;
    rdfs:label 'Variant Call Result Id' ;
    rdfs:comment 'Reference to the canonical variant record (SNP, CNV, or other variant type) for which this MAF calculation was performed, linking to the variant catalog.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantCallResult .

ind:alleleCount rdf:type rdf:Property ;
    rdfs:label 'Allele Count' ;
    rdfs:comment 'Total count of the alternate (minor) allele observed across all samples in the cohort or study population. Corresponds to the AC field in VCF INFO annotations and gnomAD allele count metrics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Allele Frequency' ;
    rdfs:comment 'Observed frequency of the alternate allele in the cohort or study population, calculated as allele_count / allele_number. Corresponds to the AF field in VCF INFO annotations. Range: 0.0 to 1.0.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alleleNumber rdf:type rdf:Property ;
    rdfs:label 'Allele Number' ;
    rdfs:comment 'Total number of alleles (both reference and alternate) observed across all samples in the cohort or study population. Corresponds to the AN field in VCF INFO annotations. Used as the denominator in MAF calculation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternateAllele rdf:type rdf:Property ;
    rdfs:label 'Alternate Allele' ;
    rdfs:comment 'The non-reference nucleotide sequence observed at this locus (e.g., T, C, ACGT). Conforms to VCF specification ALT field conventions. Represents the minor allele in MAF calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisScope rdf:type rdf:Property ;
    rdfs:label 'Analysis Scope' ;
    rdfs:comment 'Sequencing or array technology scope used to generate the variant data underlying this MAF calculation: WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), TARGETED_PANEL, ARRAY (SNP array), AMPLICON, or OTHER.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current lifecycle status of this MAF calculation record: PENDING (queued), RUNNING (in progress), COMPLETED (successfully calculated), FAILED (pipeline error), SUPERSEDED (replaced by a newer calculation for the same variant/cohort).' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'The principal business event timestamp: the date and time when the MAF calculation was executed by the bioinformatics pipeline. Distinct from record audit timestamps. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ciConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Ci Confidence Level' ;
    rdfs:comment 'Statistical confidence level used for the confidence interval calculation, expressed as a percentage (e.g., 95.00 for 95% CI, 99.00 for 99% CI). Enables reproducibility and comparison across studies.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ciLower rdf:type rdf:Property ;
    rdfs:label 'Ci Lower' ;
    rdfs:comment 'Lower bound of the confidence interval for the MAF estimate, reflecting statistical uncertainty due to sample size. Typically computed using Wilson score or Clopper-Pearson method.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ciUpper rdf:type rdf:Property ;
    rdfs:label 'Ci Upper' ;
    rdfs:comment 'Upper bound of the confidence interval for the MAF estimate, reflecting statistical uncertainty due to sample size. Typically computed using Wilson score or Clopper-Pearson method.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genomicPosition rdf:type rdf:Property ;
    rdfs:label 'Genomic Position' ;
    rdfs:comment '1-based genomic coordinate of the variant on the specified chromosome, aligned to the reference genome assembly. Used for variant lookup, annotation, and cross-database matching.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:heterozygousCount rdf:type rdf:Property ;
    rdfs:label 'Heterozygous Count' ;
    rdfs:comment 'Number of samples in the cohort that are heterozygous for the alternate allele (genotype RA). Used in Hardy-Weinberg equilibrium testing and zygosity-based clinical interpretation.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homozygousCount rdf:type rdf:Property ;
    rdfs:label 'Homozygous Count' ;
    rdfs:comment 'Number of samples in the cohort that are homozygous for the alternate allele (genotype AA). Used in Hardy-Weinberg equilibrium testing and pharmacogenomics dosing calculations.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hwePValue rdf:type rdf:Property ;
    rdfs:label 'Hwe P Value' ;
    rdfs:comment 'P-value from the Hardy-Weinberg Equilibrium test for this variant in the population. Low HWE p-values (e.g., < 1e-6) may indicate genotyping error, population stratification, or selection pressure, and are used as a QC filter.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSuperseded rdf:type rdf:Property ;
    rdfs:label 'Is Superseded' ;
    rdfs:comment 'Indicates whether this MAF record has been superseded by a newer calculation for the same variant and cohort (e.g., due to pipeline version upgrade or cohort expansion). When True, downstream consumers should use the replacement record.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Maf Calculation Method' ;
    rdfs:comment 'Statistical or computational method used to calculate the MAF value: DIRECT_COUNT (observed allele counts), IMPUTATION (genotype imputation-based), BAYESIAN (Bayesian frequency estimation), EM_ALGORITHM (expectation-maximization), or OTHER.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mafRecordCode rdf:type rdf:Property ;
    rdfs:label 'Maf Record Code' ;
    rdfs:comment 'Externally-known business identifier for this MAF record, used in reports, regulatory submissions, and cross-system references. Format: MAF-{YYYY}-{8-char alphanumeric}.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mafValue rdf:type rdf:Property ;
    rdfs:label 'Maf Value' ;
    rdfs:comment 'The principal MAF result: the frequency of the less common allele in the population, defined as min(AF, 1-AF). Range: 0.0 to 0.5. This is the primary quantitative output of the MAF calculation pipeline.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacogenomicsRelevance rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomics Relevance' ;
    rdfs:comment 'Indicates whether this variant and its MAF are relevant to pharmacogenomics (PGx) drug-gene interaction analysis. When True, this record is included in PGx reporting workflows and drug dosing recommendation pipelines.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationGroup rdf:type rdf:Property ;
    rdfs:label 'Population Group' ;
    rdfs:comment 'Population ancestry or stratification group for which this MAF was calculated (e.g., AFR, AMR, EAS, EUR, SAS, FIN, ASJ, OTH as defined by gnomAD). Enables population-specific frequency reporting and pharmacogenomics stratification. [ENUM-REF-CANDIDATE: AFR|AMR|EAS|EUR|SAS|FIN|ASJ|OTH|ALL — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcFilterFlags rdf:type rdf:Property ;
    rdfs:label 'Qc Filter Flags' ;
    rdfs:comment 'Semicolon-delimited list of specific QC filter flags applied to this record (e.g., LOW_COVERAGE;HWE_FAIL;LOW_SAMPLE_COUNT). Provides granular QC failure reasons for troubleshooting and audit purposes.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcFilterStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Filter Status' ;
    rdfs:comment 'Quality control filter outcome for this MAF record: PASS (meets all QC thresholds), FAIL (failed one or more QC filters), REVIEW (flagged for manual review), EXCLUDED (excluded from downstream analysis). Aligns with VCF FILTER field conventions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refDatabaseSource rdf:type rdf:Property ;
    rdfs:label 'Ref Database Source' ;
    rdfs:comment 'External population frequency reference database used in or compared against this MAF calculation (e.g., gnomAD, 1000 Genomes, TOPMed, ExAC). Supports cross-database validation and clinical interpretation. [ENUM-REF-CANDIDATE: gnomAD|1000_GENOMES|TOPMED|EXAC|INTERNAL|MULTI_SOURCE|OTHER — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Ref Database Version' ;
    rdfs:comment 'Version of the external reference population database used (e.g., gnomAD v4.1, 1000 Genomes Phase 3). Critical for reproducibility, regulatory submissions, and longitudinal comparisons as database versions change allele frequencies.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceAllele rdf:type rdf:Property ;
    rdfs:label 'Reference Allele' ;
    rdfs:comment 'The nucleotide sequence present in the reference genome at this locus (e.g., A, G, ACGT). Conforms to VCF specification REF field conventions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsid rdf:type rdf:Property ;
    rdfs:label 'Rsid' ;
    rdfs:comment 'NCBI dbSNP reference SNP cluster identifier (e.g., rs334) for the variant, enabling cross-referencing with public population frequency databases such as gnomAD and 1000 Genomes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCount rdf:type rdf:Property ;
    rdfs:label 'Sample Count' ;
    rdfs:comment 'Number of individual samples (subjects) included in the MAF calculation for this variant and population group. Distinct from allele_number (which counts alleles, not individuals). Used to assess statistical power.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useType rdf:type rdf:Property ;
    rdfs:label 'Use Type' ;
    rdfs:comment 'Regulatory intended use classification for this MAF record: RUO (Research Use Only), IVD (In Vitro Diagnostic), LDT (Laboratory Developed Test), RESEARCH, or CLINICAL. Governs how this data may be used in clinical reporting and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantNotation rdf:type rdf:Property ;
    rdfs:label 'Variant Notation' ;
    rdfs:comment 'Human Genome Variation Society (HGVS) standard notation for the variant (e.g., NM_000059.3:c.5266dupC), providing a human-readable and internationally recognized identifier for the variant.' ;
    rdfs:domain ind:MafRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantType rdf:type rdf:Property ;
    rdfs:label 'Variant Type' ;
    rdfs:comment 'Classification of the genomic variant: SNP (Single Nucleotide Polymorphism), INDEL (insertion/deletion), CNV (Copy Number Variation), MNP (multi-nucleotide polymorphism), SV (structural variant), or OTHER.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Id' ;
    rdfs:comment 'Unique surrogate identifier for each bioinformatics pipeline definition record in the master registry. Primary key for the pipeline data product.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pipeline .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to commercial.campaign. Business justification: Marketing campaigns promote specific pipeline capabilities (e.g., \'New CNV Detection Pipeline\' launch campaign). Campaign effectiveness is measured by pipeline adoption, trial requests, and usage metr' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GenomicsBiotech .

ind:controlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Controlled Document Id' ;
    rdfs:comment 'Reference identifier for the GxP validation documentation package stored in Veeva Vault (e.g., IQ/OQ/PQ validation report document ID). Links the pipeline definition to its formal validation evidence for regulatory audits.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:modelId rdf:type rdf:Property ;
    rdfs:label 'Model Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_model. Business justification: Bioinformatics pipelines are validated for specific sequencer platforms (e.g., NovaSeq 6000 vs MiSeq). This link enforces platform-specific pipeline qualification requirements, ensures correct algorit' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Model .

ind:annotationDatabase rdf:type rdf:Property ;
    rdfs:label 'Annotation Database' ;
    rdfs:comment 'Name and version of the variant annotation database(s) used by the pipeline (e.g., \'ClinVar 2024-01\', \'gnomAD v3.1.2\', \'dbSNP 156\', \'COSMIC v97\'). Determines the clinical and population-level context applied to called variants.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Documented reason for the creation of this pipeline version (e.g., \'Updated reference genome to GRCh38\', \'Algorithm parameter tuning for improved sensitivity\', \'Bug fix in CNV caller\'). Required for GxP change control and audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvDetectionSupported rdf:type rdf:Property ;
    rdfs:label 'Cnv Detection Supported' ;
    rdfs:comment 'Indicates whether the pipeline includes Copy Number Variation (CNV) detection capability. CNV analysis identifies genomic regions with abnormal copy numbers, relevant for oncology and rare disease diagnostics.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this pipeline version is approved and available for production use. Pipelines should not be used in production runs before this date. Supports GxP change control and regulatory traceability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedRuntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Runtime Hours' ;
    rdfs:comment 'Estimated wall-clock runtime in hours for a standard pipeline execution on a typical input dataset. Used for TAT (Turnaround Time) planning, SLA commitments, and HPC/cloud job scheduling.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Execution Environment' ;
    rdfs:comment 'Compute environment where the pipeline is designed to execute (HPC — High-Performance Computing cluster, AWS cloud, on-premise servers, hybrid, or Databricks). Drives infrastructure provisioning and cost allocation.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Gxp Validation Status' ;
    rdfs:comment 'GxP validation status of the pipeline indicating whether it has been formally validated for use in regulated (GMP/GLP/GCP) environments. Pipelines used in IVD or clinical assay workflows must be validated per FDA 21 CFR Part 11 and ISO 13485 requirements.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDataFormat rdf:type rdf:Property ;
    rdfs:label 'Input Data Format' ;
    rdfs:comment 'Primary input file format accepted by the pipeline (e.g., FASTQ for raw sequencing reads, BAM — Binary Alignment Map for aligned reads, CRAM, VCF — Variant Call Format). Defines upstream data dependencies and ingestion requirements.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isParallelizable rdf:type rdf:Property ;
    rdfs:label 'Is Parallelizable' ;
    rdfs:comment 'Indicates whether the pipeline supports parallel execution across multiple compute nodes or shards (e.g., scatter-gather parallelism in WDL). Parallelizable pipelines can be scaled horizontally on HPC or AWS for reduced TAT.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafThreshold rdf:type rdf:Property ;
    rdfs:label 'Maf Threshold' ;
    rdfs:comment 'Minor Allele Frequency (MAF) threshold used by the pipeline to filter common variants from rare variant analysis. Variants with MAF above this threshold may be excluded from clinical reporting. Expressed as a decimal (e.g., 0.01 = 1%).' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCpuCores rdf:type rdf:Property ;
    rdfs:label 'Max Cpu Cores' ;
    rdfs:comment 'Maximum number of CPU cores allocated per pipeline execution job. Used for HPC/AWS resource planning, cost estimation, and job scheduling configuration.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Max Memory Gb' ;
    rdfs:comment 'Maximum RAM memory in gigabytes (GB) required per pipeline execution job. Critical for HPC cluster and AWS instance type selection and cost management.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Min Coverage Depth' ;
    rdfs:comment 'Minimum sequencing coverage depth (read depth, expressed as integer fold-coverage, e.g., 30x) required for the pipeline to produce reliable results. Used in QC gating and assay validation documentation.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPhredScore rdf:type rdf:Property ;
    rdfs:label 'Min Phred Score' ;
    rdfs:comment 'Minimum Phred quality score threshold applied during pipeline execution for base quality filtering. Phred scores represent the probability of an incorrect base call; higher values indicate higher quality. Typical threshold is Q20 or Q30.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minReadLength rdf:type rdf:Property ;
    rdfs:label 'Min Read Length' ;
    rdfs:comment 'Minimum sequencing read length in base pairs (bp) required for this pipeline to function correctly. Ensures compatibility with sequencing instrument output and library preparation protocols.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiplexingSupported rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Supported' ;
    rdfs:comment 'Indicates whether the pipeline supports multiplexed sample processing (multiple samples pooled on a single flow cell and demultiplexed during processing). True if multiplexing/demultiplexing is handled within the pipeline.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outputDataFormat rdf:type rdf:Property ;
    rdfs:label 'Output Data Format' ;
    rdfs:comment 'Primary output file format produced by the pipeline (e.g., BAM/CRAM for alignment, VCF/gVCF — Genomic VCF for variant calls, BED, TSV). Defines downstream data consumption and annotation pipeline compatibility. [ENUM-REF-CANDIDATE: BAM|CRAM|VCF|gVCF|BED|TSV|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the bioinformatics team or organizational unit responsible for this pipeline (e.g., \'Clinical Bioinformatics\', \'Research Genomics\', \'NGS Platform Engineering\'). Supports organizational accountability and resource planning.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineCode rdf:type rdf:Property ;
    rdfs:label 'Pipeline Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the pipeline (e.g., \'NGS-ALIGN-BWA-001\', \'VC-GATK-WGS-002\'). Used in SOPs, regulatory submissions, and cross-system references.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineDescription rdf:type rdf:Property ;
    rdfs:label 'Pipeline Description' ;
    rdfs:comment 'Free-text narrative description of the pipeline\'s purpose, methodology, and key capabilities. Provides context for bioinformaticians, clinical scientists, and regulatory reviewers who need to understand the pipeline\'s function without reading the source code.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineName rdf:type rdf:Property ;
    rdfs:label 'Pipeline Name' ;
    rdfs:comment 'Human-readable name of the bioinformatics pipeline (e.g., \'BWA-MEM Alignment Pipeline\', \'GATK Variant Calling Pipeline\', \'VEP Annotation Pipeline\'). Used in reporting, dashboards, and user interfaces.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline definition (draft, active, deprecated, retired, under_validation). Controls whether the pipeline is available for production runs. Active pipelines are cleared for use; deprecated/retired pipelines are preserved for historical traceability.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineType rdf:type rdf:Property ;
    rdfs:label 'Pipeline Type' ;
    rdfs:comment 'Categorical classification of the pipeline by its primary computational function (e.g., alignment, variant calling, annotation, CNV/SNP analysis, MAF calculation, QC). Drives workflow routing and reporting segmentation. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|snp_analysis|maf_calculation|qc|other — promote to reference product]' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceGenomeAssembly rdf:type rdf:Property ;
    rdfs:label 'Reference Genome Assembly' ;
    rdfs:comment 'Name and version of the reference genome assembly used by this pipeline (e.g., \'GRCh38\', \'GRCh37/hg19\', \'GRCm39\'). Critical for variant calling accuracy, annotation consistency, and regulatory traceability. Links to the Reference Genomics data domain.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which this pipeline version was retired or deprecated and is no longer available for new production runs. Historical runs executed under this version remain traceable. Nullable for active pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snpDetectionSupported rdf:type rdf:Property ;
    rdfs:label 'Snp Detection Supported' ;
    rdfs:comment 'Indicates whether the pipeline includes Single Nucleotide Polymorphism (SNP) detection and genotyping capability. SNP analysis is foundational for population genomics, pharmacogenomics, and GWAS studies.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Document number or identifier of the Standard Operating Procedure (SOP) governing the use and execution of this pipeline (e.g., \'SOP-BIO-0042-v3\'). Required for GxP compliance and CLIA/CAP laboratory accreditation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Source Repository Url' ;
    rdfs:comment 'URL of the version-controlled source code repository for this pipeline (e.g., GitHub, GitLab, Bitbucket repository URL). Enables code traceability, change history review, and CI/CD integration for GxP-compliant software development.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCallingLod rdf:type rdf:Property ;
    rdfs:label 'Variant Calling Lod' ;
    rdfs:comment 'Limit of Detection (LOD) for variant calling expressed as the minimum variant allele frequency (VAF) detectable by this pipeline. Critical for somatic variant calling pipelines and clinical assay validation documentation.' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Semantic version number of the pipeline (e.g., \'1.0.0\', \'2.3.1\'). Tracks iterative changes to algorithms, parameters, or reference genome compatibility. Critical for GxP validation traceability and reproducibility of genomic results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowLanguage rdf:type rdf:Property ;
    rdfs:label 'Workflow Language' ;
    rdfs:comment 'Workflow definition language used to implement the pipeline (e.g., WDL — Workflow Description Language, Nextflow, Snakemake, CWL — Common Workflow Language). Determines tooling requirements for execution and portability. [ENUM-REF-CANDIDATE: WDL|Nextflow|Snakemake|CWL|Bash|Python|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineQcMetricId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Qc Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each pipeline QC metric record generated during genomic data processing. Primary key for this entity.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPipelineEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pipeline Employee Id' ;
    rdfs:comment 'Reference to the bioinformatics analyst or system account that initiated or reviewed the pipeline run generating this QC metric. Supports GxP audit trail and accountability requirements.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:qualityIssueId rdf:type rdf:Property ;
    rdfs:label 'Quality Issue Id' ;
    rdfs:comment 'Foreign key linking to data.quality_issue. Business justification: Failed QC metrics (low coverage, high duplicate rate) generate quality issues requiring data steward investigation, root cause analysis, and remediation. Links QC failures to formal issue tracking sys' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityIssue .

ind:qualityRuleId rdf:type rdf:Property ;
    rdfs:label 'Quality Rule Id' ;
    rdfs:comment 'Foreign key linking to data.quality_rule. Business justification: Pipeline QC metrics (coverage depth, Q30 rate, mapping rate) are evaluated against predefined quality rules with thresholds for pass/fail determination. Links QC metric evaluations to formal quality r' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityRule .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the QA/QC scientist who reviewed and approved or rejected this QC metric result. Required for GxP-regulated and clinical assay workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:evaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluation Timestamp' ;
    rdfs:comment 'Date and time when this QC metric was evaluated against its threshold. This is the principal business event timestamp for the metric record, used for longitudinal QC trending and SLA compliance tracking.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Structured description of why this metric failed its threshold (e.g., \'mean_coverage below 30x minimum\', \'duplication_rate exceeds 20% threshold\'). Populated only when qc_status is \'fail\' or \'warn\'. Enables systematic failure pattern analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQcGateBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Qc Gate Blocking' ;
    rdfs:comment 'Indicates whether a failure on this metric blocks downstream pipeline progression (True) or is advisory only (False). Critical for automated QC gating decisions in the bioinformatics pipeline.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Functional category grouping the QC metric for reporting and trend analysis. Enables domain-specific QC dashboards (e.g., coverage metrics vs. base quality metrics vs. alignment metrics). [ENUM-REF-CANDIDATE: coverage|base_quality|duplication|alignment|contamination|library_complexity|variant_calling — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricComputationDurationSec rdf:type rdf:Property ;
    rdfs:label 'Metric Computation Duration Sec' ;
    rdfs:comment 'Wall-clock time in seconds taken by the QC tool to compute this metric. Supports HPC/cloud compute resource optimization and pipeline performance benchmarking.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Standardized name of the QC metric being recorded (e.g., mean_coverage, pct_q30_bases, duplication_rate, on_target_rate, uniformity, insert_size_median, gc_bias_score). [ENUM-REF-CANDIDATE: mean_coverage|pct_q30_bases|duplication_rate|on_target_rate|uniformity|insert_size_median|gc_bias_score|chimeric_read_rate|adapter_contamination_rate|phred_score_mean — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricUnit rdf:type rdf:Property ;
    rdfs:label 'Metric Unit' ;
    rdfs:comment 'Unit of measurement for the metric value (e.g., \'x\' for coverage depth, \'%\' for percentage-based metrics, \'bp\' for base-pair measurements, \'reads\' for read counts). Enables correct interpretation and cross-metric comparison.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricValue rdf:type rdf:Property ;
    rdfs:label 'Metric Value' ;
    rdfs:comment 'Numeric value of the QC metric as computed by the QC tool for this pipeline step and sample. This is the principal quantitative observation (e.g., 45.3 for mean_coverage, 0.92 for pct_q30_bases).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold' ;
    rdfs:comment 'Minimum (or maximum, per threshold_direction) acceptable value for this metric to be considered passing. Defines the QC gate boundary used for automated pass/fail evaluation.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcToolName rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Name' ;
    rdfs:comment 'Name of the bioinformatics QC tool that computed this metric (e.g., FastQC, Picard, MultiQC, Samtools). Enables tool-specific metric interpretation and version-controlled reproducibility tracking. [ENUM-REF-CANDIDATE: FastQC|Picard|MultiQC|GATK|Trimmomatic|Samtools|Qualimap|Fastp|Mosdepth|VerifyBamID — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcToolVersion rdf:type rdf:Property ;
    rdfs:label 'Qc Tool Version' ;
    rdfs:comment 'Version string of the QC tool used to compute this metric (e.g., \'0.11.9\' for FastQC, \'2.27.5\' for Picard). Essential for reproducibility, audit trails, and identifying metric drift caused by tool upgrades.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryUseClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Use Classification' ;
    rdfs:comment 'Regulatory classification of the assay context in which this QC metric was generated (IVD, RUO, LDT, clinical trial, research). Determines applicable QC standards and regulatory reporting obligations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Documented corrective or remediation action taken or recommended in response to a QC failure (e.g., \'re-sequence sample\', \'increase library input\', \'repeat library preparation\'). Supports CAPA workflows and GxP compliance.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of the remediation workflow for a failed QC metric. \'not_required\' for passing metrics; \'pending\', \'in_progress\', \'resolved\', or \'escalated\' for failing metrics requiring corrective action.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Formal outcome of the QA/QC reviewer\'s assessment of this metric result. \'waived\' indicates a documented exception approval for a failing metric. Required for GxP and clinical laboratory compliance.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when a QA/QC reviewer formally reviewed this metric result. Supports GxP electronic record requirements and TAT (Turnaround Time) tracking for clinical workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceFilePath rdf:type rdf:Property ;
    rdfs:label 'Source File Path' ;
    rdfs:comment 'File system or object storage path to the QC tool output file (e.g., FastQC HTML report, Picard metrics file, MultiQC JSON) from which this metric was extracted. Supports data lineage and audit traceability.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRegionBedFile rdf:type rdf:Property ;
    rdfs:label 'Target Region Bed File' ;
    rdfs:comment 'File path or identifier of the BED file defining the genomic target regions used for on-target rate and coverage uniformity calculations. Applicable for WES and targeted panel assays.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Indicates whether the pass_threshold is a minimum bound (metric must be >= threshold), maximum bound (metric must be <= threshold), or a range (metric must fall within defined bounds). Required for correct automated QC gating logic.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLowerBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Lower Bound' ;
    rdfs:comment 'Lower boundary of an acceptable range for this metric when threshold_direction is \'range\'. Null when threshold_direction is \'min\' or \'max\'.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdUpperBound rdf:type rdf:Property ;
    rdfs:label 'Threshold Upper Bound' ;
    rdfs:comment 'Upper boundary of an acceptable range for this metric when threshold_direction is \'range\'. Null when threshold_direction is \'min\' or \'max\'.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdVersion rdf:type rdf:Property ;
    rdfs:label 'Threshold Version' ;
    rdfs:comment 'Version identifier of the QC threshold specification applied during evaluation (e.g., \'v1.2.0\'). Enables audit traceability when thresholds are updated over time and supports longitudinal comparability of QC results.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented scientific or clinical justification for waiving a QC failure and allowing downstream processing to proceed. Populated only when review_outcome is \'waived\'. Required for regulatory audit trails.' ;
    rdfs:domain ind:PipelineQcMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to instrument.instrument_asset. Business justification: Track which physical sequencer generated analyzed data. Critical for instrument-specific bias correction algorithms, troubleshooting systematic quality issues, regulatory audit trails, and correlating' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to quality.audit. Business justification: Regulatory audits (FDA, CAP, CLIA) review specific pipeline runs for GxP compliance, data integrity, electronic signature adherence, and audit trail completeness. Auditors sample pipeline runs to veri' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:batchId rdf:type rdf:Property ;
    rdfs:label 'Batch Id' ;
    rdfs:comment 'Reference to the batch grouping under which this pipeline run was submitted. Supports cohort-level monitoring, batch-level result delivery, and aggregate SLA reporting across multiple samples processed together.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Batch .

ind:catalogId rdf:type rdf:Property ;
    rdfs:label 'Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Pipeline runs consume specific sequencing reagents (library prep kits, flow cell reagents). Critical for QC root cause analysis when variant calling failures correlate to reagent lot quality issues. R' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:fieldApplicationActivityId rdf:type rdf:Property ;
    rdfs:label 'Field Application Activity Id' ;
    rdfs:comment 'Foreign key linking to commercial.field_application_activity. Business justification: Field Application Scientists execute pipeline runs on-site during customer engagements to demonstrate capabilities, troubleshoot customer protocols, or support method development. FAS activity reports' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldApplicationActivity .

ind:installedInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Installed Instrument Id' ;
    rdfs:comment 'Foreign key linking to customer.installed_instrument. Business justification: Sequencing runs executed on customer-installed instruments (at customer sites or in service labs) must be tracked to the specific instrument for utilization analytics, warranty/service contract valida' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InstalledInstrument .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Extends reagent traceability to lot level. Clinical genomics labs must document exact reagent lot used in each sequencing run for CLIA compliance and FDA submissions. Enables batch-level investigation' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Pipeline runs consume specific reagents, kits, and consumables (library prep kits, sequencing reagents, capture panels) tracked as materials. Essential for inventory management, cost allocation per ru' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:pipelineVersionId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version Id' ;
    rdfs:comment 'Reference to the specific versioned bioinformatics pipeline definition (e.g., alignment, variant calling, annotation, CNV/SNP analysis) that was executed in this run. Enables reproducibility audits and version-controlled result comparison.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineVersion .

ind:cloudJobReference rdf:type rdf:Property ;
    rdfs:label 'Cloud Job Reference' ;
    rdfs:comment 'The native job identifier assigned by the compute platform (e.g., AWS Batch Job ID, HPC SLURM Job ID) for this pipeline execution. Used for cross-referencing with infrastructure cost billing records and compute platform logs.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The date and time when the pipeline run reached a terminal state (completed, failed, or cancelled). Used to calculate wall-clock duration, TAT (Turnaround Time), and SLA compliance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cpuCoreHours rdf:type rdf:Property ;
    rdfs:label 'Cpu Core Hours' ;
    rdfs:comment 'Total CPU core-hours consumed by this pipeline run across all compute nodes. Primary metric for cloud/HPC cost attribution, capacity planning, and per-sample computational cost reporting.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCategory rdf:type rdf:Property ;
    rdfs:label 'Error Category' ;
    rdfs:comment 'Standardized classification of the failure type when a pipeline run does not complete successfully. Enables systematic failure triage, root cause analysis, and trend reporting on pipeline reliability.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessageSummary rdf:type rdf:Property ;
    rdfs:label 'Error Message Summary' ;
    rdfs:comment 'Truncated human-readable summary of the error message or exception captured at pipeline failure. Supports first-level failure triage without requiring access to full log files. Maximum 2000 characters.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedComputeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Compute Cost Usd' ;
    rdfs:comment 'Estimated monetary cost in US Dollars for the compute resources consumed by this pipeline run, derived from CPU core-hours, memory, and storage metrics against cloud/HPC pricing. Used for per-sample cost attribution, project budget tracking, and COGS reporting.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputFastqPath rdf:type rdf:Property ;
    rdfs:label 'Input Fastq Path' ;
    rdfs:comment 'Cloud or HPC storage path to the input FASTQ file(s) consumed by this pipeline run. FASTQ is the raw sequencing data format produced by NGS instruments. Required for data lineage tracking, reprocessing, and audit trail from raw data to result.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputBamPath rdf:type rdf:Property ;
    rdfs:label 'Output Bam Path' ;
    rdfs:comment 'Cloud or HPC storage path to the output BAM (Binary Alignment Map) file produced by alignment pipeline runs. BAM is the standard compressed binary format for aligned sequencing reads. Used for downstream variant calling and data lineage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputReportPath rdf:type rdf:Property ;
    rdfs:label 'Output Report Path' ;
    rdfs:comment 'Cloud or HPC storage path to the final analytical report or summary output artifact (e.g., QC report, annotation summary, CNV report) generated by this pipeline run. Used for result delivery to downstream consumers and regulatory documentation.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputVcfPath rdf:type rdf:Property ;
    rdfs:label 'Output Vcf Path' ;
    rdfs:comment 'Cloud or HPC storage path to the output VCF (Variant Call Format) file produced by variant calling pipeline runs. VCF is the standard format for representing SNPs, indels, and structural variants. Central artifact for clinical and research genomic interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Peak Memory Gb' ;
    rdfs:comment 'Maximum RAM (in gigabytes) consumed at any point during this pipeline run. Used for resource right-sizing, out-of-memory failure diagnosis, and HPC/cloud instance type optimization.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentBasesAboveQ30 rdf:type rdf:Property ;
    rdfs:label 'Percent Bases Above Q30' ;
    rdfs:comment 'Percentage of sequencing bases with a Phred quality score of 30 or higher, indicating 99.9% base call accuracy. A primary sequencing QC metric used to assess run quality before downstream analysis. Industry standard threshold is ≥80%.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentReadsMapped rdf:type rdf:Property ;
    rdfs:label 'Percent Reads Mapped' ;
    rdfs:comment 'Percentage of total sequencing reads that successfully aligned to the reference genome. A key alignment QC metric; low mapping rates indicate sample quality issues, contamination, or reference genome mismatch.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reprocessingFlag rdf:type rdf:Property ;
    rdfs:label 'Reprocessing Flag' ;
    rdfs:comment 'Indicates whether this pipeline run is a reprocessing of a previously executed run (e.g., triggered by QC failure, pipeline version upgrade, or parameter correction). When True, data_lineage_run_id should reference the original run.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Run Accession Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to this pipeline execution at submission time. Used for cross-system traceability, SLA tracking, and audit references across LIMS, BaseSpace, and downstream reporting systems.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline execution. Drives operational dashboards, SLA breach alerting, failure triage workflows, and batch-level completion monitoring. Transitions: queued → running → completed | failed | cancelled.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether this pipeline run exceeded its defined SLA target TAT. Populated upon run completion. Drives SLA breach alerting, escalation workflows in ServiceNow, and operational performance reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetTatHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Tat Hours' ;
    rdfs:comment 'The contracted or internally defined SLA target for Turnaround Time (TAT) in hours for this pipeline run, based on assay type and regulatory classification. Used to assess SLA compliance by comparing against actual wall-clock duration.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageConsumedGb rdf:type rdf:Property ;
    rdfs:label 'Storage Consumed Gb' ;
    rdfs:comment 'Total intermediate and output storage consumed by this pipeline run in gigabytes. Includes FASTQ inputs, BAM alignment files, VCF outputs, and annotation artifacts. Used for storage cost attribution and capacity planning.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalReadsCount rdf:type rdf:Property ;
    rdfs:label 'Total Reads Count' ;
    rdfs:comment 'Total number of sequencing reads processed by this pipeline run. Used as a primary input volume metric for QC assessment, cost normalization, and performance benchmarking across pipeline runs.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wallClockDurationSec rdf:type rdf:Property ;
    rdfs:label 'Wall Clock Duration Sec' ;
    rdfs:comment 'Total elapsed real-world time in seconds from pipeline start to completion. Used for performance benchmarking, SLA compliance verification, and identifying pipeline runs that exceed expected execution time thresholds.' ;
    rdfs:domain ind:BioinformaticsPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:computeCostUsd rdf:type rdf:Property ;
    rdfs:label 'Compute Cost Usd' ;
    rdfs:comment 'Estimated or actual cloud/HPC compute cost in US dollars attributed to this step execution, based on instance type, duration, and resource consumption. Supports COGS allocation, R&D cost tracking, and pipeline ROI analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataLineageHash rdf:type rdf:Property ;
    rdfs:label 'Data Lineage Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the step\'s input files, parameters, and tool version, enabling deterministic reproducibility verification and tamper detection for GxP and regulatory audit purposes.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diskIoReadGb rdf:type rdf:Property ;
    rdfs:label 'Disk Io Read Gb' ;
    rdfs:comment 'Total data read from storage in gigabytes during this step\'s execution. Used for storage cost attribution, I/O bottleneck analysis, and pipeline performance optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diskIoWriteGb rdf:type rdf:Property ;
    rdfs:label 'Disk Io Write Gb' ;
    rdfs:comment 'Total data written to storage in gigabytes during this step\'s execution. Used for storage cost attribution, output size estimation, and pipeline performance optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Wall-clock execution time of this pipeline step in seconds, as recorded by the job scheduler. Used for HPC/cloud cost attribution, performance profiling, and pipeline optimization.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputFileFormat rdf:type rdf:Property ;
    rdfs:label 'Input File Format' ;
    rdfs:comment 'Standard genomic file format of the primary input consumed by this step (e.g., FASTQ for raw reads, BAM for aligned reads, VCF for variants). Supports data lineage classification and format validation. [ENUM-REF-CANDIDATE: FASTQ|BAM|CRAM|VCF|GVCF|BED|TSV|FASTA|BCF — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFilePaths rdf:type rdf:Property ;
    rdfs:label 'Input File Paths' ;
    rdfs:comment 'Semicolon-delimited list of input file URIs consumed by this step (e.g., S3 paths to FASTQ, BAM, or VCF files). Enables data lineage tracing from raw sequencing data through each transformation step.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGxpCritical rdf:type rdf:Property ;
    rdfs:label 'Is Gxp Critical' ;
    rdfs:comment 'Indicates whether this step is classified as GxP-critical (True), meaning it falls within the validated computational workflow for clinical or regulatory submissions and requires enhanced audit trail and change control.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logFilePath rdf:type rdf:Property ;
    rdfs:label 'Log File Path' ;
    rdfs:comment 'URI path to the full execution log file for this step (e.g., S3 path to CloudWatch log export or SLURM job log). Enables detailed debugging and GxP audit trail access.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileFormat rdf:type rdf:Property ;
    rdfs:label 'Output File Format' ;
    rdfs:comment 'Standard genomic file format of the primary output produced by this step (e.g., BAM for alignment, VCF/GVCF for variant calling, annotated TSV for annotation steps). Enables format-aware downstream processing. [ENUM-REF-CANDIDATE: BAM|CRAM|VCF|GVCF|BED|TSV|FASTA|BCF|HTML — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFilePaths rdf:type rdf:Property ;
    rdfs:label 'Output File Paths' ;
    rdfs:comment 'Semicolon-delimited list of output file URIs produced by this step (e.g., S3 paths to aligned BAM, called VCF, or annotated TSV files). Supports downstream step input resolution and data lineage documentation.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parametersJson rdf:type rdf:Property ;
    rdfs:label 'Parameters Json' ;
    rdfs:comment 'JSON-serialized string of all command-line parameters and configuration settings applied to the tool during this step execution (e.g., minimum base quality, ploidy, emit-ref-confidence mode). Required for GxP reproducibility and regulatory submission.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMetricsJson rdf:type rdf:Property ;
    rdfs:label 'Qc Metrics Json' ;
    rdfs:comment 'JSON-serialized string of key QC metrics produced by this step (e.g., Phred score distribution, coverage depth, duplication rate, alignment rate, transition/transversion ratio). Enables automated QC gating and quality reporting.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spotInstanceFlag rdf:type rdf:Property ;
    rdfs:label 'Spot Instance Flag' ;
    rdfs:comment 'Indicates whether this step was executed on a cloud spot/preemptible instance (True) or an on-demand instance (False). Spot instances reduce cost but increase retry risk; used for cost-reliability trade-off analysis.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step End Timestamp' ;
    rdfs:comment 'Date and time when this pipeline step completed or terminated execution. Combined with step_start_timestamp to derive step duration for performance benchmarking and TAT reporting.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepExecutionReference rdf:type rdf:Property ;
    rdfs:label 'Step Execution Reference' ;
    rdfs:comment 'Externally-known unique identifier for this step execution as assigned by the HPC/cloud job scheduler (e.g., AWS Batch job ID, SLURM job ID, or Nextflow process hash). Used for cross-referencing with compute infrastructure logs.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepName rdf:type rdf:Property ;
    rdfs:label 'Step Name' ;
    rdfs:comment 'Human-readable name of the pipeline step (e.g., \'BWA-MEM Alignment\', \'GATK HaplotypeCaller\', \'Picard MarkDuplicates\', \'VEP Annotation\', \'Trimmomatic QC\'). Used for display, reporting, and debugging.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepOrder rdf:type rdf:Property ;
    rdfs:label 'Step Order' ;
    rdfs:comment 'Sequential position of this step within the parent pipeline run, defining the execution order and enabling reconstruction of the full data lineage chain from raw FASTQ input to final genomic result.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Start Timestamp' ;
    rdfs:comment 'Date and time when this pipeline step began execution on the compute infrastructure. Used for duration calculation, performance profiling, and TAT (Turnaround Time) analysis.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle state of the pipeline step execution. Drives monitoring dashboards, alerting workflows, and SLA tracking for bioinformatics pipeline operations.' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepType rdf:type rdf:Property ;
    rdfs:label 'Step Type' ;
    rdfs:comment 'Functional classification of the pipeline step indicating the category of genomic processing performed. Enables performance profiling and resource benchmarking by step category. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|qc|trimming|demultiplexing|cnv_analysis|snp_genotyping|library_prep_qc|indexing|phasing|imputation — promote to reference product]' ;
    rdfs:domain ind:PipelineRunStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Validation Study Id' ;
    rdfs:comment 'Unique surrogate identifier for the pipeline validation study record. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete formal analytical validation event with a defined lifecycle (in-progress, passed, failed) tied to regulatory compliance for IVD/LDT pipeline qualification.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the qualified reviewer (e.g., laboratory director, QA manager) who formally approved the validation study report. Required for GxP and CLIA/CAP compliance to demonstrate independent review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cliaAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Clia Accreditation Id' ;
    rdfs:comment 'CLIA certificate number of the laboratory in which the validation study was conducted. Required for LDT validation records to demonstrate the study was performed in a CLIA-certified facility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CliaAccreditation .

ind:primaryPipelineProtocolDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Pipeline Protocol Document Id' ;
    rdfs:comment 'Reference identifier for the formal validation protocol document as registered in Veeva Vault or MasterControl document control system. Provides traceability from the study record to the approved study design document.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:priorStudyPipelineValidationStudyId rdf:type rdf:Property ;
    rdfs:label 'Prior Study Pipeline Validation Study Id' ;
    rdfs:comment 'Reference to the preceding validation study that this study supersedes or extends. Populated when is_revalidation is True. Enables lineage tracing across successive pipeline validation generations.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineValidationStudy .

ind:rdProjectId rdf:type rdf:Property ;
    rdfs:label 'Rd Project Id' ;
    rdfs:comment 'Foreign key linking to research.project. Business justification: Pipeline validation studies are conducted within R&D projects to establish analytical performance (LOD, sensitivity, specificity) before regulatory submission or clinical deployment. Required for IVD ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Project .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Validation studies often qualify specific supplier materials and reagents for use with validated pipelines. Regulatory submissions require supplier identification in validation reports. Change control' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:comment 'Overall accuracy of the pipeline measured as concordance with a reference standard method, expressed as a percentage. Calculated as (TP + TN) / (TP + TN + FP + FN) × 100. Required for CLIA/CAP and FDA IVD qualification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the validation study report was formally reviewed and approved by the designated approver. Marks the transition from completed execution to approved regulatory evidence.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Accreditation Number' ;
    rdfs:comment 'CAP laboratory accreditation number for the facility conducting the validation. CAP accreditation is a recognized alternative to CLIA inspection and is required for many clinical genomics laboratory operations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference number of the CAPA record initiated in response to a failed or on-hold validation study. Links to the quality management system (Veeva Vault QMS) for corrective action tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The date on which the validation study was formally completed and all results were finalized. Null if the study is still in-progress. Required for regulatory submission timelines and CLIA/CAP audit records.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Privacy classification of the genomic data used in the validation study. De-identified: PHI removed per HIPAA Safe Harbor. Pseudonymized: indirect identifiers replaced. Synthetic: computationally generated data. Identifiable: requires IRB approval and full PHI controls.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hpcEnvironment rdf:type rdf:Property ;
    rdfs:label 'Hpc Environment' ;
    rdfs:comment 'Compute environment in which the validation study pipeline runs were executed (e.g., AWS cloud HPC, on-premise HPC cluster, hybrid). Documents the infrastructure context for reproducibility and regulatory traceability.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Number' ;
    rdfs:comment 'IRB protocol approval number when the validation study uses identifiable human genomic samples. Required for studies involving human subjects data to demonstrate ethical oversight compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevalidation rdf:type rdf:Property ;
    rdfs:label 'Is Revalidation' ;
    rdfs:comment 'Indicates whether this study is a revalidation triggered by a pipeline change, algorithm update, or prior validation failure (True), or an initial validation (False). Revalidations require documentation of the change that triggered them.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lodEstablished rdf:type rdf:Property ;
    rdfs:label 'Lod Established' ;
    rdfs:comment 'The analytically established Limit of Detection (LOD) for the pipeline, expressed as variant allele frequency (VAF) or copies per milliliter depending on assay type. Represents the lowest detectable signal with 95% confidence. Core regulatory performance claim for IVD/LDT qualification.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lodUnit rdf:type rdf:Property ;
    rdfs:label 'Lod Unit' ;
    rdfs:comment 'Unit of measure for the established LOD value (e.g., VAF — Variant Allele Frequency as a decimal, copies per mL for ctDNA, percent for mosaic variants). Required to correctly interpret the lod_established value.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCoverageDepth rdf:type rdf:Property ;
    rdfs:label 'Minimum Coverage Depth' ;
    rdfs:comment 'Minimum sequencing coverage depth (read depth, expressed as ×) required and validated for the pipeline to meet performance specifications (e.g., 100× for somatic variant calling). Defines the analytical boundary conditions of the validated pipeline.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPhredScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Phred Score' ;
    rdfs:comment 'Minimum base quality Phred score threshold applied during the validation study (e.g., Q20, Q30). Defines the quality filtering boundary conditions under which the pipeline performance metrics were established.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineVersionTag rdf:type rdf:Property ;
    rdfs:label 'Pipeline Version Tag' ;
    rdfs:comment 'Semantic version label of the bioinformatics pipeline validated (e.g., v3.2.1, v4.0.0-rc1). Captured directly on this record to preserve the validated version string even if the pipeline registry is updated.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionCvPercent rdf:type rdf:Property ;
    rdfs:label 'Precision Cv Percent' ;
    rdfs:comment 'Coefficient of Variation (CV%) measuring pipeline precision (reproducibility of quantitative outputs) across replicate runs. Lower CV indicates higher precision. Applicable for quantitative assays such as CNV ratio or VAF estimation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the study protocol document used to execute this validation (e.g., v1.0, v2.3). Captured to ensure the executed study is traceable to the exact approved protocol version, supporting GxP compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceStandard rdf:type rdf:Property ;
    rdfs:label 'Reference Standard' ;
    rdfs:comment 'Name or identifier of the reference standard, truth set, or orthogonal method used to establish ground truth for the validation (e.g., NIST Genome in a Bottle NA12878, Sanger sequencing, ddPCR, Platinum Genomes). Required for accuracy and concordance claims.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ref' ;
    rdfs:comment 'External regulatory submission identifier associated with this validation study (e.g., FDA 510(k) number K231234, PMA number P200001, CE-IVD Technical File reference, EMA EPAR reference). Links the validation evidence to the formal regulatory dossier.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory submission pathway for which this validation study provides supporting evidence. 510(k): FDA premarket notification. PMA: FDA premarket approval. De Novo: FDA novel device classification. CE-IVD: EU conformity assessment. EUA: Emergency Use Authorization. IVDR: EU In Vitro Diagnostic Regulation 2017/746. [ENUM-REF-CANDIDATE: 510k|PMA|De_Novo|CE-IVD|EUA|IVDR|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityPercent rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Percent' ;
    rdfs:comment 'Measured analytical sensitivity (true positive rate) of the pipeline expressed as a percentage (0–100). Calculated as TP / (TP + FN) × 100 across the validation sample set. Key regulatory performance metric for IVD/LDT claims.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificityPercent rdf:type rdf:Property ;
    rdfs:label 'Specificity Percent' ;
    rdfs:comment 'Measured analytical specificity (true negative rate) of the pipeline expressed as a percentage (0–100). Calculated as TN / (TN + FP) × 100 across the validation sample set. Key regulatory performance metric for IVD/LDT claims.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'Descriptive human-readable name of the validation study (e.g., \'SNV/Indel Analytical Sensitivity Validation — TumorScan v3.2\'). Used in reports, regulatory submissions, and internal tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyNumber rdf:type rdf:Property ;
    rdfs:label 'Study Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the validation study (e.g., PVS-2024-0042). Used in regulatory submissions, SOPs, and cross-functional communications. Sourced from Veeva Vault document control numbering convention.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'The date on which formal execution of the validation study commenced (first sample or dataset processed per the study protocol). Distinct from the protocol authoring date.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current lifecycle state of the validation study. Draft: study protocol authored but not initiated. In-progress: active execution. Passed: all acceptance criteria met. Failed: one or more criteria not met. On-hold: execution paused. Cancelled: study terminated without completion.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationType rdf:type rdf:Property ;
    rdfs:label 'Validation Type' ;
    rdfs:comment 'Category of analytical validation being performed. Analytical sensitivity measures LOD; analytical specificity measures cross-reactivity; reproducibility measures inter-run/inter-site consistency; accuracy measures concordance with reference method; precision measures intra-run variability; interference measures matrix effects. [ENUM-REF-CANDIDATE: analytical_sensitivity|analytical_specificity|reproducibility|accuracy|precision|interference|repeatability|comparability — promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantTypesEvaluated rdf:type rdf:Property ;
    rdfs:label 'Variant Types Evaluated' ;
    rdfs:comment 'Comma-separated list of genomic variant classes evaluated in this validation study (e.g., SNP, Indel, CNV, SV, fusion). Defines the analytical scope of the validation and maps to regulatory performance claims.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultStudyReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Study Reference' ;
    rdfs:comment 'System identifier for the validation study record as registered in Veeva Vault Quality Management System. Enables direct cross-system traceability between the analytics lakehouse record and the regulated document management system.' ;
    rdfs:domain ind:PipelineValidationStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlId rdf:type rdf:Property ;
    rdfs:label 'Change Control Id' ;
    rdfs:comment 'Reference identifier of the formal change control record in MasterControl or Veeva Vault that authorized the creation or modification of this pipeline version (e.g., \'CC-2024-00456\'). Mandatory for GxP-controlled pipelines to maintain a complete audit trail of version changes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeControl .

ind:geneAnnotationTrackId rdf:type rdf:Property ;
    rdfs:label 'Gene Annotation Track Id' ;
    rdfs:comment 'Foreign key linking to reference.gene_annotation_track. Business justification: Pipeline versions must specify which annotation track version (GENCODE, RefSeq, Ensembl) for reproducibility, regulatory validation documentation, reanalysis consistency, and GxP-controlled pipeline q' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneAnnotationTrack .

ind:predecessorVersionPipelineVersionId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Version Pipeline Version Id' ;
    rdfs:comment 'Reference to the pipeline_version_id of the immediately preceding version of this pipeline. Enables traversal of the full version lineage chain from the earliest to the current version, supporting data lineage tracking and regulatory audit trails.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineVersion .

ind:validatedReagentCatalogId rdf:type rdf:Property ;
    rdfs:label 'Validated Reagent Catalog Id' ;
    rdfs:comment 'Foreign key linking to reagent.reagent_catalog. Business justification: Pipeline validation studies qualify specific reagent SKUs (e.g., "validated with Illumina TruSeq DNA PCR-Free kit catalog #20015963"). Change control process requires revalidation when reagent formula' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Catalog .

ind:validationDocumentId rdf:type rdf:Property ;
    rdfs:label 'Validation Document Id' ;
    rdfs:comment 'Reference identifier of the formal validation report or protocol document stored in Veeva Vault (e.g., \'VV-VAL-2024-00123\'). Links this pipeline version to its regulatory validation evidence package for audit and regulatory submission purposes.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:algorithmConfigJson rdf:type rdf:Property ;
    rdfs:label 'Algorithm Config Json' ;
    rdfs:comment 'JSON-serialized configuration document capturing all algorithm parameter definitions for this pipeline version, including parameter name, data type, default value, allowed range, and GxP-controlled flag for each parameter (e.g., minimum Phred Score threshold, minimum coverage depth, MAF cutoff, LOD threshold). Stored as a STRING to avoid complex types per schema rules. Enables full parameter reproducibility and change-control auditing.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Timestamp when this pipeline version received formal approval for production use. Distinct from validation_date (which records scientific validation completion) — this records the organizational authorization event. Required for GxP electronic signature audit trail.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the authorized signatory (e.g., Head of Bioinformatics, Quality Assurance Manager) who formally approved this pipeline version for production use. Required for GxP electronic signature compliance under 21 CFR Part 11.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchlingEntryReference rdf:type rdf:Property ;
    rdfs:label 'Benchling Entry Reference' ;
    rdfs:comment 'Reference identifier of the Benchling R&D Notebook entry documenting the scientific design, development rationale, and experimental validation data for this pipeline version. Provides traceability from the computational pipeline back to the laboratory science.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changelogSummary rdf:type rdf:Property ;
    rdfs:label 'Changelog Summary' ;
    rdfs:comment 'Human-readable summary of changes introduced in this pipeline version compared to the immediately preceding version. Documents algorithm updates, parameter changes, bug fixes, new assay support, or reference genome updates. Essential for regulatory submissions and scientific reproducibility.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImageDigest rdf:type rdf:Property ;
    rdfs:label 'Container Image Digest' ;
    rdfs:comment 'Cryptographic SHA-256 digest of the container image, providing immutable integrity verification of the pipeline\'s computational environment. Ensures that the exact same software stack is used across all runs referencing this version, supporting GxP audit trail requirements.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerImageUri rdf:type rdf:Property ;
    rdfs:label 'Container Image Uri' ;
    rdfs:comment 'Fully-qualified URI of the Docker or Singularity container image encapsulating this pipeline version\'s runtime environment (e.g., \'registry.genomicsbiotech.com/pipelines/wgs-gvc:3.2.1\'). Ensures computational reproducibility by pinning all software dependencies. Required for GxP-compliant pipeline execution.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this pipeline version is approved and authorized for production use. Defines the start of the version\'s active period in the pipeline lifecycle. Required for regulatory traceability and change control documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this pipeline version\'s authorization expires or is superseded. Null indicates the version remains active with no planned end date. Used for lifecycle management, regulatory compliance, and preventing use of expired pipeline versions in clinical workflows.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gitCommitHash rdf:type rdf:Property ;
    rdfs:label 'Git Commit Hash' ;
    rdfs:comment 'Full 40-character SHA-1 Git commit hash uniquely identifying the exact source code state for this pipeline version. Provides immutable, cryptographically verifiable traceability to the precise codebase used, supporting GxP audit trail and reproducibility requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gxpControlled rdf:type rdf:Property ;
    rdfs:label 'Gxp Controlled' ;
    rdfs:comment 'Indicates whether this pipeline version is subject to Good Practice (GxP) regulations (GMP, GLP, GCP), requiring formal change control, validation documentation, and audit trail maintenance. True = GxP-controlled pipeline requiring full validation lifecycle; False = non-GxP pipeline (e.g., exploratory R&D).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hpcComputeProfile rdf:type rdf:Property ;
    rdfs:label 'Hpc Compute Profile' ;
    rdfs:comment 'Designated High-Performance Computing (HPC) or cloud compute execution profile for this pipeline version. Specifies the orchestration environment: AWS Batch, AWS EC2, HPC SLURM cluster, HPC LSF cluster, local execution, or hybrid. Drives resource allocation and job scheduling configurations.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDeprecated rdf:type rdf:Property ;
    rdfs:label 'Is Deprecated' ;
    rdfs:comment 'Boolean flag indicating whether this pipeline version has been formally deprecated and superseded by a newer version. True = deprecated (new pipeline runs should not use this version); False = not deprecated. Distinct from \'retired\' status — deprecated versions may still be used for legacy run reproduction.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this pipeline version record. Required for change control auditing and data lineage tracking in GxP-regulated environments. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lodSensitivity rdf:type rdf:Property ;
    rdfs:label 'Lod Sensitivity' ;
    rdfs:comment 'Analytical Limit of Detection (LOD) expressed as the minimum variant allele fraction detectable by this pipeline version at a defined confidence level. A key analytical performance characteristic for clinical and IVD-validated pipelines, reported in regulatory submissions and validation documentation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCpuCores rdf:type rdf:Property ;
    rdfs:label 'Min Cpu Cores' ;
    rdfs:comment 'Minimum number of CPU cores required to execute this pipeline version. Used for compute resource planning, job scheduling, and cost estimation on HPC/AWS infrastructure.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minMemoryGb rdf:type rdf:Property ;
    rdfs:label 'Min Memory Gb' ;
    rdfs:comment 'Minimum RAM in gigabytes required to execute this pipeline version. Critical for HPC/AWS job scheduling, instance type selection, and preventing out-of-memory failures during large WGS runs.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Primary file format produced as the final output of this pipeline version. VCF = Variant Call Format; BAM = Binary Alignment Map; FASTQ = raw sequence data; CRAM = compressed BAM; GVCF = Genomic VCF for joint genotyping. Determines downstream compatibility with analysis tools and data consumers. [ENUM-REF-CANDIDATE: VCF|BAM|FASTQ|CRAM|BED|TSV|GVCF — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineCategory rdf:type rdf:Property ;
    rdfs:label 'Pipeline Category' ;
    rdfs:comment 'Functional classification of the pipeline by its primary computational purpose. Drives routing logic, validation requirements, and reporting groupings. [ENUM-REF-CANDIDATE: alignment|variant_calling|annotation|cnv_analysis|maf_calculation|array_processing|demultiplexing|other — promote to reference product]' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineOwner rdf:type rdf:Property ;
    rdfs:label 'Pipeline Owner' ;
    rdfs:comment 'Name or employee identifier of the bioinformatics scientist or team lead who is the designated owner and accountable party for this pipeline version. Responsible for validation, change control, and scientific integrity of the pipeline.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionIds rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ids' ;
    rdfs:comment 'Comma-separated list of regulatory submission identifiers (FDA 510(k), PMA, De Novo, EMA IVDR submission numbers) in which this pipeline version is referenced or cited (e.g., \'K240001,DEN230045\'). Enables traceability between pipeline versions and regulatory filings.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:semanticVersion rdf:type rdf:Property ;
    rdfs:label 'Semantic Version' ;
    rdfs:comment 'Semantic versioning string (MAJOR.MINOR.PATCH) for this pipeline release, following SemVer 2.0 conventions (e.g., \'3.2.1\'). MAJOR increments indicate breaking algorithm changes; MINOR indicate new features; PATCH indicate bug fixes. Enables reproducibility tracking from FASTQ to final genomic output.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedAssayTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Assay Types' ;
    rdfs:comment 'Comma-separated list of genomic assay types this pipeline version is designed and validated to process (e.g., \'WGS,WES,targeted_panel\'). Assay types include WGS (Whole Genome Sequencing), WES (Whole Exome Sequencing), targeted panel, array-based, amplicon, RNA-Seq, single-cell. Drives compatibility checks at pipeline run initiation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which formal validation of this pipeline version was completed and documented. Required for IVD, LDT, and GxP-controlled pipelines. Supports regulatory submission timelines and audit readiness.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:variantCallerTool rdf:type rdf:Property ;
    rdfs:label 'Variant Caller Tool' ;
    rdfs:comment 'Name and version of the primary variant calling algorithm/tool used in this pipeline version (e.g., \'GATK HaplotypeCaller 4.4.0\', \'DeepVariant 1.5\', \'Strelka2 2.9.10\'). Directly determines the VCF output format and variant calling characteristics. Essential for reproducibility and regulatory documentation.' ;
    rdfs:domain ind:PipelineVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snpGenotypeResultId rdf:type rdf:Property ;
    rdfs:label 'Snp Genotype Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each SNP genotyping result record in the Silver Layer lakehouse. Primary key for this entity. Entity role: EVENT_LOG — this entity represents an immutable observation/measurement of a genotype call at a specific genomic locus produced by a genotyping pipeline run.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrayHybridizationId rdf:type rdf:Property ;
    rdfs:label 'Array Hybridization Id' ;
    rdfs:comment 'Reference to the instrument or array genotyping run (e.g., Illumina array scan or sequencing flow cell run) that generated the raw signal data from which this SNP call was derived. Distinct from the bioinformatics pipeline run.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArrayHybridization .

ind:glossaryTermId rdf:type rdf:Property ;
    rdfs:label 'Glossary Term Id' ;
    rdfs:comment 'Foreign key linking to data.glossary_term. Business justification: SNP genotype classifications (homozygous, heterozygous), pharmacogenomics phenotypes (poor metabolizer, rapid metabolizer), and functional consequences require controlled terminology for clinical deci' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlossaryTerm .

ind:alleleDepthAlt rdf:type rdf:Property ;
    rdfs:label 'Allele Depth Alt' ;
    rdfs:comment 'Number of sequencing reads supporting the alternate allele at this locus (AD field, ALT component in VCF). Null for array-based genotyping. Used alongside allele_depth_ref to compute allele balance ratio and validate variant calls.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alleleDepthRef rdf:type rdf:Property ;
    rdfs:label 'Allele Depth Ref' ;
    rdfs:comment 'Number of sequencing reads supporting the reference allele at this locus (AD field, REF component in VCF). Null for array-based genotyping. Used to calculate allele balance, detect strand bias, and validate heterozygous calls in sequencing-based workflows.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancestryPanelFlag rdf:type rdf:Property ;
    rdfs:label 'Ancestry Panel Flag' ;
    rdfs:comment 'Indicates whether this SNP is designated as an Ancestry Informative Marker (AIM) in the genotyping panel design. True if the SNP is used for population stratification, ancestry inference, or admixture analysis. Supports agricultural genomics breed identification and human ancestry product workflows.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assayUseClassification rdf:type rdf:Property ;
    rdfs:label 'Assay Use Classification' ;
    rdfs:comment 'Regulatory use classification of the genotyping assay that produced this result: IVD (In Vitro Diagnostic — cleared/approved for clinical use), RUO (Research Use Only — not for clinical diagnosis), LDT (Laboratory Developed Test — validated in-house), or research (internal R&D use). Governs data handling, reporting obligations, and regulatory submission requirements.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callRate rdf:type rdf:Property ;
    rdfs:label 'Call Rate' ;
    rdfs:comment 'Proportion of samples (or loci, depending on context) for which a confident genotype call was made at this SNP position, expressed as a decimal between 0 and 1. A key Quality Control (QC) metric for array-based genotyping; loci with call rate below threshold (e.g., <0.95) are typically excluded from downstream analysis.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:callTimestamp rdf:type rdf:Property ;
    rdfs:label 'Call Timestamp' ;
    rdfs:comment 'The date and time when the genotype call was computationally generated by the bioinformatics pipeline. Represents the principal business event timestamp for this result record. Stored in ISO 8601 format with timezone offset. Used for data lineage, audit trails, and TAT (Turnaround Time) calculations.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverageDepth rdf:type rdf:Property ;
    rdfs:label 'Coverage Depth' ;
    rdfs:comment 'The number of sequencing reads covering this SNP locus (read depth / coverage depth) for sequencing-based genotyping. Null for array-based genotyping. A key QC metric; loci with coverage below threshold (e.g., <10x) may yield unreliable genotype calls. Used in WGS and WES workflows.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseRestriction rdf:type rdf:Property ;
    rdfs:label 'Data Use Restriction' ;
    rdfs:comment 'The data use restriction code governing permissible downstream uses of this genomic result, as defined by the GA4GH Data Use Ontology (DUO) and NIH Genomic Data Sharing Policy. Values: GRU (General Research Use), HMB (Health/Medical/Biomedical), DS (Disease-Specific), POA (Population Origins/Ancestry), NRES (No Restrictions), no_restriction. Governs GWAS, pharmacogenomics, and agricultural genomics data sharing compliance.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalConsequence rdf:type rdf:Property ;
    rdfs:label 'Functional Consequence' ;
    rdfs:comment 'Predicted functional consequence of the SNP on gene function as annotated by the variant annotation pipeline (e.g., missense_variant, synonymous_variant, intron_variant, 3_prime_UTR_variant, stop_gained). Uses Sequence Ontology (SO) terms as standardized by Ensembl VEP and ANNOVAR. [ENUM-REF-CANDIDATE: missense_variant|synonymous_variant|intron_variant|3_prime_UTR_variant|stop_gained|splice_region_variant|intergenic_variant|other — promote to reference product]' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genotypeCall rdf:type rdf:Property ;
    rdfs:label 'Genotype Call' ;
    rdfs:comment 'The diploid genotype call at this locus expressed as allele1/allele2 (e.g., A/A, A/G, G/G) using VCF-compatible notation. Represents the observed allelic state of the sample at this SNP position. Null indicates a no-call.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genotypeClass rdf:type rdf:Property ;
    rdfs:label 'Genotype Class' ;
    rdfs:comment 'Categorical classification of the genotype call: homozygous_ref (both alleles match reference), heterozygous (one REF, one ALT allele), homozygous_alt (both alleles are ALT), or no_call (insufficient data for a confident call). Used for GWAS, pharmacogenomics stratification, and ancestry analysis.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genotypePosteriorProbability rdf:type rdf:Property ;
    rdfs:label 'Genotype Posterior Probability' ;
    rdfs:comment 'The posterior probability of the reported genotype call, expressed as a decimal between 0 and 1. Derived from Bayesian genotype likelihood models (e.g., BEAGLE imputation, array intensity clustering). Higher values indicate greater statistical confidence in the call. Used for imputation quality filtering.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genotypeQualityScore rdf:type rdf:Property ;
    rdfs:label 'Genotype Quality Score' ;
    rdfs:comment 'Phred-scaled genotype quality score (GQ) representing the confidence in the genotype call, analogous to the Phred Score used in sequencing. Higher values indicate greater confidence. Typically ranges 0–99 for array-based calls and 0–99+ for sequencing-based calls. Used for call filtering and QC thresholding.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genotypingMethod rdf:type rdf:Property ;
    rdfs:label 'Genotyping Method' ;
    rdfs:comment 'The technology or assay method used to generate this SNP genotype call. Values: array (SNP microarray), wgs (Whole Genome Sequencing), wes (Whole Exome Sequencing), targeted_panel (targeted sequencing panel), qpcr (quantitative PCR-based genotyping), other. Drives downstream analytical workflow selection and QC thresholds.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwasCatalogTrait rdf:type rdf:Property ;
    rdfs:label 'Gwas Catalog Trait' ;
    rdfs:comment 'The disease or phenotypic trait associated with this SNP as catalogued in the NHGRI-EBI GWAS Catalog (e.g., type 2 diabetes, breast cancer, LDL cholesterol). Null if no GWAS association is recorded. Enables phenotype-driven SNP filtering and reporting for research and clinical genomics applications.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haplotypeBlockIdentifier rdf:type rdf:Property ;
    rdfs:label 'Haplotype Block Identifier' ;
    rdfs:comment 'Identifier for the linkage disequilibrium (LD) haplotype block in which this SNP resides, as defined by the reference haplotype panel. Used for haplotype-based pharmacogenomics star allele calling (e.g., CYP2D6, CYP2C19), ancestry inference, and LD-aware GWAS analysis.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardyWeinbergPValue rdf:type rdf:Property ;
    rdfs:label 'Hardy Weinberg P Value' ;
    rdfs:comment 'P-value from the Hardy-Weinberg Equilibrium (HWE) exact test for this SNP locus within the study population. Significant deviation from HWE (e.g., p < 1e-6) may indicate genotyping error, population stratification, or selection pressure. A standard QC metric in GWAS and population genomics workflows.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imputationR2Score rdf:type rdf:Property ;
    rdfs:label 'Imputation R2 Score' ;
    rdfs:comment 'The imputation quality metric (R2 or INFO score) for imputed SNP calls, representing the estimated squared correlation between imputed and true genotypes. Ranges 0–1; values below threshold (e.g., <0.3) indicate poor imputation quality. Null for directly genotyped variants. Standard metric from MINIMAC/BEAGLE imputation tools.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isImputed rdf:type rdf:Property ;
    rdfs:label 'Is Imputed' ;
    rdfs:comment 'Indicates whether this SNP genotype call was statistically imputed (True) rather than directly measured by the assay (False). Imputed calls are inferred from haplotype reference panels (e.g., 1000 Genomes, TOPMed) and carry additional uncertainty. Critical for distinguishing directly genotyped from imputed variants in downstream analyses.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorAlleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Minor Allele Frequency' ;
    rdfs:comment 'The frequency of the less common allele at this SNP locus within the study cohort or population, expressed as a decimal between 0 and 0.5. A critical QC and analytical metric for GWAS, population stratification, and pharmacogenomics studies. SNPs with MAF below threshold (e.g., <0.01) may be excluded from association analyses.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacogenomicsPhenotype rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomics Phenotype' ;
    rdfs:comment 'The pharmacogenomics metabolizer or response phenotype associated with this SNP genotype call (e.g., poor_metabolizer, intermediate_metabolizer, normal_metabolizer, ultrarapid_metabolizer for CYP450 genes). Derived from CPIC or PharmGKB guidelines. Null for non-pharmacogenomics SNPs. Supports precision medicine drug dosing applications.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment '1-based genomic coordinate (base pair position) of the SNP locus on the reference chromosome. Used for positional queries, regional filtering, linkage disequilibrium analysis, and integration with annotation databases such as ClinVar and gnomAD.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:probeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Probe Identifier' ;
    rdfs:comment 'The array probe or bead identifier used to interrogate this SNP locus in array-based genotyping platforms (e.g., Illumina SNP array probe ID). Null for sequencing-based genotyping. Enables traceability to the physical array design, probe performance metrics, and manifest file.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Lifecycle status of this SNP genotype result record: preliminary (initial call pending review), final (reviewed and released), amended (corrected after final release), cancelled (result voided), failed_qc (result failed Quality Control thresholds and is excluded from analysis). Governs data release and downstream consumption eligibility.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Identifier of the scientist, bioinformatician, or clinical laboratory director who reviewed and approved this genotype result. Stored as an employee or user identifier string. Required for GxP electronic signature compliance and CLIA/CAP laboratory director accountability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsNumber rdf:type rdf:Property ;
    rdfs:label 'Rs Number' ;
    rdfs:comment 'NCBI dbSNP reference SNP cluster identifier (rsID) for the variant locus. Provides a globally standardized identifier for the SNP, enabling cross-study comparisons, GWAS catalog lookups, pharmacogenomics database queries, and ancestry panel alignment. Example: rs429358.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'The name of the source data file (e.g., VCF, FASTQ, IDAT, GTC) from which this SNP genotype result was extracted during pipeline processing. Supports data lineage tracing from the Silver Layer record back to the raw data file in the Bronze Layer or instrument output. Examples: sample001.vcf.gz, sample001.idat.' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strand rdf:type rdf:Property ;
    rdfs:label 'Strand' ;
    rdfs:comment 'The DNA strand orientation of the SNP locus relative to the reference genome: forward (+) or reverse (-). Required for correct allele interpretation in array-based genotyping where probe strand orientation affects allele assignment, and for cross-platform harmonization.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantFilterStatus rdf:type rdf:Property ;
    rdfs:label 'Variant Filter Status' ;
    rdfs:comment 'Quality Control (QC) filter status for this SNP genotype result, analogous to the FILTER field in VCF format. PASS indicates the locus passed all QC thresholds. Filtered values indicate the specific QC criterion that failed (low quality score, low call rate, low MAF, Hardy-Weinberg Equilibrium deviation, strand bias). Used to exclude low-quality calls from downstream analyses. [ENUM-REF-CANDIDATE: PASS|filtered_low_quality|filtered_low_call_rate|filtered_low_maf|filtered_hwe|filtered_strand_bias|other — promote to reference product]' ;
    rdfs:domain ind:SnpGenotypeResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAnnotationId rdf:type rdf:Property ;
    rdfs:label 'Variant Annotation Id' ;
    rdfs:comment 'Unique surrogate identifier for each variant annotation record in the Silver Layer lakehouse. Primary key for this data product. Entity role: MASTER_RESOURCE — represents a genomic variant annotation artifact with its own identity, lifecycle, and rich set of interpreted attributes derived from annotation pipelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantAnnotation .

ind:pharmacogenomicsMarkerId rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomics Marker Id' ;
    rdfs:comment 'Foreign key linking to reference.pharmacogenomics_marker. Business justification: Clinical variant interpretation workflows must link identified variants to known PGx markers for automated clinical reporting, drug-gene interaction alerts, FDA/EMA PGx label compliance, and pharmacog' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacogenomicsMarker .

ind:transcriptModelId rdf:type rdf:Property ;
    rdfs:label 'Transcript Model Id' ;
    rdfs:comment 'Ensembl or RefSeq transcript identifier used as the basis for consequence annotation (e.g., ENST00000357654, NM_007294). Specifies which transcript isoform the HGVS notation and consequence type are reported against.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TranscriptModel .

ind:variantDatabaseVersionId rdf:type rdf:Property ;
    rdfs:label 'Variant Database Version Id' ;
    rdfs:comment 'Foreign key linking to reference.variant_database_version. Business justification: Regulatory audit trails and clinical report versioning require tracking which specific ClinVar/dbSNP/gnomAD version was used for each variant classification. Supports reanalysis decisions when databas' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantDatabaseVersion .

ind:acmgClassification rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification' ;
    rdfs:comment 'Variant classification assigned per ACMG/AMP 2015 guidelines for germline variants (Pathogenic, Likely Pathogenic, Variant of Uncertain Significance (VUS), Likely Benign, Benign). The authoritative classification for clinical genetic testing reports and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acmgCriteriaCodes rdf:type rdf:Property ;
    rdfs:label 'Acmg Criteria Codes' ;
    rdfs:comment 'Pipe-delimited list of ACMG/AMP evidence criteria codes applied to support the variant classification (e.g., PVS1|PS3|PM2|PP3). Provides the evidence basis for the classification decision and supports audit and regulatory review.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:altAllele rdf:type rdf:Property ;
    rdfs:label 'Alt Allele' ;
    rdfs:comment 'The alternate (non-reference) base(s) observed at the variant position. Defines the variant allele relative to the reference genome. May include symbolic alleles for structural variants.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationDbVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Db Version' ;
    rdfs:comment 'Version of the annotation database(s) used during annotation (e.g., ClinVar 2024-01, gnomAD v3.1.2, dbSNP b156). Required for regulatory submissions and reproducibility of clinical-grade annotations.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationStatus rdf:type rdf:Property ;
    rdfs:label 'Annotation Status' ;
    rdfs:comment 'Current lifecycle status of the annotation record: pending (awaiting annotation), completed (annotation finalized), failed (annotation pipeline error), review_required (flagged for manual curation), superseded (replaced by a newer annotation run).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Annotation Timestamp' ;
    rdfs:comment 'Timestamp when the annotation pipeline completed and this annotation record was generated. Serves as the principal business event timestamp for the annotation lifecycle. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:annotationTool rdf:type rdf:Property ;
    rdfs:label 'Annotation Tool' ;
    rdfs:comment 'Name of the annotation pipeline tool used to generate this annotation record (VEP=Ensembl Variant Effect Predictor, ANNOVAR, SnpEff). Enables tool-specific interpretation and reproducibility tracking.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationToolVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Tool Version' ;
    rdfs:comment 'Version string of the annotation tool used (e.g., VEP 108.0, ANNOVAR 2023-01-12). Critical for reproducibility, regulatory submissions, and audit trails per GxP and CLIA requirements.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caddPhredScore rdf:type rdf:Property ;
    rdfs:label 'Cadd Phred Score' ;
    rdfs:comment 'Combined Annotation Dependent Depletion (CADD) Phred-scaled score integrating multiple functional annotations to predict variant deleteriousness. Scores ≥20 indicate top 1% most deleterious variants. Used for variant prioritization in research and clinical pipelines.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinvarAccession rdf:type rdf:Property ;
    rdfs:label 'Clinvar Accession' ;
    rdfs:comment 'ClinVar Reference Variant (RCV) accession number uniquely identifying the variant-condition record in the ClinVar database. Enables direct cross-referencing to the authoritative clinical variant database for regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinvarClassification rdf:type rdf:Property ;
    rdfs:label 'Clinvar Classification' ;
    rdfs:comment 'Clinical significance classification of the variant as curated in the NCBI ClinVar database (Pathogenic, Likely Pathogenic, Uncertain Significance (VUS), Likely Benign, Benign). Central to clinical reporting and IVD/LDT assay interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consequenceType rdf:type rdf:Property ;
    rdfs:label 'Consequence Type' ;
    rdfs:comment 'Sequence Ontology (SO) term describing the predicted molecular consequence of the variant on the transcript (e.g., missense_variant, frameshift_variant, stop_gained, splice_site_variant). Primary driver of clinical significance classification. [ENUM-REF-CANDIDATE: missense_variant|frameshift_variant|stop_gained|stop_lost|splice_donor_variant|splice_acceptor_variant|splice_site_variant|synonymous_variant|intron_variant|5_prime_UTR_variant|3_prime_UTR_variant|upstream_gene_variant|downstream_gene_variant|intergenic_variant — promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cosmicAccession rdf:type rdf:Property ;
    rdfs:label 'Cosmic Accession' ;
    rdfs:comment 'Catalogue of Somatic Mutations in Cancer (COSMIC) identifier for the variant (e.g., COSM476). Relevant for oncology applications, somatic variant interpretation, and OncoKB tier assignment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbsnpAccession rdf:type rdf:Property ;
    rdfs:label 'Dbsnp Accession' ;
    rdfs:comment 'NCBI dbSNP reference SNP identifier (rsID) for the variant (e.g., rs80357906). Standard cross-reference identifier used in clinical reports, publications, and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exonNumber rdf:type rdf:Property ;
    rdfs:label 'Exon Number' ;
    rdfs:comment 'Exon number within the canonical transcript where the variant is located (e.g., \'14/23\' indicating exon 14 of 23). Reported as a string to accommodate fractional or range notation. Used in clinical reports and splice-site analysis.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneSymbol rdf:type rdf:Property ;
    rdfs:label 'Gene Symbol' ;
    rdfs:comment 'Official HGNC (HUGO Gene Nomenclature Committee) gene symbol for the gene in which the variant is located (e.g., BRCA1, TP53, EGFR). Primary human-readable identifier for gene-level reporting and clinical interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gnomadMaf rdf:type rdf:Property ;
    rdfs:label 'Gnomad Maf' ;
    rdfs:comment 'Minor Allele Frequency (MAF) of the variant in the Genome Aggregation Database (gnomAD) global population. Used to assess variant rarity and support pathogenicity classification per ACMG/AMP criteria (BA1, BS1, PM2).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gnomadPopulation rdf:type rdf:Property ;
    rdfs:label 'Gnomad Population' ;
    rdfs:comment 'gnomAD population subgroup for which the MAF is reported (e.g., AFR=African, AMR=Latino/Admixed American, EAS=East Asian, NFE=Non-Finnish European). Required for population-stratified allele frequency interpretation. [ENUM-REF-CANDIDATE: AFR|AMR|ASJ|EAS|FIN|NFE|OTH|SAS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hgvsCoding rdf:type rdf:Property ;
    rdfs:label 'Hgvs Coding' ;
    rdfs:comment 'Human Genome Variation Society (HGVS) notation describing the variant at the coding DNA sequence level (e.g., NM_007294.4:c.5266dupC). Standard notation for clinical reporting, regulatory submissions, and variant database submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hgvsProtein rdf:type rdf:Property ;
    rdfs:label 'Hgvs Protein' ;
    rdfs:comment 'HGVS notation describing the predicted amino acid change at the protein level (e.g., NP_009225.1:p.Gln1756Profs). Required for clinical variant reporting and interpretation of functional impact.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Predicted functional impact severity of the variant as classified by the annotation tool (HIGH, MODERATE, LOW, MODIFIER per SnpEff/VEP convention). Used for variant prioritization in clinical and research workflows.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intronNumber rdf:type rdf:Property ;
    rdfs:label 'Intron Number' ;
    rdfs:comment 'Intron number within the canonical transcript where the variant is located (e.g., \'5/22\'). Populated for intronic and splice-site variants. Used in clinical reports and splicing impact assessment.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCanonicalTranscript rdf:type rdf:Property ;
    rdfs:label 'Is Canonical Transcript' ;
    rdfs:comment 'Indicates whether this annotation record is based on the canonical (primary) transcript for the gene as defined by Ensembl or MANE Select. Canonical transcript annotations are used for primary clinical reporting; non-canonical records are retained for completeness.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSomatic rdf:type rdf:Property ;
    rdfs:label 'Is Somatic' ;
    rdfs:comment 'Indicates whether the variant is classified as somatic (True) or germline (False). Drives routing to oncology vs. hereditary disease interpretation workflows, and determines applicable regulatory and reporting frameworks.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oncokbMutationEffect rdf:type rdf:Property ;
    rdfs:label 'Oncokb Mutation Effect' ;
    rdfs:comment 'OncoKB-curated functional effect of the somatic mutation on the gene product (Gain-of-function, Loss-of-function, Neutral, Switch-of-function, Unknown). Supports oncology biomarker reporting and therapeutic decision support.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oncokbTier rdf:type rdf:Property ;
    rdfs:label 'Oncokb Tier' ;
    rdfs:comment 'OncoKB evidence-based therapeutic actionability tier for the somatic variant (Level 1=FDA-approved biomarker, Level 2=Standard care, Level 3A/3B=Investigational, Level 4=Biological evidence, R1/R2=Resistance). Critical for oncology precision medicine and clinical trial matching. [ENUM-REF-CANDIDATE: 1|2|3A|3B|4|R1|R2 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyphen2Prediction rdf:type rdf:Property ;
    rdfs:label 'Polyphen2 Prediction' ;
    rdfs:comment 'Categorical PolyPhen-2 prediction for the amino acid substitution (probably damaging, possibly damaging, benign, unknown). Provides human-readable interpretation of the PolyPhen-2 score for clinical reporting.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:polyphen2Score rdf:type rdf:Property ;
    rdfs:label 'Polyphen2 Score' ;
    rdfs:comment 'Polymorphism Phenotyping v2 (PolyPhen-2) score predicting the impact of an amino acid substitution on protein structure and function (0=benign, 1=probably damaging). Used as evidence for ACMG/AMP pathogenicity criteria (PP3, BP4).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refAllele rdf:type rdf:Property ;
    rdfs:label 'Ref Allele' ;
    rdfs:comment 'The reference base(s) at the variant position as defined in the reference genome assembly. Used in conjunction with alt_allele to fully characterize the variant.' ;
    rdfs:domain ind:Bioinformatics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Level of expert review applied to the variant classification (e.g., not_reviewed, single_submitter, expert_panel, practice_guideline). Mirrors ClinVar review status levels and indicates confidence in the reported classification for clinical use.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siftPrediction rdf:type rdf:Property ;
    rdfs:label 'Sift Prediction' ;
    rdfs:comment 'Categorical SIFT prediction for the amino acid substitution (deleterious or tolerated, with confidence qualifier). Provides human-readable interpretation of the SIFT score for clinical reporting.' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siftScore rdf:type rdf:Property ;
    rdfs:label 'Sift Score' ;
    rdfs:comment 'Sorting Intolerant From Tolerant (SIFT) score predicting whether an amino acid substitution affects protein function (0=deleterious, 1=tolerated). Used as evidence for ACMG/AMP pathogenicity criteria (PP3, BP4).' ;
    rdfs:domain ind:VariantAnnotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorResultVariantCallResultId rdf:type rdf:Property ;
    rdfs:label 'Prior Result Variant Call Result Id' ;
    rdfs:comment 'Reference to the previous variant call result record that this result supersedes or is a reanalysis of. Enables data lineage chain tracking from original to reanalyzed results. Null for original (non-reanalysis) results.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantCallResult .

ind:arrayProbeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Array Probe Identifier' ;
    rdfs:comment 'Unique identifier of the array probe used to genotype this locus (applicable to array-based SNP genotyping only, e.g., Illumina Infinium probe ID). Null for NGS-based variant calls. Enables probe-level QC and array manifest cross-referencing.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callMethod rdf:type rdf:Property ;
    rdfs:label 'Call Method' ;
    rdfs:comment 'Discriminator indicating the technology and analytical approach used to generate this result: NGS variant calling (WGS/WES), array-based SNP genotyping, targeted panel sequencing, or targeted genotyping. Drives downstream interpretation logic and QC thresholds.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callerToolName rdf:type rdf:Property ;
    rdfs:label 'Caller Tool Name' ;
    rdfs:comment 'Name of the variant calling or genotyping software tool used (e.g., GATK HaplotypeCaller, DeepVariant, Strelka2, GenomeStudio, Illumina DRAGEN). Essential for reproducibility, audit, and regulatory submission documentation.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callerToolVersion rdf:type rdf:Property ;
    rdfs:label 'Caller Tool Version' ;
    rdfs:comment 'Software version of the variant calling or genotyping tool (e.g., 4.2.6.1 for GATK). Required for regulatory submissions, audit trails, and ensuring reproducibility of results across pipeline versions.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cnvCount rdf:type rdf:Property ;
    rdfs:label 'Cnv Count' ;
    rdfs:comment 'Number of copy number variation (CNV) events detected in this result. Applicable to WGS, WES, and array-based CNV analysis workflows. Null for targeted SNP-only panels.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dbsnpConcordanceRate rdf:type rdf:Property ;
    rdfs:label 'Dbsnp Concordance Rate' ;
    rdfs:comment 'Proportion of called variants that are present in the dbSNP database (range 0.0000–1.0000). A QC benchmark for variant calling accuracy; high concordance (>0.95 for WGS) indicates reliable calling performance.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterCriteriaApplied rdf:type rdf:Property ;
    rdfs:label 'Filter Criteria Applied' ;
    rdfs:comment 'Description or identifier of the variant filtering criteria applied to this call set (e.g., VQSR, hard-filter thresholds, panel-specific filters). Documents the post-calling filtering logic for audit, reproducibility, and regulatory submission.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indelCount rdf:type rdf:Property ;
    rdfs:label 'Indel Count' ;
    rdfs:comment 'Number of small insertion and deletion (INDEL) variants called in this result. INDELs are a distinct variant class from SNPs and require separate QC thresholds and clinical interpretation rules.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClinicalReportable rdf:type rdf:Property ;
    rdfs:label 'Is Clinical Reportable' ;
    rdfs:comment 'Indicates whether this variant call result has passed all QC gates and regulatory checks and is eligible for inclusion in a clinical genomics report. True = reportable; False = not reportable (failed QC, RUO designation, or pending review).' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafThresholdApplied rdf:type rdf:Property ;
    rdfs:label 'Maf Threshold Applied' ;
    rdfs:comment 'The minor allele frequency (MAF) cutoff applied during variant filtering or GWAS QC for this result (e.g., 0.01 = 1%). Variants below this threshold may be excluded from population-level analyses. Null if no MAF filter was applied.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctBasesAbove20x rdf:type rdf:Property ;
    rdfs:label 'Pct Bases Above 20x' ;
    rdfs:comment 'Proportion of target bases achieving at least 20x sequencing coverage depth (range 0.0000–1.0000). A standard NGS QC threshold metric used to assess adequacy of coverage for reliable variant detection.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reanalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Reanalysis Flag' ;
    rdfs:comment 'Indicates whether this result was generated as a reanalysis of a previously processed sample (e.g., due to updated pipeline version, reference genome, or QC failure). True = reanalysis; False = original analysis. Supports data lineage and version tracking.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryUseDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Use Designation' ;
    rdfs:comment 'Regulatory designation governing the intended use of this result: In Vitro Diagnostic (IVD), Research Use Only (RUO), Laboratory Developed Test (LDT), or CE-IVD (EU conformity). Determines applicable regulatory reporting obligations and data handling requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snpCount rdf:type rdf:Property ;
    rdfs:label 'Snp Count' ;
    rdfs:comment 'Number of single nucleotide polymorphism (SNP) variants called in this result. Used for QC benchmarking, GWAS analysis, and pharmacogenomics reporting.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tiTvRatio rdf:type rdf:Property ;
    rdfs:label 'Ti Tv Ratio' ;
    rdfs:comment 'Ratio of transition (Ti) to transversion (Tv) SNP variants in this call set. A critical QC metric for NGS variant calling: expected ~2.0–2.1 for WGS, ~3.0–3.3 for WES coding regions. Deviations indicate potential calling errors or contamination.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGenotypesCalled rdf:type rdf:Property ;
    rdfs:label 'Total Genotypes Called' ;
    rdfs:comment 'Total number of individual genotype calls made in this result. Primarily applicable to array-based SNP genotyping where each probe position yields a discrete genotype call. Distinct from variant count in NGS workflows.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVariantsCalled rdf:type rdf:Property ;
    rdfs:label 'Total Variants Called' ;
    rdfs:comment 'Total count of all variant sites (SNPs, INDELs, CNVs, structural variants) called in this result before any filtering. Primary quantitative output metric for NGS variant calling runs.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useCaseClassification rdf:type rdf:Property ;
    rdfs:label 'Use Case Classification' ;
    rdfs:comment 'Classification of the intended use case for this variant call result. Determines applicable regulatory framework (IVD/RUO/LDT), data access controls, and downstream workflow routing. [ENUM-REF-CANDIDATE: clinical|research|agricultural|pharmacogenomics|oncology|ancestry|gwas|ruo — promote to reference product]' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantsPassFilterCount rdf:type rdf:Property ;
    rdfs:label 'Variants Pass Filter Count' ;
    rdfs:comment 'Number of variants that passed all applied quality filters and are included in the final reportable call set. Distinct from total_variants_called which includes pre-filter counts.' ;
    rdfs:domain ind:VariantCallResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zygosity rdf:type rdf:Property ;
    rdfs:label 'Zygosity' ;
    rdfs:comment 'Zygosity classification of the primary variant call: homozygous reference, heterozygous, homozygous alternate, hemizygous (X-linked in males), or no-call. Critical for clinical interpretation, inheritance pattern analysis, and pharmacogenomics dosing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalValidationId rdf:type rdf:Property ;
    rdfs:label 'Analytical Validation Id' ;
    rdfs:comment 'Unique identifier for the analytical validation record. Primary key for the analytical validation entity.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyticalReportDocumentControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Analytical Report Document Controlled Document Id' ;
    rdfs:comment 'Reference to the controlled document containing the final validation study report with all results, analysis, and conclusions. Required for regulatory submissions and accreditation inspections.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:assayDevelopmentId rdf:type rdf:Property ;
    rdfs:label 'Assay Development Id' ;
    rdfs:comment 'Foreign key linking to research.assay_development. Business justification: Analytical validation studies validate specific assay development efforts. Required for regulatory submissions (510(k), PMA, LDT notifications), CLIA complexity determination, and CAP accreditation. L' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayDevelopment .

ind:ivdTestCatalogId rdf:type rdf:Property ;
    rdfs:label 'Ivd Test Catalog Id' ;
    rdfs:comment 'Reference to the clinical assay being validated. Links this validation study to the specific assay version under evaluation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCatalog .

ind:primaryAnalyticalControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Analytical Controlled Document Id' ;
    rdfs:comment 'Reference to the controlled document containing the detailed validation study protocol. Links to document management system for version control and audit trail.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Reference identifier for the FDA 510(k), PMA, or EMA submission that includes this validation data. Links validation records to regulatory approval documentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Pre-defined performance thresholds that the assay must meet to pass validation. Includes specific numeric criteria for sensitivity, specificity, precision, accuracy, and other performance metrics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accuracyBias rdf:type rdf:Property ;
    rdfs:label 'Accuracy Bias' ;
    rdfs:comment 'Systematic deviation of assay results from the true or reference value, expressed as a percentage. Positive bias indicates overestimation; negative bias indicates underestimation.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyticalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Analytical Sensitivity' ;
    rdfs:comment 'Proportion of true positive results correctly identified by the assay, expressed as a percentage. Measures the assay\'s ability to detect the target analyte when present.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyticalSpecificity rdf:type rdf:Property ;
    rdfs:label 'Analytical Specificity' ;
    rdfs:comment 'Proportion of true negative results correctly identified by the assay, expressed as a percentage. Measures the assay\'s ability to correctly identify samples without the target analyte.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingScientistName rdf:type rdf:Property ;
    rdfs:label 'Approving Scientist Name' ;
    rdfs:comment 'Full name of the qualified scientist or laboratory director who approved the validation study. Required for regulatory documentation and audit trails.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, observations, deviations from protocol, or special considerations identified during the validation study. Used for capturing context not covered by structured fields.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interferenceResult rdf:type rdf:Property ;
    rdfs:label 'Interference Result' ;
    rdfs:comment 'Overall determination of whether tested substances interfere with assay performance. No interference indicates acceptable performance; interference detected requires mitigation or sample rejection criteria; conditionally acceptable indicates interference only at extreme concentrations.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interferenceSubstancesTested rdf:type rdf:Property ;
    rdfs:label 'Interference Substances Tested' ;
    rdfs:comment 'Comma-separated list of endogenous and exogenous substances evaluated for potential interference with assay performance. Common interferents include hemoglobin, lipids, bilirubin, and common medications.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearityRSquared rdf:type rdf:Property ;
    rdfs:label 'Linearity R Squared' ;
    rdfs:comment 'Coefficient of determination for the linearity study regression analysis. Values closer to 1.0 indicate stronger linear relationship. Typical acceptance criterion is R² ≥ 0.95.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeLower rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Lower' ;
    rdfs:comment 'Lower boundary of the concentration range over which the assay demonstrates a linear relationship between input and output. Defines the minimum reportable value.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linearityRangeUnit rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Unit' ;
    rdfs:comment 'Unit of measurement for the linearity range boundaries. Must be consistent with LOD unit and assay measurement unit.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linearityRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Linearity Range Upper' ;
    rdfs:comment 'Upper boundary of the concentration range over which the assay demonstrates a linear relationship between input and output. Defines the maximum reportable value before dilution is required.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lodValue rdf:type rdf:Property ;
    rdfs:label 'Lod Value' ;
    rdfs:comment 'Lowest concentration or quantity of analyte that can be reliably detected by the assay. Critical performance metric for regulatory approval and clinical interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this validation record was last modified. Tracks changes for audit trail and data lineage purposes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Final determination of whether the assay met all acceptance criteria. Pass indicates full approval for clinical use; fail requires remediation; conditional pass indicates approval with specific limitations or monitoring requirements.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionRepeatability rdf:type rdf:Property ;
    rdfs:label 'Precision Repeatability' ;
    rdfs:comment 'Coefficient of variation for within-run precision, expressed as a percentage. Measures consistency of results when the same sample is tested multiple times under identical conditions by the same operator.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionReproducibility rdf:type rdf:Property ;
    rdfs:label 'Precision Reproducibility' ;
    rdfs:comment 'Coefficient of variation for between-run precision, expressed as a percentage. Measures consistency of results across different runs, days, operators, and reagent lots.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referencePopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Reference Population Description' ;
    rdfs:comment 'Demographic and clinical characteristics of the population used to establish the reference range. Includes age range, sex distribution, ethnicity, and health status criteria.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeLower rdf:type rdf:Property ;
    rdfs:label 'Reference Range Lower' ;
    rdfs:comment 'Lower boundary of the normal or expected range for the analyte in the reference population. Used for clinical interpretation of patient results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceRangeUnit rdf:type rdf:Property ;
    rdfs:label 'Reference Range Unit' ;
    rdfs:comment 'Unit of measurement for the reference range boundaries. Must be consistent with assay reporting unit.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Reference Range Upper' ;
    rdfs:comment 'Upper boundary of the normal or expected range for the analyte in the reference population. Used for clinical interpretation of patient results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replicateCount rdf:type rdf:Property ;
    rdfs:label 'Replicate Count' ;
    rdfs:comment 'Number of replicate measurements performed for each sample in the validation study. Higher replicate counts improve precision estimates.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Total number of samples or replicates tested in the validation study. Adequate sample size is critical for statistical power and regulatory acceptance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Validation Approval Date' ;
    rdfs:comment 'Date when the validation study was formally approved by the laboratory director or quality assurance team. Authorizes the assay for clinical use or regulatory submission.' ;
    rdfs:domain ind:AnalyticalValidation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Validation Completion Date' ;
    rdfs:comment 'Date when all validation testing was completed and results were finalized. Marks the end of the experimental phase before review and approval.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationStartDate rdf:type rdf:Property ;
    rdfs:label 'Validation Start Date' ;
    rdfs:comment 'Date when the validation study was initiated. Used for tracking study duration and regulatory submission timelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assayQcRunId rdf:type rdf:Property ;
    rdfs:label 'Assay Qc Run Id' ;
    rdfs:comment 'Unique identifier for the quality control run record. Primary key for the assay QC run entity.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayQcRun .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_approval. Business justification: QC runs validate assay performance within specifications established in the regulatory approval (LOD, sensitivity, specificity). Required for demonstrating continued compliance with approval condition' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:primaryAssaySampleSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Primary Assay Sample Specimen Id' ;
    rdfs:comment 'Identifier of the positive control sample included in the QC run. Used to verify assay sensitivity and detect false negatives.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSpecimen .

ind:productionBatchId rdf:type rdf:Property ;
    rdfs:label 'Production Batch Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_batch. Business justification: QC runs consume reagent batches; lot-to-lot performance tracking required for release decisions and trending analysis. Replaces denormalized reagent_lot_number with proper FK for batch genealogy and s' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:qcMaterialId rdf:type rdf:Property ;
    rdfs:label 'Qc Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: QC runs validate specific reagent materials/lots before clinical use; material-level tracking enables lot release decisions, regulatory compliance (CLIA/CAP), and investigation of QC failures linked t' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:reagentLotId rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Id' ;
    rdfs:comment 'Foreign key linking to reagent.lot. Business justification: Clinical QC runs must trace to specific reagent lots (library prep kits, sequencing reagents) for regulatory compliance, lot release decisions, and root cause analysis when QC failures occur. Critical' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:acceptanceCriteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria Version' ;
    rdfs:comment 'Version identifier of the acceptance criteria document used to evaluate this QC run. Ensures traceability to validated QC thresholds.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Initiated Flag' ;
    rdfs:comment 'Boolean flag indicating whether a CAPA workflow was initiated as a result of this QC run failure or out-of-specification result.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference number linking this QC run to the associated CAPA record in the quality management system. Enables traceability of quality issues to resolution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clusterDensity rdf:type rdf:Property ;
    rdfs:label 'Cluster Density' ;
    rdfs:comment 'Number of clusters per square millimeter on the flow cell. Optimal density ensures adequate signal intensity without overcrowding that degrades quality.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationCheckPercent rdf:type rdf:Property ;
    rdfs:label 'Contamination Check Percent' ;
    rdfs:comment 'Estimated percentage of cross-sample contamination detected through allele frequency analysis or sample fingerprinting. Values above threshold trigger QC failure.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageUniformityPercent rdf:type rdf:Property ;
    rdfs:label 'Coverage Uniformity Percent' ;
    rdfs:comment 'Percentage of target bases covered at a uniform depth, indicating consistency of sequencing across the target region. Low uniformity may indicate technical issues.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the laboratory personnel who created this QC run record. Part of the audit trail required for CLIA and CAP compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duplicate Rate Percent' ;
    rdfs:comment 'Percentage of sequencing reads identified as PCR or optical duplicates. High duplicate rates reduce effective coverage and may indicate library complexity issues.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Error Rate Percent' ;
    rdfs:comment 'Estimated sequencing error rate based on PhiX control or known reference sequences. Monitors instrument and reagent performance over time.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the laboratory personnel who last modified this QC run record. Maintains complete audit trail for regulatory inspections.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPrepKitLot rdf:type rdf:Property ;
    rdfs:label 'Library Prep Kit Lot' ;
    rdfs:comment 'Lot number of the library preparation kit used for sample processing prior to sequencing. Tracks consumable quality impact on QC metrics.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotReleaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Release Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this QC run supports lot release decisions for reagents or consumables. Used in manufacturing quality control workflows.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negativeControlResult rdf:type rdf:Property ;
    rdfs:label 'Negative Control Result' ;
    rdfs:comment 'Pass/fail determination for the negative control sample. Failure indicates potential contamination or specificity issues.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noTemplateControlResult rdf:type rdf:Property ;
    rdfs:label 'No Template Control Result' ;
    rdfs:comment 'Pass/fail determination for the no-template control. Detects reagent contamination or carryover from previous runs.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTargetRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Target Rate Percent' ;
    rdfs:comment 'Percentage of sequencing reads that align to the intended target regions. Low on-target rates indicate library preparation or capture efficiency issues.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positiveControlResult rdf:type rdf:Property ;
    rdfs:label 'Positive Control Result' ;
    rdfs:comment 'Pass/fail determination for the positive control sample. Failure indicates potential assay sensitivity issues requiring investigation.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:q30ScorePercent rdf:type rdf:Property ;
    rdfs:label 'Q30 Score Percent' ;
    rdfs:comment 'Percentage of bases with Phred quality score of 30 or higher, indicating base call accuracy of 99.9% or better. Industry standard metric for sequencing quality.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcRunNumber rdf:type rdf:Property ;
    rdfs:label 'Qc Run Number' ;
    rdfs:comment 'Business identifier for the QC run, typically formatted as a human-readable run number used in laboratory documentation and CLIA compliance records.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Boolean flag indicating whether this QC run data is included in regulatory submissions to FDA, EMA, or other governing bodies for assay validation or post-market surveillance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Free-text comments from the reviewing scientist documenting observations, conditional pass justifications, or follow-up actions required.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Completion Timestamp' ;
    rdfs:comment 'Precise timestamp when the QC run completed all processing steps and generated final metrics.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The calendar date on which the QC run was executed in the clinical laboratory.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Precise timestamp when the QC run was initiated on the sequencing instrument or analysis platform.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:westgardRuleEvaluation rdf:type rdf:Property ;
    rdfs:label 'Westgard Rule Evaluation' ;
    rdfs:comment 'Result of Westgard multi-rule statistical QC evaluation applied to control samples. Documents which Westgard rules (1-2s, 1-3s, 2-2s, R-4s, 4-1s, 10x) were triggered, if any.' ;
    rdfs:domain ind:AssayQcRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedOrdererId rdf:type rdf:Property ;
    rdfs:label 'Authorized Orderer Id' ;
    rdfs:comment 'Primary key for authorized_orderer' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthorizedOrderer .

ind:kolEngagementId rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Id' ;
    rdfs:comment 'Foreign key linking to commercial.kol_engagement. Business justification: Ordering physicians are frequently KOLs. Commercial teams track which KOLs are active orderers to prioritize engagement investments, measure influence-to-revenue conversion, and optimize KOL program R' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KolEngagement .

ind:billingNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Npi' ;
    rdfs:comment 'NPI used for billing and reimbursement purposes. May differ from ordering NPI if billing is handled by a group practice or institution.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccreditedFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Accredited Flag' ;
    rdfs:comment 'Boolean flag indicating whether the provider is affiliated with a CAP-accredited laboratory or institution. Used for quality assurance and accreditation reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cliaOrderingPrivilege rdf:type rdf:Property ;
    rdfs:label 'Clia Ordering Privilege' ;
    rdfs:comment 'Boolean flag indicating whether the provider is authorized to order high-complexity CLIA tests. True if provider meets CLIA personnel qualifications for ordering genomic assays.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Consent On File Flag' ;
    rdfs:comment 'Boolean flag indicating whether a signed provider agreement and consent for test ordering is on file. Required before first test order can be accepted.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Expiration Date' ;
    rdfs:comment 'Date when the current credentialing verification expires and re-verification is required. Triggers proactive outreach for credential renewal.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingNotes rdf:type rdf:Property ;
    rdfs:label 'Credentialing Notes' ;
    rdfs:comment 'Free-text notes documenting special credentialing circumstances, verification sources, or exceptions granted during the credentialing process.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Verification Date' ;
    rdfs:comment 'Date when the providers credentials, licenses, and ordering privileges were last verified by the laboratory credentialing team. CLIA requires periodic re-verification.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentials rdf:type rdf:Property ;
    rdfs:label 'Credentials' ;
    rdfs:comment 'Professional credentials and degree designation of the ordering provider. Determines ordering authority scope for high-complexity genomic testing under CLIA regulations. [ENUM-REF-CANDIDATE: MD|DO|PhD|MS|CGC|LCGC|NP|PA|DVM|PharmD — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaNumber rdf:type rdf:Property ;
    rdfs:label 'Dea Number' ;
    rdfs:comment 'DEA registration number for providers authorized to prescribe controlled substances. Optional field used for comprehensive provider identity verification.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehrFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Ehr Facility Code' ;
    rdfs:comment 'Unique facility or organization identifier within the EHR system. Used for HL7 message routing and result interface mapping.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehrSystemName rdf:type rdf:Property ;
    rdfs:label 'Ehr System Name' ;
    rdfs:comment 'Name of the EHR system used by the provider or institution (e.g., Epic, Cerner, Allscripts). Required for HL7 interface configuration and automated result delivery.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the ordering provider. Used for electronic report delivery, test status notifications, and critical result alerts.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for secure report delivery. Legacy delivery channel still required by many institutions for PHI-compliant document transmission.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name of the authorized ordering provider as registered with state medical board and credentialing authority.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Protocol Number' ;
    rdfs:comment 'IRB protocol number if the provider is ordering tests under a research protocol. Links test orders to approved research studies for compliance tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name of the authorized ordering provider as registered with state medical board and credentialing authority.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the authorized ordering provider. Optional field for full legal name matching.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment 'Ten-digit unique identification number issued by the Centers for Medicare and Medicaid Services (CMS) to healthcare providers in the United States. Required for CLIA-compliant test ordering and billing.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingStatus rdf:type rdf:Property ;
    rdfs:label 'Ordering Status' ;
    rdfs:comment 'Current status of the providers authorization to order clinical genomic tests. Active status required for test order acceptance. Inactive or revoked status blocks new orders.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the ordering provider. Required for critical result notification and clinical consultation per CLIA requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Report Delivery Method' ;
    rdfs:comment 'Preferred method for delivering clinical genomic test reports to the ordering provider. Determines routing logic for automated report distribution.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialty rdf:type rdf:Property ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Primary medical specialty or practice area of the ordering provider (e.g., Medical Genetics, Oncology, Cardiology, Genetic Counseling). Used for test menu filtering and clinical decision support.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'State License Expiration Date' ;
    rdfs:comment 'Expiration date of the state medical license. Monitored for proactive re-credentialing and to prevent test orders from providers with lapsed licenses.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'State License Number' ;
    rdfs:comment 'State-issued medical license number for the ordering provider. Required for verification of ordering authority and CLIA compliance validation.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLicenseState rdf:type rdf:Property ;
    rdfs:label 'State License State' ;
    rdfs:comment 'Two-letter state code of the jurisdiction that issued the medical license. Determines geographic ordering authority and cross-state practice limitations.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subspecialty rdf:type rdf:Property ;
    rdfs:label 'Subspecialty' ;
    rdfs:comment 'Subspecialty or fellowship-trained area of focus within the primary specialty (e.g., Molecular Genetic Pathology, Pediatric Oncology). Provides additional context for test appropriateness validation.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal tax identification number (EIN or SSN) for the provider or practice. Used for billing, invoicing, and 1099 reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMenuAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Test Menu Access Level' ;
    rdfs:comment 'Level of access to the clinical genomic test catalog based on provider credentials and specialty. Determines which tests the provider is authorized to order.' ;
    rdfs:domain ind:AuthorizedOrderer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryDirectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Director Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: CLIA regulations mandate designated laboratory director who must be qualified internal employee. Critical for regulatory compliance, inspection readiness, personnel qualification tracking, and linking' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accreditationFeeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Accreditation Fee Amount Usd' ;
    rdfs:comment 'The total fee amount paid or due for the accreditation or certificate, expressed in US dollars. Includes application fees, inspection fees, and annual maintenance fees.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationFeePaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Fee Payment Status' ;
    rdfs:comment 'Current status of payment for accreditation fees. Tracks whether fees have been paid, are pending, or are overdue, which may impact accreditation standing.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationScope rdf:type rdf:Property ;
    rdfs:label 'Accreditation Scope' ;
    rdfs:comment 'Detailed description of the scope of testing authorized under this accreditation. Includes test categories, specialty areas, complexity levels (waived, moderate, high), and specific analytes or methodologies covered.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current lifecycle status of the accreditation. Indicates whether the laboratory is currently authorized to perform clinical testing under this accreditation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The externally-issued unique certificate or accreditation number assigned by CLIA or CAP. Business identifier for the accreditation agreement.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the accreditation or certificate type. Indicates the regulatory framework and scope of laboratory operations permitted.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complexityLevel rdf:type rdf:Property ;
    rdfs:label 'Complexity Level' ;
    rdfs:comment 'The CLIA complexity categorization of tests authorized under this accreditation. Determines regulatory requirements for personnel, quality control, and proficiency testing.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The deadline by which corrective action plans must be submitted or implemented to address inspection deficiencies. Nullable if no corrective action is required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of corrective action plans submitted in response to inspection deficiencies. Tracks the laboratory\'s progress in addressing compliance gaps.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficienciesCitedCount rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Cited Count' ;
    rdfs:comment 'The total number of deficiencies or non-conformances identified during the most recent inspection. Used to assess compliance risk and prioritize corrective actions.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencySummary rdf:type rdf:Property ;
    rdfs:label 'Deficiency Summary' ;
    rdfs:comment 'Narrative summary of the deficiencies or non-conformances cited during the most recent inspection. Includes checklist item references, severity classification, and areas requiring corrective action.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which the accreditation or certificate expires and must be renewed. Nullable for indefinite or rolling accreditations pending inspection cycles.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'The overall result or finding from the most recent inspection. Indicates whether the laboratory met all requirements, had minor recommendations, or had deficiencies requiring corrective action.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The regulatory or accrediting organization that issued the certificate. Examples include CMS (Centers for Medicare & Medicaid Services), CAP (College of American Pathologists), state health departments, or other approved accrediting organizations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAddress rdf:type rdf:Property ;
    rdfs:label 'Laboratory Address' ;
    rdfs:comment 'The physical address of the clinical laboratory facility. Required for regulatory reporting, inspection scheduling, and certificate issuance. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryCliaNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Clia Number' ;
    rdfs:comment 'The unique 10-digit CLIA identification number assigned to the laboratory by CMS. This is the primary regulatory identifier for the laboratory and is distinct from the certificate number.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'The official name of the clinical laboratory holding this accreditation. Used for regulatory reporting, certificate display, and external communications.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'The date of the most recent on-site inspection or survey conducted by the accrediting body or regulatory agency. Critical for tracking compliance cycles and renewal timelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The scheduled or anticipated date for the next on-site inspection or survey. Used for proactive compliance planning and resource allocation.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or context related to the accreditation record. May include special conditions, historical context, or internal tracking information.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptAnalyteTestSystem rdf:type rdf:Property ;
    rdfs:label 'Pt Analyte Test System' ;
    rdfs:comment 'The specific analyte, test system, or specialty area evaluated through proficiency testing. Examples include Glucose, HbA1c, Molecular Oncology, Cytogenetics, or specific gene panels.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptCorrectiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pt Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator of whether corrective action is required in response to unsuccessful proficiency testing performance. True indicates corrective action is required; False indicates acceptable performance.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptEnrollmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Pt Enrollment Period' ;
    rdfs:comment 'The time period or cycle for which the laboratory is enrolled in the proficiency testing program. Typically expressed as a year or year-quarter (e.g., 2024-Q1, 2024 Annual).' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptGradedOutcome rdf:type rdf:Property ;
    rdfs:label 'Pt Graded Outcome' ;
    rdfs:comment 'The overall graded outcome or performance result for the proficiency testing cycle. Indicates whether the laboratory met acceptable performance criteria for the analyte or test system.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptProgramName rdf:type rdf:Property ;
    rdfs:label 'Pt Program Name' ;
    rdfs:comment 'The name of the proficiency testing program in which the laboratory is enrolled. Examples include CAP Surveys, ARUP Proficiency Testing, or other CMS-approved PT providers.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptResultsSubmittedCount rdf:type rdf:Property ;
    rdfs:label 'Pt Results Submitted Count' ;
    rdfs:comment 'The number of proficiency testing results or reports submitted by the laboratory during the enrollment period. Used to verify compliance with PT submission requirements.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptSampleSetsReceived rdf:type rdf:Property ;
    rdfs:label 'Pt Sample Sets Received' ;
    rdfs:comment 'The number of proficiency testing sample sets or challenges received by the laboratory during the enrollment period. Used to track PT participation completeness.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptScorePercent rdf:type rdf:Property ;
    rdfs:label 'Pt Score Percent' ;
    rdfs:comment 'The percentage score achieved by the laboratory on the proficiency testing challenge. Calculated as the number of acceptable results divided by the total number of challenges, expressed as a percentage.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptSubmissionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Pt Submission Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the laboratory submitted proficiency testing results by the required deadline. True indicates on-time submission; False indicates late or missing submission.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Pt Submission Deadline' ;
    rdfs:comment 'The deadline by which proficiency testing results must be submitted to the PT provider. Used to track compliance with PT submission timelines and avoid late submission penalties.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the laboratory submitted the renewal application for the accreditation or certificate. Used to track renewal cycle timelines and compliance with submission deadlines.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Workflow Status' ;
    rdfs:comment 'Current status of the accreditation renewal process. Tracks the laboratory\'s progress through the renewal application, review, and approval workflow.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSpecialtyAreas rdf:type rdf:Property ;
    rdfs:label 'Test Specialty Areas' ;
    rdfs:comment 'Comma-separated list of specialty areas or disciplines covered by the accreditation (e.g., Molecular Pathology, Cytogenetics, Clinical Chemistry, Hematology, Microbiology). Defines the breadth of clinical testing capabilities.' ;
    rdfs:domain ind:CliaAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayVersionId rdf:type rdf:Property ;
    rdfs:label 'Assay Version Id' ;
    rdfs:comment 'Unique identifier for each version of a clinical assay configuration. Primary key for the clinical assay version entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssayVersion .

ind:approvedReagentSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Reagent Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Assay versions specify approved suppliers for critical reagents as part of analytical validation and supply chain risk management. Enables supplier qualification tracking, dual-source strategies, and ' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:clinicalAssayId rdf:type rdf:Property ;
    rdfs:label 'Clinical Assay Id' ;
    rdfs:comment 'Reference to the parent clinical assay in the IVD (In Vitro Diagnostic) test catalog. Links this version to the base assay definition.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalAssay .

ind:libraryPrepMaterialId rdf:type rdf:Property ;
    rdfs:label 'Library Prep Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Each assay version locks specific library prep kit as material for regulatory validation and reproducibility. Critical for version control, change management, regulatory submissions (510k/PMA), and en' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:rdCapitalizationId rdf:type rdf:Property ;
    rdfs:label 'Rd Capitalization Id' ;
    rdfs:comment 'Foreign key linking to finance.rd_capitalization. Business justification: Assay versions reaching technical feasibility and regulatory approval milestones trigger capitalization decisions per ASC 730. Link enables tracking which assay development costs are capitalized to in' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RdCapitalization .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Assay versions require specific SKU linkage for lot traceability, regulatory compliance (21 CFR Part 820), inventory management, and configuration control. Critical for CLIA/CAP compliance and post-ma' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:analyticalValidationDate rdf:type rdf:Property ;
    rdfs:label 'Analytical Validation Date' ;
    rdfs:comment 'Date when analytical validation study was completed and approved for this assay version. Required for regulatory submissions and laboratory accreditation.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Analytical Validation Status' ;
    rdfs:comment 'Status of the analytical validation study for this assay version. Completed and approved status required before version can be activated for clinical use. Tracks compliance with CLIA and CAP requirements.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annotationDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Annotation Database Version' ;
    rdfs:comment 'Version of the variant annotation database used for clinical interpretation (e.g., ClinVar version, dbSNP build, COSMIC version). Database version affects variant classification and clinical significance assignment.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioinformaticsPipelineVersion rdf:type rdf:Property ;
    rdfs:label 'Bioinformatics Pipeline Version' ;
    rdfs:comment 'Version identifier of the bioinformatics analysis pipeline used for data processing, variant calling, and annotation. Links to the pipeline version entity for full pipeline configuration details.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Business and technical justification for creating this new assay version. Documents reasons such as improved analytical performance, updated reference genome, regulatory requirement, or bug fix. Required for regulatory audit trail.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaComplexity rdf:type rdf:Property ;
    rdfs:label 'Clia Complexity' ;
    rdfs:comment 'CLIA complexity categorization for this assay version. Waived tests have lowest complexity; high complexity tests require specialized personnel and quality systems. Determines laboratory accreditation requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCellType rdf:type rdf:Property ;
    rdfs:label 'Flow Cell Type' ;
    rdfs:comment 'Type of flow cell used in the sequencing platform for this assay version. Different flow cell types have different throughput and read length capabilities.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUseStatement rdf:type rdf:Property ;
    rdfs:label 'Intended Use Statement' ;
    rdfs:comment 'Regulatory-approved statement describing the clinical purpose and intended patient population for this assay version. Required for IVD labeling and marketing materials.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryPreparationProtocol rdf:type rdf:Property ;
    rdfs:label 'Library Preparation Protocol' ;
    rdfs:comment 'Identifier or name of the library preparation protocol used for sample processing in this assay version. Links to detailed SOP (Standard Operating Procedure) documentation.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplexingStrategy rdf:type rdf:Property ;
    rdfs:label 'Multiplexing Strategy' ;
    rdfs:comment 'Strategy used for pooling multiple samples in a single sequencing run. Single index uses one barcode; dual index uses two barcodes for higher sample throughput and reduced index hopping.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelGeneListVersion rdf:type rdf:Property ;
    rdfs:label 'Panel Gene List Version' ;
    rdfs:comment 'Version identifier of the curated gene list or panel used in this assay configuration. Tracks which genes are included in targeted sequencing or array-based assays. Essential for clinical validity documentation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredDate rdf:type rdf:Property ;
    rdfs:label 'Retired Date' ;
    rdfs:comment 'Date when this assay version was retired from active clinical use. Null if the version is still active or planned. Critical for traceability of which version was used for historical patient results.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sensitivityPercentage rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Percentage' ;
    rdfs:comment 'Percentage of true positive results correctly identified by the assay (true positives divided by true positives plus false negatives). Key analytical performance metric for clinical validity.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificityPercentage rdf:type rdf:Property ;
    rdfs:label 'Specificity Percentage' ;
    rdfs:comment 'Percentage of true negative results correctly identified by the assay (true negatives divided by true negatives plus false positives). Key analytical performance metric for clinical validity.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReadLength rdf:type rdf:Property ;
    rdfs:label 'Target Read Length' ;
    rdfs:comment 'Target length of sequencing reads in base pairs for this assay version. Affects ability to detect structural variants and map reads to repetitive regions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testClassification rdf:type rdf:Property ;
    rdfs:label 'Test Classification' ;
    rdfs:comment 'Regulatory classification of the test: IVD (In Vitro Diagnostic) for FDA-cleared or CE-marked tests, LDT (Laboratory Developed Test) for CLIA-validated tests, or RUO (Research Use Only) for non-clinical tests.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Target time from sample receipt to report delivery for this assay version, measured in hours. Used for SLA (Service Level Agreement) tracking and operational planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCallingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Variant Calling Algorithm' ;
    rdfs:comment 'Name and version of the primary variant calling algorithm used in this assay version (e.g., GATK HaplotypeCaller, FreeBayes, VarScan). Algorithm choice affects sensitivity and specificity of variant detection.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Semantic version number of the clinical assay configuration (e.g., 1.0, 2.1, 3.0.1). Follows semantic versioning convention to track major and minor changes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle state of this assay version. Draft indicates under development; validation indicates undergoing analytical validation; active indicates approved for clinical use; deprecated indicates superseded but still in use; retired indicates no longer in use; withdrawn indicates removed from catalog due to regulatory or quality issues.' ;
    rdfs:domain ind:AssayVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalConsentRecordId rdf:type rdf:Property ;
    rdfs:label 'Clinical Consent Record Id' ;
    rdfs:comment 'Unique identifier for the clinical consent record. Primary key for tracking patient consent throughout the clinical genomics workflow.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentFormControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Consent Form Controlled Document Id' ;
    rdfs:comment 'Foreign key linking to quality.controlled_document. Business justification: Consent records must reference the specific IRB-approved consent form version used. Regulatory requirement for human subjects research (45 CFR 46) and clinical testing (CLIA/CAP). Critical for audit t' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:dpiaId rdf:type rdf:Property ;
    rdfs:label 'Dpia Id' ;
    rdfs:comment 'Foreign key linking to data.dpia. Business justification: Consent records are inputs to DPIA assessments - they define the legal basis and scope of data processing. Demonstrating lawful basis for processing under GDPR requires linking consent records to the ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dpia .

ind:irbSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Irb Submission Id' ;
    rdfs:comment 'Foreign key linking to research.irb_submission. Business justification: Consent records must link to specific IRB submissions for audit trails, protocol version compliance, continuing review documentation, and regulatory inspections (FDA, OHRP). Required for human subject' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrbSubmission .

ind:patientId rdf:type rdf:Property ;
    rdfs:label 'Patient Id' ;
    rdfs:comment 'Unique identifier linking this consent record to the patient in the clinical system. Required for PHI-compliant consent tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patient .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier to the detailed audit trail log for this consent record. Required for 21 CFR Part 11 compliance and regulatory inspections.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Biobanking Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to long-term storage of biological samples for future research or testing. Required for biorepository management.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date when the patient provided informed consent. Used to determine consent validity period and regulatory compliance timelines.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Document Number' ;
    rdfs:comment 'Business identifier for the consent document. Used for audit trails and regulatory submissions.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiration Date' ;
    rdfs:comment 'Date when the consent expires and must be renewed. Null for consents without expiration. Required for time-limited research protocols.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'ISO 639-3 three-letter language code indicating the language in which consent was obtained. Required for multilingual patient populations and regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLocation rdf:type rdf:Property ;
    rdfs:label 'Consent Location' ;
    rdfs:comment 'Physical or virtual location where consent was obtained (clinic name, hospital, telehealth platform). Required for audit trails and regulatory compliance.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'Method by which consent was obtained from the patient or legal guardian. Determines documentation and audit requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Consent Scope Description' ;
    rdfs:comment 'Detailed description of what the patient consented to, including specific tests, data usage, and sharing permissions. Required for informed consent documentation.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent record. Determines whether genomic testing and data usage are permissible.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent provided by the patient. Determines scope of permissible genomic testing and data usage.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent form template used. Required for tracking consent form changes over time and ensuring regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingPartyName rdf:type rdf:Property ;
    rdfs:label 'Consenting Party Name' ;
    rdfs:comment 'Full legal name of the individual who provided consent. Required for legal documentation and audit trails.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingPartyType rdf:type rdf:Property ;
    rdfs:label 'Consenting Party Type' ;
    rdfs:comment 'Relationship of the person providing consent to the patient. Required for minors, incapacitated patients, or legally authorized representatives.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Consenting Physician Name' ;
    rdfs:comment 'Name of the physician or healthcare provider who obtained informed consent from the patient. Required for clinical accountability and audit trails.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingPhysicianNpi rdf:type rdf:Property ;
    rdfs:label 'Consenting Physician Npi' ;
    rdfs:comment 'National Provider Identifier of the physician who obtained consent. Required for regulatory reporting and provider accountability.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to sharing of de-identified genomic data with external databases or research consortia. Required for NIH and GDPR compliance.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this consent record meets GDPR requirements for EU patients. Required for international genomic testing operations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:germlineTestingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Germline Testing Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to germline genomic testing (inherited variants). Critical for test ordering and result interpretation.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentalFindingsReturnFlag rdf:type rdf:Property ;
    rdfs:label 'Incidental Findings Return Flag' ;
    rdfs:comment 'Indicates whether patient consented to receive incidental or secondary findings from genomic testing. Required per ACMG guidelines for return of results.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used Flag' ;
    rdfs:comment 'Indicates whether a medical interpreter was used during the consent process. Required for documenting informed consent quality and regulatory compliance.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Date' ;
    rdfs:comment 'Date when the IRB approved the consent form and protocol. Used to validate consent form currency and regulatory compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phiCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Compliant Flag' ;
    rdfs:comment 'Indicates whether this consent record meets all HIPAA PHI protection requirements. Used for compliance audits and data governance.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recontactPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Recontact Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to be recontacted for future research opportunities or updated findings. Required for longitudinal genomic studies.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the regulatory jurisdiction governing this consent. Required for multi-country genomic testing operations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchUsePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Research Use Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to use of genomic data for research purposes beyond clinical care. Required for NIH data sharing compliance.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureReference rdf:type rdf:Property ;
    rdfs:label 'Signature Reference' ;
    rdfs:comment 'Reference identifier to the stored signature artifact (electronic or scanned paper). Used for audit and legal verification purposes.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:somaticTestingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Somatic Testing Permitted Flag' ;
    rdfs:comment 'Indicates whether patient consented to somatic genomic testing (tumor/acquired variants). Required for oncology genomic testing workflows.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date when patient withdrew consent. Null if consent has not been withdrawn. Required for GDPR right to withdraw and HIPAA compliance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'Method by which patient communicated withdrawal of consent. Required for audit trail and regulatory compliance. Null if consent not withdrawn.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text explanation of why patient withdrew consent. Used for quality improvement and regulatory reporting. Null if consent not withdrawn.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the witness who observed the consent process. Required for certain consent types and regulatory jurisdictions. Null if witness not required.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Reference' ;
    rdfs:comment 'Reference identifier to the stored witness signature artifact. Required for certain consent types. Null if witness not required.' ;
    rdfs:domain ind:ClinicalConsentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalPipelineRunId rdf:type rdf:Property ;
    rdfs:label 'Clinical Pipeline Run Id' ;
    rdfs:comment 'Unique identifier for the clinical-grade bioinformatics pipeline execution record. Primary key for this GxP-validated pipeline run subject to 21 CFR Part 11 controls.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryClinicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Clinical Employee Id' ;
    rdfs:comment 'Identifier of the laboratory personnel or automated system account that initiated this pipeline run. Part of 21 CFR Part 11 electronic signature requirements.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sequencingReagentMaterialId rdf:type rdf:Property ;
    rdfs:label 'Sequencing Reagent Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Bioinformatics pipelines require full traceability to upstream wet-lab reagent lots for regulatory compliance and quality investigations. Enables end-to-end lot genealogy from sequencing reagents thro' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:testOrderId rdf:type rdf:Property ;
    rdfs:label 'Test Order Id' ;
    rdfs:comment 'Reference to the clinical test order that triggered this pipeline execution. Links the computational analysis to the patient specimen and clinical context.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestOrder .

ind:clinicallySignificantVariants rdf:type rdf:Property ;
    rdfs:label 'Clinically Significant Variants' ;
    rdfs:comment 'Number of variants flagged as clinically significant based on annotation databases and clinical interpretation rules. Subset of total variants requiring clinical review.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:computeEnvironmentHash rdf:type rdf:Property ;
    rdfs:label 'Compute Environment Hash' ;
    rdfs:comment 'Cryptographic hash of the validated compute environment configuration including software versions, container images, and system libraries. Ensures reproducibility per 21 CFR Part 11.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeInstanceCode rdf:type rdf:Property ;
    rdfs:label 'Compute Instance Code' ;
    rdfs:comment 'Identifier of the specific compute instance or cluster node that executed this pipeline run. Supports infrastructure troubleshooting and audit trails.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computeResourceType rdf:type rdf:Property ;
    rdfs:label 'Compute Resource Type' ;
    rdfs:comment 'Type of high-performance computing infrastructure used for this pipeline execution. Tracks whether analysis was performed on-premise or in cloud environments.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Date' ;
    rdfs:comment 'Date until which this pipeline run data and associated genomic files must be retained per regulatory and legal requirements. Typically 2-10 years post-analysis.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duplicateReadRatePercent rdf:type rdf:Property ;
    rdfs:label 'Duplicate Read Rate Percent' ;
    rdfs:comment 'Percentage of sequencing reads identified as PCR or optical duplicates. High duplication rates may indicate library preparation issues.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorLogPath rdf:type rdf:Property ;
    rdfs:label 'Error Log Path' ;
    rdfs:comment 'Storage location URI for detailed error logs if the pipeline run failed. Supports troubleshooting and root cause analysis.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution End Timestamp' ;
    rdfs:comment 'Date and time when the pipeline execution completed or failed. Used to calculate processing time and meet TAT requirements.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Start Timestamp' ;
    rdfs:comment 'Date and time when the pipeline execution was initiated. Part of the audit trail for turnaround time tracking and regulatory compliance.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inputFastqR1Path rdf:type rdf:Property ;
    rdfs:label 'Input Fastq R1 Path' ;
    rdfs:comment 'Storage location URI for the forward read FASTQ file input to this pipeline run. Part of the raw sequencing data lineage.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputFastqR2Path rdf:type rdf:Property ;
    rdfs:label 'Input Fastq R2 Path' ;
    rdfs:comment 'Storage location URI for the reverse read FASTQ file input to this pipeline run. Applicable for paired-end sequencing workflows.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineParametersJson rdf:type rdf:Property ;
    rdfs:label 'Pipeline Parameters Json' ;
    rdfs:comment 'JSON-serialized configuration parameters used for this pipeline execution. Locked per validation protocol to ensure consistent analytical performance.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Processing Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from execution start to completion. Key metric for operational efficiency and TAT compliance.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runIdentifier rdf:type rdf:Property ;
    rdfs:label 'Run Identifier' ;
    rdfs:comment 'Human-readable business identifier for this pipeline execution. Used for operational tracking and audit trail references.' ;
    rdfs:domain ind:ClinicalPipelineRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportId rdf:type rdf:Property ;
    rdfs:label 'Report Id' ;
    rdfs:comment 'Unique identifier for the clinical genomics report. Primary key.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Report .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Clinical report finalization triggers billing and AR creation. Link enables revenue cycle management, DSO tracking, collection workflows, and reconciliation of reported tests to invoiced amounts. Esse' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:amendedContent rdf:type rdf:Property ;
    rdfs:label 'Amended Content' ;
    rdfs:comment 'Description of the specific content that was amended, corrected, or added in this version of the report.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date the amendment was made to the report.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Notification Status' ;
    rdfs:comment 'Status of notification to the ordering physician regarding the amendment (pending, notified, acknowledged).' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Detailed explanation of the reason for the amendment, including what was changed and why.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Type of amendment applied to the report (e.g., correction of error, addendum with new information, clarification, retraction).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayName rdf:type rdf:Property ;
    rdfs:label 'Assay Name' ;
    rdfs:comment 'Name of the clinical genomics assay performed (e.g., Whole Exome Sequencing (WES), targeted gene panel).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayVersion rdf:type rdf:Property ;
    rdfs:label 'Assay Version' ;
    rdfs:comment 'Version identifier of the assay used, including pipeline and reagent versions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizingPathologistCredentials rdf:type rdf:Property ;
    rdfs:label 'Authorizing Pathologist Credentials' ;
    rdfs:comment 'Professional credentials of the authorizing pathologist (e.g., MD, PhD, FACMG).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizingPathologistName rdf:type rdf:Property ;
    rdfs:label 'Authorizing Pathologist Name' ;
    rdfs:comment 'Full name of the board-certified pathologist or laboratory director who authorized and electronically signed the report.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalInterpretation rdf:type rdf:Property ;
    rdfs:label 'Clinical Interpretation' ;
    rdfs:comment 'Detailed clinical interpretation narrative explaining the significance of the findings, disease associations, and clinical context.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmatoryTestingRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmatory Testing Recommended Flag' ;
    rdfs:comment 'Indicates whether confirmatory testing (e.g., Sanger sequencing) is recommended to validate the findings.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the report was delivered to the ordering physician and patient (e.g., Electronic Health Record (EHR) integration, secure portal, encrypted email).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time the report was delivered to the ordering physician.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electronicSignature rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature' ;
    rdfs:comment 'Electronic signature or digital signature token of the authorizing pathologist, ensuring report authenticity and non-repudiation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time the report was finalized and authorized for release.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Format in which the clinical report is delivered (e.g., PDF, HL7 FHIR, HL7 v2).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geneticCounselingRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Genetic Counseling Recommended Flag' ;
    rdfs:comment 'Indicates whether genetic counseling is recommended for the patient based on the findings.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Language in which the clinical report is written (e.g., English, Spanish, French), using ISO 639-1 two-letter codes.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingFacilityName rdf:type rdf:Property ;
    rdfs:label 'Ordering Facility Name' ;
    rdfs:comment 'Name of the healthcare facility or clinic from which the test was ordered.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Ordering Physician Name' ;
    rdfs:comment 'Full name of the physician who ordered the clinical genomics test.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingPhysicianNpi rdf:type rdf:Property ;
    rdfs:label 'Ordering Physician Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the ordering physician, used for billing and regulatory tracking.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Patient Date Of Birth' ;
    rdfs:comment 'Date of birth of the patient, used for identity verification and age-related clinical interpretation.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Patient Identifier' ;
    rdfs:comment 'De-identified or pseudonymized patient identifier compliant with Protected Health Information (PHI) regulations.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientName rdf:type rdf:Property ;
    rdfs:label 'Patient Name' ;
    rdfs:comment 'Full legal name of the patient for whom the clinical report was generated.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSex rdf:type rdf:Property ;
    rdfs:label 'Patient Sex' ;
    rdfs:comment 'Biological sex of the patient, relevant for sex-linked genetic variant interpretation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Clinical recommendations provided to the ordering physician, including genetic counseling, confirmatory testing, family screening, or treatment implications.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-visible unique report identifier used for physician and patient communication.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the clinical report.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultSummary rdf:type rdf:Property ;
    rdfs:label 'Result Summary' ;
    rdfs:comment 'High-level summary of the genomic test result: positive (pathogenic variant detected), negative (no pathogenic variant detected), inconclusive, or Variant of Uncertain Significance (VUS) detected.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Date' ;
    rdfs:comment 'Date the specimen was collected from the patient.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Type of biological specimen analyzed (e.g., whole blood, saliva, tissue biopsy).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Variant Findings Summary' ;
    rdfs:comment 'Textual summary of key variant findings included in the report, listing genes and variant classifications.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Clinical Specimen Id' ;
    rdfs:comment 'Unique identifier for the clinical specimen record. Primary key for the clinical specimen entity.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionKitMaterialId rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Specimen collection and processing consumes collection tubes, preservatives, extraction kits tracked as materials. Enables preanalytical workflow tracking, material lot traceability for quality invest' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:nonconformanceId rdf:type rdf:Property ;
    rdfs:label 'Nonconformance Id' ;
    rdfs:comment 'Foreign key linking to quality.nonconformance. Business justification: Preanalytical specimen failures (hemolysis, insufficient volume, contamination, labeling errors) trigger NCRs that must be traceable to the specimen for CLIA/CAP compliance and root cause analysis of ' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nonconformance .

ind:parentSpecimenClinicalSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Parent Specimen Clinical Specimen Id' ;
    rdfs:comment 'Identifier of the parent specimen if this record represents an aliquot or derivative specimen. Null for original specimens. Enables traceability of specimen lineage.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalSpecimen .

ind:rdSampleRequestId rdf:type rdf:Property ;
    rdfs:label 'Rd Sample Request Id' ;
    rdfs:comment 'Foreign key linking to research.sample_request. Business justification: Clinical specimens fulfilled for research sample requests link to originating requests for chain-of-custody documentation, consent verification, IRB protocol compliance, and biobank audit trails. Stan' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleRequest .

ind:reagentProductionBatchId rdf:type rdf:Property ;
    rdfs:label 'Reagent Production Batch Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_batch. Business justification: Specimens are processed using reagent batches. Batch traceability required for quality investigations when QC failures occur, enabling lot-specific CAPA and customer notifications. Critical for ISO 15' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionBatch .

ind:accessionNumber rdf:type rdf:Property ;
    rdfs:label 'Accession Number' ;
    rdfs:comment 'Unique laboratory-assigned identifier for specimen tracking through the clinical workflow. Externally-known business identifier used across LIMS, clinical reports, and regulatory submissions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotCount rdf:type rdf:Property ;
    rdfs:label 'Aliquot Count' ;
    rdfs:comment 'Number of aliquots created from the original specimen for testing, storage, or repeat analysis. Used for inventory management and specimen tracking.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chainOfCustodyEvents rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Events' ;
    rdfs:comment 'Comma-separated or structured log of chain-of-custody events tracking specimen handling from collection through testing. Includes timestamps, handler identifiers, and transfer locations. Critical for forensic and regulatory compliance.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalIndication rdf:type rdf:Property ;
    rdfs:label 'Clinical Indication' ;
    rdfs:comment 'Clinical reason or diagnosis code for ordering the genomic test. Examples: suspected hereditary cancer syndrome, pharmacogenomic screening, prenatal diagnosis. Used for test appropriateness review and variant interpretation.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clottingObserved rdf:type rdf:Property ;
    rdfs:label 'Clotting Observed' ;
    rdfs:comment 'Boolean flag indicating whether clotting was observed in the specimen upon receipt. Clotted specimens may yield insufficient DNA or introduce bias in cell-free DNA assays.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the specimen was collected from the patient. Critical for calculating turnaround time (TAT) and pre-analytical stability assessment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionSite rdf:type rdf:Property ;
    rdfs:label 'Collection Site' ;
    rdfs:comment 'Name or identifier of the clinical facility, hospital, or physician office where the specimen was collected. Used for quality tracking and logistics analysis.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCliaNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Site Clia Number' ;
    rdfs:comment 'CLIA certification number of the collection site if applicable. Required for regulatory compliance when collection site is a certified laboratory.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTime rdf:type rdf:Property ;
    rdfs:label 'Collection Time' ;
    rdfs:comment 'Precise timestamp when the specimen was collected from the patient. Used for time-sensitive pre-analytical quality assessments and cfDNA stability calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Boolean flag indicating whether informed consent was obtained from the patient for genomic testing and data use. Required for compliance with IRB protocols and GDPR.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of collection container or tube used for specimen transport. Examples: EDTA tube, PAXgene tube, Streck tube, OMNIgene tube, formalin jar. Impacts pre-analytical quality and DNA/RNA stability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preanalyticalQcStatus rdf:type rdf:Property ;
    rdfs:label 'Preanalytical Qc Status' ;
    rdfs:comment 'Overall pre-analytical quality control assessment status. Indicates whether specimen meets quality thresholds for downstream testing (Phred Score, DIN, RIN, hemolysis, clotting).' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Quantity of specimen received by the laboratory. May differ from collected volume due to aliquoting or partial submission. Unit depends on specimen type (ml for liquid, mg for tissue).' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the specimen quantity. Varies by specimen type: ml for blood/saliva, mg for tissue, ug for extracted DNA/RNA, cells for cell suspensions, slides for FFPE.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the specimen was received and accessioned by the clinical laboratory. Start point for laboratory TAT calculations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise timestamp when the specimen was received and logged into the LIMS. Used for chain-of-custody documentation and pre-analytical time tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason for specimen rejection if QC failed or specimen was deemed unsuitable for testing. Examples: insufficient volume, hemolyzed, mislabeled, expired transport time. Null if specimen was accepted.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceAnatomicalSite rdf:type rdf:Property ;
    rdfs:label 'Source Anatomical Site' ;
    rdfs:comment 'Anatomical site or body location from which the specimen was collected. Examples: peripheral blood, bone marrow, lung tissue, colon biopsy. Critical for pathology correlation and variant interpretation.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenStatus rdf:type rdf:Property ;
    rdfs:label 'Specimen Status' ;
    rdfs:comment 'Current state of the specimen in the clinical laboratory workflow. Tracks progression from receipt through testing to final disposition.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Current storage temperature and condition for the specimen. Critical for maintaining specimen integrity and meeting pre-analytical quality requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage location identifier within the laboratory (freezer ID, shelf, box, position). Used for specimen retrieval and inventory management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCollectedMl rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Ml' ;
    rdfs:comment 'Volume of specimen collected in milliliters. Critical for determining sufficiency for testing and for calculating input quantities for library preparation.' ;
    rdfs:domain ind:ClinicalSpecimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geneticCounselingSessionId rdf:type rdf:Property ;
    rdfs:label 'Genetic Counseling Session Id' ;
    rdfs:comment 'Unique identifier for the genetic counseling session record.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Protocol Controlled Document Id' ;
    rdfs:comment 'Foreign key linking to quality.controlled_document. Business justification: Genetic counseling sessions must follow documented protocols (informed consent scripts, disclosure procedures, ACMG secondary findings policies, psychosocial support guidelines). Required for CLIA/CAP' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition. Business justification: Genetic counseling sessions are billable professional services requiring separate revenue recognition from laboratory testing per ASC 606. Link enables service revenue accounting, performance obligati' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:billingCode rdf:type rdf:Property ;
    rdfs:label 'Billing Code' ;
    rdfs:comment 'CPT or HCPCS billing code associated with the genetic counseling session for reimbursement purposes.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cascadeScreeningRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Cascade Screening Recommended Flag' ;
    rdfs:comment 'Indicates whether cascade screening of at-risk family members was recommended based on the findings discussed in this session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counselorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Counselor Certification Number' ;
    rdfs:comment 'Professional certification number of the genetic counselor, typically issued by the American Board of Genetic Counseling (ABGC) or equivalent certifying body.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counselorName rdf:type rdf:Property ;
    rdfs:label 'Counselor Name' ;
    rdfs:comment 'Full name of the genetic counselor who conducted the session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyMembersPresent rdf:type rdf:Property ;
    rdfs:label 'Family Members Present' ;
    rdfs:comment 'Description of family members or support persons present during the counseling session, including their relationship to the patient.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActions rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions' ;
    rdfs:comment 'Documented follow-up actions required or recommended, including additional testing, family cascade screening, surveillance protocols, or repeat counseling sessions.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentalFindingIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Incidental Finding Identified Flag' ;
    rdfs:comment 'Indicates whether an incidental or secondary genomic finding was identified and discussed during this session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientNotificationPreference rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Preference' ;
    rdfs:comment 'Patient\'s documented preference regarding notification of secondary or incidental genomic findings, captured during informed consent or counseling.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientUnderstandingAssessment rdf:type rdf:Property ;
    rdfs:label 'Patient Understanding Assessment' ;
    rdfs:comment 'Genetic counselor\'s assessment of the patient\'s comprehension of the information presented during the session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psychosocialSupportProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Psychosocial Support Provided Flag' ;
    rdfs:comment 'Indicates whether psychosocial support or counseling was provided to address emotional, psychological, or social concerns related to genetic testing or results.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralRecommendations rdf:type rdf:Property ;
    rdfs:label 'Referral Recommendations' ;
    rdfs:comment 'Clinical referrals recommended by the genetic counselor, such as referrals to medical genetics specialists, oncologists, cardiologists, or other healthcare providers for further evaluation and management.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDecision rdf:type rdf:Property ;
    rdfs:label 'Reporting Decision' ;
    rdfs:comment 'Decision made regarding whether the secondary or incidental finding will be formally reported to the patient, based on clinical actionability, patient preference, and laboratory policy.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryFindingCategory rdf:type rdf:Property ;
    rdfs:label 'Secondary Finding Category' ;
    rdfs:comment 'Category of secondary or incidental finding identified, such as ACMG SF v3.2 gene list findings, pharmacogenomic variants, or carrier status for recessive conditions. [ENUM-REF-CANDIDATE: ACMG SF v3.2 gene|pharmacogenomic|carrier status|cancer predisposition|cardiovascular condition|metabolic disorder|other — promote to reference product]' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'Date on which the genetic counseling session was conducted or scheduled.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Minutes' ;
    rdfs:comment 'Total duration of the genetic counseling session measured in minutes.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Precise date and time when the genetic counseling session concluded.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionLocation rdf:type rdf:Property ;
    rdfs:label 'Session Location' ;
    rdfs:comment 'Physical location or facility where the in-person genetic counseling session was conducted, or platform used for telehealth sessions.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionModality rdf:type rdf:Property ;
    rdfs:label 'Session Modality' ;
    rdfs:comment 'Mode of delivery for the genetic counseling session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Detailed clinical notes documenting the content, discussions, patient questions, counselor observations, and outcomes of the genetic counseling session. Contains Protected Health Information (PHI).' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Business identifier for the counseling session, typically formatted as a sequential or structured code for tracking and reference.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Precise date and time when the genetic counseling session began.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the genetic counseling session.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Type of genetic counseling session conducted. Pre-test counseling occurs before testing to discuss implications and consent; post-test counseling reviews results; result disclosure communicates findings; family planning addresses reproductive implications; incidental and secondary finding reviews address unexpected genomic discoveries per ACMG guidelines.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicsCovered rdf:type rdf:Property ;
    rdfs:label 'Topics Covered' ;
    rdfs:comment 'Comprehensive list or narrative of topics discussed during the genetic counseling session, including inheritance patterns, disease risk, testing options, result interpretation, and psychosocial implications.' ;
    rdfs:domain ind:GeneticCounselingSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantHgvsNotation rdf:type rdf:Property ;
    rdfs:label 'Variant Hgvs Notation' ;
    rdfs:comment 'Standardized HGVS notation describing the genomic variant associated with the secondary or incidental finding discussed in this session.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicResultId rdf:type rdf:Property ;
    rdfs:label 'Genomic Result Id' ;
    rdfs:comment 'Unique identifier for the genomic result record. Primary key for patient-level genomic findings generated from clinical assay runs.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variantKnowledgeBaseId rdf:type rdf:Property ;
    rdfs:label 'Variant Knowledge Base Id' ;
    rdfs:comment 'Foreign key linking to clinical.variant_knowledge_base. Business justification: When a genomic result identifies a clinically significant variant, it should link to the curated internal knowledge base entry for that variant (if one exists). This provides access to historical obse' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VariantKnowledgeBase .

ind:acmgClassificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification Criteria' ;
    rdfs:comment 'ACMG/AMP evidence codes applied during variant interpretation (e.g., PVS1, PS1, PM2, PP3). Documents the rationale for clinical significance classification.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseAssociation rdf:type rdf:Property ;
    rdfs:label 'Disease Association' ;
    rdfs:comment 'Known disease or phenotype associations for this variant. References conditions linked to the genetic finding.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterStatus rdf:type rdf:Property ;
    rdfs:label 'Filter Status' ;
    rdfs:comment 'Quality filter status applied during variant calling. PASS indicates the variant met all quality thresholds.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genomicPositionEnd rdf:type rdf:Property ;
    rdfs:label 'Genomic Position End' ;
    rdfs:comment 'Ending chromosomal coordinate of the variant in base pairs. For single nucleotide variants, equals start position. Uses GRCh38 reference genome coordinates.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genomicPositionStart rdf:type rdf:Property ;
    rdfs:label 'Genomic Position Start' ;
    rdfs:comment 'Starting chromosomal coordinate of the variant in base pairs. Uses GRCh38 reference genome coordinates.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentalFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Incidental Finding Flag' ;
    rdfs:comment 'Indicates whether this result is an incidental or secondary finding not directly related to the primary test indication. Important for patient consent and reporting workflows.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mafGnomad rdf:type rdf:Property ;
    rdfs:label 'Maf Gnomad' ;
    rdfs:comment 'Minor allele frequency of this variant in the gnomAD population database. Indicates how common the variant is in the general population.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacogenomicImplication rdf:type rdf:Property ;
    rdfs:label 'Pharmacogenomic Implication' ;
    rdfs:comment 'Clinical pharmacogenomic guidance associated with this variant. Describes drug response, dosing recommendations, or contraindications. Protected Health Information (PHI).' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phredQualityScore rdf:type rdf:Property ;
    rdfs:label 'Phred Quality Score' ;
    rdfs:comment 'Phred-scaled quality score for the variant call. Higher scores indicate greater confidence in the accuracy of the call.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Date' ;
    rdfs:comment 'Date when the genomic result was officially reported to the ordering physician or patient. Key milestone for turnaround time (TAT) tracking.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultInterpretation rdf:type rdf:Property ;
    rdfs:label 'Result Interpretation' ;
    rdfs:comment 'Clinical interpretation narrative provided by the laboratory director or genetic counselor. Explains the clinical significance of the finding. Protected Health Information (PHI).' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultType rdf:type rdf:Property ;
    rdfs:label 'Result Type' ;
    rdfs:comment 'Classification of the genomic finding. Indicates the category of variant or genetic marker detected by the clinical assay.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'The primary genomic finding value. Format varies by result type: genotype call (e.g., A/G), copy number (e.g., 3), variant notation (e.g., c.1234G>A). Protected Health Information (PHI).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantAlleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Variant Allele Frequency' ;
    rdfs:comment 'Fraction of sequencing reads supporting the alternate allele at this position. Used to assess variant heterogeneity and quality.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantClassification rdf:type rdf:Property ;
    rdfs:label 'Variant Classification' ;
    rdfs:comment 'Functional classification of the variant based on its predicted impact on the gene product. [ENUM-REF-CANDIDATE: missense|nonsense|frameshift|splice_site|synonymous|intronic|utr|intergenic — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Variant Database Version' ;
    rdfs:comment 'Version identifier of the variant annotation databases (ClinVar, gnomAD, dbSNP) used for interpretation. Critical for result reproducibility.' ;
    rdfs:domain ind:GenomicResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentalFindingId rdf:type rdf:Property ;
    rdfs:label 'Incidental Finding Id' ;
    rdfs:comment 'Unique identifier for the incidental finding record. Primary key for this entity.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acmgClassificationRuleId rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification Rule Id' ;
    rdfs:comment 'Foreign key linking to reference.acmg_classification_rule. Business justification: Documents ACMG evidence codes applied to incidental findings classification. Required for clinical validation, patient notification decisions, and regulatory compliance. Links classification to struct' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcmgClassificationRule .

ind:policyControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Policy Controlled Document Id' ;
    rdfs:comment 'Foreign key linking to quality.controlled_document. Business justification: Incidental finding reporting decisions must reference the specific version of ACMG Secondary Findings policy (v2.0, v3.0, v3.2) used. Regulatory and ethical requirement for defensibility of disclosure' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:primaryIncidentalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Incidental Employee Id' ;
    rdfs:comment 'Reference to the genetic counselor assigned to discuss this incidental finding with the patient. Required for reportable findings per ACMG recommendations.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryIncidentalApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Incidental Approved By User Employee Id' ;
    rdfs:comment 'Reference to the laboratory director or designee who approved and signed out the incidental finding report.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryIncidentalReviewedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Incidental Reviewed By User Employee Id' ;
    rdfs:comment 'Reference to the laboratory professional who performed peer review of the variant interpretation.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:associatedCondition rdf:type rdf:Property ;
    rdfs:label 'Associated Condition' ;
    rdfs:comment 'Medical condition or disease associated with this incidental finding. Examples include hereditary breast and ovarian cancer syndrome, Lynch syndrome, familial hypercholesterolemia.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Clinical Action Recommended' ;
    rdfs:comment 'Free-text description of recommended clinical actions based on this incidental finding, such as enhanced surveillance, prophylactic interventions, or specialist referral.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceSummary rdf:type rdf:Property ;
    rdfs:label 'Evidence Summary' ;
    rdfs:comment 'Summary of clinical and scientific evidence supporting the variant classification, including references to published literature, functional studies, and population data.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyCascadeRecommended rdf:type rdf:Property ;
    rdfs:label 'Family Cascade Recommended' ;
    rdfs:comment 'Indicates whether cascade testing of at-risk family members is recommended based on the clinical significance and inheritance pattern of this finding.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Category of incidental finding identified. ACMG secondary finding refers to medically actionable genes per ACMG SF v3.2 list; pharmacogenomic refers to drug-gene interactions; carrier status refers to recessive disease alleles.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which the incidental finding was first identified during bioinformatics analysis or variant interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interpretationStatus rdf:type rdf:Property ;
    rdfs:label 'Interpretation Status' ;
    rdfs:comment 'Current status of the variant interpretation workflow for this incidental finding. Draft indicates initial interpretation; reviewed indicates peer review complete; approved indicates sign-out by laboratory director; amended indicates post-release update.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientConsentPreference rdf:type rdf:Property ;
    rdfs:label 'Patient Consent Preference' ;
    rdfs:comment 'Patient preference for receiving incidental findings as documented in informed consent. Receive all indicates patient wants all secondary findings; receive actionable only limits to medically actionable findings; decline all indicates patient opted out.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Date' ;
    rdfs:comment 'Date on which the patient was notified of the incidental finding, typically through genetic counseling session or clinical consultation. Null if patient has not yet been notified.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Phred-scaled quality score for the variant call. Higher scores indicate greater confidence in the variant call.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date on which the incidental finding was reported to the patient and ordering physician. Null if reporting decision is do not report.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRationale rdf:type rdf:Property ;
    rdfs:label 'Reporting Rationale' ;
    rdfs:comment 'Free-text explanation of the rationale for the reporting decision, including consideration of patient consent, clinical actionability, and laboratory policy.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantAlleleFraction rdf:type rdf:Property ;
    rdfs:label 'Variant Allele Fraction' ;
    rdfs:comment 'Fraction of sequencing reads supporting the alternate allele at the variant position. Expected to be approximately 0.5 for heterozygous germline variants and 1.0 for homozygous variants.' ;
    rdfs:domain ind:IncidentalFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Foreign key linking to commercial.lead. Business justification: Research institutions and clinical sites often start as leads before becoming patients/sample sources. Tracking lead-to-patient conversion is critical for commercial effectiveness measurement and unde' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the patient. Used for clinical report mailing, specimen collection coordination, and patient identification. Subject to HIPAA PHI geographic subdivision restrictions for de-identification.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number. Optional field used for complete patient address information.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biologicalSex rdf:type rdf:Property ;
    rdfs:label 'Biological Sex' ;
    rdfs:comment 'Biological sex of the patient as recorded for clinical genomic testing purposes. Critical for sex-chromosome analysis (X/Y), X-linked variant interpretation, and assay-specific quality control. Distinct from gender identity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of patient residence. Used for clinical report delivery and geographic analysis of patient populations. Subject to HIPAA de-identification rules for populations under 20,000.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Patient\'s preferred method for receiving clinical reports and test result notifications. Used to respect patient communication preferences and ensure HIPAA-compliant delivery of Protected Health Information (PHI).' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of patient residence. Used for international clinical report delivery, regulatory compliance tracking, and cross-border genomic data sharing governance.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the patient. Critical for patient identification, age-based clinical interpretation of genomic variants, pediatric vs adult assay selection, and HIPAA-compliant de-identification workflows. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deIdentificationFlag rdf:type rdf:Property ;
    rdfs:label 'De Identification Flag' ;
    rdfs:comment 'Boolean flag indicating whether this patient record has been de-identified according to HIPAA Safe Harbor or Expert Determination methods. True indicates PHI has been removed for research or secondary use. Critical for genomic data sharing and research applications.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Self-reported ethnicity of the patient. Used for population-specific genomic variant interpretation, ancestry-based allele frequency assessment, and precision medicine applications. Complements race data for clinical genomics analysis.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Rights Flag' ;
    rdfs:comment 'Boolean flag indicating whether patient has exercised GDPR data subject rights (right to access, rectification, erasure, restriction, portability, or objection). True indicates active data subject request requiring special handling.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Self-identified gender of the patient. Used for patient communication preferences and respectful clinical interactions. Distinct from biological sex used for genomic analysis.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianEmail rdf:type rdf:Property ;
    rdfs:label 'Guardian Email' ;
    rdfs:comment 'Email address for the patient\'s guardian or healthcare proxy. Used for secure clinical report delivery and communication when patient cannot receive reports directly.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianName rdf:type rdf:Property ;
    rdfs:label 'Guardian Name' ;
    rdfs:comment 'Full name of legal guardian or healthcare proxy authorized to make decisions on behalf of the patient. Required for pediatric patients and patients lacking decision-making capacity. Used for consent documentation and clinical report delivery.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPhone rdf:type rdf:Property ;
    rdfs:label 'Guardian Phone' ;
    rdfs:comment 'Primary contact phone number for the patient\'s guardian or healthcare proxy. Used for clinical report delivery, critical result communication, and consent verification when patient cannot be reached directly.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRelationship rdf:type rdf:Property ;
    rdfs:label 'Guardian Relationship' ;
    rdfs:comment 'Type of relationship between the guardian/proxy and the patient. Used to verify legal authority for consent and clinical decision-making in pediatric and incapacitated patient cases.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Flag' ;
    rdfs:comment 'Boolean flag indicating whether patient has provided HIPAA authorization for use and disclosure of Protected Health Information (PHI) for clinical genomic testing and research purposes. True indicates authorization granted.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceGroupNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Group Number' ;
    rdfs:comment 'Group number associated with the patient\'s health insurance policy. Used for insurance verification and claims processing for clinical genomic testing services.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Patient\'s health insurance policy or member identification number. Used for insurance verification, prior authorization, and claims submission for clinical genomic testing. Subject to HIPAA PHI controls.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Insurance Provider' ;
    rdfs:comment 'Name of the patient\'s primary health insurance provider. Used for billing, prior authorization, and reimbursement workflows for clinical genomic testing services.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or system account that last modified the patient record. Used for audit trails, accountability tracking, and regulatory compliance verification. Not patient PII.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrn rdf:type rdf:Property ;
    rdfs:label 'Mrn' ;
    rdfs:comment 'Medical Record Number assigned by the healthcare institution. Unique patient identifier used across clinical systems for patient identification and record linkage. Critical for specimen tracking and clinical report delivery.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Status' ;
    rdfs:comment 'Current lifecycle status of the patient record. Active indicates patient is eligible for new test orders. Inactive indicates patient has not had recent activity. Deceased triggers special handling for posthumous data access. Merged indicates record consolidated with another MRN.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of patient residence. Used for clinical report delivery and geographic analysis. Subject to HIPAA de-identification rules requiring aggregation to first 3 digits for populations under 20,000.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Preferred language for patient communication and clinical report delivery. Used to ensure culturally competent care and compliance with language access requirements. ISO 639-1 two-letter language codes recommended.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary contact phone number for the patient. Used for clinical report delivery notifications, critical result communication, and patient consent verification. Subject to HIPAA PHI controls.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:race rdf:type rdf:Property ;
    rdfs:label 'Race' ;
    rdfs:comment 'Self-reported race of the patient. Used for population-specific variant frequency analysis, ancestry-informed variant interpretation, and clinical genomics research. Critical for accurate Minor Allele Frequency (MAF) assessment and pathogenicity classification.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Referring Physician Name' ;
    rdfs:comment 'Name of the physician or healthcare provider who referred the patient for clinical genomic testing. Used for clinical report delivery, result interpretation consultation, and billing. Not classified as patient PII.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referringPhysicianNpi rdf:type rdf:Property ;
    rdfs:label 'Referring Physician Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the referring physician. 10-digit unique identifier used for healthcare provider identification, clinical report routing, and billing compliance. Required for CLIA-compliant test reporting.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Research Participation Flag' ;
    rdfs:comment 'Boolean flag indicating whether patient has consented to participate in genomic research studies. True indicates patient data and specimens may be used for IRB-approved research beyond clinical care. Distinct from clinical testing consent.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Phone' ;
    rdfs:comment 'Alternate contact phone number for the patient. Used as backup communication channel for clinical report delivery and critical result notifications.' ;
    rdfs:domain ind:Patient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of patient residence. Used for clinical report delivery, regulatory compliance tracking, and state-specific Laboratory Developed Test (LDT) requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pgxReportId rdf:type rdf:Property ;
    rdfs:label 'Pgx Report Id' ;
    rdfs:comment 'Unique identifier for the pharmacogenomics clinical report record. Primary key for this entity.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guidelineControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Guideline Controlled Document Id' ;
    rdfs:comment 'Foreign key linking to quality.controlled_document. Business justification: Pharmacogenomics reports must reference the specific version of CPIC/PharmGKB guidelines used for drug-gene interaction interpretation. Regulatory requirement for clinical decision support and defensi' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:primaryPgxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Pgx Employee Id' ;
    rdfs:comment 'Reference to the board-certified pathologist or clinical geneticist who authorized and signed this report.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Report Amendment Id' ;
    rdfs:comment 'Reference to the report amendment record if this report has been amended or corrected.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportAmendment .

ind:actionableRecommendationCount rdf:type rdf:Property ;
    rdfs:label 'Actionable Recommendation Count' ;
    rdfs:comment 'Number of actionable prescribing recommendations provided in this report based on pharmacogenomic findings.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cliaCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Certificate Number' ;
    rdfs:comment 'CLIA certificate number of the laboratory that performed the pharmacogenomic testing.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalDecisionSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Decision Support Flag' ;
    rdfs:comment 'Indicates whether this report has been integrated into electronic health record clinical decision support systems.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpicGuidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Cpic Guideline Version' ;
    rdfs:comment 'Version of CPIC guidelines used for interpretation and recommendation generation in this report.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugGeneInteractionCount rdf:type rdf:Property ;
    rdfs:label 'Drug Gene Interaction Count' ;
    rdfs:comment 'Total number of clinically significant drug-gene interactions identified in this report.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ehrIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Ehr Integration Status' ;
    rdfs:comment 'Status of integration of pharmacogenomic results into the patient\'s electronic health record system.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genePanelTested rdf:type rdf:Property ;
    rdfs:label 'Gene Panel Tested' ;
    rdfs:comment 'Comma-separated list of pharmacogenes analyzed in this report (e.g., CYP2D6, CYP2C19, SLCO1B1, VKORC1).' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highRiskDrugList rdf:type rdf:Property ;
    rdfs:label 'High Risk Drug List' ;
    rdfs:comment 'Comma-separated list of medications for which the patient has high-risk pharmacogenomic variants requiring dose adjustment or alternative therapy.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metabolizerPhenotypeSummary rdf:type rdf:Property ;
    rdfs:label 'Metabolizer Phenotype Summary' ;
    rdfs:comment 'Summary of predicted metabolizer phenotypes (e.g., poor metabolizer, intermediate metabolizer, normal metabolizer, rapid metabolizer, ultrarapid metabolizer) for all tested genes.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmgkbEvidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Pharmgkb Evidence Level' ;
    rdfs:comment 'Highest PharmGKB evidence level for drug-gene interactions reported, indicating strength of clinical evidence (1A=highest, 4=lowest).' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmvarDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Pharmvar Database Version' ;
    rdfs:comment 'Version of the PharmVar database used for star allele nomenclature and haplotype assignment.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescribingRecommendationSummary rdf:type rdf:Property ;
    rdfs:label 'Prescribing Recommendation Summary' ;
    rdfs:comment 'Executive summary of key prescribing recommendations for ordering clinicians, including dose adjustments, alternative medications, and monitoring guidance.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Delivered Timestamp' ;
    rdfs:comment 'Date and time when the report was delivered to the ordering clinician or healthcare system.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportFinalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Finalized Timestamp' ;
    rdfs:comment 'Date and time when the report was finalized and authorized for clinical use.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Generated Timestamp' ;
    rdfs:comment 'Date and time when the pharmacogenomics report was initially generated by the bioinformatics pipeline.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportLanguage rdf:type rdf:Property ;
    rdfs:label 'Report Language' ;
    rdfs:comment 'ISO 639-3 language code indicating the language in which the report is written.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the pharmacogenomics report based on scope and clinical indication.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Version number of this report, incremented when amendments or corrections are issued.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starAlleleDiplotypeSummary rdf:type rdf:Property ;
    rdfs:label 'Star Allele Diplotype Summary' ;
    rdfs:comment 'Summary of star allele and diplotype calls for all tested pharmacogenes, formatted as gene:diplotype pairs.' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingMethodology rdf:type rdf:Property ;
    rdfs:label 'Testing Methodology' ;
    rdfs:comment 'Laboratory methodology used for pharmacogenomic variant detection (e.g., NGS, array-based genotyping, PCR).' ;
    rdfs:domain ind:PgxReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingId rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Id' ;
    rdfs:comment 'Unique identifier for the proficiency testing event record.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Reference identifier linking to the corrective action plan or CAPA record initiated in response to unsatisfactory PT results.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Foreign key linking to order.order_header. Business justification: Proficiency testing sample sets are purchased products from PT providers (CAP, EMQN). Linking PT records to procurement orders enables compliance spend tracking, vendor management, and regulatory audi' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:performingLaboratoryId rdf:type rdf:Property ;
    rdfs:label 'Performing Laboratory Id' ;
    rdfs:comment 'Identifier of the laboratory location or facility that performed the proficiency testing.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformingLaboratory .

ind:primaryProficiencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Proficiency Employee Id' ;
    rdfs:comment 'Identifier of the laboratory personnel who performed the PT testing.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ptSupplierId rdf:type rdf:Property ;
    rdfs:label 'Pt Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: PT samples are purchased from external PT program suppliers (CAP, EMQN, etc.); tracking supplier enables procurement management, performance correlation with supplier quality, and regulatory complianc' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:quaternaryProficiencyLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Proficiency Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the proficiency testing record.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryProficiencyCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Proficiency Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created the proficiency testing record.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptablePerformanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Acceptable Performance Threshold' ;
    rdfs:comment 'Minimum score percentage required for satisfactory performance as defined by the PT program.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyteCode rdf:type rdf:Property ;
    rdfs:label 'Analyte Code' ;
    rdfs:comment 'Standardized code for the analyte or test method being assessed (e.g., CLIA analyte code, CAP test code).' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Date the corrective action plan was completed and verified.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required following unsatisfactory PT performance (True/False).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date the laboratory enrolled in the proficiency testing event.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Period' ;
    rdfs:comment 'The enrollment period or cycle identifier for the PT event (e.g., 2024-Q1, 2024-Survey-A).' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingOutcome rdf:type rdf:Property ;
    rdfs:label 'Grading Outcome' ;
    rdfs:comment 'Overall grading outcome assigned by the PT program: satisfactory, unsatisfactory, pending review, or not graded.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingReportReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Grading Report Received Date' ;
    rdfs:comment 'Date the laboratory received the grading report from the PT program provider.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfChallengesCorrect rdf:type rdf:Property ;
    rdfs:label 'Number Of Challenges Correct' ;
    rdfs:comment 'Number of PT challenges or samples for which the laboratory provided correct results.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfChallengesIncorrect rdf:type rdf:Property ;
    rdfs:label 'Number Of Challenges Incorrect' ;
    rdfs:comment 'Number of PT challenges or samples for which the laboratory provided incorrect results.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfSamples rdf:type rdf:Property ;
    rdfs:label 'Number Of Samples' ;
    rdfs:comment 'Total number of samples or challenges included in the PT sample set.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptDocumentationLocation rdf:type rdf:Property ;
    rdfs:label 'Pt Documentation Location' ;
    rdfs:comment 'File path, document management system reference, or physical location where PT records and supporting documentation are stored.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptEventType rdf:type rdf:Property ;
    rdfs:label 'Pt Event Type' ;
    rdfs:comment 'Type of external quality assessment event: proficiency testing (formal PT), alternative assessment (AA), or inter-laboratory comparison.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptProgramCode rdf:type rdf:Property ;
    rdfs:label 'Pt Program Code' ;
    rdfs:comment 'Standardized code or identifier assigned by the PT program provider to uniquely identify the program.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date regulatory authorities were notified of unsatisfactory PT results, if applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether unsatisfactory PT results must be reported to regulatory authorities (e.g., CMS, state health department) per CLIA requirements (True/False).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Results Submitted Date' ;
    rdfs:comment 'Date the laboratory submitted PT results to the program provider.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date the PT results and grading report were reviewed by the laboratory director or technical supervisor.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date the proficiency testing sample set was received by the laboratory.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sample Set Identifier' ;
    rdfs:comment 'Unique identifier for the PT sample set or challenge set received by the laboratory.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorePercentage rdf:type rdf:Property ;
    rdfs:label 'Score Percentage' ;
    rdfs:comment 'Numerical score achieved by the laboratory expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Compliance Status' ;
    rdfs:comment 'Indicates whether PT results were submitted on time, late, or not submitted by the deadline.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Deadline date by which PT results must be submitted to the program provider.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testSystemEvaluated rdf:type rdf:Property ;
    rdfs:label 'Test System Evaluated' ;
    rdfs:comment 'The specific test system, assay, or analyte being evaluated in this PT event (e.g., WGS variant calling, SNP genotyping, CNV detection).' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Testing Completed Date' ;
    rdfs:comment 'Date the laboratory completed testing of the PT samples.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unsatisfactoryReason rdf:type rdf:Property ;
    rdfs:label 'Unsatisfactory Reason' ;
    rdfs:comment 'Detailed explanation or root cause for unsatisfactory PT performance, if applicable.' ;
    rdfs:domain ind:ProficiencyTesting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalReportId rdf:type rdf:Property ;
    rdfs:label 'Original Report Id' ;
    rdfs:comment 'Reference to the original finalized clinical report that is being amended. Links to the clinical report entity.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Report .

ind:primaryReportEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Report Employee Id' ;
    rdfs:comment 'Reference to the board-certified pathologist or laboratory director who reviewed and authorized the amendment.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendedContentSummary rdf:type rdf:Property ;
    rdfs:label 'Amended Content Summary' ;
    rdfs:comment 'High-level summary of what content was changed in the report, such as variant classification, clinical interpretation, test results, or patient demographics.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedReportVersion rdf:type rdf:Property ;
    rdfs:label 'Amended Report Version' ;
    rdfs:comment 'Version number of the amended report in format vX.Y where X is major version and Y is amendment sequence (e.g., v1.1 for first amendment, v1.2 for second).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment in format AMD-YYYYMMDD-NNN where NNN is the sequential amendment number for that report.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the amendment: lab_error (testing or processing mistake), variant_reclassification (updated pathogenicity classification), new_clinical_evidence (new research findings), transcription_error (clerical mistake), interpretation_update (refined clinical interpretation), technical_issue (instrument or reagent problem).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the amendment was necessary, including specific circumstances, errors identified, or new information that prompted the change.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment: draft (being prepared), pending_review (awaiting pathologist approval), approved (authorized but not yet distributed), issued (sent to ordering physician), cancelled (voided before issuance).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amendment Timestamp' ;
    rdfs:comment 'Precise date and time when the amendment was issued, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clinicalSignificanceChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Significance Change Flag' ;
    rdfs:comment 'Indicates whether the amendment resulted in a change to the clinical significance or actionability of the findings that may impact patient care.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctedFinding rdf:type rdf:Property ;
    rdfs:label 'Corrected Finding' ;
    rdfs:comment 'The new or corrected content that replaces the original finding in the amended report.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of corrective actions implemented to prevent recurrence of the error that necessitated the amendment.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingPhysicianNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ordering Physician Notification Status' ;
    rdfs:comment 'Status of notification to the ordering physician: pending (not yet sent), notified (amendment sent), acknowledged (physician confirmed receipt), failed (delivery unsuccessful).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFinding rdf:type rdf:Property ;
    rdfs:label 'Original Finding' ;
    rdfs:comment 'The original content or finding from the report that is being amended, captured for audit trail and comparison purposes.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalVariantClassification rdf:type rdf:Property ;
    rdfs:label 'Original Variant Classification' ;
    rdfs:comment 'The original ACMG/AMP variant classification before the amendment, if applicable.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Required Flag' ;
    rdfs:comment 'Indicates whether direct patient notification is required based on the clinical significance of the amendment and institutional policy.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Patient Notification Status' ;
    rdfs:comment 'Status of direct patient notification if required: not_required (no direct notification needed), pending (notification planned), notified (patient informed), acknowledged (patient confirmed receipt).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Physician Notification Date' ;
    rdfs:comment 'Date when the ordering physician was notified of the amended report.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicianNotificationMethod rdf:type rdf:Property ;
    rdfs:label 'Physician Notification Method' ;
    rdfs:comment 'Method used to notify the ordering physician of the amendment: EHR integration, secure email, fax, phone call, postal mail, or patient portal.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the amendment was reported to regulatory authorities, if required.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this amendment must be reported to regulatory authorities (FDA, state health departments) due to the nature of the error or clinical impact.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedVariantClassification rdf:type rdf:Property ;
    rdfs:label 'Revised Variant Classification' ;
    rdfs:comment 'The updated ACMG/AMP variant classification after the amendment, if applicable.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed Flag' ;
    rdfs:comment 'Indicates whether a formal root cause analysis was conducted to identify the underlying cause of the error requiring amendment.' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level category of the root cause identified: human error, equipment failure, reagent issue, process failure, software error, or communication breakdown.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantReclassificationFlag rdf:type rdf:Property ;
    rdfs:label 'Variant Reclassification Flag' ;
    rdfs:comment 'Indicates whether this amendment involves a change in variant pathogenicity classification (e.g., from Variant of Uncertain Significance to Pathogenic).' ;
    rdfs:domain ind:ReportAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testCatalogId rdf:type rdf:Property ;
    rdfs:label 'Test Catalog Id' ;
    rdfs:comment 'Primary key for test_catalog' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCatalog .

ind:primaryMaterialId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: IVD test catalog entries specify primary reagent kit/material required for each assay. Enables procurement planning, inventory management, test costing, and regulatory traceability of material specifi' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:processValidationId rdf:type rdf:Property ;
    rdfs:label 'Process Validation Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.process_validation. Business justification: FDA QSR requires process validation for IVD manufacturing. Test catalog must reference validation protocols to demonstrate analytical performance claims are supported by validated manufacturing proces' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcessValidation .

ind:productSkuId rdf:type rdf:Property ;
    rdfs:label 'Product Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: IVD test catalog items are commercial products that should reference the product catalog. This enables pricing, ordering, and inventory management for clinical test kits. The test_code becomes redunda' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:productionRoutingId rdf:type rdf:Property ;
    rdfs:label 'Production Routing Id' ;
    rdfs:comment 'Foreign key linking to manufacturing.production_routing. Business justification: IVD test kits are manufactured products requiring validated production routings for GMP compliance (21 CFR Part 820). Links test catalog entries to their manufacturing process definitions for regulato' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionRouting .

ind:analyticalSensitivityPercent rdf:type rdf:Property ;
    rdfs:label 'Analytical Sensitivity Percent' ;
    rdfs:comment 'Analytical performance metric: percentage of true positive results correctly identified by the assay (true positive rate).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyticalSpecificityPercent rdf:type rdf:Property ;
    rdfs:label 'Analytical Specificity Percent' ;
    rdfs:comment 'Analytical performance metric: percentage of true negative results correctly identified by the assay (true negative rate).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assayVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Assay Version Number' ;
    rdfs:comment 'Version identifier for the assay configuration (e.g., v1.0, v2.1). Incremented when assay parameters, panel content, or pipeline change.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capAccreditationFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Accreditation Flag' ;
    rdfs:comment 'Indicates whether the test is performed in a CAP-accredited laboratory. True=CAP accredited, False=not CAP accredited.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalValidityEvidence rdf:type rdf:Property ;
    rdfs:label 'Clinical Validity Evidence' ;
    rdfs:comment 'Summary of evidence supporting the clinical validity of the test (e.g., peer-reviewed publications, clinical trial data, professional guidelines).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptCode rdf:type rdf:Property ;
    rdfs:label 'Cpt Code' ;
    rdfs:comment 'Five-digit CPT billing code used for reimbursement and insurance claims for the clinical test.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intendedUseCategory rdf:type rdf:Property ;
    rdfs:label 'Intended Use Category' ;
    rdfs:comment 'Regulatory classification of the test. IVD=In Vitro Diagnostic (FDA-cleared or CE-marked for clinical use), RUO=Research Use Only (not for clinical decision-making), LDT=Laboratory Developed Test (CLIA-validated for clinical use).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitOfDetection rdf:type rdf:Property ;
    rdfs:label 'Limit Of Detection' ;
    rdfs:comment 'Analytical performance metric: the lowest quantity of analyte that can be reliably detected. Expressed with units (e.g., 5% variant allele frequency, 10 copies/mL).' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingPhysicianSpecialty rdf:type rdf:Property ;
    rdfs:label 'Ordering Physician Specialty' ;
    rdfs:comment 'Target physician specialties for which this test is intended (e.g., Medical Oncology, Genetic Counseling, Cardiology, Pediatrics). Multiple specialties may be listed.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUsd rdf:type rdf:Property ;
    rdfs:label 'Price Usd' ;
    rdfs:comment 'List price of the clinical test in USD. Used for quotations, billing, and revenue recognition.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reflexTestingRules rdf:type rdf:Property ;
    rdfs:label 'Reflex Testing Rules' ;
    rdfs:comment 'Conditional logic for automatic follow-up testing based on initial results (e.g., if variant detected in gene X, reflex to confirmatory Sanger sequencing).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Eligible Flag' ;
    rdfs:comment 'Indicates whether the test is eligible for insurance reimbursement. True=eligible, False=not eligible (patient pay only).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDescription rdf:type rdf:Property ;
    rdfs:label 'Test Description' ;
    rdfs:comment 'Detailed description of the clinical assay, including methodology, clinical indications, and intended use statement.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMenuCategory rdf:type rdf:Property ;
    rdfs:label 'Test Menu Category' ;
    rdfs:comment 'Organizational category for grouping tests in the clinical test menu (e.g., Oncology, Cardiology, Rare Disease, Pharmacogenomics, Infectious Disease).' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Human-readable name of the clinical assay as displayed in test menus, requisition forms, and clinical reports.' ;
    rdfs:domain ind:TestCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the test in the catalog. active=available for ordering, inactive=temporarily unavailable, pending_approval=awaiting regulatory or internal approval, discontinued=permanently retired, under_review=undergoing quality or compliance review.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRequestId rdf:type rdf:Property ;
    rdfs:label 'Access Request Id' ;
    rdfs:comment 'Foreign key linking to data.access_request. Business justification: Test orders for research-use specimens require formal data access requests when results will be used in secondary research or shared externally. Essential for consent management, IRB compliance, and t' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessRequest .

ind:consumedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Consumed Material Id' ;
    rdfs:comment 'Foreign key linking to supply.material. Business justification: Test orders consume specific materials during execution; tracking material per order enables COGS calculation, inventory depletion, lot genealogy for regulatory traceability, and material usage varian' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique identifier for the physician who ordered the clinical test. Links to physician master data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to commercial.commercial_contract. Business justification: Enterprise clinical testing agreements are governed by commercial contracts. Orders must reference contracts for pricing verification, terms compliance, volume commitment tracking, and revenue recogni' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:insurancePayerId rdf:type rdf:Property ;
    rdfs:label 'Insurance Payer Id' ;
    rdfs:comment 'Unique identifier for the insurance payer responsible for payment of the clinical test. Links to payer master data.' ;
    rdfs:domain ind:Clinical ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InsurancePayer .

ind:reagentSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Reagent Subscription Id' ;
    rdfs:comment 'Foreign key linking to commercial.reagent_subscription. Business justification: High-volume clinical testing customers often have reagent subscriptions. Linking orders to subscriptions enables consumption tracking, overage calculation, renewal forecasting, and subscription compli' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReagentSubscription .

ind:referenceLabSupplierId rdf:type rdf:Property ;
    rdfs:label 'Reference Lab Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier. Business justification: Send-out tests performed by external reference labs (suppliers) require tracking for performance monitoring, TAT compliance, quality metrics, and cost management. Enables supplier scorecard for refere' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:accessionedDate rdf:type rdf:Property ;
    rdfs:label 'Accessioned Date' ;
    rdfs:comment 'Date and time when the specimen was accessioned into the Laboratory Information Management System (LIMS).' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTatHours rdf:type rdf:Property ;
    rdfs:label 'Actual Tat Hours' ;
    rdfs:comment 'Actual turnaround time in hours from specimen receipt to result reporting. Used for performance monitoring and Service Level Agreement (SLA) compliance.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current status of billing and reimbursement for the clinical test order.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Number' ;
    rdfs:comment 'CLIA certification number of the laboratory performing the test. Required for all clinical laboratory testing in the United States.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date and time when the clinical test was completed and results were finalized.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'ICD-10 diagnosis code associated with the clinical indication for the test. Used for billing and medical necessity documentation. Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Authorization Number' ;
    rdfs:comment 'Prior authorization number obtained from the patient\'s insurance provider for coverage of the clinical test.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date and time when the clinical test order was placed by the ordering physician or institution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-facing unique order number for the clinical test order. Used for customer communication and order tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the clinical test order in the laboratory workflow.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Ordering Institution Name' ;
    rdfs:comment 'Name of the healthcare institution or facility that placed the test order.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientGender rdf:type rdf:Property ;
    rdfs:label 'Patient Gender' ;
    rdfs:comment 'Gender of the patient as recorded for clinical purposes. Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientMedicalRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Patient Medical Record Number' ;
    rdfs:comment 'Medical record number assigned by the ordering institution for the patient. Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level for processing the test order. STAT indicates immediate/emergency processing, urgent indicates expedited processing, routine indicates standard turnaround time (TAT).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTatHours rdf:type rdf:Property ;
    rdfs:label 'Required Tat Hours' ;
    rdfs:comment 'Required turnaround time in hours from specimen receipt to result reporting, based on test type and priority.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Test Price Usd' ;
    rdfs:comment 'List price of the clinical test in USD. Used for billing and revenue recognition.' ;
    rdfs:domain ind:TestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantInterpretationId rdf:type rdf:Property ;
    rdfs:label 'Variant Interpretation Id' ;
    rdfs:comment 'Unique identifier for the clinical variant interpretation record. Primary key.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVariantEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Variant Employee Id' ;
    rdfs:comment 'Reference to the molecular pathologist or clinical geneticist who performed the interpretation.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryVariantModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Variant Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this interpretation record.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acmgEvidenceCodes rdf:type rdf:Property ;
    rdfs:label 'Acmg Evidence Codes' ;
    rdfs:comment 'Comma-separated list of ACMG/AMP evidence codes applied to support the classification (e.g., PVS1, PS1, PM2, PP3, BA1, BS1, BP4).' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version number of the classification, incremented when the interpretation is updated or reclassified.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Guideline Version' ;
    rdfs:comment 'Version of the ACMG/AMP or other clinical guidelines used for this interpretation (e.g., ACMG 2015, ClinGen 2018).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpretationDate rdf:type rdf:Property ;
    rdfs:label 'Interpretation Date' ;
    rdfs:comment 'Date when the variant interpretation was completed.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interpretationRationale rdf:type rdf:Property ;
    rdfs:label 'Interpretation Rationale' ;
    rdfs:comment 'Detailed rationale and evidence summary supporting the variant classification, including literature references and functional studies.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:literatureReferences rdf:type rdf:Property ;
    rdfs:label 'Literature References' ;
    rdfs:comment 'Comma-separated list of PubMed IDs (PMIDs) or DOIs of publications supporting the interpretation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mondoAccession rdf:type rdf:Property ;
    rdfs:label 'Mondo Accession' ;
    rdfs:comment 'MONDO ontology identifier for the associated disease.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omimAccession rdf:type rdf:Property ;
    rdfs:label 'Omim Accession' ;
    rdfs:comment 'OMIM identifier for the associated disease or phenotype.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phiFlag rdf:type rdf:Property ;
    rdfs:label 'Phi Flag' ;
    rdfs:comment 'Indicates whether this record contains Protected Health Information subject to HIPAA regulations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationDatabase rdf:type rdf:Property ;
    rdfs:label 'Population Database' ;
    rdfs:comment 'Name of the population frequency database used (e.g., gnomAD, 1000 Genomes, ExAC).' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Report Inclusion Flag' ;
    rdfs:comment 'Indicates whether this variant interpretation should be included in the clinical report delivered to the ordering physician.' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variantConsequence rdf:type rdf:Property ;
    rdfs:label 'Variant Consequence' ;
    rdfs:comment 'Predicted functional consequence of the variant on the protein (e.g., missense, nonsense, frameshift, splice site, synonymous).' ;
    rdfs:domain ind:VariantInterpretation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantIdentifier rdf:type rdf:Property ;
    rdfs:label 'Variant Identifier' ;
    rdfs:comment 'Human-readable identifier for the genomic variant, typically in HGVS notation (e.g., NM_000059.3:c.1521_1523delCTT).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curationSopControlledDocumentId rdf:type rdf:Property ;
    rdfs:label 'Curation Sop Controlled Document Id' ;
    rdfs:comment 'Foreign key linking to quality.controlled_document. Business justification: Variant knowledge base curation must follow documented SOPs for evidence evaluation, ACMG criteria application, literature review, and ClinVar submission. Required for CAP molecular pathology accredit' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ControlledDocument .

ind:curatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Curator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Variant curation is GxP-critical activity requiring qualified personnel with documented training in ACMG guidelines and variant interpretation. Links curator to workforce qualification records for reg' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acmgClassificationDate rdf:type rdf:Property ;
    rdfs:label 'Acmg Classification Date' ;
    rdfs:comment 'Date when the current ACMG classification was assigned. Critical for tracking classification currency and reanalysis requirements.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acmgCriteriaApplied rdf:type rdf:Property ;
    rdfs:label 'Acmg Criteria Applied' ;
    rdfs:comment 'Comma-separated list of ACMG/AMP evidence codes applied in the classification (e.g., PVS1, PS3, PM2, PP3). Documents the evidence basis for the classification.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clingenExpertPanelName rdf:type rdf:Property ;
    rdfs:label 'Clingen Expert Panel Name' ;
    rdfs:comment 'Name of the ClinGen expert panel that reviewed this variant (e.g., Hereditary Cancer Clinical Domain Working Group). Null if not reviewed by ClinGen.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clingenExpertPanelReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Clingen Expert Panel Review Status' ;
    rdfs:comment 'Status of ClinGen expert panel review for this variant. Indicates whether the variant has been evaluated by a disease-specific expert panel.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalActionability rdf:type rdf:Property ;
    rdfs:label 'Clinical Actionability' ;
    rdfs:comment 'Assessment of whether the variant has clinical management implications (e.g., surveillance, prophylactic surgery, targeted therapy). Guides clinical decision-making.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinvarSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Clinvar Submission Date' ;
    rdfs:comment 'Date when the variant interpretation was submitted to ClinVar. Null if not yet submitted.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinvarSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Clinvar Submission Status' ;
    rdfs:comment 'Status of Genomics Biotech\'s submission of this variant interpretation to ClinVar. Tracks regulatory and data-sharing compliance.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinvarVariationAccession rdf:type rdf:Property ;
    rdfs:label 'Clinvar Variation Accession' ;
    rdfs:comment 'ClinVar accession number for this variant (e.g., VCV000012345). Links to the public ClinVar database entry.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Evidence Level' ;
    rdfs:comment 'Overall strength of evidence supporting the variant-disease association. Aggregates multiple evidence types per ACMG framework.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalImpactPrediction rdf:type rdf:Property ;
    rdfs:label 'Functional Impact Prediction' ;
    rdfs:comment 'Computational prediction of the variant\'s functional impact on protein function. Aggregated from tools such as SIFT, PolyPhen-2, and CADD.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAlleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Internal Allele Frequency' ;
    rdfs:comment 'Allele frequency of this variant within Genomics Biotech\'s tested population. Calculated as observation count divided by total alleles tested. Proprietary metric for internal variant prioritization.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for curator notes, interpretation rationale, or internal discussion points. Not included in external submissions or patient reports.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalObservationCount rdf:type rdf:Property ;
    rdfs:label 'Internal Observation Count' ;
    rdfs:comment 'Number of times this variant has been observed in Genomics Biotech\'s patient population. Proprietary frequency data distinct from public databases.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this variant interpretation was last reviewed by a curator. Used to trigger periodic reanalysis per ACMG guidelines (recommended every 2 years).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this variant interpretation. Supports compliance with reanalysis requirements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penetrance rdf:type rdf:Property ;
    rdfs:label 'Penetrance' ;
    rdfs:comment 'Likelihood that individuals carrying this variant will develop the associated disease. Important for risk counseling.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationAlleleFrequency rdf:type rdf:Property ;
    rdfs:label 'Population Allele Frequency' ;
    rdfs:comment 'Allele frequency in the general population as reported by gnomAD or other population databases. Used for variant filtering and classification.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinChange rdf:type rdf:Property ;
    rdfs:label 'Protein Change' ;
    rdfs:comment 'HGVS protein-level notation for the amino acid change caused by the variant (e.g., p.Arg273His). Null for non-coding variants.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingLiteraturePubmedIds rdf:type rdf:Property ;
    rdfs:label 'Supporting Literature Pubmed Ids' ;
    rdfs:comment 'Comma-separated list of PubMed identifiers (PMIDs) for publications supporting the variant interpretation. Provides evidence traceability.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transcriptConsequence rdf:type rdf:Property ;
    rdfs:label 'Transcript Consequence' ;
    rdfs:comment 'Predicted effect of the variant on the transcript (e.g., missense_variant, frameshift_variant, splice_donor_variant). Uses Sequence Ontology terms.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantIdentifierHgvs rdf:type rdf:Property ;
    rdfs:label 'Variant Identifier Hgvs' ;
    rdfs:comment 'Standardized HGVS nomenclature for the genomic variant (e.g., NM_000059.3:c.274G>T). This is the canonical identifier used for variant representation across clinical genomics systems.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantStatus rdf:type rdf:Property ;
    rdfs:label 'Variant Status' ;
    rdfs:comment 'Current lifecycle status of this variant knowledge base entry. Active entries are used in clinical reporting; archived entries are retained for historical reference.' ;
    rdfs:domain ind:VariantKnowledgeBase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyId rdf:type rdf:Property ;
    rdfs:label 'Family Id' ;
    rdfs:comment 'Foreign key linking to product.product_family. Business justification: Campaigns typically target product families (e.g., "NGS Platform" campaign) rather than individual SKUs. Strategic marketing planning, budget allocation, and campaign performance analysis by product l' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Family .

ind:marketSegmentTargetId rdf:type rdf:Property ;
    rdfs:label 'Market Segment Target Id' ;
    rdfs:comment 'Foreign key linking to commercial.market_segment_target. Business justification: Marketing campaigns target specific market segments. Adding market_segment_target_id FK links the campaign to the authoritative segment definition, enabling segment-based campaign performance analysis' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketSegmentTarget .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to a parent or umbrella campaign if this campaign is part of a larger multi-wave or integrated marketing initiative. Null for standalone campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the campaign execution concluded. May differ from planned end date due to extensions or early termination.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualLeadCount rdf:type rdf:Property ;
    rdfs:label 'Actual Lead Count' ;
    rdfs:comment 'Actual number of qualified leads generated by the campaign to date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Actual Opportunity Count' ;
    rdfs:comment 'Actual number of sales opportunities created or influenced by the campaign to date.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Revenue Amount' ;
    rdfs:comment 'Actual revenue pipeline value attributed to the campaign in USD, tracked through opportunity influence.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the campaign execution commenced. May differ from planned start date due to operational adjustments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current approval state of the campaign plan and budget: pending (awaiting management review), approved (authorized to proceed), rejected (not approved for execution).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the executive or manager who approved the campaign plan and budget. Null if not yet approved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the campaign was formally approved for execution. Null if not yet approved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total financial budget allocated for this campaign in USD, covering all channels and activities.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpentAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Spent Amount' ;
    rdfs:comment 'Actual amount spent to date on campaign execution in USD, tracked against allocated budget.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign, used in marketing materials, tracking URLs, and cross-system references.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative describing the campaign objectives, target messaging, and strategic rationale.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign (e.g., \'Q1 2024 NGS Product Launch\', \'ASHG 2024 Conference Sponsorship\').' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign: draft (initial planning), planned (approved but not started), active (currently executing), completed (finished and closed), cancelled (terminated before completion), on_hold (temporarily paused).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign execution model: digital (online ads, social media), field_marketing (regional events, roadshows), conference (industry event sponsorship such as ASHG, AGBT), email (targeted email campaigns), webinar (virtual educational sessions), direct_mail (physical collateral distribution).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-separated list of marketing channels utilized in this campaign (e.g., \'email, social_media, webinar, conference_booth, direct_mail\').' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceLocation rdf:type rdf:Property ;
    rdfs:label 'Conference Location' ;
    rdfs:comment 'City and country where the conference is held (e.g., \'San Diego, USA\', \'Barcelona, Spain\'). Null for non-conference campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceName rdf:type rdf:Property ;
    rdfs:label 'Conference Name' ;
    rdfs:comment 'Name of the industry conference or event if this campaign is conference-based (e.g., \'ASHG 2024\', \'AGBT 2024\', \'ASCO Annual Meeting\'). Null for non-conference campaigns.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for budget amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic reach of the campaign: global (worldwide), north_america (USA, Canada, Mexico), emea (Europe, Middle East, Africa), apac (Asia-Pacific), latam (Latin America), usa (United States only), multi_region (custom combination). [ENUM-REF-CANDIDATE: global|north_america|emea|apac|latam|usa|multi_region — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP internal order number used for detailed budget tracking and cost allocation for this campaign.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kolEngagementFlag rdf:type rdf:Property ;
    rdfs:label 'Kol Engagement Flag' ;
    rdfs:comment 'Indicates whether this campaign includes targeted engagement with key opinion leaders in the genomics research or clinical community (True) or not (False).' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByName rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Name' ;
    rdfs:comment 'Full name of the user who last modified this campaign record.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmail rdf:type rdf:Property ;
    rdfs:label 'Owner Email' ;
    rdfs:comment 'Primary email address of the campaign owner for coordination and reporting.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the marketing manager or campaign lead responsible for planning, execution, and performance tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when the campaign is intended to conclude.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when the campaign is intended to begin execution.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetLeadCount rdf:type rdf:Property ;
    rdfs:label 'Target Lead Count' ;
    rdfs:comment 'Planned number of qualified leads the campaign aims to generate.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Target Opportunity Count' ;
    rdfs:comment 'Planned number of sales opportunities the campaign aims to create or influence.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Target Revenue Amount' ;
    rdfs:comment 'Planned revenue pipeline value the campaign aims to generate in USD.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignResponseId rdf:type rdf:Property ;
    rdfs:label 'Campaign Response Id' ;
    rdfs:comment 'Unique identifier for the campaign response record. Primary key.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:convertedToLeadId rdf:type rdf:Property ;
    rdfs:label 'Converted To Lead Id' ;
    rdfs:comment 'Identifier of the lead record created as a result of this campaign response. Null if no lead was created.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:convertedToOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Converted To Opportunity Id' ;
    rdfs:comment 'Identifier of the opportunity record created as a result of this campaign response. Null if no opportunity was created.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Opportunity .

ind:salesTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Sales Territory Id' ;
    rdfs:comment 'Identifier of the sales territory to which this response is assigned for follow-up.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:applicationArea rdf:type rdf:Property ;
    rdfs:label 'Application Area' ;
    rdfs:comment 'The genomics application area or use case the respondent is interested in.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignAssetName rdf:type rdf:Property ;
    rdfs:label 'Campaign Asset Name' ;
    rdfs:comment 'Name of the specific campaign asset or content piece that triggered the response (e.g., whitepaper title, webinar topic).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToContact rdf:type rdf:Property ;
    rdfs:label 'Consent To Contact' ;
    rdfs:comment 'Flag indicating whether the respondent provided explicit consent to be contacted for marketing or sales purposes.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionOutcome rdf:type rdf:Property ;
    rdfs:label 'Conversion Outcome' ;
    rdfs:comment 'The downstream conversion result or action taken as a result of this campaign response. [ENUM-REF-CANDIDATE: lead_created|opportunity_created|meeting_scheduled|quote_requested|trial_started|no_conversion|disqualified — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the response was converted to a lead or opportunity. Null if not yet converted.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Status of the sales follow-up activity for this campaign response.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Timestamp' ;
    rdfs:comment 'Date and time when the sales team first followed up on this campaign response. Null if not yet followed up.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Flag indicating whether the response was captured anonymously (true) or from an identified contact (false).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadScoreAfterResponse rdf:type rdf:Property ;
    rdfs:label 'Lead Score After Response' ;
    rdfs:comment 'Total lead score of the contact after this response was recorded.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadScoreDelta rdf:type rdf:Property ;
    rdfs:label 'Lead Score Delta' ;
    rdfs:comment 'Change in lead score attributed to this campaign response. Positive values indicate increased engagement.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt In Timestamp' ;
    rdfs:comment 'Date and time when the respondent provided marketing consent or opt-in. Null if consent not provided.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productInterest rdf:type rdf:Property ;
    rdfs:label 'Product Interest' ;
    rdfs:comment 'Specific genomics product, service, or solution the respondent expressed interest in (e.g., NGS platform, WGS service, CRISPR tool).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchFocus rdf:type rdf:Property ;
    rdfs:label 'Research Focus' ;
    rdfs:comment 'Specific research focus or scientific area of interest indicated by the respondent (e.g., oncology, rare disease, microbiome).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentCompany rdf:type rdf:Property ;
    rdfs:label 'Respondent Company' ;
    rdfs:comment 'Company or organization name of the respondent as captured at the time of response.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentCountryCode rdf:type rdf:Property ;
    rdfs:label 'Respondent Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the respondent\'s geographic location.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentEmail rdf:type rdf:Property ;
    rdfs:label 'Respondent Email' ;
    rdfs:comment 'Email address provided by the respondent at the time of response. May be used for anonymous lead capture.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentFirstName rdf:type rdf:Property ;
    rdfs:label 'Respondent First Name' ;
    rdfs:comment 'First name of the respondent as captured at the time of response.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Respondent Job Title' ;
    rdfs:comment 'Job title or role of the respondent as provided at the time of response.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentLastName rdf:type rdf:Property ;
    rdfs:label 'Respondent Last Name' ;
    rdfs:comment 'Last name of the respondent as captured at the time of response.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'The channel or medium through which the response was captured (e.g., email, web form, conference booth). [ENUM-REF-CANDIDATE: email|web|mobile_app|social_media|conference|webinar|direct_mail|phone|partner_portal|field_event — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Unique business identifier for this campaign response, used for tracking and attribution across systems.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes or comments captured about this campaign response, including respondent questions or special requests.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSource rdf:type rdf:Property ;
    rdfs:label 'Response Source' ;
    rdfs:comment 'Specific source or referrer that drove the response (e.g., LinkedIn ad, Google search, partner referral, conference name).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the campaign response indicating progression through the lead qualification funnel.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date and time when the prospect or customer responded to the campaign. Principal business event timestamp.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Classification of the type of engagement or action taken by the respondent in response to the campaign. [ENUM-REF-CANDIDATE: webinar_registration|content_download|conference_booth_visit|email_click|demo_request|whitepaper_download|trial_signup|contact_form|phone_inquiry|event_attendance — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign parameter from the campaign URL used for digital attribution tracking.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'UTM content parameter from the campaign URL used for A/B testing and content differentiation.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium parameter from the campaign URL used for digital attribution tracking.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source parameter from the campaign URL used for digital attribution tracking.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelPartnerId rdf:type rdf:Property ;
    rdfs:label 'Channel Partner Id' ;
    rdfs:comment 'Unique identifier for the channel partner record. Primary key for the channel partner entity.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChannelPartner .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'Date when the partnership agreement became legally effective and the partner was authorized to begin operations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiration Date' ;
    rdfs:comment 'Date when the current partnership agreement expires or is scheduled for renewal. Null for evergreen agreements.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualRevenueCommitmentUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Commitment Usd' ;
    rdfs:comment 'Contractual annual revenue commitment or quota the partner has agreed to achieve, expressed in US Dollars. Used for tier qualification and performance tracking.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizedProductLines rdf:type rdf:Property ;
    rdfs:label 'Authorized Product Lines' ;
    rdfs:comment 'Comma-separated list of product lines, families, or SKU (Stock Keeping Unit) categories the partner is authorized to sell (e.g., NGS Sequencing Instruments, Array Platforms, CRISPR Kits, Reagents and Consumables).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'Date when the partners current certification expires and requires renewal or recertification.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Highest technical or sales certification level achieved by the partner organization (e.g., NGS Certified, CRISPR Specialist, Clinical Genomics Expert). Multiple certifications may be concatenated.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Usd' ;
    rdfs:comment 'Maximum outstanding accounts receivable credit limit approved for the partner, expressed in US Dollars.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealRegistrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Deal Registration Enabled' ;
    rdfs:comment 'Boolean flag indicating whether the partner is authorized to register deals for opportunity protection and additional discounts. True if enabled, False if disabled.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountTierPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Tier Percentage' ;
    rdfs:comment 'Standard discount percentage off list price that the partner receives based on their tier and volume commitments. Expressed as percentage (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet unique identifier for the partner organization, used for credit assessment and business verification.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic territories, regions, or countries where the partner is authorized to sell or distribute Genomics Biotech products. May include multiple countries or regions separated by semicolons.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'Primary street address line for the partner organization headquarters or principal place of business.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, building, or additional location details.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City or municipality of the partner headquarters location.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the partner headquarters location (e.g., USA, GBR, DEU, CHN).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the headquarters address.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State, province, or primary administrative subdivision of the headquarters location.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdfEligible rdf:type rdf:Property ;
    rdfs:label 'Mdf Eligible' ;
    rdfs:comment 'Boolean flag indicating whether the partner is eligible to receive Market Development Funds for co-marketing activities. True if eligible, False if not.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the partner completed onboarding process including training, certification, and system access provisioning.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerLegalName rdf:type rdf:Property ;
    rdfs:label 'Partner Legal Name' ;
    rdfs:comment 'Full legal registered name of the channel partner organization as it appears on partnership agreements and regulatory filings.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerNotes rdf:type rdf:Property ;
    rdfs:label 'Partner Notes' ;
    rdfs:comment 'Free-text field for internal notes, special handling instructions, strategic relationship context, or historical information about the partner.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the channel partner, used in contracts, invoices, and partner portal. Format: CP- prefix followed by alphanumeric code.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerPortalEnabled rdf:type rdf:Property ;
    rdfs:label 'Partner Portal Enabled' ;
    rdfs:comment 'Boolean flag indicating whether the partner has active access to the partner portal for order management, training, and marketing resources. True if enabled, False if disabled.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Status' ;
    rdfs:comment 'Current operational status of the partnership. Active (full operations), Probation (performance review), Suspended (temporary hold), Terminated (ended), Pending Approval (onboarding in progress).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Partner program tier indicating level of investment, certification, and benefits. Platinum (highest strategic partners), Gold (certified high-volume), Silver (certified standard), Bronze (emerging), Registered (entry level).' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTradeName rdf:type rdf:Property ;
    rdfs:label 'Partner Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used by the partner in the market, may differ from legal name.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner business model: distributor (bulk wholesale), reseller (direct sales), VAR (Value-Added Reseller with services), OEM (Original Equipment Manufacturer integration), referral (lead generation only), or system integrator (solution provider).' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Partnership Agreement Number' ;
    rdfs:comment 'Reference number or identifier of the master partnership agreement or contract governing the relationship, stored in contract management system.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard payment terms in days for invoices issued to the partner (e.g., 30, 60, 90 days net).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary partner contact for operational communications, order processing, and escalations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the partner organization responsible for the partnership relationship.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the partner contact, including country code and extension if applicable.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Tax identification number, VAT number, or equivalent government-issued business tax identifier for the partner organization in their primary jurisdiction.' ;
    rdfs:domain ind:ChannelPartner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the partnership was terminated or ended. Null for active partnerships.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Business reason or cause for partnership termination (e.g., performance issues, strategic realignment, partner request, compliance violation). Null for active partnerships.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Agreement Id' ;
    rdfs:comment 'Foreign key linking to customer.service_agreement. Business justification: Commercial contracts (MSAs, volume purchase agreements) often reference or supersede service agreements for instrument maintenance and support. Legal and sales operations teams cross-reference contrac' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAgreement .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: Master commercial contracts with customers may reference underlying supplier contracts for pass-through pricing, supply guarantees, or back-to-back terms. Business process: back-to-back contract manag' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews for an additional term unless either party provides notice of non-renewal. True means contract will auto-renew; false means contract expires at term end unless explicitly renewed.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes confidentiality or non-disclosure provisions protecting proprietary information, trade secrets, or sensitive business data. True means confidentiality obligations exist; false means no specific confidentiality terms beyond standard commercial practice.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the contract, used in communications with customers and partners. Typically follows a structured format including year, region, or contract type prefix.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract. Draft indicates contract is being negotiated; pending approval awaits internal sign-off; executed means signed by all parties; active indicates contract is in force; expired means term has ended; terminated indicates early cancellation; suspended indicates temporary hold. [ENUM-REF-CANDIDATE: draft|pending_approval|executed|active|expired|terminated|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contract based on the primary commercial relationship it governs. Instrument purchase agreements cover sequencing systems and hardware; reagent supply agreements govern consumables and kits; software license agreements cover bioinformatics platforms; MSAs establish framework terms; evaluation agreements enable product trials; maintenance agreements cover post-warranty service.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyLegalName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Legal Name' ;
    rdfs:comment 'Full legal name of the customer or partner organization as it appears on the executed contract. Must match official registration documents for contract enforceability.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the contracting party based on their relationship to Genomics Biotech. Direct customers purchase for their own use; channel partners resell; distributors provide regional coverage; OEM partners integrate products; academic institutions include universities and research centers; government entities include public health and regulatory bodies.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Agreed-upon method for resolving disputes arising from the contract. Arbitration is common for commercial contracts to avoid court proceedings; mediation involves a neutral third party; litigation means court-based resolution.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'Link to the executed contract document stored in the document management system (e.g., Veeva Vault). Provides access to the full legal agreement and any amendments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the contract grants exclusive rights to the counterparty within a defined scope (territory, product line, or customer segment). True means exclusive rights granted; false means non-exclusive. Common in channel partner and distributor agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'Date and time when the contract was fully executed (signed by all parties). Marks the point at which the contract becomes legally binding, which may differ from the effective date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the contract. Typically specified as a state or country (e.g., State of California, England and Wales). Critical for dispute resolution.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Summary of insurance coverage requirements specified in the contract, such as general liability, professional liability, product liability, or cyber liability insurance. May include minimum coverage amounts and certificate of insurance requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipTerms rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Terms' ;
    rdfs:comment 'Summary of intellectual property ownership and licensing terms, particularly relevant for R&D collaborations, custom development, or co-marketing agreements. Specifies who owns IP created under the contract and any license grants.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum monetary amount of liability that either party may be held responsible for under the contract, excluding certain carve-outs (e.g., IP infringement, gross negligence). Null if no liability cap is specified. Typically expressed as a multiple of contract value or a fixed amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPurchaseCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Commitment' ;
    rdfs:comment 'Minimum monetary value or quantity that the customer commits to purchase over the contract term. Used in volume discount agreements and channel partner contracts. Null if no minimum commitment exists.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Preferred or required method of payment specified in the contract. Wire transfer and ACH are common for large transactions; credit card for smaller purchases; purchase order for institutional buyers; letter of credit for international or high-value deals.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms governing when payment is due after invoice. Net terms indicate days until payment due; installment and milestone-based indicate structured payment schedules; subscription terms indicate recurring billing cycles. [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|due_on_receipt|installment|milestone_based|subscription_monthly|subscription_annual — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productScope rdf:type rdf:Property ;
    rdfs:label 'Product Scope' ;
    rdfs:comment 'Summary description of the products, services, or solutions covered by this contract. May include instrument models, reagent SKUs, software platforms, or service packages. Provides high-level context without listing every line item.' ;
    rdfs:domain ind:GenomicsBiotech ;
