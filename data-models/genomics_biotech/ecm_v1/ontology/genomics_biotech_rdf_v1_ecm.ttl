ind:averageDealSizeUsd rdf:type rdf:Property ;
    rdfs:label 'Average Deal Size Usd' ;
    rdfs:comment 'Average revenue per closed-won opportunity in this segment. Used for pipeline value estimation and quota planning.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Assessment of competitive pressure in this market segment. High intensity indicates crowded market with aggressive pricing and differentiation challenges.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this market segment target definition was deprecated or replaced. Null for currently active segments.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this market segment target definition became active and available for use in campaigns and territory planning.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicFocus rdf:type rdf:Property ;
    rdfs:label 'Geographic Focus' ;
    rdfs:comment 'Primary geographic regions or countries where this segment is targeted (e.g., North America, EMEA, APAC, specific country codes). Used for territory assignment and localization planning.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:growthRatePercent rdf:type rdf:Property ;
    rdfs:label 'Growth Rate Percent' ;
    rdfs:comment 'Estimated annual market growth rate for this segment as a percentage. Positive values indicate growth; negative values indicate contraction.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyBuyingCriteria rdf:type rdf:Property ;
    rdfs:label 'Key Buying Criteria' ;
    rdfs:comment 'Primary factors that influence purchasing decisions in this segment (e.g., throughput, cost per sample, data quality, regulatory compliance, ease of use, technical support).' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSizeAsOfDate rdf:type rdf:Property ;
    rdfs:label 'Market Size As Of Date' ;
    rdfs:comment 'Date when the addressable market size estimate was calculated or last updated. Critical for understanding the currency of market intelligence.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketSizeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Market Size Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the addressable market size (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingMessageTheme rdf:type rdf:Property ;
    rdfs:label 'Marketing Message Theme' ;
    rdfs:comment 'Core value proposition and messaging theme for campaigns targeting this segment (e.g., cost efficiency, throughput, data quality, ease of use, regulatory compliance).' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSalesChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Sales Channel' ;
    rdfs:comment 'Primary go-to-market channel for this segment (direct sales force, channel partners, distributors, hybrid model, or e-commerce).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryApplicationAreas rdf:type rdf:Property ;
    rdfs:label 'Primary Application Areas' ;
    rdfs:comment 'Comma-separated list of primary genomics application areas relevant to this segment (e.g., WGS, WES, SNP arrays, CRISPR screening, qPCR, RNA-Seq). Indicates which product families and assay types are most relevant.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRationale rdf:type rdf:Property ;
    rdfs:label 'Priority Rationale' ;
    rdfs:comment 'Business justification for the assigned strategic priority tier, including market dynamics, competitive position, growth potential, and strategic fit.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplexity rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complexity' ;
    rdfs:comment 'Assessment of regulatory requirements and compliance burden for selling into this segment (e.g., RUO vs IVD, CLIA requirements, FDA clearance needs).' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Unique business code identifying the market segment (e.g., ACAD-RES, CLIN-LAB, BIOPHARMA). Used for campaign targeting, territory design, and pipeline segmentation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed description of the market segment, including key characteristics, typical customer profiles, and business context.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Full business name of the market segment (e.g., Academic Research Institutions, Clinical Reference Laboratories, Biopharma R&D).' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the market segment target. Active segments are used for campaign targeting and territory design.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segment granularity level: primary (top-level segment), sub-segment (subdivision of primary), niche (specialized market), or emerging (new market opportunity).' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Strategic importance classification of the market segment. Tier 1 segments receive highest investment and focus; tier 2 are growth opportunities; tier 3 are maintenance; watch list are monitored for future potential.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAccountCount rdf:type rdf:Property ;
    rdfs:label 'Target Account Count' ;
    rdfs:comment 'Estimated number of target accounts (organizations) within this market segment. Used for territory sizing and coverage planning.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalCustomerProfile rdf:type rdf:Property ;
    rdfs:label 'Typical Customer Profile' ;
    rdfs:comment 'Description of the typical customer characteristics within this segment, including organization type, size, research focus, budget range, and purchasing behavior patterns.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalSalesCycleDays rdf:type rdf:Property ;
    rdfs:label 'Typical Sales Cycle Days' ;
    rdfs:comment 'Average number of days from initial contact to closed-won opportunity for this segment. Used for pipeline forecasting and resource planning.' ;
    rdfs:domain ind:MarketSegmentTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opportunityAccountId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Account Id' ;
    rdfs:comment 'FK to customer.account.account_id — Commercial opportunities must link to customer accounts for pipeline reporting, territory assignment validation, and account-level forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:opportunityPartnerAccountId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Partner Account Id' ;
    rdfs:comment 'Reference to the channel partner account involved in this opportunity, if applicable. Used for partner-sourced or co-sell deals.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:priceBookId rdf:type rdf:Property ;
    rdfs:label 'Price Book Id' ;
    rdfs:comment 'Foreign key linking to commercial.price_book. Business justification: Opportunities use specific price books for quoting based on customer segment, geography, and sales channel. Adding price_book_id FK links the opportunity to the price book being used, enabling pricing' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceBook .

ind:primaryOpportunityAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Opportunity Account Id' ;
    rdfs:comment 'Reference to the customer account associated with this opportunity. Links to the account master record in the customer domain.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Actual date when the opportunity was closed. Populated only after the opportunity reaches closed-won or closed-lost stage.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arr rdf:type rdf:Property ;
    rdfs:label 'Arr' ;
    rdfs:comment 'Annual recurring revenue value for subscription-based products and services (e.g., bioinformatics software licenses, service contracts). Expressed in USD.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Anticipated date when the opportunity will be closed (won or lost). Used for revenue forecasting and pipeline management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveLandscape rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape' ;
    rdfs:comment 'Description of competitive dynamics for this opportunity, including known competitors, their positioning, and our competitive advantages. Used for win/loss analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the contract or service agreement in months. Used for calculating ARR and contract lifecycle management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysInCurrentStage rdf:type rdf:Property ;
    rdfs:label 'Days In Current Stage' ;
    rdfs:comment 'Number of days the opportunity has been in its current stage. Calculated field used for pipeline velocity analysis and identifying stalled opportunities.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the deal based on customer relationship status. New logo = first purchase, expansion = additional products to existing customer, renewal = contract renewal, upgrade = replacement of existing product.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Total discount percentage applied to list price for this opportunity. Used for pricing analysis and margin management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Boolean flag indicating whether the opportunity has been closed (won or lost). True = closed, False = still active in pipeline.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWon rdf:type rdf:Property ;
    rdfs:label 'Is Won' ;
    rdfs:comment 'Boolean flag indicating whether the opportunity was won. True = closed-won, False = closed-lost or still open. Only meaningful when is_closed is True.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastStageChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Stage Change Date' ;
    rdfs:comment 'Date when the opportunity last moved to a different stage. Used for calculating stage duration and identifying stalled deals.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextStep rdf:type rdf:Property ;
    rdfs:label 'Next Step' ;
    rdfs:comment 'Description of the next action or milestone required to advance the opportunity. Used for pipeline hygiene and sales coaching.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Opportunity Description' ;
    rdfs:comment 'Detailed description of the opportunity scope, customer requirements, proposed solution, and strategic importance. Free-text field for context and notes.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Business-friendly name or title of the opportunity, typically describing the customer and product scope (e.g., \'Acme Labs - NovaSeq 6000 Expansion\').' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the opportunity, used in communications and reporting. Format: OPP-########.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCompetitor rdf:type rdf:Property ;
    rdfs:label 'Primary Competitor' ;
    rdfs:comment 'Name of the primary competitor identified in this opportunity. Used for competitive intelligence and market share analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probability rdf:type rdf:Property ;
    rdfs:label 'Probability' ;
    rdfs:comment 'Estimated probability of winning this opportunity, expressed as a percentage (0.00 to 100.00). Used for weighted pipeline forecasting.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'Regulatory classification of the products or services in this opportunity. RUO = Research Use Only, IVD = In Vitro Diagnostic, LDT = Laboratory Developed Test, CE-IVD = European conformity for diagnostics.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current stage of the opportunity in the sales pipeline lifecycle. Represents progression from initial prospecting through closure. [ENUM-REF-CANDIDATE: prospecting|qualification|solution_design|proposal|negotiation|closed_won|closed_lost — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcv rdf:type rdf:Property ;
    rdfs:label 'Tcv' ;
    rdfs:comment 'Total contract value including all one-time and recurring revenue over the contract lifetime. Includes instruments, reagents, consumables, and services. Expressed in USD.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossCategory rdf:type rdf:Property ;
    rdfs:label 'Win Loss Category' ;
    rdfs:comment 'Categorical classification of the primary win or loss reason. Used for structured win/loss analysis and trend identification. [ENUM-REF-CANDIDATE: price|product_features|service_quality|competitor|timing|budget|relationship|technical_fit — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossReason rdf:type rdf:Property ;
    rdfs:label 'Win Loss Reason' ;
    rdfs:comment 'Detailed explanation of why the opportunity was won or lost. Captured at closure for continuous improvement and competitive analysis.' ;
    rdfs:domain ind:Opportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityLineId rdf:type rdf:Property ;
    rdfs:label 'Opportunity Line Id' ;
    rdfs:comment 'Unique identifier for the opportunity line item. Primary key for this entity.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Optional identifier linking multiple line items that are sold together as a configured bundle or package deal. Null for standalone line items.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created this opportunity line item record. Used for audit trail and accountability.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deviceIdentifierId rdf:type rdf:Property ;
    rdfs:label 'Device Identifier Id' ;
    rdfs:comment 'Foreign key linking to regulatory.device_identifier. Business justification: UDI (Unique Device Identifier) is required on commercial transactions for regulated IVD products per FDA/EU MDR requirements. Opportunity lines must reference the correct UDI-DI for traceability, regu' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviceIdentifier .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this opportunity line item record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partnerAccountId rdf:type rdf:Property ;
    rdfs:label 'Partner Account Id' ;
    rdfs:comment 'Reference to the channel partner or distributor account involved in this line item sale. Null for direct sales. Used for partner commission calculation.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:commissionPercent rdf:type rdf:Property ;
    rdfs:label 'Commission Percent' ;
    rdfs:comment 'The sales commission percentage applicable to this line item. May vary by product family, sales territory, or partner involvement. Confidential compensation data.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorProduct rdf:type rdf:Property ;
    rdfs:label 'Competitor Product' ;
    rdfs:comment 'Name of the competing product or platform that this line item is being positioned against. Used for competitive analysis and win/loss tracking.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationAttributes rdf:type rdf:Property ;
    rdfs:label 'Configuration Attributes' ;
    rdfs:comment 'JSON or delimited string capturing product configuration options selected for this line. Examples: flow cell type, read length, multiplexing capacity, software modules enabled.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'The standard cost to manufacture or procure this product per unit. Used for margin analysis and profitability reporting. Confidential financial data.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'The percentage discount applied to the list price to arrive at the sales price. Calculated as ((list_price - sales_price) / list_price) * 100.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'The expected delivery or fulfillment date for this line item based on current lead times and production schedules. Used for customer expectation management.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percent' ;
    rdfs:comment 'The gross profit margin percentage for this line item. Calculated as ((sales_price - cost_of_goods_sold) / sales_price) * 100. Confidential financial metric.' ;
    rdfs:domain ind:Commercial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryProduct rdf:type rdf:Property ;
    rdfs:label 'Is Primary Product' ;
    rdfs:comment 'Boolean flag indicating whether this line item represents the primary product in the opportunity (e.g., the main sequencing instrument) versus ancillary products (reagents, accessories, services).' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The number of days from order placement to expected delivery for this product. Varies by product type: instruments may have 60-90 day lead times, consumables 7-14 days.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Free-text description providing additional context about this line item. May include special terms, customer-specific configurations, or delivery instructions.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent opportunity. Used for ordering and display purposes in multi-product deals.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of this individual opportunity line item. Tracks the progression from initial quote through approval and ordering. Line status may differ from overall opportunity status. [ENUM-REF-CANDIDATE: draft|quoted|negotiation|approved|ordered|cancelled|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'The total amount for this line item before taxes. Calculated as quantity * sales_price. Represents the extended line value.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'The published catalog list price per unit in the opportunity currency. Represents the standard price before any discounts or negotiations.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The number of units being quoted or sold in this line item. May represent instrument count, reagent kit boxes, software licenses, or service hours depending on product type.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory status of the product being sold. Research Use Only (RUO) products cannot be used for clinical diagnostics; In Vitro Diagnostic (IVD) products are clinically validated and approved.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresInstallation rdf:type rdf:Property ;
    rdfs:label 'Requires Installation' ;
    rdfs:comment 'Boolean flag indicating whether this product requires professional installation services. True for sequencing instruments and array scanners; false for reagent kits and software.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueScheduleType rdf:type rdf:Property ;
    rdfs:label 'Revenue Schedule Type' ;
    rdfs:comment 'Defines how revenue from this line will be recognized over time. Critical for subscription-based bioinformatics software and reagent rental programs.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of revenue recognition type for this line item. Determines accounting treatment and revenue recognition schedule per ASC 606 / IFRS 15.' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesPrice rdf:type rdf:Property ;
    rdfs:label 'Sales Price' ;
    rdfs:comment 'The negotiated sales price per unit after discounts, volume pricing, or contract terms have been applied. This is the actual price the customer will pay.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'The planned or actual end date for service delivery, subscription access, or maintenance coverage. Null for perpetual licenses or one-time sales.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'The planned or actual start date for service delivery, subscription access, or maintenance coverage for this line item. Used for revenue recognition and fulfillment scheduling.' ;
    rdfs:domain ind:OpportunityLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the quantity field. Genomics-specific units include runs (sequencing runs), lanes (flow cell lanes), samples, or gigabases of sequencing output. [ENUM-REF-CANDIDATE: each|box|kit|license|subscription|hour|run|sample|lane|gigabase — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GenomicsBiotech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerDealRegistrationId rdf:type rdf:Property ;
