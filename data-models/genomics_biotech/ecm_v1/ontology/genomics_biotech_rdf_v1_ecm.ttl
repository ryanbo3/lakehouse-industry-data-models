    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingManagerName rdf:type rdf:Property ;
    rdfs:label 'Approving Manager Name' ;
    rdfs:comment 'Full name of the channel manager who approved or rejected the deal registration.' ;
    rdfs:domain ind:PartnerDealRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coSellEligibleFlag rdf:type rdf:Property ;
