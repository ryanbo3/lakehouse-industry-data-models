ind:guestProfileId rdf:type rdf:Property ;
    rdfs:label 'Guest Profile Id' ;
    rdfs:comment 'Foreign key linking to guest.profile. Business justification: Illness reports in foodservice must identify the affected guest for follow-up, legal liability management, and health department notification. Currently illness_report only has employee_id; guest-repo' ;
    rdfs:domain ind:IllnessReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primaryIllnessRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Illness Restaurant Unit Id' ;
