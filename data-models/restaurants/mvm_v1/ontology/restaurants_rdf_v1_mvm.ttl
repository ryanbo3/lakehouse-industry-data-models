    rdfs:range xsd:string .

ind:paymentVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Variance Amount' ;
    rdfs:comment 'The difference between the scheduled payment amount and the actual total payment amount, indicating overpayment or underpayment.' ;
