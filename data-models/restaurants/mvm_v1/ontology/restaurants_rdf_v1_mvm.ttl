ind:feeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to franchise.fee_schedule. Business justification: Billing records charge fees defined in the fee_schedule (one-time and recurring franchise fees beyond royalties). Linking billing to fee_schedule normalizes the fee definition away from the billing re' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:primarySalesLocationUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Sales Location Unit Id' ;
