    rdfs:range xsd:boolean .

ind:supportsThirdPartyDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Third Party Delivery' ;
    rdfs:comment 'Indicates whether the terminal can process orders from third-party delivery platforms.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Code' ;
    rdfs:comment 'Business identifier or asset tag used in inventory and reporting.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Currency Code' ;
    rdfs:comment 'ISO 4217 currency code used for transactions processed by this terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Human-readable name assigned to the terminal for operational identification.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalNumber rdf:type rdf:Property ;
    rdfs:label 'Terminal Number' ;
    rdfs:comment 'Business-facing terminal number or code used for operational identification and reporting.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the POS terminal by its operational role and form factor.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zone rdf:type rdf:Property ;
