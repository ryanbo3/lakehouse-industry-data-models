    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leasePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease Period End Date' ;
    rdfs:comment 'The end date of the lease period covered by this rent payment.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leasePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Period Start Date' ;
