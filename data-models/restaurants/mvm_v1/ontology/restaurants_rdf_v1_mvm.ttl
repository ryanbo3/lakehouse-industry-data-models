    rdfs:range xsd:string .

ind:pciComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Status' ;
    rdfs:comment 'Current PCI DSS compliance status of the terminal for secure payment processing.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalStatus rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Status' ;
    rdfs:comment 'Current lifecycle status of the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printerAttached rdf:type rdf:Property ;
    rdfs:label 'Printer Attached' ;
    rdfs:comment 'Indicates whether a receipt printer is attached to this POS terminal.' ;
