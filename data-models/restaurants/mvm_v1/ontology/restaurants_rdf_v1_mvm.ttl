    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageStoreSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Average Store Size Sqft' ;
    rdfs:comment 'Mean square-footage of restaurants operating under the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCategory rdf:type rdf:Property ;
    rdfs:label 'Brand Category' ;
    rdfs:comment 'High-level category describing the brand\'s product focus.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
