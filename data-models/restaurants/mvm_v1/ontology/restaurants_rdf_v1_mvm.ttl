    rdfs:range xsd:string .

ind:paymentRunDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Run Description' ;
    rdfs:comment 'Free-form text describing the purpose or context of the payment run.' ;
    rdfs:domain ind:PaymentRun ;
