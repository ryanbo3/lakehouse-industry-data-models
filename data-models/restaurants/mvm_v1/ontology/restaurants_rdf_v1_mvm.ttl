# RDFS Schema for Business: Restaurants

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/restaurants#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Restaurants ---
ind:Restaurants rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Restaurants' ;
    rdfs:comment 'Restaurants is a global foodservice industry operating quick-service, casual, and fine-dining establishments through franchise and company-owned models, serving millions of customers daily with a focus on speed, quality, and value.' .

# --- Domain Classes ---
ind:Menu rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Menu' ;
    rdfs:comment 'Single source of truth for all menu items, recipes, BOMs (Bill of Materials), nutritional data, allergen declarations, pricing, product mix (PMIX), limited time offers (LTO), and menu engineering decisions across dayparts, channels (DT, OLO, 3PD), and restaurant formats (QSR, casual, fine-dining). Governs what the business sells.' .

ind:Guest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Guest' ;
    rdfs:comment 'Single source of truth for customer identity, profiles, preferences, demographics, segments, loyalty membership, and guest engagement across all channels (dine-in, drive-thru, online ordering). Manages CSAT, NPS, lifetime value, and consent/privacy management. Master record for WHO the business serves.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Order' ;
    rdfs:comment 'Core transactional domain managing order capture, fulfillment, and delivery across all service channels including POS (Oracle MICROS), drive-thru (DT), online ordering (OLO), third-party delivery (3PD), and catering. Tracks order lifecycle, KDS routing, ticket time, speed of service (SOS), average transaction count (ATC), and average check value (ACV).' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Manages end-to-end food and non-food supply chain including supplier master data, vendor management, sourcing, purchase orders, inbound logistics, distribution center operations, and ingredient traceability. Tracks COGS, supplier performance, contract compliance, and spend analytics via Coupa Procurement.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Manages BOH stock levels, SKU tracking, PAR levels (Periodic Automatic Replenishment), waste tracking (Waste%), yield management, receiving, transfers, physical counts, and replenishment orders via MarketMan. Supports COGS% optimization and food cost control across all restaurant units.' .

ind:Restaurant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Restaurant' ;
    rdfs:comment 'Master record for every restaurant unit — company-owned and franchised — including location attributes, format (QSR/casual/fine-dining), FOH/BOH configuration, operating hours, daypart schedules, equipment, throughput capacity, speed-of-service (SOS) benchmarks, table turns, cover counts, AUV, SSS, and comp sales. Operational anchor for brand standards and SOPs.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'Manages employee lifecycle including recruiting, onboarding, scheduling, time and attendance, labor forecasting, Labor% optimization, FTE tracking, certifications (ServSafe), performance management, and payroll integration via Workday HCM and Planday. Optimizes labor deployment across dayparts, BOH/FOH staffing ratios, and restaurant locations.' .

ind:Franchise rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Franchise' ;
    rdfs:comment 'SSOT for franchise partner identity, FDD agreements, territory management, royalty rate calculations, franchise fees, compliance tracking, NRO (New Restaurant Opening) pipeline, franchisee performance metrics, and development lifecycle via FranConnect. Ensures adherence to brand standards, IFA best practices, and FTC Franchise Rule.' .

ind:Foodsafety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Foodsafety' ;
    rdfs:comment 'Governs HACCP plan management, food safety audit results, health inspection records, corrective action tracking, temperature monitoring logs, sanitation schedules, allergen management, and SOP compliance via Zenput. Ensures adherence to FDA FSMA, local health department requirements, ISO 22000, and ServSafe standards across all restaurant units.' .

ind:Loyalty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Loyalty' ;
    rdfs:comment 'Manages guest loyalty program enrollment, membership tiers, points accrual and redemption, rewards catalog, promotional offers, personalized campaigns, member engagement, and loyalty analytics. Drives repeat visits, ACV lift, and customer lifetime value through targeted incentives and gamification across OLO and POS channels.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Manages promotional campaign planning, LTO execution, advertising spend, media channel performance (digital, social, traditional), brand positioning, local store marketing, guest segmentation, and campaign ROI measurement. Drives traffic, average daily transactions (ADT), and comparable store sales (comp sales) lift.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Authoritative domain for general ledger (GL), accounts payable (AP), accounts receivable (AR), fixed assets (FA), cost center management, budgeting, P&L reporting, EBITDA tracking, CapEx/OpEx classification, revenue management, royalty income accounting, and multi-entity consolidation via SAP S/4HANA. GAAP/IFRS compliant financial statements.' .

ind:Realestate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurants ;
    rdfs:label 'Realestate' ;
    rdfs:comment 'Manages site selection, lease negotiations, property acquisition, facility design and construction, CAM (Common Area Maintenance) charges, landlord relationships, lease administration, NRO development pipeline, facility R&M (Repairs and Maintenance), and CapEx planning for new builds and remodels. Tracks lease obligations for IFRS 16 / ASC 842 compliance.' .

# --- Data Product Classes (Tables) ---
ind:MenuItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Menu Item' ;
    rdfs:comment 'Master record for every sellable item on the menu across all restaurant formats (QSR, casual, fine-dining) and service channels (DT, OLO, 3PD, dine-in). Captures item identity, guest-facing name, internal name, description, PLU/SKU code, category, sub-category, daypart availability flags, format eligibility flags, channel availability flags, item status (active/inactive/seasonal/LTO), prep time estimate, portion size, serving temperature, calorie display value, image asset reference, and lifecycle dates (created, launched, discontinued). This is the SSOT for what the business sells — the anchor entity for the entire menu domain.' .

ind:Menu rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Menu' ;
    rdfs:comment 'Master record for each published menu — the container that groups menu items for a specific restaurant format, daypart, channel, and effective date range. Tracks menu name, version, format (QSR/casual/fine-dining), channel (DT/OLO/3PD/dine-in), daypart (breakfast/lunch/dinner/late-night), effective start/end dates, approval status, and publishing state. Enables menu versioning and rollout governance.' .

ind:Recipe rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Recipe' ;
    rdfs:comment 'Master record for each standardized recipe (SOP) associated with a menu item. Captures recipe name, version, yield quantity, yield unit, prep method, cook method, cook temperature, cook time, plating instructions, BOH preparation notes, and recipe status. Serves as the culinary SSOT linking menu items to their production specifications and BOM components.' .

ind:RecipeIngredient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Recipe Ingredient' ;
    rdfs:comment 'Bill of Materials (BOM) line-item record for each ingredient within a recipe. Captures ingredient SKU reference, ingredient name, quantity, unit of measure, preparation state (raw/cooked/prepped), waste factor percentage, yield percentage, sequence order, and substitution flag. Drives COGS calculations, procurement planning, and PAR level management.' .

ind:ItemPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Item Price' ;
    rdfs:comment 'Transactional pricing record capturing the effective price of a menu item for a specific restaurant, channel, daypart, and date range. Tracks base price, promotional price, price tier, currency, effective start/end dates, price change reason, approval status, 3PD commission markup percentage, delivery surcharge amount, and dynamic pricing eligibility flag. Supports channel-specific pricing (DT vs OLO vs 3PD with commission pass-through), daypart pricing, regional price variation, and franchise price compliance monitoring. SSOT for what the guest pays per item per context.' .

ind:NutritionProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Nutrition Profile' ;
    rdfs:comment 'Master nutritional data record for each menu item as required by FDA menu labeling regulations. Captures calories, total fat, saturated fat, trans fat, cholesterol, sodium, total carbohydrates, dietary fiber, total sugars, added sugars, protein, and serving size per FDA Nutrition Facts panel standards. Includes data source, lab analysis date, and regulatory approval status.' .

ind:AllergenDeclaration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Allergen Declaration' ;
    rdfs:comment 'Regulatory master record capturing the allergen profile for each menu item per FDA Food Allergen Labeling and Consumer Protection Act (FALCPA) requirements. Tracks the presence, may-contain, and absence status for the 9 major FDA allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame), cross-contact risk level, declaration date, and regulatory review status.' .

ind:MenuLto rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Menu Lto' ;
    rdfs:comment 'Master record for each Limited Time Offer (LTO) — a time-bounded promotional menu item or bundle. Captures LTO name, concept description, target daypart, target channel, planned and actual launch/end dates, LTO type (new item/returning item/bundle), constituent menu item references with item roles (hero/side/beverage/component), marketing campaign reference, test market flag, rollout scope (national/regional/franchise group), and performance targets. Governs the full LTO lifecycle from ideation through execution to sunset analysis.' .

ind:ModifierGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Modifier Group' ;
    rdfs:comment 'Master record for groups of customization options (modifiers) applicable to menu items — e.g., Protein Choice, Sauce Selection, Size Upgrade, Add-Ons. Captures group name, selection type (single/multi-select), min/max selections, display name, and item applicability rules (which menu items this group attaches to, display order, required/optional flag, channel-specific overrides). Drives POS and OLO customization logic and item-to-modifier mapping.' .

ind:MenuModifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Menu Modifier' ;
    rdfs:comment 'Master record for each individual modifier option within a modifier group — e.g., \'Extra Cheese\', \'No Onions\', \'Large Size\', \'Gluten-Free Bun\'. Captures modifier name, modifier group reference, price delta (upcharge or discount), calorie delta, default selection flag, availability status, and channel applicability. Feeds Oracle MICROS POS and Olo Digital Ordering Platform for guest customization.' .

ind:PmixRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Pmix Record' ;
    rdfs:comment 'Transactional menu performance record capturing the sales volume, revenue contribution, and margin performance of each menu item at a restaurant for a given reporting period (day/week/daypart). Tracks units sold, gross sales, net sales, discount amount, void count, contribution margin amount, contribution margin percentage, rank within category, daypart breakdown, channel breakdown, and menu engineering classification (star/plow-horse/puzzle/dog). References item_cost for theoretical COGS comparison but does NOT own cost data. Core input for menu engineering reviews, pricing optimization, item lifecycle decisions, and LTO performance evaluation.' .

ind:ItemCost rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Item Cost' ;
    rdfs:comment 'Transactional record capturing the theoretical COGS (Cost of Goods Sold) for each menu item at a point in time, derived from recipe BOM and current ingredient purchase prices. Tracks theoretical food cost amount, theoretical CoGS%, actual CoGS% (from inventory management systems like MarketMan), variance amount, variance percentage, cost calculation date, ingredient price snapshot reference, and cost approval status. Updated when ingredient prices change (weekly/daily frequency) — distinct from pmix_record which captures periodic sales performance. Feeds menu engineering decisions, pricing optimization, P&L reporting, and franchise profitability benchmarking.' .

ind:ComboMeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Combo Meal' ;
    rdfs:comment 'Master record for bundled combo meal offerings — pre-defined combinations of menu items sold together at a bundle price (e.g., Value Meal, Family Pack, Kids Meal). Captures combo name, component items, bundle price, individual item price sum, bundle discount amount, applicable channels, daypart availability, and active status. Distinct from LTOs in that combos are permanent or semi-permanent menu fixtures.' .

ind:Item86Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Item 86 Event' ;
    rdfs:comment 'Transactional record capturing an \'86\' event — when a menu item is temporarily removed from service at a specific restaurant due to stockout, quality issue, or equipment failure. Captures the item, restaurant, channel affected, start timestamp, end timestamp, reason code (out-of-stock/equipment/quality/recall), reported-by, and resolution action. Critical for operational compliance and guest experience tracking.' .

ind:GuestOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Guest Order' ;
    rdfs:comment 'Core transactional header record for every guest order placed across all service channels (POS/MICROS, drive-thru, OLO, 3PD, catering, kiosk). Captures order-level attributes: ticket number, order type, service channel, daypart, order status, guest count, total amount, tax total, discount total, timestamps (placed, promised, completed), and source system reference. This is the authoritative SSOT for all order transactions — every order_item, order_payment, order_status_event, and kds_ticket FKs back to this record.' .

ind:OrderItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Item' ;
    rdfs:comment 'Line-item detail for each menu item within a guest order. Captures the ordered menu item, quantity, unit price, modifiers applied, line-level discounts, PMIX contribution, preparation instructions, KDS station routing, and item-level fulfillment status. Supports PMIX analysis, COGS% calculation, and kitchen throughput reporting.' .

ind:OrderModifier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Modifier' ;
    rdfs:comment 'Records all customizations and modifiers applied to individual order items, including add-ons, substitutions, removals, and special preparation requests. Captures modifier name, modifier group, price delta, and whether the modifier was guest-initiated or system-defaulted. Essential for accurate COGS% tracking and kitchen execution fidelity.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Captures all payment tender records associated with a guest order, supporting split-tender scenarios. Includes tender type (cash, credit, debit, gift card, loyalty redemption, 3PD settlement), amount tendered, change due, authorization code, PCI-compliant masked card data, payment processor reference, and payment status. Authoritative SSOT for order-level payment capture; financial settlement lives in the finance domain.' .

ind:StatusEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status Event' ;
    rdfs:comment 'Immutable event log tracking every lifecycle state transition of a guest order from placement through fulfillment or cancellation. States include: received, acknowledged, in_preparation, ready, dispatched, delivered, cancelled, voided. Captures the state, prior state, transition timestamp, triggering actor (POS, KDS, OLO, 3PD webhook), and any exception reason. Enables SOS (Speed of Service) and ticket time analytics.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Reference master defining all service channels through which guest orders are placed: POS (dine-in, counter), drive-thru (DT), online ordering (OLO), third-party delivery (3PD — DoorDash, Uber Eats, Grubhub), catering, kiosk, and mobile app. Captures channel code, channel category, integration platform, fulfillment mode (dine-in, takeout, delivery, curbside), and active status. Serves as the FK target for guest_order channel attribution, channel-mix reporting, and ACV benchmarking.' .

ind:DeliveryOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Order' ;
    rdfs:comment 'Manages the delivery fulfillment record for orders dispatched via third-party delivery (3PD) platforms (DoorDash, Uber Eats, Grubhub) or first-party delivery. Captures 3PD platform reference ID, courier assignment, estimated and actual delivery times, delivery distance, delivery fee, platform commission rate, delivery status, and any delivery exception (late, missing item, cancelled). Bridges the Olo digital ordering platform data with internal order records.' .

ind:CateringOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Catering Order' ;
    rdfs:comment 'Manages large-format catering orders placed by corporate, event, or group guests. Captures catering event date, headcount, delivery or pickup mode, setup requirements, special dietary accommodations, catering package selected, quoted price, deposit amount, balance due, and fulfillment status. Distinct from standard guest orders due to advance booking lead time, custom BOM requirements, and dedicated fulfillment workflow.' .

ind:Discount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Discount' ;
    rdfs:comment 'Records all discounts, promotions, coupons, and comp adjustments applied to a guest order or individual order items. Captures discount type (coupon, loyalty redemption, employee meal, manager comp, promotional LTO, bundle/combo deal), discount amount or percentage, promotion reference, authorization employee, and pre-approved vs. exception-based flag. Supports COGS% impact analysis, promotional ROI tracking, and combo savings attribution.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Captures refund and void transactions issued against a completed or in-progress guest order. Records refund reason (wrong item, quality complaint, missing item, guest dissatisfaction), refund amount, refund method (original tender, gift card, loyalty points), authorizing manager, refund timestamp, and whether the refund was full or partial. Supports CSAT root-cause analysis and exception management.' .

ind:Tax rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Tax' ;
    rdfs:comment 'Records tax line details applied to a guest order, supporting multi-jurisdiction tax compliance. Captures tax authority (federal, state, county, city), tax type (sales tax, VAT, beverage tax, bag fee), tax rate, taxable amount, tax amount, and whether the tax was included in the menu price or added at checkout. Supports financial reconciliation and regulatory tax reporting across all restaurant locations.' .

ind:Unit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Unit' ;
    rdfs:comment 'Master record for every restaurant unit — company-owned and franchised. The authoritative identity of each physical location including unit number, brand, concept type (QSR/casual/fine-dining), ownership model (company-owned vs. franchised), legal entity name, trade name, opening date, closure date, current operational status, and geographic coordinates. This is the operational anchor for the entire restaurant domain and the primary FK target for all cross-domain joins (order, inventory, workforce, finance, franchise). One row per physical restaurant location. All other restaurant domain products reference this entity.' .

ind:LocationProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Location Profile' ;
    rdfs:comment 'Physical and geographic attributes of each restaurant unit including full street address, city, state, province, postal code, country, DMA (Designated Market Area), trade area classification, latitude/longitude, timezone, locale, accessibility features, parking capacity, drive-thru lane count, patio seating availability, and proximity to key landmarks. Supports site analytics, delivery radius configuration, and regional reporting.' .

ind:FormatConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Format Config' ;
    rdfs:comment 'Defines the operational format, physical configuration, and total capacity of a restaurant unit. Includes dining format (QSR, fast-casual, casual, fine-dining), service model (counter, table, drive-thru, kiosk), FOH layout (total indoor seating capacity, outdoor/patio seating capacity, bar seating count, private dining room capacity, ADA-compliant seating count, table count, cover count), BOH layout (kitchen footprint sq ft, cooking lines, prep stations), drive-thru configuration (lane count, stacking capacity for vehicles), kiosk count, counter service positions, and maximum cover count per daypart. This is the single source of truth for all physical capacity and layout attributes of a unit — governs brand standard compliance, throughput benchmarking, labor staffing ratios, health department permit compliance, and fire marshal occupancy limits.' .

ind:OperatingHours rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Scheduled operating hours for each restaurant unit by day of week and daypart (breakfast, lunch, dinner, late-night, 24hr). Captures open time, close time, daypart start/end times, holiday schedule overrides, seasonal hour adjustments, drive-thru-specific hours, delivery window hours, and last-order cutoff times. Used for order routing, labor scheduling, and SSS (Same-Store Sales) period alignment.' .

ind:EquipmentAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Equipment Asset' ;
    rdfs:comment 'Inventory of all BOH and FOH equipment assets installed at each restaurant unit including all equipment types (fryer, grill, oven, KDS stations, POS terminals, refrigeration units, ice machines, espresso machines, drive-thru timers). Captures make, model, serial number, installation date, warranty expiry, last service date, next scheduled maintenance date, asset condition rating, replacement cost, software version (for digital equipment), and equipment-specific configuration attributes. Supports R&M (Repairs and Maintenance) planning, CapEx forecasting, PCI DSS compliance for payment terminals, and food safety compliance for temperature-critical equipment.' .

ind:BrandStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Brand Standard' ;
    rdfs:comment 'Defines the brand standards and SOPs (Standard Operating Procedures) applicable to each restaurant unit by concept type and ownership model. Captures standard code, standard name, standard category (food quality, cleanliness, service, safety, brand presentation), applicable format (QSR/casual/fine-dining), compliance requirement level (mandatory/recommended), effective date, expiry date, governing body reference (NRA, FDA, OSHA), and linked SOP document reference. Operational anchor for audit and compliance workflows.' .

ind:UnitPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Unit Performance' ;
    rdfs:comment 'Periodic operational and financial performance record for each restaurant unit capturing AUV (Average Unit Volume), SSS (Same-Store Sales) growth %, comp sales (Comparable Store Sales) vs. prior period, ADT (Average Daily Transactions), ATC (Average Transaction Count), ACV (Average Check Value), COGS% (Cost of Goods Sold Percentage), Labor% (Labor Cost Percentage), Waste% (Food Waste Percentage), EBITDA, and net revenue. Sourced from Oracle MICROS POS and SAP S/4HANA. Primary performance scorecard for unit-level P&L management.' .

ind:CapacityConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Capacity Config' ;
    rdfs:comment 'Defines the seating and service capacity configuration for each restaurant unit including total indoor seating capacity, outdoor/patio seating capacity, bar seating count, private dining room capacity, drive-thru stacking capacity (number of vehicles), kiosk count, counter service positions, maximum cover count per daypart, and ADA-compliant seating count. Used for throughput planning, labor staffing ratios, and health department permit compliance.' .

ind:AreaManagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Area Management' ;
    rdfs:comment 'Defines the operational management hierarchy above the restaurant unit level. Captures area/district/region boundaries, area manager assignment (name, employee ID, assignment effective dates), number of units in area, geographic region, division, brand, and area performance targets (AUV target, SSS target, CSAT target, Labor% target). Supports multi-unit management accountability, area manager performance reviews, regional performance rollups, and franchise territory alignment. One row per area/district assignment period.' .

ind:UnitOwnership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Unit Ownership' ;
    rdfs:comment 'Tracks the ownership and operational control history of each restaurant unit including ownership type (company-owned, franchised, licensed, joint-venture), franchise partner reference, ownership effective start date, ownership effective end date, transfer reason (new franchise award, resale, corporate acquisition, closure), and operating entity legal name. Provides the authoritative ownership timeline for royalty calculation, P&L attribution, and franchise compliance reporting. Complements the franchise domain without duplicating franchise partner master data.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Chart of accounts master record for the general ledger in SAP S/4HANA (CO/GL modules). Defines every account code used across all legal entities, including P&L accounts, balance sheet accounts, cost element accounts, and statistical accounts. Supports multi-entity consolidation, GAAP/IFRS dual-ledger reporting, and account group hierarchies. Each record carries account type (asset, liability, equity, revenue, expense), functional area, account group, and currency settings.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational cost center master data and cost allocation activity from SAP S/4HANA CO module. Represents the smallest unit of cost accountability — individual restaurant units, regional offices, corporate departments, and shared service centers. Master data tracks cost center type (restaurant, regional, corporate), responsible manager, controlling area, profit center assignment, valid-from/to dates, and hierarchy node. Allocation activity captures periodic distributions of shared costs (corporate overhead, IT, HR, marketing fund) using defined allocation keys (headcount, revenue, square footage), including sender/receiver relationships, allocation cycles, allocation rules, basis amounts, and reversal indicators. Enables fully-loaded restaurant P&L, Labor%/COGS%/OpEx allocation, accurate EBITDA by unit, and transparent overhead burden rates for franchise vs. company-owned comparisons.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center master record from SAP S/4HANA EC-PCA module. Represents a business segment for internal P&L reporting — individual restaurant units, brand segments, geographic regions, or franchise vs. company-owned groupings. Supports SSS (Same-Store Sales) reporting, AUV (Average Unit Volume) tracking, and EBITDA decomposition by segment. Carries hierarchy assignment, controlling area, and responsible executive.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master record for each legal entity (company code) within the Restaurants corporate structure and intercompany transaction activity from SAP S/4HANA FI. Covers company-owned operating entities, holding companies, franchise subsidiaries, and joint ventures across all geographies. Entity master stores fiscal year variant, chart of accounts assignment, local currency, tax jurisdiction, GAAP/IFRS reporting standard, and consolidation group membership. Intercompany activity captures management fee charges, shared service allocations, intercompany loans, cross-entity food supply transfers, netting status, elimination flags, and reconciliation periods. Foundation for multi-entity financial consolidation, intercompany elimination in consolidated financial statements, and segment reporting.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'General ledger journal entry from SAP S/4HANA FI-GL, encompassing both header and line-level detail. Captures every financial posting across all legal entities — accruals, reversals, intercompany eliminations, period-end adjustments, and manual corrections. Header stores document type, posting date, fiscal period, reference document, ledger (leading/non-leading), currency, and posting user. Each line carries GL account, cost center, profit center, functional area, business area, debit/credit amount in document and local currency, tax code, assignment field, and line item text. The authoritative audit trail for all GL movements supporting GAAP/IFRS compliance, P&L drill-down, balance sheet construction, intercompany reconciliation, and external audit evidence.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit/credit line items within a GL journal entry from SAP S/4HANA FI-GL. Each line carries GL account, cost center, profit center, functional area, business area, amount in document and local currency, tax code, assignment field, and line item text. Enables granular P&L and balance sheet drill-down, cost center reporting, and intercompany reconciliation at the line level.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable vendor invoice and payment lifecycle from SAP S/4HANA FI-AP, encompassing invoice header, line-level detail, and outbound payment settlement. Records all supplier invoices for food and beverage purchases, equipment, R&M, utilities, and services. Header stores vendor ID, invoice date, due date, payment terms, gross/net amount, tax, currency, payment block, three-way match status, and dunning level. Each line captures purchased item/service, quantity, unit price, GL account, cost center, PO reference, goods receipt reference, and tax code. Payment data stores payment method (ACH, wire, check), payment date, bank account, cleared invoice references, discount taken, and payment run ID. Enables COGS% analysis by ingredient category, food vs. non-food spend split, three-way match reconciliation, DPO (Days Payable Outstanding) tracking, cash discount optimization, and cash flow forecasting.' .

ind:ApPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Payment' ;
    rdfs:comment 'Accounts payable payment run records from SAP S/4HANA FI-AP. Captures outbound payments to food suppliers, equipment vendors, landlords (CAM charges), and service providers. Stores payment method (ACH, wire, check), payment date, bank account, cleared invoice references, discount taken, payment amount in local and document currency, and payment run ID. Supports cash management, DPO (Days Payable Outstanding) tracking, and supplier relationship management.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable invoice and payment lifecycle from SAP S/4HANA FI-AR. Covers all revenue-generating billings and their collection: royalty invoices to franchisees, catering and corporate account billings, gift card liability settlements, and intercompany charges. Invoice data stores customer/franchisee ID, invoice date, due date, payment terms, gross amount, tax, currency, dunning level, and collection status. Payment receipt data captures payment method, receipt date, bank clearing account, applied invoice references, unapplied cash amounts, and DSO (Days Sales Outstanding) impact. Supports royalty income accounting, franchise fee revenue recognition (ASC 606/IFRS 15), franchisee cash flow monitoring, and aging analysis.' .

ind:ArPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Payment' ;
    rdfs:comment 'Accounts receivable payment receipt records from SAP S/4HANA FI-AR. Captures inbound payments from franchisees (royalties, franchise fees, marketing fund contributions), corporate catering clients, and intercompany settlements. Stores payment method, receipt date, bank clearing account, applied invoice references, unapplied cash amounts, and DSO (Days Sales Outstanding) impact. Critical for royalty income reconciliation and franchise cash flow monitoring.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master record, depreciation lifecycle, and impairment tracking from SAP S/4HANA FI-AA. Tracks all capitalized assets across company-owned restaurants and corporate facilities: kitchen equipment (fryers, grills, KDS units), POS hardware, leasehold improvements, furniture and fixtures, vehicles, and IT infrastructure. Master data stores asset class, acquisition date, acquisition cost, useful life, depreciation method, salvage value, and CapEx project reference. Depreciation detail captures periodic planned/posted depreciation by fiscal period, depreciation area (book, tax, IFRS), depreciation amount, accumulated depreciation, net book value, and depreciation key. Supports CapEx vs. OpEx classification, EBITDA calculation (adding back D&A), tax depreciation schedules, impairment testing, and asset disposal/retirement processing for restaurant closures and remodels.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Annual and rolling financial budget and forecast records from SAP S/4HANA CO, encompassing plan header and granular line-level allocations with cash forecasting integration. Stores budget version (original, revised, rolling forecast), fiscal year, approval status, and approving authority. Line-level detail specifies GL account, cost center or profit center, fiscal period, budget category (food cost, labor, occupancy, marketing, R&M, CapEx), planned amount, and currency. Supports monthly phasing of annual budgets, variance analysis (actual vs. budget), NRO CapEx budgeting, daypart-level labor budgeting, food cost (COGS%) targets by restaurant unit, cash flow forecasting by period, and liquidity planning for treasury operations.' .

ind:BudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Line' ;
    rdfs:comment 'Granular line-level budget allocations within a budget plan. Each line specifies the GL account, cost center or profit center, fiscal period, budget category (food cost, labor, occupancy, marketing, R&M), planned amount, and currency. Supports monthly phasing of annual budgets, daypart-level labor budgeting, and food cost (COGS%) targets by restaurant unit.' .

ind:BankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Bank Account' ;
    rdfs:comment 'Corporate bank account master record and daily transactional statement activity from SAP S/4HANA FI-TR (Treasury). Master data defines all operating, payroll, concentration, and zero-balance accounts across legal entities and geographies — storing bank name, account number (masked), IBAN/routing, account type, currency, cash pool group, signatory list, and reconciliation GL account. Statement lines capture daily electronic bank statement imports including value date, posting date, transaction type (credit/debit), amount, bank reference, counterparty name, clearing status, and matched GL posting. Supports daily automated bank reconciliation, real-time cash position reporting, fraud detection for restaurant cash deposits, POS settlement flow matching, and treasury cash pooling across entities.' .

ind:StockItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Item' ;
    rdfs:comment 'Master record for every SKU tracked in restaurant inventory — food, beverage, packaging, and non-food supplies. Captures SKU code, item name, unit of measure (UOM), item category (protein, produce, dry goods, beverage, paper goods, cleaning), storage class (ambient, refrigerated, frozen), reorder point, reorder quantity, standard cost, vendor item code, shelf life days, HACCP temperature range, allergen flags, daypart applicability, seasonal adjustment flags, and active status. Also owns PAR-level configuration per unit-location: PAR quantity, minimum quantity (reorder point), maximum quantity (shelf capacity), day-of-week overrides, seasonal adjustment flags, and effective date range. This is the SSOT for all stockable items and their replenishment parameters managed through MarketMan.' .

ind:StockLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Location' ;
    rdfs:comment 'Master record for every physical storage location within a restaurant unit where inventory is held — walk-in cooler, walk-in freezer, dry storage room, BOH prep area, FOH service station, bar storage. Captures location code, location name, location type (refrigerated, frozen, ambient, bar), temperature zone, capacity (cubic feet or shelf count), restaurant unit reference, and active status. Enables granular stock-on-hand tracking by storage zone.' .

ind:OnHandBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'On Hand Balance' ;
    rdfs:comment 'Current stock-on-hand snapshot for each SKU at each storage location within a restaurant unit. Captures quantity on hand, quantity reserved (committed to prep), quantity available, last physical count date, last adjustment date, last received date, unit cost, extended value, and variance from PAR level. Updated by receiving, transfers, waste events, and physical counts. The authoritative real-time inventory position record used for replenishment decisions and food cost reporting.' .

ind:ReceivingOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Receiving Order' ;
    rdfs:comment 'Records the receipt of goods delivered to a restaurant unit from a supplier or distribution center, capturing both delivery-level header information and line-level SKU detail in a single consolidated entity. Header attributes: purchase order reference, delivery date/time, supplier reference, driver name, invoice number, total received value, receiving status (pending/partial/complete/rejected), temperature check result, seal integrity check, and receiving manager reference. Line attributes (one per SKU received): stock item reference, ordered vs received vs rejected quantities, unit of measure, unit cost, extended cost, lot number, expiration date, temperature at receipt (°F/°C), condition code (acceptable/damaged/short-dated/rejected), and variance reason code. Links to MarketMan purchase order and SAP S/4HANA goods receipt. Drives on-hand balance updates, COGS% tracking, and supplier performance measurement.' .

ind:PhysicalCount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Count' ;
    rdfs:comment 'Records scheduled or ad-hoc physical inventory count events at a restaurant unit, capturing both count-level header metadata and line-level SKU counts in a single consolidated entity. Header attributes: count date, count type (full/spot-check/cycle-count/pre-close/post-close), count status, count period, initiated-by/approved-by employees, total variance value and percentage. Line attributes (one per SKU-location counted): stock item reference, storage location, system quantity (book inventory), counted quantity, variance quantity and value ($), unit of measure, unit cost, count method (manual/scan), counted-by employee reference, and recount flag. Variance lines trigger investigation workflows and feed period-end food cost reconciliation and COGS% reporting.' .

ind:WasteLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Waste Log' ;
    rdfs:comment 'Records every food waste event at a restaurant unit — spoilage, overproduction, prep waste, expiration, and quality rejection. Captures waste date, waste time, stock item reference, waste quantity, unit of measure, waste cost ($), waste category (spoilage, overproduction, prep loss, expiration, quality-reject, theft/unknown), waste reason description, responsible station (BOH/FOH), recorded-by employee reference, and manager approval flag. Drives Waste% KPI calculation and supports yield management and COGS% optimization.' .

ind:StockTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Transfer' ;
    rdfs:comment 'Records the movement of inventory between restaurant units, between storage locations within a unit, or from a unit back to a distribution center — capturing both transfer header and line-level SKU detail in a single consolidated entity. Header attributes: transfer date, transfer type (inter-unit/intra-unit/return-to-vendor/return-to-DC), origin and destination units/locations, transfer status, requested-by/approved-by employees, and total transfer value. Line attributes (one per SKU transferred): stock item reference, transferred quantity, unit of measure, unit cost, extended cost, lot number, expiration date, and condition code. Maintains inventory accuracy across the restaurant network and supports inter-unit food cost allocation.' .

ind:ReplenishmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Replenishment Order' ;
    rdfs:comment 'Automated or manually triggered replenishment order generated when stock falls below PAR level or reorder point, capturing both order header and line-level SKU detail in a single consolidated entity. Header attributes: order date, order type (auto-PAR/manual/emergency), restaurant unit reference, supplier reference, requested delivery date, order status, total order value, order source (MarketMan auto-replenishment/manager-initiated), and approval status. Line attributes (one per SKU ordered): stock item reference, ordered quantity, unit of measure, unit cost, extended cost, PAR quantity at time of order, on-hand quantity at time of order, variance-to-PAR quantity, and confirmed delivery quantity. Bridges inventory management and procurement; links to purchase orders in Coupa and SAP MM. Enables food cost forecasting and supplier fill-rate tracking.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Records manual adjustments to on-hand inventory balances outside of standard receiving, waste, or count workflows. Captures adjustment date, adjustment type (positive adjustment, negative adjustment, write-off, theft, breakage, system correction), stock item reference, storage location, adjusted quantity, adjustment value ($), reason code, supporting document reference, adjusted-by employee, and manager approval. Provides a complete audit trail for all non-standard inventory movements and supports shrinkage analysis.' .

ind:FoodCostPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Food Cost Period' ;
    rdfs:comment 'Period-level food cost summary record for each restaurant unit, capturing the calculated COGS% for a defined accounting period (weekly, bi-weekly, monthly). Captures period start date, period end date, opening inventory value ($), purchases value ($), transfers-in value ($), transfers-out value ($), waste value ($), closing inventory value ($), theoretical food cost ($), actual food cost ($), COGS% actual, COGS% theoretical, variance ($), and variance percentage. The operational food cost control record — NOT an analytics aggregate but the posted period-close record used by restaurant managers and finance.' .

ind:Uom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Uom' ;
    rdfs:comment 'Reference master for all units of measure used in inventory transactions — ordering UOM, storage UOM, and recipe UOM — plus their conversion factors. Captures UOM code, UOM name, UOM type (weight/volume/count/length), base UOM flag, and applicable item categories. Conversion detail: from-UOM, to-UOM, stock-item-specific overrides (item-specific conversions override global defaults), conversion factor, effective date, and source (vendor spec/lab measurement/standard). Supports accurate translation between ordering (case of 6), storage (each), and recipe (ounce/gram) contexts — critical for inventory valuation and COGS% calculation across all restaurant units.' .

ind:VendorItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Vendor Item' ;
    rdfs:comment 'Maps each stock item to the supplier(s) that provide it, capturing the supplier-specific item details used in ordering and receiving. Captures supplier reference, stock item reference, supplier item code (vendor SKU), supplier item description, order UOM, pack size, pack quantity, current unit cost, contract price flag, lead time days, minimum order quantity, preferred vendor flag, and active status. Enables multi-vendor sourcing for critical items and supports cost comparison and replenishment order generation. Distinct from the procurement domain\'s supplier master — this is the inventory-domain view of what each vendor supplies.' .

ind:Member rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member' ;
    rdfs:comment 'Master record for every enrolled loyalty program member. Captures member identity linkage (guest_id FK to guest domain), enrollment channel (OLO, POS, in-app, kiosk, staff-assisted), enrollment date, current tier assignment, lifetime points earned/redeemed, opt-in preferences, program assignment, auto-accrue payment linkage flag, and program status (active, suspended, churned). This is the SSOT for loyalty membership identity — distinct from the guest profile master in the guest domain.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Reference catalog of all loyalty membership tiers (e.g., Bronze, Silver, Gold, Platinum) defined in the Restaurants loyalty program. Stores tier name, tier code, qualification threshold (points or visit count), tier benefits summary, tier multiplier for points accrual, tier validity period, and sort order. Drives tier assignment logic and benefit entitlement across the program.' .

ind:TierHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier History' ;
    rdfs:comment 'Transactional audit of every tier change event for a loyalty member — captures previous tier, new tier, effective date, expiry date, reason code (qualification, demotion, manual override, promotional upgrade), and the triggering transaction reference. Enables tier progression analytics, member lifecycle tracking, and regulatory audit trails for program fairness.' .

ind:PointsLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Points Ledger' ;
    rdfs:comment 'Immutable financial-grade ledger recording every points movement for a loyalty member — accruals, redemptions, expirations, adjustments, bonus awards, goodwill credits, promotional credits, dispute resolutions, system error corrections, and fraud reversals. Each row captures transaction type (earn, redeem, expire, adjust, bonus, goodwill, reversal, correction), points delta, running balance, source channel (POS, OLO, 3PD), source order reference, campaign reference, expiry date of earned points, adjustment reason code, adjustment category (goodwill, dispute, error_correction, promotional, fraud), authorizing agent (for manual adjustments), approval status (auto_approved, pending_review, approved, rejected), processing timestamp, and related original transaction reference (for reversals/corrections). This is the single SSOT for ALL member point balance movements — no other product in this domain records points changes of any kind.' .

ind:Reward rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Reward' ;
    rdfs:comment 'Master catalog of all redeemable rewards available in the Restaurants loyalty rewards catalog — free menu items, discounts, merchandise, experiences, and partner offers. Captures reward name, reward type (food, discount, merchandise, experience), points cost, monetary value equivalent, redemption channel eligibility (POS, OLO, app), availability window (start/end date), quantity limit, restaurant applicability scope (all units, specific markets, specific formats), and active status. Distinct from promotional offers which are push-based incentives.' .

ind:Redemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Redemption' ;
    rdfs:comment 'Transactional record of every burn event by a loyalty member — both reward catalog redemptions (member-initiated pull from rewards catalog) and offer redemptions (program-initiated push incentives). Captures member reference, redemption type (reward, offer), reward or offer reference, redemption channel (POS, OLO, drive-thru, kiosk), restaurant unit, order reference, redemption timestamp, points deducted, monetary discount applied, offer assignment reference (for offer-type), delivery confirmation details, redemption status (pending, fulfilled, voided, expired, duplicate_attempt), and fulfillment confirmation. Unified SSOT for ALL burn events — no other product in this domain records redemption transactions. Enables holistic redemption analytics, PMIX impact analysis, offer ROI measurement, and reward popularity tracking.' .

ind:AccrualRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Accrual Rule' ;
    rdfs:comment 'Business rules governing how loyalty points are earned across channels, dayparts, menu categories, and member tiers. Each rule defines the earning trigger (purchase, visit, referral, birthday, survey), points awarded per dollar spent or per qualifying event, applicable tier multipliers, menu item or category scope, channel scope (POS, OLO, 3PD), effective date range, and rule priority for conflict resolution. Managed by the loyalty program team and versioned for auditability.' .

ind:Offer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Offer' ;
    rdfs:comment 'Master record for all personalized and mass loyalty offers distributed to members — targeted discounts, BOGO deals, bonus points events, LTO (Limited Time Offer) incentives, and gamification challenge rewards. Captures offer name, offer type (discount, bonus_points, free_item, challenge, sweepstakes), offer value, eligibility criteria (tier, segment, visit frequency), distribution channel (push notification, email, in-app, POS display), start/end dates, redemption limit per member, and offer status. Also owns member-level offer assignment detail: each assignment captures target member or segment, assignment channel, assignment timestamp, delivery status (sent, delivered, opened, clicked), member-specific expiry date, personalization flag, and engagement tracking. Sourced from Salesforce CRM campaign execution. Enables offer wallet management, delivery tracking, and distribution analytics.' .

ind:OfferAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Offer Assignment' ;
    rdfs:comment 'Association record linking a specific loyalty offer to a specific member or member segment, capturing the assignment channel, assignment timestamp, delivery status (sent, delivered, opened, clicked), expiry date for that member\'s instance of the offer, and whether the offer was personalized or mass-distributed. Enables offer delivery tracking and member-level offer wallet management.' .

ind:OfferRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Offer Redemption' ;
    rdfs:comment 'Transactional record of every loyalty offer redeemed by a member at a restaurant unit. Captures member reference, offer reference, redemption channel (POS, OLO, drive-thru), restaurant unit, order reference, redemption timestamp, discount value applied, and redemption status (fulfilled, voided, duplicate_attempt). Distinct from reward redemption — offers are push-distributed incentives while rewards are pull-selected from the catalog.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master configuration record for each loyalty program operated by Restaurants — covering program name, program type (points-based, visit-based, hybrid, subscription), currency name (e.g., \'Stars\', \'Points\', \'Coins\'), points-to-dollar conversion rate, program launch date, geographic scope (global, regional, country), applicable restaurant formats (QSR, casual, fine-dining), enrollment channels, and program status. Supports multi-program architectures across franchise and company-owned units.' .

ind:EnrollmentEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Enrollment Event' ;
    rdfs:comment 'Transactional record of every loyalty program enrollment action — new enrollments, re-enrollments, and program transfers. Captures member reference, program reference, enrollment channel (OLO, POS, in-app, kiosk, staff-assisted), enrollment restaurant unit, enrollment timestamp, referral source (organic, referral_code, campaign), welcome offer issued flag, and enrollment status. Feeds acquisition funnel analysis and channel attribution for the loyalty program.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Site' ;
    rdfs:comment 'Master record for every physical site under evaluation, active operation, or disposition in the restaurant real estate portfolio. Captures site identification, geographic coordinates, full address, market classification, trade area demographics, traffic counts (ADT), visibility scores, zoning classification, site type (pad, inline, endcap, freestanding, drive-thru capable), ownership status (owned/leased/ground-lease), parcel size, and current lifecycle stage (prospecting, under negotiation, LOI executed, active, temporarily closed, permanently closed, disposed). Serves as the SSOT for all site-level real estate data across the NRO pipeline and existing portfolio. Links to restaurant unit in the restaurant domain.' .

ind:Lease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Lease' ;
    rdfs:comment 'Authoritative master record for every lease agreement governing a restaurant location, including ground leases, building leases, and sublease arrangements. Captures lease type, commencement and expiration dates, base rent, rent escalation schedule, renewal option terms, termination clauses, co-tenancy provisions, exclusive use rights, permitted use language, landlord entity, guarantor, and IFRS 16 / ASC 842 classification (operating vs. finance lease). Tracks right-of-use (ROU) asset value, lease liability, discount rate, and remaining lease term for accounting compliance. Includes structured clause abstractions: clause type (rent escalation, renewal option, termination right, co-tenancy, exclusivity, assignment, subletting, HVAC responsibility, CAM cap, audit right), clause text, effective date range, financial impact flag, and compliance obligation indicator. Links to site and landlord records. Serves as the SSOT for all lease agreement data including clause-level detail.' .

ind:Landlord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Landlord' ;
    rdfs:comment 'Master record for every landlord, property owner, or lessor entity with whom the company maintains a real estate relationship. Captures landlord legal name, entity type (REIT, private owner, developer, municipality), primary contact details, billing address, tax identification, preferred communication channel, relationship tier, and portfolio overlap count. Tracks relationship health score, escalation history, and negotiation posture. Serves as the SSOT for landlord identity within the real estate domain.' .

ind:RentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Rent Schedule' ;
    rdfs:comment 'Periodic rent obligation schedule derived from executed lease agreements, capturing each scheduled rent payment period, base rent amount, percentage rent threshold and rate, CAM (Common Area Maintenance) estimate, real estate tax contribution, insurance contribution, total occupancy cost, and payment due date. Supports IFRS 16 / ASC 842 lease liability amortization schedules, cash flow forecasting, and occupancy cost benchmarking against AUV (Average Unit Volume). One record per lease per billing period.' .

ind:RentPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Rent Payment' ;
    rdfs:comment 'Transactional record of each rent and occupancy cost payment made to a landlord, capturing payment date, payment method, amount paid (base rent, CAM, taxes, insurance), payment reference number, lease period covered, variance from scheduled amount, late fee applied flag, and reconciliation status. Supports accounts payable integration with SAP S/4HANA, landlord dispute resolution, and occupancy cost audit trails. Distinct from the rent schedule (obligation) — this captures actual cash disbursements.' .

ind:NroProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Nro Project' ;
    rdfs:comment 'Master record for each New Restaurant Opening (NRO) development project, tracking the full lifecycle from site approval through construction completion and restaurant opening. Captures project name, restaurant unit number, project type (new build, relocation, conversion), target and actual opening dates, project manager, general contractor, architect of record, total CapEx budget reference, and blocking issues. Includes detailed construction milestone tracking: each milestone (site plan approval, permit submission, permit issuance, groundbreaking, foundation complete, steel erection, MEP rough-in, drywall, equipment installation, punch list, final inspection, certificate of occupancy, opening day) with planned date, actual date, variance in days, responsible party, completion status, and blocking issues. Supports critical path management, CapEx draw schedule alignment, and integration with SAP S/4HANA CapEx modules and FranConnect NRO tracking.' .

ind:CapexBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Capex Budget' ;
    rdfs:comment 'CapEx (Capital Expenditure) planning, budgeting, and spend tracking record for each real estate project (NRO, remodel, relocation, or major facility upgrade). Budget envelope: total approved budget, budget by cost category (land, building shell, leasehold improvements, FF&E, signage, technology, soft costs), budget version, approval date, approving authority, funding source. Actual spend detail: each invoice-level expenditure event with vendor, cost category, amount, payment date, PO reference, SAP cost element, budget line item, cumulative spend to date, and variance to budget. Enables real-time CapEx tracking, budget burn rate monitoring, cost-to-complete forecasting, and draw schedule management. Integrates with SAP S/4HANA CO (Controlling) and Coupa Procurement for PO-to-invoice matching. Serves as the single source of truth for both authorized budgets and actual capital expenditures.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for the physical facility (building and improvements) associated with each restaurant location, capturing building square footage, seating capacity (FOH covers), drive-thru lane configuration (DT lanes, stacking capacity), kitchen layout type (BOH configuration), building ownership (owned/leased shell), year built, last remodel date, remodel type, ADA compliance status, energy rating, utility account references, and facility condition score. Distinct from the site (land/location) — this represents the built structure. Links to the restaurant unit in the restaurant domain.' .

ind:MaintenanceWorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Maintenance Work Order' ;
    rdfs:comment 'Transactional record for each R&M (Repairs and Maintenance) work order issued for a restaurant facility, capturing work order number, facility, issue category (HVAC, plumbing, electrical, equipment, structural, exterior, signage), issue description, priority level, reported date, assigned vendor/technician, scheduled date, completion date, labor hours, parts cost, total cost, warranty claim flag, and resolution notes. Supports OpEx R&M spend tracking, vendor performance management, and preventive maintenance compliance. Integrates with facility management workflows.' .

ind:MaintenanceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Maintenance Contract' ;
    rdfs:comment 'Master record for each preventive maintenance and service contract covering restaurant facility equipment and systems, capturing contract type (HVAC PM, hood cleaning, grease trap, pest control, elevator, fire suppression, refrigeration), service provider, covered equipment list, service frequency, contract start and end dates, annual contract value, SLA response time, and auto-renewal terms. Enables R&M budget forecasting, vendor contract compliance tracking, and equipment warranty management. Distinct from procurement contracts — this is facility-specific service agreements.' .

ind:LeaseAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Realestate ;
    rdfs:label 'Lease Amendment' ;
    rdfs:comment 'Transactional record for each lease lifecycle change event including executed amendments, renewal exercises, option exercises, and lease modifications. Captures event type (rent modification, term extension, renewal exercise, space expansion/reduction, permitted use change, assignment consent, landlord work letter, co-tenancy waiver, early termination), effective date, financial impact (rent change amount, TI allowance received, free rent granted, new rent amount, rent delta versus expiring rent), negotiation details (start date, option exercise deadline, negotiating broker, approval authority, negotiation outcome), option number exercised (for renewals), renewal term length, new expiration date, and execution date. Maintains complete modification and renewal history for IFRS 16 / ASC 842 lease modification accounting, proactive lease expiration management, and portfolio renewal pipeline tracking.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for every marketing campaign executed by Restaurants, including promotional campaigns, LTO (Limited Time Offer) launches, brand awareness drives, and traffic-building initiatives. Captures campaign name, type (national/local/digital/traditional), objective (ADT lift, comp sales, brand awareness), status (planned/active/completed/cancelled), planned and actual start/end dates, target daypart, target guest segment, owning brand, channel mix, budget allocation, and campaign owner. SSOT for campaign identity across all marketing execution.' .

ind:CampaignExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Execution' ;
    rdfs:comment 'Transactional record capturing the actual execution of a campaign within a specific market, restaurant group, or channel. Tracks execution status, launch date, actual vs. planned go-live, execution channel (digital, social, OOH, radio, TV, in-store POS), market/DMA, restaurant scope (all units, franchise group, company-owned), execution owner, and any deviations from the campaign plan. Enables operational tracking of campaign rollout across thousands of restaurant units.' .

ind:MarketingLto rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Marketing Lto' ;
    rdfs:comment 'Master record for Limited Time Offers (LTOs) — the cornerstone of QSR marketing strategy. Captures LTO name, associated menu item(s), promotional price, offer window (start/end date), daypart applicability, channel availability (DT, OLO, 3PD, dine-in), target guest segment, PMIX impact forecast, sourcing readiness flag, and regulatory compliance status (FDA labeling). Links to campaign and menu domain for full LTO lifecycle management from ideation through execution.' .

ind:MediaPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Media Plan' ;
    rdfs:comment 'Master record for the media planning document that defines how advertising spend is allocated across channels (TV, radio, digital, social, OOH, print) for a given campaign or fiscal period. Captures plan name, planning period, total planned spend, channel mix breakdown, target DMA/market, agency partner, brand, daypart targeting, reach and frequency targets, and approval status. SSOT for pre-buy media strategy and spend authorization.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Master record for all guest-facing promotional offers and their issued instruments (coupons) — including discounts, BOGOs (buy-one-get-one), combo deals, value meals, loyalty reward redemptions, digital app deals, and physical/digital coupons. Captures promotion name, type (discount/BOGO/bundle/coupon/loyalty/app-exclusive), discount value or percentage, minimum purchase threshold, channel eligibility (POS/OLO/3PD/app), guest segment targeting, redemption limits, and associated campaign. For coupon-type promotions: coupon code, coupon format (single-use/multi-use/loyalty-exclusive/app-only/printed), eligible menu items or categories, issue date, expiry date, maximum redemption count, and fraud prevention flags (velocity checks, geo-fencing). SSOT for all promotional offer mechanics and issued coupon instruments.' .

ind:PromotionRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Promotion Redemption' ;
    rdfs:comment 'Transactional record capturing each instance of a guest redeeming a promotional offer at a restaurant. Captures redemption timestamp, channel (POS/OLO/3PD/app), restaurant unit, promotion redeemed, discount amount applied, order value before and after discount, guest identifier (if known), and loyalty member flag. Enables measurement of promotion uptake, discount liability, and incremental traffic driven by promotional activity.' .

ind:Coupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Coupon' ;
    rdfs:comment 'Master record for physical and digital coupons issued as part of marketing campaigns or standalone promotional activity. Captures coupon code, coupon type (single-use/multi-use/loyalty-exclusive/app-only/printed), face value or discount type, eligible menu items or categories, channel restrictions (POS/OLO/3PD/app), issue date, expiry date, maximum redemption count, and fraud prevention flags. Distinct from promotion (which defines the offer mechanic) — coupon is the specific issued instrument.' .

ind:Employee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Employee' ;
    rdfs:comment 'Master record for every restaurant employee across company-owned and franchised locations. Captures full employee lifecycle data including personal details, employment type (FTE/PTE), BOH/FOH role classification, hire date, termination date, employment status, pay grade, home restaurant assignment, Workday HCM employee ID, declared availability windows (preferred dayparts, max weekly hours, blackout dates, cross-location availability), and current benefit enrollment summary. Single source of truth for workforce identity and worker profile across the enterprise.' .

ind:Shift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Represents a scheduled work shift for an employee at a specific restaurant location, daypart (breakfast, lunch, dinner, late-night), and station assignment (grill, fry, drive-thru, expo, host, bar, dish). Captures planned start/end times, actual clock-in/clock-out times, assigned BOH/FOH station, shift type (regular, overtime, on-call, training), break duration, scheduling source (Planday), and swap/coverage details (original assignee, covering employee, swap request reason, swap approval status, approval timestamp) when shift reassignment occurs. Core operational record for labor deployment, station coverage planning, Speed of Service (SOS) staffing optimization, and Planday shift coverage workflows.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Weekly or period-level labor schedule published for a restaurant location, representing the planned staffing plan across all dayparts. Captures schedule period (start/end dates), restaurant unit, total scheduled hours, scheduled Labor%, FTE count by daypart, publication status (draft/published/locked), and the manager who approved the schedule. Links to individual shifts for granular staffing detail.' .

ind:TimeEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Time Entry' ;
    rdfs:comment 'Captures actual clock-in and clock-out events for each employee per shift, sourced from Workday HCM time tracking or POS-integrated time clocks. Records regular hours, overtime hours, break time, missed punch flags, and manager approval status. Foundation for payroll processing, Labor% calculation, and compliance with FLSA/OSHA labor regulations.' .

ind:LaborForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Forecast' ;
    rdfs:comment 'Projected labor demand by restaurant, daypart, and week based on historical transaction volume (ADT/ATC), seasonal patterns, and planned promotions or LTOs. Captures forecasted cover count, expected throughput, recommended FTE count by BOH/FOH, projected Labor%, and the forecasting model version used. Drives Planday schedule generation and labor budget alignment.' .

ind:PayrollRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Payroll Record' ;
    rdfs:comment 'Period-level payroll summary for each employee, capturing gross pay, net pay, regular hours paid, overtime hours paid, tips declared, deductions (benefits, taxes, garnishments), pay period dates, and payroll run status. Sourced from Workday HCM payroll module. Serves as the authoritative payroll transaction record for finance integration and Labor% reporting.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Single source of truth for all employee learning credentials, training completions, and regulatory certifications required for foodservice operations. Covers external certifications (ServSafe Food Handler, ServSafe Manager, allergen awareness, HACCP, alcohol service permits, OSHA safety) and internal training completions (new hire orientation, food safety modules, POS/KDS operation, BOH/FOH SOPs, LTO product training, management development). Captures credential type, issuing body (NRA ServSafe, local health department, internal L&D), delivery method (in-person, e-learning, OJT), issue/completion date, expiration date, assessment score, trainer/facilitator, and compliance status. Critical for food safety regulatory compliance, health department inspections, scheduling eligibility validation, and employee development tracking.' .

ind:TrainingCompletion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Training Completion' ;
    rdfs:comment 'Records completion of training programs by employees, including new hire orientation, food safety modules, POS operation, KDS usage, BOH/FOH SOPs, LTO product training, and management development programs. Captures training program name, delivery method (in-person, e-learning, OJT), completion date, assessment score, and trainer/facilitator. Supports compliance tracking and performance development.' .

ind:LaborBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Budget' ;
    rdfs:comment 'Period-level labor budget targets by restaurant location, capturing budgeted Labor%, budgeted total labor dollars, budgeted FTE count by BOH/FOH, budgeted hours by daypart, budgeted SPLH (Sales Per Labor Hour), and the fiscal period. Serves as the financial target against which actual labor spend (from payroll_record and time_entry) and forecasted demand (from labor_forecast) are measured. Supports P&L management, AUV optimization, and manager accountability for labor cost control.' .

ind:HaccpPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Haccp Plan' ;
    rdfs:comment 'Master record for each restaurant units Hazard Analysis and Critical Control Points (HACCP) plan, including plan version, scope, approval status, regulatory framework alignment (FDA FSMA, ISO 22000, Codex Alimentarius), effective and expiration dates, responsible food safety manager, team members, and prerequisite program references. Serves as the authoritative SSOT for HACCP program governance across all company-owned and franchised units. Each plan undergoes annual review and revalidation.' .

ind:CriticalControlPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Critical Control Point' ;
    rdfs:comment 'Defines each Critical Control Point (CCP) within a HACCP plan, including the hazard type (biological, chemical, physical), critical limits (min/max temperature, pH, time), monitoring method, corrective action procedure, and verification frequency. Each CCP is tied to a specific process step (e.g., cooking, cooling, receiving) and HACCP plan version.' .

ind:FoodSafetyAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Food Safety Audit' ;
    rdfs:comment 'Header-and-line transactional record of each food safety audit conducted at a restaurant unit, including audit metadata (type: internal/third-party/health-department, date, auditor, overall score, pass/fail) and individual findings (category: critical/major/minor, regulatory reference, corrective action required, responsible party, due date, resolution status). Managed via Zenput. Supports QA compliance tracking, trend analysis, and regulatory reporting. Each audit contains zero-to-many findings as line items.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual finding or violation recorded during a food safety audit, capturing finding category (critical, major, minor), description, regulatory reference (FDA Food Code, local health code), corrective action required, responsible party, due date, and resolution status. Each finding is linked to a specific audit and restaurant unit.' .

ind:HealthInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Health Inspection' ;
    rdfs:comment 'Header-and-line record of official health inspections conducted by local health departments or regulatory authorities at restaurant units, including inspection header (date, inspector, agency, type: routine/follow-up/complaint-driven, overall grade, permit status, closure orders) and individual violations as line items (violation code, severity: critical/non-critical, FDA Food Code citation, corrective action required, compliance deadline, re-inspection outcome). This is the authoritative regulatory inspection record distinct from internal food safety audits.' .

ind:InspectionViolation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Inspection Violation' ;
    rdfs:comment 'Individual violation cited during an official health inspection, including violation code, description, severity classification (critical, non-critical), regulatory citation (FDA Food Code section, local ordinance), corrective action required, compliance deadline, and re-inspection outcome. Supports regulatory compliance tracking and trend analysis.' .

ind:CorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Tracks corrective and preventive actions (CAPA) initiated in response to food safety audit findings, health inspection violations, CCP deviations, temperature exceedances, pest control findings, or allergen incidents. Captures root cause analysis method (5-Why, fishbone), corrective action description, responsible manager, target and actual completion dates, verification method, effectiveness check outcome, and closure status. Serves as the central CAPA registry managed via Zenput task management, supporting FDA Food Code and ISO 22000 corrective action requirements.' .

ind:TemperatureLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Temperature Log' ;
    rdfs:comment 'Time-series log of temperature readings captured at critical monitoring points (walk-in coolers, freezers, hot-holding units, cooking equipment, receiving docks), including equipment ID, reading timestamp, measured temperature, unit of measure (°F/°C), critical limit thresholds, deviation flag, and monitoring method (manual probe, automated sensor). Core HACCP monitoring record per Principle 4.' .

ind:SanitationTaskLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Sanitation Task Log' ;
    rdfs:comment 'Transactional record of each completed or missed sanitation task execution at a restaurant unit, capturing task completion timestamp, employee who performed the task, actual chemical concentration measured, pass/fail status, and any deviation notes. Linked to the master sanitation schedule and managed via Zenput task management.' .

ind:FoodSafetyCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Food Safety Certification' ;
    rdfs:comment 'Unified food safety workforce compliance record covering both training events and resulting certifications held by restaurant employees. Training attributes: program name, type (onboarding/annual refresher/corrective retraining/allergen awareness), delivery method (in-person/e-learning/Zenput), completion date, assessment score, pass/fail, trainer identity. Certification attributes: type (ServSafe Manager/Food Handler/HACCP/allergen awareness), issuing body (NRA ServSafe, ANSI-accredited provider), certification number, issue date, expiration date, validity status. Supports regulatory staffing requirements, retraining triggers, and compliance dashboards.' .

ind:IllnessReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Foodsafety ;
    rdfs:label 'Illness Report' ;
    rdfs:comment 'Transactional record of a reported employee foodborne illness or suspected foodborne illness event at a restaurant unit, capturing report date, employee role, symptoms reported, onset date, suspected pathogen or food item, exclusion-from-work decision, return-to-work clearance date, and health department notification status. Supports FDA Food Code employee health policy compliance.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Master record for every guest identity across all service channels (dine-in, drive-thru, OLO, 3PD). Single source of truth for WHO the business serves — captures full identity and demographic attributes including name, contact details, date of birth, language preference, age band, gender identity, household income band, education level, employment status, geographic market classification, demographic data source (self-declared vs. third-party enrichment), enrichment provider and date. Also owns digital account attributes: username, account status (active/suspended/deactivated), registration date, registration channel, last login timestamp, device type, app version, two-factor authentication status, and account tier. Sourced primarily from Salesforce CRM, Olo Digital Ordering Platform, and brand mobile app. This is the anchor entity for the entire guest domain.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Address' ;
    rdfs:comment 'Stores all physical and delivery addresses associated with a guest profile, including home address, saved delivery addresses, and billing addresses. Captures address type, street, city, state/province, postal code, country, geolocation coordinates, delivery instructions, and validation status. Supports OLO delivery fulfillment and personalized marketing by geography.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Captures all guest-stated and inferred preferences, dietary restrictions, and food allergen declarations. Covers FDA major allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame) with severity levels (intolerance vs. allergy), dietary restriction types (vegetarian, vegan, halal, kosher, gluten-free), declaration source (self-declared, healthcare provider), cuisine preferences, favorite menu items, preferred service channel (dine-in, DT, OLO), preferred daypart, communication channel preferences (email, SMS, push), and marketing opt-in/opt-out flags. Sourced from Salesforce CRM, Olo guest data, and guest self-declaration. Drives personalization, targeted marketing, and HACCP-aligned guest food safety compliance including FDA allergen labeling requirements.' .

ind:ConsentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Consent Record' ;
    rdfs:comment 'Authoritative record of guest consent and privacy elections per regulatory requirement (GDPR, CCPA, CAN-SPAM). Tracks consent type (marketing email, SMS, data sharing, profiling), consent status (granted/withdrawn), consent timestamp, consent source channel, consent version/policy version, and expiry date. Mandatory for compliance with FDA labeling, FTC advertising regulations, and applicable data privacy laws. Immutable audit trail of all consent changes.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Defines guest segmentation classifications used for targeted marketing, personalization, and operational planning. Captures segment name, segment type (behavioral, demographic, value-based, lifecycle stage), definition criteria, effective date range, segment owner (marketing vs. operations), and channel applicability. Examples include high-frequency QSR visitors, lapsed guests, LTO responders, and high-ACV guests. Managed in Salesforce CRM.' .

ind:LifetimeValue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Lifetime Value' ;
    rdfs:comment 'Stores calculated and periodically refreshed guest lifetime value (LTV) metrics at the individual profile level. Captures total historical spend, visit frequency, average check value (ACV), average transaction count (ATC), predicted future value, LTV tier classification, first visit date, most recent visit date, and days since last visit. Refreshed on a scheduled cadence from order domain transactional data. Supports retention prioritization and loyalty tier management.' .

ind:SatisfactionSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Satisfaction Survey' ;
    rdfs:comment 'Records guest satisfaction survey instances with full question-level response detail. Captures survey type (CSAT, NPS, post-delivery, post-visit), delivery channel (email, SMS, in-app, receipt QR), delivery timestamp, completion status, NPS score (0-10), CSAT score, restaurant unit, daypart, and respondent profile. Includes granular question-level data: question text, question type (rating, open-text, multiple-choice), response value, response timestamp, and sentiment classification for open-text responses. Sourced from Salesforce CRM and Olo guest feedback flows. Enables CSAT/NPS driver analysis at both survey and question level, supporting operational improvement across FOH and BOH.' .

ind:Complaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Complaint' ;
    rdfs:comment 'Operational record of a guest complaint or service recovery case raised through any channel (in-restaurant, phone, digital, social media). Captures complaint category (food quality, speed of service/SOS, order accuracy, cleanliness, staff behavior), severity level, channel of receipt, restaurant unit, associated order reference, resolution status, resolution type (refund, replacement, apology), resolution timestamp, and escalation flag. Managed in Salesforce CRM service cloud.' .

ind:ChannelIdentity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Channel Identity' ;
    rdfs:comment 'Stores channel-specific guest identifiers that map back to the canonical guest profile. Captures the source system (Oracle MICROS POS, Olo, Salesforce CRM, 3PD partner, loyalty app), the external identifier in that system, identifier type (email, phone, loyalty card number, device ID, 3PD customer ID), creation date, and active status. Enables cross-channel identity stitching and supports the identity resolution process.' .

ind:Visit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Visit' ;
    rdfs:comment 'Captures each confirmed guest visit to a restaurant unit across all service modes (dine-in, DT, OLO, 3PD). Distinct from the order domain\'s order transaction — this is the guest-centric visit record that may span multiple orders or be a zero-spend visit (e.g., complaint resolution visit). Captures visit date, daypart, service mode, restaurant unit, party size (cover count), table number (dine-in), DT lane (drive-thru), visit duration, and whether the visit was incentivized by a promotion.' .

ind:DigitalAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Guest ;
    rdfs:label 'Digital Account' ;
    rdfs:comment 'Represents a guest\'s registered digital account on the brand\'s owned digital channels (mobile app, website, OLO platform). Captures account username, account status (active, suspended, deactivated), registration date, registration channel, last login timestamp, device type, app version, two-factor authentication status, and account tier. Distinct from the guest profile (identity) — this is the digital access credential and session management record sourced from Olo Digital Ordering Platform.' .

ind:Franchisee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Franchisee' ;
    rdfs:comment 'Master record for each franchise partner entity — the legal business entity (individual, LLC, corporation) that holds one or more franchise agreements with the brand. Captures franchisee identity, legal structure, ownership details, contact information, financial standing, FDD disclosure status, IFA membership, and FranConnect system ID. SSOT for franchise partner identity across the enterprise.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Authoritative record of each franchise agreement between the franchisor and a franchisee, encompassing the full agreement lifecycle from execution through renewal, transfer, or termination. Captures agreement type (initial, renewal, transfer, successor), effective and expiration dates, territory grant, initial franchise fee, royalty rate and basis, marketing fund contribution rate, renewal terms, and agreement status. Owns all lifecycle event records including: transfers (transferor/transferee, ROFR exercise, approval, transfer conditions, effective date), renewals (updated terms, FDD re-disclosure, renewal fee, execution date), and terminations (type, default notice, cure period, de-identification, post-termination obligations, non-compete). SSOT for all contractual franchise obligations and their complete lifecycle history. Supports FTC Franchise Rule Items 5, 6, 17 disclosure requirements.' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Defines the protected or exclusive geographic territory granted to a franchisee under a franchise agreement. Captures territory boundaries (polygon, zip codes, DMA, radius), territory type (exclusive, protected, non-exclusive), population count, trade area classification, territory status, and assignment history. Supports territory conflict resolution and development pipeline planning.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Transactional record of all periodic franchise fees billed to a franchisee for a specific reporting period, including royalties, marketing fund contributions, technology fees, and other recurring charges. Captures billing period, gross sales reported, rates applied, line-item amounts (royalty, marketing fund, technology, other), total amount billed, payment due date, payment status, and variance from prior period. Source of truth for franchise revenue recognition, AR aging, and marketing fund governance. Supports FDD Item 6 and Item 11 disclosure compliance.' .

ind:SalesReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Sales Report' ;
    rdfs:comment 'Franchisee-submitted periodic gross sales report used as the basis for royalty and marketing fund calculation, SSS (Same-Store Sales) tracking, and operational benchmarking. Captures reporting period (weekly, monthly), reported gross sales by daypart, net sales, transaction count (ATC), average check value (ACV), submission date, submission method (POS auto-pull, manual entry, EDI), validation status, and variance flags. Supports royalty billing, comp sales analysis, franchisee performance benchmarking, and FDD Item 19 financial performance representation validation.' .

ind:NroPipeline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Nro Pipeline' ;
    rdfs:comment 'Tracks all franchise capital construction and development projects from initiation through completion, including New Restaurant Openings (NROs), remodels, reimaging, refreshes, and conversions. Captures project type (new build, conversion, full remodel, refresh, reimaging, ADA compliance), project stage (site identified, LOI signed, lease executed, permits obtained, construction started, construction complete, training complete, opened/completed), target and actual completion dates, development type, assigned development consultant, capital investment estimate, approved contractor, permit and inspection status, brand approval status, contractual obligation source, and milestone completion dates. SSOT for the franchise development and facility lifecycle in FranConnect.' .

ind:DevelopmentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Development Schedule' ;
    rdfs:comment 'Contractual development schedule committing a franchisee to open a specified number of restaurants within defined time windows under a multi-unit development agreement (MUDA). Captures total units committed, units opened to date, units remaining, development period start and end dates, annual opening targets by year, cure period terms, and schedule compliance status. Supports franchise development pipeline forecasting and default tracking.' .

ind:ComplianceAudit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Compliance Audit' ;
    rdfs:comment 'Records the results of brand standards compliance audits conducted at franchised restaurant units. Captures audit date, audit type (scheduled, unannounced, follow-up), auditor identity, overall compliance score, section scores (food safety, cleanliness, service, brand standards, equipment), critical and non-critical violation counts, corrective action required flag, and audit disposition (pass, conditional pass, fail). Supports franchise agreement compliance enforcement and performance scorecard inputs.' .

ind:FeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Fee Schedule' ;
    rdfs:comment 'Records all one-time and recurring franchise fees charged to franchisees beyond royalties, including initial franchise fees, renewal fees, transfer fees, training fees, technology fees, and marketing fund contributions. Captures fee type, fee amount, billing trigger event, payment status, waiver or discount applied, and associated agreement. Complements royalty_invoice which handles periodic royalty billing specifically.' .

ind:TrainingEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Training Enrollment' ;
    rdfs:comment 'Tracks franchisee and designated manager enrollment and completion of required brand training programs (initial training, refresher, new product, food safety certification). Captures trainee identity, training program name, training type (classroom, online, in-restaurant), enrollment date, scheduled completion date, actual completion date, pass/fail status, certification issued, and expiration date. Supports compliance tracking for brand standards and ServSafe/NRA certification requirements.' .

ind:PerformanceScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Franchise ;
    rdfs:label 'Performance Scorecard' ;
    rdfs:comment 'Periodic franchisee performance evaluation record aggregating key operational and financial KPIs for a franchisee across their restaurant portfolio. Captures evaluation period, AUV (Average Unit Volume), SSS (Same-Store Sales) growth, CSAT score, NPS, compliance audit average score, royalty payment timeliness, training completion rate, food safety score, and overall performance tier (platinum, gold, silver, at-risk). Supports franchisee recognition programs and remediation prioritization.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for every supplier and vendor in the foodservice supply chain, including food and non-food suppliers, distributors, co-manufacturers, and their key contacts. Captures supplier identity, classification (broadline, specialty, local), approval status, diversity certification, payment terms, lead times, regulatory compliance status (FDA, USDA, HACCP), and primary/secondary contact information. SSOT for supplier identity and contact details across supply chain operations. Sourced from Coupa Procurement supplier master and SAP S/4HANA vendor master (MM).' .

ind:Ingredient rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Ingredient' ;
    rdfs:comment 'Master catalog of all food ingredients, raw materials, beverages, and packaging SKUs procured across the foodservice supply chain. Captures SKU code, ingredient name, commodity category, unit of measure, allergen flags (Big 9), USDA grade, country of origin, shelf life days, storage temperature requirements (ambient/refrigerated/frozen), and HACCP critical control classification. Serves as the supply-side item master linking to menu domain BOM for recipe costing. SSOT for ingredient identity across supply, inventory, and menu domains. Sourced from SAP MM material master and MarketMan Inventory Management.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Core transactional record for every purchase order issued to suppliers for food ingredients, beverages, packaging, and non-food supplies. Captures PO number, supplier reference, order date, requested delivery date, ship-to distribution center or restaurant, total PO value, currency, payment terms, approval status, and sourcing event linkage. Represents the contractual commitment to buy. Sourced from Coupa Procurement PO module and SAP S/4HANA MM purchasing.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Transactional record of inbound goods received at a distribution center or restaurant, including both header-level receipt information and line-level detail per SKU. Header captures receipt date/time, receiving location, PO reference, receiving condition, and inspector ID. Lines capture specific ingredient/SKU received, quantity accepted/rejected, lot number, expiration date, temperature at receipt (cold chain compliance), storage location assigned, and variance from PO quantity. Critical for three-way match (PO-receipt-invoice), HACCP traceability, and ingredient-level lot tracking. Sourced from SAP S/4HANA MM (MIGO) and MarketMan receiving module.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Accounts payable invoice record from a supplier for goods or services delivered. Captures invoice number, supplier ID, invoice date, due date, payment terms, gross amount, tax amount, net amount, currency, three-way match status (PO–GR–invoice), dispute flag, and payment status. Feeds SAP S/4HANA AP (FI-AP) for payment processing and COGS accrual. Sourced from Coupa invoice management and SAP S/4HANA FI.' .

ind:SupplierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supplier Contract' ;
    rdfs:comment 'Master record for negotiated supply agreements and their associated price schedules. Captures contract number, effective and expiration dates, volume commitments, rebate agreements, exclusivity terms, renewal type, and compliance status. Includes contracted unit prices per ingredient/SKU with validity periods, volume tiers, and price types (fixed, indexed, market-based). Used by supply chain for price validation during goods receipt and invoice matching, and for COGS variance analysis. Sourced from Coupa contract management module.' .

ind:ContractPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Contract Price' ;
    rdfs:comment 'Contracted unit price records tied to a supplier contract for specific ingredients or SKUs over a defined validity period. Captures ingredient/SKU reference, contracted unit price, currency, price validity start and end dates, price tier (volume break), and price type (fixed, indexed, market-based). Enables COGS% variance analysis against actual invoice prices and supports menu costing in the menu domain.' .

ind:DistributionCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Distribution Center' ;
    rdfs:comment 'Master record for each distribution center (DC), warehouse, and logistics node in the foodservice supply network including company-owned DCs, third-party logistics (3PL) facilities, cross-dock locations, and commissary kitchens. Captures DC code, name, full address, geographic region/market, facility type (ambient, refrigerated, frozen, mixed-temp), total storage capacity (pallet positions), operating hours, supported restaurant count, primary and backup DC assignments, and facility manager. SSOT for DC identity used across inbound logistics, inventory allocation, and restaurant replenishment. Sourced from SAP EWM and network design tools.' .

ind:InboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Inbound Shipment' ;
    rdfs:comment 'Transactional record tracking each inbound freight shipment from a supplier to a distribution center or restaurant. Captures shipment ID, carrier name, mode of transport (refrigerated truck, dry van, LTL, FTL), origin supplier location, destination DC or restaurant, scheduled and actual arrival date/time, bill of lading number, freight cost, cold chain temperature log flag, and shipment status (in-transit, arrived, delayed, exception). Supports inbound logistics visibility and carrier performance tracking.' .

ind:RecallEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Recall Event' ;
    rdfs:comment 'Operational record of a food product or ingredient recall event initiated by a supplier, regulatory agency (FDA/USDA), or internal quality team. Captures recall reference number, recall class (Class I, II, III), affected ingredient/SKU, affected lot numbers, recall reason (contamination, allergen mislabeling, foreign material), recall initiation date, affected DC and restaurant locations, quantity recalled, disposal method, and regulatory notification status. Enables rapid traceability response using ingredient_lot linkage.' .

ind:FinancialPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Financial Period' ;
    rdfs:comment 'Master reference table for financial_period. ' .

ind:PosTerminal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Pos Terminal' ;
    rdfs:comment 'Master reference table for pos_terminal. Referenced by: loyalty.offer_redemption.pos_terminal_id, loyalty.payment_method_link.pos_terminal_id, loyalty.redemption.pos_terminal_id, loyalty.visit.pos_terminal_id, order.drive_thru_event.pos_terminal_id' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
    rdfs:comment 'Master reference table for payment_run. Referenced by payment_run_id.' .

ind:DeliveryPlatform rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Platform' ;
    rdfs:comment 'Master reference table for delivery_platform. Referenced by delivery_platform_id.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master reference table for brand. Referenced by brand_id.' .

ind:Department rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Restaurant ;
    rdfs:label 'Department' ;
    rdfs:comment 'Master reference table for department. Referenced by department_id.' .

ind:ItemAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Item Assignment' ;
    rdfs:comment 'This association product represents the Assignment between menu and menu_item. It captures the formal menu engineering decision to include a specific menu item on a specific published menu, along with all context that governs how that item appears and behaves within that menu. Each record links one menu to one menu_item and carries attributes — sort order, display category, featured flag, effective dates, channel availability override, and price override — that exist only in the context of this specific menu-item pairing. This is the configuration record that POS systems consume to render a menu.. Existence Justification: In foodservice operations, menu engineers explicitly assign specific menu items to specific menus — a menu is a curated collection of items, and the same item (e.g., \'Classic Cheeseburger\') can appear on multiple menus (breakfast, lunch, drive-thru, OLO, franchise, LTO) while each menu contains many items. This assignment is actively managed: items are added, removed, reordered, featured, and price-overridden per menu context. The relationship is not derivable from transactional data — it is a master-data configuration decision made by menu engineers before any orders are placed.' .

ind:ComboMealComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Menu ;
    rdfs:label 'Combo Meal Component' ;
    rdfs:comment 'This association product represents the Component Role between combo_meal and menu_item. It captures the formal definition of which menu items constitute a given combo meal, in what quantity, in what sequence, and under what substitution rules. Each record links one combo_meal to one menu_item and carries attributes that exist only in the context of that specific pairing — such as whether the component is required, whether it can be substituted, its position in the bundle, and its caloric and cost contribution to the combo total. This is the operational source of truth for combo meal composition used by menu engineering, POS configuration, and digital ordering systems.. Existence Justification: In QSR and casual dining, a combo meal is explicitly defined as a bundle of specific menu items — a Value Meal #1 contains a burger, fries, and a drink, while a Family Pack contains different items. One combo meal contains multiple menu items (components), and one menu item (e.g., a medium fries) participates in multiple combo meals simultaneously. This is an actively managed, operational business concept: menu engineers define, update, and retire combo compositions as part of menu management workflows.' .

ind:PhysicalCountLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Physical Count Line' ;
    rdfs:comment 'This association product represents the line-level Event between physical_count and stock_item in restaurant inventory operations. It captures the per-SKU count result for each physical inventory count event, including the counted quantity, system (book) quantity, variance, lot and expiration data, and recount disposition. Each record links one physical_count event to one stock_item and carries the operational data required for COGS% analysis, MarketMan reconciliation, variance investigation workflows, and period-end food cost reporting. Without this entity, the model cannot represent per-SKU variance, recount flags, or lot-level count data.. Existence Justification: A physical inventory count in foodservice operations produces one count line per SKU per storage location — a physical_count event covers many stock_items, and each stock_item appears across many physical_count events over time. This line-level detail (counted_quantity, system_quantity, variance_quantity, variance_value, recount_required_flag) is the operational record that drives COGS% reporting, MarketMan reconciliation, and variance investigation workflows. The relationship is universally recognized in foodservice inventory management as a \'physical_count_line\' or \'count_detail\' — a first-class operational entity that humans create, review, and act upon.' .

ind:ApprovedVendorItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Approved Vendor Item' ;
    rdfs:comment 'This association product represents the sourcing contract between a supplier and an ingredient in the foodservice supply chain. It captures the Approved Vendor List (AVL) entry that procurement teams actively manage — recording which suppliers are approved to provide which ingredients, at what price, under what terms, and for what time period. Each record links one supply_supplier to one ingredient with attributes that exist only in the context of this supplier-ingredient sourcing relationship, enabling multi-sourcing strategy, price benchmarking, and supply continuity planning.. Existence Justification: In foodservice procurement, a supplier provides many ingredients (e.g., a broadline distributor like Sysco supplies beef, lettuce, cooking oil, and packaging), and a single ingredient (e.g., ground beef) is sourced from multiple approved suppliers at different prices, lead times, and minimum order quantities. This relationship is actively managed by procurement teams as an Approved Vendor List (AVL) or Supplier Item Catalog — a recognized operational business concept with its own lifecycle (approval, pricing updates, deactivation). The relationship carries substantial data (unit_price, lead_time_days, min_order_quantity, preferred_supplier_flag, effective_from, effective_until) that belongs to neither the supplier master nor the ingredient master alone.' .

# --- Attribute Properties ---
ind:menuItemId rdf:type rdf:Property ;
    rdfs:label 'Menu Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each menu item record in the lakehouse. Primary key for the menu_item master data product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuItem .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'Foreign key linking to restaurant.brand. Business justification: Menu items are brand-owned master data. Brand-level menu engineering, nutritional compliance reporting, and franchise menu approval all require direct brand association on menu_item. A foodservice dom' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Required for Campaign Planning: associate specific menu items with marketing campaigns (e.g., seasonal featured dishes) to enable menu rollout, budgeting, and performance reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Menu item creation workflow requires recording the employee (chef/manager) who created the item for audit and traceability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:franchiseeId rdf:type rdf:Property ;
    rdfs:label 'Franchisee Id' ;
    rdfs:comment 'Foreign key linking to franchise.franchisee. Business justification: Franchisee Menu Customization Report requires linking each menu item to the owning franchisee for localized availability and pricing decisions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Revenue reporting requires each menu item to map to a GL account for posting sales; finance teams use this for daily sales ledger reconciliation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:haccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.haccp_plan. Business justification: REGULATORY: HACCP compliance per menu item is required for safety reporting and audit traceability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:stockItemId rdf:type rdf:Property ;
    rdfs:label 'Stock Item Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_item. Business justification: Required for POS and inventory forecasting: each menu item must be linked to its underlying stock item (SKU) to reconcile sales with inventory levels and generate daily sales-vs-stock reports.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockItem .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier. Business justification: REQUIRED: Supplier sourcing for each menu item is needed for cost analysis, procurement planning, and supplier performance dashboards; experts expect a direct supplier_id on menu_item.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:allergenFlags rdf:type rdf:Property ;
    rdfs:label 'Allergen Flags' ;
    rdfs:comment 'Pipe-delimited list of the FDA\'s 9 major food allergens present in this menu item (milk, eggs, fish, shellfish, tree_nuts, peanuts, wheat, soybeans, sesame). Required for FDA allergen labeling compliance and guest safety disclosures on OLO and 3PD platforms. Example: \'wheat|milk|soy\'.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'The standard retail selling price of the menu item before any discounts, promotions, or channel-specific pricing adjustments. Expressed in the local operating currency. This is the principal quantitative value (MEASUREMENT_OR_VALUE) for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorieCount rdf:type rdf:Property ;
    rdfs:label 'Calorie Count' ;
    rdfs:comment 'Total caloric content of the menu item in kilocalories (kcal) per standard serving. Mandatory disclosure on menus for restaurant chains with 20+ locations under FDA Menu Labeling Rule (Section 4205 of the ACA).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Standard cost of goods sold (COGS) for this menu item, representing the total ingredient and packaging cost per serving. Used to calculate CoGS% and gross margin in P&L reporting. Sourced from SAP S/4HANA CO and MarketMan BOM costing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this menu item record was first created in the system of record (Oracle MICROS POS). Represents the business creation event, not the ETL load time. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the base_price and cost fields (e.g., USD, CAD, GBP). Supports multi-currency operations across international franchise markets.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'The daypart(s) during which this menu item is available for sale. Daypart segmentation drives kitchen prep scheduling, labor planning, and PMIX reporting by time-of-day. Standard foodservice dayparts: breakfast, lunch, dinner, late_night, snack, all_day.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinueDate rdf:type rdf:Property ;
    rdfs:label 'Discontinue Date' ;
    rdfs:comment 'The date this menu item was permanently discontinued and removed from the menu. Null for active items. Used for menu lifecycle management, historical PMIX analysis, and supply chain wind-down planning.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL of the approved product image for this menu item used on digital menus, OLO platform, 3PD marketplace listings, and marketing materials. Must reference the approved brand asset in the digital asset management system.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is3pdAvailable rdf:type rdf:Property ;
    rdfs:label 'Is 3pd Available' ;
    rdfs:comment 'Indicates whether this menu item is available through Third-Party Delivery (3PD) partners (e.g., DoorDash, Uber Eats, Grubhub). Controls item syndication to 3PD marketplace menus via Olo integration.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCustomizable rdf:type rdf:Property ;
    rdfs:label 'Is Customizable' ;
    rdfs:comment 'Indicates whether this menu item supports guest customization (e.g., add/remove ingredients, size selection, preparation modifications). Drives modifier group configuration in Oracle MICROS POS and OLO ordering flows.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDineInAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Dine In Available' ;
    rdfs:comment 'Indicates whether this menu item is available for dine-in service. Used to configure FOH (Front of House) menu boards and server-facing POS screens.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDtAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Dt Available' ;
    rdfs:comment 'Indicates whether this menu item is available for sale through the Drive-Thru (DT) channel. Used to configure channel-specific menus in Oracle MICROS POS and drive-thru menu boards.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlutenFree rdf:type rdf:Property ;
    rdfs:label 'Is Gluten Free' ;
    rdfs:comment 'Indicates whether this menu item is certified or designated as gluten-free per FDA gluten-free labeling standards (less than 20 ppm gluten). Used for allergen filtering on digital ordering platforms and guest safety disclosures.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLto rdf:type rdf:Property ;
    rdfs:label 'Is Lto' ;
    rdfs:comment 'Indicates whether this menu item is a Limited Time Offer (LTO). LTO items have defined availability windows and are used for promotional campaigns, seasonal offerings, and new product testing. Drives marketing campaign execution and supply chain planning.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOloAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Olo Available' ;
    rdfs:comment 'Indicates whether this menu item is available through the Online Ordering (OLO) digital channel. Controls item visibility on the Olo Digital Ordering Platform for web and mobile ordering.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this menu item is subject to sales tax. Tax applicability varies by jurisdiction and item type (e.g., prepared food vs. grocery). Drives tax calculation in Oracle MICROS POS and SAP S/4HANA AR.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegan rdf:type rdf:Property ;
    rdfs:label 'Is Vegan' ;
    rdfs:comment 'Indicates whether this menu item meets vegan dietary criteria (no animal products including dairy and eggs). Used for dietary filter functionality on OLO, 3PD platforms, and in-restaurant menu boards.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVegetarian rdf:type rdf:Property ;
    rdfs:label 'Is Vegetarian' ;
    rdfs:comment 'Indicates whether this menu item meets vegetarian dietary criteria (no meat, poultry, or seafood). Used for dietary filter functionality on OLO, 3PD platforms, and in-restaurant menu boards.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the menu item used across POS, KDS, ERP, and supply chain systems. Equivalent to the PLU (Price Look-Up) code in Oracle MICROS POS.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Long-form marketing and operational description of the menu item including key ingredients, preparation style, and flavor profile. Used on digital menus, OLO platform, 3PD integrations, and guest-facing materials.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'The customer-facing display name of the menu item as it appears on the menu board, POS screen, and digital ordering channels (DT, OLO, 3PD).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the menu item. \'active\' = currently sold; \'inactive\' = temporarily removed; \'lto\' = Limited Time Offer (LTO) with defined availability window; \'discontinued\' = permanently removed; \'pending_launch\' = approved but not yet live; \'suspended\' = pulled due to safety or supply issue.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date this menu item was first made available for sale across the restaurant network. Used for item lifecycle tracking, PMIX trend analysis, and new product performance reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltoEndDate rdf:type rdf:Property ;
    rdfs:label 'Lto End Date' ;
    rdfs:comment 'The date on which a Limited Time Offer (LTO) menu item is removed from sale. Null for non-LTO items. Triggers automatic item deactivation in POS and removal from OLO and 3PD channel menus.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltoStartDate rdf:type rdf:Property ;
    rdfs:label 'Lto Start Date' ;
    rdfs:comment 'The date on which a Limited Time Offer (LTO) menu item becomes available for sale. Null for non-LTO items. Used to coordinate marketing campaign launches, supply chain procurement, and POS menu activation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:menuEngineeringClass rdf:type rdf:Property ;
    rdfs:label 'Menu Engineering Class' ;
    rdfs:comment 'Menu engineering quadrant classification based on the item\'s profitability and popularity: \'star\' (high profit, high popularity), \'plow_horse\' (low profit, high popularity), \'puzzle\' (high profit, low popularity), \'dog\' (low profit, low popularity). Used by menu development teams to make pricing and promotion decisions.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portionSizeGrams rdf:type rdf:Property ;
    rdfs:label 'Portion Size Grams' ;
    rdfs:comment 'Standard portion weight of the menu item in grams as defined in the recipe and BOM (Bill of Materials). Used for food cost control, yield management, waste tracking, and FDA nutrition label compliance.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Prep Time Seconds' ;
    rdfs:comment 'Standard preparation time for this menu item measured in seconds, from order receipt on the KDS (Kitchen Display System) to item ready. Used for Speed of Service (SOS) benchmarking, Ticket Time targets, and kitchen throughput planning.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restaurantFormat rdf:type rdf:Property ;
    rdfs:label 'Restaurant Format' ;
    rdfs:comment 'Identifies which restaurant format(s) this menu item is eligible for: QSR (Quick-Service Restaurant), casual dining, fine dining, or all formats. Governs menu item availability across the restaurant portfolio.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingTemperature rdf:type rdf:Property ;
    rdfs:label 'Serving Temperature' ;
    rdfs:comment 'Required serving temperature classification for this menu item: hot, cold, ambient, or frozen. Critical for HACCP (Hazard Analysis Critical Control Points) compliance, food safety SOPs, and Zenput audit checklists.' ;
    rdfs:domain ind:MenuItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code that links the sellable menu item to its corresponding inventory and procurement record in MarketMan and SAP S/4HANA MM. Enables COGS tracking and PAR level management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sodiumMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Mg' ;
    rdfs:comment 'Sodium content of the menu item in milligrams (mg) per standard serving. Required for FDA nutrition disclosure and supports guest health-conscious ordering decisions on digital platforms.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort order controlling the display sequence of this item within its category on POS screens, digital menu boards, OLO, and 3PD platforms. Lower values appear first. Used by menu engineering teams to influence guest ordering behavior.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The native item identifier from the operational source system (Oracle MICROS POS) from which this record was ingested into the lakehouse Silver layer. Enables lineage tracing and reconciliation between the lakehouse and the POS system of record.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification within the item category for granular PMIX analysis and menu engineering (e.g., Burger, Chicken Sandwich, Fountain Drink, Milkshake, French Fries). Supports drill-down reporting in P&L and product mix analytics.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax category code assigned to this menu item in SAP S/4HANA for jurisdiction-specific tax rate determination. Maps to the tax condition type in SD pricing. Examples: FOOD_PREP, BEVERAGE_ALCO, BEVERAGE_NON_ALCO.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this menu item record in the system of record. Used to detect changes for incremental lakehouse ingestion and to track menu item modification history. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:menuId rdf:type rdf:Property ;
    rdfs:label 'Menu Id' ;
    rdfs:comment 'Unique surrogate identifier for each published menu record in the lakehouse. Serves as the primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Menu .

ind:financialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Id' ;
    rdfs:comment 'Foreign key linking to finance.financial_period. Business justification: Menu version approval and activation is tied to fiscal periods for menu engineering reviews and budget cycle planning. Foodservice finance and operations teams track which menu version was active in e' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to loyalty.program. Business justification: Loyalty program menu configuration: QSR loyalty apps serve program-specific digital menus with member pricing and exclusive items. The menu record must reference which loyalty program it serves to dri' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to realestate.site. Business justification: Required for site-specific menu publishing, compliance, and pricing; each restaurant location (site) maintains its own active menu.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to franchise.territory. Business justification: Regional Menu Planning uses territory assignment to determine which menu set applies to each geographic area.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:unitId rdf:type rdf:Property ;
    rdfs:label 'Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: Required for POS and reporting to assign each menu to the specific restaurant unit where it is served.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:allergenDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Allergen Disclosure Required' ;
    rdfs:comment 'Indicates whether this menu requires allergen declarations for the nine FDA-recognized major food allergens (milk, eggs, fish, shellfish, tree nuts, peanuts, wheat, soybeans, sesame). Supports HACCP compliance and guest safety.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current workflow state of the menu in the approval lifecycle. Menus must be approved before publishing. Tracks progression from draft through review, approval, and eventual archival.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the individual who granted final approval for this menu version. Required for audit trail and regulatory compliance with FDA food labeling and franchise disclosure obligations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the menu received final approval, recorded in ISO 8601 format with timezone offset. Establishes the official approval event in the menu lifecycle audit trail.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:categoryCount rdf:type rdf:Property ;
    rdfs:label 'Category Count' ;
    rdfs:comment 'Total number of menu categories (e.g., Burgers, Sides, Beverages, Desserts) included in this menu version. Supports menu structure analysis and POS display configuration.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The ordering or service channel this menu is published for. Drive-Thru (DT), Online Ordering (OLO), Third-Party Delivery (3PD), dine-in, kiosk, and catering channels may carry different item availability, pricing, and promotional content. [ENUM-REF-CANDIDATE: dine_in|drive_thru|olo|third_party_delivery|kiosk|catering|curbside|mobile_app — promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the country where this menu is published. Drives regulatory compliance (FDA, USDA, local health departments), currency, and language localization.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartEndTime rdf:type rdf:Property ;
    rdfs:label 'Daypart End Time' ;
    rdfs:comment 'The local wall-clock time (HH:MM, 24-hour) at which this menu\'s daypart ends service. Used by POS and KDS to automatically deactivate the menu and transition to the next daypart.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daypartStartTime rdf:type rdf:Property ;
    rdfs:label 'Daypart Start Time' ;
    rdfs:comment 'The local wall-clock time (HH:MM, 24-hour) at which this menu\'s daypart begins service. Used by POS and KDS (Kitchen Display System) to automatically switch active menus.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:digitalMenuBoardEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Menu Board Enabled' ;
    rdfs:comment 'Indicates whether this menu is configured for display on digital menu boards in restaurant locations. Digital menu boards require specific image assets, layout templates, and real-time price synchronization.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The calendar date on which this menu version is retired and no longer available for ordering. Null indicates an open-ended menu with no planned expiry. Critical for LTO (Limited Time Offer) lifecycle management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The calendar date on which this menu version becomes active and available for ordering. Governs menu rollout scheduling for New Restaurant Openings (NRO), Limited Time Offers (LTO), and seasonal rotations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineeringTier rdf:type rdf:Property ;
    rdfs:label 'Engineering Tier' ;
    rdfs:comment 'Menu engineering classification based on the Boston Consulting Group (BCG) matrix adapted for foodservice: Stars (high popularity, high margin), Plow Horses (high popularity, low margin), Puzzles (low popularity, high margin), Dogs (low popularity, low margin). Drives strategic menu optimization decisions.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpReviewed rdf:type rdf:Property ;
    rdfs:label 'Haccp Reviewed' ;
    rdfs:comment 'Indicates whether this menu version has undergone a HACCP (Hazard Analysis Critical Control Points) review to ensure all items meet food safety critical control point requirements before publication.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this menu is the default active menu for its restaurant format, channel, and daypart combination. Only one menu per format-channel-daypart combination should be flagged as default at any point in time.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFranchiseMenu rdf:type rdf:Property ;
    rdfs:label 'Is Franchise Menu' ;
    rdfs:comment 'Indicates whether this menu is designated for franchise-operated restaurants as opposed to company-owned locations. Franchise menus may have restricted customization rights governed by the Franchise Disclosure Document (FDD).' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of distinct menu items included in this menu version. Used in menu engineering analysis to assess menu complexity, PMIX (Product Mix) breadth, and operational throughput impact.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kdsRoutingProfile rdf:type rdf:Property ;
    rdfs:label 'Kds Routing Profile' ;
    rdfs:comment 'Identifier for the KDS (Kitchen Display System) routing profile associated with this menu. Determines how orders are routed to BOH (Back of House) preparation stations based on item categories and prep sequences.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'IETF BCP 47 language code for the menu\'s display language (e.g., \'en-US\', \'fr-CA\', \'es-MX\'). Supports multilingual menu publishing for diverse guest populations and regulatory bilingual requirements.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when this menu record was most recently updated, recorded in ISO 8601 format with timezone offset. Used for change detection, incremental ETL processing, and audit compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'The geographic market or region this menu is scoped to (e.g., \'US-Southeast\', \'Canada\', \'EMEA-UK\'). Supports regional menu variation, localization, and regulatory compliance across jurisdictions.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuCode rdf:type rdf:Property ;
    rdfs:label 'Menu Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the menu, used in Oracle MICROS POS configurations, franchise communications, and cross-system references (e.g., BRKFST-QSR-DT-2024).' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuDescription rdf:type rdf:Property ;
    rdfs:label 'Menu Description' ;
    rdfs:comment 'Free-text narrative description of the menu\'s purpose, scope, and key characteristics. Used in internal documentation, franchise communications, and menu engineering review sessions.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuName rdf:type rdf:Property ;
    rdfs:label 'Menu Name' ;
    rdfs:comment 'Human-readable display name of the menu as it appears in POS systems, digital ordering platforms, and internal reporting (e.g., \'Breakfast Drive-Thru Menu Q1 2024\').' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for operational notes, change justifications, or franchise-specific instructions associated with this menu version. Used by menu managers and franchise business consultants during review cycles.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Nutritional Disclosure Required' ;
    rdfs:comment 'Indicates whether this menu requires calorie and nutritional information disclosure per FDA menu labeling regulations (21 CFR Part 101.11). Mandatory for restaurant chains with 20 or more locations in the United States.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloMenuCode rdf:type rdf:Property ;
    rdfs:label 'Olo Menu Code' ;
    rdfs:comment 'The native menu identifier as configured in the Olo Digital Ordering Platform. Enables reconciliation of digital channel menu versions with the master menu record.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmixTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Pmix Tracking Enabled' ;
    rdfs:comment 'Indicates whether Product Mix (PMIX) sales tracking is enabled for this menu version. When enabled, POS transaction data is aggregated to measure item-level sales velocity, supporting menu engineering and COGS% analysis.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posMenuCode rdf:type rdf:Property ;
    rdfs:label 'Pos Menu Code' ;
    rdfs:comment 'The native menu identifier as configured in Oracle MICROS POS. Used for system-of-record reconciliation between the lakehouse silver layer and the POS operational system.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'Pricing tier classification for this menu, reflecting the overall price positioning strategy (value, standard, premium, luxury). Drives ACV (Average Check Value) benchmarking and revenue management decisions.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishStatus rdf:type rdf:Property ;
    rdfs:label 'Publish Status' ;
    rdfs:comment 'Current publishing state of the menu indicating whether it is live and visible to guests across channels. Distinct from approval_status — a menu may be approved but not yet published, or suspended post-publication.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the menu was pushed live to POS systems, digital ordering platforms (OLO), and third-party delivery (3PD) integrations. Critical for SSS (Same-Store Sales) period alignment and rollout governance.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retiredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Retired Timestamp' ;
    rdfs:comment 'Date and time when the menu was deactivated and retired from all channels. Null if the menu is still active. Used for historical PMIX analysis and LTO post-campaign reporting.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this menu record originated (e.g., Oracle MICROS POS, Olo Digital Ordering Platform, FranConnect). Supports data lineage and reconciliation in the lakehouse silver layer.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential integer version of the menu, incremented each time the menu is revised and republished. Enables rollback, audit, and comparison of menu changes over time.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeId rdf:type rdf:Property ;
    rdfs:label 'Recipe Id' ;
    rdfs:comment 'Unique surrogate identifier for each standardized recipe record in the foodservice master recipe repository. Serves as the primary key for all downstream joins to menu items, Bill of Materials (BOM) components, and production specifications.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recipe .

ind:criticalControlPointId rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.critical_control_point. Business justification: HACCP documentation requires each recipe to reference the specific CCP governing its critical process step (e.g., cook temperature CCP for a burger). Recipe already has haccp_ccp_flag and haccp_plan_i' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CriticalControlPoint .

ind:primarySupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier. Business justification: Supplier recall and food safety traceability: when a supplier is recalled or audited, procurement and food safety teams must identify all affected recipes. Recipe-level supplier traceability is a stan' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this recipe version was formally approved for production use by the culinary or food safety authority. Supports recipe version lifecycle management, audit trail, and regulatory compliance documentation.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bohPrepNotes rdf:type rdf:Property ;
    rdfs:label 'Boh Prep Notes' ;
    rdfs:comment 'Supplementary Back of House (BOH) preparation notes and special handling instructions for kitchen staff, including equipment-specific guidance, batch preparation tips, and quality checkpoints not captured in the structured prep_method field. Sourced from culinary SOP documentation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calories rdf:type rdf:Property ;
    rdfs:label 'Calories' ;
    rdfs:comment 'Total caloric content per serving in kilocalories (kcal) as required for FDA menu labeling compliance under the Affordable Care Act Section 4205. Displayed on menu boards and digital ordering platforms per FDA 21 CFR Part 101.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caloriesFromFat rdf:type rdf:Property ;
    rdfs:label 'Calories From Fat' ;
    rdfs:comment 'Calories derived from fat content per serving in kilocalories (kcal), as declared on the FDA Nutrition Facts Panel. Supports nutritional transparency and menu labeling compliance.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookMethod rdf:type rdf:Property ;
    rdfs:label 'Cook Method' ;
    rdfs:comment 'The primary cooking technique applied to this recipe (e.g., fry, grill, bake, steam, broil, saute, raw, microwave, sous_vide, smoke). Drives Kitchen Display System (KDS) routing, equipment assignment, and HACCP critical control point identification. [ENUM-REF-CANDIDATE: fry|grill|bake|steam|broil|saute|raw|microwave|sous_vide|smoke — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cookTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Cook Temperature F' ;
    rdfs:comment 'Required internal or cooking equipment temperature in degrees Fahrenheit for this recipe. Critical for HACCP compliance, food safety critical control point (CCP) monitoring, and Zenput food safety audit verification. Ensures pathogen elimination per FDA Food Code minimum temperature requirements.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cookTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Cook Time Seconds' ;
    rdfs:comment 'Standardized cook time in seconds for this recipe as defined in the culinary SOP. Used for Kitchen Display System (KDS) timer configuration, Speed of Service (SOS) benchmarking, Ticket Time analysis, and throughput optimization in BOH operations.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this recipe version becomes active and available for production in restaurant operations. Used for recipe version scheduling, Limited Time Offer (LTO) launch planning, and menu change management across Oracle MICROS POS and Olo.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which this recipe version is retired from active production use. Applicable for Limited Time Offers (LTO), seasonal items, and superseded recipe versions. Null for open-ended core menu recipes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foodCost rdf:type rdf:Property ;
    rdfs:label 'Food Cost' ;
    rdfs:comment 'Calculated raw ingredient cost in USD to produce one yield unit of this recipe, derived from Bill of Materials (BOM) component costs in MarketMan Inventory Management. Used for Cost of Goods Sold (COGS) analysis, CoGS% reporting, menu pricing strategy, and P&L management in SAP S/4HANA.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodCostPct rdf:type rdf:Property ;
    rdfs:label 'Food Cost Pct' ;
    rdfs:comment 'Recipe food cost expressed as a percentage of the menu selling price, representing the Cost of Goods Sold Percentage (CoGS%). A key menu engineering metric used to evaluate recipe profitability, set pricing targets, and manage P&L performance. Calculated as food_cost divided by menu selling price.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCcpFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Flag' ;
    rdfs:comment 'Indicates whether this recipe contains one or more Hazard Analysis Critical Control Points (HACCP CCPs) requiring mandatory monitoring, verification, and corrective action procedures per ISO 22000 and FDA Food Safety Modernization Act (FSMA). Drives Zenput food safety audit task generation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdingTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Holding Temperature F' ;
    rdfs:comment 'Required hot or cold holding temperature in degrees Fahrenheit for maintaining food safety after cooking and prior to service. Critical HACCP critical control point (CCP) parameter monitored via Zenput food safety audits and local health department inspections.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingTimeMaxMinutes rdf:type rdf:Property ;
    rdfs:label 'Holding Time Max Minutes' ;
    rdfs:comment 'Maximum allowable holding time in minutes after cooking before the item must be discarded, per HACCP and food safety SOP. Drives waste tracking in MarketMan and Zenput task management for BOH discard compliance and Waste% reporting.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:menuPrice rdf:type rdf:Property ;
    rdfs:label 'Menu Price' ;
    rdfs:comment 'Standard menu selling price in USD for this recipe as configured in Oracle MICROS POS. Used for revenue management, menu engineering analysis, Average Check Value (ACV) calculations, and Same-Store Sales (SSS) reporting.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platingInstructions rdf:type rdf:Property ;
    rdfs:label 'Plating Instructions' ;
    rdfs:comment 'Standardized plating and presentation instructions for this recipe as defined in the culinary SOP. Specifies garnish placement, portioning, vessel type, and visual presentation standards for Front of House (FOH) service quality and brand consistency.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepMethod rdf:type rdf:Property ;
    rdfs:label 'Prep Method' ;
    rdfs:comment 'Standardized description of the preparation technique for this recipe as defined in the culinary Standard Operating Procedure (SOP). Includes steps such as marinating, chopping, mixing, or assembling performed prior to cooking. Governs BOH preparation workflow and kitchen training.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeCategory rdf:type rdf:Property ;
    rdfs:label 'Recipe Category' ;
    rdfs:comment 'Culinary category grouping for the recipe used in menu engineering and Product Mix (PMIX) reporting (e.g., Entrée, Appetizer, Dessert, Beverage, Side, Sauce, Condiment). Supports daypart analysis and menu mix optimization. [ENUM-REF-CANDIDATE: entree|appetizer|dessert|beverage|side|sauce|condiment|breakfast|snack — promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeCode rdf:type rdf:Property ;
    rdfs:label 'Recipe Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the recipe, used across Oracle MICROS POS, MarketMan Inventory Management, and SAP S/4HANA for cross-system reference. Follows the format RCP-XXXX. Serves as the operational lookup key in kitchen and procurement workflows.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeName rdf:type rdf:Property ;
    rdfs:label 'Recipe Name' ;
    rdfs:comment 'Human-readable name of the standardized recipe as it appears in culinary Standard Operating Procedures (SOP) documentation and kitchen training materials. Used by Back of House (BOH) staff and culinary teams for identification and communication.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeStatus rdf:type rdf:Property ;
    rdfs:label 'Recipe Status' ;
    rdfs:comment 'Current lifecycle state of the recipe within the culinary development and operations workflow. \'draft\' indicates in-development; \'active\' indicates approved for production use; \'inactive\' indicates temporarily suspended; \'archived\' indicates retired; \'under_review\' indicates pending culinary or food safety re-evaluation.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeType rdf:type rdf:Property ;
    rdfs:label 'Recipe Type' ;
    rdfs:comment 'Classification of the recipe by its menu permanence and scope. \'core\' indicates a permanent menu item; \'limited_time_offer\' (LTO) indicates a time-bound promotional item; \'seasonal\' indicates availability tied to seasonal ingredients; \'test\' indicates a recipe under culinary trial; \'regional\' indicates a market-specific variant.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servingSizeG rdf:type rdf:Property ;
    rdfs:label 'Serving Size G' ;
    rdfs:comment 'Standardized serving size in grams as declared for nutritional labeling purposes. Required for FDA Nutrition Facts Panel compliance and menu labeling regulations. Used in nutritional data calculations and USDA reporting.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeHours rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Hours' ;
    rdfs:comment 'Maximum shelf life in hours for the prepared recipe item from time of production, as defined in the food safety SOP. Governs discard scheduling, holding time compliance, and waste tracking in MarketMan. Critical for HACCP date-marking compliance per FDA Food Code.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature F' ;
    rdfs:comment 'Required storage temperature in degrees Fahrenheit for raw ingredients or prepared components of this recipe prior to production. HACCP critical control point (CCP) parameter for cold chain compliance, monitored via Zenput food safety audits.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from start of preparation to completion of plating, combining prep_time_seconds and cook_time_seconds plus any resting or holding time. Used for Speed of Service (SOS) targets, throughput modeling, and KDS configuration.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the recipe in major.minor format (e.g., 1.0, 2.3), tracking iterative culinary changes, reformulations, or ingredient substitutions over the recipe lifecycle. Enables version-controlled recipe management and rollback capability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastePct rdf:type rdf:Property ;
    rdfs:label 'Waste Pct' ;
    rdfs:comment 'Expected food waste percentage for this recipe during production, representing trim loss, cooking loss, and preparation waste as a proportion of raw ingredient weight. Used for Yield Management, PAR Level planning, and Waste% reporting in MarketMan Inventory Management.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldQuantity rdf:type rdf:Property ;
    rdfs:label 'Yield Quantity' ;
    rdfs:comment 'The standardized output quantity produced by one execution of this recipe (e.g., 1.0 for a single portion, 12.0 for a batch of 12 units). Used in Bill of Materials (BOM) scaling, food cost calculations, and PAR Level (Periodic Automatic Replenishment Level) planning in MarketMan.' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldUnit rdf:type rdf:Property ;
    rdfs:label 'Yield Unit' ;
    rdfs:comment 'Unit of measure for the recipe yield quantity (e.g., portion, oz, g, kg, lb, ml, L, each, batch, serving). Aligns with MarketMan Inventory Management unit-of-measure standards for accurate food cost and waste tracking. [ENUM-REF-CANDIDATE: portion|oz|g|kg|lb|ml|L|each|batch|serving — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recipe ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipeIngredientId rdf:type rdf:Property ;
    rdfs:label 'Recipe Ingredient Id' ;
    rdfs:comment 'Unique surrogate identifier for each Bill of Materials (BOM) line-item record linking an ingredient to a recipe. Primary key for the recipe_ingredient entity.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: HACCP critical control point ingredients require approval by a certified food safety employee. Tracing ingredient approvals to a specific employee is mandatory for HACCP audit documentation and allerg' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ingredientId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Id' ;
    rdfs:comment 'Reference to the master ingredient or Stock Keeping Unit (SKU) record that identifies the specific raw material, semi-finished, or finished component used in this recipe line.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ingredient .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier. Business justification: Approved supplier list management: procurement and HACCP compliance require tracking which supplier is approved for each ingredient-in-recipe. supplier_item_code is a denormalized supplier reference a' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryRecipeSubstituteIngredientId rdf:type rdf:Property ;
    rdfs:label 'Primary Recipe Substitute Ingredient Id' ;
    rdfs:comment 'Reference to the approved substitute ingredient SKU that may replace this ingredient when is_substitution_allowed is True. Supports supply chain contingency planning and procurement flexibility.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ingredient .

ind:bomVersion rdf:type rdf:Property ;
    rdfs:label 'Bom Version' ;
    rdfs:comment 'Version identifier for the recipe Bill of Materials (BOM) line, following semantic versioning convention (e.g., v1.0, v2.3). Enables change control tracking, regulatory audit trails, and rollback capability for recipe modifications.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsDairy rdf:type rdf:Property ;
    rdfs:label 'Contains Dairy' ;
    rdfs:comment 'Indicates whether this ingredient contains milk or dairy derivatives as a major allergen per FDA FALCPA. True = dairy present; False = dairy-free. Supports allergen management and guest dietary accommodation.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containsGluten rdf:type rdf:Property ;
    rdfs:label 'Contains Gluten' ;
    rdfs:comment 'Indicates whether this ingredient contains or may contain gluten as a major allergen per FDA FALCPA requirements. True = gluten present or cross-contact risk; False = gluten-free. Used for menu allergen labeling and guest dietary accommodation.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Procurement cost of the ingredient per one unit of measure at the time of recipe costing. Used as the primary input for Cost of Goods Sold (COGS) and Cost of Goods Sold Percentage (CoGS%) calculations at the recipe level. Sourced from Coupa Procurement or SAP AP.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedCost rdf:type rdf:Property ;
    rdfs:label 'Extended Cost' ;
    rdfs:comment 'Total cost contribution of this ingredient line to the recipe, calculated as quantity × cost_per_unit adjusted for yield. Represents the line-level Cost of Goods Sold (COGS) input for recipe costing and menu engineering decisions.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpCriticalControlPoint rdf:type rdf:Property ;
    rdfs:label 'Haccp Critical Control Point' ;
    rdfs:comment 'Indicates whether this ingredient represents a Hazard Analysis Critical Control Point (HACCP) in the recipe preparation process requiring mandatory temperature, time, or handling controls. True = CCP applies; False = standard handling. Drives food safety audit requirements in Zenput.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ingredientStatus rdf:type rdf:Property ;
    rdfs:label 'Ingredient Status' ;
    rdfs:comment 'Current lifecycle status of this ingredient within the recipe Bill of Materials (BOM). Controls whether the ingredient is actively used in production, pending approval, seasonal, or discontinued. Drives menu engineering and procurement decisions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalIngredient rdf:type rdf:Property ;
    rdfs:label 'Is Critical Ingredient' ;
    rdfs:comment 'Indicates whether this ingredient is designated as a critical or signature component of the recipe whose absence or substitution would materially alter the menu item\'s identity, quality standard, or brand promise. True = critical; False = non-critical. Drives supply chain risk prioritization.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalalCertified rdf:type rdf:Property ;
    rdfs:label 'Is Halal Certified' ;
    rdfs:comment 'Indicates whether this ingredient holds a valid Halal certification from an accredited certifying body. True = Halal certified; False = not certified. Required for menu compliance in markets with Halal dietary requirements.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosherCertified rdf:type rdf:Property ;
    rdfs:label 'Is Kosher Certified' ;
    rdfs:comment 'Indicates whether this ingredient holds a valid Kosher certification. True = Kosher certified; False = not certified. Required for menu compliance in markets with Kosher dietary requirements.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOrganic rdf:type rdf:Property ;
    rdfs:label 'Is Organic' ;
    rdfs:comment 'Indicates whether this ingredient is certified organic under USDA National Organic Program (NOP) standards. True = USDA Organic certified; False = conventional. Supports menu labeling claims and premium ingredient sourcing tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubstitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Substitution Allowed' ;
    rdfs:comment 'Indicates whether this ingredient may be substituted with an approved alternative ingredient without altering the recipe\'s quality, taste profile, or regulatory compliance. True = substitution permitted; False = ingredient is mandatory and cannot be substituted.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Ordinal position of this ingredient within the recipe Bill of Materials (BOM). Governs the assembly and preparation sequence displayed on Kitchen Display System (KDS) and Standard Operating Procedure (SOP) documentation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minInternalTempF rdf:type rdf:Property ;
    rdfs:label 'Min Internal Temp F' ;
    rdfs:comment 'Minimum required internal cooking temperature in degrees Fahrenheit for this ingredient as mandated by FDA Food Code and HACCP plan. Applicable when haccp_critical_control_point is True. Enforced via Zenput food safety task management.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parLevelQuantity rdf:type rdf:Property ;
    rdfs:label 'Par Level Quantity' ;
    rdfs:comment 'Periodic Automatic Replenishment (PAR) level quantity for this ingredient at the restaurant level, expressed in the ingredient\'s unit of measure. Drives automated reorder triggers in MarketMan and procurement planning in Coupa.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prepState rdf:type rdf:Property ;
    rdfs:label 'Prep State' ;
    rdfs:comment 'Preparation state of the ingredient at the point of use in the recipe (e.g., raw, cooked, prepped, frozen, thawed). Drives kitchen workflow sequencing, food safety HACCP critical control point documentation, and yield calculations. [ENUM-REF-CANDIDATE: raw|cooked|prepped|frozen|thawed|marinated|portioned — promote to reference product]' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Specified quantity of the ingredient required per one unit of the parent recipe, expressed in the designated unit of measure. Used as the basis for COGS calculations, procurement planning, and PAR level management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days this ingredient remains safe and usable from the date of receipt or preparation, under specified storage conditions. Used for PAR level management, waste reduction, and FIFO inventory rotation in MarketMan.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageTemperatureMaxF rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max F' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Fahrenheit for this ingredient. Exceeding this threshold triggers a food safety violation per HACCP plan and FDA Food Code requirements.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinF rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min F' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Fahrenheit for this ingredient to maintain food safety and quality standards. Used in HACCP temperature monitoring and cold chain compliance tracking.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure in which the ingredient quantity is expressed (e.g., oz, g, ml, each). Must align with the unit of measure used in procurement and inventory systems to enable accurate COGS and PAR level calculations. [ENUM-REF-CANDIDATE: oz|lb|g|kg|ml|L|fl_oz|cup|tsp|tbsp|each|slice|portion|pkg — promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteFactorPct rdf:type rdf:Property ;
    rdfs:label 'Waste Factor Pct' ;
    rdfs:comment 'Percentage of the ingredient quantity expected to be lost during preparation, trimming, cooking, or handling (e.g., 5.00 = 5%). Applied in COGS calculations and procurement planning to account for Food Waste Percentage (Waste%). Sourced from MarketMan waste tracking.' ;
    rdfs:domain ind:RecipeIngredient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPct rdf:type rdf:Property ;
    rdfs:label 'Yield Pct' ;
    rdfs:comment 'Percentage of the as-purchased ingredient quantity that results in usable product after preparation (e.g., 80.00 = 80% yield). Complements waste_factor_pct and is used in Yield Management calculations to determine actual cost per usable unit.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemPriceId rdf:type rdf:Property ;
    rdfs:label 'Item Price Id' ;
    rdfs:comment 'Unique surrogate identifier for each item price record in the menu pricing table. Primary key for the item_price data product.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryItemApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee or user who approved this price record. Supports pricing governance and audit trail requirements.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to marketing.promotion. Business justification: Promotional pricing process: a promotion directly authorizes a promotional_price on an item_price record. Pricing analysts and marketing teams must trace which promotion governs each price change for ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:channelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Channel Surcharge' ;
    rdfs:comment 'Additional amount added to the base price for specific ordering channels such as Third-Party Delivery (3PD) or Online Ordering (OLO) to offset platform fees or delivery costs. Zero when no surcharge applies.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPct rdf:type rdf:Property ;
    rdfs:label 'Cogs Pct' ;
    rdfs:comment 'The ratio of Cost of Goods Sold (COGS) to the base selling price, expressed as a decimal (e.g., 0.28 = 28%). A key menu engineering metric used to assess item profitability and pricing adequacy.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfGoods rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods' ;
    rdfs:comment 'The direct food and packaging cost associated with producing this menu item at the time of pricing. Used to calculate Cost of Goods Sold Percentage (CoGS%) and support menu engineering decisions.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchisePriceDeviationPct rdf:type rdf:Property ;
    rdfs:label 'Franchise Price Deviation Pct' ;
    rdfs:comment 'The percentage deviation of the franchisee\'s actual price from the franchisor\'s Suggested Retail Price (SRP). Positive values indicate pricing above SRP; negative values indicate pricing below SRP. Used in franchise compliance monitoring.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this price record is currently active and eligible to be applied at the Point of Sale (POS). False for expired, superseded, or deactivated price records. Distinct from approval_status — a record may be approved but not yet active.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriceOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Price Override Allowed' ;
    rdfs:comment 'Indicates whether a cashier or manager is permitted to manually override this price at the Point of Sale (POS). Controls POS-level price override permissions for this item.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltoCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Lto Campaign Code' ;
    rdfs:comment 'Alphanumeric identifier linking this price record to a specific Limited Time Offer (LTO) marketing campaign. Populated only when is_lto is True. Enables PMIX and revenue analysis by LTO campaign.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Order Quantity' ;
    rdfs:comment 'The maximum number of units that can be ordered at this price point per transaction. Used to enforce promotional price limits and prevent abuse of discounted pricing.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:menuEngineeringCategory rdf:type rdf:Property ;
    rdfs:label 'Menu Engineering Category' ;
    rdfs:comment 'Menu engineering classification of the item based on its profitability and popularity (Product Mix / PMIX). Stars are high-profit/high-popularity; Plow Horses are low-profit/high-popularity; Puzzles are high-profit/low-popularity; Dogs are low-profit/low-popularity.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'The minimum number of units that must be ordered for this price to apply. Used for bulk pricing, catering orders, or combo deal minimum quantity thresholds.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingChannel rdf:type rdf:Property ;
    rdfs:label 'Ordering Channel' ;
    rdfs:comment 'The sales channel for which this price record applies. Supports channel-specific pricing strategies across Dine-In, Drive-Thru (DT), Online Ordering (OLO), Third-Party Delivery (3PD), Kiosk, and Catering.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the restaurant location is company-owned or franchised. Franchise pricing may be subject to different governance rules and royalty implications.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posPriceLevel rdf:type rdf:Property ;
    rdfs:label 'Pos Price Level' ;
    rdfs:comment 'The POS system price level code assigned to this price record in Oracle MICROS POS (e.g., PRICE_LEVEL_1, HAPPY_HOUR). Maps the price record to the POS configuration layer for terminal-level price application.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business justification or reason code explaining why this price was set or changed. Common reasons include commodity cost increase, competitive repositioning, LTO activation, regional adjustment, or franchise directive. [ENUM-REF-CANDIDATE: commodity_cost|competitive_repositioning|lto_activation|regional_adjustment|franchise_directive|menu_engineering|regulatory_compliance|other — promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason Notes' ;
    rdfs:comment 'Free-text narrative providing additional context or detail for the price change reason. Supplements the structured reason code with qualitative business commentary.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDisplayLabel rdf:type rdf:Property ;
    rdfs:label 'Price Display Label' ;
    rdfs:comment 'The formatted price string as it should appear on the menu board, digital display, or OLO/3PD platform (e.g., \'$5.99\', \'From $4.99\'). Supports localized and channel-specific price presentation.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceElasticityBand rdf:type rdf:Property ;
    rdfs:label 'Price Elasticity Band' ;
    rdfs:comment 'Classification of the menu item\'s demand sensitivity to price changes. Used in menu engineering and revenue management to guide pricing decisions and promotional strategy.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceOverrideLimit rdf:type rdf:Property ;
    rdfs:label 'Price Override Limit' ;
    rdfs:comment 'The maximum price value to which a POS operator may override this item\'s price when is_price_override_allowed is True. Null when price override is not permitted.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Price Record Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this price record, used in POS configuration exports, pricing change communications, and audit references. Follows the format PRC-XXXXXXXX.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Price Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this price record originated. Supports data lineage tracking and reconciliation between Oracle MICROS POS, SAP S/4HANA, Olo, and FranConnect.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVersion rdf:type rdf:Property ;
    rdfs:label 'Price Version' ;
    rdfs:comment 'Sequential version number for this price record, incremented each time the price is updated. Supports price history tracking and audit trail requirements for the same item-restaurant-channel-daypart combination.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'The discounted or special selling price applied during a promotional period or Limited Time Offer (LTO). Null when no active promotion applies to this item at this location.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemPriceCode rdf:type rdf:Property ;
    rdfs:label 'Source System Price Code' ;
    rdfs:comment 'The native identifier of this price record in the originating operational system (e.g., MICROS POS price record ID, SAP condition record number). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:ItemPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suggestedRetailPrice rdf:type rdf:Property ;
    rdfs:label 'Suggested Retail Price' ;
    rdfs:comment 'The franchisor-recommended selling price for this menu item. For franchised locations, this is the corporate-suggested price that franchisees may adopt or deviate from within permitted bounds.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nutritionProfileId rdf:type rdf:Property ;
    rdfs:label 'Nutrition Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for each nutrition profile record in the Silver Layer lakehouse. Primary key for the nutrition_profile data product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NutritionProfile .

ind:addedSugarsG rdf:type rdf:Property ;
    rdfs:label 'Added Sugars G' ;
    rdfs:comment 'Added sugars content per declared serving size in grams. Mandatory declaration on FDA Nutrition Facts panel per 2016 labeling rule update. Critical for compliance with FDA dietary guidelines and sugar-reduction reformulation tracking.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calciumMg rdf:type rdf:Property ;
    rdfs:label 'Calcium Mg' ;
    rdfs:comment 'Calcium content per declared serving size in milligrams. Mandatory micronutrient declaration on FDA Nutrition Facts panel per 2016 labeling rule update. Supports bone-health menu claims and dietary compliance reporting.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorieRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Calorie Range High' ;
    rdfs:comment 'Upper bound of the calorie range for menu items with variability in preparation. Used alongside calorie_range_low to display a calorie range on FDA-compliant menu boards when a single calorie value is not applicable.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calorieRangeLow rdf:type rdf:Property ;
    rdfs:label 'Calorie Range Low' ;
    rdfs:comment 'Lower bound of the calorie range for menu items with variability in preparation (e.g., customizable items, combo meals with choice components). Required for FDA menu board labeling when a single calorie value cannot be declared due to preparation variability.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cholesterolMg rdf:type rdf:Property ;
    rdfs:label 'Cholesterol Mg' ;
    rdfs:comment 'Cholesterol content per declared serving size in milligrams. Mandatory nutrient declaration on FDA Nutrition Facts panel. Critical for heart-health dietary compliance and menu engineering decisions.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyValueBasisCalories rdf:type rdf:Property ;
    rdfs:label 'Daily Value Basis Calories' ;
    rdfs:comment 'Reference caloric intake used to calculate percent Daily Value (%DV) figures on the FDA Nutrition Facts panel. Standard FDA reference is 2,000 kcal/day for adults. Stored to support accurate %DV recalculation if FDA reference values are updated.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Method by which the nutritional values in this profile were determined. Drives confidence level and regulatory defensibility of declared values. Lab analysis is the gold standard for FDA compliance; recipe calculation is acceptable for composite items. [ENUM-REF-CANDIDATE: lab_analysis|database_lookup|recipe_calculation|supplier_provided|literature_value — promote to reference product if values expand]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryFiberG rdf:type rdf:Property ;
    rdfs:label 'Dietary Fiber G' ;
    rdfs:comment 'Dietary fiber content per declared serving size in grams. Mandatory sub-component of total carbohydrate on FDA Nutrition Facts panel. Supports high-fiber menu claims and dietary guideline alignment.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insolubleFiberG rdf:type rdf:Property ;
    rdfs:label 'Insoluble Fiber G' ;
    rdfs:comment 'Insoluble fiber content per declared serving size in grams. Voluntary sub-component of dietary fiber on FDA Nutrition Facts panel; supports digestive health menu claims.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironMg rdf:type rdf:Property ;
    rdfs:label 'Iron Mg' ;
    rdfs:comment 'Iron content per declared serving size in milligrams. Mandatory micronutrient declaration on FDA Nutrition Facts panel per 2016 labeling rule update. Key metric for dietary adequacy reporting and menu engineering.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Indicates whether this nutrition profile record is the currently active and published version for the associated menu item. Supports Slowly Changing Dimension (SCD) Type 2 versioning in the Silver Layer lakehouse, ensuring only one active profile per menu item at any point in time.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Number' ;
    rdfs:comment 'Accreditation number of the third-party laboratory that performed the nutritional analysis. Supports regulatory audit defensibility and ensures analysis was conducted by an ISO 17025-accredited or FDA-recognized laboratory.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Date' ;
    rdfs:comment 'Date on which the laboratory analysis was conducted to determine the nutritional values in this profile. Required for regulatory audit trails and to determine when re-analysis is needed due to recipe changes or ingredient substitutions.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:menuBoardCalorieDisplay rdf:type rdf:Property ;
    rdfs:label 'Menu Board Calorie Display' ;
    rdfs:comment 'Formatted calorie string as it must appear on FDA-compliant customer-facing menu boards and digital ordering platforms (e.g., \'540 Cal\', \'430-780 Cal\'). Derived from calories or calorie range fields; stored as the authoritative display string to ensure consistent rendering across POS, OLO, and 3PD channels.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monounsaturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Monounsaturated Fat G' ;
    rdfs:comment 'Monounsaturated fat content per declared serving size in grams. Voluntary declaration on FDA Nutrition Facts panel; supports heart-healthy menu claims and nutritional transparency for guests.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:polyunsaturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Polyunsaturated Fat G' ;
    rdfs:comment 'Polyunsaturated fat content per declared serving size in grams. Voluntary declaration on FDA Nutrition Facts panel; included to support health-conscious menu positioning and nutritional transparency initiatives.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potassiumMg rdf:type rdf:Property ;
    rdfs:label 'Potassium Mg' ;
    rdfs:comment 'Potassium content per declared serving size in milligrams. Mandatory micronutrient declaration on FDA Nutrition Facts panel per 2016 labeling rule update. Supports heart-health and blood-pressure-related menu claims.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this nutrition profile record, used in regulatory submissions, lab reports, and cross-system references (e.g., NP-BURG001). Distinct from the surrogate primary key.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable label for this nutrition profile, typically combining the menu item name and serving configuration (e.g., \'Classic Cheeseburger – Regular Serving\'). Used in regulatory filings and internal reporting.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileType rdf:type rdf:Property ;
    rdfs:label 'Profile Type' ;
    rdfs:comment 'Classification of the nutrition profile indicating whether it represents a standard menu item, a customized build, a Limited Time Offer (LTO), a regional variant, or a test/pilot item. Drives which profiles are published to FDA-mandated menu boards. [ENUM-REF-CANDIDATE: standard|customized|limited_time_offer|regional|test — promote to reference product if values expand]' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proteinG rdf:type rdf:Property ;
    rdfs:label 'Protein G' ;
    rdfs:comment 'Protein content per declared serving size in grams. Mandatory nutrient declaration on FDA Nutrition Facts panel. Key metric for high-protein menu positioning and athletic/dietary segment marketing.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saturatedFatG rdf:type rdf:Property ;
    rdfs:label 'Saturated Fat G' ;
    rdfs:comment 'Saturated fat content per declared serving size in grams. Mandatory sub-component of total fat on FDA Nutrition Facts panel. Key metric for heart-health menu engineering and dietary guideline compliance.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servingSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Serving Size Description' ;
    rdfs:comment 'Household measure description of the serving size as it appears on the FDA Nutrition Facts panel (e.g., \'1 sandwich\', \'1 cup (240 mL)\'). Required for consumer-facing menu labeling compliance.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solubleFiberG rdf:type rdf:Property ;
    rdfs:label 'Soluble Fiber G' ;
    rdfs:comment 'Soluble fiber content per declared serving size in grams. Voluntary sub-component of dietary fiber on FDA Nutrition Facts panel; supports heart-health and cholesterol-reduction menu claims.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCarbohydrateG rdf:type rdf:Property ;
    rdfs:label 'Total Carbohydrate G' ;
    rdfs:comment 'Total carbohydrate content per declared serving size in grams. Mandatory nutrient declaration on FDA Nutrition Facts panel. Includes dietary fiber, total sugars, and added sugars as sub-components.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFatG rdf:type rdf:Property ;
    rdfs:label 'Total Fat G' ;
    rdfs:comment 'Total fat content per declared serving size in grams. Mandatory nutrient declaration on FDA Nutrition Facts panel. Includes saturated fat, trans fat, polyunsaturated fat, and monounsaturated fat.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSugarsG rdf:type rdf:Property ;
    rdfs:label 'Total Sugars G' ;
    rdfs:comment 'Total sugars content per declared serving size in grams. Mandatory sub-component of total carbohydrate on FDA Nutrition Facts panel. Includes both naturally occurring and added sugars.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transFatG rdf:type rdf:Property ;
    rdfs:label 'Trans Fat G' ;
    rdfs:comment 'Trans fat content per declared serving size in grams. Mandatory sub-component of total fat on FDA Nutrition Facts panel. Regulatory threshold: items with less than 0.5g may declare 0g per FDA rounding rules.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vitaminDMcg rdf:type rdf:Property ;
    rdfs:label 'Vitamin D Mcg' ;
    rdfs:comment 'Vitamin D content per declared serving size in micrograms. Mandatory micronutrient declaration on FDA Nutrition Facts panel per 2016 labeling rule update. Expressed as micrograms (mcg) with percent Daily Value (%DV) calculated separately.' ;
    rdfs:domain ind:NutritionProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Allergen Declaration Id' ;
    rdfs:comment 'Unique surrogate identifier for each allergen declaration record. Primary key for the allergen_declaration data product in the menu domain.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllergenDeclaration .

ind:supersededByAllergenDeclarationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Allergen Declaration Id' ;
    rdfs:comment 'Reference to the allergen_declaration_id of the newer declaration that supersedes this record when a recipe change or regulatory update requires a revised allergen profile. Null if this is the current active declaration. Enables full version history traversal.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllergenDeclaration .

ind:triggeringIngredientId rdf:type rdf:Property ;
    rdfs:label 'Triggering Ingredient Id' ;
    rdfs:comment 'Foreign key linking to supply.ingredient. Business justification: FDA allergen labeling compliance: when an ingredient\'s allergen status changes, all affected allergen_declarations must be reviewed and reissued. Linking declaration to the triggering ingredient enabl' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ingredient .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of service channels for which this allergen declaration is applicable (e.g., DT, OLO, 3PD, dine-in, catering). Supports channel-specific menu publishing and allergen disclosure requirements across Drive-Thru (DT), Online Ordering (OLO), and Third-Party Delivery (3PD) platforms. [ENUM-REF-CANDIDATE: dt|olo|3pd|dine_in|catering|kiosk|mobile_app — promote to reference product]' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossContactRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Cross Contact Risk Level' ;
    rdfs:comment 'Assessed risk level for unintentional allergen cross-contact during food preparation in the restaurant kitchen (BOH). Determined through HACCP analysis of shared equipment, preparation surfaces, and ingredient handling procedures. Drives operational protocols and guest advisories.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossContactSource rdf:type rdf:Property ;
    rdfs:label 'Cross Contact Source' ;
    rdfs:comment 'Free-text description of the identified source(s) of potential allergen cross-contact risk in the kitchen environment (e.g., shared fryer oil, shared prep surfaces, shared utensils, proximity to allergen-containing ingredients). Supports HACCP documentation and staff training.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartApplicability rdf:type rdf:Property ;
    rdfs:label 'Daypart Applicability' ;
    rdfs:comment 'Daypart(s) during which this allergen declaration is applicable (e.g., breakfast, lunch, dinner, late_night, all_day). Relevant when the same menu item has different ingredient formulations by daypart, resulting in different allergen profiles. [ENUM-REF-CANDIDATE: breakfast|lunch|dinner|late_night|snack|all_day — promote to reference product]' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'The business date on which this allergen declaration was formally issued or last certified by the food safety team. Used for regulatory compliance tracking and HACCP documentation.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declarationNumber rdf:type rdf:Property ;
    rdfs:label 'Declaration Number' ;
    rdfs:comment 'Externally-known business identifier for this allergen declaration record, used in regulatory submissions, audit trails, and cross-system references. Format: ALGN-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationStatus rdf:type rdf:Property ;
    rdfs:label 'Declaration Status' ;
    rdfs:comment 'Current regulatory review and approval lifecycle status of this allergen declaration. Controls whether the declaration is active and publishable to guests and regulatory bodies. Valid values: draft, pending_review, approved, superseded, withdrawn.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationType rdf:type rdf:Property ;
    rdfs:label 'Declaration Type' ;
    rdfs:comment 'Classification of the allergen declaration by menu item category context. Standard declarations apply to core menu items; LTO (Limited Time Offer) declarations apply to temporary promotional items; seasonal and regional declarations apply to market-specific or time-limited variants; custom applies to made-to-order or catering items.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eggsStatus rdf:type rdf:Property ;
    rdfs:label 'Eggs Status' ;
    rdfs:comment 'Declares the presence status of eggs allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fishSpecies rdf:type rdf:Property ;
    rdfs:label 'Fish Species' ;
    rdfs:comment 'Specific fish species present in the menu item (e.g., salmon, tuna, tilapia, cod) when fish_status is \'contains\'. FDA FALCPA requires species-level disclosure for fish allergens on food labels.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fishStatus rdf:type rdf:Property ;
    rdfs:label 'Fish Status' ;
    rdfs:comment 'Declares the presence status of fish allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glutenFreeCertified rdf:type rdf:Property ;
    rdfs:label 'Gluten Free Certified' ;
    rdfs:comment 'Indicates whether this menu item has been certified as gluten-free per FDA gluten-free labeling rule (21 CFR Part 101.91), requiring less than 20 ppm gluten. Distinct from wheat allergen status — an item may be wheat-free but not certified gluten-free.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestAdvisoryText rdf:type rdf:Property ;
    rdfs:label 'Guest Advisory Text' ;
    rdfs:comment 'Standardized guest-facing allergen advisory statement for this menu item, suitable for display on menus, digital ordering platforms (OLO, 3PD), and in-restaurant signage. Drafted in compliance with FDA menu labeling and FTC advertising regulations.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal food safety team notes regarding this allergen declaration, including rationale for cross-contact risk assessments, supplier-provided allergen data caveats, or pending ingredient change investigations. Not for guest-facing use. Classified as confidential business information.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mayContainAllergenCount rdf:type rdf:Property ;
    rdfs:label 'May Contain Allergen Count' ;
    rdfs:comment 'Count of the 9 FDA major allergens declared as \'may_contain\' (cross-contact risk) status for this menu item. Supports risk stratification, guest advisory communications, and HACCP reporting.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milkStatus rdf:type rdf:Property ;
    rdfs:label 'Milk Status' ;
    rdfs:comment 'Declares the presence status of milk (dairy) allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peanutsStatus rdf:type rdf:Property ;
    rdfs:label 'Peanuts Status' ;
    rdfs:comment 'Declares the presence status of peanuts allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'The date on which this allergen declaration was formally submitted to the relevant regulatory authority (e.g., FDA, local health department). Null if regulatory_submission_required is false or submission is pending.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether this allergen declaration requires formal submission to a regulatory body (e.g., FDA, local health department) as part of menu labeling compliance. Drives workflow routing to the regulatory affairs team.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restaurantFormatApplicability rdf:type rdf:Property ;
    rdfs:label 'Restaurant Format Applicability' ;
    rdfs:comment 'Restaurant format(s) for which this allergen declaration applies. QSR (Quick-Service Restaurant), casual dining, fine dining, or all formats. Supports multi-format operations where the same menu item may have different preparation methods and allergen profiles by format.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which this allergen declaration was last reviewed by the food safety or regulatory compliance team. Supports audit readiness and HACCP critical control point documentation.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or employee identifier of the food safety officer or regulatory compliance specialist who last reviewed and certified this allergen declaration. Supports audit trail and accountability.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sesameStatus rdf:type rdf:Property ;
    rdfs:label 'Sesame Status' ;
    rdfs:comment 'Declares the presence status of sesame allergen in this menu item per FDA FALCPA major allergen requirements (sesame added as the 9th major allergen effective January 1, 2023 under FASTER Act). Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shellfishSpecies rdf:type rdf:Property ;
    rdfs:label 'Shellfish Species' ;
    rdfs:comment 'Specific shellfish species present in the menu item (e.g., shrimp, crab, lobster, crayfish) when shellfish_status is \'contains\'. FDA FALCPA requires species-level disclosure for crustacean shellfish allergens.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shellfishStatus rdf:type rdf:Property ;
    rdfs:label 'Shellfish Status' ;
    rdfs:comment 'Declares the presence status of shellfish (crustacean shellfish) allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soybeansStatus rdf:type rdf:Property ;
    rdfs:label 'Soybeans Status' ;
    rdfs:comment 'Declares the presence status of soybeans allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAllergenCount rdf:type rdf:Property ;
    rdfs:label 'Total Allergen Count' ;
    rdfs:comment 'Count of the 9 FDA major allergens declared as \'contains\' status for this menu item. Used in menu engineering, guest-facing allergen filtering tools, and regulatory reporting to quickly identify high-allergen items.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treeNutVarieties rdf:type rdf:Property ;
    rdfs:label 'Tree Nut Varieties' ;
    rdfs:comment 'Specific tree nut varieties present in the menu item (e.g., almonds, cashews, walnuts, pecans, pistachios) when tree_nuts_status is \'contains\'. FDA FALCPA requires variety-level disclosure for tree nut allergens.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treeNutsStatus rdf:type rdf:Property ;
    rdfs:label 'Tree Nuts Status' ;
    rdfs:comment 'Declares the presence status of tree nuts allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheatStatus rdf:type rdf:Property ;
    rdfs:label 'Wheat Status' ;
    rdfs:comment 'Declares the presence status of wheat allergen in this menu item per FDA FALCPA major allergen requirements. Values: contains (intentionally present), may_contain (cross-contact risk), free_from (absent and no cross-contact risk).' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zenputAuditTaskCode rdf:type rdf:Property ;
    rdfs:label 'Zenput Audit Task Code' ;
    rdfs:comment 'Reference identifier for the Zenput food safety audit task or operational compliance checklist item associated with the verification of this allergen declaration in restaurant operations. Supports traceability between the master declaration and field-level compliance verification.' ;
    rdfs:domain ind:AllergenDeclaration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuLtoId rdf:type rdf:Property ;
    rdfs:label 'Menu Lto Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each Limited Time Offer (LTO) record. Primary key for the lto data product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuLto .

ind:foodSafetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Audit Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.food_safety_audit. Business justification: LTO launch approval workflows require a food safety audit sign-off before a new item goes live. menu_lto has a \'food_safety_approved\' flag that is a denormalized signal; a direct FK to the approving f' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyAudit .

ind:loyaltyOfferId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.offer. Business justification: LTO loyalty offer coordination: QSR operators pair LTO launches with specific loyalty offers (e.g., double points during launch week). Marketing operations require this link to execute integrated LTO+' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:nroProjectId rdf:type rdf:Property ;
    rdfs:label 'Nro Project Id' ;
    rdfs:comment 'Foreign key linking to realestate.nro_project. Business justification: Grand opening LTO planning is a named QSR business process: NRO project teams coordinate with marketing to launch location-specific LTOs tied to new restaurant openings. This link enables grand openin' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NroProject .

ind:previousLtoMenuLtoId rdf:type rdf:Property ;
    rdfs:label 'Previous Lto Menu Lto Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior LTO record if this is a returning or re-run offer. Enables lineage tracking of recurring LTOs, year-over-year performance comparison, and fan-favorite lifecycle analysis.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuLto .

ind:supplierContractId rdf:type rdf:Property ;
    rdfs:label 'Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: LTO launch approval gate: menu planning and procurement teams must validate that a supplier contract covers the full LTO window (planned_launch_date to planned_end_date) before approving launch. This ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:targetGuestSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Guest Segment Id' ;
    rdfs:comment 'Foreign key linking to guest.guest_segment. Business justification: LTO launches are planned and evaluated against specific guest segments (e.g., loyalty members, value seekers). Linking menu_lto to guest_segment enables segment-targeted rollout planning and post-laun' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The actual calendar date on which the LTO was removed from menus. May differ from planned_end_date due to early discontinuation, extended popularity, or supply constraints. Used for LTO lifecycle duration analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Launch Date' ;
    rdfs:comment 'The actual calendar date on which the LTO went live in restaurants. May differ from planned_launch_date due to supply chain delays, regulatory approvals, or operational readiness issues. Used for post-launch performance analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allergenReviewed rdf:type rdf:Property ;
    rdfs:label 'Allergen Reviewed' ;
    rdfs:comment 'Indicates whether a formal allergen review has been completed (True) for this LTO item, confirming all major allergens (per FDA FALCPA — Big 9 allergens) are identified and declared. Required for regulatory compliance and guest safety.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Calendar date on which the LTO received final business approval to proceed. Used to measure ideation-to-approval cycle time and track governance compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptDescription rdf:type rdf:Property ;
    rdfs:label 'Concept Description' ;
    rdfs:comment 'Internal narrative describing the culinary concept, inspiration, and strategic rationale behind the LTO. Used by Menu Development and Engineering teams during ideation and approval stages.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWeeklyUnits rdf:type rdf:Property ;
    rdfs:label 'Estimated Weekly Units' ;
    rdfs:comment 'Forecasted number of LTO units expected to be sold per restaurant per week during the active offer period. Used for supply chain procurement planning, PAR level setting in MarketMan, and labor scheduling in Planday.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foodSafetyApproved rdf:type rdf:Property ;
    rdfs:label 'Food Safety Approved' ;
    rdfs:comment 'Indicates whether the LTO item has received food safety clearance (True) per HACCP protocols and FDA/USDA regulatory requirements before launch. Tracked via Zenput food safety audit workflows. No LTO may go active without this flag being True.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNationalLaunch rdf:type rdf:Property ;
    rdfs:label 'Is National Launch' ;
    rdfs:comment 'Indicates whether this LTO is a full national launch (True) as opposed to a regional, franchise group, or test market deployment (False). Used for executive reporting, national marketing budget allocation, and supply chain capacity planning.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturningItem rdf:type rdf:Property ;
    rdfs:label 'Is Returning Item' ;
    rdfs:comment 'Indicates whether this LTO features an item that has been previously offered (True) or is a brand-new menu introduction (False). Supports fan-favorite tracking, nostalgia marketing strategies, and historical PMIX benchmarking.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestMarket rdf:type rdf:Property ;
    rdfs:label 'Is Test Market' ;
    rdfs:comment 'Indicates whether this LTO is currently in a limited test market phase (True) or has been deployed beyond test market scope (False). Used to segregate test performance data from production PMIX reporting.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Launch Lead Time Days' ;
    rdfs:comment 'Number of calendar days between the LTO approval date and the planned launch date. Used by supply chain and procurement teams to validate that sufficient lead time exists for ingredient sourcing, supplier onboarding, and distribution via Coupa Procurement.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the LTO in its end-to-end lifecycle: ideation (concept under development), approved (greenlit for production), in_test (active in test markets only), active (live in production rollout), sunset (offer period ended naturally), cancelled (discontinued before planned end).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltoCode rdf:type rdf:Property ;
    rdfs:label 'Lto Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the LTO, used in Oracle MICROS POS menu management, Salesforce CRM campaign references, and Olo Digital Ordering Platform configurations. Serves as the cross-system reference key.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltoType rdf:type rdf:Property ;
    rdfs:label 'Lto Type' ;
    rdfs:comment 'Classification of the LTO by its nature: new_item (first-time introduction), returning_item (previously offered item brought back), bundle (combination of existing items at a promotional price), promotional_price (existing item at a temporary price), or seasonal (tied to a calendar season or holiday).' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingHeadline rdf:type rdf:Property ;
    rdfs:label 'Marketing Headline' ;
    rdfs:comment 'Short consumer-facing promotional tagline or headline used in advertising, in-restaurant POP (Point of Purchase) materials, and digital marketing for this LTO (e.g., \'Back by Popular Demand — For a Limited Time Only!\'). Sourced from Salesforce CRM campaign assets.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuLtoName rdf:type rdf:Property ;
    rdfs:label 'Menu Lto Name' ;
    rdfs:comment 'Consumer-facing marketing name of the Limited Time Offer as it appears on menus, POS displays, digital ordering platforms, and promotional materials (e.g., \'Spicy Crispy Chicken Sandwich LTO\').' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nutritionalApproved rdf:type rdf:Property ;
    rdfs:label 'Nutritional Approved' ;
    rdfs:comment 'Indicates whether the LTO item\'s nutritional profile has been reviewed and approved (True) for menu labeling compliance per FDA menu labeling regulations (21 CFR Part 101). Required before consumer-facing publication.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloItemCode rdf:type rdf:Property ;
    rdfs:label 'Olo Item Code' ;
    rdfs:comment 'The item identifier assigned to this LTO in the Olo Digital Ordering Platform for online ordering and third-party delivery (3PD) channel activation. Used to synchronize LTO availability across digital channels.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Indicates whether the LTO applies to franchise-operated restaurants, company-owned restaurants, or both. Governs FranConnect compliance tracking, royalty rate applicability, and franchise disclosure obligations under FTC regulations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Total number of calendar days the LTO is planned to be active, calculated as the difference between planned_end_date and planned_launch_date. Used for supply chain volume forecasting, marketing campaign budgeting, and franchisee communication planning.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'The originally scheduled calendar date on which the LTO was planned to be removed from menus. Drives supply chain wind-down, inventory PAR level adjustments, and marketing campaign sunset planning.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'The originally scheduled calendar date on which the LTO was planned to go live in restaurants. Used for supply chain procurement lead time planning, marketing campaign scheduling, and NRO coordination.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmixTargetPct rdf:type rdf:Property ;
    rdfs:label 'Pmix Target Pct' ;
    rdfs:comment 'The target Product Mix (PMIX) percentage representing the share of total transactions this LTO is expected to capture during its active period. Used by Menu Engineering to set performance benchmarks and evaluate LTO success post-launch.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posItemCode rdf:type rdf:Property ;
    rdfs:label 'Pos Item Code' ;
    rdfs:comment 'The item code assigned to this LTO in Oracle MICROS POS for order capture, menu display, and PMIX reporting. This is the operational identifier used by cashiers, KDS (Kitchen Display System), and sales reporting.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code identifying the market(s) where this LTO is deployed (e.g., \'US-NORTHEAST\', \'EMEA\', \'APAC\'). Used for regional rollout scoping, localized marketing campaign alignment, and regional P&L reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloutScope rdf:type rdf:Property ;
    rdfs:label 'Rollout Scope' ;
    rdfs:comment 'Geographic and operational scope of the LTO deployment: national (all restaurants), regional (specific geographic region), franchise_group (specific franchisee group), company_owned (company-operated units only), or test_market (limited pilot locations). Governs FranConnect franchise compliance and royalty tracking.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonOrOccasion rdf:type rdf:Property ;
    rdfs:label 'Season Or Occasion' ;
    rdfs:comment 'The seasonal period or consumer occasion this LTO is designed to capitalize on (e.g., \'Summer 2025\', \'Super Bowl\', \'Halloween\', \'Valentine\'s Day\', \'Back to School\'). Supports marketing calendar planning and year-over-year seasonal PMIX trend analysis.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'The primary ordering channel(s) for which the LTO is available: dine_in (Front of House), drive_thru (DT), olo (Online Ordering via Olo Digital Ordering Platform), third_party_delivery (3PD aggregators), or all_channels. Governs channel-specific menu activation in Oracle MICROS POS and Olo.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFoodCostPct rdf:type rdf:Property ;
    rdfs:label 'Target Food Cost Pct' ;
    rdfs:comment 'The planned food cost as a percentage of the LTO selling price, representing the target CoGS% for this offer. Used by Menu Engineering to evaluate profitability and ensure the LTO meets financial thresholds before approval.' ;
    rdfs:domain ind:MenuLto ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifierGroupId rdf:type rdf:Property ;
    rdfs:label 'Modifier Group Id' ;
    rdfs:comment 'Unique surrogate identifier for the modifier group record. Primary key for the modifier_group data product in the menu domain. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ModifierGroup .

ind:allergenRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Relevance Flag' ;
    rdfs:comment 'Indicates whether any modifier options within this group may introduce allergen variations that require disclosure to guests. True = allergen-relevant group requiring allergen declaration logic at POS/OLO; False = no allergen impact. Supports FDA food labeling compliance and HACCP (Hazard Analysis Critical Control Points) protocols.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calorieImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Calorie Impact Flag' ;
    rdfs:comment 'Indicates whether modifier selections within this group materially affect the calorie count of the parent menu item, triggering calorie range display requirements on menus and digital ordering platforms. Supports FDA menu labeling compliance (21 CFR Part 101).' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultModifierCode rdf:type rdf:Property ;
    rdfs:label 'Default Modifier Code' ;
    rdfs:comment 'The business code of the modifier option that is pre-selected by default when a guest views this modifier group on POS or OLO. Supports speed of service (SOS) optimization by pre-populating the most common selection. Null if no default applies.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Customer-facing label shown on POS screens, KDS (Kitchen Display System), OLO (Online Ordering) interfaces, and 3PD (Third-Party Delivery) menus. May differ from the internal group_name for marketing or localization purposes. Example: \'Choose Your Protein\', \'Pick a Sauce\'.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering position that controls the sequence in which this modifier group is presented to the guest on POS screens, KDS, OLO, and 3PD interfaces. Lower values appear first. Enables menu engineers to control the customization flow and upsell sequencing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freeModifierLimit rdf:type rdf:Property ;
    rdfs:label 'Free Modifier Limit' ;
    rdfs:comment 'Number of modifier selections within this group that are included at no additional charge. Selections beyond this limit may incur an upcharge per the individual modifier\'s pricing. A value of 0 means all selections are charged; null means unlimited free selections. Supports COGS (Cost of Goods Sold) management and pricing strategy.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the modifier group, used in POS configuration, OLO platform integration, and 3PD channel mapping. Serves as the BUSINESS_IDENTIFIER category for this MASTER_RESOURCE entity. Example: \'PROT-CHOICE\', \'SAUCE-SEL\', \'SIZE-UPG\'.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Internal business name for the modifier group used in back-office systems, menu engineering reports, and POS configuration. Serves as the IDENTITY_LABEL category for this MASTER_RESOURCE entity. Example: \'Protein Choice\', \'Sauce Selection\', \'Size Upgrade\'.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Categorical classification of the modifier group by its culinary or operational function. Drives menu engineering analysis (PMIX), reporting by customization category, and POS screen layout. [ENUM-REF-CANDIDATE: protein|sauce|size|add_on|side|beverage|preparation|topping|crust|dietary — promote to reference product]' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCollapsible rdf:type rdf:Property ;
    rdfs:label 'Is Collapsible' ;
    rdfs:comment 'Indicates whether this modifier group can be collapsed or hidden in the guest-facing UI when not interacted with. True = group can be collapsed to reduce screen clutter on OLO and kiosk interfaces; False = always fully expanded. Supports UX optimization for digital ordering channels.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFranchiseConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Franchise Configurable' ;
    rdfs:comment 'Indicates whether franchise operators are permitted to modify the configuration of this modifier group (e.g., adjust min/max selections, add local modifiers) within the bounds of the franchise agreement. True = franchisee may configure; False = corporate-locked configuration. Supports franchise management and brand standards compliance.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKdsDisplayed rdf:type rdf:Property ;
    rdfs:label 'Is Kds Displayed' ;
    rdfs:comment 'Indicates whether this modifier group and its selected options are displayed on the KDS (Kitchen Display System) in the BOH (Back of House). True = modifier group selections are shown to kitchen staff; False = suppressed from KDS display (e.g., packaging or FOH-only modifiers). Supports BOH operational efficiency.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrintedOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Is Printed On Receipt' ;
    rdfs:comment 'Indicates whether the modifier group\'s selected options are printed on the guest receipt. True = selections appear on receipt for guest reference; False = suppressed from receipt printing. Supports guest transparency and order accuracy.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether the guest must make at least one selection from this modifier group before the parent menu item can be added to the order. True = mandatory selection; False = optional. Derived operationally from min_selections > 0 but stored explicitly for POS/OLO rendering logic.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localizationKey rdf:type rdf:Property ;
    rdfs:label 'Localization Key' ;
    rdfs:comment 'Reference key used to look up translated display names and descriptions for this modifier group in multi-language markets. Supports international franchise operations and localized guest-facing menu presentation across global markets.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSelections rdf:type rdf:Property ;
    rdfs:label 'Max Selections' ;
    rdfs:comment 'Maximum number of modifier options a guest may select from this group. For single-select groups this is typically 1. For multi-select groups this caps the number of add-ons or customizations. Enforced at POS and OLO order validation.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minSelections rdf:type rdf:Property ;
    rdfs:label 'Min Selections' ;
    rdfs:comment 'Minimum number of modifier options a guest must select from this group to complete an order. A value of 0 indicates the group is optional. A value of 1 or more makes the group mandatory. Enforced at POS and OLO order validation.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifierGroupDescription rdf:type rdf:Property ;
    rdfs:label 'Modifier Group Description' ;
    rdfs:comment 'Detailed narrative description of the modifier group\'s purpose, scope, and applicable customization context. Used by menu engineers and franchise operators for documentation and training materials.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifierGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Modifier Group Status' ;
    rdfs:comment 'Current lifecycle state of the modifier group. Serves as the LIFECYCLE_STATUS category for this MASTER_RESOURCE entity. \'active\' = currently in use on POS/OLO; \'inactive\' = temporarily disabled; \'draft\' = under menu engineering review; \'archived\' = retired from all channels; \'suspended\' = paused due to supply or compliance issue.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oloGroupRef rdf:type rdf:Property ;
    rdfs:label 'Olo Group Ref' ;
    rdfs:comment 'Native identifier assigned to this modifier group within the Olo Digital Ordering Platform. Used for synchronization between the enterprise menu master and the OLO channel, ensuring consistent customization options across in-store and digital ordering.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posGroupRef rdf:type rdf:Property ;
    rdfs:label 'Pos Group Ref' ;
    rdfs:comment 'Native identifier or reference code assigned to this modifier group within the Oracle MICROS POS system. Used for reconciliation between the lakehouse silver layer and the POS system of record during menu synchronization and audit processes.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionType rdf:type rdf:Property ;
    rdfs:label 'Selection Type' ;
    rdfs:comment 'Defines whether a guest may select only one modifier (single-select, e.g., Size Upgrade) or multiple modifiers (multi-select, e.g., Add-Ons, Sauce Selection) from this group. Drives POS and OLO customization logic and guest-facing UI rendering.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrderMethod rdf:type rdf:Property ;
    rdfs:label 'Sort Order Method' ;
    rdfs:comment 'Defines how individual modifier options within this group are sorted when displayed to the guest. \'manual\' = display_sequence on each modifier; \'alphabetical\' = A-Z by modifier name; \'price_asc/desc\' = by price; \'popularity\' = by historical selection frequency from PMIX data. Supports menu engineering and upsell optimization.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upchargeBasis rdf:type rdf:Property ;
    rdfs:label 'Upcharge Basis' ;
    rdfs:comment 'Defines how additional charges are applied when a guest selects modifiers beyond the free_modifier_limit. \'per_item\' = each additional modifier is charged individually; \'flat_group\' = a single flat charge applies to the group regardless of count; \'none\' = no upcharges apply. Drives POS pricing logic and revenue management.' ;
    rdfs:domain ind:ModifierGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuModifierId rdf:type rdf:Property ;
    rdfs:label 'Menu Modifier Id' ;
    rdfs:comment 'Unique surrogate identifier for each modifier option record in the master modifier catalog. Serves as the primary key for all downstream references from Oracle MICROS POS and Olo Digital Ordering Platform.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuModifier .

ind:availableChannels rdf:type rdf:Property ;
    rdfs:label 'Available Channels' ;
    rdfs:comment 'Pipe-delimited list of ordering channels where this modifier is available (e.g., \'dine_in|drive_thru|olo|3pd\'). Supports channel-specific menu configuration for DT (Drive-Thru), OLO (Online Ordering), and 3PD (Third-Party Delivery) platforms. [ENUM-REF-CANDIDATE: dine_in|drive_thru|olo|3pd|kiosk|catering — promote to reference product]' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableDayparts rdf:type rdf:Property ;
    rdfs:label 'Available Dayparts' ;
    rdfs:comment 'Pipe-delimited list of dayparts during which this modifier is available (e.g., \'breakfast|lunch|dinner|late_night\'). Enables daypart-specific menu engineering and ensures modifiers are only offered during operationally appropriate time windows.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calorieDelta rdf:type rdf:Property ;
    rdfs:label 'Calorie Delta' ;
    rdfs:comment 'The incremental calorie change (in kilocalories) added to or subtracted from the base menu item\'s calorie count when this modifier is selected. Positive for additions, negative for removals. Required for FDA menu labeling compliance and nutritional transparency on digital ordering channels.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbohydrateDeltaG rdf:type rdf:Property ;
    rdfs:label 'Carbohydrate Delta G' ;
    rdfs:comment 'Incremental change in total carbohydrate content (in grams) when this modifier is applied. Required for FDA nutritional labeling and supports guest dietary needs (e.g., low-carb, diabetic-friendly options).' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsDelta rdf:type rdf:Property ;
    rdfs:label 'Cogs Delta' ;
    rdfs:comment 'The incremental raw ingredient cost (COGS) associated with applying this modifier, expressed in the local currency. Used for menu engineering profitability analysis, CoGS% (Cost of Goods Sold Percentage) calculations, and P&L (Profit and Loss) reporting at the modifier level.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fatDeltaG rdf:type rdf:Property ;
    rdfs:label 'Fat Delta G' ;
    rdfs:comment 'Incremental change in total fat content (in grams) when this modifier is applied to the base menu item. Required for FDA nutritional labeling compliance on menus and digital ordering platforms.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAllergenFree rdf:type rdf:Property ;
    rdfs:label 'Is Allergen Free' ;
    rdfs:comment 'Indicates whether this modifier introduces zero major allergens (True) or introduces at least one allergen (False). Used for rapid allergen filtering on digital ordering platforms and guest-facing allergen transparency tools.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Available' ;
    rdfs:comment 'Real-time availability flag indicating whether this modifier is currently orderable (True) or temporarily unavailable due to ingredient stockout, 86\'d item, or operational hold (False). Distinct from status, which reflects the lifecycle state; this flag reflects operational availability at a point in time.' ;
    rdfs:domain ind:Menu ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'Maximum number of times this modifier can be applied to a single menu item in one order (e.g., a guest can add up to 3 extra cheese slices). Enforced at POS and digital ordering checkout to control portion and cost.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:menuModifierDescription rdf:type rdf:Property ;
    rdfs:label 'Menu Modifier Description' ;
    rdfs:comment 'Detailed description of the modifier option for internal documentation, menu engineering analysis, and digital channel display (e.g., online ordering, third-party delivery apps).' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuModifierName rdf:type rdf:Property ;
    rdfs:label 'Menu Modifier Name' ;
    rdfs:comment 'Human-readable display name of the modifier option as it appears on POS terminals, KDS (Kitchen Display System), and digital ordering channels (e.g., \'Extra Cheese\', \'No Onions\', \'Gluten-Free Bun\', \'Large Size\').' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuModifierStatus rdf:type rdf:Property ;
    rdfs:label 'Menu Modifier Status' ;
    rdfs:comment 'Current lifecycle status of the modifier option. \'active\' indicates available for ordering; \'inactive\' is temporarily unavailable; \'discontinued\' is permanently removed; \'pending_approval\' is awaiting menu engineering sign-off; \'seasonal\' is available only during specific periods.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifierType rdf:type rdf:Property ;
    rdfs:label 'Modifier Type' ;
    rdfs:comment 'Categorical classification of the modifier\'s operational intent. \'addition\' adds an ingredient (e.g., Extra Cheese), \'removal\' removes an ingredient (e.g., No Onions), \'substitution\' replaces an ingredient (e.g., Gluten-Free Bun), \'size_upsize\'/\'size_downsize\' changes portion size, \'preparation\' specifies cooking instruction (e.g., Well Done). [ENUM-REF-CANDIDATE: addition|removal|substitution|size_upsize|size_downsize|preparation — promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pluCode rdf:type rdf:Property ;
    rdfs:label 'Plu Code' ;
    rdfs:comment 'Price Look-Up code assigned to this modifier in Oracle MICROS POS for transaction processing and sales reporting. Used for PMIX (Product Mix) reporting and COGS (Cost of Goods Sold) tracking at the modifier level.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posButtonColor rdf:type rdf:Property ;
    rdfs:label 'Pos Button Color' ;
    rdfs:comment 'Hexadecimal color code for the modifier\'s button on Oracle MICROS POS touchscreen terminals. Used to visually differentiate modifier categories (e.g., additions in green, removals in red) to improve FOH (Front of House) order accuracy and speed of service (SOS).' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepInstruction rdf:type rdf:Property ;
    rdfs:label 'Prep Instruction' ;
    rdfs:comment 'Specific BOH (Back of House) preparation instruction associated with this modifier, transmitted to the KDS (Kitchen Display System) when the modifier is selected (e.g., \'Grill well done\', \'Toast bun\', \'Serve sauce on side\'). Supports SOP (Standard Operating Procedure) compliance in kitchen operations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDelta rdf:type rdf:Property ;
    rdfs:label 'Price Delta' ;
    rdfs:comment 'The incremental price adjustment applied to the base menu item price when this modifier is selected. Positive values represent upcharges (e.g., +1.50 for Extra Cheese); negative values represent discounts or removals (e.g., -0.50 for No Protein). Zero indicates no price change. Used by Oracle MICROS POS for real-time transaction pricing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proteinDeltaG rdf:type rdf:Property ;
    rdfs:label 'Protein Delta G' ;
    rdfs:comment 'Incremental change in protein content (in grams) when this modifier is applied. Supports FDA nutritional labeling requirements and enables protein-focused menu analytics for health-oriented menu engineering.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name used on KDS (Kitchen Display System) screens and printed receipts where space is constrained (e.g., \'XTR CHSE\', \'NO ONI\', \'GF BUN\').' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'SKU (Stock Keeping Unit) code linking this modifier to the inventory and supply chain systems (MarketMan Inventory Management, SAP S/4HANA MM module) for ingredient-level cost tracking and PAR Level management.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sodiumDeltaMg rdf:type rdf:Property ;
    rdfs:label 'Sodium Delta Mg' ;
    rdfs:comment 'Incremental change in sodium content (in milligrams) when this modifier is applied. Critical for FDA menu labeling compliance and guest dietary transparency, particularly for health-conscious consumers and those managing sodium intake.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unavailabilityReason rdf:type rdf:Property ;
    rdfs:label 'Unavailability Reason' ;
    rdfs:comment 'Reason code explaining why this modifier is currently unavailable (is_available = False). Supports operational reporting, supply chain issue tracking, and guest communication on digital ordering platforms.' ;
    rdfs:domain ind:MenuModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmixRecordId rdf:type rdf:Property ;
    rdfs:label 'Pmix Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each product mix (PMIX) record in the Silver layer. Serves as the primary key for this transactional reporting entity.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalId rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Id' ;
    rdfs:comment 'Foreign key linking to restaurant.pos_terminal. Business justification: Product mix data originates from POS terminal transactions. Terminal-level sales audit, POS reconciliation, and identifying terminal-specific anomalies (voids, comps) are named operational processes. ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to guest.guest_segment. Business justification: Segment-level product mix analysis is a core menu engineering report — operators need to know which items sell to which guest segments to drive targeted promotions and menu optimization. A foodservice' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:avgSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Avg Selling Price' ;
    rdfs:comment 'Average net selling price per unit of the menu item during the reporting period, calculated as net sales divided by units sold. Reflects actual realized price after discounts and may differ from the menu list price.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryRank rdf:type rdf:Property ;
    rdfs:label 'Category Rank' ;
    rdfs:comment 'Rank of the menu item within its menu category at the restaurant for the reporting period, ordered by units sold descending. Used to identify top and bottom performers within each category for menu rationalization decisions.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cogsAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Amount' ;
    rdfs:comment 'Total Cost of Goods Sold (COGS) for the menu item during the reporting period, calculated as units sold multiplied by the item\'s standard recipe cost. Core input for menu engineering profitability analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Amount' ;
    rdfs:comment 'Total monetary value of complimentary (comped) menu items given during the reporting period. Represents a direct cost to the restaurant and is tracked for P&L accuracy and loss prevention.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compCount rdf:type rdf:Property ;
    rdfs:label 'Comp Count' ;
    rdfs:comment 'Number of complimentary (comped) units of this menu item given to guests during the reporting period (e.g., for service recovery, employee meals, or promotional giveaways). Tracked for cost control and loss prevention.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Contribution Margin Amount' ;
    rdfs:comment 'Contribution margin for the menu item during the reporting period, calculated as net sales minus COGS. Represents the dollar contribution of the item toward covering fixed costs and generating profit. Core metric in menu engineering star/plow-horse/puzzle/dog classification.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total value of discounts, promotional reductions, and coupon redemptions applied to the menu item during the reporting period. Used to reconcile gross to net sales and evaluate promotional effectiveness.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue generated by the menu item during the reporting period, before discounts, voids, and comps. Expressed in local currency. Core component of the MONETARY_TRIPLET for revenue reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:menuCategory rdf:type rdf:Property ;
    rdfs:label 'Menu Category' ;
    rdfs:comment 'The menu category to which the item belongs (e.g., Burgers, Beverages, Sides, Desserts, LTO). Used for category-level PMIX analysis and menu engineering decisions. [ENUM-REF-CANDIDATE: entree|beverage|side|dessert|appetizer|lto|combo|condiment — promote to reference product]' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuEngineeringClassification rdf:type rdf:Property ;
    rdfs:label 'Menu Engineering Classification' ;
    rdfs:comment 'Menu engineering quadrant classification of the item for the reporting period based on the Boston Consulting Group (BCG) matrix adapted for foodservice: Star (high popularity, high margin), Plow Horse (high popularity, low margin), Puzzle (low popularity, high margin), Dog (low popularity, low margin). Core output of menu engineering analysis.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuListPrice rdf:type rdf:Property ;
    rdfs:label 'Menu List Price' ;
    rdfs:comment 'The standard listed menu price for the item at the restaurant during the reporting period. Used to calculate price realization (average selling price vs. list price) and assess discount impact.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:menuMixPct rdf:type rdf:Property ;
    rdfs:label 'Menu Mix Pct' ;
    rdfs:comment 'The percentage of total units sold at the restaurant during the reporting period that this menu item represents. Core Product Mix (PMIX) metric used to identify high-velocity and low-velocity items for menu engineering decisions.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Net sales revenue for the menu item after deducting discounts, voids, and comps from gross sales. The primary revenue figure used in P&L reporting, PMIX analysis, and AUV calculations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRank rdf:type rdf:Property ;
    rdfs:label 'Overall Rank' ;
    rdfs:comment 'Rank of the menu item across all menu items at the restaurant for the reporting period, ordered by units sold descending. Provides a holistic view of item velocity for menu engineering and operational prioritization.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this PMIX record in the Silver layer. \'active\' indicates the current valid record; \'revised\' indicates the record has been superseded by a correction; \'voided\' indicates the record was invalidated due to a data quality issue.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total monetary value of refunds issued for this menu item during the reporting period. Used in net revenue reconciliation and guest satisfaction analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundCount rdf:type rdf:Property ;
    rdfs:label 'Refund Count' ;
    rdfs:comment 'Number of refunds issued for this menu item during the reporting period. Elevated refund counts may indicate quality issues, order accuracy problems, or guest dissatisfaction.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Date' ;
    rdfs:comment 'Calendar date for which this PMIX record applies. Used for daily and weekly menu engineering analysis and comparable store sales (Comp Sales / SSS) reporting.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Granularity of the PMIX record — whether it represents a daily, weekly, or daypart-level aggregation. Determines how units sold and revenue figures should be interpreted.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The ordering channel through which the menu item was sold (e.g., Drive-Thru (DT), Online Ordering (OLO), Third-Party Delivery (3PD), dine-in, kiosk). Enables channel-level PMIX analysis for menu engineering and pricing strategy.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesMixPct rdf:type rdf:Property ;
    rdfs:label 'Sales Mix Pct' ;
    rdfs:comment 'The percentage of total net sales revenue at the restaurant during the reporting period attributable to this menu item. Distinct from menu mix percentage (unit-based); this is revenue-based mix used for revenue contribution analysis.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unavailabilityHours rdf:type rdf:Property ;
    rdfs:label 'Unavailability Hours' ;
    rdfs:comment 'Total number of hours during the reporting period that the menu item was unavailable for sale (e.g., due to stock-out or being 86\'d). Used to adjust PMIX velocity calculations and identify supply chain or inventory issues.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of individual menu item units sold during the reporting period at the restaurant. The primary volume metric in PMIX analysis and menu engineering.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidAmount rdf:type rdf:Property ;
    rdfs:label 'Void Amount' ;
    rdfs:comment 'Total monetary value of voided transactions for this menu item during the reporting period. Used alongside void count for loss prevention analysis and operational quality monitoring.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidCount rdf:type rdf:Property ;
    rdfs:label 'Void Count' ;
    rdfs:comment 'Number of voided transactions for this menu item during the reporting period. Voids indicate order errors, customer changes, or operational issues and are tracked separately from discounts for loss prevention and operational quality analysis.' ;
    rdfs:domain ind:PmixRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemCostId rdf:type rdf:Property ;
    rdfs:label 'Item Cost Id' ;
    rdfs:comment 'Unique surrogate identifier for each item cost record. Primary key for the item_cost data product in the menu domain.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Cost accounting assigns each menu item\'s calculated cost to a cost center for internal budgeting and variance analysis; essential for COGS reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Profit center-level food cost variance reporting is a standard foodservice finance process — each restaurant unit maps to a profit center, and COGS must be attributed to profit centers for unit-level ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:actualCogsPct rdf:type rdf:Property ;
    rdfs:label 'Actual Cogs Pct' ;
    rdfs:comment 'Actual realized Cost of Goods Sold percentage sourced from MarketMan Inventory Management, reflecting real purchase costs, waste, and yield losses. Compared against theoretical_cogs_pct to compute variance and identify operational inefficiencies.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Base Selling Price' ;
    rdfs:comment 'The menu item\'s base selling price at the time of cost calculation, used as the denominator for CoGS% computation. Captured as a point-in-time snapshot to ensure historical cost percentage accuracy even when prices change.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPctVariance rdf:type rdf:Property ;
    rdfs:label 'Cogs Pct Variance' ;
    rdfs:comment 'Difference between actual_cogs_pct and theoretical_cogs_pct (actual minus theoretical). Positive variance indicates actual costs exceeded theoretical expectations, signaling waste, theft, or pricing issues. Critical metric for P&L reporting and operational control.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Cost Calculation Date' ;
    rdfs:comment 'The business date on which the theoretical item cost was calculated. Used to track cost trends over time and align with menu engineering review cycles and P&L reporting periods.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Calculation Method' ;
    rdfs:comment 'Method used to derive the item cost: \'theoretical_bom\' = derived from recipe Bill of Materials and price snapshot; \'actual_marktman\' = sourced directly from MarketMan actual cost data; \'blended\' = weighted combination of theoretical and actual. Ensures analytical transparency.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerGram rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gram' ;
    rdfs:comment 'Theoretical cost per gram of the menu item (theoretical_cost_amount / portion_size_grams). Enables normalized cost comparison across items of different portion sizes and supports portion engineering decisions.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Status' ;
    rdfs:comment 'Lifecycle status of this item cost record. \'draft\' indicates pending review; \'approved\' indicates validated and active for menu engineering; \'superseded\' indicates replaced by a newer calculation; \'archived\' indicates retired from active use.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientCount rdf:type rdf:Property ;
    rdfs:label 'Ingredient Count' ;
    rdfs:comment 'Total number of distinct ingredients in the Bill of Materials (BOM) used for this cost calculation. Provides a quick indicator of recipe complexity and the number of price inputs contributing to the theoretical cost.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marktmanCostRecordCode rdf:type rdf:Property ;
    rdfs:label 'Marktman Cost Record Code' ;
    rdfs:comment 'The native record identifier from MarketMan Inventory Management for the actual cost data used in this calculation. Enables direct traceability back to the source system record for audit and reconciliation purposes.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingCost rdf:type rdf:Property ;
    rdfs:label 'Packaging Cost' ;
    rdfs:comment 'Cost contribution of packaging materials (containers, wrappers, bags, cups) to the total theoretical item cost. Tracked separately from food ingredients to support packaging procurement decisions and sustainability reporting.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'The pricing basis applied to ingredient costs in this calculation: \'last_purchase\' = most recent purchase price; \'moving_average\' = weighted average of recent purchases; \'contract\' = contracted supplier price from Coupa; \'standard\' = standard cost set by finance. Affects cost comparability.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Price Snapshot Date' ;
    rdfs:comment 'The effective date of the ingredient purchase prices used in this cost calculation. Distinct from cost_calculation_date — the snapshot may use prices from a prior period (e.g., last purchase price, rolling average). Critical for cost audit and variance explanation.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceSnapshotReference rdf:type rdf:Property ;
    rdfs:label 'Price Snapshot Reference' ;
    rdfs:comment 'Reference to the ingredient price snapshot used in this cost calculation. Captures the specific point-in-time purchase prices from MarketMan that were applied to the Bill of Materials to derive theoretical Cost of Goods Sold (COGS).' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProteinCost rdf:type rdf:Property ;
    rdfs:label 'Primary Protein Cost' ;
    rdfs:comment 'Cost contribution of the primary protein ingredient(s) to the total theoretical item cost. Proteins (beef, chicken, seafood) are typically the highest-cost BOM component and are tracked separately for commodity price sensitivity analysis and USDA-aligned procurement reporting.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipeVersion rdf:type rdf:Property ;
    rdfs:label 'Recipe Version' ;
    rdfs:comment 'Version identifier of the recipe / Bill of Materials (BOM) used in this cost calculation (e.g., \'v3.2\'). Enables traceability of cost changes driven by recipe reformulations versus ingredient price movements.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCogsPct rdf:type rdf:Property ;
    rdfs:label 'Target Cogs Pct' ;
    rdfs:comment 'The budgeted or target CoGS% for this menu item as set by the finance and menu engineering teams. Used as the benchmark against which theoretical_cogs_pct and actual_cogs_pct are evaluated. Expressed as a decimal (e.g., 0.2800 = 28.00%).' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetVariancePct rdf:type rdf:Property ;
    rdfs:label 'Target Variance Pct' ;
    rdfs:comment 'Acceptable tolerance band for CoGS% variance (theoretical vs actual) before an alert or review is triggered. Expressed as a decimal (e.g., 0.0200 = ±2.00%). Supports automated exception reporting in menu engineering workflows.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalCogsPct rdf:type rdf:Property ;
    rdfs:label 'Theoretical Cogs Pct' ;
    rdfs:comment 'Theoretical Cost of Goods Sold expressed as a percentage of the menu item\'s base selling price (theoretical_cost_amount / base_price). Key menu engineering metric used to classify items and set pricing strategy. Expressed as a decimal (e.g., 0.2850 = 28.50%).' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Theoretical Cost Amount' ;
    rdfs:comment 'The theoretical food cost amount in the operating currency for one unit of the menu item, derived by multiplying each Bill of Materials (BOM) ingredient quantity by its point-in-time purchase price. Core input to menu engineering and pricing decisions.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalCostVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Theoretical Cost Variance Amount' ;
    rdfs:comment 'Absolute monetary variance between actual cost and theoretical cost per unit (actual cost amount minus theoretical_cost_amount). Expressed in the operating currency. Used alongside cogs_pct_variance for financial impact quantification in P&L reporting.' ;
    rdfs:domain ind:ItemCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comboMealId rdf:type rdf:Property ;
    rdfs:label 'Combo Meal Id' ;
    rdfs:comment 'Unique surrogate identifier for the combo meal record. Primary key for the combo_meal data product in the menu domain.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComboMeal .

ind:bundleDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Bundle Discount Amount' ;
    rdfs:comment 'The monetary discount provided to the guest by purchasing the combo meal versus buying each component item individually (individual_items_price_sum minus bundle_price). Key metric for menu engineering and promotional value analysis.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundlePrice rdf:type rdf:Property ;
    rdfs:label 'Bundle Price' ;
    rdfs:comment 'The retail selling price of the combo meal as a bundle, charged to the guest at POS or digital ordering channels. This is the price the guest pays for the full combo, distinct from the sum of individual item prices.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorieRangeMax rdf:type rdf:Property ;
    rdfs:label 'Calorie Range Max' ;
    rdfs:comment 'Maximum calorie count for the combo meal when customizable components are at their highest-calorie configuration. Required for FDA menu labeling compliance when combos offer substitution options.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calorieRangeMin rdf:type rdf:Property ;
    rdfs:label 'Calorie Range Min' ;
    rdfs:comment 'Minimum calorie count for the combo meal when customizable components are at their lowest-calorie configuration. Required for FDA menu labeling compliance when combos offer substitution options.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comboCode rdf:type rdf:Property ;
    rdfs:label 'Combo Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the combo meal, used in Oracle MICROS POS, Olo Digital Ordering Platform, and 3PD integrations for menu lookup and order capture. Serves as the canonical cross-system reference code.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comboDescription rdf:type rdf:Property ;
    rdfs:label 'Combo Description' ;
    rdfs:comment 'Detailed description of the combo meal contents and value proposition, used for digital menu boards, Olo OLO platform, and 3PD (Third-Party Delivery) channel listings. Supports guest decision-making and marketing copy.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comboName rdf:type rdf:Property ;
    rdfs:label 'Combo Name' ;
    rdfs:comment 'Human-readable marketing name of the combo meal as displayed on menu boards, POS screens, and digital ordering channels (e.g., \'Classic Value Meal\', \'Family Pack\', \'Kids Meal\'). Used for guest-facing display and reporting.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comboStatus rdf:type rdf:Property ;
    rdfs:label 'Combo Status' ;
    rdfs:comment 'Current lifecycle status of the combo meal offering. Controls whether the combo is available for sale across channels. \'test\' indicates a market-test combo not yet in full rollout.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comboType rdf:type rdf:Property ;
    rdfs:label 'Combo Type' ;
    rdfs:comment 'Classification of the combo meal by bundle format. Drives menu engineering analysis, PMIX reporting, and promotional targeting. [ENUM-REF-CANDIDATE: value_meal|family_pack|kids_meal|party_pack|snack_combo|premium_combo — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualItemsPriceSum rdf:type rdf:Property ;
    rdfs:label 'Individual Items Price Sum' ;
    rdfs:comment 'The sum of the base prices of all individual component menu items if purchased separately. Used to calculate the bundle discount amount and communicate value to guests. Sourced from Oracle MICROS POS item pricing.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCost rdf:type rdf:Property ;
    rdfs:label 'Item Cost' ;
    rdfs:comment 'Total Cost of Goods Sold (COGS) for the combo meal, representing the combined food cost of all component items. Used to calculate COGS% and support P&L and menu engineering decisions. Sourced from MarketMan Inventory Management and SAP S/4HANA CO module.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCalories rdf:type rdf:Property ;
    rdfs:label 'Total Calories' ;
    rdfs:comment 'Total calorie count for the combo meal as configured with default component items. Required for FDA menu labeling compliance on menus with 20+ locations. Displayed on menu boards and digital ordering platforms.' ;
    rdfs:domain ind:ComboMeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:item86EventId rdf:type rdf:Property ;
    rdfs:label 'Item 86 Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each 86 event record — when a menu item is temporarily pulled from service at a restaurant. Primary key of this table.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to order.channel. Business justification: When an item is 86\'d, the specific channel affected (OLO, drive-thru, dine-in) must be recorded for channel suppression actions and impact reporting. channel_affected is a denormalized plain column; r' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:inspectionViolationId rdf:type rdf:Property ;
    rdfs:label 'Inspection Violation Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.inspection_violation. Business justification: When a health inspector orders removal of a menu item due to a violation, the 86 event must be traceable to the triggering inspection_violation for compliance documentation and corrective action track' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionViolation .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to realestate.maintenance_work_order. Business justification: Equipment failure causing item unavailability (86 event) must be correlated with the maintenance work order raised to resolve it. QSR operations teams use this link for root cause analysis, SLA compli' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceWorkOrder .

ind:primaryItemEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Equipment Asset Id' ;
    rdfs:comment 'Reference to the specific kitchen equipment unit that failed and caused the 86 event, when reason_code = \'equipment_failure\'. Supports Repairs and Maintenance (R&M) tracking and equipment reliability analysis.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentAsset .

ind:primaryItemReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Item Reported By Employee Id' ;
    rdfs:comment 'Reference to the employee (Back of House (BOH) or Front of House (FOH) staff member) who first reported or logged the 86 event. Links to workforce employee master.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryMenuItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Menu Item Id' ;
    rdfs:comment 'Reference to the menu item that was 86\'d (removed from service). Links to the menu.menu_item master record.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuItem .

ind:recallEventId rdf:type rdf:Property ;
    rdfs:label 'Recall Event Id' ;
    rdfs:comment 'Foreign key linking to supply.recall_event. Business justification: FDA/USDA recall traceability: when is_recall_related=true on an 86 event, regulators and operations teams require a direct link to the specific recall_event for compliance reporting, affected-location' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecallEvent .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Foreign key linking to workforce.shift. Business justification: Item 86 events occur during a specific shift. Linking to the active shift enables operational reporting on which shifts experience the most stockouts, supports labor-menu correlation analysis, and is ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:daypartAffected rdf:type rdf:Property ;
    rdfs:label 'Daypart Affected' ;
    rdfs:comment 'The daypart during which the 86 event was active or first occurred. Enables PMIX (Product Mix) and daypart-level impact analysis. Aligns with menu.daypart definitions.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from start_timestamp to end_timestamp. Populated upon resolution. Used for Speed of Service (SOS) impact analysis and operational KPI reporting.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the menu item was restored to service and the 86 event was closed. Null if the event is still open. Used to calculate total downtime duration.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalatedToTeam rdf:type rdf:Property ;
    rdfs:label 'Escalated To Team' ;
    rdfs:comment 'The internal team to which the 86 event was escalated, if applicable. Supports accountability tracking and cross-functional response coordination.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the 86 event was escalated to operations management, supply chain, or franchise support teams. Null if the event was resolved without escalation. Supports SLA and response time analysis.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedLostCovers rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Covers' ;
    rdfs:comment 'Estimated number of guest covers (transactions) that could not be fulfilled due to the 86 event during the affected period. Derived operationally at the restaurant level for guest experience impact reporting. Not a calculated KPI — captured as a manager estimate at time of resolution.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for the 86 event (e.g., 86-2024-07-15-A3F9K2). Used in operational communications, Zenput audit tasks, and guest experience escalations.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the 86 event. \'open\' = item currently unavailable; \'resolved\' = item restored to service; \'escalated\' = issue elevated to operations or supply chain team; \'cancelled\' = event logged in error.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Guest Notification Sent' ;
    rdfs:comment 'Indicates whether a guest-facing notification was sent (e.g., via OLO or 3PD platform) to inform customers that the item is temporarily unavailable. True = notification dispatched. Supports Customer Satisfaction (CSAT) and Net Promoter Score (NPS) impact tracking.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haccpCcpReference rdf:type rdf:Property ;
    rdfs:label 'Haccp Ccp Reference' ;
    rdfs:comment 'Reference code to the specific HACCP Critical Control Point (CCP) that was breached or triggered this 86 event, if applicable. Used for food safety audit trails and regulatory compliance reporting.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFoodSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Food Safety Related' ;
    rdfs:comment 'Indicates whether the 86 event was triggered by a food safety concern (e.g., HACCP Critical Control Point (CCP) failure, quality issue, or regulatory recall). True = food safety event requiring Zenput audit task and potential regulatory notification.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLtoItem rdf:type rdf:Property ;
    rdfs:label 'Is Lto Item' ;
    rdfs:comment 'Indicates whether the 86\'d item is a Limited Time Offer (LTO). True = LTO item. 86 events on LTO items carry heightened business impact due to marketing commitments and guest expectations, and may require immediate escalation.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecallRelated rdf:type rdf:Property ;
    rdfs:label 'Is Recall Related' ;
    rdfs:comment 'Indicates whether the 86 event was triggered by a formal supplier or regulatory product recall. True = item must not be served and recall protocol must be followed per FDA/USDA guidelines.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsAlertSent rdf:type rdf:Property ;
    rdfs:label 'Kds Alert Sent' ;
    rdfs:comment 'Indicates whether a Kitchen Display System (KDS) alert was sent to BOH staff notifying them of the 86 event. True = KDS alert dispatched. Supports BOH operational awareness and throughput management.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloSuppressed rdf:type rdf:Property ;
    rdfs:label 'Olo Suppressed' ;
    rdfs:comment 'Indicates whether the item was suppressed on the Olo Digital Ordering Platform during the 86 event. True = item hidden from online ordering menu. Prevents guest orders for unavailable items on digital channels.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posSuppressed rdf:type rdf:Property ;
    rdfs:label 'Pos Suppressed' ;
    rdfs:comment 'Indicates whether the item was actively suppressed (hidden/disabled) on the Oracle MICROS POS system during the 86 event. True = item removed from POS ordering screens. Ensures operational accuracy and prevents staff from ringing up unavailable items.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the menu item was removed from service. \'out_of_stock\' = inventory depleted; \'equipment_failure\' = kitchen equipment down; \'quality_issue\' = item failed quality/HACCP check; \'recall\' = supplier or regulatory recall; \'supplier_delay\' = ingredient not delivered; \'prep_time_exceeded\' = throughput constraint. [ENUM-REF-CANDIDATE: out_of_stock|equipment_failure|quality_issue|recall|supplier_delay|prep_time_exceeded — promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Free-text narrative providing additional context beyond the reason_code. For example, specifying which piece of equipment failed, which ingredient was out of stock, or the nature of the quality issue. Supports root cause analysis.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByRole rdf:type rdf:Property ;
    rdfs:label 'Reported By Role' ;
    rdfs:comment 'Job role of the employee who reported the 86 event (e.g., manager, Back of House (BOH) staff, Front of House (FOH) staff, shift lead, franchisee). Supports accountability and training gap analysis.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'The corrective action taken to resolve the 86 event and restore the item to service. \'restocked\' = inventory replenished; \'equipment_repaired\' = kitchen equipment fixed; \'item_substituted\' = alternative item offered; \'recalled_item_removed\' = item permanently pulled per recall; \'supplier_order_placed\' = emergency procurement initiated; \'no_action\' = event closed without resolution (e.g., end of daypart). [ENUM-REF-CANDIDATE: restocked|equipment_repaired|item_substituted|recalled_item_removed|supplier_order_placed|no_action — promote to reference product]' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the menu item was first removed from service (86\'d). This is the principal real-world event timestamp. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:zenputTaskCode rdf:type rdf:Property ;
    rdfs:label 'Zenput Task Code' ;
    rdfs:comment 'Reference to the Zenput food safety audit task or operational compliance task created in response to this 86 event. Enables traceability between the 86 event and the corrective action workflow in Zenput.' ;
    rdfs:domain ind:Item86Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestOrderId rdf:type rdf:Property ;
    rdfs:label 'Guest Order Id' ;
    rdfs:comment 'Unique surrogate identifier for each guest order record in the lakehouse Silver layer. Primary key for the guest_order data product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:couponId rdf:type rdf:Property ;
    rdfs:label 'Coupon Id' ;
    rdfs:comment 'Foreign key linking to marketing.coupon. Business justification: Needed for coupon redemption audit: linking an order to the coupon entity allows accurate discount accounting and fraud detection.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coupon .

ind:deliveryPlatformId rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform Id' ;
    rdfs:comment 'Foreign key linking to order.delivery_platform. Business justification: guest_order.delivery_provider is a denormalized STRING storing the third-party delivery platform name (e.g., \'DoorDash\', \'Uber Eats\'). Normalizing to delivery_platform_id FK referencing order.delivery' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryPlatform .

ind:digitalAccountId rdf:type rdf:Property ;
    rdfs:label 'Digital Account Id' ;
    rdfs:comment 'Foreign key linking to guest.digital_account. Business justification: Digital orders placed via app or web are associated with a specific digital account. Linking guest_order to digital_account enables digital channel analytics, app engagement reporting, and loyalty int' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalAccount .

ind:loyaltyMemberId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Needed for loyalty points accrual and member order history report linking each order to the member who placed it.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Identifier of the loyalty program associated with this order, if the guest is enrolled. Used to link loyalty point accrual and redemption events to the order transaction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:primaryGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Guest Profile Id' ;
    rdfs:comment 'Identifier of the guest (customer) who placed the order. Nullable for anonymous walk-in transactions where no loyalty or digital profile is associated. Serves as the PARTY_REFERENCE for this transaction header.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primaryGuestSegmentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Primary Guest Segment Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_guest_segment. Business justification: Supports segment-based sales analysis: orders are associated with the guest segment targeted by marketing campaigns for segmentation reporting.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:serverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Server Employee Id' ;
    rdfs:comment 'Identifier of the Front of House (FOH) server or cashier employee who took or managed the order. Used for labor performance tracking, tip allocation, and service quality analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancelledAt rdf:type rdf:Property ;
    rdfs:label 'Cancelled At' ;
    rdfs:comment 'Timestamp when the order was cancelled or voided. Null for orders that were fulfilled. Used for cancellation rate reporting and operational analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this guest_order record was first created in the lakehouse Silver layer. Serves as the RECORD_AUDIT_CREATED field for this transaction header. Distinct from placed_at which captures the business event time.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for delivery orders. Contains personally identifiable location information for the guest. Null for non-delivery order types.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the delivery address. Used for delivery zone analysis, geographic sales reporting, and logistics optimization. Contains guest location data classified as PII.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilledAt rdf:type rdf:Property ;
    rdfs:label 'Fulfilled At' ;
    rdfs:comment 'Timestamp when the order was handed to the guest or dispatched for delivery, marking the completion of the service transaction. Used for end-to-end Speed of Service (SOS) measurement.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isVoided rdf:type rdf:Property ;
    rdfs:label 'Is Voided' ;
    rdfs:comment 'Indicates whether the order was voided by a manager after tender. Voided orders are retained for audit and loss prevention purposes but excluded from revenue reporting. Distinct from cancelled orders (cancelled before preparation).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsRoutedAt rdf:type rdf:Property ;
    rdfs:label 'Kds Routed At' ;
    rdfs:comment 'Timestamp when the order was routed to the Kitchen Display System (KDS) for preparation. Used to calculate kitchen queue time and Back of House (BOH) throughput metrics.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of loyalty reward points earned by the guest for this order transaction. Used for loyalty program accrual tracking and guest engagement analytics.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of loyalty reward points redeemed by the guest as part of this order transaction. Used for loyalty liability accounting and promotional cost analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oloOrderRef rdf:type rdf:Property ;
    rdfs:label 'Olo Order Ref' ;
    rdfs:comment 'External order reference number assigned by the Olo Digital Ordering Platform for orders placed through digital channels (web, mobile app). Null for in-store POS orders.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the guest order. Tracks the order from placement through fulfillment or cancellation. \'placed\' = order received; \'in_preparation\' = KDS routing active; \'ready\' = food ready for pickup/delivery; \'fulfilled\' = order handed to guest; \'cancelled\' = cancelled before preparation; \'voided\' = voided post-tender by manager.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Fulfillment type of the order indicating how the guest intends to receive their food. Distinct from order_channel (which captures the ordering interface). Used for kitchen routing, packaging, and service time analytics.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partySize rdf:type rdf:Property ;
    rdfs:label 'Party Size' ;
    rdfs:comment 'Number of guests in the dining party associated with this order. Applicable for dine-in orders. Used for cover count reporting, table turn analysis, and per-cover revenue calculations.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction associated with this order. Distinct from order_status which tracks fulfillment lifecycle. Used for financial reconciliation and exception management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placedAt rdf:type rdf:Property ;
    rdfs:label 'Placed At' ;
    rdfs:comment 'The principal real-world event timestamp when the guest order was placed and confirmed in the POS or digital ordering system. Serves as the BUSINESS_EVENT_TIMESTAMP for this transaction header. Used for Speed of Service (SOS) calculations and daypart assignment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:posTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Ref' ;
    rdfs:comment 'Native transaction reference or check number generated by the Oracle MICROS POS system. Used for reconciliation between the lakehouse and the POS system of record.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyAt rdf:type rdf:Property ;
    rdfs:label 'Ready At' ;
    rdfs:comment 'Timestamp when the order was marked ready for pickup or delivery by kitchen staff. Used to calculate ticket time (time from order placement to food ready) and Speed of Service (SOS) metrics.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sosSeconds rdf:type rdf:Property ;
    rdfs:label 'Sos Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from order placement (placed_at) to order fulfillment (fulfilled_at). Represents the end-to-end guest experience time. A primary operational KPI for Quick-Service Restaurants (QSR) and Drive-Thru (DT) performance benchmarking.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field capturing guest-specific preparation instructions, allergy notes, or customization requests entered at the time of ordering. Used by kitchen staff for order fulfillment and food safety compliance (HACCP allergen awareness).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Gross pre-tax, pre-discount monetary value of all items in the order. Represents the base order value before adjustments. Part of the MONETARY_TRIPLET for this transaction header.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tableNumber rdf:type rdf:Property ;
    rdfs:label 'Table Number' ;
    rdfs:comment 'Table or seat identifier assigned to the dine-in order within the restaurant floor plan. Null for takeout, drive-thru, and delivery orders. Used for table turn analysis and Front of House (FOH) service management.' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax amount applied to the order based on applicable local, state, and federal tax rates. Part of the MONETARY_TRIPLET adjustment. Used for tax remittance reporting and financial reconciliation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderType rdf:type rdf:Property ;
    rdfs:label 'Tender Type' ;
    rdfs:comment 'Primary payment instrument used to settle the order. Supports payment mix analysis and PCI DSS compliance reporting. [ENUM-REF-CANDIDATE: cash|credit_card|debit_card|mobile_pay|gift_card|loyalty_points|voucher|comp — promote to reference product]' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Human-readable, externally visible order ticket number assigned by the Point of Sale (POS) system (Oracle MICROS). Printed on receipts and displayed on the Kitchen Display System (KDS). Serves as the BUSINESS_IDENTIFIER for this transaction. Format varies by restaurant configuration (e.g., sequential daily number).' ;
    rdfs:domain ind:GuestOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Ticket Time Seconds' ;
    rdfs:comment 'Elapsed time in seconds from order placement (placed_at) to order ready (ready_at). Represents the kitchen preparation time, a key Speed of Service (SOS) and throughput KPI in restaurant operations. Stored as a raw operational field captured by the POS/KDS system.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tipAmount rdf:type rdf:Property ;
    rdfs:label 'Tip Amount' ;
    rdfs:comment 'Gratuity amount added by the guest at the time of payment. Applicable for casual and fine-dining service models. Used for labor compensation reporting and financial reconciliation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final net monetary amount charged to the guest after applying discounts and adding taxes (subtotal_amount - discount_amount + tax_amount). Represents the Average Check Value (ACV) for this transaction. Net total component of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp when this guest_order record was last modified in the lakehouse Silver layer. Serves as the RECORD_AUDIT_UPDATED field for this transaction header. Used for incremental data processing and change data capture (CDC) pipelines.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason code for why the order was voided. Null for non-voided orders. Used for loss prevention, operational exception reporting, and manager accountability tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderItemId rdf:type rdf:Property ;
    rdfs:label 'Order Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each line item within a guest order. Primary key for the order_item entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderItem .

ind:departmentId rdf:type rdf:Property ;
    rdfs:label 'Department Id' ;
    rdfs:comment 'Foreign key linking to restaurant.department. Business justification: In full-service and casual-dining restaurants, line items are routed to specific departments (bar, kitchen, pastry) for KDS routing, departmental P&L reporting, and labor allocation. A foodservice dom' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:discountId rdf:type rdf:Property ;
    rdfs:label 'Discount Id' ;
    rdfs:comment 'Reference to the promotional discount, coupon, or loyalty reward applied to this line item. Null when no discount is applied. Links to the marketing domain for promotional effectiveness analysis.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Discount .

ind:prepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prep Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Labor costing & food-safety audit need to know which employee prepared each menu item; supports per-item labor allocation and accountability.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOrderComboComboMealId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Combo Combo Meal Id' ;
    rdfs:comment 'Reference to the combo meal or bundle to which this line item belongs. Null when is_combo_component is False. Groups combo components for bundle-level revenue and PMIX reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComboMeal .

ind:rewardId rdf:type rdf:Property ;
    rdfs:label 'Reward Id' ;
    rdfs:comment 'Foreign key linking to loyalty.reward. Business justification: Item-level reward attribution: when a loyalty reward (free item, BOGO) is applied to a specific line item, order_item must reference the reward for COGS attribution, reward redemption reporting, and m' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reward .

ind:allergenOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Override Flag' ;
    rdfs:comment 'Indicates whether a manager or authorized staff member overrode an allergen warning for this line item at the Point of Sale (POS). True triggers an audit trail for food safety compliance and liability management.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daypartCode rdf:type rdf:Property ;
    rdfs:label 'Daypart Code' ;
    rdfs:comment 'Operational daypart during which this line item was ordered (e.g., breakfast, lunch, dinner, late_night). Supports daypart-level PMIX analysis, labor scheduling alignment, and revenue management by time segment.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComboComponent rdf:type rdf:Property ;
    rdfs:label 'Is Combo Component' ;
    rdfs:comment 'Indicates whether this line item is a component of a combo meal or bundle (True) or a standalone item (False). Supports combo meal PMIX analysis and bundle pricing validation.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsBumpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kds Bump Timestamp' ;
    rdfs:comment 'Timestamp when the kitchen staff bumped (completed) this line item on the Kitchen Display System (KDS), indicating preparation is complete. Core metric for ticket time and kitchen throughput reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:kdsSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kds Sent Timestamp' ;
    rdfs:comment 'Timestamp when this line item was transmitted to the Kitchen Display System (KDS) station for preparation. Used to calculate ticket time and Speed of Service (SOS) from order placement to kitchen receipt.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total discount applied at the line-item level, including promotional discounts, coupon redemptions, loyalty rewards, and employee meal discounts. Supports promotional effectiveness and margin analysis.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Gross extended amount for this line item before discounts and taxes, calculated as quantity × (unit_price + modifier_price). Used as the basis for COGS% and revenue reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net revenue amount for this line item after all line-level discounts, before tax. Equals line_gross_amount minus line_discount_amount. Core metric for Average Check Value (ACV) and P&L reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifierPrice rdf:type rdf:Property ;
    rdfs:label 'Modifier Price' ;
    rdfs:comment 'Incremental price charged for the applied modifier (e.g., upsize surcharge, premium add-on). Zero or null when no modifier price applies. Contributes to line-level revenue and Average Check Value (ACV) analysis.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmixCategory rdf:type rdf:Property ;
    rdfs:label 'Pmix Category' ;
    rdfs:comment 'Menu engineering classification of this item within the Product Mix (PMIX) framework (e.g., Star, Plow Horse, Puzzle, Dog per the BCG matrix). Supports menu engineering decisions and item lifecycle management. [ENUM-REF-CANDIDATE: star|plow_horse|puzzle|dog — promote to reference product]' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparationInstructions rdf:type rdf:Property ;
    rdfs:label 'Preparation Instructions' ;
    rdfs:comment 'Free-text special preparation instructions entered by the guest or cashier for this line item (e.g., \'well done\', \'no salt\', \'extra crispy\'). Transmitted to the Kitchen Display System (KDS) for Back of House (BOH) execution.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Alphanumeric promotional or coupon code entered at the Point of Sale (POS) or Online Ordering (OLO) platform that triggered the line-level discount. Supports campaign attribution and redemption tracking.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether this line item has been refunded (True). Supports refund rate tracking, guest satisfaction (CSAT) analysis, and financial reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemItemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Item Ref' ;
    rdfs:comment 'Native item identifier from the originating Point of Sale (POS) or Online Ordering (OLO) system (e.g., Oracle MICROS detail line ID, Olo order item UUID). Supports data lineage, reconciliation, and cross-system traceability in the Silver Layer.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this line item is exempt from sales tax (True), such as for qualifying food items under state/local tax law or institutional catering orders. Supports tax compliance and remittance reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Selling price per single unit of the menu item at the time of order, before modifiers, discounts, or taxes. Reflects the menu price in effect during the transaction for historical accuracy.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Coded reason for voiding this line item (e.g., GUEST_CHANGE, PREP_ERROR, OUT_OF_STOCK, MANAGER_COMP). Null when item is not voided. Supports waste tracking and operational exception reporting. [ENUM-REF-CANDIDATE: GUEST_CHANGE|PREP_ERROR|OUT_OF_STOCK|MANAGER_COMP|ALLERGY|DUPLICATE — promote to reference product]' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Flag' ;
    rdfs:comment 'Indicates whether this line item was recorded as food waste (True) rather than served to a guest. Supports Food Waste Percentage (Waste%) tracking, inventory reconciliation, and sustainability reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waste Reason Code' ;
    rdfs:comment 'Coded reason for food waste on this line item when waste_flag is True. Supports root-cause analysis for Waste% reduction initiatives and HACCP compliance reporting.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderModifierId rdf:type rdf:Property ;
    rdfs:label 'Order Modifier Id' ;
    rdfs:comment 'Unique surrogate identifier for each order modifier record applied to an order line item. Primary key for the order_modifier data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applied By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Compliance audit requires recording which employee applied a modifier (e.g., discount, special request) to ensure authorization and traceability.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOrderMenuModifierId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Menu Modifier Id' ;
    rdfs:comment 'Reference to the menu modifier master record defining the base modifier configuration, pricing rules, and preparation instructions. Links to the menu domain modifier catalog.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuModifier .

ind:sourceModifierMenuModifierId rdf:type rdf:Property ;
    rdfs:label 'Source Modifier Menu Modifier Id' ;
    rdfs:comment 'The native modifier transaction identifier from the originating operational system (e.g., Oracle MICROS POS modifier line ID, Olo modifier ID). Enables exact record traceability and reconciliation between the Silver Layer and the system of record.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuModifier .

ind:allergenFlag rdf:type rdf:Property ;
    rdfs:label 'Allergen Flag' ;
    rdfs:comment 'Indicates whether this modifier introduces or removes an allergen from the order item (True). Triggers allergen advisory workflows and supports FDA food labeling compliance and HACCP allergen control point tracking.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenNotes rdf:type rdf:Property ;
    rdfs:label 'Allergen Notes' ;
    rdfs:comment 'Descriptive notes identifying the specific allergen(s) introduced or removed by this modifier (e.g., \'Contains: Tree Nuts\', \'Removes: Gluten\'). Supports FDA FALCPA compliance, HACCP Hazard Analysis Critical Control Points documentation, and guest safety communication.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'The date and time when this modifier was applied to the order item at the Point of Sale (POS) or digital ordering channel. Principal business event timestamp for Speed of Service (SOS) and Ticket Time analysis. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiationSource rdf:type rdf:Property ;
    rdfs:label 'Initiation Source' ;
    rdfs:comment 'Indicates whether the modifier was explicitly requested by the guest, automatically applied as a system default (e.g., standard condiment), suggested by crew, or triggered by a loyalty or promotional rule. Critical for distinguishing guest-driven customization from operational defaults in PMIX and CoGS% analysis.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComped rdf:type rdf:Property ;
    rdfs:label 'Is Comped' ;
    rdfs:comment 'Indicates whether the price delta for this modifier was comped (complimentary, zero-charged) as part of a guest recovery, promotional offer, or manager override. Supports comp tracking for P&L and guest satisfaction (CSAT) analysis.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kds Acknowledged Timestamp' ;
    rdfs:comment 'The date and time when the kitchen crew acknowledged this modifier on the Kitchen Display System (KDS). Used to calculate kitchen execution latency and Ticket Time for Speed of Service (SOS) reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:kdsRouted rdf:type rdf:Property ;
    rdfs:label 'Kds Routed' ;
    rdfs:comment 'Indicates whether this modifier was successfully routed to the Kitchen Display System (KDS) for preparation execution (True). Supports kitchen execution fidelity tracking and Speed of Service (SOS) analysis.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsStationName rdf:type rdf:Property ;
    rdfs:label 'Kds Station Name' ;
    rdfs:comment 'The name of the Back of House (BOH) kitchen station to which this modifier was routed on the Kitchen Display System (KDS) (e.g., \'Grill\', \'Fryer\', \'Assembly\', \'Beverage\'). Supports station-level throughput and execution fidelity analysis.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyRedemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Loyalty Redemption Flag' ;
    rdfs:comment 'Indicates whether this modifier was applied as part of a loyalty program redemption (True), such as a free add-on reward. Supports loyalty program ROI analysis and modifier-level redemption tracking.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltoFlag rdf:type rdf:Property ;
    rdfs:label 'Lto Flag' ;
    rdfs:comment 'Indicates whether this modifier is associated with a Limited Time Offer (LTO) promotion (True). Supports LTO performance tracking, promotional PMIX analysis, and campaign effectiveness measurement.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifierName rdf:type rdf:Property ;
    rdfs:label 'Modifier Name' ;
    rdfs:comment 'Human-readable name of the modifier as displayed on the Point of Sale (POS) screen, guest receipt, and Kitchen Display System (KDS) at the time the order was placed. Captured as a snapshot to preserve historical accuracy independent of menu changes.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifierStatus rdf:type rdf:Property ;
    rdfs:label 'Modifier Status' ;
    rdfs:comment 'Current lifecycle state of the modifier on the order item. \'applied\' indicates the modifier was successfully executed; \'voided\' indicates it was removed post-capture; \'pending\' indicates awaiting kitchen confirmation; \'rejected\' indicates the modifier could not be fulfilled.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oloModifierCode rdf:type rdf:Property ;
    rdfs:label 'Olo Modifier Code' ;
    rdfs:comment 'The modifier code assigned by the Olo Digital Ordering Platform for online and third-party delivery orders. Enables cross-channel modifier reconciliation between POS and digital ordering channels.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posModifierCode rdf:type rdf:Property ;
    rdfs:label 'Pos Modifier Code' ;
    rdfs:comment 'The native modifier code assigned by the Oracle MICROS POS system. Used for reconciliation between the Silver Layer lakehouse and the POS system of record, and for menu management synchronization.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this modifier within the set of modifiers applied to the parent order item. Used to preserve the display and preparation order on the Kitchen Display System (KDS) and printed receipts.' ;
    rdfs:domain ind:OrderModifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'The date and time when this modifier was voided, if applicable. Null if the modifier was not voided. Supports void rate analysis and kitchen error tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment tender record associated with a guest order. Serves as the primary key for the order_payment data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.bank_account. Business justification: Restaurant POS settlements are deposited to specific bank accounts per unit. Daily cash and card settlement batch processing requires knowing the target depository bank account for reconciliation and ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:cashierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cashier Employee Id' ;
    rdfs:comment 'Reference to the FOH (Front of House) employee who processed this payment transaction at the POS terminal. Used for cash accountability, tip reporting, and labor performance analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:memberId rdf:type rdf:Property ;
    rdfs:label 'Member Id' ;
    rdfs:comment 'Reference to the guest loyalty account from which points or rewards were redeemed as a payment tender. Applicable when tender_type is loyalty_redemption. Links to the loyalty domain for redemption tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Foreign key linking to guest.profile. Business justification: Required for payment reconciliation reports linking each payment to the guest profile; essential for fraud detection and loyalty crediting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:redemptionId rdf:type rdf:Property ;
    rdfs:label 'Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.redemption. Business justification: Loyalty tender payment reconciliation: when points or rewards are used as a payment tender, the payment record must reference the redemption for tender-type reporting, loyalty liability accounting, an' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Redemption .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'The identifier of the original payment transaction being refunded or reversed. Populated only when payment_status is refunded or voided. Enables linkage between the original charge and its corresponding credit for reconciliation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The net amount actually applied from this tender toward the order balance. In split-tender scenarios, this may be less than the tendered_amount. Represents the actual financial obligation satisfied by this tender line.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'The alphanumeric approval code returned by the payment processor or card network upon successful authorization of a card-based tender. Used for chargeback resolution, settlement reconciliation, and audit purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capturedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captured Timestamp' ;
    rdfs:comment 'The real-world date and time when the payment tender was captured at the Point of Sale (POS) or digital ordering channel. Principal business event timestamp for the payment record. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Card Entry Method' ;
    rdfs:comment 'The method by which card data was captured at the point of interaction. Impacts interchange rates, fraud liability, and PCI DSS compliance scope. Contactless includes NFC/tap-to-pay and mobile wallet transactions.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'The card network or brand associated with the payment card used for this tender (e.g., Visa, Mastercard, Amex). Used for interchange fee analysis and payment mix reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDueAmount rdf:type rdf:Property ;
    rdfs:label 'Change Due Amount' ;
    rdfs:comment 'The amount of change to be returned to the guest when the tendered_amount exceeds the applied_amount. Applicable primarily to cash tender transactions. Zero for card and digital payment types.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Gift Card Number Masked' ;
    rdfs:comment 'Masked identifier for the restaurant-issued gift card used in this tender transaction. Retains only partial digits for identification while protecting the full card value. Applicable when tender_type is gift_card.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Amount' ;
    rdfs:comment 'The fee charged by the card-issuing bank for processing this card payment, expressed in the transaction currency. A key component of payment processing cost analysis and COGS% (Cost of Goods Sold Percentage) calculations.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSplitTender rdf:type rdf:Property ;
    rdfs:label 'Is Split Tender' ;
    rdfs:comment 'Flag indicating whether this payment record is part of a split-tender transaction where multiple payment instruments were used to satisfy a single order. True when the order has more than one associated payment tender record.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Card Number' ;
    rdfs:comment 'PCI DSS-compliant masked representation of the payment card number, retaining only the first 4 and last 4 digits (e.g., 4111********1111). Full PANs (Primary Account Numbers) are never stored in the lakehouse per PCI DSS Requirement 3.3.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offlineAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Offline Authorization Flag' ;
    rdfs:comment 'Indicates whether this payment was authorized in offline mode due to network connectivity loss at the restaurant. Offline authorizations carry elevated fraud and chargeback risk and require special reconciliation handling.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Number' ;
    rdfs:comment 'The externally-known transaction number assigned by the Oracle MICROS POS system at the time of payment capture. Used for end-of-day reconciliation, chargeback research, and audit trails.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorName rdf:type rdf:Property ;
    rdfs:label 'Processor Name' ;
    rdfs:comment 'The name of the payment processing service provider that handled authorization and settlement for this tender (e.g., Worldpay, Heartland, Stripe, Square). Used for processor-level performance and fee analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Processor Reference Code' ;
    rdfs:comment 'The unique transaction identifier assigned by the external payment processor (e.g., Stripe, Worldpay, Heartland) for this tender. Used for cross-system reconciliation between POS and payment gateway records.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeApplied rdf:type rdf:Property ;
    rdfs:label 'Promo Code Applied' ;
    rdfs:comment 'The promotional or discount code entered by the guest at the time of payment, if applicable. Used to link payment records to marketing campaign performance and LTO (Limited Time Offer) redemption analytics.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Categorical reason code explaining why a refund or void was issued for this payment. Used for operational quality analysis, CSAT (Customer Satisfaction) root cause investigation, and fraud monitoring.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'The ISO 8583 or processor-specific response code returned by the payment network for this authorization attempt (e.g., 00 = Approved, 05 = Do Not Honor, 51 = Insufficient Funds). Used for decline analysis and payment success rate monitoring.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementBatchCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Code' ;
    rdfs:comment 'The batch identifier assigned by the payment processor during end-of-day settlement processing. Groups all captured transactions submitted together for bank funding. Used for daily cash reconciliation and SAP S/4HANA AR posting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the payment processor settled funds to the restaurant\'s bank account. Distinct from captured_timestamp. Used for cash flow forecasting, bank reconciliation, and financial close processes in SAP S/4HANA.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:splitTenderSequence rdf:type rdf:Property ;
    rdfs:label 'Split Tender Sequence' ;
    rdfs:comment 'Sequential line number identifying the order of tender application within a split-tender transaction. For example, a guest paying part cash and part credit card would have sequence 1 (cash) and sequence 2 (credit card). Enables correct reconstruction of multi-tender payment scenarios.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tenderedAmount rdf:type rdf:Property ;
    rdfs:label 'Tendered Amount' ;
    rdfs:comment 'The gross amount presented by the guest for this specific tender line. In cash scenarios, this may exceed the order total, resulting in change due. In card scenarios, this equals the charged amount. Core component of the MONETARY_TRIPLET for payment-level financial analysis.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thirdPartyDeliveryPartner rdf:type rdf:Property ;
    rdfs:label 'Third Party Delivery Partner' ;
    rdfs:comment 'Identifies the 3PD (Third-Party Delivery) aggregator platform responsible for payment settlement when tender_type is 3pd_settlement. Used for partner-level remittance reconciliation and commission tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyOrderReference rdf:type rdf:Property ;
    rdfs:label 'Third Party Order Reference' ;
    rdfs:comment 'The order identifier assigned by the 3PD (Third-Party Delivery) partner platform (e.g., DoorDash order ID, Uber Eats order ID). Used to cross-reference restaurant POS records with delivery partner settlement reports.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:token rdf:type rdf:Property ;
    rdfs:label 'Token' ;
    rdfs:comment 'A network-issued or processor-issued token that replaces the actual card PAN (Primary Account Number) for secure storage and recurring payment processing. Enables PCI DSS scope reduction through tokenization.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable order lifecycle state transition event record in the Silver layer. Primary key of this append-only event log.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the employee (FOH cashier, BOH cook, or manager) who manually triggered this state transition. Null when the transition was system- or device-initiated. Supports labor accountability and SOS coaching.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceEventStatusEventId rdf:type rdf:Property ;
    rdfs:label 'Source Event Status Event Id' ;
    rdfs:comment 'The native event or transaction identifier assigned by the originating source system (e.g., MICROS transaction ID, OLO event UUID, KDS bump ID). Enables exact-match deduplication and cross-system reconciliation during Silver layer ingestion.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusEvent .

ind:businessDate rdf:type rdf:Property ;
    rdfs:label 'Business Date' ;
    rdfs:comment 'The operational business date to which this event is attributed for financial and operational reporting purposes. May differ from event_date for late-night orders that cross midnight but belong to the prior business day\'s P&L period.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cumulativeElapsedSeconds rdf:type rdf:Property ;
    rdfs:label 'Cumulative Elapsed Seconds' ;
    rdfs:comment 'Total number of seconds elapsed from the initial \'received\' event to this event, representing the running ticket time for the order up to this point. Used to measure end-to-end Speed of Service (SOS) at any point in the lifecycle.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentState rdf:type rdf:Property ;
    rdfs:label 'Current State' ;
    rdfs:comment 'The order lifecycle state that this event transitions the order INTO. Drives Speed of Service (SOS) analytics, KDS routing, and fulfillment tracking. [ENUM-REF-CANDIDATE: received|acknowledged|in_preparation|ready|dispatched|delivered|cancelled|voided — promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Silver layer data quality classification for this event record. Values: valid (passed all checks), suspect (failed one or more quality rules), duplicate (identified as a duplicate of another event), late_arriving (received significantly after event_timestamp), corrected (overrides a prior suspect record).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryZone rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone' ;
    rdfs:comment 'Geographic delivery zone or radius tier assigned to this order for third-party delivery (3PD) or direct delivery fulfillment. Used for delivery time SOS benchmarking and zone-level fulfillment analytics.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLane rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lane' ;
    rdfs:comment 'Identifies the specific drive-thru (DT) lane associated with this order event for multi-lane drive-thru configurations. Null or \'none\' for non-drive-thru channels. Enables per-lane SOS and throughput analytics.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elapsedSecondsInPriorState rdf:type rdf:Property ;
    rdfs:label 'Elapsed Seconds In Prior State' ;
    rdfs:comment 'Number of seconds the order spent in the prior_state before transitioning to the current_state. Computed at ingestion time from consecutive event timestamps. Core input for Speed of Service (SOS) and ticket time analytics.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date (yyyy-MM-dd) on which this event occurred, derived from event_timestamp. Stored as a discrete DATE column to support efficient date-based partitioning, daily SOS reporting, and Same-Store Sales (SSS) period alignment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventSequence rdf:type rdf:Property ;
    rdfs:label 'Event Sequence' ;
    rdfs:comment 'Monotonically increasing integer representing the ordinal position of this event within the full lifecycle of a single order. Enables reconstruction of the complete state machine path (e.g., 1=received, 2=acknowledged, 3=in_preparation).' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) at which the order transitioned into the current state. The principal real-world event time used for Speed of Service (SOS) and ticket time calculations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Structured code indicating why an exceptional transition occurred (e.g., ITEM_OUT_OF_STOCK, GUEST_CANCEL, PAYMENT_FAILED, EQUIPMENT_DOWN, DUPLICATE_ORDER). Null for normal lifecycle transitions. Drives exception reporting and root-cause analytics. [ENUM-REF-CANDIDATE: promote to reference product for full code list]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Description' ;
    rdfs:comment 'Free-text narrative describing the exception or anomaly that caused this state transition, as entered by staff or returned by the triggering system. Supplements the structured exception_reason_code for operational context.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal reporting period (e.g., \'2024-P04-W02\') to which this event belongs, aligned to the company\'s internal fiscal calendar. Enables period-over-period SOS and throughput comparisons in financial reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentMode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Mode' ;
    rdfs:comment 'Indicates whether the order was placed for immediate fulfillment, scheduled for a future time (advance order), or ASAP (as-soon-as-possible with a requested window). Affects SOS target calculation and kitchen scheduling.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The date and time this event record was first written into the Silver layer of the Databricks Lakehouse. Distinct from event_timestamp (real-world event time). Used for data latency monitoring, pipeline SLA tracking, and audit trail.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCancellationEvent rdf:type rdf:Property ;
    rdfs:label 'Is Cancellation Event' ;
    rdfs:comment 'Flag indicating whether this event represents an order cancellation (current_state = \'cancelled\'). Enables rapid filtering for cancellation rate analytics, refund processing triggers, and guest recovery workflows.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSosBreach rdf:type rdf:Property ;
    rdfs:label 'Is Sos Breach' ;
    rdfs:comment 'Flag indicating whether the cumulative elapsed time at this event exceeded the configured SOS target for the channel and daypart. True = SOS breach detected. Drives SOS compliance dashboards and operational alerts.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTerminalState rdf:type rdf:Property ;
    rdfs:label 'Is Terminal State' ;
    rdfs:comment 'Flag indicating whether the current_state is a terminal (end-of-lifecycle) state for the order (i.e., delivered, cancelled, or voided). Simplifies filtering for completed order analytics without requiring state enumeration logic.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVoidEvent rdf:type rdf:Property ;
    rdfs:label 'Is Void Event' ;
    rdfs:comment 'Flag indicating whether this event represents an order void (current_state = \'voided\'). Voids differ from cancellations in that they are typically manager-initiated post-tender corrections. Supports POS audit and loss prevention reporting.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsStationCode rdf:type rdf:Property ;
    rdfs:label 'Kds Station Code' ;
    rdfs:comment 'Identifier of the KDS (Kitchen Display System) station that acknowledged or bumped this order event. Populated only when the triggering actor is KDS. Enables BOH (Back of House) station-level ticket time analysis.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerOverride rdf:type rdf:Property ;
    rdfs:label 'Manager Override' ;
    rdfs:comment 'Flag indicating whether this state transition required a manager authorization override (e.g., void, post-close cancellation, or exception state). Supports loss prevention, audit compliance, and operational accountability reporting.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloOrderReference rdf:type rdf:Property ;
    rdfs:label 'Olo Order Reference' ;
    rdfs:comment 'External order reference number assigned by the Olo Digital Ordering Platform for online and mobile orders. Populated only for OLO-originated events. Enables cross-system reconciliation between the lakehouse and the OLO platform.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partitionDate rdf:type rdf:Property ;
    rdfs:label 'Partition Date' ;
    rdfs:comment 'The date value used as the physical partition key for this table in the Databricks Lakehouse Delta Lake storage layer. Typically aligned to business_date to optimize time-range query performance for SOS and throughput analytics.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'The order lifecycle state immediately before this transition event. Null for the first event (initial placement). Enables detection of invalid state transitions and rollback analysis. [ENUM-REF-CANDIDATE: received|acknowledged|in_preparation|ready|dispatched|delivered|cancelled|voided — promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promiseTimeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Promise Time Timestamp' ;
    rdfs:comment 'The date and time communicated to the guest as the expected ready or delivery time at the moment of order placement. Used to measure promise-time accuracy and guest satisfaction (CSAT) correlation.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time this event record was last modified in the Silver layer (e.g., due to late-arriving corrections or enrichment). For a truly immutable event log this should rarely change; tracked for data quality auditing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledFulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Fulfillment Timestamp' ;
    rdfs:comment 'The date and time the guest requested or the system scheduled for order fulfillment. Populated only for scheduled/advance orders. Used to calculate on-time fulfillment rate and schedule adherence.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sosTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sos Target Seconds' ;
    rdfs:comment 'The configured Speed of Service (SOS) target in seconds for this service channel and daypart combination at the time of the event. Enables real-time and historical SOS compliance measurement against operational benchmarks.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyDeliveryProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Delivery Provider' ;
    rdfs:comment 'Name of the third-party delivery (3PD) aggregator that submitted the webhook triggering this event (e.g., doordash, uber_eats, grubhub). Null or \'none\' for non-3PD channels. Enables 3PD-specific SOS and fulfillment analytics.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyEventReference rdf:type rdf:Property ;
    rdfs:label 'Third Party Event Reference' ;
    rdfs:comment 'External event or webhook identifier provided by the third-party delivery (3PD) provider for this specific state transition. Used for cross-system reconciliation and dispute resolution with 3PD partners.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringActor rdf:type rdf:Property ;
    rdfs:label 'Triggering Actor' ;
    rdfs:comment 'The system or human actor that initiated this state transition. Values include POS (Oracle MICROS Point of Sale), KDS (Kitchen Display System), OLO (Online Ordering platform), 3PD (Third-Party Delivery webhook), CATERING, STAFF (manual override), SYSTEM (automated rule), or GUEST (self-service cancellation). [ENUM-REF-CANDIDATE: POS|KDS|OLO|3PD|CATERING|STAFF|SYSTEM|GUEST — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when this order channel was first activated and made available for order placement across the restaurant network.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averageTicketTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Ticket Time Seconds' ;
    rdfs:comment 'Benchmark average ticket time (order placement to fulfillment) in seconds for this channel, used for Speed of Service (SOS) performance tracking. Null if not applicable.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'High-level classification of the channel by service model: dine_in (FOH counter, table service), takeout (DT, counter pickup), delivery (3PD, own delivery), catering (bulk orders), hybrid (multi-mode channels like kiosk).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the order channel (e.g., POS, DT, OLO, 3PD, KIOSK, MOBILE, CATERING). Used as the business identifier for integration and reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the order channel, including its purpose, typical use cases, and any special operational considerations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Full descriptive name of the order channel (e.g., Point of Sale, Drive-Thru, Online Ordering, Third-Party Delivery, Kiosk, Mobile App, Catering).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Ownership classification of the channel: owned (company-operated channels like POS, DT, proprietary OLO), third_party (external platforms like 3PD aggregators), hybrid (co-branded or white-label solutions).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Commission or transaction fee percentage charged by the channel provider (applicable to 3PD channels). Null for owned channels. Used for COGS and P&L analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this order channel was deactivated or retired. Null if the channel is still active.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defaultDaypart rdf:type rdf:Property ;
    rdfs:label 'Default Daypart' ;
    rdfs:comment 'Default daypart (e.g., breakfast, lunch, dinner, late_night) typically associated with this channel. Null if the channel operates across all dayparts equally.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sort order for displaying this channel in reporting dashboards and user interfaces. Lower numbers appear first.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationPlatform rdf:type rdf:Property ;
    rdfs:label 'Integration Platform' ;
    rdfs:comment 'Name of the technology platform or system that powers this channel (e.g., Oracle MICROS, Olo, DoorDash, Uber Eats, Grubhub, proprietary mobile app). Null for native POS channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDigital rdf:type rdf:Property ;
    rdfs:label 'Is Digital' ;
    rdfs:comment 'Boolean flag indicating whether this is a digital channel (true for OLO, mobile app, kiosk, 3PD; false for traditional POS, DT counter service).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsRoutingEnabled rdf:type rdf:Property ;
    rdfs:label 'Kds Routing Enabled' ;
    rdfs:comment 'Boolean flag indicating whether orders from this channel are routed to the Kitchen Display System (KDS) for BOH preparation tracking. True for most channels; may be false for catering orders prepared off-site.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRestaurantAssignment rdf:type rdf:Property ;
    rdfs:label 'Requires Restaurant Assignment' ;
    rdfs:comment 'Boolean flag indicating whether orders from this channel must be assigned to a specific restaurant location at order time (true for delivery, catering; false for walk-in POS).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsGuestDataCapture rdf:type rdf:Property ;
    rdfs:label 'Supports Guest Data Capture' ;
    rdfs:comment 'Boolean flag indicating whether this channel captures guest identification and contact information (true for OLO, mobile, 3PD; false for anonymous POS transactions).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsLoyaltyIntegration rdf:type rdf:Property ;
    rdfs:label 'Supports Loyalty Integration' ;
    rdfs:comment 'Boolean flag indicating whether this channel supports integration with the customer loyalty program for points accrual and redemption.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPaymentAtOrder rdf:type rdf:Property ;
    rdfs:label 'Supports Payment At Order' ;
    rdfs:comment 'Boolean flag indicating whether payment is collected at the time of order placement (true for OLO, 3PD, mobile; false for traditional counter service where payment occurs at pickup).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsScheduledOrders rdf:type rdf:Property ;
    rdfs:label 'Supports Scheduled Orders' ;
    rdfs:comment 'Boolean flag indicating whether this channel allows customers to schedule orders for future fulfillment (true for catering, some OLO platforms; false for immediate-service channels like DT).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetSosSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Sos Seconds' ;
    rdfs:comment 'Target Speed of Service (SOS) threshold in seconds for this channel, representing the operational goal for order fulfillment time. Used for performance benchmarking and SOP compliance.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyProvider rdf:type rdf:Property ;
    rdfs:label 'Third Party Provider' ;
    rdfs:comment 'Name of the third-party delivery service provider if this channel is a 3PD channel (e.g., DoorDash, Uber Eats, Grubhub, Postmates). Null for non-3PD channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryOrderId rdf:type rdf:Property ;
    rdfs:label 'Delivery Order Id' ;
    rdfs:comment 'Unique identifier for the delivery order record. Primary key.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to realestate.facility. Business justification: Delivery orders are fulfilled from a specific facility (ghost kitchen, satellite prep station, or multi-facility site). Facility health inspection scores, operational status, and kitchen capacity dire' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken by the courier to deliver the order from pickup to guest, calculated from picked up timestamp to actual delivery timestamp.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Actual date and time when the order was delivered to the guest, as confirmed by the courier or delivery platform.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPrepTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Prep Time Minutes' ;
    rdfs:comment 'Actual time in minutes taken by the restaurant to prepare the order, calculated from order confirmation to ready for pickup.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerFeedback rdf:type rdf:Property ;
    rdfs:label 'Customer Feedback' ;
    rdfs:comment 'Free-text feedback provided by the guest about the delivery experience. Used for quality improvement and service recovery.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRating rdf:type rdf:Property ;
    rdfs:label 'Customer Rating' ;
    rdfs:comment 'Guest rating for the delivery experience on a scale of 1 to 5. Used for Net Promoter Score (NPS) and Customer Satisfaction (CSAT) tracking.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for apartment, suite, or unit number. Contains personally identifiable information (PII).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery destination. Contains personally identifiable information (PII).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery destination (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Delivery Distance Km' ;
    rdfs:comment 'Calculated distance in kilometers from the restaurant to the delivery destination. Used for delivery fee calculation and logistics analysis.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryExceptionType rdf:type rdf:Property ;
    rdfs:label 'Delivery Exception Type' ;
    rdfs:comment 'Type of exception or issue encountered during delivery fulfillment. Used for quality tracking and Customer Satisfaction (CSAT) analysis. [ENUM-REF-CANDIDATE: none|late_delivery|missing_items|wrong_address|customer_unavailable|order_damaged|cancelled_by_customer|cancelled_by_restaurant — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Delivery Fee Amount' ;
    rdfs:comment 'Delivery fee charged to the guest for the delivery service. Excludes taxes and tips.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special instructions provided by the guest for delivery (e.g., gate code, building entrance, leave at door). May contain personally identifiable information (PII).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLatitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the delivery destination. Used for routing optimization and distance calculation. Contains location PII.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLongitude rdf:type rdf:Property ;
    rdfs:label 'Delivery Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the delivery destination. Used for routing optimization and distance calculation. Contains location PII.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the delivery destination. Contains personally identifiable information (PII).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery order. Tracks progression from order placement through final delivery or cancellation. [ENUM-REF-CANDIDATE: pending|confirmed|preparing|ready_for_pickup|picked_up|in_transit|delivered|cancelled|failed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for the courier to deliver the order from pickup to guest, as provided by the delivery platform routing algorithm.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Timestamp' ;
    rdfs:comment 'Estimated date and time for delivery to the guest, as communicated by the delivery platform or internal routing system.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedPrepTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Prep Time Minutes' ;
    rdfs:comment 'Estimated time in minutes for the restaurant to prepare the order, as communicated to the delivery platform.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing the delivery exception or issue. Captured by courier, restaurant staff, or customer service.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContactlessDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Contactless Delivery' ;
    rdfs:comment 'Indicates whether the delivery was requested as contactless (leave at door). True if contactless, False otherwise.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the restaurant confirmed acceptance of the delivery order.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Date and time when the delivery order was placed by the guest via the online ordering (OLO) or third-party delivery (3PD) platform.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedUpTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Up Timestamp' ;
    rdfs:comment 'Date and time when the courier picked up the order from the restaurant location.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:platformCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Platform Commission Amount' ;
    rdfs:comment 'Total commission amount paid to the third-party delivery platform for this order. Business-confidential financial information.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Platform Commission Rate' ;
    rdfs:comment 'Commission rate (as a decimal) charged by the third-party delivery platform on the order subtotal. Business-confidential pricing information.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformOrderReference rdf:type rdf:Property ;
    rdfs:label 'Platform Order Reference' ;
    rdfs:comment 'External order identifier provided by the third-party delivery platform. Used for reconciliation and support inquiries with 3PD providers.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Url' ;
    rdfs:comment 'URL to the proof of delivery image or document (e.g., photo of order at doorstep). Used for dispute resolution.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyForPickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ready For Pickup Timestamp' ;
    rdfs:comment 'Date and time when the order was marked as ready for courier pickup in the Kitchen Display System (KDS) or Point of Sale (POS).' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalTicketTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Ticket Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from order placement to actual delivery. Key Speed of Service (SOS) metric for delivery orders.' ;
    rdfs:domain ind:DeliveryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringOrderId rdf:type rdf:Property ;
    rdfs:label 'Catering Order Id' ;
    rdfs:comment 'Unique identifier for the catering order. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CateringOrder .

ind:cateringGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Catering Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Catering revenue is posted to a distinct GL account (catering/banquet revenue) separate from regular food sales for P&L segmentation. Role-prefix \'catering_\' used because catering revenue GL differs f' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:primaryCateringGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Catering Guest Profile Id' ;
    rdfs:comment 'Identifier of the guest or corporate account placing the catering order.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:salesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sales Rep Employee Id' ;
    rdfs:comment 'Identifier of the sales representative or catering coordinator who managed this order.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:balanceDue rdf:type rdf:Property ;
    rdfs:label 'Balance Due' ;
    rdfs:comment 'Remaining balance due after deposit, to be paid before or at event delivery.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason provided for catering order cancellation, if applicable.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cateringOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Catering Order Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the catering order, used for guest communication and tracking.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedAt rdf:type rdf:Property ;
    rdfs:label 'Confirmed At' ;
    rdfs:comment 'Timestamp when the catering order was confirmed by restaurant staff or system.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for order confirmation and updates.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person for the catering event.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person for day-of-event coordination.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Deposit amount paid at time of order confirmation to secure the catering reservation.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dietaryAccommodations rdf:type rdf:Property ;
    rdfs:label 'Dietary Accommodations' ;
    rdfs:comment 'Special dietary requirements or accommodations requested for the catering event (e.g., vegetarian, gluten-free, allergen restrictions).' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'Scheduled start time for the catering event, used for delivery or pickup timing.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gratuityAmount rdf:type rdf:Property ;
    rdfs:label 'Gratuity Amount' ;
    rdfs:comment 'Gratuity or service charge amount included in the catering order total.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcount rdf:type rdf:Property ;
    rdfs:label 'Headcount' ;
    rdfs:comment 'Expected number of guests to be served at the catering event.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days in advance the catering order was placed before the event date.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Payment instrument used for the catering order transaction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Price' ;
    rdfs:comment 'Total price quoted to the guest for the catering order, including all items and services.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupInstructions rdf:type rdf:Property ;
    rdfs:label 'Setup Instructions' ;
    rdfs:comment 'Detailed instructions for on-site setup, including table arrangement, buffet layout, and service requirements.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setupRequired rdf:type rdf:Property ;
    rdfs:label 'Setup Required' ;
    rdfs:comment 'Indicates whether on-site setup service is required for the catering order.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorization Employee Id' ;
    rdfs:comment 'Reference to the employee who authorized or applied the discount, particularly for manager comps and exception-based discounts.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:offerId rdf:type rdf:Property ;
    rdfs:label 'Offer Id' ;
    rdfs:comment 'Foreign key linking to loyalty.offer. Business justification: Offer-driven discount traceability: when a loyalty offer generates a discount, the discount record must reference the offer for offer ROI reporting, discount liability reconciliation, and marketing sp' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Absolute monetary value of the discount applied, in the transaction currency. Used for Cost of Goods Sold (COGS) impact analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAt rdf:type rdf:Property ;
    rdfs:label 'Applied At' ;
    rdfs:comment 'The date and time when the discount was applied to the order or item at the Point of Sale (POS).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Authorization Required' ;
    rdfs:comment 'Indicates whether manager or supervisor authorization was required to apply this discount.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cogs Impact Amount' ;
    rdfs:comment 'The calculated impact of this discount on Cost of Goods Sold (COGS) for financial and profitability analysis.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daypartRestriction rdf:type rdf:Property ;
    rdfs:label 'Daypart Restriction' ;
    rdfs:comment 'Specifies the daypart(s) during which this discount is valid (e.g., breakfast, lunch, dinner, late_night). Null if no restriction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountName rdf:type rdf:Property ;
    rdfs:label 'Discount Name' ;
    rdfs:comment 'Human-readable name or description of the discount as displayed on the receipt and Kitchen Display System (KDS).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountScope rdf:type rdf:Property ;
    rdfs:label 'Discount Scope' ;
    rdfs:comment 'Defines the scope at which the discount is applied: entire order, individual item, menu category, or combo meal.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Classification of the discount mechanism applied to the order or item.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPrice rdf:type rdf:Property ;
    rdfs:label 'Final Price' ;
    rdfs:comment 'The final price after the discount was applied to the item or order.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPreApproved rdf:type rdf:Property ;
    rdfs:label 'Is Pre Approved' ;
    rdfs:comment 'Indicates whether the discount was pre-approved through a promotional campaign (true) or applied as an exception at the Point of Sale (false).' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this discount can be combined with other discounts on the same order or item.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'The maximum allowable discount amount for this promotion or discount type, as configured in the promotion rules.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Min Purchase Amount' ;
    rdfs:comment 'The minimum order subtotal required to qualify for this discount.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'The original price of the item or order subtotal before the discount was applied.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Percentage discount applied to the item or order subtotal. Null if discount is a fixed amount.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Free-text explanation or reason code for the discount, particularly for manager comps and exception-based adjustments.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The calculated impact of this discount on gross revenue for Profit and Loss (P&L) reporting and Same-Store Sales (SSS) analysis.' ;
    rdfs:domain ind:Discount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'Indicates whether the discount is applied before tax calculation, after tax calculation, or results in a tax-exempt transaction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The start date from which this discount or promotion is valid and can be applied.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The end date after which this discount or promotion is no longer valid.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voidedAt rdf:type rdf:Property ;
    rdfs:label 'Voided At' ;
    rdfs:comment 'The date and time when the discount was voided or removed from the order. Null if discount was not voided.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:illnessReportId rdf:type rdf:Property ;
    rdfs:label 'Illness Report Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.illness_report. Business justification: Refunds issued as compensation for foodborne illness complaints must be linked to the illness report for financial impact analysis of food safety incidents. Finance and QA teams use this link to quant' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IllnessReport .

ind:refundEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Refund Employee Id' ;
    rdfs:comment 'Identifier of the manager or supervisor who approved and authorized the refund transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:refundGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Refund Guest Profile Id' ;
    rdfs:comment 'Identifier of the guest who received the refund, if known and captured in the Customer Relationship Management (CRM) system.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:refundProcessingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Employee Id' ;
    rdfs:comment 'Identifier of the Front of House (FOH) employee who processed the refund transaction at the Point of Sale (POS).' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:refundProfileId rdf:type rdf:Property ;
    rdfs:label 'Refund Profile Id' ;
    rdfs:comment 'Identifier of the guest who received the refund, if known and captured in the Customer Relationship Management (CRM) system.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:refundVoidedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Refund Voided By Employee Id' ;
    rdfs:comment 'Identifier of the employee who voided or reversed the refund transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedAt rdf:type rdf:Property ;
    rdfs:label 'Approved At' ;
    rdfs:comment 'Date and time when the refund was approved by the authorizing manager.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchCode rdf:type rdf:Property ;
    rdfs:label 'Batch Code' ;
    rdfs:comment 'Identifier for the financial batch in which this refund was grouped for accounting reconciliation and settlement.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Csat Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this refund is associated with a Customer Satisfaction (CSAT) incident requiring follow-up or root-cause analysis.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Notes' ;
    rdfs:comment 'Internal notes from fraud review or investigation related to this refund transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date on which the refund transaction was posted to the General Ledger (GL) for financial reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guestContactMethod rdf:type rdf:Property ;
    rdfs:label 'Guest Contact Method' ;
    rdfs:comment 'Method by which the guest communicated the refund request or complaint to the restaurant.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudulent rdf:type rdf:Property ;
    rdfs:label 'Is Fraudulent' ;
    rdfs:comment 'Boolean flag indicating whether this refund was flagged as potentially fraudulent during review or audit.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsRefunded rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Refunded' ;
    rdfs:comment 'Number of loyalty program points returned to the guest as part of the refund, if applicable.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveySent rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Sent' ;
    rdfs:comment 'Boolean flag indicating whether a Net Promoter Score (NPS) survey was sent to the guest following the refund.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'Service channel through which the original order was placed, retained for refund analysis by channel.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Original Payment Method' ;
    rdfs:comment 'Payment method used in the original order transaction, retained for reconciliation and audit purposes.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessorRef rdf:type rdf:Property ;
    rdfs:label 'Payment Processor Ref' ;
    rdfs:comment 'External reference number from the payment processor for the refund transaction, used for reconciliation with payment gateway.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text detailed explanation of the refund reason provided by the manager or customer service representative.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund value was returned to the guest, indicating the tender type used for reimbursement.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Business-facing unique refund transaction number displayed on receipts and used for customer service tracking.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction indicating processing state.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification indicating whether the refund covers the entire order or only specific items.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundedAt rdf:type rdf:Property ;
    rdfs:label 'Refunded At' ;
    rdfs:comment 'Date and time when the refund transaction was completed and funds were returned to the guest.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedAt rdf:type rdf:Property ;
    rdfs:label 'Requested At' ;
    rdfs:comment 'Date and time when the refund was initially requested by the guest or identified by staff.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtotal rdf:type rdf:Property ;
    rdfs:label 'Subtotal' ;
    rdfs:comment 'Pre-tax amount of the refund, representing the base value of items or services refunded.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax line record applied to a guest order. Primary key for the order_tax data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjusted Timestamp' ;
    rdfs:comment 'The date and time (yyyy-MM-ddTHH:mm:ss.SSSXXX) when a post-transaction tax adjustment was applied to this line. Populated only when tax_status = \'adjusted\'. Supports audit trail for tax corrections.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'The reason code for a post-transaction tax adjustment when tax_status = \'adjusted\' (e.g., rate_correction, jurisdiction_change, exemption_applied, refund, audit_correction, other). Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityCode rdf:type rdf:Property ;
    rdfs:label 'Authority Code' ;
    rdfs:comment 'Standardized code identifying the tax authority or jurisdiction as defined by the tax engine or ERP (SAP S/4HANA Tax Condition). Used for automated tax remittance and reconciliation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'The governmental jurisdiction level that imposes this tax line. Supports multi-jurisdiction tax compliance across all restaurant locations. Values: federal, state, county, city, district, special.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'The full name of the tax authority or jurisdiction imposing this tax (e.g., \'California State Board of Equalization\', \'Cook County Revenue Department\', \'City of Chicago\'). Used for regulatory reporting and remittance.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The SAP S/4HANA cost center code associated with the restaurant location for this tax line. Used for internal cost allocation, P&L reporting by location, and management accounting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineSource rdf:type rdf:Property ;
    rdfs:label 'Engine Source' ;
    rdfs:comment 'Identifies the system or engine that calculated and applied this tax line (e.g., pos = Oracle MICROS POS built-in tax, vertex = Vertex O Series, avalara = Avalara AvaTax, sap_tax = SAP S/4HANA tax engine, manual = manually entered). Used for reconciliation and audit.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCertificateRef rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Ref' ;
    rdfs:comment 'Reference number or identifier of the tax exemption certificate presented by the guest or organization. Required for audit documentation when is_exempt is True. Null when no exemption applies.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'The reason code for a tax exemption when is_exempt is True (e.g., government, non_profit, resale, diplomatic, employee_meal, other). Required for audit trail and regulatory compliance. Null when is_exempt is False.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExempt rdf:type rdf:Property ;
    rdfs:label 'Is Exempt' ;
    rdfs:comment 'Indicates whether this tax line was flagged as exempt (True) due to a guest exemption certificate, government order, or qualifying non-profit status. When True, tax_amount should be zero and exemption_reason should be populated.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefunded rdf:type rdf:Property ;
    rdfs:label 'Is Refunded' ;
    rdfs:comment 'Indicates whether the tax amount on this line has been refunded to the guest (True) as part of an order refund or cancellation. Used for refund reconciliation and tax reversal tracking.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxInclusive rdf:type rdf:Property ;
    rdfs:label 'Is Tax Inclusive' ;
    rdfs:comment 'Indicates whether this tax was already included in the menu price (True) or added at checkout on top of the menu price (False). Critical for VAT/GST jurisdictions and for accurate revenue recognition and tax remittance calculations.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Original Tax Amount' ;
    rdfs:comment 'The tax amount as originally computed at the time of order placement, before any post-transaction adjustments. Populated when tax_status = \'adjusted\' to preserve the audit trail of the original calculation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodDate rdf:type rdf:Property ;
    rdfs:label 'Period Date' ;
    rdfs:comment 'The business date (yyyy-MM-dd) to which this tax line is attributed for tax remittance and financial period reporting. May differ from the transaction timestamp for end-of-day batch processing or period adjustments.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:posTaxLineRef rdf:type rdf:Property ;
    rdfs:label 'Pos Tax Line Ref' ;
    rdfs:comment 'The native tax line identifier or sequence number assigned by Oracle MICROS POS for this tax entry. Used for cross-system reconciliation between the POS transaction log and the lakehouse Silver Layer.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'The applicable tax rate expressed as a decimal fraction (e.g., 0.0875 for 8.75%). Sourced from the tax engine or POS tax configuration at the time of the transaction. Used for tax amount validation and audit.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittancePeriod rdf:type rdf:Property ;
    rdfs:label 'Remittance Period' ;
    rdfs:comment 'The fiscal period (e.g., \'2024-Q1\', \'2024-03\') in which this tax amount is scheduled for remittance to the tax authority. Used for tax filing calendar management and period-end close.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Indicates whether this tax amount has been remitted to the applicable tax authority (pending = not yet remitted, remitted = successfully paid to authority, not_applicable = exempt or zero-rate, failed = remittance attempt failed). Supports tax compliance tracking.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapTaxDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Sap Tax Document Ref' ;
    rdfs:comment 'The SAP S/4HANA FI-TX tax document number associated with this tax line for GL posting and tax remittance. Enables end-to-end traceability from POS transaction to ERP financial posting.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state code (or equivalent provincial code) of the tax jurisdiction where the restaurant is located (e.g., \'IL\', \'CA\', \'TX\'). Used for state-level tax rate lookup, remittance routing, and regulatory reporting.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The internal or POS-assigned tax code identifying the specific tax rule applied (e.g., \'TX_CA_SALES\', \'TX_CHI_BEV\'). Maps to the tax condition record in SAP S/4HANA and Oracle MICROS POS tax configuration.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxName rdf:type rdf:Property ;
    rdfs:label 'Tax Name' ;
    rdfs:comment 'Human-readable name of the tax as displayed on the guest receipt or financial report (e.g., \'Illinois Sales Tax\', \'Chicago Beverage Tax\', \'CA Bag Fee\'). Required for receipt compliance and guest transparency.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current lifecycle status of this tax line record. \'applied\' = tax successfully computed and applied; \'voided\' = tax line cancelled due to order void; \'adjusted\' = tax amount corrected post-transaction; \'pending\' = awaiting tax engine resolution; \'reversed\' = tax reversed for refund.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'The category of tax applied to this line (e.g., sales_tax, vat, beverage_tax, bag_fee, excise_tax, service_tax). Supports differentiated tax reporting and compliance across jurisdictions. [ENUM-REF-CANDIDATE: sales_tax|vat|beverage_tax|bag_fee|excise_tax|service_tax|surcharge|environmental_fee — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The portion of the order subtotal that is subject to this specific tax line, expressed in the transaction currency. Excludes non-taxable items, exempt amounts, and tax-inclusive components. Used for tax calculation validation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaManagementId rdf:type rdf:Property ;
    rdfs:label 'Area Management Id' ;
    rdfs:comment 'Foreign key linking to restaurant.area_management. Business justification: Every restaurant unit belongs to an area/district management hierarchy — this is a fundamental operational relationship in foodservice. The area_management product defines the geographic and operation' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AreaManagement .

ind:brandStandardId rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Id' ;
    rdfs:comment 'Foreign key linking to restaurant.brand_standard. Business justification: Units must be linked to the applicable brand standard for compliance tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandStandard .

ind:landlordId rdf:type rdf:Property ;
    rdfs:label 'Landlord Id' ;
    rdfs:comment 'Foreign key linking to realestate.landlord. Business justification: Landlord-to-Unit link supports landlord contact management, rent negotiations, and compliance audits; each unit has a responsible landlord.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Landlord .

ind:leaseId rdf:type rdf:Property ;
    rdfs:label 'Lease Id' ;
    rdfs:comment 'Foreign key linking to realestate.lease. Business justification: Lease-to-Unit association needed for lease-expiry alerts, rent schedule generation, and financial reporting; each unit operates under a specific lease.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lease .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Required for consolidated financial statements and tax compliance; each restaurant unit must be mapped to its legal entity for reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryDistributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Primary Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_center. Business justification: DC-to-unit routing assignment: supply chain operations require knowing each unit\'s primary distribution center for inbound shipment routing, emergency replenishment planning, and freight cost allocati' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the restaurant unit including street number and name.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information such as suite number, building name, or floor.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCoverCount rdf:type rdf:Property ;
    rdfs:label 'Average Cover Count' ;
    rdfs:comment 'Average number of guests (covers) served per day. Used for labor planning and revenue forecasting in table-service restaurants.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageUnitVolumeUsd rdf:type rdf:Property ;
    rdfs:label 'Average Unit Volume Usd' ;
    rdfs:comment 'Average annual sales revenue for this unit in US dollars. Key performance metric for franchise valuation and benchmarking.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the restaurant unit is located.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date this restaurant unit permanently ceased operations. Null for active units.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conceptType rdf:type rdf:Property ;
    rdfs:label 'Concept Type' ;
    rdfs:comment 'The restaurant format classification. QSR (Quick-Service Restaurant) for fast food, casual dining for table service, fast casual for counter service with higher quality, fine dining for upscale full service, food court for mall locations, ghost kitchen for delivery-only.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartSchedule rdf:type rdf:Property ;
    rdfs:label 'Daypart Schedule' ;
    rdfs:comment 'Structured schedule defining daypart time windows (breakfast, lunch, dinner, late night) for menu and pricing management.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLanes rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lanes' ;
    rdfs:comment 'Number of drive-thru lanes available at this unit. Zero indicates no drive-thru capability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the restaurant unit used for operational communications.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether this unit maintains current HACCP certification for food safety management.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasOnlineOrdering rdf:type rdf:Property ;
    rdfs:label 'Has Online Ordering' ;
    rdfs:comment 'Indicates whether this unit supports online ordering through web or mobile app channels.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasThirdPartyDelivery rdf:type rdf:Property ;
    rdfs:label 'Has Third Party Delivery' ;
    rdfs:comment 'Indicates whether this unit is enabled for third-party delivery services such as DoorDash, Uber Eats, or Grubhub.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthInspectionScore rdf:type rdf:Property ;
    rdfs:label 'Health Inspection Score' ;
    rdfs:comment 'Most recent health inspection score from local health department. Scale and passing thresholds vary by jurisdiction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kdsStationCount rdf:type rdf:Property ;
    rdfs:label 'Kds Station Count' ;
    rdfs:comment 'Number of KDS stations installed in the BOH for order routing and kitchen workflow management.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent health and safety inspection by local regulatory authority.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the restaurant unit in decimal degrees.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the restaurant unit in decimal degrees.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date this restaurant unit first opened for business to customers.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the unit, typically formatted as day ranges with time windows (e.g., Mon-Fri 6:00-22:00, Sat-Sun 7:00-23:00).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the restaurant unit. Active indicates normal operations, temporarily closed for renovations or seasonal closure, permanently closed for shut down units, under construction for new builds, pending opening for units awaiting launch.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpaces rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces' ;
    rdfs:comment 'Number of dedicated parking spaces available for guest use at this location.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the restaurant unit.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Pos System Version' ;
    rdfs:comment 'Version identifier of the POS system software deployed at this unit.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the restaurant unit location.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameStoreSalesPct rdf:type rdf:Property ;
    rdfs:label 'Same Store Sales Pct' ;
    rdfs:comment 'Year-over-year comparable store sales growth percentage. Measures organic growth for units open at least 12 months.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum number of guest seats available in the FOH (Front of House) dining area.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:speedOfServiceSeconds rdf:type rdf:Property ;
    rdfs:label 'Speed Of Service Seconds' ;
    rdfs:comment 'Average time in seconds from order placement to order delivery. Critical QSR operational metric for customer satisfaction.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total interior floor space of the restaurant unit in square feet, including FOH and BOH (Back of House) areas.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'Two-letter state or province code where the restaurant unit is located.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableTurnRate rdf:type rdf:Property ;
    rdfs:label 'Table Turn Rate' ;
    rdfs:comment 'Average number of times a table is occupied by different parties during a service period. Relevant for casual and fine-dining concepts.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of customer orders this unit can process per hour at peak efficiency, based on equipment and staffing design.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The customer-facing name of the restaurant unit as displayed on signage and marketing materials.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Business identifier for the restaurant unit. Externally-known unique code used across operational systems and franchise communications.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationProfileId rdf:type rdf:Property ;
    rdfs:label 'Location Profile Id' ;
    rdfs:comment 'Unique identifier for the restaurant location profile. Primary key for this entity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LocationProfile .

ind:primaryLocationRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Location Restaurant Unit Id' ;
    rdfs:comment 'Reference to the master restaurant unit record. Links this location profile to the operational restaurant entity.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the restaurant location including street number and name. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, unit, or building number. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Building Ownership Type' ;
    rdfs:comment 'Type of ownership or lease arrangement for the restaurant building. Impacts financial reporting and CapEx decisions.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Delivery Radius Km' ;
    rdfs:comment 'Maximum delivery radius in kilometers for online ordering and third-party delivery services. Configured per location based on geography and capacity.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the media market. Used for marketing campaign planning and regional media analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLaneCount rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lane Count' ;
    rdfs:comment 'Number of drive-thru lanes at the restaurant. Critical for throughput capacity planning and speed of service benchmarking.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the restaurant location if applicable. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAccessibleParking rdf:type rdf:Property ;
    rdfs:label 'Has Accessible Parking' ;
    rdfs:comment 'Indicates whether the restaurant has ADA-compliant accessible parking spaces. Required for regulatory compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDriveThru rdf:type rdf:Property ;
    rdfs:label 'Has Drive Thru' ;
    rdfs:comment 'Indicates whether the restaurant has drive-thru service capability. Key differentiator for QSR format and operational model.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPatioSeating rdf:type rdf:Property ;
    rdfs:label 'Has Patio Seating' ;
    rdfs:comment 'Indicates whether the restaurant has outdoor patio seating available. Impacts cover count and seasonal capacity.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPlayground rdf:type rdf:Property ;
    rdfs:label 'Has Playground' ;
    rdfs:comment 'Indicates whether the restaurant has a children\'s playground. Differentiator for family-oriented locations.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasRestroom rdf:type rdf:Property ;
    rdfs:label 'Has Restroom' ;
    rdfs:comment 'Indicates whether the restaurant has customer restroom facilities. Impacts guest experience and local health code compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasWheelchairAccess rdf:type rdf:Property ;
    rdfs:label 'Has Wheelchair Access' ;
    rdfs:comment 'Indicates whether the restaurant has wheelchair-accessible entrances and facilities. Required for ADA compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasWifi rdf:type rdf:Property ;
    rdfs:label 'Has Wifi' ;
    rdfs:comment 'Indicates whether the restaurant offers guest WiFi service. Enhances guest experience and supports digital ordering.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRemodelDate rdf:type rdf:Property ;
    rdfs:label 'Last Remodel Date' ;
    rdfs:comment 'Date of the most recent major remodel or renovation. Used for CapEx tracking and brand standard compliance.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this location profile record was last modified. Audit trail for data lineage and change tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'Locale identifier for language and regional formatting preferences. Used for menu display, signage, and customer communications.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Lot Size Sqft' ;
    rdfs:comment 'Total lot size in square feet including building, parking, and landscaping. Used for site selection and property management.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Total number of parking spaces available at or near the restaurant location. Influences site selection and accessibility.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patioSeatCount rdf:type rdf:Property ;
    rdfs:label 'Patio Seat Count' ;
    rdfs:comment 'Number of seats available on the outdoor patio. Used for capacity planning and table turn analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proximityToAirportKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Airport Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest airport. Influences traveler traffic and site classification.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proximityToHighwayKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Highway Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest major highway. Used for site selection and trade area analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proximityToMallKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Mall Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest shopping mall. Impacts foot traffic and co-location strategy.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restaurantNumber rdf:type rdf:Property ;
    rdfs:label 'Restaurant Number' ;
    rdfs:comment 'Business identifier for the restaurant unit. Externally-known code used in operations, reporting, and franchise communications.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteClosedDate rdf:type rdf:Property ;
    rdfs:label 'Site Closed Date' ;
    rdfs:comment 'Date when the restaurant location permanently closed. Used for portfolio analysis and historical reporting.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Site Opened Date' ;
    rdfs:comment 'Date when the restaurant location first opened for business. Used for NRO tracking, maturity analysis, and comp sales calculations.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational status of the restaurant site. Used for reporting, site portfolio management, and NRO tracking.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the restaurant location. Used for daypart scheduling, operating hours, and time-based reporting.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Trade Area Classification' ;
    rdfs:comment 'Classification of the trade area type where the restaurant is located. Influences site selection, menu offerings, and operational strategies. [ENUM-REF-CANDIDATE: urban|suburban|rural|highway|airport|mall|downtown|neighborhood — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatConfigId rdf:type rdf:Property ;
    rdfs:label 'Format Config Id' ;
    rdfs:comment 'Unique identifier for the restaurant format configuration record. Primary key.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFormatRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Format Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit to which this format configuration applies.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:alcoholServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Service Flag' ;
    rdfs:comment 'Indicates whether the restaurant format is licensed and configured to serve alcoholic beverages.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bohCookingLineCount rdf:type rdf:Property ;
    rdfs:label 'Boh Cooking Line Count' ;
    rdfs:comment 'Number of cooking lines or production stations in the Back of House (BOH) kitchen.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bohKitchenSqFt rdf:type rdf:Property ;
    rdfs:label 'Boh Kitchen Sq Ft' ;
    rdfs:comment 'Total square footage of the Back of House (BOH) kitchen and food preparation area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bohPrepStationCount rdf:type rdf:Property ;
    rdfs:label 'Boh Prep Station Count' ;
    rdfs:comment 'Number of food preparation stations in the Back of House (BOH) kitchen.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandStandardComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Compliance Status' ;
    rdfs:comment 'Current compliance status of the format configuration against brand standards and Standard Operating Procedures (SOPs).' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakfastDaypartFlag rdf:type rdf:Property ;
    rdfs:label 'Breakfast Daypart Flag' ;
    rdfs:comment 'Indicates whether the restaurant format operates during the breakfast daypart and serves breakfast menu items.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version identifier for this format configuration, used to track changes and updates over time.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverCountCapacityPerDaypart rdf:type rdf:Property ;
    rdfs:label 'Cover Count Capacity Per Daypart' ;
    rdfs:comment 'Maximum number of covers (individual meals served) the restaurant can accommodate during a single daypart (breakfast, lunch, dinner) based on seating and throughput.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curbsidePickupEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Enabled Flag' ;
    rdfs:comment 'Indicates whether the restaurant format supports curbside pickup service for online orders.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diningFormatType rdf:type rdf:Property ;
    rdfs:label 'Dining Format Type' ;
    rdfs:comment 'The primary dining format classification of the restaurant unit: Quick-Service Restaurant (QSR), fast-casual, casual dining, or fine-dining.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLaneConfig rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lane Config' ;
    rdfs:comment 'Drive-Thru (DT) lane configuration: none (no drive-thru), single lane, dual lane, or triple lane.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruWindowCount rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Window Count' ;
    rdfs:comment 'Number of Drive-Thru (DT) service windows available for order pickup.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohBarSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Foh Bar Seating Count' ;
    rdfs:comment 'Number of bar seats available in the Front of House (FOH) area, if applicable.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohOutdoorSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Foh Outdoor Seating Count' ;
    rdfs:comment 'Number of outdoor patio or sidewalk seats available in the Front of House (FOH) area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Foh Seating Capacity' ;
    rdfs:comment 'Total number of guest seats available in the Front of House (FOH) dining area, including indoor and outdoor seating.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohTableCount rdf:type rdf:Property ;
    rdfs:label 'Foh Table Count' ;
    rdfs:comment 'Total number of dining tables in the Front of House (FOH) area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Human-readable name or label for this format configuration (e.g., \'Standard QSR with DT\', \'Urban Fast-Casual\').' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kdsScreenCount rdf:type rdf:Property ;
    rdfs:label 'Kds Screen Count' ;
    rdfs:comment 'Number of Kitchen Display System (KDS) screens installed in the Back of House (BOH) for order routing and production management.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kioskCount rdf:type rdf:Property ;
    rdfs:label 'Kiosk Count' ;
    rdfs:comment 'Number of self-service digital ordering kiosks installed in the restaurant.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateNightDaypartFlag rdf:type rdf:Property ;
    rdfs:label 'Late Night Daypart Flag' ;
    rdfs:comment 'Indicates whether the restaurant format operates during late-night hours (typically after 10 PM).' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Olo Enabled Flag' ;
    rdfs:comment 'Indicates whether the restaurant format supports Online Ordering (OLO) through web or mobile app channels.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingSpaceCount rdf:type rdf:Property ;
    rdfs:label 'Parking Space Count' ;
    rdfs:comment 'Number of parking spaces available for guest use at the restaurant location.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCount rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count' ;
    rdfs:comment 'Number of Point of Sale (POS) terminals installed for order capture and payment processing.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceModel rdf:type rdf:Property ;
    rdfs:label 'Service Model' ;
    rdfs:comment 'Primary service delivery model: counter service, table service, drive-thru, self-service kiosk, or hybrid combination.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sosBenchmarkSeconds rdf:type rdf:Property ;
    rdfs:label 'Sos Benchmark Seconds' ;
    rdfs:comment 'Target Speed of Service (SOS) benchmark in seconds from order placement to order delivery, based on format and service model.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tableTurnTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Table Turn Target Minutes' ;
    rdfs:comment 'Target table turn time in minutes for table-service formats, representing the average time from guest seating to table availability.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyDeliveryEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Delivery Enabled Flag' ;
    rdfs:comment 'Indicates whether the restaurant format supports Third-Party Delivery (3PD) integration with external delivery platforms.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throughputCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Per Hour' ;
    rdfs:comment 'Maximum number of customer transactions the restaurant can process per hour under optimal conditions, based on format configuration.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twentyFourHourOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Operation Flag' ;
    rdfs:comment 'Indicates whether the restaurant operates 24 hours per day, 7 days per week.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHoursId rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Id' ;
    rdfs:comment 'Unique identifier for the operating hours record. Primary key.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOperatingApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Operating Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this operating hours schedule. Used for audit trail and compliance tracking.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOperatingRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Operating Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit to which these operating hours apply. Links to the restaurant master record.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:closeTime rdf:type rdf:Property ;
    rdfs:label 'Close Time' ;
    rdfs:comment 'The time the restaurant closes for the specified day and daypart, in 24-hour HH:mm format (e.g., 22:00). May extend past midnight for late-night operations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'The day of the week for which these operating hours are defined. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowCloseTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Close Time' ;
    rdfs:comment 'The time the restaurant stops accepting delivery orders (Online Ordering (OLO) and Third-Party Delivery (3PD)), in 24-hour HH:mm format. May differ from dine-in hours.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowOpenTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Open Time' ;
    rdfs:comment 'The time the restaurant begins accepting delivery orders (Online Ordering (OLO) and Third-Party Delivery (3PD)), in 24-hour HH:mm format. May differ from dine-in hours.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driveThruCloseTime rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Close Time' ;
    rdfs:comment 'The time the Drive-Thru (DT) lane closes, in 24-hour HH:mm format. May differ from Front of House (FOH) close time for QSR (Quick-Service Restaurant) units.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driveThruOpenTime rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Open Time' ;
    rdfs:comment 'The time the Drive-Thru (DT) lane opens, in 24-hour HH:mm format. May differ from Front of House (FOH) open time for QSR (Quick-Service Restaurant) units.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCoverCount rdf:type rdf:Property ;
    rdfs:label 'Expected Cover Count' ;
    rdfs:comment 'The expected number of covers (individual diners served) during this daypart for casual and fine-dining establishments. Used for labor scheduling and inventory planning.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedTableTurnCount rdf:type rdf:Property ;
    rdfs:label 'Expected Table Turn Count' ;
    rdfs:comment 'The expected number of table turns (times a table is occupied and vacated) during this daypart for casual and fine-dining establishments. Used for capacity planning and revenue forecasting.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'The name of the holiday for which this schedule override applies (e.g., Christmas, Thanksgiving, New Year\'s Day). Null if not a holiday override.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayScheduleOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Schedule Override Flag' ;
    rdfs:comment 'Indicates whether these operating hours represent a holiday schedule override. True if this is a holiday exception, False for regular schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is24HourOperation rdf:type rdf:Property ;
    rdfs:label 'Is 24 Hour Operation' ;
    rdfs:comment 'Indicates whether the restaurant operates 24 hours a day for the specified day. True if open continuously, False otherwise.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Indicates whether the restaurant is closed for the specified day and daypart. True if closed, False if open.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOrderCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Last Order Cutoff Time' ;
    rdfs:comment 'The time by which the last order must be placed before the restaurant stops accepting new orders, in 24-hour HH:mm format. Used for Online Ordering (OLO) and Third-Party Delivery (3PD) routing.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openTime rdf:type rdf:Property ;
    rdfs:label 'Open Time' ;
    rdfs:comment 'The time the restaurant opens for the specified day and daypart, in 24-hour HH:mm format (e.g., 06:00).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'The current lifecycle status of this operating hours record. Active schedules are in effect; pending schedules are future-dated; expired schedules are past their end date; suspended schedules are temporarily disabled.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'The type of operating hours schedule. Regular for standard weekly hours, holiday for holiday overrides, seasonal for seasonal adjustments, temporary for one-time changes, special_event for event-driven hours.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether these operating hours represent a seasonal adjustment (e.g., extended summer hours, reduced winter hours). True if seasonal, False for standard schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalPeriodName rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period Name' ;
    rdfs:comment 'The name of the seasonal period for which this schedule adjustment applies (e.g., Summer, Winter, Back-to-School). Null if not a seasonal adjustment.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEventName rdf:type rdf:Property ;
    rdfs:label 'Special Event Name' ;
    rdfs:comment 'The name of the special event for which these operating hours apply (e.g., Super Bowl Sunday, Local Festival, Grand Opening). Null if not a special event schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSpeedOfServiceSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Speed Of Service Seconds' ;
    rdfs:comment 'The target Speed of Service (SOS) in seconds for this daypart. Represents the benchmark time from order placement to order fulfillment. Used for operational performance tracking.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTicketTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Ticket Time Seconds' ;
    rdfs:comment 'The target ticket time in seconds for this daypart. Represents the benchmark time from order entry to Kitchen Display System (KDS) completion. Used for Back of House (BOH) performance tracking.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Id' ;
    rdfs:comment 'Unique identifier for the equipment asset record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentAsset .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Asset depreciation and financial reporting require each physical equipment asset to be tied to a fixed-asset record in finance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:primaryEquipmentRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where this equipment asset is installed.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:acquisitionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Usd' ;
    rdfs:comment 'Original purchase price paid for the equipment asset in US dollars, used for CapEx (Capital Expenditure) tracking and depreciation calculations.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetConditionRating rdf:type rdf:Property ;
    rdfs:label 'Asset Condition Rating' ;
    rdfs:comment 'Current physical and operational condition assessment of the equipment asset based on inspection and performance criteria.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Externally visible unique asset tag or barcode identifier affixed to the equipment for tracking and inventory purposes.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Expiry Date' ;
    rdfs:comment 'Date when the current compliance certification expires and recertification or inspection is required.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Number' ;
    rdfs:comment 'Certification or approval number from regulatory bodies (FDA, NSF, UL, OSHA) confirming the equipment meets safety and sanitation standards.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to allocate the cost of the equipment asset over its useful life for financial reporting and tax purposes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the equipment asset was decommissioned and removed from the restaurant, marking the end of its operational lifecycle.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the equipment was disposed of at end of life, supporting asset lifecycle tracking and environmental compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyRating rdf:type rdf:Property ;
    rdfs:label 'Energy Rating' ;
    rdfs:comment 'Energy efficiency rating or certification (e.g., Energy Star rating) indicating the equipment\'s power consumption performance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level classification grouping equipment by operational domain (cooking, refrigeration, POS systems, etc.). [ENUM-REF-CANDIDATE: cooking|refrigeration|food_prep|beverage|pos_system|kitchen_display|sanitation|hvac — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or designation of the equipment asset (e.g., Fryer Station 1, POS Terminal 3, Walk-in Cooler).' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of equipment asset distinguishing its primary function within BOH (Back of House) or FOH (Front of House) operations. [ENUM-REF-CANDIDATE: fryer|grill|oven|refrigeration_unit|freezer|ice_machine|pos_terminal|kds_display|espresso_machine|beverage_dispenser|dishwasher|ventilation_hood|warming_cabinet|prep_table — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the equipment asset was installed and commissioned at the restaurant location.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Most recent date when preventive maintenance or repair service was performed on this equipment asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTemperatureCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Temperature Check Timestamp' ;
    rdfs:comment 'Most recent date and time when temperature was verified for temperature-critical equipment, supporting food safety audit trails.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the lease or rental agreement for this equipment expires, requiring renewal or return of the asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Physical zone within the restaurant where the equipment is installed: BOH (Back of House), FOH (Front of House), Drive-Thru, Storage, or Outdoor.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Number of days between scheduled preventive maintenance services as defined by manufacturer guidelines or internal SOPs.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the company that manufactured the equipment asset.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer-assigned model number or designation for the equipment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Planned date for the next preventive maintenance service visit based on manufacturer recommendations and SOP (Standard Operating Procedure) schedules.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Rated electrical power consumption of the equipment in watts under normal operating conditions, used for energy cost forecasting.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementCostUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Usd' ;
    rdfs:comment 'Estimated current market cost to replace this equipment asset with a comparable new unit, used for R&M (Repairs and Maintenance) budgeting and insurance valuation.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the manufacturer to this specific equipment unit for warranty and service tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Reference number of the active service or maintenance contract covering this equipment asset, if applicable.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Critical Flag' ;
    rdfs:comment 'Indicates whether this equipment maintains temperature-sensitive food products and requires continuous monitoring for HACCP (Hazard Analysis Critical Control Points) compliance.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Max F' ;
    rdfs:comment 'Maximum safe operating temperature threshold in Fahrenheit for temperature-critical equipment, above which food safety is compromised.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Min F' ;
    rdfs:comment 'Minimum safe operating temperature threshold in Fahrenheit for temperature-critical equipment, below which food safety is compromised.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected operational lifespan of the equipment asset in years, used for depreciation calculations and replacement planning.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage ends, after which repairs and parts are at the restaurant\'s expense.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage begins for this equipment asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Owner Department Id' ;
    rdfs:comment 'Foreign key linking to restaurant.department. Business justification: brand_standard carries an owner_department STRING column representing the department responsible for maintaining the standard (e.g., Operations, Food Safety, Marketing). The department product exists ' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:supersededByStandardBrandStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Standard Brand Standard Id' ;
    rdfs:comment 'Reference to the brand_standard_id of the newer standard that replaces this one. Null if this standard is current and has not been superseded.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandStandard .

ind:applicableFormat rdf:type rdf:Property ;
    rdfs:label 'Applicable Format' ;
    rdfs:comment 'Restaurant format(s) to which this brand standard applies. QSR (Quick-Service Restaurant) for fast food, casual for casual dining, fine_dining for upscale establishments, or combinations/all formats. [ENUM-REF-CANDIDATE: all|qsr|casual|fine_dining|qsr_casual|qsr_fine_dining|casual_fine_dining — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Applicable Ownership Model' ;
    rdfs:comment 'Ownership model(s) to which this standard applies: company-owned units, franchised units, or all units regardless of ownership.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Expected frequency at which compliance with this standard should be audited or inspected (e.g., daily temperature logs, monthly cleanliness audits, annual safety inspections). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Status' ;
    rdfs:comment 'Current lifecycle status of the brand standard. Active standards are in force. Inactive standards are no longer enforced. Draft standards are under development. Under_review standards are being revised. Superseded standards have been replaced by a newer version.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the external organization or authority that issues the required certification (e.g., National Restaurant Association ServSafe, OSHA, Local Health Department). Null if no certification is required.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether staff must obtain a formal certification to perform tasks related to this standard (e.g., ServSafe Food Handler certification for food safety standards). True if certification is mandatory, False otherwise.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Level' ;
    rdfs:comment 'Enforcement level of the standard. Mandatory standards must be met for operational compliance and are subject to audit consequences. Recommended standards are best practices encouraged but not enforced. Aspirational standards represent future-state goals.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which this brand standard is no longer active or enforceable. Null indicates an open-ended standard with no planned expiration.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingBodyReference rdf:type rdf:Property ;
    rdfs:label 'Governing Body Reference' ;
    rdfs:comment 'External regulatory or industry body that mandates or influences this standard (e.g., FDA, USDA, OSHA, NRA ServSafe, Local Health Department, ISO 22000). Null if the standard is purely internal.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Facing Flag' ;
    rdfs:comment 'Indicates whether this standard directly impacts the guest experience and is visible or perceptible to customers (e.g., FOH cleanliness, service speed, food presentation). True if guest-facing, False if back-of-house or internal only.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which this brand standard was last reviewed for accuracy, relevance, and compliance with current regulations. Used to track review cycles and ensure standards remain current.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method by which compliance with this standard is assessed: direct observation (visual inspection), checklist (structured audit form), measurement (thermometer, timer), testing (lab analysis, swab test), documentation review (log verification), or guest feedback (CSAT, NPS).' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this brand standard. Ensures periodic reassessment to maintain relevance and regulatory alignment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceConsequence rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Consequence' ;
    rdfs:comment 'Consequence or remediation action triggered when a unit fails to meet this standard. Ranges from warnings and corrective action plans to financial penalties, operational suspension, or franchise termination for critical violations.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority level of the standard. Critical standards directly impact guest safety or regulatory compliance. High standards affect brand reputation or operational efficiency. Medium and low standards are important but less urgent.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sop Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the detailed SOP document that operationalizes this brand standard. May be a document management system ID, SharePoint link, or file path.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'High-level classification of the brand standard into operational domains: food quality (taste, temperature, freshness), food safety (HACCP compliance, contamination prevention), cleanliness (sanitation, hygiene), service excellence (guest interaction, speed of service), brand presentation (signage, uniforms, decor), workplace safety (OSHA compliance, injury prevention), or equipment maintenance (preventive maintenance, calibration). [ENUM-REF-CANDIDATE: food_quality|food_safety|cleanliness|service_excellence|brand_presentation|workplace_safety|equipment_maintenance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Unique business identifier code for the brand standard, typically following a category-number pattern (e.g., FS-001 for Food Safety standard 001, CL-042 for Cleanliness standard 042).' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDescription rdf:type rdf:Property ;
    rdfs:label 'Standard Description' ;
    rdfs:comment 'Detailed narrative description of the brand standard, including the specific requirement, rationale, and expected outcome. May reference specific procedures, thresholds, or quality criteria.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Full descriptive name of the brand standard (e.g., \'Proper Handwashing Protocol\', \'Drive-Thru Speed of Service Target\', \'Uniform and Appearance Guidelines\').' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Target Metric Unit' ;
    rdfs:comment 'Unit of measure for the target metric value (e.g., degrees Fahrenheit, seconds, percentage, count). Null if the standard does not have a quantitative metric.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Specific quantitative or qualitative target that defines compliance with this standard (e.g., \'Food temperature >= 165°F\', \'Speed of Service <= 90 seconds\', \'Cleanliness score >= 95%\', \'Zero critical violations\'). Null if the standard is qualitative without a numeric threshold.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModuleReference rdf:type rdf:Property ;
    rdfs:label 'Training Module Reference' ;
    rdfs:comment 'Reference identifier to the training module or course that covers this brand standard. May be an LMS (Learning Management System) course ID or training document reference. Null if no formal training module exists.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether formal training is required for staff to understand and comply with this standard. True if training is mandatory, False otherwise.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Unit Performance Id' ;
    rdfs:comment 'Unique identifier for the unit performance record. Primary key for this periodic operational and financial performance snapshot.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnitPerformance .

ind:primaryRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit for which this performance record is captured. Links to the restaurant master record.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:acvAmount rdf:type rdf:Property ;
    rdfs:label 'Acv Amount' ;
    rdfs:comment 'Average Check Value (ACV) - average revenue per customer transaction during the performance period. Calculated as total revenue divided by transaction count.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adtCount rdf:type rdf:Property ;
    rdfs:label 'Adt Count' ;
    rdfs:comment 'Average Daily Transactions (ADT) - average number of customer transactions processed per day during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcCount rdf:type rdf:Property ;
    rdfs:label 'Atc Count' ;
    rdfs:comment 'Average Transaction Count (ATC) - total number of customer transactions during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aucAmount rdf:type rdf:Property ;
    rdfs:label 'Auc Amount' ;
    rdfs:comment 'Average Unit Volume (AUV) - total revenue generated by the restaurant unit during the performance period. Key metric for unit-level revenue performance.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPercent rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent' ;
    rdfs:comment 'Cost of Goods Sold (COGS) Percentage - COGS as a percentage of total revenue. Key metric for food cost management.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Amount' ;
    rdfs:comment 'Comparable Store Sales (Comp Sales) - revenue for the current period for units that were operational in both the current and prior comparison period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Variance Amount' ;
    rdfs:comment 'Variance in Comparable Store Sales between current period and prior period, expressed as an absolute amount.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) - key profitability metric for unit-level P&L management.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Gross revenue before any deductions (discounts, promotions, refunds, voids) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost including wages, benefits, and payroll taxes for the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPercent rdf:type rdf:Property ;
    rdfs:label 'Labor Percent' ;
    rdfs:comment 'Labor Cost Percentage - total labor cost as a percentage of total revenue. Key metric for workforce efficiency.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Marketing and promotional expenses allocated to this unit during the performance period, including local store marketing and national campaign contributions.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Income Amount' ;
    rdfs:comment 'Net income (profit after all expenses, taxes, interest, depreciation, and amortization) for the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after deducting discounts, promotions, refunds, and voids during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Operating Income Amount' ;
    rdfs:comment 'Operating income (revenue minus operating expenses) for the performance period. Excludes interest, taxes, depreciation, and amortization.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Status of the performance record indicating whether the data is draft, preliminary, final, revised, or archived.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this performance record was first created in the system.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rentExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Rent Expense Amount' ;
    rdfs:comment 'Rent or lease expense for the restaurant facility during the performance period. Includes base rent and Common Area Maintenance (CAM) charges for leased locations.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Rm Expense Amount' ;
    rdfs:comment 'Repairs and Maintenance (R&M) expense for equipment, facilities, and infrastructure during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sssGrowthPercent rdf:type rdf:Property ;
    rdfs:label 'Sss Growth Percent' ;
    rdfs:comment 'Same-Store Sales (SSS) growth percentage comparing current period revenue to the same period in the prior year for units open at least 12 months. Excludes new restaurant openings.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses Amount' ;
    rdfs:comment 'Total operating expenses including COGS, labor, utilities, rent, repairs and maintenance, and other operational costs.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilityExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Utility Expense Amount' ;
    rdfs:comment 'Total utility expenses (electricity, gas, water, waste disposal) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteAmount rdf:type rdf:Property ;
    rdfs:label 'Waste Amount' ;
    rdfs:comment 'Total cost of food waste (spoilage, preparation errors, expired inventory) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastePercent rdf:type rdf:Property ;
    rdfs:label 'Waste Percent' ;
    rdfs:comment 'Food Waste Percentage - waste cost as a percentage of total COGS. Key metric for inventory and quality management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityConfigId rdf:type rdf:Property ;
    rdfs:label 'Capacity Config Id' ;
    rdfs:comment 'Unique identifier for the capacity configuration record. Primary key.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCapacityRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Capacity Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit to which this capacity configuration applies.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:adaCompliantSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Seating Count' ;
    rdfs:comment 'Number of seating positions that meet ADA accessibility requirements for guests with disabilities.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgPartySize rdf:type rdf:Property ;
    rdfs:label 'Avg Party Size' ;
    rdfs:comment 'Average number of guests per dining party used for capacity planning and labor forecasting.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Bar Seating Count' ;
    rdfs:comment 'Number of seats available at the bar or counter service area.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Config Effective Date' ;
    rdfs:comment 'The date from which this capacity configuration becomes effective for the restaurant unit.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configEndDate rdf:type rdf:Property ;
    rdfs:label 'Config End Date' ;
    rdfs:comment 'The date on which this capacity configuration ceases to be effective. Null indicates the configuration is currently active.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Free-text notes documenting special considerations, constraints, or context for this capacity configuration.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the capacity configuration record.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterServicePositions rdf:type rdf:Property ;
    rdfs:label 'Counter Service Positions' ;
    rdfs:comment 'Number of staffed counter service positions available for order taking and guest interaction.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curbsidePickupSpaces rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Spaces' ;
    rdfs:comment 'Number of designated parking spaces available for curbside pickup and online ordering (OLO) fulfillment.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStagingCapacity rdf:type rdf:Property ;
    rdfs:label 'Delivery Staging Capacity' ;
    rdfs:comment 'Number of completed delivery orders that can be staged simultaneously in the designated pickup area for third-party delivery (3PD) drivers.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruSosTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Sos Target Seconds' ;
    rdfs:comment 'Target time in seconds for drive-thru order fulfillment from order point to pickup window.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruStackingCapacity rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Stacking Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can queue in the drive-thru lane before reaching the order point.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireCodeOccupancyLimit rdf:type rdf:Property ;
    rdfs:label 'Fire Code Occupancy Limit' ;
    rdfs:comment 'Maximum number of occupants (guests and staff) permitted in the facility as determined by local fire safety regulations.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthPermitCapacity rdf:type rdf:Property ;
    rdfs:label 'Health Permit Capacity' ;
    rdfs:comment 'Maximum seating capacity approved by the local health department on the restaurant operating permit.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indoorSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Indoor Seating Capacity' ;
    rdfs:comment 'Total number of indoor seats available for guest dining in the Front of House (FOH) area.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitchenProductionCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Kitchen Production Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of orders the Back of House (BOH) kitchen can produce per hour at full operational capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborStaffingRatio rdf:type rdf:Property ;
    rdfs:label 'Labor Staffing Ratio' ;
    rdfs:comment 'Target ratio of Full-Time Equivalent (FTE) staff to seating capacity or covers, used for workforce scheduling and labor cost planning.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCoverCountBreakfast rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Breakfast' ;
    rdfs:comment 'Maximum number of guest covers (individual diners) that can be served during the breakfast daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountDinner rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Dinner' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the dinner daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountLateNight rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Late Night' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the late night daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountLunch rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Lunch' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the lunch daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outdoorSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Outdoor Seating Capacity' ;
    rdfs:comment 'Total number of outdoor or patio seats available for guest dining.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakHourThroughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Throughput Capacity' ;
    rdfs:comment 'Maximum number of guest transactions or covers that can be processed during the busiest hour of operation.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateDiningCapacity rdf:type rdf:Property ;
    rdfs:label 'Private Dining Capacity' ;
    rdfs:comment 'Total seating capacity in private dining rooms or event spaces within the restaurant.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Seating Capacity' ;
    rdfs:comment 'Aggregate seating capacity across all dining areas including indoor, outdoor, bar, and private dining.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAreaAreaManagementId rdf:type rdf:Property ;
    rdfs:label 'Parent Area Area Management Id' ;
    rdfs:comment 'Identifier of the parent area in the management hierarchy. Null for top-level areas.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AreaManagement .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Business identifier code for the area or district. Used in operational reporting and area manager assignment.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Descriptive name of the area or district (e.g., \'Northeast Metro\', \'Southern California Region\').' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaStatus rdf:type rdf:Property ;
    rdfs:label 'Area Status' ;
    rdfs:comment 'Current operational status of the area management record.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the area management level within the organizational hierarchy.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auvTarget rdf:type rdf:Property ;
    rdfs:label 'Auv Target' ;
    rdfs:comment 'Target Average Unit Volume (AUV) for restaurants in this area, representing expected annual sales per unit.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPercentTarget rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent Target' ;
    rdfs:comment 'Target Cost of Goods Sold (COGS) as a percentage of sales for restaurants in this area.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyOwnedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Company Owned Unit Count' ;
    rdfs:comment 'Number of company-owned restaurant units within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csatTargetScore rdf:type rdf:Property ;
    rdfs:label 'Csat Target Score' ;
    rdfs:comment 'Target Customer Satisfaction (CSAT) score for this area, typically measured on a scale of 0-100.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:division rdf:type rdf:Property ;
    rdfs:label 'Division' ;
    rdfs:comment 'Corporate division or business unit to which this area is assigned.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Flag' ;
    rdfs:comment 'Indicates whether this area is governed by a franchise area development agreement.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseUnitCount rdf:type rdf:Property ;
    rdfs:label 'Franchise Unit Count' ;
    rdfs:comment 'Number of franchised restaurant units within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Broader geographic region to which this area belongs (e.g., \'West Coast\', \'Midwest\', \'Southeast\').' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level in the area management hierarchy, with 1 being the top level (e.g., national) and higher numbers representing more granular levels (e.g., region, district).' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborPercentTarget rdf:type rdf:Property ;
    rdfs:label 'Labor Percent Target' ;
    rdfs:comment 'Target labor cost as a percentage of sales for restaurants in this area.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingFundContributionPercent rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Contribution Percent' ;
    rdfs:comment 'Percentage of sales contributed to the marketing fund by units in this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsTargetScore rdf:type rdf:Property ;
    rdfs:label 'Nps Target Score' ;
    rdfs:comment 'Target Net Promoter Score (NPS) for this area, measuring customer loyalty and likelihood to recommend.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nroTargetCount rdf:type rdf:Property ;
    rdfs:label 'Nro Target Count' ;
    rdfs:comment 'Target number of New Restaurant Openings (NRO) planned for this area within the current fiscal year.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Standard royalty rate percentage applied to franchise units in this area.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sssTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sss Target Percent' ;
    rdfs:comment 'Target Same-Store Sales (SSS) growth percentage for this area, used to measure year-over-year comparable store performance.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Boundary Description' ;
    rdfs:comment 'Textual description of the geographic or operational boundaries defining this area (e.g., \'All units within 50 miles of downtown Chicago\').' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total number of restaurant units (company-owned and franchised) within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Unit Ownership Id' ;
    rdfs:comment 'Unique identifier for each unit ownership record. Primary key for the unit ownership history table.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to franchise.agreement. Business justification: Unit ownership is governed by a specific franchise agreement defining royalty rates, term, and operating obligations. Franchise compliance and legal teams require the direct link between a unit\'s owne' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:primaryUnitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Unit Employee Id' ;
    rdfs:comment 'The identifier of the user who created this ownership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryUnitFranchisePartnerFranchiseeId rdf:type rdf:Property ;
    rdfs:label 'Primary Unit Franchise Partner Franchisee Id' ;
    rdfs:comment 'Reference to the franchise partner master record when ownership_type is franchised, licensed, joint_venture, master_franchise, or area_development. Null for company-owned units.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:tertiaryUnitLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Unit Last Modified By User Employee Id' ;
    rdfs:comment 'The identifier of the user who last modified this ownership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaDevelopmentAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Area Development Agreement Flag' ;
    rdfs:comment 'Indicates whether this ownership is part of a multi-unit area development agreement. Used for franchise development tracking and compliance reporting.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this ownership arrangement with franchise agreement terms and brand standards. Used for franchise compliance reporting and risk management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Expiration Date' ;
    rdfs:comment 'The expiration date of the franchise agreement. Used for renewal planning and compliance tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseAgreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Start Date' ;
    rdfs:comment 'The start date of the franchise agreement governing this ownership. May differ from ownership_effective_start_date if ownership transferred mid-agreement.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialFranchiseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Initial Franchise Fee Usd' ;
    rdfs:comment 'The one-time initial franchise fee paid at the start of this ownership arrangement. Null for company-owned units. Used for revenue recognition and franchise economics analysis.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jointVenturePartnerName rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Partner Name' ;
    rdfs:comment 'The name of the joint venture partner if ownership_type is joint_venture. Used for partnership management and financial reporting.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Audit Date' ;
    rdfs:comment 'The date of the most recent compliance audit for this ownership arrangement. Used for audit scheduling and compliance tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingFeePercent rdf:type rdf:Property ;
    rdfs:label 'Marketing Fee Percent' ;
    rdfs:comment 'The percentage of gross sales contributed to the marketing fund under this ownership arrangement. Used for marketing fund accounting and campaign budget allocation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:masterFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Master Franchise Flag' ;
    rdfs:comment 'Indicates whether this ownership operates under a master franchise arrangement with sub-franchising rights. Used for franchise hierarchy management and royalty flow tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextComplianceAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next compliance audit. Used for audit planning and compliance management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingEntityLegalName rdf:type rdf:Property ;
    rdfs:label 'Operating Entity Legal Name' ;
    rdfs:comment 'The full legal name of the entity that owns and operates this restaurant unit. Used for legal compliance, tax reporting, and franchise agreement documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Operating License Expiration Date' ;
    rdfs:comment 'The expiration date of the operating license. Used for renewal tracking and compliance management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Operating License Number' ;
    rdfs:comment 'The business operating license number issued by local authorities for this ownership entity. Used for regulatory compliance and legal documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective End Date' ;
    rdfs:comment 'The date on which this ownership arrangement ended or will end. Null for current active ownership. Used to close out royalty periods and finalize P&L attribution.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective Start Date' ;
    rdfs:comment 'The date on which this ownership arrangement became effective. Used to determine royalty calculation periods and P&L attribution windows.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipNotes rdf:type rdf:Property ;
    rdfs:label 'Ownership Notes' ;
    rdfs:comment 'Free-text notes capturing additional context about this ownership arrangement, including special terms, conditions, or historical information.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of ownership stake held by this entity in joint venture arrangements. 100% for sole ownership. Used for P&L attribution and profit distribution.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Ownership Record Number' ;
    rdfs:comment 'Business-facing unique identifier for this ownership record, used in franchise agreements and legal documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Current lifecycle status of this ownership record. Active indicates current operational ownership; pending indicates ownership transfer in progress; transferred indicates completed ownership change; terminated indicates closure or reversion; suspended indicates temporary operational hold.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipTransferDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Date' ;
    rdfs:comment 'The date on which ownership was transferred from a previous owner to the current owner. Used for historical tracking and transfer analysis.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousOwnerName rdf:type rdf:Property ;
    rdfs:label 'Previous Owner Name' ;
    rdfs:comment 'The name of the previous owner if this ownership record represents a transfer or resale. Used for historical tracking and franchise relationship management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'The geographic territory code assigned to this franchise ownership. Used for territory management, market planning, and franchise compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Approval Date' ;
    rdfs:comment 'The date on which the franchisor approved the ownership transfer. Used for compliance tracking and transfer timeline analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Transfer Approved By' ;
    rdfs:comment 'The name or identifier of the franchisor representative who approved the ownership transfer. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'The business reason for this ownership record being created or terminated. Used for franchise compliance reporting, trend analysis, and strategic planning. [ENUM-REF-CANDIDATE: new_franchise_award|resale|corporate_acquisition|refranchising|closure|default|voluntary_termination|expiration — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Gl Account Id' ;
    rdfs:comment 'Reference to the parent account in the account hierarchy for roll-up reporting. Null for top-level accounts. Enables multi-level account group hierarchies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for accounts that manage balances in a specific currency (e.g., \'USD\', \'EUR\', \'GBP\'). Null for accounts managed only in company code currency.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed business description of the account purpose, usage guidelines, and what types of transactions should be posted to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group code that defines the account\'s characteristics, field status, and number range. Controls account behavior and validation rules in SAP S/4HANA.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Human-readable short name or title of the GL account (e.g., \'Food Cost - Beef\', \'Franchise Royalty Revenue\', \'Depreciation - Equipment\').' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known unique account code used across all legal entities in the chart of accounts. Typically 6-10 digit numeric code following SAP S/4HANA GL numbering convention.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account: \'active\' for normal use, \'blocked\' for temporarily suspended, \'closed\' for permanently retired, \'pending_activation\' for newly created accounts awaiting approval.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'High-level classification of the account into one of the five fundamental financial statement categories: asset, liability, equity, revenue, or expense.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Account Number' ;
    rdfs:comment 'Alternative or legacy account code used for cross-reference, migration mapping, or external reporting (e.g., mapping to previous ERP system account numbers).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Specific balance sheet line item classification for asset, liability, and equity accounts. Set to \'not_applicable\' for P&L (Profit and Loss) accounts (revenue/expense).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification of this account for cash flow statement presentation: \'operating\' for operational cash flows, \'investing\' for CapEx (Capital Expenditure) and asset transactions, \'financing\' for debt and equity, \'not_applicable\' for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'Mapped account number used in corporate consolidation reporting to standardize accounts across multiple legal entities and chart of accounts structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of cost element: \'primary\' for costs posted from external transactions (FI to CO), \'secondary\' for internal allocations and assessments, \'not_applicable\' if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Flag indicating whether this GL account is also defined as a cost element in SAP Controlling (CO) module for cost center and internal order postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or name of the person who created this GL account record. Supports accountability and audit requirements.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group code that controls which fields are required, optional, or suppressed when posting transactions to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Detailed sub-classification within the account type for financial statement presentation (e.g., \'Current Assets\', \'Long-Term Liabilities\', \'Operating Revenue\', \'Cost of Goods Sold (COGS)\', \'Selling General and Administrative (SG&A)\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Business function or operational area this account supports (e.g., \'Restaurant Operations\', \'Franchise\', \'Supply Chain\', \'Marketing\', \'Corporate\', \'Real Estate\'). Used for segment reporting and management accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Gaap Account Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used in GAAP-compliant financial statements. Supports dual-ledger reporting for companies reporting under both GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Ifrs Account Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used in IFRS-compliant financial statements. Supports dual-ledger reporting for companies reporting under both GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used for intercompany transactions between legal entities that require elimination during consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified this GL account record. Supports change tracking and accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Indicator' ;
    rdfs:comment 'Flag indicating whether individual line item details are stored and displayed for this account. True for most operational accounts; false for summary accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Indicator' ;
    rdfs:comment 'Flag indicating whether this account uses open item management for tracking and clearing individual transactions (e.g., for clearing accounts, suspense accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Granularity level at which budget planning and forecasting is performed for this account (e.g., \'corporate\', \'region\', \'restaurant\', \'cost_center\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Indicator' ;
    rdfs:comment 'Flag indicating whether direct transaction postings are allowed to this account. False for summary/header accounts that only receive totals from sub-accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Classification' ;
    rdfs:comment 'Specific P&L statement line item classification for revenue and expense accounts (e.g., \'Sales Revenue\', \'COGS (Cost of Goods Sold)\', \'Labor Cost\', \'Occupancy Cost\', \'EBITDA (Earnings Before Interest Taxes Depreciation and Amortization)\'). Null for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from AP (Accounts Payable), AR (Accounts Receivable), or FA (Fixed Assets) subledgers.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentReportingIndicator rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Indicator' ;
    rdfs:comment 'Flag indicating whether transactions posted to this account are included in segment reporting for business unit, geographic, or product line analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP sort key that determines the default sorting and grouping of line items posted to this account (e.g., by posting date, document number, or business partner).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a statistical account used for tracking non-monetary quantities (e.g., headcount, transaction counts, cover counts) without affecting financial balances.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment classification for this account (e.g., \'taxable_revenue\', \'non_taxable_revenue\', \'input_tax\', \'output_tax\', \'exempt\'). Used for sales tax, VAT, and GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual budget amount for this cost center in local currency. Used for variance analysis, Labor% and COGS% target setting, and OpEx control. Updated during annual budgeting cycles and mid-year reforecasts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'The fiscal year for which the budget_amount is applicable. Enables multi-year budget tracking and year-over-year variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'The SAP business area classification. Used to segment financial reporting by line of business (e.g., QSR, casual dining, catering, franchise operations) for multi-brand or multi-format portfolios.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Eligible Flag' ;
    rdfs:comment 'Indicates whether this cost center is eligible to receive capital expenditure allocations. True for restaurant units (equipment, R&M), distribution centers, and major corporate facilities. False for pure administrative departments. Used to distinguish CapEx from OpEx in financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The SAP Controlling Area to which this cost center belongs. Controlling areas represent the highest level of cost accounting organization, typically aligned with legal entities or major geographic regions for multi-entity consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'High-level categorization of the cost center\'s role. Revenue-generating centers (FOH, BOH) directly contribute to sales; support centers (maintenance, training) enable operations; administrative centers (HR, finance) provide governance; overhead centers (facilities, utilities) are indirect; capital project centers track CapEx initiatives.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Free-text description providing additional context about this cost center\'s purpose, scope, or special characteristics. Used for documentation and reporting clarity.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full business name of the cost center (e.g., \'Store #1234 - Downtown Chicago\', \'Regional Office - Midwest\', \'Corporate HR Department\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept cost postings; inactive centers are temporarily disabled; pending centers are awaiting approval; closed centers are permanently retired; suspended centers are on hold; planned centers are scheduled for future activation (e.g., NRO pipeline).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by organizational function. Restaurant units are individual QSR locations; regional offices manage geographic territories; corporate departments are headquarters functions; shared service centers provide centralized support; distribution centers handle supply chain; franchise support manages franchisee relations.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'The restaurant format classification. Examples: DT (Drive-Thru), DINE_IN, KIOSK, FOOD_COURT, AIRPORT, GHOST_KITCHEN. Used for format-specific cost benchmarking, throughput analysis, and real estate site selection.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Flag' ;
    rdfs:comment 'Indicates whether this cost center represents a franchise-owned unit (true) or a company-owned unit (false). Critical for revenue recognition (royalty income vs direct sales), P&L consolidation, and franchise compliance tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'The functional area classification for cross-company-code reporting. Typical values include operations, marketing, R&D, administration, IT, finance. Used for functional P&L views and OpEx analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opexAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Opex Allocation Method' ;
    rdfs:comment 'The method used to allocate shared operating expenses to this cost center. Direct costs are posted directly; allocated methods distribute corporate overhead based on revenue, headcount, square footage, transaction volume, or fixed percentages. Used for full-absorption P&L reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'The cost center code of the immediate parent in the organizational hierarchy. Nullable for top-level cost centers. Enables recursive hierarchy traversal for regional and corporate rollups.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in the organizational hierarchy. Enables recursive roll-up for regional and brand-level P&L aggregation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:aovTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Aov Target Amount' ;
    rdfs:comment 'Target annual revenue for this profit center expressed in the profit center\'s functional currency. Used for AUV benchmarking and performance variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Business reason for profit center closure (e.g., lease expiration, underperformance, market exit, franchise termination). Used for portfolio optimization analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code identifying the consolidation unit for multi-entity financial consolidation. Used in GAAP/IFRS-compliant consolidated financial statement preparation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code of the cost center group associated with this profit center. Links profit center P&L to underlying cost center actuals for COGS and OpEx analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Target Amount' ;
    rdfs:comment 'Target EBITDA for this profit center expressed in the profit center\'s functional currency. Used for profitability benchmarking and executive performance evaluation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Code representing the geographic region (e.g., Northeast, Southwest, EMEA, APAC). Used for regional P&L consolidation and market performance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the profit center is locked for transaction posting. Locked centers cannot receive new P&L entries but remain visible for historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingFundRatePercent rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Rate Percent' ;
    rdfs:comment 'Marketing fund contribution rate percentage for franchise profit centers. Represents the percentage of gross sales contributed to the brand marketing fund.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'Functional category of the profit center. Operating centers generate direct revenue; non-operating centers represent overhead or shared services allocated to operating units.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Business identifier code for the profit center as defined in SAP controlling area. Used in financial reporting and P&L statements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full descriptive name of the profit center (e.g., \'Downtown Chicago QSR Unit 1234\', \'Northeast Regional Franchise Group\', \'Company-Owned Casual Dining Segment\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active centers participate in P&L reporting; inactive centers are excluded from current period consolidation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Flag' ;
    rdfs:comment 'Indicates whether this profit center is a reportable segment under GAAP ASC 280 or IFRS 8. Reportable segments require separate disclosure in external financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the profit center by business segment type. Determines the level of P&L aggregation and reporting hierarchy.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sssEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sss Eligible Flag' ;
    rdfs:comment 'Indicates whether this profit center is included in Same-Store Sales (SSS) / Comparable Store Sales (Comp Sales) calculations. Typically requires 12+ months of operating history.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary tax jurisdiction for this profit center. Determines applicable sales tax, VAT, and income tax treatment in P&L reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the parent legal entity in the corporate hierarchy. Null for the ultimate parent company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the top-level parent entity in the corporate structure. Used for ultimate consolidation and group reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting framework used for financial statement preparation. GAAP for US entities, IFRS for international, or local statutory standards.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character alphanumeric code uniquely identifying the legal entity in SAP S/4HANA FI. Used as the organizational unit for financial accounting and external reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Identifier of the consolidation group or reporting segment this entity belongs to for multi-entity financial consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Method used to consolidate this entity\'s financial results into group reporting. Full for subsidiaries, equity for associates, none for non-consolidated entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP S/4HANA organizational unit for cost accounting, internal reporting, and profitability analysis. May span multiple company codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP S/4HANA organizational unit for managing customer credit limits and credit exposure across one or more company codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date the legal entity was officially dissolved or ceased operations. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet for business credit and supplier management.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this legal entity record is effective for financial posting and reporting. Used for time-dependent organizational changes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this legal entity record is effective. Null for currently active entities. Used for historical tracking of organizational changes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity. Active entities post transactions; inactive entities are retained for historical reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity structure. Determines ownership model, consolidation treatment, and reporting obligations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the end of the entity\'s fiscal year. 12 = December for calendar year entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Code defining the fiscal year calendar structure (e.g., calendar year, 4-4-5 retail calendar, 52/53 week year) used by this entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date the legal entity was officially registered or incorporated with the governing jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this entity participates in automated intercompany clearing and reconciliation processes for intra-group transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is incorporated and legally domiciled.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStateProvince rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Province' ;
    rdfs:comment 'State, province, or sub-national jurisdiction where the entity is registered. Relevant for federal systems (USA, Canada, etc.).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the entity as filed with government authorities. Used on official financial statements, tax filings, and legal contracts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier issued by the Global LEI Foundation for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the entity\'s functional currency for financial reporting and local statutory books.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary business contact for the legal entity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary business contact or registered agent for the legal entity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary business contact for the legal entity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether profit center assignment is mandatory for all financial postings in this legal entity. True enforces segment reporting compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number assigned by the jurisdiction\'s corporate registry.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for consolidated group reporting. Typically USD for US-based parent companies.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this entity is subject to segment reporting requirements under GAAP ASC 280 or IFRS 8.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identifier (EIN in USA, VAT number in EU, etc.) used for tax filing and reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for entities operating in jurisdictions with value-added tax systems. Used for tax reporting and invoice compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry header in SAP S/4HANA FI-GL.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'SAP user ID of the person who approved this journal entry for posting. Populated only for entries requiring approval workflow. Used for segregation of duties compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'SAP user ID of the person or system account that posted this journal entry. Used for audit trail and segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryJournalLastModifiedUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Journal Last Modified User Employee Id' ;
    rdfs:comment 'SAP user ID of the person who last modified this journal entry header (e.g., added notes, changed status). Blank if never modified after initial posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentPeriodIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Period Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry was posted in a special adjustment period (periods 13-16) for year-end close. True if adjustment period; False if regular period.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Exact date and time when the journal entry was approved. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if no approval required or not yet approved.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditClass rdf:type rdf:Property ;
    rdfs:label 'Audit Class' ;
    rdfs:comment 'Classification of the journal entry for audit sampling and risk assessment. Values: standard (routine posting), high_risk (unusual or large amount), manual_adjustment (manual journal entry requiring scrutiny), system_generated (automated posting).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date from which payment terms are calculated (typically document date or posting date). Used to determine net due date and discount periods. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Name of the batch input session if this journal entry was posted via batch processing (e.g., mass upload, automated interface). Blank for manually posted entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this journal entry was cleared. Populated only for cleared documents. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number of the clearing document if this journal entry has been cleared (e.g., open item cleared by payment or offsetting entry). Blank if not cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationTransactionType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Transaction Type' ;
    rdfs:comment 'Three-character code classifying the journal entry for consolidation purposes (e.g., 100=standard posting, 200=intercompany elimination, 300=currency translation adjustment, 400=consolidation adjustment). Used in multi-entity financial consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date printed on the source document (invoice date, receipt date, contract date). May differ from posting date. Used for aging analysis and payment terms calculation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description or memo entered at the document header level. Provides business context for the journal entry (e.g., \'Monthly depreciation run\', \'Accrual for Q4 marketing expenses\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Ten-digit accounting document number assigned by SAP upon posting. The externally-known unique identifier for this journal entry within the company code and fiscal year. Used for audit trail and cross-reference.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code classifying the nature of the accounting document (e.g., SA=GL account document, KR=vendor invoice, DR=customer invoice, AB=accounting document, AA=asset posting). Controls number ranges and posting keys.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the document was entered into the SAP system by the user. Used for audit trail and processing time analysis. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert document currency to local currency at the time of posting. Expressed as local currency per one unit of document currency.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger in which this entry is posted (e.g., 0L=leading ledger for GAAP, 2L=IFRS ledger, 3L=management ledger). Supports parallel accounting for multiple reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDueDate rdf:type rdf:Property ;
    rdfs:label 'Net Due Date' ;
    rdfs:comment 'The calculated due date for payment based on payment terms and baseline date. Used for cash flow forecasting and AP/AR aging. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is in parked status (saved but not yet posted). True if parked; False if posted. Parked documents do not update GL balances until posted.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Four-character code defining payment terms for vendor invoices or customer invoices (e.g., net 30, 2/10 net 30). Used to calculate due dates and cash discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry is posted to the general ledger. Determines the fiscal period assignment and is the primary date for financial reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit numeric code that controls the type of posting (debit or credit) and the account type (e.g., 40=debit GL, 50=credit GL, 01=debit customer, 31=debit vendor). Determines field status and processing logic.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the journal entry was posted to the general ledger. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and real-time reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Free-text field for external reference numbers such as vendor invoice number, purchase order number, or intercompany document reference. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is a reversal of a prior posting. True if this document reverses another document; False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Two-character code explaining why the document was reversed (e.g., 01=reversal in current period, 02=reversal in next period, 03=error correction). Populated only for reversal documents.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True. Maintains audit trail for accrual reversals and error corrections.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date used for tax reporting purposes (may differ from posting date based on jurisdiction rules). Used for VAT/GST returns and sales tax filings. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Four-character company code of the intercompany trading partner. Populated only when intercompany_indicator is True. Used for intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'SAP transaction code (T-code) used to create this journal entry (e.g., FB01, FB50, F-02). Indicates the posting method and user interface path.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current state of the journal entry in the approval workflow. Values: draft (initial entry), pending_approval (submitted for review), approved (authorized but not posted), posted (final state in GL), rejected (not approved), cancelled (voided before posting).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular GL transaction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJournalCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Customer Profile Id' ;
    rdfs:comment 'Reference to the customer master record if this line represents an accounts receivable transaction. Null for non-AR entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'Transaction amount in the original document currency. Used for multi-currency transactions before conversion to local currency.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Transaction amount converted to the local reporting currency of the legal entity. Used for consolidated financial statements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field for additional reference information. Often used for invoice numbers, PO numbers, or internal tracking codes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date for payment terms calculation. Typically the invoice date or goods receipt date.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line is a debit (D) or credit (C) entry. Fundamental to double-entry bookkeeping.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the document currency (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Payment due date for AP/AR line items. Calculated based on posting date and payment terms. Null for non-payable/receivable entries.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year to which this line item is posted. Derived from the posting date and fiscal calendar configuration.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text explaining the purpose or nature of this journal entry line. Provides business context for the transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the journal entry. Determines the order of debit and credit entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Single-character code for special GL transactions (e.g., down payments, guarantees, bills of exchange). Blank for standard postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner code for intercompany transactions. Identifies the counterparty legal entity for consolidation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'SAP user ID of the person who created this journal entry line. Audit trail for accountability.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Value date for cash management and bank reconciliation. Represents the effective date funds are available or debited.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the invoice for payment. Used for audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:maintenanceContractId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Id' ;
    rdfs:comment 'Foreign key linking to realestate.maintenance_contract. Business justification: AP invoices from maintenance vendors are matched against maintenance contracts for three-way matching and contract spend tracking. Foodservice operators validate vendor invoices against contract terms' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceContract .

ind:primaryApCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ap Created By User Employee Id' ;
    rdfs:comment 'The user ID of the person who created the invoice record in the system. Used for audit trail and accountability.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryApRestaurantLocationUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Ap Restaurant Location Unit Id' ;
    rdfs:comment 'Identifier for the restaurant location or unit to which this invoice expense is allocated. Used for unit-level P&L and Average Unit Volume (AUV) analysis.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:tertiaryApModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ap Modified By User Employee Id' ;
    rdfs:comment 'The user ID of the person who last modified the invoice record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'The dunning level or escalation stage for overdue invoices. Zero indicates no dunning. Higher numbers indicate escalated collection efforts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level categorization of the invoice expense type. Used for Cost of Goods Sold (COGS) percentage and Operating Expense (OpEx) tracking.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming physical receipt of goods or services. Used for three-way matching.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, including line item charges and taxes. Represents the full amount billed by the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. This is the principal business event timestamp for the invoice transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the invoice, such as the nature of goods or services purchased.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor-assigned invoice number as printed on the supplier invoice document. This is the externally-known business identifier for the invoice.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type (standard invoice, credit memo for returns, debit memo for additional charges, prepayment, or recurring invoice).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Net invoice amount converted to the company code local currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when the invoice record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount payable to the vendor after applying discounts and adjustments. This is the amount that will be paid.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Code indicating whether payment is blocked and the reason for the block (e.g., pricing dispute, quantity variance, quality issue). Empty if no block is active.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date the invoice was actually paid to the vendor. Null if the invoice is unpaid.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The payment document number or transaction reference assigned when the invoice was paid. Used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The purchase order number against which this invoice is being verified. Used for three-way matching and spend tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order (PO), goods receipt (GR), and invoice. Indicates whether the invoice matches the PO and GR within tolerance or has variances.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the invoice payment as required by tax regulations. Reduces the net payment to the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the batch payment run that generated this payment. Groups multiple payments processed together.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the company\'s payment account.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or division code for cross-company reporting (e.g., QSR, casual dining, franchise operations).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'Cash discount amount deducted from invoice total for early payment. Supports supplier relationship management and Cost of Goods Sold (COGS) optimization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the payment amount (e.g., USD, CAD, EUR, GBP, MXN).' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'Number of invoices cleared by this payment. A single payment may settle multiple invoices.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code\'s local reporting currency.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID of the last person who modified the payment record (e.g., status change, cancellation, reversal).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total payment amount in document currency. Net amount remitted to vendor after discounts and adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code if payment was blocked or held for review (e.g., duplicate invoice, pricing dispute, quality issue). Null if not blocked.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the payment purpose or special handling instructions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'SAP payment document number assigned during payment run. Externally-known business identifier for this payment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to payment for processing sequence. Urgent for critical suppliers, high for preferred vendors, normal for standard terms, low for deferred payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of third-party payment processor or banking partner used to execute the payment (e.g., JP Morgan, Bank of America, Citibank).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms code applied to this payment (e.g., Net 30, 2/10 Net 30). Determines discount eligibility and due date calculation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of payment purpose. Vendor invoice for goods/services, credit memo for returns, down payment for Capital Expenditure (CapEx) projects, advance payment for future delivery, expense reimbursement for employee-paid vendor costs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Bank reconciliation status indicating whether payment has been matched to bank statement. Unreconciled: not yet matched. Reconciled: matched to bank statement. Exception: discrepancy found. Pending review: awaiting manual review.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Remittance Email' ;
    rdfs:comment 'Vendor email address to which remittance advice is sent. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Vendor\'s bank account number or payment account identifier used for remittance.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Legal name of the vendor receiving payment.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable invoice record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:primaryArLocationUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Ar Location Unit Id' ;
    rdfs:comment 'Restaurant location associated with the invoice when billing is location-specific (e.g., royalty based on location sales). Null for corporate-level billings.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Manual adjustments applied to the invoice for credits, rebates, or billing corrections. Can be positive or negative.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address for invoice mailing. Includes street number and name.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address for suite, apartment, or building information. Optional field.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address. Used for invoice mailing and tax jurisdiction determination.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact at the customer or franchisee organization. Used for invoice delivery and payment inquiries.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code for the billing address. Used for international invoicing and tax compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Email' ;
    rdfs:comment 'Email address for electronic invoice delivery and billing communications. Primary channel for invoice distribution.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for royalty and franchise fee revenue recognition alignment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for royalty invoices based on monthly or weekly sales performance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address. Required for invoice delivery and tax jurisdiction determination.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province code for the billing address. Used for tax calculation and regulatory reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice was sent to the customer. Used to track collection activity and determine next dunning action.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified the invoice record. Used for change tracking and accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid amount on the invoice. Updated as payments are received and applied. Zero when invoice is fully paid.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number or identifier provided to customer for payment remittance. Used for automated payment matching and reconciliation.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this invoice is recognized for financial reporting purposes. May differ from invoice date per GAAP/IFRS revenue recognition rules.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment record. Primary key.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The ACH network trace number for ACH payments. Enables tracking and reconciliation of electronic payments.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number for check payments. Null for electronic payment methods. Used for audit trails and bank reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoImpactDays rdf:type rdf:Property ;
    rdfs:label 'Dso Impact Days' ;
    rdfs:comment 'The number of days between invoice due date and payment receipt date. Used to calculate DSO metrics and monitor collection efficiency.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The payment amount converted to the company code functional currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The business date when the payment was received and recorded in the AR system. Used for Days Sales Outstanding (DSO) calculation and revenue recognition.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Customer-provided reference number or remittance advice identifier. Used to match payments to invoices during application.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date when the payment was reversed. Null for non-reversed payments. Used for audit trails and financial period corrections.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'The payment processor transaction identifier for card or digital wallet payments. Used for chargeback management and reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unallocated to invoices. Represents cash on account or overpayments requiring future application.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Confirmation Number' ;
    rdfs:comment 'Bank-provided confirmation or trace number for wire transfer payments. Used for payment verification and dispute resolution.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for the custody and maintenance of the asset. Supports accountability and asset stewardship.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized to date since acquisition. Contra-asset account that reduces the gross book value to net book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total capitalized cost of the fixed asset at acquisition including purchase price, installation, freight, and other directly attributable costs. Recorded in USD.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the fixed asset was acquired or placed into service. Used as the start date for depreciation calculations and useful life tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Classification category of the fixed asset used for grouping and reporting. Determines depreciation rules and capitalization thresholds per GAAP/IFRS standards.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset including make, model, and specifications (e.g., \'Vulcan 6-Burner Gas Range Model XYZ123\').' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known unique asset tag or serial number assigned to the fixed asset for tracking and identification purposes. Used for physical asset verification and audit trails.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Determines whether depreciation is active and whether the asset appears on the balance sheet. [ENUM-REF-CANDIDATE: active|in_service|under_construction|retired|disposed|impaired|held_for_sale — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubclass rdf:type rdf:Property ;
    rdfs:label 'Asset Subclass' ;
    rdfs:comment 'Detailed sub-classification within the asset class for granular tracking (e.g., \'Fryers\', \'Grills\', \'KDS Units\' under kitchen_equipment).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectCode rdf:type rdf:Property ;
    rdfs:label 'Capex Project Code' ;
    rdfs:comment 'Reference code linking the asset to the originating capital expenditure project or budget line item. Supports CapEx tracking and ROI analysis.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal for P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Flag indicating whether the asset has been tested for impairment and found to have a carrying value exceeding its recoverable amount per GAAP/IFRS standards.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Amount of impairment loss recognized when the asset\'s carrying value exceeds its fair value or value in use. Recorded as a non-cash charge to P&L.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number for property and casualty insurance covering the asset. Used for claims processing and risk management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date of the most recent physical verification or audit of the asset. Supports SOX compliance and internal control over fixed assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Lease Indicator' ;
    rdfs:comment 'Flag indicating whether the asset is subject to a lease agreement (finance lease or operating lease under ASC 842 / IFRS 16). Determines right-of-use asset treatment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying value of the asset calculated as acquisition cost minus accumulated depreciation. Represents the asset value on the balance sheet.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Subtracted from acquisition cost to determine depreciable base.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty expires. Used to plan for extended service contracts and budget for repairs and maintenance (R&M).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:budgetRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Budget Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the specific restaurant location to which this budget line applies. Null for corporate or regional-level budgets.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:budgetUnitId rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Id' ;
    rdfs:comment 'Identifier of the specific restaurant location to which this budget line applies. Null for corporate or regional-level budgets.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the individual or committee that approved this budget line (e.g., CFO, Budget Committee, Regional Director).' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Amount' ;
    rdfs:comment 'The baseline or prior-year budget amount used as a reference point for variance analysis and year-over-year comparisons.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level categorization of the budget line for reporting and analysis purposes (e.g., Store Operations, Corporate Overhead, Franchise Support, New Restaurant Opening).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current approval and lifecycle status of the budget record. Draft indicates work in progress, Submitted indicates pending approval, Approved indicates finalized, Rejected indicates not approved, Locked indicates no further changes allowed.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget line by expense or revenue category. OpEx (Operating Expenditure), CapEx (Capital Expenditure), Labor, Food Cost, Revenue, COGS (Cost of Goods Sold), Marketing, R&M (Repairs and Maintenance). [ENUM-REF-CANDIDATE: opex|capex|labor|food_cost|revenue|cogs|marketing|rm — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEntity rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entity' ;
    rdfs:comment 'Legal entity or consolidation unit for multi-entity financial consolidation and GAAP/IFRS reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nroFlag rdf:type rdf:Property ;
    rdfs:label 'Nro Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is associated with a New Restaurant Opening (NRO) project. True if NRO-related, False otherwise.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nroProjectCode rdf:type rdf:Property ;
    rdfs:label 'Nro Project Code' ;
    rdfs:comment 'Unique project code for the New Restaurant Opening initiative if this budget line is NRO-related. Null for non-NRO budgets.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Pct' ;
    rdfs:comment 'The acceptable variance threshold percentage for budget-to-actual reporting. Variances exceeding this threshold trigger alerts or reviews.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Version of the budget record indicating whether it is the original budget, a revised budget, a forecast, a reforecast, or the final approved budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the individual who created this budget record.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBudgetId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Id' ;
    rdfs:comment 'Reference to the parent budget plan that contains this line item.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:primaryBudgetRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Restaurant Unit Id' ;
    rdfs:comment 'Reference to the specific restaurant location if this budget line is allocated at the unit level. Null for corporate or regional budget lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:allocationDriver rdf:type rdf:Property ;
    rdfs:label 'Allocation Driver' ;
    rdfs:comment 'Business metric or driver used as the basis for allocation (e.g., revenue, transaction count, square footage, headcount). Null if allocation_method is direct.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or calculate this budget line (e.g., direct assignment, proportional allocation based on revenue, driver-based using transaction volume, zero-based budgeting, incremental from prior year).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Budget Percentage Target' ;
    rdfs:comment 'Target percentage of revenue or total budget that this line represents (e.g., COGS% target of 30.00, Labor% target of 25.00). Used for ratio-based budgeting and variance analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Budget Subcategory' ;
    rdfs:comment 'Detailed subcategory within the budget category for granular tracking (e.g., within labor: FOH labor, BOH labor, management labor; within food cost: protein, produce, dairy).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version or type of budget this line represents (original annual budget, mid-year revision, rolling forecast, or actual results for comparison).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Budgeted monetary amount for this line item in the specified currency. Represents the target spend or revenue for the fiscal period.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTarget rdf:type rdf:Property ;
    rdfs:label 'Quantity Target' ;
    rdfs:comment 'Budgeted quantity or volume for non-monetary metrics (e.g., labor hours, transaction count, covers, units sold). Null for purely monetary budget lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Absolute monetary variance threshold that triggers alerts or requires management review. Null if no threshold is set.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Percentage variance threshold that triggers alerts or requires management review. Null if no threshold is set.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Typically matches the legal entity name but may differ for special-purpose accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier. In the US this is the ABA routing number; in other countries it may be a sort code, bank code, or clearing number.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Delivery Method' ;
    rdfs:comment 'How bank statements are delivered: electronic (email or portal), paper (postal mail), or both.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Full street address of the bank branch. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolGroup rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Group' ;
    rdfs:comment 'Identifier for the cash pooling or notional pooling group this account belongs to. Used for multi-entity liquidity management and interest optimization.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date the bank account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dualSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Signature Required Flag' ;
    rdfs:comment 'Indicates whether two authorized signatories are required for transactions above a certain threshold. True if dual control is mandated; false otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualSignatureThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dual Signature Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which dual signature is required. Null if dual signature is not applicable or always required.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electronicBankingCode rdf:type rdf:Property ;
    rdfs:label 'Electronic Banking Code' ;
    rdfs:comment 'Identifier or login ID for online banking or electronic funds transfer systems. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for accounts in IBAN-participating countries. Up to 34 alphanumeric characters. Restricted due to account identification sensitivity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'Annual interest rate applied to the account balance, expressed as a percentage. May be positive for interest-bearing accounts or negative for fee-based accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date of the most recent successful bank reconciliation for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum balance required to avoid fees or maintain account status. Null if no minimum is required.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdraftFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Flag' ;
    rdfs:comment 'Indicates whether the account has an overdraft or line of credit facility. True if overdraft is available; false otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft or credit line available on this account. Null if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this account (e.g., ACH, wire, check, EFT, SEPA). [ENUM-REF-CANDIDATE: ACH|wire|check|EFT|SEPA|BACS|CHAPS|RTP — promote to reference product]' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'How often this bank account is reconciled against the general ledger: daily (high-volume operating accounts), weekly (moderate activity), monthly (low activity or reserve accounts).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryList rdf:type rdf:Property ;
    rdfs:label 'Signatory List' ;
    rdfs:comment 'Comma-separated list of employee IDs or names authorized to sign checks or approve wire transfers on this account. Confidential for fraud prevention.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'Bank Identifier Code (BIC) or SWIFT code for international wire transfers. 8 or 11 character alphanumeric code identifying the bank and branch.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomId rdf:type rdf:Property ;
    rdfs:label 'Uom Id' ;
    rdfs:comment 'Foreign key linking to inventory.uom. Business justification: stock_item.unit_of_measure is a STRING column that denotes the storage/base unit of measure for the SKU. The uom table is the authoritative UOM reference master in this domain. Adding uom_id FK normal' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:allergenEggs rdf:type rdf:Property ;
    rdfs:label 'Allergen Eggs' ;
    rdfs:comment 'Indicates whether the item contains or may contain eggs. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenFish rdf:type rdf:Property ;
    rdfs:label 'Allergen Fish' ;
    rdfs:comment 'Indicates whether the item contains or may contain fish. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenMilk rdf:type rdf:Property ;
    rdfs:label 'Allergen Milk' ;
    rdfs:comment 'Indicates whether the item contains or may contain milk or dairy derivatives. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenPeanuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Peanuts' ;
    rdfs:comment 'Indicates whether the item contains or may contain peanuts. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenShellfish rdf:type rdf:Property ;
    rdfs:label 'Allergen Shellfish' ;
    rdfs:comment 'Indicates whether the item contains or may contain crustacean shellfish. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenSoybeans rdf:type rdf:Property ;
    rdfs:label 'Allergen Soybeans' ;
    rdfs:comment 'Indicates whether the item contains or may contain soybeans. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenTreeNuts rdf:type rdf:Property ;
    rdfs:label 'Allergen Tree Nuts' ;
    rdfs:comment 'Indicates whether the item contains or may contain tree nuts. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allergenWheat rdf:type rdf:Property ;
    rdfs:label 'Allergen Wheat' ;
    rdfs:comment 'Indicates whether the item contains or may contain wheat. Required for menu labeling and allergen disclosure.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:casePackQuantity rdf:type rdf:Property ;
    rdfs:label 'Case Pack Quantity' ;
    rdfs:comment 'Number of individual units contained in one case. Used for ordering and receiving conversions.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the standard cost (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when the item was or will be discontinued from inventory. Used for phase-out planning and historical analysis.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gtin rdf:type rdf:Property ;
    rdfs:label 'Gtin' ;
    rdfs:comment 'International product identifier used for supply chain tracking and barcode scanning. May be UPC, EAN, or other GS1 format.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpMaxTempF rdf:type rdf:Property ;
    rdfs:label 'Haccp Max Temp F' ;
    rdfs:comment 'Maximum safe storage temperature in Fahrenheit to maintain product quality and food safety standards.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haccpMinTempF rdf:type rdf:Property ;
    rdfs:label 'Haccp Min Temp F' ;
    rdfs:comment 'Minimum safe storage temperature in Fahrenheit required to prevent bacterial growth and ensure food safety compliance.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGmoFree rdf:type rdf:Property ;
    rdfs:label 'Is Gmo Free' ;
    rdfs:comment 'Indicates whether the item is certified non-GMO. Used for menu transparency and consumer preference alignment.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHalal rdf:type rdf:Property ;
    rdfs:label 'Is Halal' ;
    rdfs:comment 'Indicates whether the item meets Islamic dietary law requirements. Used for menu segmentation and cultural accommodation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKosher rdf:type rdf:Property ;
    rdfs:label 'Is Kosher' ;
    rdfs:comment 'Indicates whether the item meets Jewish dietary law requirements. Used for menu segmentation and cultural accommodation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Primary classification of the stock item by food service category. Used for inventory organization, COGS analysis, and procurement planning. [ENUM-REF-CANDIDATE: protein|produce|dairy|dry_goods|beverage|paper_goods|cleaning|packaging — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSubcategory rdf:type rdf:Property ;
    rdfs:label 'Item Subcategory' ;
    rdfs:comment 'Secondary classification providing finer granularity within the item category (e.g., beef, chicken, lettuce, tomato).' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parLevel rdf:type rdf:Property ;
    rdfs:label 'Par Level' ;
    rdfs:comment 'Target inventory quantity that should be maintained at all times to support operational needs without overstocking. Used for automated reorder triggers.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory threshold quantity that triggers a replenishment order. Set below PAR level to account for lead time.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to order when inventory falls below reorder point. Calculated to restore inventory to PAR level.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Expected unit cost of the item used for COGS calculations and variance analysis. Updated periodically based on procurement contracts.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageClass rdf:type rdf:Property ;
    rdfs:label 'Storage Class' ;
    rdfs:comment 'Required storage temperature zone for the item. Determines BOH storage location and HACCP compliance requirements.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Code' ;
    rdfs:comment 'Supplier\'s unique identifier for this item. Used for purchase order matching and invoice reconciliation.' ;
    rdfs:domain ind:StockItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldPercentage rdf:type rdf:Property ;
    rdfs:label 'Yield Percentage' ;
    rdfs:comment 'Percentage of usable product after preparation and trimming. Critical for recipe costing and waste tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockLocationId rdf:type rdf:Property ;
    rdfs:label 'Stock Location Id' ;
    rdfs:comment 'Unique identifier for the stock location. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for HACCP temperature monitoring accountability; each storage location has an assigned manager employee who signs compliance reports.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryStockEquipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Equipment Asset Id' ;
    rdfs:comment 'Identifier for the refrigeration or climate control equipment serving this location, used for maintenance tracking and temperature monitoring integration.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentAsset .

ind:restaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where this stock location is physically situated.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:accessControlRequired rdf:type rdf:Property ;
    rdfs:label 'Access Control Required' ;
    rdfs:comment 'Indicates whether electronic or physical access control (keycard, PIN, lock) is required to enter this location.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsReceiving rdf:type rdf:Property ;
    rdfs:label 'Allows Receiving' ;
    rdfs:comment 'Indicates whether this location is designated as a receiving point for incoming inventory deliveries.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsTransfers rdf:type rdf:Property ;
    rdfs:label 'Allows Transfers' ;
    rdfs:comment 'Indicates whether inventory can be transferred into or out of this location to other stock locations within the restaurant or across units.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsWasteTracking rdf:type rdf:Property ;
    rdfs:label 'Allows Waste Tracking' ;
    rdfs:comment 'Indicates whether waste events (spoilage, damage, expiration) can be recorded against inventory in this location for Waste% calculation.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binCount rdf:type rdf:Property ;
    rdfs:label 'Bin Count' ;
    rdfs:comment 'Number of individual storage bins or compartments within this location for granular SKU organization.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildingSection rdf:type rdf:Property ;
    rdfs:label 'Building Section' ;
    rdfs:comment 'Specific section or wing of the building where the location is situated (e.g., Kitchen, Bar, Prep Area, Receiving Dock).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCubicFeet rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Feet' ;
    rdfs:comment 'Total storage capacity of the location measured in cubic feet.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Number of days between scheduled physical inventory cycle counts for this location to maintain stock accuracy.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Physical floor level where the storage location is situated (e.g., 1 for ground floor, -1 for basement, 2 for second floor).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date when the most recent physical inventory cycle count was completed for this location.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the most recent maintenance or inspection was performed on the storage location or its equipment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the storage location within the restaurant unit (e.g., WIC01 for walk-in cooler 1, DRY02 for dry storage room 2).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable name of the stock location (e.g., Walk-In Cooler, Dry Storage Room, Bar Storage, Prep Area Shelf).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location based on its primary function and environmental control (refrigerated, frozen, ambient, bar, prep_area, service_station).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Cycle Count Date' ;
    rdfs:comment 'Date when the next physical inventory cycle count is scheduled for this location.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parLevelEnabled rdf:type rdf:Property ;
    rdfs:label 'Par Level Enabled' ;
    rdfs:comment 'Indicates whether PAR level inventory management is enabled for this location to trigger automatic replenishment orders.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCommodityCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Commodity Category' ;
    rdfs:comment 'Primary category of inventory items typically stored in this location (e.g., Proteins, Dairy, Produce, Dry Goods, Beverages, Alcohol).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresHaccpMonitoring rdf:type rdf:Property ;
    rdfs:label 'Requires Haccp Monitoring' ;
    rdfs:comment 'Indicates whether this location requires HACCP monitoring and documentation for food safety compliance.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Security classification for the location indicating access control requirements (open: unrestricted, restricted: authorized staff only, locked: key/code required, high_value: premium items with enhanced security).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfCount rdf:type rdf:Property ;
    rdfs:label 'Shelf Count' ;
    rdfs:comment 'Number of shelves or storage levels available in this location for organizing inventory.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Location Status' ;
    rdfs:comment 'Current operational status of the stock location (active: in use, inactive: temporarily not in use, maintenance: under repair, decommissioned: permanently retired).' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaType rdf:type rdf:Property ;
    rdfs:label 'Storage Area Type' ;
    rdfs:comment 'Indicates whether the location is in Back of House (BOH) or Front of House (FOH) area of the restaurant.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTemperatureMaxF rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Max F' ;
    rdfs:comment 'Maximum target temperature in Fahrenheit for this storage location to maintain food safety and quality standards.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetTemperatureMinF rdf:type rdf:Property ;
    rdfs:label 'Target Temperature Min F' ;
    rdfs:comment 'Minimum target temperature in Fahrenheit for this storage location to maintain food safety and quality standards.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitoringFrequencyHours rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Frequency Hours' ;
    rdfs:comment 'Required frequency in hours for temperature checks and logging at this location to ensure food safety compliance.' ;
    rdfs:domain ind:StockLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature control classification for the location (freezer: below 0°F, cooler: 32-40°F, ambient: room temperature, controlled: climate-controlled but not refrigerated).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandBalanceId rdf:type rdf:Property ;
    rdfs:label 'On Hand Balance Id' ;
    rdfs:comment 'Unique identifier for the on-hand balance record. Primary key for the inventory position snapshot.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOnRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary On Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where this inventory is held. Links to the restaurant operations master.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryOnSkuStockItemId rdf:type rdf:Property ;
    rdfs:label 'Primary On Sku Stock Item Id' ;
    rdfs:comment 'Reference to the SKU (Stock Keeping Unit) for which this balance is recorded. Links to the inventory item master.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockItem .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'The ABC inventory classification based on value and usage velocity. A items are high-value/high-velocity requiring tight control, C items are low-value/low-velocity.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'The frequency at which this SKU should be physically counted as part of the cycle count program. Typically aligned with ABC classification.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysUntilExpiration rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiration' ;
    rdfs:comment 'The number of days remaining until the expiration date. Used to prioritize usage and identify items at risk of waste.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extendedValue rdf:type rdf:Property ;
    rdfs:label 'Extended Value' ;
    rdfs:comment 'The total dollar value of the on-hand inventory, calculated as quantity_on_hand multiplied by unit_cost. Used for financial reporting and COGS% analysis.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current lifecycle status of this inventory position. Determines whether the inventory is available for use, held for quality review, or flagged for disposal.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPerishable rdf:type rdf:Property ;
    rdfs:label 'Is Perishable' ;
    rdfs:comment 'Indicates whether this SKU is a perishable item requiring temperature control and expiration tracking. True for fresh produce, dairy, meat; false for dry goods.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAdjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Adjustment Date' ;
    rdfs:comment 'The date when the last inventory adjustment (waste, transfer, or correction) was recorded for this SKU at this location.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'The date and time of the last inventory transaction (receipt, transfer, issue, or adjustment) that affected this balance. Used to identify stagnant inventory.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'The date when the last physical inventory count was performed for this SKU at this location. Used to track audit compliance and inventory accuracy.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'The date when this SKU was last received into inventory at this location. Used to track inventory freshness and identify slow-moving items.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'The supplier or manufacturer lot number for traceability and recall management. Critical for food safety compliance under HACCP (Hazard Analysis Critical Control Points).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'The net quantity available for use or sale, calculated as quantity_on_hand minus quantity_reserved. Represents the true available-to-promise inventory.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The total physical quantity of the SKU currently in stock at this location. Represents the gross inventory position before reservations.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'The quantity of the SKU that is committed to prep, production, or pending orders and not available for new allocation. Used in BOH (Back of House) prep planning.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'The minimum buffer stock maintained to protect against stockouts due to demand variability or supply delays. Part of the PAR level calculation.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuDescription rdf:type rdf:Property ;
    rdfs:label 'Sku Description' ;
    rdfs:comment 'Human-readable description of the SKU. Denormalized from SKU master for reporting convenience.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The date and time when this on-hand balance snapshot was captured. Represents the point-in-time inventory position for reporting and reconciliation.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The cost per unit of measure for this SKU at this location. Used to calculate extended inventory value and COGS (Cost of Goods Sold).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The accounting method used to value this inventory (FIFO - First In First Out, LIFO - Last In First Out, weighted average, or standard cost). Determines COGS calculation.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromPar rdf:type rdf:Property ;
    rdfs:label 'Variance From Par' ;
    rdfs:comment 'The difference between quantity_on_hand and par_level. Positive values indicate overstocking, negative values indicate understocking and trigger replenishment.' ;
    rdfs:domain ind:OnHandBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingOrderId rdf:type rdf:Property ;
    rdfs:label 'Receiving Order Id' ;
    rdfs:comment 'Unique identifier for the receiving order record. Primary key for inbound inventory transactions at restaurant unit level.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to supply.goods_receipt. Business justification: Goods receipt to inventory posting reconciliation is a core foodservice receiving control. The receiving_order (inventory posting) must reference the supply-side goods_receipt (physical inspection rec' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.inbound_shipment. Business justification: Delivery performance tracking requires linking the inventory receiving event to the logistics shipment record. Foodservice operators compare scheduled vs actual arrival (inbound_shipment) against what' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundShipment .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_purchase_order. Business justification: Three-way match (PO → receipt → invoice) is a fundamental AP control in foodservice procurement. Linking receiving_order to supply_purchase_order enables PO fulfillment reporting and quantity variance' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:receivingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Employee Id' ;
    rdfs:comment 'Employee identifier of the restaurant manager or BOH staff member who inspected and accepted the delivery. Links to Workday HCM employee master.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the restaurant manager or BOH staff member who inspected and accepted the delivery. Links to Workday HCM employee master.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Receiving Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit receiving the goods. Links to restaurant operations master data.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:receivingUnitId rdf:type rdf:Property ;
    rdfs:label 'Receiving Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit receiving the goods. Links to restaurant operations master data.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.replenishment_order. Business justification: A receiving_order is the physical fulfillment event for a replenishment_order. Linking receiving_order.replenishment_order_id → replenishment_order.replenishment_order_id closes the procurement loop: ' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:daysVariance rdf:type rdf:Property ;
    rdfs:label 'Days Variance' ;
    rdfs:comment 'Calculated difference in days between expected and actual delivery date. Positive values indicate late delivery; negative values indicate early delivery. Used for supplier scorecard.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Calendar date when the goods were delivered to the restaurant unit. Used for inventory aging and FIFO tracking.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Packing slip or delivery note number provided by the supplier. Cross-reference document for reconciliation and dispute resolution.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Time' ;
    rdfs:comment 'Precise timestamp when the delivery was received at the restaurant Back of House (BOH). Critical for temperature control compliance and HACCP documentation.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryTimeliness rdf:type rdf:Property ;
    rdfs:label 'Delivery Timeliness' ;
    rdfs:comment 'Classification of delivery punctuality relative to expected delivery date. On Time: within agreed window; Early: before window; Late: after window. Key supplier performance indicator.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver who delivered the goods. Captured for traceability and food safety audit trail per HACCP requirements.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Scheduled delivery date from the original purchase order. Used to calculate delivery timeliness and supplier on-time performance metrics.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postedToInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Inventory Flag' ;
    rdfs:comment 'Boolean indicator that received goods have been posted to restaurant unit inventory in MarketMan and SAP S/4HANA. True when goods receipt is complete and stock levels updated.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedToInventoryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted To Inventory Timestamp' ;
    rdfs:comment 'Timestamp when the receiving transaction was posted to inventory system. Used for inventory valuation date and FIFO/LIFO costing.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Result' ;
    rdfs:comment 'Overall quality assessment result for the received goods. Approved: meets standards; Rejected: fails quality criteria; Conditional: accepted with notes; Not Inspected: visual check only. Aligns with Good Manufacturing Practice (GMP) standards.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityNotes rdf:type rdf:Property ;
    rdfs:label 'Quality Notes' ;
    rdfs:comment 'Free-text notes captured by receiving manager regarding product quality, packaging condition, or other observations. Used for supplier feedback and continuous improvement.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNumber rdf:type rdf:Property ;
    rdfs:label 'Receiving Number' ;
    rdfs:comment 'Business-facing unique receiving document number generated by MarketMan or restaurant POS system. Format: RCV-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingStatus rdf:type rdf:Property ;
    rdfs:label 'Receiving Status' ;
    rdfs:comment 'Current lifecycle status of the receiving transaction. Pending: awaiting inspection; Partial: some items received; Complete: fully received and accepted; Rejected: delivery refused; Disputed: discrepancy under review.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation if receiving status is rejected. Captures specific food safety, quality, or compliance failure that led to refusal of delivery. Required for FDA and HACCP audit trail.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntegrityCheck rdf:type rdf:Property ;
    rdfs:label 'Seal Integrity Check' ;
    rdfs:comment 'Verification that tamper-evident seals on delivery containers were intact upon arrival. Intact: seal unbroken; Broken: potential contamination risk; Not Applicable: no seal required. Part of food safety protocol.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Legal or trade name of the supplier or distributor. Denormalized for reporting convenience; authoritative source is supplier master.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCheckResult rdf:type rdf:Property ;
    rdfs:label 'Temperature Check Result' ;
    rdfs:comment 'Result of temperature verification for refrigerated and frozen goods upon delivery. Pass: within safe range; Fail: out of range, reject or quarantine; Not Applicable: ambient goods. Critical for HACCP and FDA compliance.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRecorded rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded' ;
    rdfs:comment 'Actual temperature reading in Fahrenheit recorded during delivery inspection for refrigerated or frozen items. Null for ambient goods. Used for food safety audit trail.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalItemsOrdered rdf:type rdf:Property ;
    rdfs:label 'Total Items Ordered' ;
    rdfs:comment 'Total count of distinct Stock Keeping Units (SKUs) listed on the originating purchase order. Used for completeness verification.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalItemsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Items Received' ;
    rdfs:comment 'Total count of distinct SKUs actually received and accepted in this transaction. Variance from total_items_ordered triggers partial or disputed status.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReceivedValue rdf:type rdf:Property ;
    rdfs:label 'Total Received Value' ;
    rdfs:comment 'Total monetary value of all goods received in this transaction, in local currency. Used for Cost of Goods Sold (COGS) calculation and variance analysis against PO.' ;
    rdfs:domain ind:ReceivingOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Boolean indicator that quantity or value variance exists between PO and received goods. True triggers exception workflow for manager review and supplier follow-up.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Categorized reason for any discrepancy between ordered and received goods. Used for supplier performance tracking and root cause analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCountId rdf:type rdf:Property ;
    rdfs:label 'Physical Count Id' ;
    rdfs:comment 'Unique identifier for the physical inventory count event. Primary key.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalCount .

ind:glJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Entry Id' ;
    rdfs:comment 'Reference to the General Ledger journal entry created to record the inventory variance from this physical count.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:primaryPhysicalInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Initiated By Employee Id' ;
    rdfs:comment 'Reference to the employee who initiated or started the physical count event.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPhysicalRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Physical Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where the physical count was performed.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:recountOfCountId rdf:type rdf:Property ;
    rdfs:label 'Recount Of Count Id' ;
    rdfs:comment 'Reference to the original physical count ID if this count is a recount or correction of a previous count event.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalCount .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The actual date and time when the physical count was completed and submitted.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time when the physical count was started by the counting team.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time when the physical count was cancelled or voided, if applicable.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countDate rdf:type rdf:Property ;
    rdfs:label 'Count Date' ;
    rdfs:comment 'The calendar date on which the physical inventory count was conducted.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'The method used to perform the physical count: manual (paper-based or manual entry), barcode-scan (handheld scanner), rfid (radio-frequency identification), or hybrid (combination of methods).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the physical count event, formatted as PC-YYYYMMDD-NNNN for external reference and audit trail.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countPeriod rdf:type rdf:Property ;
    rdfs:label 'Count Period' ;
    rdfs:comment 'The daypart or shift during which the count was performed, aligned with restaurant operating periods.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the count event: scheduled (planned but not started), in-progress (counting underway), submitted (completed awaiting approval), approved (validated by manager), posted (applied to inventory system), or cancelled (voided).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Classification of the count event: full (complete inventory), spot-check (random sample), cycle-count (scheduled rotation), pre-close (before period end), post-close (after period end), or opening (new restaurant opening).' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPeriodEndCount rdf:type rdf:Property ;
    rdfs:label 'Is Period End Count' ;
    rdfs:comment 'Boolean flag indicating whether this count is a mandatory period-end count for financial close and COGS% (Cost of Goods Sold Percentage) calculation. True if period-end count, False otherwise.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Physical Inventory Value' ;
    rdfs:comment 'The total dollar value of inventory based on the physical count results, calculated by multiplying counted quantities by unit costs.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedToGlTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Timestamp' ;
    rdfs:comment 'The date and time when the count variance was posted to the General Ledger (GL) for financial reporting, typically after approval.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a recount is required due to excessive variance or data quality issues. True if recount needed, False otherwise.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The planned date and time when the physical count was scheduled to begin.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time when the physical count was submitted for approval after completion.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemInventoryValue rdf:type rdf:Property ;
    rdfs:label 'System Inventory Value' ;
    rdfs:comment 'The total dollar value of inventory according to the system (MarketMan) at the time of count, used as the baseline for variance calculation.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSkuCounted rdf:type rdf:Property ;
    rdfs:label 'Total Sku Counted' ;
    rdfs:comment 'The total number of unique SKUs (Stock Keeping Units) that were physically counted during this count event.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkuWithVariance rdf:type rdf:Property ;
    rdfs:label 'Total Sku With Variance' ;
    rdfs:comment 'The number of SKUs that showed a variance (difference) between system inventory and physical count.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'The total dollar value variance between system inventory and physical count results, calculated as (physical count value - system inventory value). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVariancePercentage rdf:type rdf:Property ;
    rdfs:label 'Total Variance Percentage' ;
    rdfs:comment 'The total variance expressed as a percentage of system inventory value, calculated as (variance amount / system inventory value) * 100. Key metric for COGS% (Cost of Goods Sold Percentage) analysis and food cost control.' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Primary reason code for inventory variance: theft (shrinkage), spoilage (expired/damaged), waste (prep waste), receiving-error (incorrect receipt), transfer-error (incorrect transfer), system-error (data entry mistake), or unknown. [ENUM-REF-CANDIDATE: theft|spoilage|waste|receiving-error|transfer-error|system-error|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PhysicalCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogId rdf:type rdf:Property ;
    rdfs:label 'Waste Log Id' ;
    rdfs:comment 'Unique identifier for the waste log entry. Primary key.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteLog .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.foodsafety_corrective_action. Business justification: When a food safety corrective action mandates disposal of non-compliant stock (temperature exceedance, contamination), the resulting waste event must be traceable to that corrective action for HACCP c' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:healthInspectionId rdf:type rdf:Property ;
    rdfs:label 'Health Inspection Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.health_inspection. Business justification: Health inspectors can mandate immediate disposal of food items during an inspection. Linking waste_log to health_inspection provides regulatory traceability — health departments and operators need to ' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthInspection .

ind:primaryWasteRecordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Recorded By Employee Id' ;
    rdfs:comment 'Identifier of the employee who recorded the waste event in the system.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWasteRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where the waste event occurred.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:wasteGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Waste Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Posts waste expense to a designated GL account for waste cost reporting and profitability analysis.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The production or receiving batch identifier for the wasted item, used for traceability and food safety compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of any corrective action implemented to prevent recurrence of this type of waste.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpViolation rdf:type rdf:Property ;
    rdfs:label 'Haccp Violation' ;
    rdfs:comment 'Indicates whether the waste event was associated with a HACCP critical control point violation.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managerApproved rdf:type rdf:Property ;
    rdfs:label 'Manager Approved' ;
    rdfs:comment 'Indicates whether a manager has reviewed and approved this waste log entry.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onHandQuantityBeforeWaste rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity Before Waste' ;
    rdfs:comment 'The inventory quantity on hand immediately before the waste event was recorded.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parLevelAtWaste rdf:type rdf:Property ;
    rdfs:label 'Par Level At Waste' ;
    rdfs:comment 'The PAR level setting for this item at the time of waste, used to analyze whether overstocking contributed to waste.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleStation rdf:type rdf:Property ;
    rdfs:label 'Responsible Station' ;
    rdfs:comment 'The operational area where the waste occurred: BOH (Back of House - kitchen/prep areas) or FOH (Front of House - service/dining areas).' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtWaste rdf:type rdf:Property ;
    rdfs:label 'Temperature At Waste' ;
    rdfs:comment 'The temperature in Fahrenheit of the item or storage area at the time of waste, relevant for food safety and spoilage analysis.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'The classification of the waste event: spoilage (deterioration), overproduction (excess prepared food), prep-loss (trimming/cooking loss), expiration (past use-by date), quality-reject (failed quality standards), theft-unknown (unexplained loss).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCost rdf:type rdf:Property ;
    rdfs:label 'Waste Cost' ;
    rdfs:comment 'The monetary cost of the wasted item in the restaurant\'s operating currency, calculated as quantity times unit cost.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDate rdf:type rdf:Property ;
    rdfs:label 'Waste Date' ;
    rdfs:comment 'The calendar date on which the waste event occurred.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wastePreventionOpportunity rdf:type rdf:Property ;
    rdfs:label 'Waste Prevention Opportunity' ;
    rdfs:comment 'Notes on potential process improvements or training opportunities identified from this waste event.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity' ;
    rdfs:comment 'The numeric quantity of the item wasted, measured in the unit of measure specified.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteReason rdf:type rdf:Property ;
    rdfs:label 'Waste Reason' ;
    rdfs:comment 'Free-text description providing additional context and specific reason for the waste event.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waste Timestamp' ;
    rdfs:comment 'The precise date and time when the waste event was recorded.' ;
    rdfs:domain ind:WasteLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'Unique identifier for the stock transfer transaction. Primary key for the stock transfer record.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Destination Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit or distribution center receiving the transferred inventory. For intra-unit transfers, this is the same as origin unit.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:destinationStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Stock Location Id' ;
    rdfs:comment 'Reference to the specific storage location (walk-in cooler, dry storage, freezer) within the destination unit where items will be received. Critical for BOH (Back of House) inventory accuracy.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:originRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Origin Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit or distribution center from which inventory is being transferred. For intra-unit transfers, this is the same as destination unit.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:originStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Origin Stock Location Id' ;
    rdfs:comment 'Reference to the specific storage location (walk-in cooler, dry storage, freezer) within the origin unit from which items are being transferred. Critical for BOH (Back of House) inventory accuracy.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:primaryStockRequestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Requested By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically kitchen manager or shift supervisor) who initiated the stock transfer request. Used for accountability and audit trail.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryStockReceivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Stock Received By Employee Id' ;
    rdfs:comment 'Reference to the employee at the destination unit who physically received and confirmed the transferred inventory. Null until transfer is received.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the stock transfer was cancelled. Null if transfer was not cancelled.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transportation carrier or delivery service used for inter-unit transfers. Null for intra-unit transfers or self-pickup.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTransferReference rdf:type rdf:Property ;
    rdfs:label 'External Transfer Reference' ;
    rdfs:comment 'Unique identifier from the source operational system (MarketMan, SAP MM). Used for data lineage, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Haccp Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether this transfer requires continuous temperature monitoring and documentation per HACCP critical control point protocols. True for high-risk perishable items.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes from quality inspection documenting any issues, observations, or conditions. Used for quality tracking and supplier performance evaluation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether items in this transfer require formal quality inspection upon receipt per GMP (Good Manufacturing Practice) or food safety protocols. True for high-value or high-risk items.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Result of quality inspection at receiving: not-required (no inspection needed), pending (awaiting inspection), passed (accepted), failed (rejected), conditional-accept (accepted with notes or partial rejection).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Method used to transport inventory between locations: internal-delivery (company fleet), courier (contracted delivery service), third-party (3PD logistics provider), self-pickup (destination unit retrieves), direct-transfer (hand-carried for intra-unit).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this transfer requires temperature-controlled transportation to maintain food safety and quality. True for perishable items requiring refrigeration or freezing per HACCP (Hazard Analysis Critical Control Points) standards.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureZoneRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone Required' ;
    rdfs:comment 'Required temperature zone for transport: ambient (room temperature), refrigerated (33-40°F), frozen (0°F or below), multi-temp (mixed temperature requirements). Critical for HACCP compliance and food safety.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Item Count' ;
    rdfs:comment 'Total number of distinct SKU (Stock Keeping Unit) line items included in this transfer. Used for transfer complexity assessment and receiving workload planning.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalQuantityTransferred rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Transferred' ;
    rdfs:comment 'Aggregate quantity of all items transferred, summed across all line items. Unit of measure varies by item (cases, pounds, gallons, each). Used for high-level transfer volume tracking.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTransferValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Transfer Value Usd' ;
    rdfs:comment 'Total dollar value of all items included in this stock transfer, calculated at standard cost. Critical for COGS% (Cost of Goods Sold Percentage) tracking and inventory valuation across units.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment tracking number provided by carrier for monitoring in-transit status. Null for internal transfers without formal tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Business-facing unique transfer document number used for tracking and reference in operational systems and communications. Format: STR-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Code' ;
    rdfs:comment 'Business reason for initiating the stock transfer: par-replenishment (restore PAR levels), excess-stock (reduce overstock), expiring-soon (move near-expiry items), quality-issue (return defective goods), menu-change (redistribute due to menu update), seasonal-adjustment (rebalance for seasonal demand).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for the transfer. Used for operational communication and audit documentation.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Received Date' ;
    rdfs:comment 'Date when the inventory was physically received and confirmed at the destination location. Null until transfer is fully or partially received.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferRequestDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Request Date' ;
    rdfs:comment 'Date when the stock transfer was initially requested. Used for tracking lead times and transfer cycle analytics.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferShipDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Ship Date' ;
    rdfs:comment 'Date when the inventory physically left the origin location. Used for in-transit tracking and speed of service metrics.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the stock transfer: requested (initiated but pending approval), approved (authorized for execution), rejected (denied by approver), in-transit (shipped but not yet received), received (fully received and confirmed), cancelled (voided before completion), partially-received (some items received, others pending). [ENUM-REF-CANDIDATE: requested|approved|rejected|in-transit|received|cancelled|partially-received — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer based on origin and destination: inter-unit (between restaurant units), intra-unit (between storage locations within same unit), return-to-dc (from unit back to distribution center), return-to-vendor (from unit back to supplier), emergency (urgent replenishment), rebalance (inventory optimization transfer).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryReplenishmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Replenishment Employee Id' ;
    rdfs:comment 'Reference to the user (manager or approver) who approved the replenishment order. Null if approval not required or still pending.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryReplenishmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Replenishment Employee Id' ;
    rdfs:comment 'Reference to the user (manager or approver) who approved the replenishment order. Null if approval not required or still pending.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:receivingUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving User Employee Id' ;
    rdfs:comment 'Reference to the user (typically BOH manager or receiving clerk) who received and verified the replenishment order delivery at the restaurant unit.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryReplenishmentCancelledByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Replenishment Cancelled By User Employee Id' ;
    rdfs:comment 'Reference to the user who cancelled the replenishment order. Used for audit trail and accountability.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryReplenishmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Replenishment Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the replenishment order. For auto-PAR orders, may reference system user account.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the replenishment order was received at the restaurant unit. Used for supplier performance tracking and variance analysis.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was cancelled. Used for order lifecycle tracking and supplier performance analysis.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'Supplier-confirmed date for delivery of the replenishment order. May differ from requested date based on supplier availability.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the replenishment order was created or initiated. Business event date for order placement.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business-facing unique order number for tracking and reference. Format: RO-YYYYMMDD-XXXXXX where YYYYMMDD is order date and XXXXXX is sequence.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderSource rdf:type rdf:Property ;
    rdfs:label 'Order Source' ;
    rdfs:comment 'System or channel that originated the replenishment order. Identifies whether order was auto-generated by MarketMan, manually created by manager, or triggered by integrated system.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was physically received and logged into inventory at the restaurant unit. Triggers inventory update and AP invoice matching.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which the restaurant unit requests delivery of the replenishment order. Used for planning and scheduling.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingFee rdf:type rdf:Property ;
    rdfs:label 'Shipping Fee' ;
    rdfs:comment 'Delivery or freight charge for the replenishment order in USD. May be waived based on minimum order value or supplier agreement.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the replenishment order was submitted to the supplier. Marks transition from draft to active order.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierOrderReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Order Reference' ;
    rdfs:comment 'Supplier-provided order confirmation number or reference. Used for cross-referencing with supplier systems and delivery documentation.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'Final total amount payable for the replenishment order in USD, including order value, tax, and shipping fees. Used for AP invoice reconciliation.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValue rdf:type rdf:Property ;
    rdfs:label 'Total Order Value' ;
    rdfs:comment 'Total monetary value of the replenishment order in USD, including all line items before tax and fees. Used for budget tracking and COGS calculation.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Detailed notes describing any discrepancies found during receiving. Includes short shipments, damaged goods, wrong items, or quality issues. Used for supplier dispute resolution.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the inventory adjustment record. Primary key.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentApprovedByManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Approved By Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Employee Id' ;
    rdfs:comment 'Reference to the manager or supervisor who reviewed and approved the inventory adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInventoryAdjustedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Adjusted By Employee Id' ;
    rdfs:comment 'Reference to the employee who initiated and recorded the inventory adjustment transaction.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInventoryPhysicalCountId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Physical Count Id' ;
    rdfs:comment 'Reference to the physical inventory count record that triggered this adjustment, if the adjustment resulted from a count reconciliation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PhysicalCount .

ind:reversalAdjustmentInventoryAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversal Adjustment Inventory Adjustment Id' ;
    rdfs:comment 'Reference to the adjustment record that reversed this adjustment, if applicable.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The quantity of inventory adjusted, expressed in the stock item\'s unit of measure. Positive values indicate increases to on-hand inventory; negative values indicate decreases.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentDate rdf:type rdf:Property ;
    rdfs:label 'Adjustment Date' ;
    rdfs:comment 'The business date on which the inventory adjustment was recorded and applied to on-hand balances.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the inventory adjustment transaction. Format: ADJ-YYYYMMDD-NNNNNN.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The precise date and time when the inventory adjustment transaction was recorded in the system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the inventory adjustment indicating the nature of the non-standard inventory movement (positive adjustment, negative adjustment, write-off, theft, breakage, spoilage, system correction, transfer correction, count reconciliation, damaged goods, expired product, vendor credit). [ENUM-REF-CANDIDATE: positive adjustment|negative adjustment|write-off|theft|breakage|spoilage|system correction|transfer correction|count reconciliation|damaged goods|expired product|vendor credit — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'The total monetary value of the inventory adjustment, calculated as adjusted quantity multiplied by unit cost. Positive values increase inventory asset value; negative values decrease it.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactsCogs rdf:type rdf:Property ;
    rdfs:label 'Impacts Cogs' ;
    rdfs:comment 'Indicates whether this inventory adjustment impacts the restaurant unit\'s Cost of Goods Sold (COGS) percentage calculation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether this inventory adjustment has been reversed by a subsequent correcting adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isShrinkage rdf:type rdf:Property ;
    rdfs:label 'Is Shrinkage' ;
    rdfs:comment 'Indicates whether this adjustment represents inventory shrinkage (unexplained loss, theft, or discrepancy between physical count and system records).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onHandQuantityAfter rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity After' ;
    rdfs:comment 'The on-hand inventory quantity for this stock item at this location immediately after the adjustment was applied.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onHandQuantityBefore rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity Before' ;
    rdfs:comment 'The on-hand inventory quantity for this stock item at this location immediately before the adjustment was applied.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Approval' ;
    rdfs:comment 'Indicates whether this adjustment type or value threshold requires manager approval before being applied to inventory balances.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference number or identifier for supporting documentation (e.g., incident report number, physical count sheet ID, vendor credit memo number, manager approval form) that justifies the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureAtAdjustmentF rdf:type rdf:Property ;
    rdfs:label 'Temperature At Adjustment F' ;
    rdfs:comment 'The recorded storage temperature in Fahrenheit at the time of adjustment, relevant for temperature-related spoilage or HACCP compliance documentation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodCostPeriodId rdf:type rdf:Property ;
    rdfs:label 'Food Cost Period Id' ;
    rdfs:comment 'Unique identifier for the food cost period record. Primary key for this entity.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborBudgetId rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_budget. Business justification: Prime cost reporting (food cost % + labor cost %) is the foundational P&L metric in foodservice operations. Linking food_cost_period directly to the corresponding labor_budget for the same unit and pe' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborBudget .

ind:primaryFoodEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Food Employee Id' ;
    rdfs:comment 'Identifier of the user who closed and finalized this food cost period. Typically a restaurant manager or accounting staff member.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:salesReportId rdf:type rdf:Property ;
    rdfs:label 'Sales Report Id' ;
    rdfs:comment 'Foreign key linking to franchise.sales_report. Business justification: Food cost percentage is calculated using sales revenue from the franchisee\'s submitted sales report. Linking food_cost_period to the specific sales_report used as the revenue denominator enables audit' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesReport .

ind:tertiaryFoodEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Food Employee Id' ;
    rdfs:comment 'Identifier of the user who closed and finalized this food cost period. Typically a restaurant manager or accounting staff member.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualFoodCost rdf:type rdf:Property ;
    rdfs:label 'Actual Food Cost' ;
    rdfs:comment 'The actual Cost of Goods Sold (COGS) for the period, calculated as: Opening Inventory + Purchases + Transfers In - Transfers Out - Closing Inventory. The real food cost incurred.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beverageSalesRevenue rdf:type rdf:Property ;
    rdfs:label 'Beverage Sales Revenue' ;
    rdfs:comment 'The total beverage sales revenue for the period. Tracked separately from food sales for category-specific cost analysis.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when this food cost period was officially closed and calculations were finalized. Marks the completion of the period-close process.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closingInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Closing Inventory Value' ;
    rdfs:comment 'The total dollar value of food inventory on hand at the end of the period, determined by physical count or perpetual inventory system. Represents the ending stock value for COGS calculation.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPercentActual rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent Actual' ;
    rdfs:comment 'The actual food cost as a percentage of food sales revenue for the period. Key performance metric for restaurant profitability and cost control. Calculated as (Actual Food Cost / Food Sales Revenue) * 100.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPercentTheoretical rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent Theoretical' ;
    rdfs:comment 'The theoretical food cost as a percentage of food sales revenue for the period. Represents the ideal COGS% if all operational standards were met. Calculated as (Theoretical Food Cost / Food Sales Revenue) * 100.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodSalesRevenue rdf:type rdf:Property ;
    rdfs:label 'Food Sales Revenue' ;
    rdfs:comment 'The total food sales revenue (excluding beverage) for the period. Used as the denominator in COGS% calculations. Sourced from Point of Sale (POS) system.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Opening Inventory Value' ;
    rdfs:comment 'The total dollar value of food inventory on hand at the beginning of the period. Represents the starting stock value for Cost of Goods Sold (COGS) calculation.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The last date of the accounting period for which food costs are being calculated. Marks the close of the cost accumulation window.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'The accounting period identifier in format YYYY-PNN (e.g., 2024-P01 for period 1 of 2024). Used for financial reporting alignment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The first date of the accounting period for which food costs are being calculated. Marks the beginning of the cost accumulation window.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'The current status of the food cost period: open (still accepting transactions), closed (period ended, calculations complete), locked (finalized, no further changes allowed), or under_review (being audited or reviewed).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'The frequency type of the accounting period for food cost calculation (weekly, bi-weekly, monthly, or quarterly).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasesValue rdf:type rdf:Property ;
    rdfs:label 'Purchases Value' ;
    rdfs:comment 'The total dollar value of all food and beverage purchases received during the period. Includes all vendor invoices posted to inventory during the period.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:theoreticalFoodCost rdf:type rdf:Property ;
    rdfs:label 'Theoretical Food Cost' ;
    rdfs:comment 'The calculated ideal food cost based on recipe costing and actual sales mix (PMIX). Represents what food cost should have been if all recipes were followed perfectly with no waste or theft.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSalesRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Sales Revenue' ;
    rdfs:comment 'The combined food and beverage sales revenue for the period. Represents total top-line revenue for the restaurant unit during the period.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transfersInValue rdf:type rdf:Property ;
    rdfs:label 'Transfers In Value' ;
    rdfs:comment 'The total dollar value of inventory transferred into this restaurant unit from other locations during the period. Increases available inventory.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transfersOutValue rdf:type rdf:Property ;
    rdfs:label 'Transfers Out Value' ;
    rdfs:comment 'The total dollar value of inventory transferred out of this restaurant unit to other locations during the period. Decreases available inventory.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The dollar difference between actual food cost and theoretical food cost (Actual - Theoretical). Positive variance indicates higher-than-expected costs due to waste, theft, portioning errors, or recipe non-compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Percent' ;
    rdfs:comment 'The variance expressed as a percentage of theoretical food cost. Calculated as (Variance Amount / Theoretical Food Cost) * 100. Used to assess the magnitude of cost control issues.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteValue rdf:type rdf:Property ;
    rdfs:label 'Waste Value' ;
    rdfs:comment 'The total dollar value of food waste recorded during the period, including spoilage, expiration, preparation errors, and quality control discards. Tracked for Waste% calculation and food cost control.' ;
    rdfs:domain ind:FoodCostPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseUomId rdf:type rdf:Property ;
    rdfs:label 'Base Uom Id' ;
    rdfs:comment 'Reference to the base UOM for this measurement type. Used to establish conversion chains. Null if this UOM is itself the base unit.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Short form or symbol for the UOM (e.g., lb, oz, gal, kg, g, ml). Used in compact displays, labels, and Kitchen Display System (KDS) screens.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowsFractionalQuantities rdf:type rdf:Property ;
    rdfs:label 'Allows Fractional Quantities' ;
    rdfs:comment 'Indicates whether fractional quantities are permitted for this UOM (e.g., 2.5 pounds allowed, but 2.5 cases may not be). Enforces business rules in inventory transactions and recipe scaling.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsTemperatureTracking rdf:type rdf:Property ;
    rdfs:label 'Allows Temperature Tracking' ;
    rdfs:comment 'Indicates whether items measured in this UOM require Hazard Analysis Critical Control Points (HACCP) temperature monitoring during storage and transfer. Supports food safety compliance per Food and Drug Administration (FDA) regulations.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableItemCategories rdf:type rdf:Property ;
    rdfs:label 'Applicable Item Categories' ;
    rdfs:comment 'Comma-separated list of Stock Keeping Unit (SKU) categories or commodity types where this UOM is applicable (e.g., dry goods, produce, dairy, beverages, proteins). Supports context-aware UOM selection in ordering and recipe management.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFactorToBase rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor To Base' ;
    rdfs:comment 'Multiplier to convert this UOM to the base UOM (e.g., 1 pound = 453.592 grams, so conversion_factor_to_base = 453.592). Critical for accurate Cost of Goods Sold (COGS%) calculation and yield management across ordering, storage, and recipe contexts.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultShelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Default Shelf Life Days' ;
    rdfs:comment 'Default shelf life in days for items measured in this UOM. Used as a fallback when Stock Keeping Unit (SKU)-specific shelf life is not defined. Supports waste tracking (Waste%) and First In First Out (FIFO) rotation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBaseUom rdf:type rdf:Property ;
    rdfs:label 'Is Base Uom' ;
    rdfs:comment 'Indicates whether this UOM is the base unit for its type (e.g., gram for weight, milliliter for volume). Base UOMs have a conversion factor of 1.0 and serve as the reference for all conversions within their type.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemStandard rdf:type rdf:Property ;
    rdfs:label 'Is System Standard' ;
    rdfs:comment 'Indicates whether this UOM is a system-defined standard (e.g., gram, liter, each) that cannot be modified or deleted by users. Protects core reference data integrity.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCode rdf:type rdf:Property ;
    rdfs:label 'Iso Code' ;
    rdfs:comment 'ISO 80000 standard code for the unit of measure. Supports international operations and regulatory compliance across multiple jurisdictions.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingUomFlag rdf:type rdf:Property ;
    rdfs:label 'Ordering Uom Flag' ;
    rdfs:comment 'Indicates whether this UOM is used in purchase orders and vendor ordering (e.g., case, pallet). Supports procurement workflows and vendor catalog integration.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pluralName rdf:type rdf:Property ;
    rdfs:label 'Plural Name' ;
    rdfs:comment 'Plural form of the UOM name (e.g., Pounds, Ounces, Cases). Supports grammatically correct reporting and user interface text generation.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precisionDecimalPlaces rdf:type rdf:Property ;
    rdfs:label 'Precision Decimal Places' ;
    rdfs:comment 'Number of decimal places to use when displaying or calculating quantities in this UOM. Ensures consistent rounding and precision across inventory transactions.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipeUomFlag rdf:type rdf:Property ;
    rdfs:label 'Recipe Uom Flag' ;
    rdfs:comment 'Indicates whether this UOM is used in recipe Bill of Materials (BOM) and menu item costing (e.g., ounce, gram, tablespoon). Critical for accurate recipe yield management and menu engineering.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLotTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Lot Tracking' ;
    rdfs:comment 'Indicates whether items measured in this UOM require lot number and expiration date tracking for traceability. Supports food safety recalls and Good Manufacturing Practice (GMP) compliance.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageUomFlag rdf:type rdf:Property ;
    rdfs:label 'Storage Uom Flag' ;
    rdfs:comment 'Indicates whether this UOM is used for Back of House (BOH) inventory storage and stock tracking (e.g., each, bag, box). Supports Periodic Automatic Replenishment (PAR) level management and cycle counts.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:symbol rdf:type rdf:Property ;
    rdfs:label 'Symbol' ;
    rdfs:comment 'Standard international symbol for the UOM (e.g., °F, °C, %, #). Used in scientific and regulatory contexts, particularly for Hazard Analysis Critical Control Points (HACCP) temperature monitoring.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unCefactCode rdf:type rdf:Property ;
    rdfs:label 'Un Cefact Code' ;
    rdfs:comment 'Standardized UN/CEFACT Recommendation 20 code for the unit of measure. Supports Electronic Data Interchange (EDI) integration with suppliers and third-party logistics providers.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCategory rdf:type rdf:Property ;
    rdfs:label 'Uom Category' ;
    rdfs:comment 'Measurement system category (metric, imperial, count-based, or custom). Supports multi-region operations with different measurement standards.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'Short alphanumeric code representing the unit of measure (e.g., EA, CS, LB, OZ, GAL, KG, G, ML, L). Used as the business identifier in inventory transactions and recipe management.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomName rdf:type rdf:Property ;
    rdfs:label 'Uom Name' ;
    rdfs:comment 'Full descriptive name of the unit of measure (e.g., Each, Case, Pound, Ounce, Gallon, Kilogram, Gram, Milliliter, Liter). Human-readable label for reporting and user interfaces.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomStatus rdf:type rdf:Property ;
    rdfs:label 'Uom Status' ;
    rdfs:comment 'Current lifecycle status of the UOM. Active UOMs are available for use in transactions; deprecated UOMs are retained for historical data but not available for new transactions.' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uomType rdf:type rdf:Property ;
    rdfs:label 'Uom Type' ;
    rdfs:comment 'Classification of the unit of measure by dimension type. Determines conversion logic and applicability to different inventory contexts (receiving, storage, recipe). [ENUM-REF-CANDIDATE: weight|volume|count|length|area|temperature|time — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Uom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemId rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Id' ;
    rdfs:comment 'Unique identifier for the vendor item mapping record. Primary key.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expenseGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Expense Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Maps vendor items to expense GL accounts for automated AP posting and cost tracking.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:managedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Managed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Vendor item master management is a named procurement process: a purchasing/category manager employee owns each vendor item record, negotiating pricing and preferred vendor status. Foodservice procurem' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:orderUomId rdf:type rdf:Property ;
    rdfs:label 'Order Uom Id' ;
    rdfs:comment 'Foreign key linking to inventory.uom. Business justification: vendor_item.order_uom is a STRING column denoting the unit of measure used when ordering from this vendor. The uom table is the authoritative UOM reference master. Adding order_uom_id FK (prefixed \'or' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uom .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'The date when the contract pricing becomes effective for this vendor item.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'The date when the contract pricing expires for this vendor item.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference number of the procurement contract governing this vendor item pricing, if applicable.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Price Flag' ;
    rdfs:comment 'Indicates whether the unit cost is based on a negotiated contract (True) or spot pricing (False).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where this item is produced or sourced by the vendor. [ENUM-REF-CANDIDATE: USA|CAN|MEX|CHN|BRA|ARG|AUS|NZL|GBR|FRA|DEU|ITA|ESP|JPN|KOR|THA|VNM|IND — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Business reason for deactivating this vendor item mapping (e.g., vendor discontinued, better pricing found, quality issues).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCostUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Update Date' ;
    rdfs:comment 'The date when the unit cost for this vendor item was last updated.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'The most recent date when this item was ordered from this vendor.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The manufacturer\'s unique part or item number for this product.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity (in order UOM) that must be ordered from this vendor for this item.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Cost Review Date' ;
    rdfs:comment 'The scheduled date for the next cost review or renegotiation with this vendor for this item.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryPercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Percent' ;
    rdfs:comment 'Percentage of orders for this vendor item that were delivered within the promised lead time window.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderIncrement rdf:type rdf:Property ;
    rdfs:label 'Order Increment' ;
    rdfs:comment 'The quantity increment (in order UOM) in which this item must be ordered (e.g., must order in multiples of 5).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packQuantity rdf:type rdf:Property ;
    rdfs:label 'Pack Quantity' ;
    rdfs:comment 'The number of individual packs or units contained in one order UOM (e.g., 12 cans per case, 4 bags per box).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'The size or weight of each individual pack or unit within the order UOM (e.g., \'5 LB\', \'12 OZ\', \'1 GAL\').' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred supplier for this stock item (True) or an alternate source (False).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Quality score for this vendor\'s supply of this item, typically on a scale of 0.00 to 5.00, based on receiving inspections and quality audits.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorBrandName rdf:type rdf:Property ;
    rdfs:label 'Vendor Brand Name' ;
    rdfs:comment 'The brand name under which the vendor supplies this item, if applicable.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemDescription rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Description' ;
    rdfs:comment 'Detailed description of the item from the vendor\'s catalog, including specifications, grade, or quality attributes.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemName rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Name' ;
    rdfs:comment 'The supplier\'s product name or description for this item as it appears in their catalog.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorItemStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Item Status' ;
    rdfs:comment 'Current status of this vendor item mapping in the system lifecycle.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Vendor Priority Rank' ;
    rdfs:comment 'Numeric ranking of this vendor for this item when multiple vendors supply the same SKU (1=first choice, 2=second choice, etc.).' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorProductCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Product Category' ;
    rdfs:comment 'The vendor\'s classification or category for this item in their catalog structure.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSku rdf:type rdf:Property ;
    rdfs:label 'Vendor Sku' ;
    rdfs:comment 'The supplier\'s unique item code or SKU for this product. Used in purchase orders and receiving documents.' ;
    rdfs:domain ind:VendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Needed for assigning a dedicated employee to manage high-value members, enabling personalized service and performance reporting.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Acquisition Campaign Attribution report requires linking each new member to the marketing campaign that drove the sign-up, enabling ROI calculation of acquisition spend.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:currentTierId rdf:type rdf:Property ;
    rdfs:label 'Current Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: member.current_tier is a denormalized STRING storing the tier name/code. Replacing it with a FK to the tier reference catalog (current_tier_id -> loyalty.tier.tier_id) normalizes this relationship and' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:memberGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Member Guest Profile Id' ;
    rdfs:comment 'Foreign key reference to the guest domain master record. Links loyalty membership to the guest profile system of record.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:memberPreferredLocationUnitId rdf:type rdf:Property ;
    rdfs:label 'Member Preferred Location Unit Id' ;
    rdfs:comment 'Restaurant location that the member visits most frequently or has designated as their preferred location. Used for personalized offers and location-based campaigns.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:memberProfileId rdf:type rdf:Property ;
    rdfs:label 'Member Profile Id' ;
    rdfs:comment 'Foreign key reference to the guest domain master record. Links loyalty membership to the guest profile system of record.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:memberUnitId rdf:type rdf:Property ;
    rdfs:label 'Member Unit Id' ;
    rdfs:comment 'Restaurant location where the member enrolled, if enrollment occurred at a physical location. Null for digital enrollments.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:referredByMemberId rdf:type rdf:Property ;
    rdfs:label 'Referred By Member Id' ;
    rdfs:comment 'Member ID of the existing member who referred this member to the loyalty program. Null if member enrolled without a referral.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:accountClosureDate rdf:type rdf:Property ;
    rdfs:label 'Account Closure Date' ;
    rdfs:comment 'Date when the loyalty membership was closed or terminated. Null for active memberships. Used for retention analysis and right-to-be-forgotten compliance.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountClosureReason rdf:type rdf:Property ;
    rdfs:label 'Account Closure Reason' ;
    rdfs:comment 'Business reason for account closure. Examples: member request, fraud, inactivity, duplicate account, policy violation, data privacy request.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Created Timestamp' ;
    rdfs:comment 'Timestamp when the loyalty member record was first created in the system. Audit field for data lineage and compliance.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Updated Timestamp' ;
    rdfs:comment 'Timestamp when the loyalty member record was last modified. Audit field for data lineage and change tracking.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:badgesEarned rdf:type rdf:Property ;
    rdfs:label 'Badges Earned' ;
    rdfs:comment 'Total number of achievement badges earned by the member through gamification activities, challenges, and milestones.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:birthdayMonth rdf:type rdf:Property ;
    rdfs:label 'Birthday Month' ;
    rdfs:comment 'Month of the member\'s birthday (1-12). Stored without year or day for privacy. Used for birthday reward campaigns and personalized offers.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that the member can redeem. Calculated as lifetime earned minus lifetime redeemed minus expired points.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataPrivacyConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Date' ;
    rdfs:comment 'Date when the member provided explicit consent for data collection, processing, and storage under applicable privacy regulations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Direct Mail Opt In' ;
    rdfs:comment 'Indicates whether the member has consented to receive physical direct mail offers and communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the member has consented to receive promotional and transactional emails. True if opted in, False if opted out.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the guest enrolled in the loyalty program. OLO (Online Ordering), POS (Point of Sale), mobile app, website, in-restaurant kiosk, or call center.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the guest enrolled in the loyalty program. Marks the start of the member lifecycle.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamificationLevel rdf:type rdf:Property ;
    rdfs:label 'Gamification Level' ;
    rdfs:comment 'Current level in the loyalty program gamification system. Members progress through levels by completing challenges, earning badges, and accumulating points.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent loyalty program activity by the member, including points earned, points redeemed, or profile updates. Used for churn prediction and reactivation campaigns.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent purchase transaction where the member earned or redeemed points. Subset of last_activity_date focused on revenue-generating activity.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Total cumulative loyalty points earned by the member since enrollment. Never decreases; used for tier qualification and lifetime value analysis.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Total cumulative loyalty points redeemed by the member for rewards, discounts, or offers since enrollment.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Externally-facing unique membership identifier displayed on loyalty cards, mobile app, and customer communications. Human-readable alphanumeric code.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiration Date' ;
    rdfs:comment 'Date when the next batch of points will expire. Null if no points are scheduled to expire.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score provided by the member, ranging from 0 (detractor) to 10 (promoter). Measures member satisfaction and likelihood to recommend.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date when the most recent NPS survey was completed by the member.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pointsExpiringSoon rdf:type rdf:Property ;
    rdfs:label 'Points Expiring Soon' ;
    rdfs:comment 'Number of points scheduled to expire within the next 30 days. Used for proactive member engagement and retention campaigns.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Member\'s preferred language for communications and app interface. Three-letter ISO 639-2 language code.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty membership. Active: member in good standing. Suspended: temporarily blocked due to policy violation. Churned: member opted out or account closed. Inactive: no activity for extended period. Pending: enrollment initiated but not completed.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In' ;
    rdfs:comment 'Indicates whether the member has consented to receive push notifications through the mobile app. True if opted in, False if opted out.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Unique referral code assigned to this member for member-get-member campaigns. When shared and used by new enrollees, both parties receive bonus points.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the member has consented to receive promotional and transactional SMS text messages. True if opted in, False if opted out.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Business reason or explanation for the current program status. Examples: fraud detection, member request, inactivity, policy violation, system migration.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Date' ;
    rdfs:comment 'Date when the member accepted the loyalty program terms and conditions. Required for legal compliance and dispute resolution.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version number of the loyalty program terms and conditions that the member accepted. Format: v1.0, v2.1, etc.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingOptIn rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Opt In' ;
    rdfs:comment 'Indicates whether the member has consented to sharing their data with third-party partners for marketing purposes. True if opted in, False if opted out.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date when the member achieved or was assigned their current tier level. Used for tier anniversary calculations and renewal cycles.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiration Date' ;
    rdfs:comment 'Date when the current tier status expires and member will be re-evaluated for tier qualification. Null for lifetime tiers.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalVisits rdf:type rdf:Property ;
    rdfs:label 'Total Visits' ;
    rdfs:comment 'Total number of restaurant visits or orders placed by the member since enrollment. Includes dine-in, drive-thru, OLO, and 3PD orders where loyalty was applied.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Unique identifier for the loyalty membership tier. Primary key.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:modifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tier configuration change management requires tracking which employee modified tier thresholds, multipliers, or qualification criteria — essential for loyalty program governance and compliance audits.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual membership fee charged to maintain this tier status, if applicable. Null or zero indicates no fee. Used for premium tier monetization.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Comma-separated or structured text summary of key benefits and perks associated with this tier (e.g., free delivery, birthday rewards, exclusive offers, priority support). Used for member communications and benefit entitlement logic.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdayRewardEligible rdf:type rdf:Property ;
    rdfs:label 'Birthday Reward Eligible' ;
    rdfs:comment 'Indicates whether members in this tier receive a special birthday reward (e.g., free item, bonus points, discount). True if eligible, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Hexadecimal color code used for tier branding in digital channels (e.g., #CD7F32 for bronze, #C0C0C0 for silver, #FFD700 for gold). Used in mobile app, website, and marketing materials.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeThreshold rdf:type rdf:Property ;
    rdfs:label 'Downgrade Threshold' ;
    rdfs:comment 'Minimum threshold value required to maintain this tier status during re-evaluation period. Falling below this value triggers downgrade to lower tier. Null indicates no downgrade policy.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyAccessLto rdf:type rdf:Property ;
    rdfs:label 'Early Access Lto' ;
    rdfs:comment 'Indicates whether members in this tier receive early access to new Limited Time Offers (LTO) before general availability. True if eligible, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusiveOffersEligible rdf:type rdf:Property ;
    rdfs:label 'Exclusive Offers Eligible' ;
    rdfs:comment 'Indicates whether members in this tier receive access to exclusive promotional offers and Limited Time Offers (LTO) not available to lower tiers. True if eligible, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeDeliveryEligible rdf:type rdf:Property ;
    rdfs:label 'Free Delivery Eligible' ;
    rdfs:comment 'Indicates whether members in this tier are eligible for free delivery on Online Ordering (OLO) and Third-Party Delivery (3PD) orders. True if eligible, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after tier expiration during which members retain tier benefits before downgrade. Used to provide buffer period for re-qualification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL path to the tier badge or icon image asset used in member portal, mobile app, and digital communications. Supports tier visual identity and gamification.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRedemptionDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Max Redemption Discount Pct' ;
    rdfs:comment 'Maximum percentage discount that can be applied when redeeming points for rewards in this tier (e.g., 20.00 for 20% max discount). Used to control reward economics and prevent abuse.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'Multiplier applied to base points accrual for members in this tier (e.g., 1.0 for base, 1.5 for 50% bonus, 2.0 for double points). Used to calculate accelerated points earning.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prioritySupportEligible rdf:type rdf:Property ;
    rdfs:label 'Priority Support Eligible' ;
    rdfs:comment 'Indicates whether members in this tier receive priority customer support (e.g., dedicated phone line, faster response times). True if eligible, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Qualification Metric' ;
    rdfs:comment 'The metric used to determine tier qualification (points accrued, visit count, total spend amount, or transaction count). Defines how qualification_threshold is interpreted.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Days' ;
    rdfs:comment 'Number of days over which the qualification threshold must be met (e.g., 365 for annual qualification, 90 for quarterly). Null indicates lifetime accumulation.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Threshold' ;
    rdfs:comment 'Numeric threshold value required to qualify for this tier (e.g., 1000 points, 25 visits, $500 spend). Interpretation depends on qualification_metric.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Referral Bonus Points' ;
    rdfs:comment 'Bonus points awarded to members in this tier for each successful referral of a new loyalty program member. Used to incentivize member acquisition through word-of-mouth.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rolloverPointsAllowed rdf:type rdf:Property ;
    rdfs:label 'Rollover Points Allowed' ;
    rdfs:comment 'Indicates whether unused points can roll over to the next qualification period for members in this tier. True if rollover is allowed, false if points expire at period end.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetMemberSegment rdf:type rdf:Property ;
    rdfs:label 'Target Member Segment' ;
    rdfs:comment 'Description of the target guest segment this tier is designed to attract and retain (e.g., frequent visitors, high spenders, digital-first guests, family diners). Used for marketing strategy and program design.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier (e.g., BRONZE, SILVER, GOLD, PLATINUM). Used as business identifier in operational systems and reporting.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the tier, including value proposition, benefits summary, and marketing messaging. Used in loyalty program communications and member portal.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable display name of the loyalty tier (e.g., Bronze Member, Silver Member, Gold Member, Platinum Elite). Used in guest-facing communications and marketing materials.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier. Active tiers are available for member assignment; inactive tiers are temporarily disabled; retired tiers are no longer offered but may have legacy members; pending tiers are configured but not yet launched.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeNotification rdf:type rdf:Property ;
    rdfs:label 'Upgrade Notification' ;
    rdfs:comment 'Indicates whether members should receive automated notification when they qualify for upgrade to this tier. True if notification is enabled, false otherwise.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityDays rdf:type rdf:Property ;
    rdfs:label 'Validity Days' ;
    rdfs:comment 'Number of days a member retains this tier status after qualification before re-evaluation (e.g., 365 for annual renewal). Null indicates permanent tier assignment.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welcomeBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Welcome Bonus Points' ;
    rdfs:comment 'One-time bonus points awarded to a member upon first achieving this tier. Used to incentivize tier progression and enhance member engagement.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierHistoryId rdf:type rdf:Property ;
    rdfs:label 'Tier History Id' ;
    rdfs:comment 'Unique identifier for each tier change event in the loyalty program. Primary key for the tier history transactional audit log.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:newTierTierId rdf:type rdf:Property ;
    rdfs:label 'New Tier Tier Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier. Business justification: tier_history records every tier change event and stores new_tier_code as a STRING. Replacing this with a FK (new_tier_tier_id -> loyalty.tier.tier_id) normalizes the reference to the tier catalog for ' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:overrideAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Override Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Manual tier override authorization requires tracking which manager authorized the override — critical for fraud prevention and compliance in loyalty operations. override_authorized_by is a denormalize' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryTierRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Tier Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant location where the triggering transaction occurred. Null for tier changes not associated with a specific location (e.g., scheduled reviews, manual adjustments).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:promotionalCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign that granted this promotional tier upgrade. Null for non-promotional tier changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether this tier change was manually processed by an administrator or customer service representative rather than automatically triggered by system rules. True for manual adjustments, false for automated changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPromotionalTier rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Tier' ;
    rdfs:comment 'Indicates whether this tier change was the result of a promotional campaign or marketing offer rather than organic qualification. True for promotional upgrades, false for earned tier changes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newTierBenefitsActivatedFlag rdf:type rdf:Property ;
    rdfs:label 'New Tier Benefits Activated Flag' ;
    rdfs:comment 'Indicates whether benefits associated with the new tier were immediately activated and available for member use. Used for benefit provisioning tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the member of this tier change: email, SMS, push notification, in-app message, physical mail, or none if no notification was sent.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a tier change notification was successfully sent to the member via email, mobile app push, or other communication channel. Used for member engagement tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The date and time when the tier change notification was sent to the member. Used for communication audit and member experience analytics.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Business justification and approval notes for manual tier overrides, required for regulatory audit trails and program fairness documentation.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTierBenefitsRevokedFlag rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Benefits Revoked Flag' ;
    rdfs:comment 'Indicates whether benefits associated with the previous tier were immediately revoked upon tier change. Used for benefit lifecycle management and member experience tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousTierCode rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Code' ;
    rdfs:comment 'The loyalty tier code the member held immediately before this change event (e.g., BRONZE, SILVER, GOLD, PLATINUM).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingChannel rdf:type rdf:Property ;
    rdfs:label 'Processing Channel' ;
    rdfs:comment 'The channel through which this tier change was processed: POS (Point of Sale), OLO (Online Ordering), mobile app, web portal, call center, or admin portal. Used for channel analytics.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Period End Date' ;
    rdfs:comment 'The ending date of the measurement period used to evaluate tier qualification criteria.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Start Date' ;
    rdfs:comment 'The beginning date of the measurement period used to evaluate tier qualification criteria (e.g., rolling 12 months, calendar year).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Qualifying Points Balance' ;
    rdfs:comment 'The total loyalty points balance at the time of tier change that contributed to qualification or demotion decision.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'The cumulative spend amount that qualified the member for this tier change, measured in the program\'s base currency. Used for tier progression analytics.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingVisitCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Visit Count' ;
    rdfs:comment 'The number of restaurant visits or transactions during the qualification period that contributed to this tier change.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this tier change record in the source operational system, used for data reconciliation and troubleshooting.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeNotes rdf:type rdf:Property ;
    rdfs:label 'Tier Change Notes' ;
    rdfs:comment 'Additional free-text notes or comments about this tier change event, used for customer service context and audit documentation.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Change Number' ;
    rdfs:comment 'Business-readable identifier for this tier change event, used for customer service reference and audit tracking.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the tier change: qualification (earned through spend/visits), demotion (failed to maintain requirements), manual_override (customer service adjustment), promotional_upgrade (marketing campaign), anniversary_renewal (annual tier review), points_threshold (points-based qualification), spend_threshold (spend-based qualification), visit_threshold (frequency-based qualification).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason Description' ;
    rdfs:comment 'Detailed human-readable explanation of why this tier change occurred, providing context for customer service and audit purposes.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tier Change Timestamp' ;
    rdfs:comment 'The precise date and time when the tier change event was processed and recorded in the loyalty system.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tierChangeType rdf:type rdf:Property ;
    rdfs:label 'Tier Change Type' ;
    rdfs:comment 'Classification of the tier movement direction and nature: upgrade (promotion to higher tier), downgrade (demotion to lower tier), lateral (same tier level renewal), initial_enrollment (first tier assignment), reinstatement (reactivation after lapse), manual_adjustment (administrative override).' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDurationDays rdf:type rdf:Property ;
    rdfs:label 'Tier Duration Days' ;
    rdfs:comment 'The number of days this tier status is valid, calculated as the difference between effective date and expiry date. Used for tier lifecycle analytics.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Transaction Reference' ;
    rdfs:comment 'Business-readable reference number of the transaction that triggered this tier change, used for customer service inquiries and audit trails.' ;
    rdfs:domain ind:TierHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Points Ledger Id' ;
    rdfs:comment 'Unique identifier for each points transaction record in the loyalty ledger. Serves as the immutable primary key for this financial-grade system of record.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualRuleId rdf:type rdf:Property ;
    rdfs:label 'Accrual Rule Id' ;
    rdfs:comment 'Foreign key linking to loyalty.accrual_rule. Business justification: Each points accrual entry in the ledger is generated by a specific accrual rule (e.g., 2x points on weekends, bonus points for specific menu categories). Adding accrual_rule_id to points_ledger links ' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccrualRule .

ind:enrollmentEventId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Id' ;
    rdfs:comment 'Foreign key linking to loyalty.enrollment_event. Business justification: Enrollment events award initial_points_awarded to new members, which generates a points_ledger entry. Adding enrollment_event_id to points_ledger links the welcome/enrollment bonus ledger entry to the' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnrollmentEvent .

ind:offerRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Offer Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.offer_redemption. Business justification: Offer redemptions can trigger points accrual events (e.g., bonus points for redeeming an offer). Adding offer_redemption_id to points_ledger links the ledger entry to the specific offer redemption tha' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferRedemption .

ind:pointsRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Points Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant location where this points transaction originated. Populated for POS and kiosk transactions. Null for OLO, mobile app, or admin transactions not tied to a specific physical location.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryPointsAdjustedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Points Adjusted By User Employee Id' ;
    rdfs:comment 'Identifier of the system user or customer service agent who authorized and executed the manual adjustment or reversal. Populated for adjust and reversal transactions. Critical for SOX compliance and fraud prevention.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPointsFranchiseFranchiseeId rdf:type rdf:Property ;
    rdfs:label 'Primary Points Franchise Franchisee Id' ;
    rdfs:comment 'Identifier of the franchise entity that owns or operates the restaurant where this transaction occurred. Used for royalty calculations and franchise performance analytics. Null for company-owned locations or non-location transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:primaryPointsGuestOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Points Guest Order Id' ;
    rdfs:comment 'Reference to the originating order transaction that triggered this points movement. Populated for earn and redeem transactions tied to guest purchases. Null for non-order events such as bonus awards, expirations, or manual adjustments.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:reversalOfTransactionPointsLedgerId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Transaction Points Ledger Id' ;
    rdfs:comment 'Reference to the original points_ledger_id that this reversal transaction is canceling. Populated only for reversal transaction types. Creates an audit chain linking reversals to their source transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PointsLedger .

ind:sourceChannelId rdf:type rdf:Property ;
    rdfs:label 'Source Channel Id' ;
    rdfs:comment 'Foreign key linking to order.channel. Business justification: Points accrual channel normalization: points_ledger.source_channel is a plain-text denormalized attribute. FK to order.channel normalizes channel taxonomy for channel-level points accrual reporting an' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:sourceTransactionGuestOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Guest Order Id' ;
    rdfs:comment 'The unique transaction identifier from the originating source system. Enables end-to-end traceability and reconciliation between the loyalty ledger and upstream systems. Format varies by source system.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code explaining why a manual adjustment or reversal was made. Populated only for adjust and reversal transaction types. Supports audit compliance and customer service quality tracking.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Notes' ;
    rdfs:comment 'Free-text explanation provided by the customer service representative or system administrator who initiated the adjustment. Populated for adjust and reversal transactions. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Identifier of the processing batch or job that created this ledger entry. Used for bulk operations such as nightly expiration runs, mass bonus awards, or system migrations. Null for real-time individual transactions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Order Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the order total amount. Supports multi-currency loyalty programs for international operations. Null for non-order transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'The total monetary value of the order that triggered this points transaction, in the local currency. Used to calculate points earn rate and for financial reconciliation. Null for non-order transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'The cumulative running balance of points for this member immediately after this transaction was applied. Provides audit trail and reconciliation capability. Must equal prior balance plus points_delta.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsDelta rdf:type rdf:Property ;
    rdfs:label 'Points Delta' ;
    rdfs:comment 'The signed integer change in points balance for this transaction. Positive values represent accruals (earn, bonus), negative values represent deductions (redeem, expire, adjust downward). Zero-delta entries are not permitted.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsEarnRate rdf:type rdf:Property ;
    rdfs:label 'Points Earn Rate' ;
    rdfs:comment 'The rate at which points were earned per currency unit spent. Example: 1.0000 means 1 point per dollar, 2.0000 means 2 points per dollar (double points promotion). Populated for earn transactions, null otherwise.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'The date on which the points earned in this transaction will expire if not redeemed. Populated only for earn and bonus transaction types. Null for redeem, expire, and adjust transactions. Supports FIFO expiration logic and member communication.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time when this ledger entry was committed to the loyalty system of record. May differ from transaction_timestamp for batch processing or delayed reconciliation. Used for ETL audit and SLA monitoring.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Source Order Number' ;
    rdfs:comment 'Human-readable order number or receipt identifier from the POS or OLO system. Provides guest-facing reference for customer service inquiries. Null for non-order transactions.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time when this points transaction occurred in the source system. Represents the business event time, not the ETL load time. Critical for sequencing and audit.' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the points movement: earn (points accrued from purchase or activity), redeem (points spent on rewards), expire (points lapsed due to inactivity or time limit), adjust (manual correction by support or system), bonus (promotional award), reversal (cancellation of prior transaction).' ;
    rdfs:domain ind:PointsLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeItemStockItemId rdf:type rdf:Property ;
    rdfs:label 'Free Item Stock Item Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_item. Business justification: Reward definitions for free-item rewards must reference the inventory stock_item to calculate COGS and theoretical food cost impact. Foodservice operators track reward fulfillment cost per stock item ' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockItem .

ind:originCampaignId rdf:type rdf:Property ;
    rdfs:label 'Origin Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Campaign-Reward mapping needed for tracking which marketing campaign created a specific reward, supporting performance analysis of campaign-driven incentives.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:availabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Availability End Date' ;
    rdfs:comment 'Date when this reward is no longer available for redemption. Null for evergreen rewards with no expiration. Used for Limited Time Offer (LTO) rewards and seasonal promotions.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Availability Start Date' ;
    rdfs:comment 'Date when this reward becomes available for redemption by loyalty members. Used for Limited Time Offer (LTO) rewards and seasonal promotions.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:combinableWithOtherOffers rdf:type rdf:Property ;
    rdfs:label 'Combinable With Other Offers' ;
    rdfs:comment 'Indicates whether this reward can be combined with other promotional offers, coupons, or discounts in a single transaction. True if combinable, False if exclusive.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costOfGoodsSold rdf:type rdf:Property ;
    rdfs:label 'Cost Of Goods Sold' ;
    rdfs:comment 'Direct cost to the business to fulfill this reward, including food cost, packaging, and direct labor. Used for profitability analysis, loyalty program Return on Investment (ROI) calculation, and financial accrual. Expressed in USD.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'Numeric value of the discount. For percentage discounts, this is the percentage (e.g., 15.00 for 15%). For fixed amount discounts, this is the dollar amount (e.g., 5.00 for $5 off). Null for free items and non-discount rewards.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this reward is featured prominently in the loyalty app and marketing campaigns. True if featured, False if standard catalog placement. Used to drive awareness and redemption of strategic rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formatRestrictionList rdf:type rdf:Property ;
    rdfs:label 'Format Restriction List' ;
    rdfs:comment 'Comma-separated list of restaurant format types where this reward is valid (e.g., QSR, casual, fine-dining, food court). Null if applicable to all formats. Used when restaurant_applicability_scope is \'specific_formats\'.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRestrictionList rdf:type rdf:Property ;
    rdfs:label 'Market Restriction List' ;
    rdfs:comment 'Comma-separated list of market codes or geographic regions where this reward is valid. Null if applicable to all markets. Used when restaurant_applicability_scope is \'specific_markets\'.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Purchase Amount' ;
    rdfs:comment 'Minimum transaction amount required to redeem this reward. Null if no minimum purchase is required. Used to protect Average Check Value (ACV) and prevent low-value transactions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Estimated dollar value equivalent of the reward for financial reporting, liability accrual, and Average Check Value (ACV) impact analysis. Expressed in USD.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Name of the third-party partner providing this reward (for partner offers). Null for internally-fulfilled rewards. Used for co-branded rewards and strategic partnerships.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOfferCode rdf:type rdf:Property ;
    rdfs:label 'Partner Offer Code' ;
    rdfs:comment 'External offer code or voucher code provided by the partner for redemption tracking. Null for internally-fulfilled rewards.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsCost rdf:type rdf:Property ;
    rdfs:label 'Points Cost' ;
    rdfs:comment 'Number of loyalty points required to redeem this reward. Used to calculate point liability and drive guest engagement.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLimitPerMember rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Per Member' ;
    rdfs:comment 'Maximum number of times a single loyalty member can redeem this reward during the availability window. Null indicates no limit.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannelApp rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel App' ;
    rdfs:comment 'Indicates whether this reward can be redeemed exclusively through the branded mobile app (distinct from general OLO). True if eligible, False if not.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionChannelDriveThru rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Drive Thru' ;
    rdfs:comment 'Indicates whether this reward can be redeemed at Drive-Thru (DT) service points. True if eligible, False if not.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionChannelOlo rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Olo' ;
    rdfs:comment 'Indicates whether this reward can be redeemed through Online Ordering (OLO) platforms including web and mobile app. True if eligible, False if not.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionChannelPos rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Pos' ;
    rdfs:comment 'Indicates whether this reward can be redeemed at Point of Sale (POS) terminals in restaurant locations. True if eligible, False if not.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionChannelThirdPartyDelivery rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Third Party Delivery' ;
    rdfs:comment 'Indicates whether this reward can be redeemed through Third-Party Delivery (3PD) platforms such as DoorDash, Uber Eats, or Grubhub. True if eligible, False if not.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Total number of times this reward has been redeemed by loyalty members since inception. Used for popularity analysis, inventory planning, and loyalty program performance reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restaurantApplicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Restaurant Applicability Scope' ;
    rdfs:comment 'Defines which restaurant units can honor this reward: all units (system-wide), specific markets (geographic regions), specific formats (Quick-Service Restaurant (QSR), casual, fine-dining), franchise only, or company-owned only.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardCode rdf:type rdf:Property ;
    rdfs:label 'Reward Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the reward, used in Point of Sale (POS) and Online Ordering (OLO) systems for redemption lookup.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardDescription rdf:type rdf:Property ;
    rdfs:label 'Reward Description' ;
    rdfs:comment 'Detailed description of the reward, including terms, conditions, and guest-facing messaging used in marketing materials and the loyalty app.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardName rdf:type rdf:Property ;
    rdfs:label 'Reward Name' ;
    rdfs:comment 'Human-readable name of the reward displayed to guests in the loyalty app, Online Ordering (OLO) platform, and Point of Sale (POS) system.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardStatus rdf:type rdf:Property ;
    rdfs:label 'Reward Status' ;
    rdfs:comment 'Current lifecycle status of the reward: active (available for redemption), inactive (temporarily unavailable), pending (scheduled for future activation), expired (past availability end date), or discontinued (permanently removed from catalog).' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'Classification of the reward by category: food item (free menu item), beverage (free drink), discount (percentage or dollar off), merchandise (branded goods), experience (event access, VIP treatment), or partner offer (third-party rewards).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Legal terms and conditions governing the redemption and use of this reward. Includes restrictions, exclusions, and compliance language required by Federal Trade Commission (FTC) regulations.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEligibility rdf:type rdf:Property ;
    rdfs:label 'Tier Eligibility' ;
    rdfs:comment 'Specifies which loyalty membership tier(s) are eligible to redeem this reward. Used to create tier-exclusive rewards that drive tier progression and engagement.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Total Quantity Limit' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all loyalty members for this reward. Used for limited-supply rewards and exclusive experiences. Null indicates no limit.' ;
    rdfs:domain ind:Reward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redeemedStockItemId rdf:type rdf:Property ;
    rdfs:label 'Redeemed Stock Item Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_item. Business justification: When a free-item loyalty reward is redeemed, the specific stock_item consumed must be recorded for inventory depletion, COGS tracking, and food cost variance reporting. Foodservice operators require t' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockItem .

ind:redemptionRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Redemption Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where the redemption occurred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:redemptionUnitId rdf:type rdf:Property ;
    rdfs:label 'Redemption Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where the redemption occurred.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Boolean indicator set to true if the redemption was flagged for potential fraudulent activity or policy violation.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numeric fraud risk score assigned by the loyalty platform fraud detection engine, ranging from 0.00 (low risk) to 100.00 (high risk).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentCode rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Code' ;
    rdfs:comment 'Alphanumeric confirmation code generated upon successful fulfillment of the redemption, used for audit and reconciliation.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberTier rdf:type rdf:Property ;
    rdfs:label 'Member Tier' ;
    rdfs:comment 'Loyalty program membership tier of the member at the time of redemption, used for tier-based redemption analysis.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTotalAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total After Discount' ;
    rdfs:comment 'Total order amount after the loyalty reward discount was applied, representing the net revenue from the transaction.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderTotalBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Order Total Before Discount' ;
    rdfs:comment 'Total order amount before the loyalty reward discount was applied, used for calculating incremental ACV (Average Check Value) impact.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Points Balance Before' ;
    rdfs:comment 'Loyalty points balance of the member immediately before this redemption transaction.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsDeducted rdf:type rdf:Property ;
    rdfs:label 'Points Deducted' ;
    rdfs:comment 'Number of loyalty points deducted from the member account to redeem this reward.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Number' ;
    rdfs:comment 'Externally visible unique business identifier for the redemption transaction, used for customer service and tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionSource rdf:type rdf:Property ;
    rdfs:label 'Redemption Source' ;
    rdfs:comment 'Indicates how the redemption was initiated. Manual for member-selected reward, automatic for system-applied offer, promotional trigger for campaign-driven redemption, gamification for achievement-based reward, tier benefit for membership tier perk.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption transaction. Pending indicates awaiting fulfillment, fulfilled indicates successfully applied, voided indicates cancelled before fulfillment, expired indicates reward expired before use, reversed indicates post-fulfillment reversal, failed indicates technical or validation failure.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the loyalty member initiated the reward redemption at the point of sale or online ordering platform.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text explanation for why the redemption was reversed or voided, captured for customer service and fraud analysis.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the redemption was reversed or voided, if applicable.' ;
    rdfs:domain ind:Redemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelScope rdf:type rdf:Property ;
    rdfs:label 'Channel Scope' ;
    rdfs:comment 'Order channel(s) where this accrual rule is active. All = applies across all channels, POS = Point of Sale (Point of Sale) in-store, OLO = Online Ordering (Online Ordering) web/app, Mobile_app = native mobile application, Kiosk = self-service kiosk, Drive_thru = drive-through lane, 3PD = Third-Party Delivery (Third-Party Delivery) platforms. [ENUM-REF-CANDIDATE: all|pos|olo|mobile_app|kiosk|drive_thru|3pd — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartScope rdf:type rdf:Property ;
    rdfs:label 'Daypart Scope' ;
    rdfs:comment 'Comma-separated list of daypart codes (e.g., breakfast, lunch, dinner, late_night) to which this rule applies. Empty or null = applies to all dayparts. Used for time-of-day promotional earning.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningBasis rdf:type rdf:Property ;
    rdfs:label 'Earning Basis' ;
    rdfs:comment 'The calculation basis for points accrual. Dollar_spent = points per currency unit, Transaction_count = points per visit, Item_count = points per menu item purchased, Fixed_event = flat points for qualifying event.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionList rdf:type rdf:Property ;
    rdfs:label 'Exclusion List' ;
    rdfs:comment 'Comma-separated list of menu item codes, categories, or member segments explicitly excluded from this rule. Used to carve out exceptions (e.g., alcohol, gift cards, discounted items).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedPointsAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Points Amount' ;
    rdfs:comment 'Flat number of points awarded for qualifying events (e.g., 500 points for birthday, 100 points for survey completion). Used when earning_basis is fixed_event. Null for variable earning rules.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseIdList rdf:type rdf:Property ;
    rdfs:label 'Franchise Id List' ;
    rdfs:comment 'Comma-separated list of franchisee IDs when franchise_scope is specific_franchisee. Null for all other franchise scopes.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseScope rdf:type rdf:Property ;
    rdfs:label 'Franchise Scope' ;
    rdfs:comment 'Ownership model scope for this rule. All = applies to all restaurants, Company_owned = corporate locations only, Franchise = franchisee locations only, Specific_franchisee = limited to designated franchisee IDs (stored in franchise_id_list).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPointsPerDay rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Day' ;
    rdfs:comment 'Cap on the number of points a member can earn per calendar day under this rule. Null = no daily cap. Used for frequency-based earning controls.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumPointsPerMember rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Member' ;
    rdfs:comment 'Lifetime or campaign-period cap on points a single member can earn under this rule. Null = no member cap. Used for limited-time offers and promotional campaigns.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumPointsPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Points Per Transaction' ;
    rdfs:comment 'Cap on the number of points that can be earned in a single transaction under this rule. Null = no cap. Used to prevent abuse and manage liability.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberTierScope rdf:type rdf:Property ;
    rdfs:label 'Member Tier Scope' ;
    rdfs:comment 'Comma-separated list of loyalty tier codes (e.g., bronze, silver, gold, platinum) eligible for this rule. Empty or null = applies to all tiers. Used for tier-exclusive earning opportunities.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Menu Category Scope' ;
    rdfs:comment 'Comma-separated list of menu category codes to which this rule applies. Empty or null = applies to all categories. Used to restrict earning to specific product categories (e.g., beverages, entrees, LTO items).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menuItemScope rdf:type rdf:Property ;
    rdfs:label 'Menu Item Scope' ;
    rdfs:comment 'Comma-separated list of specific menu item codes to which this rule applies. Empty or null = applies to all items within category scope. Used for item-specific promotions.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpirationDays rdf:type rdf:Property ;
    rdfs:label 'Points Expiration Days' ;
    rdfs:comment 'Number of days from earning date after which points awarded by this rule expire. Null = points do not expire. Used for promotional points with limited validity.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsPerUnit rdf:type rdf:Property ;
    rdfs:label 'Points Per Unit' ;
    rdfs:comment 'Number of loyalty points awarded per unit of the earning basis (e.g., 10 points per dollar spent, 50 points per transaction). Null for fixed_event earning basis.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresOptIn rdf:type rdf:Property ;
    rdfs:label 'Requires Opt In' ;
    rdfs:comment 'Indicates whether members must explicitly opt in or activate this rule to earn points. True = member action required, False = automatically applied to eligible transactions.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-readable unique code for the accrual rule (e.g., BASE_EARN, TIER_BONUS, BIRTHDAY_PROMO). Used for operational reference and system integration.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the accrual rule, including business logic, conditions, and intended use case.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the accrual rule for display and reporting purposes.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Numeric priority for conflict resolution when multiple accrual rules apply to the same transaction. Lower number = higher priority. Used to determine which rule takes precedence (e.g., promotional rule overrides base earning).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the accrual rule. Draft = under development, Active = currently awarding points, Paused = temporarily disabled, Expired = past effective_end_date, Archived = retired and no longer in use.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Category of earning trigger that activates this accrual rule. Purchase = transaction-based earning, Visit = frequency-based earning, Referral = member-get-member, Birthday = anniversary reward, Survey = feedback incentive, Signup = enrollment bonus.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackable rdf:type rdf:Property ;
    rdfs:label 'Stackable' ;
    rdfs:comment 'Indicates whether this rule can be combined with other accrual rules in the same transaction. True = can stack with other rules, False = mutually exclusive (highest priority rule wins).' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierMultiplierApplicable rdf:type rdf:Property ;
    rdfs:label 'Tier Multiplier Applicable' ;
    rdfs:comment 'Indicates whether member tier multipliers (e.g., Gold = 1.5x, Platinum = 2x) apply to this accrual rule. True = tier bonus applies, False = base earning only.' ;
    rdfs:domain ind:AccrualRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeMenuItemId rdf:type rdf:Property ;
    rdfs:label 'Free Menu Item Id' ;
    rdfs:comment 'Foreign key linking to menu.menu_item. Business justification: Free-item offer fulfillment: when a loyalty offer type is \'free item\', the POS and OLO systems must resolve the exact menu_item to comp. Role-prefix \'free_\' distinguishes this from other menu_item FKs' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuItem .

ind:fundingSupplierContractId rdf:type rdf:Property ;
    rdfs:label 'Funding Supplier Contract Id' ;
    rdfs:comment 'Foreign key linking to supply.supplier_contract. Business justification: Supplier contracts in foodservice commonly include trade spend / promotional funding clauses that obligate the supplier to fund specific loyalty offers. Finance and procurement teams must reconcile of' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierContract .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username or user ID of the marketing manager who approved the offer for distribution. Null if offer is still in draft status.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether the offer is automatically applied at checkout when eligibility criteria are met (True) or requires manual code entry by the member (False).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusPointsValue rdf:type rdf:Property ;
    rdfs:label 'Bonus Points Value' ;
    rdfs:comment 'Number of bonus loyalty points awarded when the offer is redeemed. Applicable to bonus_points and challenge offer types. Null for other offer types.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekRestriction rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Restriction' ;
    rdfs:comment 'Comma-separated list of days of the week when the offer is valid (e.g., monday,tuesday,wednesday). Null if valid all days.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel through which the offer is communicated to members: push_notification, email, in_app (mobile app banner), sms, pos_display (printed receipt or screen), direct_mail.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMemberSegments rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Segments' ;
    rdfs:comment 'Comma-separated list of member segment codes targeted for this offer (e.g., lapsed_guests, high_frequency, new_members). Null if offer is mass-distributed.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMemberTiers rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Tiers' ;
    rdfs:comment 'Comma-separated list of loyalty membership tier codes eligible to receive this offer (e.g., silver, gold, platinum). Null if offer is available to all tiers.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMenuItems rdf:type rdf:Property ;
    rdfs:label 'Eligible Menu Items' ;
    rdfs:comment 'Comma-separated list of menu item SKUs or category codes that qualify for the offer. Null if offer applies to entire menu or transaction total.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the offer expires and is no longer redeemable. Null for evergreen offers without a fixed expiration.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCostPerRedemption rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Redemption' ;
    rdfs:comment 'Estimated financial cost to the business for each redemption of this offer, including discount value and incremental COGS. Used for campaign budget planning and ROI analysis.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excludedMenuItems rdf:type rdf:Property ;
    rdfs:label 'Excluded Menu Items' ;
    rdfs:comment 'Comma-separated list of menu item SKUs or category codes explicitly excluded from the offer (e.g., alcohol, LTO items). Null if no exclusions.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumVisitFrequency rdf:type rdf:Property ;
    rdfs:label 'Minimum Visit Frequency' ;
    rdfs:comment 'Minimum number of visits in the trailing 90 days required for a member to be eligible for this offer. Null if no visit frequency requirement.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Externally-visible unique alphanumeric code used by members to redeem the offer at POS or OLO channels. Typically 6-12 characters.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed marketing copy describing the offer terms, benefits, and redemption instructions displayed to members.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name of the offer displayed to loyalty members in app, email, and push notifications.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle state of the offer: draft (being designed), scheduled (approved, awaiting start date), active (live and redeemable), paused (temporarily suspended), expired (end date passed), cancelled (terminated before expiration).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the offer mechanism: discount (percentage or dollar off), bonus_points (accelerated points accrual), free_item (complimentary menu item), bogo (buy-one-get-one), challenge (gamification task), sweepstakes (prize drawing entry).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizedFlag rdf:type rdf:Property ;
    rdfs:label 'Personalized Flag' ;
    rdfs:comment 'Indicates whether this offer is personalized to individual members based on purchase history and preferences (True) or is a mass offer distributed to all eligible members (False).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Display priority ranking for this offer when multiple offers are available to a member. Lower numbers indicate higher priority (1 = highest).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'Channel(s) where the offer can be redeemed: pos (in-store point of sale), olo (online ordering), mobile_app, kiosk, drive_thru, all_channels (omnichannel).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerMember rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Member' ;
    rdfs:comment 'Maximum number of times a single loyalty member can redeem this offer during its active period. Null for unlimited redemptions.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackableFlag rdf:type rdf:Property ;
    rdfs:label 'Stackable Flag' ;
    rdfs:comment 'Indicates whether this offer can be combined with other offers in a single transaction. True = stackable, False = exclusive.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the offer becomes active and available for redemption by eligible members.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Target Redemption Count' ;
    rdfs:comment 'Marketing team\'s target goal for total number of redemptions during the offer period. Used for campaign performance evaluation.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRedemptionLimit rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Limit' ;
    rdfs:comment 'Maximum total number of redemptions allowed across all members for this offer (budget cap). Null for unlimited total redemptions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Offer Assignment Id' ;
    rdfs:comment 'Unique identifier for the offer assignment record. Primary key for the offer assignment entity.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfferAssignment .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifier for the A/B test or multivariate test variant this offer assignment belongs to. Supports controlled experimentation and offer optimization.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentChannel rdf:type rdf:Property ;
    rdfs:label 'Assignment Channel' ;
    rdfs:comment 'The channel through which the offer assignment was delivered to the member: email, SMS (Short Message Service), push notification, in-app message, POS (Point of Sale) terminal, or web portal.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Code' ;
    rdfs:comment 'A code or identifier explaining why this offer was assigned to this member (e.g., birthday, win-back, high-value, new-member-welcome, lapsed-reactivation). Supports offer attribution and effectiveness analysis.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'The system or process that created this offer assignment: CRM (Customer Relationship Management) automation, loyalty engine rule, manual admin action, API (Application Programming Interface) integration, or batch job.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The date and time when the offer was assigned to the member or segment. Represents the business event time of offer distribution.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of how the offer was assigned: personalized (individual-level targeting), mass-distributed (broadcast to all members), segment-targeted (distributed to a defined segment), triggered (event-based automation), or manual (operator-assigned).' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'The date and time when the member clicked through or engaged with the offer assignment (applicable for digital channels with trackable links).' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time when the offer was successfully delivered to the member through the assignment channel.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstRedemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Redemption Timestamp' ;
    rdfs:comment 'The date and time when the member first redeemed this offer assignment.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isWalletVisible rdf:type rdf:Property ;
    rdfs:label 'Is Wallet Visible' ;
    rdfs:comment 'Boolean flag indicating whether this offer assignment is currently visible in the member\'s digital offer wallet (OLO, mobile app). False indicates the offer is assigned but hidden (e.g., surprise-and-delight offers revealed at checkout).' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRedemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Timestamp' ;
    rdfs:comment 'The date and time of the most recent redemption of this offer assignment by the member.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Max Redemption Count' ;
    rdfs:comment 'The maximum number of times this member can redeem this specific offer assignment. Null indicates unlimited redemptions within the validity period.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationPreferenceHonored rdf:type rdf:Property ;
    rdfs:label 'Notification Preference Honored' ;
    rdfs:comment 'Boolean flag indicating whether the member\'s communication preferences were honored when delivering this offer assignment. Supports compliance with opt-in/opt-out regulations.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when the member first opened or viewed the offer assignment (applicable for email, push, in-app channels).' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:personalizationScore rdf:type rdf:Property ;
    rdfs:label 'Personalization Score' ;
    rdfs:comment 'A numeric score (0.00 to 100.00) indicating the degree of personalization applied to this offer assignment based on member behavior, preferences, and predictive models. Higher scores indicate more tailored offers.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Free-text explanation or code describing why this offer assignment was revoked (e.g., member request, fraud detection, offer recall, system error correction).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'The date and time when this offer assignment was revoked or cancelled, if applicable.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:walletDisplayStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Wallet Display Start Timestamp' ;
    rdfs:comment 'The date and time when this offer assignment becomes visible in the member\'s offer wallet. Supports delayed reveal strategies.' ;
    rdfs:domain ind:OfferAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryOfferCashierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Offer Cashier Employee Id' ;
    rdfs:comment 'Reference to the employee who processed the redemption transaction at the POS. Null for digital channels.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryOfferFranchiseFranchiseeId rdf:type rdf:Property ;
    rdfs:label 'Primary Offer Franchise Franchisee Id' ;
    rdfs:comment 'Reference to the franchise entity that owns the restaurant unit where redemption occurred. Used for franchise-level redemption analytics and royalty calculations.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:redemptionChannelId rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel Id' ;
    rdfs:comment 'Foreign key linking to order.channel. Business justification: Offer redemption channel normalization: offer_redemption.redemption_channel is a plain-text attribute. FK to order.channel normalizes channel taxonomy for offer-channel performance reporting (e.g., wh' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied when discount_type is percentage. Null for non-percentage discount types.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Final Order Amount' ;
    rdfs:comment 'Total order amount after the offer discount was applied. Represents the actual amount paid by the member.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDuplicateAttempt rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Attempt' ;
    rdfs:comment 'Boolean flag indicating whether this redemption was flagged as a duplicate attempt (member trying to redeem same offer multiple times).' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirstRedemption rdf:type rdf:Property ;
    rdfs:label 'Is First Redemption' ;
    rdfs:comment 'Boolean flag indicating whether this is the members first-ever offer redemption in the loyalty program. Used for new member engagement analytics.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Offer Distribution Channel' ;
    rdfs:comment 'Channel through which the offer was originally distributed to the member. Distinct from redemption_channel which captures where it was redeemed. [ENUM-REF-CANDIDATE: email|sms|push_notification|in_app|direct_mail|receipt_print|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Offer Expiration Date' ;
    rdfs:comment 'Date when the offer expires and can no longer be redeemed. Captured at redemption time for historical tracking.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Original Order Amount' ;
    rdfs:comment 'Total order amount before the offer discount was applied. Used to calculate discount impact and ACV (Average Check Value) lift.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsEarned rdf:type rdf:Property ;
    rdfs:label 'Points Earned' ;
    rdfs:comment 'Number of loyalty points earned by the member on this transaction after the offer discount was applied. May be zero if offer disqualifies points accrual.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsMultiplierApplied rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier Applied' ;
    rdfs:comment 'Points multiplier applied to this transaction if the offer included accelerated points accrual (e.g., 2x points, 3x points). Default is 1.0 for standard accrual.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'Unique alphanumeric code presented by the member to redeem the offer. May be system-generated or campaign-specific.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'External transaction reference number from the POS or OLO system. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'Method used to validate and apply the offer at redemption. Barcode_scan for scanning printed or digital barcodes, manual_entry for cashier-entered codes, qr_code for QR code scanning, nfc_tap for near-field communication, api_validation for system-to-system validation, loyalty_card_swipe for physical card swipe.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Date and time when the redemption was voided. Null if redemption was not voided.' ;
    rdfs:domain ind:OfferRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:birthdayBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Birthday Bonus Points' ;
    rdfs:comment 'Number of bonus points awarded to members on their birthday. Zero if no birthday bonus is offered.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the program is available (e.g., USA,CAN,MEX). Null for global programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Name of the loyalty currency used in the program (e.g., Stars, Points, Coins, Miles, Rewards).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dollarPerPoint rdf:type rdf:Property ;
    rdfs:label 'Dollar Per Point' ;
    rdfs:comment 'Monetary value of each loyalty point when redeemed. Used to calculate redemption value and liability.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentBonusPoints rdf:type rdf:Property ;
    rdfs:label 'Enrollment Bonus Points' ;
    rdfs:comment 'Number of bonus points awarded to new members upon successful enrollment. Zero if no enrollment bonus is offered.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentChannels rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channels' ;
    rdfs:comment 'Comma-separated list of channels through which guests can enroll in the program (e.g., mobile_app, website, pos, kiosk, third_party).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gamification Enabled Flag' ;
    rdfs:comment 'Indicates whether the program includes gamification elements such as challenges, badges, streaks, or missions.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic coverage of the loyalty program: global (all markets), regional (multi-country region), country (single country), state (sub-national), or local (specific metro/franchise group).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRedemptionPoints rdf:type rdf:Property ;
    rdfs:label 'Minimum Redemption Points' ;
    rdfs:comment 'Minimum number of points required to make a redemption. Used to prevent micro-redemptions and manage transaction costs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oloIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Olo Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether the program is integrated with online ordering platforms for digital points accrual and redemption.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Enabled Flag' ;
    rdfs:comment 'Indicates whether the program uses guest data to deliver personalized offers, recommendations, and communications.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpirationMonths rdf:type rdf:Property ;
    rdfs:label 'Points Expiration Months' ;
    rdfs:comment 'Number of months after which unused loyalty points expire. Null if points never expire.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsPerDollar rdf:type rdf:Property ;
    rdfs:label 'Points Per Dollar' ;
    rdfs:comment 'Number of loyalty points earned per dollar spent. Used to calculate points accrual from transaction amounts.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:posIntegrationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Pos Integration Enabled Flag' ;
    rdfs:comment 'Indicates whether the program is integrated with POS systems for in-store points accrual and redemption.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'Web URL to the privacy policy explaining how member data is collected, used, and protected.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known unique business identifier for the loyalty program used in integrations and reporting (e.g., REWARDS_PLUS, STAR_CLUB).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the loyalty program value proposition, benefits, and how it works. Used for internal reference and guest communications.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Marketing name of the loyalty program displayed to guests (e.g., Rewards Plus, Star Club, VIP Circle).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure: points-based (earn and redeem points), visit-based (frequency rewards), hybrid (combination), subscription (paid membership), or tiered (status levels).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restaurantFormats rdf:type rdf:Property ;
    rdfs:label 'Restaurant Formats' ;
    rdfs:comment 'Comma-separated list of restaurant formats where the program is valid (e.g., QSR, casual_dining, fine_dining, food_truck, ghost_kitchen).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Subscription Fee Amount' ;
    rdfs:comment 'Monthly or annual subscription fee required for paid membership programs. Null for free programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Subscription Fee Frequency' ;
    rdfs:comment 'Billing frequency for subscription-based programs: monthly, annual, or one-time. Null for free programs.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the primary guest segment the program is designed to attract and retain (e.g., frequent diners, families, business travelers, value seekers).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web URL to the official terms and conditions document governing the loyalty program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Enabled Flag' ;
    rdfs:comment 'Indicates whether the program includes membership tiers with progressive benefits (True) or is a single-tier program (False).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Campaign Id' ;
    rdfs:comment 'Reference to the marketing campaign that drove the enrollment. Null if enrollment was not campaign-driven. Enables campaign ROI analysis.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:initialTierId rdf:type rdf:Property ;
    rdfs:label 'Initial Tier Id' ;
    rdfs:comment 'Reference to the membership tier assigned at enrollment. Typically the base tier for new members, but may be elevated tier for transfer or upgrade enrollments.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:primaryEnrollmentMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Enrollment Member Id' ;
    rdfs:comment 'Reference to the loyalty program member who enrolled. Links to the member master record.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:primaryEnrollmentRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Enrollment Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant unit where the enrollment occurred. Null for digital-only enrollments without a specific unit association.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryEnrollmentStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Enrollment Staff Employee Id' ;
    rdfs:comment 'Reference to the staff member who assisted with the enrollment. Null for self-service enrollments. Used for staff performance tracking.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEnrollmentTransactionGuestOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Enrollment Transaction Guest Order Id' ;
    rdfs:comment 'Original transaction identifier from the source system. Used for reconciliation and traceability back to the source system.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:welcomeOfferId rdf:type rdf:Property ;
    rdfs:label 'Welcome Offer Id' ;
    rdfs:comment 'Reference to the specific welcome offer or promotional reward issued at enrollment. Null if no offer was issued.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:emailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Email Opt In Flag' ;
    rdfs:comment 'Indicates whether the member opted in to receive email communications at enrollment. Required for CAN-SPAM compliance.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentCountryCode rdf:type rdf:Property ;
    rdfs:label 'Enrollment Country Code' ;
    rdfs:comment 'Country where the enrollment occurred. ISO 3166-1 alpha-3 three-letter country codes. Used for geographic segmentation and compliance. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|FRA|DEU|AUS|JPN|CHN|BRA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDeviceType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Device Type' ;
    rdfs:comment 'Type of device used to complete the enrollment. Supports channel and user experience analysis.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentGeolocation rdf:type rdf:Property ;
    rdfs:label 'Enrollment Geolocation' ;
    rdfs:comment 'Geographic coordinates (latitude, longitude) of the enrollment location if captured. Format: latitude,longitude. Used for location-based analytics.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Enrollment Ip Address' ;
    rdfs:comment 'IP address from which the enrollment was initiated. Used for fraud detection and geographic analysis. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentLanguage rdf:type rdf:Property ;
    rdfs:label 'Enrollment Language' ;
    rdfs:comment 'Language preference selected by the member at enrollment. ISO 639-2 three-letter language codes. Used for personalized communications. [ENUM-REF-CANDIDATE: eng|spa|fra|deu|ita|por|zho|jpn|kor — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes or comments about the enrollment event. Used for special circumstances, exceptions, or customer service annotations.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment transaction number. Format: ENR followed by 10 digits. Used for customer service and audit tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Name of the source system that captured the enrollment event. Examples: Olo, Oracle MICROS, Salesforce CRM, Mobile App. Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment event. Completed indicates successful enrollment; pending indicates awaiting verification; failed indicates enrollment did not complete; cancelled indicates member-initiated cancellation; reversed indicates system or compliance reversal.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Date and time when the enrollment event occurred in the source system. Represents the real-world business event time, distinct from record audit timestamps.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Type of enrollment action. New indicates first-time enrollment; re_enrollment indicates returning member; transfer indicates program migration; upgrade indicates tier promotion enrollment.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Status' ;
    rdfs:comment 'Status of fraud detection checks performed at enrollment. Passed indicates clean enrollment; failed indicates suspected fraud; pending indicates checks in progress; not_required indicates no checks were performed.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialPointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Initial Points Awarded' ;
    rdfs:comment 'Number of loyalty points awarded to the member at enrollment as a sign-up bonus. Zero if no points were awarded.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the member opted in to receive marketing communications at enrollment. True if opted in; False if declined.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushNotificationOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In Flag' ;
    rdfs:comment 'Indicates whether the member opted in to receive mobile app push notifications at enrollment.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Source that drove the enrollment. Organic for unprompted; referral_code for member referral; campaign for marketing campaign; social_media for social channels; email for email marketing; in_store for restaurant promotion; partner for third-party partner. [ENUM-REF-CANDIDATE: organic|referral_code|campaign|social_media|email|in_store|partner — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In Flag' ;
    rdfs:comment 'Indicates whether the member opted in to receive SMS/text message communications at enrollment. Required for TCPA compliance.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the member accepted the loyalty program terms and conditions at enrollment. Required for compliance and legal purposes.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Completed Flag' ;
    rdfs:comment 'Indicates whether required verification has been completed. True if completed; False if pending or not completed.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Completed Timestamp' ;
    rdfs:comment 'Date and time when enrollment verification was completed. Null if verification is not required or not yet completed.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Required Flag' ;
    rdfs:comment 'Indicates whether the enrollment requires additional verification (e.g., email verification, identity verification). True if verification is required; False if not required.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:welcomeOfferIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Welcome Offer Issued Flag' ;
    rdfs:comment 'Indicates whether a welcome offer or sign-up bonus was issued to the member upon enrollment. True if issued; False if not issued.' ;
    rdfs:domain ind:EnrollmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityScore rdf:type rdf:Property ;
    rdfs:label 'Accessibility Score' ;
    rdfs:comment 'Quantitative assessment of ease of ingress and egress, typically scored 0-100. Considers turn lanes, traffic signals, median cuts, and parking availability.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Building Square Footage' ;
    rdfs:comment 'Total interior square footage of the restaurant building. Used for lease valuation, R&M (Repairs and Maintenance) budgeting, and utility forecasting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyTrafficCount rdf:type rdf:Property ;
    rdfs:label 'Daily Traffic Count' ;
    rdfs:comment 'Average daily vehicle or pedestrian traffic count passing the site. Critical visibility and accessibility metric for site selection scoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruCapable rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Capable' ;
    rdfs:comment 'Indicates whether the site configuration and zoning permit a drive-thru lane. Critical for QSR (Quick-Service Restaurant) operational model and throughput forecasting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date on which the lease agreement becomes effective and rent obligations begin. Critical for IFRS 16 / ASC 842 right-of-use asset recognition.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date on which the current lease term expires. Used for lease renewal planning, portfolio optimization, and financial forecasting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the site within the NRO (New Restaurant Opening) pipeline or existing portfolio lifecycle. Drives workflow, reporting, and financial treatment. [ENUM-REF-CANDIDATE: prospecting|under_negotiation|approved|under_construction|active|temporarily_closed|closed|disposed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Lot Square Footage' ;
    rdfs:comment 'Total land area of the site parcel in square feet. Used for property valuation, CAM (Common Area Maintenance) calculations, and site development planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Demographic and geographic market segment classification. Drives menu mix, pricing strategy, and operational model selection.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBaseRent rdf:type rdf:Property ;
    rdfs:label 'Monthly Base Rent' ;
    rdfs:comment 'Fixed monthly rent payment obligation under the lease agreement, excluding variable charges. Used for P&L (Profit and Loss) forecasting and lease liability calculation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyCamCharges rdf:type rdf:Property ;
    rdfs:label 'Monthly Cam Charges' ;
    rdfs:comment 'Monthly charges for common area maintenance, property taxes, and insurance allocated to the tenant. Variable component of total occupancy cost.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRentRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Rate' ;
    rdfs:comment 'Percentage of sales above the threshold that is paid as additional rent. Expressed as a decimal (e.g., 0.0600 for 6%).' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRentThreshold rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Threshold' ;
    rdfs:comment 'Annual sales breakpoint above which percentage rent becomes due to the landlord. Common in retail lease structures for high-traffic locations.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAuv rdf:type rdf:Property ;
    rdfs:label 'Projected Auv' ;
    rdfs:comment 'Forecasted annual sales volume for the site based on site selection model. Used for NRO (New Restaurant Opening) approval and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name or designation for the site, often incorporating location landmarks or address elements for easy identification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteNumber rdf:type rdf:Property ;
    rdfs:label 'Site Number' ;
    rdfs:comment 'Externally-known unique business identifier for the site, used across real estate, operations, and finance systems. Typically assigned during site prospecting phase.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Physical configuration and placement classification of the site within its development or property. Critical for site selection scoring and operational model determination. [ENUM-REF-CANDIDATE: freestanding|inline|endcap|pad|food_court|airport|travel_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapexInvestment rdf:type rdf:Property ;
    rdfs:label 'Total Capex Investment' ;
    rdfs:comment 'Total capital investment for site development, including land acquisition, construction, equipment, and pre-opening costs. Used for ROI calculation and capital planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visibilityScore rdf:type rdf:Property ;
    rdfs:label 'Visibility Score' ;
    rdfs:comment 'Quantitative assessment of site visibility from primary traffic routes, typically scored 0-100. Incorporates signage sightlines, obstructions, and approach angles.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Local government zoning designation for the site parcel. Determines permitted uses, building restrictions, and signage allowances.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingClassification rdf:type rdf:Property ;
    rdfs:label 'Accounting Classification' ;
    rdfs:comment 'Lease classification for financial reporting purposes under IFRS 16 / ASC 842: operating lease (most common for real estate) or finance lease (if lease transfers substantially all risks and rewards of ownership).' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRentAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rent Amount' ;
    rdfs:comment 'Fixed monthly or annual base rent payment amount specified in the lease agreement, excluding variable charges such as CAM, taxes, and percentage rent.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseRentFrequency rdf:type rdf:Property ;
    rdfs:label 'Base Rent Frequency' ;
    rdfs:comment 'Frequency at which base rent payments are due: monthly, quarterly, or annually.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camChargesAnnual rdf:type rdf:Property ;
    rdfs:label 'Cam Charges Annual' ;
    rdfs:comment 'Estimated annual Common Area Maintenance charges for shared property expenses such as landscaping, parking lot maintenance, snow removal, and common utilities.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coTenancyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Co Tenancy Clause Flag' ;
    rdfs:comment 'Indicates whether the lease includes a co-tenancy provision allowing rent reduction or termination if anchor tenants or a minimum occupancy threshold is not maintained.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'Date when the lease agreement becomes effective and rent obligations begin. Critical for IFRS 16 / ASC 842 right-of-use asset recognition.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Interest rate used to discount future lease payments to present value for IFRS 16 / ASC 842 calculations. Represents the rate the lessee would pay to borrow funds to purchase a similar asset.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Reference URL or file path to the digitally stored lease agreement document for audit and compliance purposes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveUseRights rdf:type rdf:Property ;
    rdfs:label 'Exclusive Use Rights' ;
    rdfs:comment 'Description of exclusive use provisions that restrict the landlord from leasing to competing restaurant concepts within the same property or trade area.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the lease agreement was signed by all parties, establishing the legal contract.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guarantorEntity rdf:type rdf:Property ;
    rdfs:label 'Guarantor Entity' ;
    rdfs:comment 'Name of the corporate entity providing a lease guarantee, typically the parent company for franchise or subsidiary-operated locations.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAnnual rdf:type rdf:Property ;
    rdfs:label 'Insurance Annual' ;
    rdfs:comment 'Estimated annual property insurance premium obligation passed through to the tenant under a triple-net (NNN) lease structure.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Number' ;
    rdfs:comment 'Externally-known unique business identifier for the lease agreement, used in legal documents and correspondence.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle status of the lease agreement: draft (under negotiation), active (in force), expired (term ended), terminated (ended early), renewed (extended), or pending renewal (approaching expiration with renewal option).' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease arrangement: ground lease (land only), building lease (structure and land), sublease (tenant subleases from another tenant), or license agreement.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityValue rdf:type rdf:Property ;
    rdfs:label 'Liability Value' ;
    rdfs:comment 'Initial measurement of the lease liability recognized on the balance sheet under IFRS 16 / ASC 842, representing the present value of future lease payments discounted at the incremental borrowing rate.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedUse rdf:type rdf:Property ;
    rdfs:label 'Permitted Use' ;
    rdfs:comment 'Legal description of the permitted business activities and operations allowed under the lease, typically specifying restaurant or foodservice use.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyTaxAnnual rdf:type rdf:Property ;
    rdfs:label 'Property Tax Annual' ;
    rdfs:comment 'Estimated annual property tax obligation passed through to the tenant under a triple-net (NNN) lease structure.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingTermMonths rdf:type rdf:Property ;
    rdfs:label 'Remaining Term Months' ;
    rdfs:comment 'Number of months remaining from the current date until lease expiration, used for lease liability calculations under IFRS 16 / ASC 842.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to lease expiration by which the tenant must notify the landlord of intent to exercise a renewal option. Typically 180-365 days.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Count' ;
    rdfs:comment 'Number of renewal option periods available to the tenant after the initial lease term expires. Common in restaurant leases to provide long-term site control.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOptionTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Term Months' ;
    rdfs:comment 'Duration in months of each renewal option period. Typically 5 years (60 months) per option in QSR leases.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentEscalationRate rdf:type rdf:Property ;
    rdfs:label 'Rent Escalation Rate' ;
    rdfs:comment 'Annual percentage rate of rent increase if escalation type is fixed percentage. Null if escalation is CPI-indexed or fair market value.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentEscalationType rdf:type rdf:Property ;
    rdfs:label 'Rent Escalation Type' ;
    rdfs:comment 'Method by which base rent increases over the lease term: fixed percentage (e.g., 3% annually), CPI-indexed (tied to Consumer Price Index), fair market value (periodic reappraisal), or none (flat rent).' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'Initial measurement of the right-of-use asset recognized on the balance sheet under IFRS 16 / ASC 842, representing the present value of future lease payments plus initial direct costs.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable deposit held by the landlord to cover potential damages or unpaid rent. Typically equivalent to 1-3 months of base rent.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Total duration of the initial lease term expressed in months, excluding renewal options.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Clause Flag' ;
    rdfs:comment 'Indicates whether the lease includes an early termination clause allowing the tenant to exit the lease before expiration under specified conditions.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required to exercise the early termination clause, if applicable.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty or buyout amount required to exercise the early termination clause, if applicable.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camBillingMethod rdf:type rdf:Property ;
    rdfs:label 'Cam Billing Method' ;
    rdfs:comment 'Method by which CAM charges are calculated and billed by this landlord.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or DBA name under which the landlord operates, if different from legal name.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Escalation History Count' ;
    rdfs:comment 'Total number of formal escalations or disputes raised with this landlord over the relationship history.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceCertificateFrequency rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Frequency' ;
    rdfs:comment 'Frequency at which insurance certificates must be submitted to this landlord.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Required Flag' ;
    rdfs:comment 'Indicates whether this landlord requires periodic submission of insurance certificates.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landlordStatus rdf:type rdf:Property ;
    rdfs:label 'Landlord Status' ;
    rdfs:comment 'Current lifecycle status of the landlord relationship.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Date' ;
    rdfs:comment 'Date of the most recent formal escalation or dispute with this landlord.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationPosture rdf:type rdf:Property ;
    rdfs:label 'Negotiation Posture' ;
    rdfs:comment 'Assessment of the landlord\'s typical approach to lease negotiations and dispute resolution.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard number of days for rent payment terms agreed with this landlord (e.g., Net 30).' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioPropertyCount rdf:type rdf:Property ;
    rdfs:label 'Portfolio Property Count' ;
    rdfs:comment 'Number of properties currently leased from this landlord across the restaurant portfolio.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The landlord\'s preferred method for receiving communications and notices.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person (e.g., Property Manager, Leasing Director, Asset Manager).' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'Quantitative score (0-100) representing the overall health of the landlord relationship based on payment history, dispute frequency, and collaboration quality.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Classification of the landlord relationship based on portfolio size, negotiation history, and strategic importance.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the landlord entity.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the landlord relationship was terminated or when the last lease with this landlord expired.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:w9LastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'W9 Last Updated Date' ;
    rdfs:comment 'Date when the W-9 form was last received or updated for this landlord.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:w9OnFileFlag rdf:type rdf:Property ;
    rdfs:label 'W9 On File Flag' ;
    rdfs:comment 'Indicates whether a current IRS Form W-9 is on file for this landlord for tax reporting purposes.' ;
    rdfs:domain ind:Landlord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL for the landlord entity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rent Schedule Id' ;
    rdfs:comment 'Unique identifier for the rent schedule record. Primary key. Represents one billing period for one lease agreement.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RentSchedule .

ind:primaryRentRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Rent Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant location occupying the leased premises for this rent schedule period.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:camAmount rdf:type rdf:Property ;
    rdfs:label 'Cam Amount' ;
    rdfs:comment 'The tenant\'s share of common area maintenance charges for this billing period, including property management, landscaping, parking lot maintenance, and shared facility upkeep. May be estimated or reconciled.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:camReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Cam Reconciliation Flag' ;
    rdfs:comment 'Indicates whether this billing period includes a CAM reconciliation adjustment, where estimated CAM charges are trued up to actual landlord expenses.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'The annual escalation rate applied to base rent for this period, expressed as a decimal (e.g., 0.0300 for 3% annual increase). Null if escalation type is none or stepped.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'The method by which base rent increases over the lease term. Fixed = predetermined amount, CPI = Consumer Price Index linked, Percentage = annual percentage increase, Stepped = scheduled step increases, None = flat rent.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'The tenant\'s share of property insurance premiums for this billing period, covering landlord\'s building and liability insurance. May be estimated and reconciled.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestExpense rdf:type rdf:Property ;
    rdfs:label 'Interest Expense' ;
    rdfs:comment 'The interest expense component of the lease payment for this period under IFRS 16 / ASC 842 finance lease accounting. Calculated using the incremental borrowing rate.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseAccountingClassification rdf:type rdf:Property ;
    rdfs:label 'Lease Accounting Classification' ;
    rdfs:comment 'The accounting treatment classification for this lease under IFRS 16 / ASC 842. Operating leases recognize rent expense; finance leases recognize depreciation and interest expense.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiabilityReduction rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Reduction' ;
    rdfs:comment 'The portion of the total occupancy cost that reduces the lease liability on the balance sheet for this period under IFRS 16 / ASC 842. Represents principal payment component.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyCostPercentage rdf:type rdf:Property ;
    rdfs:label 'Occupancy Cost Percentage' ;
    rdfs:comment 'The total occupancy cost as a percentage of restaurant sales for this period, calculated as (total_occupancy_cost / reported_sales_amount). Key performance metric for site profitability. Null if sales not reported.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the total rent and occupancy cost payment must be remitted to the landlord to avoid late fees or default.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentageRentAmount rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Amount' ;
    rdfs:comment 'The calculated percentage rent due for this billing period based on actual sales performance exceeding the threshold. Zero if sales did not exceed threshold or lease has no percentage rent clause.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyAddress rdf:type rdf:Property ;
    rdfs:label 'Property Address' ;
    rdfs:comment 'The full street address of the leased restaurant property for this rent schedule. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realEstateTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Real Estate Tax Amount' ;
    rdfs:comment 'The tenant\'s proportionate share of property taxes for this billing period. May be estimated monthly and reconciled annually based on actual tax assessments.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentPerSquareFoot rdf:type rdf:Property ;
    rdfs:label 'Rent Per Square Foot' ;
    rdfs:comment 'The base rent amount divided by square footage for this billing period, expressed as cost per square foot. Key benchmarking metric for real estate portfolio management.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Reported Sales Amount' ;
    rdfs:comment 'The gross sales revenue reported to the landlord for this billing period, used to calculate percentage rent. Confidential business performance data. Null if sales reporting is not required.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightOfUseAssetDepreciation rdf:type rdf:Property ;
    rdfs:label 'Right Of Use Asset Depreciation' ;
    rdfs:comment 'The depreciation expense for the right-of-use asset for this period under IFRS 16 / ASC 842. Typically straight-line over the lease term.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the tenant is contractually required to report sales revenue to the landlord for this billing period, typically for percentage rent calculation or lease compliance.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reconciliation Flag' ;
    rdfs:comment 'Indicates whether this billing period includes a real estate tax reconciliation adjustment, where estimated tax charges are trued up to actual property tax assessments.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalOccupancyCost rdf:type rdf:Property ;
    rdfs:label 'Total Occupancy Cost' ;
    rdfs:comment 'The sum of all rent and occupancy charges for this billing period: base rent + percentage rent + CAM + real estate tax + insurance + other charges. Represents total cash outflow for occupancy.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentPaymentId rdf:type rdf:Property ;
    rdfs:label 'Rent Payment Id' ;
    rdfs:comment 'Unique identifier for the rent payment transaction. Primary key.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRentApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rent Approved By User Employee Id' ;
    rdfs:comment 'Reference to the user or employee who approved this payment for disbursement.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:daysLate rdf:type rdf:Property ;
    rdfs:label 'Days Late' ;
    rdfs:comment 'The number of days between the payment due date and the actual payment date, indicating payment timeliness.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this payment is under dispute with the landlord due to billing discrepancies or lease interpretation issues.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for dispute if the payment is flagged as disputed (e.g., incorrect CAM charges, billing error, lease term interpretation).' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'The amount of late fee charged for this payment if payment was made after the due date.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Late Fee Applied Flag' ;
    rdfs:comment 'Indicates whether a late fee was applied to this payment due to payment being made after the due date.' ;
