ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Scheduling model applied to the employee.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to workforce.schedule. Business justification: A shift is a specific scheduled work block that belongs to a weekly/period-level schedule. The schedule is the parent container (published labor plan for a restaurant location and period); individual ' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:shiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shift Employee Id' ;
    rdfs:comment 'Identifier of the employee assigned to the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:shiftScheduledByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shift Scheduled By User Employee Id' ;
    rdfs:comment 'Identifier of the user who scheduled the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEnd rdf:type rdf:Property ;
    rdfs:label 'Actual End' ;
    rdfs:comment 'Actual clock-out timestamp recorded for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
