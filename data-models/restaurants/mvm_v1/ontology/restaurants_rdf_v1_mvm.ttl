ind:paymentRunType rdf:type rdf:Property ;
    rdfs:label 'Payment Run Type' ;
    rdfs:comment 'Classification of the run based on its business purpose.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeSeconds rdf:type rdf:Property ;
