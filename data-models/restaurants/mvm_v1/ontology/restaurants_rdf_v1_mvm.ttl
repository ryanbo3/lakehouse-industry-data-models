    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier1Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Price' ;
    rdfs:comment 'Unit price applied when the purchase quantity meets tier 1 minimum.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier2Min rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Min' ;
    rdfs:comment 'Minimum quantity required to qualify for the second volume discount tier.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier2Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Price' ;
    rdfs:comment 'Unit price applied when the purchase quantity meets tier 2 minimum.' ;
    rdfs:domain ind:SupplierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractPriceId rdf:type rdf:Property ;
    rdfs:label 'Contract Price Id' ;
    rdfs:comment 'System-generated unique identifier for the contract price record.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractPriceCode rdf:type rdf:Property ;
    rdfs:label 'Contract Price Code' ;
    rdfs:comment 'Business identifier or code assigned to the contract price (e.g., CP-2024-001).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPriceStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Price Status' ;
    rdfs:comment 'Current lifecycle status of the price record.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPrice rdf:type rdf:Property ;
    rdfs:label 'Default Price' ;
    rdfs:comment 'Baseline price per unit (SKU) when no volume tier applies. [Moved from supplier_contract: default_price on supplier_contract represents a baseline price per SKU — but in a contract covering multiple ingredients, each ingredient has its own contracted price. This attribute is more accurately represented as contracted_unit_price on the contract_price association, where it is scoped to a specific contract-ingredient combination. Keeping it on supplier_contract implies a single price for the entire contract, which misrepresents multi-SKU contracts.]' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Indicates whether this price record is the currently active price for the SKU.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Amount' ;
    rdfs:comment 'Numeric value of the contracted unit price.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'External index or commodity reference used for indexed pricing (e.g., USDA Corn Index).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTierMaxQty rdf:type rdf:Property ;
    rdfs:label 'Price Tier Max Qty' ;
    rdfs:comment 'Upper bound quantity for this price tier (null if no upper limit).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceTierMinQty rdf:type rdf:Property ;
    rdfs:label 'Price Tier Min Qty' ;
    rdfs:comment 'Lower bound quantity for this price tier (volume break).' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the price calculation method.' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUom rdf:type rdf:Property ;
    rdfs:label 'Price Uom' ;
    rdfs:comment 'Unit of measure for the default price (e.g., per unit, per case). [Moved from supplier_contract: price_uom on supplier_contract is the UOM for the default_price, which is ingredient-specific. Since each ingredient in a contract may have a different UOM (e.g., beef by lb, buns by case), this attribute belongs on the contract_price association as unit_of_measure, scoped to the specific contract-ingredient price line.]' ;
    rdfs:domain ind:ContractPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Compliance Documentation Url' ;
    rdfs:comment 'Link to stored compliance certificates and audit documents.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerSquareMeter rdf:type rdf:Property ;
    rdfs:label 'Cost Per Square Meter' ;
    rdfs:comment 'Operational cost metric expressed in local currency per m².' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossDockEnabled rdf:type rdf:Property ;
    rdfs:label 'Cross Dock Enabled' ;
    rdfs:comment 'True if the facility supports cross-docking operations.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dcCode rdf:type rdf:Property ;
    rdfs:label 'Dc Code' ;
    rdfs:comment 'Business-visible code used to reference the distribution center in external systems.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCenterName rdf:type rdf:Property ;
    rdfs:label 'Distribution Center Name' ;
    rdfs:comment 'Human-readable name of the distribution center.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Center Status' ;
    rdfs:comment 'Current operational status of the distribution center.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed (e.g., sprinkler, FM-200).' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCompliant rdf:type rdf:Property ;
    rdfs:label 'Haccp Compliant' ;
    rdfs:comment 'True if the facility complies with HACCP food-safety standards.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionScore rdf:type rdf:Property ;
    rdfs:label 'Inspection Score' ;
    rdfs:comment 'Numeric score assigned during the last inspection (0-100).' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfLoadingDocks rdf:type rdf:Property ;
    rdfs:label 'Number Of Loading Docks' ;
    rdfs:comment 'Count of loading dock bays available for inbound/outbound trucks.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refrigerationType rdf:type rdf:Property ;
    rdfs:label 'Refrigeration Type' ;
    rdfs:comment 'Specific refrigeration technology employed (e.g., cascade, glycol).' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Meters' ;
    rdfs:comment 'Total usable storage volume of the center in cubic meters.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedRestaurantCount rdf:type rdf:Property ;
    rdfs:label 'Supported Restaurant Count' ;
    rdfs:comment 'Number of restaurant locations served by this distribution center.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlSystem rdf:type rdf:Property ;
    rdfs:label 'Temperature Control System' ;
    rdfs:comment 'Description of the system used to maintain required temperatures.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMonitoringIntervalMinutes rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring Interval Minutes' ;
    rdfs:comment 'Frequency at which temperature readings are recorded.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyLogisticsFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Logistics Flag' ;
    rdfs:comment 'Indicates whether a 3PL provider manages the facility.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteManagementCertified rdf:type rdf:Property ;
    rdfs:label 'Waste Management Certified' ;
    rdfs:comment 'Indicates whether the center holds a certified waste-management program.' ;
    rdfs:domain ind:DistributionCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationSiteId rdf:type rdf:Property ;
    rdfs:label 'Destination Site Id' ;
    rdfs:comment 'Foreign key linking to realestate.site. Business justification: Shipments are delivered to individual restaurant sites; the FK enables logistics dashboards and delivery performance metrics per site.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Real date and time when the shipment arrived at the destination.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Real date and time when the shipment left the origin.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Identifier on the bill of lading document issued by the carrier.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContactPhone rdf:type rdf:Property ;
    rdfs:label 'Carrier Contact Phone' ;
    rdfs:comment 'Primary phone number for the carrier\'s logistics contact.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Standard Carrier Alpha Code used to uniquely identify the carrier in logistics systems.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Flag' ;
    rdfs:comment 'Indicates whether all required compliance documents were attached.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Physical container classification used for the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Status' ;
    rdfs:comment 'Current status of customs clearance for the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Total minutes the shipment arrived later than the scheduled arrival.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Free-text description of any exception or issue affecting the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total cost charged by the carrier for transporting the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Freight Invoice Number' ;
    rdfs:comment 'Invoice number issued by the carrier for freight charges.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Incoterm defining responsibility for freight costs and risk.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazard Material Flag' ;
    rdfs:comment 'True if the shipment contains regulated hazardous materials.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'True if the shipment was processed under an expedited service level.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfItems rdf:type rdf:Property ;
    rdfs:label 'Number Of Items' ;
    rdfs:comment 'Count of individual items or SKUs contained in the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the supplier\'s shipping location.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Planned date and time when the shipment is expected to arrive at the destination.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time when the shipment is expected to leave the origin.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal identifier applied to the container.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business identifier assigned by the carrier or logistics system for tracking the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Flag' ;
    rdfs:comment 'Indicates whether the shipment required temperature-controlled transport.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum temperature recorded during transport (°C).' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum temperature recorded during transport (°C).' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transport used for the shipment.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic M' ;
    rdfs:comment 'Total volume of the shipment in cubic meters.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Gross weight of the shipment in kilograms.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recall Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: FDA/USDA recall regulations (21 CFR Part 7) require a designated recall coordinator responsible for executing recalls, notifying affected restaurant locations, and filing regulatory reports. Every foo' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedLotNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Lot Numbers' ;
    rdfs:comment 'Comma-separated list of lot or batch numbers impacted by the recall.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRestaurantLocations rdf:type rdf:Property ;
    rdfs:label 'Affected Restaurant Locations' ;
    rdfs:comment 'List of restaurant sites that received the recalled product.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFda rdf:type rdf:Property ;
    rdfs:label 'Compliance Fda' ;
    rdfs:comment 'True if the product complies with FDA regulations.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceHaccp rdf:type rdf:Property ;
    rdfs:label 'Compliance Haccp' ;
    rdfs:comment 'True if the product meets HACCP safety standards.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceUsda rdf:type rdf:Property ;
    rdfs:label 'Compliance Usda' ;
    rdfs:comment 'True if the product complies with USDA regulations.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Broad category of the recalled product.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRecalled rdf:type rdf:Property ;
    rdfs:label 'Quantity Recalled' ;
    rdfs:comment 'Total amount of product recalled, expressed in the unit_of_measure.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'Regulatory classification indicating severity and health risk of the recall.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClosureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recall Closure Timestamp' ;
    rdfs:comment 'Date and time when the recall was officially closed or resolved.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallInitiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recall Initiation Timestamp' ;
    rdfs:comment 'Date and time when the recall was initiated.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official recall reference number assigned by regulatory agency or supplier.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Root cause for the recall (e.g., contamination, allergen mislabeling, foreign material).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallSeverity rdf:type rdf:Property ;
    rdfs:label 'Recall Severity' ;
    rdfs:comment 'Severity level assigned to the recall based on health risk.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Whether the recall was initiated voluntarily by the supplier or mandated by regulators.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of notification to regulatory bodies (e.g., FDA, USDA).' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk rating (e.g., 1-5) used for internal prioritization.' ;
    rdfs:domain ind:RecallEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comparativePriorPeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparative Prior Period Id' ;
    rdfs:comment 'Foreign key reference to the immediately preceding period (e.g., prior month). Used for sequential period-over-period analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:comparativePriorYearPeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparative Prior Year Period Id' ;
    rdfs:comment 'Foreign key reference to the equivalent period in the prior fiscal year. Used for year-over-year comparative analysis and SSS reporting.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:priorFinancialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Financial Period Id' ;
    rdfs:comment 'Self-referencing FK on financial_period (prior_financial_period_id)' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'Accounting standard applied in this ledger: US_GAAP (United States Generally Accepted Accounting Principles), IFRS (International Financial Reporting Standards), local_GAAP (country-specific standards), management (internal reporting).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether adjustment postings (corrections, reclassifications) are allowed in this period after initial close. Used for controlled reopening during audit or correction cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this period is subject to external audit review. Typically true for year-end periods and quarterly periods for publicly traded entities.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Flag' ;
    rdfs:comment 'True if changes to this period are tracked for audit purposes.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarDaysCount rdf:type rdf:Property ;
    rdfs:label 'Calendar Days Count' ;
    rdfs:comment 'Total number of calendar days in the period. Used for daily average calculations and period normalization in financial analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'Month number (1-12) in the calendar year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'Quarter number (1-4) in the calendar year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'Gregorian calendar year of the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeActualDate rdf:type rdf:Property ;
    rdfs:label 'Close Actual Date' ;
    rdfs:comment 'Actual date when the period-end close process was completed and the period status changed to closed. Null if period is still open.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Close Scheduled Date' ;
    rdfs:comment 'Target date for completing the period-end close process. Used for close calendar planning and tracking adherence to financial reporting deadlines.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Close Variance Days' ;
    rdfs:comment 'Number of days between scheduled and actual close date (positive if late, negative if early). Used to track period-end close efficiency and identify process improvement opportunities.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Required Flag' ;
    rdfs:comment 'Indicates whether this period requires multi-entity consolidation processing. True for periods where intercompany eliminations and group reporting are performed.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayCount rdf:type rdf:Property ;
    rdfs:label 'Day Count' ;
    rdfs:comment 'Total count of calendar days covered by the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRateToReporting rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Reporting' ;
    rdfs:comment 'Conversion rate from functional currency to reporting currency for the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate applied for currency translation in this period: average (period average rate for P&L), closing (period-end rate for balance sheet), budget (planning rate), historical (acquisition date rate for fixed assets).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Financial Period Description' ;
    rdfs:comment 'Optional free-text description of the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementType rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Type' ;
    rdfs:comment 'Type of financial statement the period primarily supports.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Month number (1-12) within the fiscal year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Code' ;
    rdfs:comment 'Standard code used by SAP for the fiscal period (e.g., "2023P01").' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Quarter number (1-4) within the fiscal year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayIndicator rdf:type rdf:Property ;
    rdfs:label 'Holiday Indicator' ;
    rdfs:comment 'Degree to which holidays affect the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'True if the period is used for post-close adjustments.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'True if the period values are based on estimates rather than actuals.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Period' ;
    rdfs:comment 'True if the period includes a recognized holiday schedule.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterim rdf:type rdf:Property ;
    rdfs:label 'Is Interim' ;
    rdfs:comment 'True if the period is an interim (non-full) reporting period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger: leading (primary GAAP ledger for statutory reporting), non_leading (parallel IFRS or local GAAP ledger), special_purpose (management or segment reporting ledger).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockFlag rdf:type rdf:Property ;
    rdfs:label 'Lock Flag' ;
    rdfs:comment 'True when the period is locked for posting to prevent changes.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCategory rdf:type rdf:Property ;
    rdfs:label 'Period Category' ;
    rdfs:comment 'Business classification of the period data.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodKey rdf:type rdf:Property ;
    rdfs:label 'Period Key' ;
    rdfs:comment 'Compact code representing the period (e.g., FY2023Q1, FY2023M04).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the period (e.g., \'January 2024\', \'Q1 FY2024\', \'Period 13 - Year-End Adjustments\'). Used for reporting and user interface display.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Period Sequence Number' ;
    rdfs:comment 'Sequential order of the period within its fiscal year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether new transactions can be posted to this period. True if period is open for posting, false if closed or locked.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'Fiscal quarter number (1-4) to which this period belongs. Supports quarterly financial reporting and Same-Store Sales (SSS) analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'True if the period is used for tax reporting calculations.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period Flag' ;
    rdfs:comment 'Indicates whether this period is a tax reporting period requiring submission of tax returns (e.g., quarterly estimated tax, annual tax filing). Used for tax compliance tracking.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'Number of business working days in the period, excluding weekends and holidays. Used for normalizing operational metrics and labor cost analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearPeriodKey rdf:type rdf:Property ;
    rdfs:label 'Year Period Key' ;
    rdfs:comment 'Concatenated key combining fiscal year and period number (format: YYYYPPP, e.g., 2024001 for FY2024 Period 1). Used for sorting and comparative period analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPosRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Pos Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit to which the terminal is assigned.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryReplacementTerminalPosTerminalId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Terminal Pos Terminal Id' ;
    rdfs:comment 'Identifier of the POS terminal that replaced this unit, if applicable.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:assignedStation rdf:type rdf:Property ;
    rdfs:label 'Assigned Station' ;
    rdfs:comment 'Physical station or service point where the terminal is deployed (e.g., FOH counter, DT window 1, DT window 2, bar, patio, expo).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDrawerAttached rdf:type rdf:Property ;
    rdfs:label 'Cash Drawer Attached' ;
    rdfs:comment 'Indicates whether a cash drawer is attached to this POS terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the POS terminal was decommissioned and removed from active service.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Identifier of the encryption key used to secure transaction data on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version of the firmware currently running on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Numeric floor level of the terminal location, useful for multi-story venues.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardwareModel rdf:type rdf:Property ;
    rdfs:label 'Hardware Model' ;
    rdfs:comment 'Manufacturer model number or designation of the physical POS terminal hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance or security audit performed on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPciAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Pci Audit Date' ;
    rdfs:comment 'Date of the most recent PCI DSS compliance audit or assessment for this terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSoftwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Software Update Date' ;
    rdfs:comment 'Date of the most recent software update or patch applied to the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-form description of where the terminal is situated within the restaurant (e.g., "Front Counter – Station 3").' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware MAC address of the POS terminal network interface.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that produced the POS terminal hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Physical or logical network connection type used by the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Planned date for the next routine maintenance.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPciAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Pci Audit Date' ;
    rdfs:comment 'Scheduled date for the next PCI DSS compliance audit or assessment.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodsSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Supported' ;
    rdfs:comment 'Comma-separated list of payment method codes the terminal can accept (e.g., "credit,debit,cash,applepay").' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessingCapability rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Capability' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this terminal (e.g., credit, debit, NFC, gift_card, mobile_wallet).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessingVendor rdf:type rdf:Property ;
