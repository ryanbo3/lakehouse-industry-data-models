ind:workforceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Workforce Certification Id' ;
    rdfs:comment 'Foreign key linking to workforce.certification. Business justification: Food safety audit certifications must reconcile with HR certification records for regulatory compliance. Linking food_safety_certification to workforce.certification enables cross-domain expiration tr' ;
    rdfs:domain ind:FoodSafetyCertification ;
    rdf:type owl:ObjectProperty ;
