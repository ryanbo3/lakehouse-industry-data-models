    rdfs:label 'Nro Pipeline Id' ;
    rdfs:comment 'Foreign key linking to franchise.nro_pipeline. Business justification: The real estate NRO project executes the franchise NRO pipeline opportunity. Linking nro_project to nro_pipeline enables integrated new-opening reporting, aligning construction/permitting milestones w' ;
    rdfs:domain ind:Restaurants ;
