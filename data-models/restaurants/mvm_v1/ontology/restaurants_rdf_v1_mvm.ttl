    rdfs:comment 'Typical time in minutes from order acceptance to delivery completion for this platform.' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the contractual agreement with the platform expires or is terminated (nullable for open-ended contracts).' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the contractual agreement with the platform became effective.' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryPlatformCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the platform in internal systems.' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPlatformName rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform Name' ;
    rdfs:comment 'Official name of the delivery platform (e.g., DoorDash, UberEats).' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPlatformStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Platform Status' ;
    rdfs:comment 'Current operational status of the delivery platform.' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePercentage rdf:type rdf:Property ;
