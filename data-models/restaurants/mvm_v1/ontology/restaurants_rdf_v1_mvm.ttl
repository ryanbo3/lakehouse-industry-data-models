    rdfs:comment 'Primary service channel that this terminal supports for order capture and fulfillment.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Current version of the Oracle MICROS POS software installed on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the station area: Front of House (FOH), Back of House (BOH), Drive-Thru (DT), kiosk, or mobile.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsChip rdf:type rdf:Property ;
    rdfs:label 'Supports Chip' ;
    rdfs:comment 'Indicates whether the terminal can read EMV chip cards.' ;
