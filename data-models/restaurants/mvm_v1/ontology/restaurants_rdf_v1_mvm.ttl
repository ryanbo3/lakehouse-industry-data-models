    rdfs:range xsd:string .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date of the shift (derived from scheduled_start).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift (e.g., regular, overtime, on-call, training).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:station rdf:type rdf:Property ;
    rdfs:label 'Station' ;
    rdfs:comment 'Work station or area assigned to the employee (Back-of-House, Front-of-House, etc.).' ;
    rdfs:domain ind:Shift ;
