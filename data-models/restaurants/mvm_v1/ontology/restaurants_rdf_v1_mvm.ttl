    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Human-readable name of the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle state of the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandType rdf:type rdf:Property ;
    rdfs:label 'Brand Type' ;
    rdfs:comment 'Classification of the brand by service format.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorHex rdf:type rdf:Property ;
    rdfs:label 'Color Hex' ;
    rdfs:comment 'Hexadecimal representation of the brand\'s primary color.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAllowed rdf:type rdf:Property ;
    rdfs:label 'Franchise Allowed' ;
    rdfs:comment 'Indicates whether the brand is offered as a franchise model.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseFeePercent rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Percent' ;
    rdfs:comment 'Initial franchise fee expressed as a percent of initial investment.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the brand\'s corporate headquarters is located.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the brand\'s headquarters.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'Link to the brand\'s primary logo image.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSharePercent rdf:type rdf:Property ;
    rdfs:label 'Market Share Percent' ;
    rdfs:comment 'Estimated share of the market segment held by the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryMarketRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Market Region' ;
    rdfs:comment 'Geographic region where the brand has its strongest presence.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyFeePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Fee Percent' ;
    rdfs:comment 'Ongoing royalty fee charged to franchisees, expressed as a percent of sales.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media identifier (e.g., @brand) used for marketing.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagline rdf:type rdf:Property ;
    rdfs:label 'Tagline' ;
    rdfs:comment 'Short marketing slogan associated with the brand.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentDepartmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Department Id' ;
    rdfs:comment 'Identifier of the immediate parent department in the organizational hierarchy.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Department .

ind:areaSqft rdf:type rdf:Property ;
    rdfs:label 'Area Sqft' ;
    rdfs:comment 'Square-footage occupied by the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Service Time Minutes' ;
    rdfs:comment 'Average time in minutes to complete a core service task for the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Higher-level classification used for reporting and cost allocation.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Business-assigned short code that uniquely identifies the department within the enterprise.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentDescription rdf:type rdf:Property ;
    rdfs:label 'Department Description' ;
    rdfs:comment 'Free-form text describing the department\'s purpose and responsibilities.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Human-readable name of the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentStatus rdf:type rdf:Property ;
    rdfs:label 'Department Status' ;
    rdfs:comment 'Current lifecycle status of the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Categorizes the department by its functional area.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFranchise rdf:type rdf:Property ;
    rdfs:label 'Is Franchise' ;
    rdfs:comment 'True if the department belongs to a franchised unit.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHours rdf:type rdf:Property ;
    rdfs:label 'Operational Hours' ;
    rdfs:comment 'Standard daily operating hours expressed as HH:MM-HH:MM.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Level of service the department is expected to deliver.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftSchedule rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule' ;
    rdfs:comment 'Primary shift schedule pattern used by the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnoverRate rdf:type rdf:Property ;
    rdfs:label 'Turnover Rate' ;
    rdfs:comment 'Annual percentage of staff turnover in the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Item Assignment Id' ;
    rdfs:comment 'Primary key for the menu_item_assignment association' ;
    rdfs:domain ind:ItemAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Channel-specific availability override for this item on this menu, expressed as a pipe-delimited list of enabled channels (e.g., \'DT|OLO\'). Overrides the item-level channel flags when a menu engineer restricts or expands availability for a specific menu context. Belongs to the assignment because channel restrictions may differ per menu.' ;
    rdfs:domain ind:ItemAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayCategory rdf:type rdf:Property ;
    rdfs:label 'Display Category' ;
    rdfs:comment 'The category label under which this item is grouped on this specific menu (e.g., \'Burgers\', \'Sides\', \'Beverages\'). Belongs to the assignment because the same item may be categorized differently across menus (e.g., a chicken sandwich may appear under \'Sandwiches\' on one menu and \'Value Meals\' on another).' ;
    rdfs:domain ind:ItemAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this item is promoted or highlighted on this specific menu (e.g., shown in a featured section, displayed with a badge, or given visual prominence on digital menu boards). Belongs to the assignment because featured status is a menu-context decision, not an intrinsic item property.' ;
    rdfs:domain ind:ItemAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceOverride rdf:type rdf:Property ;
    rdfs:label 'Price Override' ;
    rdfs:comment 'Menu-specific selling price for this item that overrides the item\'s base_price on menu_item. Used for channel-specific pricing (e.g., 3PD surcharge menus), franchise-specific pricing, or LTO promotional pricing. Belongs to the assignment because the same item may be priced differently across menus. Null indicates no override — base_price applies.' ;
    rdfs:domain ind:ItemAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comboMealComponentId rdf:type rdf:Property ;
    rdfs:label 'Combo Meal Component Id' ;
    rdfs:comment 'Primary key for the combo_meal_component association' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calorieContribution rdf:type rdf:Property ;
    rdfs:label 'Calorie Contribution' ;
    rdfs:comment 'The caloric value (kcal) attributed to this specific component within the combo meal, used to compute the combo\'s total and range calorie display. Belongs to the pairing because the same item may contribute different calories in different combo contexts (e.g., different portion sizes).' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Ordinal position of this menu item within the combo meal\'s component list. Drives display order on menu boards, POS screens, and digital ordering interfaces. Belongs to the pairing, not to either entity alone.' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Functional role of this menu item within the combo meal bundle (e.g., ENTREE, SIDE, BEVERAGE). The same menu item may play different roles in different combos. Belongs to the pairing.' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costContribution rdf:type rdf:Property ;
    rdfs:label 'Cost Contribution' ;
    rdfs:comment 'The standard cost of goods (COGS) allocated to this component within the combo meal bundle, used for food cost and margin analysis at the combo level. Belongs to the pairing, not to the item or combo alone.' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isComboEligible rdf:type rdf:Property ;
    rdfs:label 'Is Combo Eligible' ;
    rdfs:comment 'Indicates whether this menu item can be included as a component in a combo meal offering. Used by menu engineering teams to configure combo meal bundles and upsell prompts in POS and OLO. [Moved from menu_item: This boolean flag on menu_item indicates whether an item CAN participate in a combo, but the actual participation — which combo, in what role, in what quantity — is now captured in combo_meal_component. The eligibility flag is a derived or redundant signal once the association table exists. It may be retained on menu_item as a denormalized convenience flag for filtering, but architecturally the ground truth of combo participation lives in the association. Teams should evaluate whether to deprecate it or keep it as a computed/maintained flag.]' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubstitutable rdf:type rdf:Property ;
    rdfs:label 'Is Substitutable' ;
    rdfs:comment 'Indicates whether the guest may substitute this component with an eligible alternative menu item. Drives substitution logic in POS and OLO systems. Belongs to the pairing.' ;
    rdfs:domain ind:ComboMealComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalCountLineId rdf:type rdf:Property ;
    rdfs:label 'Physical Count Line Id' ;
    rdfs:comment 'Primary key for the physical_count_line association' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countUom rdf:type rdf:Property ;
    rdfs:label 'Count Uom' ;
    rdfs:comment 'The unit of measure used by the counting team for this SKU during this count event (e.g., each, case, lb). May differ from the stock item\'s standard UOM and is specific to this count line.' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'The physical quantity of this SKU observed and recorded by the counting team during the count event. Belongs to the line, not the header or the stock item master.' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemQuantity rdf:type rdf:Property ;
    rdfs:label 'System Quantity' ;
    rdfs:comment 'The inventory system\'s expected on-hand quantity for this SKU at the time of the count event. Captured at count time and belongs to this specific count line, not the stock item master.' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between counted_quantity and system_quantity for this SKU in this count event. Positive indicates overage; negative indicates shortage.' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The dollar value of the variance for this SKU line, calculated as variance_quantity multiplied by the unit cost at count time. Feeds period-end COGS% and GL journal entry.' ;
    rdfs:domain ind:PhysicalCountLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVendorItemId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Item Id' ;
    rdfs:comment 'Primary key for the approved_vendor_item association' ;
    rdfs:domain ind:ApprovedVendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier is the designated primary (preferred) source for this ingredient. Used in multi-sourcing strategy to determine default sourcing decisions.' ;
    rdfs:domain ind:ApprovedVendorItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
