ind:laborRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Per Hour' ;
    rdfs:comment 'Pay rate per hour for the employee on this shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onCallFlag rdf:type rdf:Property ;
