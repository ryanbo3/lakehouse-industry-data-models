ind:laborPctMidday rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Midday' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the midday shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
