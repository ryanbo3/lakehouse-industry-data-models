ind:unionMember rdf:type rdf:Property ;
    rdfs:label 'Union Member' ;
    rdfs:comment 'True if the employee is a member of a labor union.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
