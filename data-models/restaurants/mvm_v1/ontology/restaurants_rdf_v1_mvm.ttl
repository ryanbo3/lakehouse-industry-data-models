    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Property Tax Amount' ;
    rdfs:comment 'The property tax amount paid as part of this rent payment, representing the tenant\'s share of real estate taxes.' ;
