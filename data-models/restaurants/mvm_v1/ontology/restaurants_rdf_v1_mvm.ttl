ind:laborPctMorning rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Morning' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the morning shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPctNight rdf:type rdf:Property ;
    rdfs:label 'Labor Pct Night' ;
    rdfs:comment 'Target labor cost as a percentage of sales for the night shift.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Human-readable schedule code assigned by the scheduling system (e.g., SCHED-2024-W15).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
