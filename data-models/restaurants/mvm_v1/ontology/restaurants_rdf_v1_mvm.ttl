ind:openedUnitId rdf:type rdf:Property ;
    rdfs:label 'Opened Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: When an NRO project completes, the resulting restaurant unit must be linked back to the pipeline record for development tracking, ROI analysis, and post-opening performance benchmarking. Franchise dev' ;
