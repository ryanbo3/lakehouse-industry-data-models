ind:developmentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Development Schedule Id' ;
    rdfs:comment 'Foreign key linking to franchise.development_schedule. Business justification: Each NRO pipeline project fulfills a commitment under a franchisee\'s contractual development schedule. Linking nro_pipeline to development_schedule enables tracking of which specific schedule commitme' ;
