    rdfs:range ind:Unit .

ind:scheduleUnitId rdf:type rdf:Property ;
    rdfs:label 'Schedule Unit Id' ;
    rdfs:comment 'Unique identifier of the restaurant unit for which the schedule is created.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:daypartScheduleNotes rdf:type rdf:Property ;
