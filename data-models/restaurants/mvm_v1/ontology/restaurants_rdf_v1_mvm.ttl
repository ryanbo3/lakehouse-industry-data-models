ind:actualStart rdf:type rdf:Property ;
    rdfs:label 'Actual Start' ;
    rdfs:comment 'Actual clock-in timestamp recorded for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total break time in minutes allocated for the shift.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Flag indicating soft deletion of the shift record.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborPercentage rdf:type rdf:Property ;
    rdfs:label 'Labor Percentage' ;
    rdfs:comment 'Labor cost expressed as a percentage of projected sales for the shift.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
