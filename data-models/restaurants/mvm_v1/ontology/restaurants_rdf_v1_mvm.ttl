ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Classification of the platform based on ownership and integration model.' ;
    rdfs:domain ind:DeliveryPlatform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactEmail rdf:type rdf:Property ;
    rdfs:label 'Support Contact Email' ;
