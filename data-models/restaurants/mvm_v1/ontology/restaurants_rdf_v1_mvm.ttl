    rdfs:comment 'Calendar date of the guest\'s inaugural purchase.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltvCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Ltv Calculation Date' ;
    rdfs:comment 'Calendar date on which the LTV metrics were most recently refreshed.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltvLastUpdated rdf:type rdf:Property ;
    rdfs:label 'Ltv Last Updated' ;
    rdfs:comment 'Exact moment the LTV record was last refreshed.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltvStatus rdf:type rdf:Property ;
    rdfs:label 'Ltv Status' ;
    rdfs:comment 'Current lifecycle state of the LTV record.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentVisitDate rdf:type rdf:Property ;
    rdfs:label 'Most Recent Visit Date' ;
    rdfs:comment 'Calendar date of the guest\'s latest purchase.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:predictedFutureValue rdf:type rdf:Property ;
    rdfs:label 'Predicted Future Value' ;
    rdfs:comment 'Forecasted monetary contribution of the guest over the next 12 months.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Analytical segment assigned to the guest for targeting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHistoricalSpend rdf:type rdf:Property ;
    rdfs:label 'Total Historical Spend' ;
    rdfs:comment 'Cumulative monetary amount the guest has spent across all transactions to date.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionSurveyId rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Id' ;
    rdfs:comment 'Unique identifier for each satisfaction survey instance.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SatisfactionSurvey .

ind:performanceScorecardId rdf:type rdf:Property ;
    rdfs:label 'Performance Scorecard Id' ;
    rdfs:comment 'Foreign key linking to franchise.performance_scorecard. Business justification: Franchisor performance scorecards store customer_satisfaction_score and net_promoter_score derived from guest surveys. Linking each survey to its evaluation period scorecard enables auditors and franc' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceScorecard .

ind:primarySatisfactionGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Satisfaction Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who received the survey.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:primarySatisfactionUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Satisfaction Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where the guest experience occurred.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:tertiarySatisfactionUnitId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Satisfaction Unit Id' ;
    rdfs:comment 'Identifier of the restaurant unit where the guest experience occurred.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text comments entered by the guest.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Indicates whether the guest completed, partially completed, declined, or never received the survey.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'CSAT rating provided by the guest, typically on a 1-5 scale.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Channel used to deliver the survey to the guest.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO language code of the survey presented to the guest.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date-time when the guest submitted the survey response.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:satisfactionSurveyStatus rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Status' ;
    rdfs:comment 'Current lifecycle status of the survey record.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey (Customer Satisfaction, Net Promoter Score, or post-delivery feedback).' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the survey questionnaire used.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'Calendar date of the guest\'s visit, derived from visit_timestamp.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit Timestamp' ;
    rdfs:comment 'Date-time when the guest\'s visit or order took place.' ;
    rdfs:domain ind:SatisfactionSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Complaint Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who raised the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:complaintProfileId rdf:type rdf:Property ;
    rdfs:label 'Complaint Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who raised the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:complaintRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Complaint Restaurant Unit Id' ;
    rdfs:comment 'Identifier of the restaurant location where the complaint originated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:complaintUnitId rdf:type rdf:Property ;
    rdfs:label 'Complaint Unit Id' ;
    rdfs:comment 'Identifier of the restaurant location where the complaint originated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:complianceAuditId rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Id' ;
    rdfs:comment 'Foreign key linking to franchise.compliance_audit. Business justification: Guest complaints (especially food safety and brand standards violations) are reviewed and cited during franchise compliance audits. Auditors reference specific complaint records when scoring franchise' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAudit .

ind:handlingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handling Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for Complaint Resolution Report that assigns a responsible employee to each complaint, enabling accountability and SLA tracking.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resolutionGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Resolution Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Complaint resolution payouts (resolution_amount already on complaint) must be posted to a specific GL account for expense recognition and P&L reporting. Foodservice controllers require GL account assi' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:complaintCategory rdf:type rdf:Property ;
    rdfs:label 'Complaint Category' ;
    rdfs:comment 'Primary classification of the complaint reason.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Free-text description provided by the guest detailing the issue.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Human-readable business identifier assigned to the complaint (e.g., C-20231234).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current lifecycle state of the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Complaint Timestamp' ;
    rdfs:comment 'Date and time when the complaint was initially recorded.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalatedTo rdf:type rdf:Property ;
    rdfs:label 'Escalated To' ;
    rdfs:comment 'Identifier of the employee or manager to whom the complaint was escalated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the complaint was escalated to higher management.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Additional free-text feedback from the guest regarding the complaint handling.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Timestamp' ;
    rdfs:comment 'Timestamp when the guest provided privacy consent.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordCreatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Created At' ;
    rdfs:comment 'Timestamp when the complaint record was first persisted in the data lake.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedAt rdf:type rdf:Property ;
    rdfs:label 'Record Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to the complaint record.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'Monetary value associated with the resolution (e.g., refund amount).' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the complaint resolution process.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the complaint was resolved.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Method used to resolve the complaint.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelIdentityId rdf:type rdf:Property ;
    rdfs:label 'Channel Identity Id' ;
    rdfs:comment 'System-generated unique identifier for each channel identity record.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChannelGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Channel Guest Profile Id' ;
    rdfs:comment 'Reference to the canonical guest profile that this channel identity belongs to.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:channelIdentityStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Identity Status' ;
    rdfs:comment 'Current lifecycle status of the channel identity record.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelUserEmail rdf:type rdf:Property ;
    rdfs:label 'Channel User Email' ;
    rdfs:comment 'Email address of the guest in the source channel.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelUserName rdf:type rdf:Property ;
    rdfs:label 'Channel User Name' ;
    rdfs:comment 'Display name of the guest as known in the source channel.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelUserPhone rdf:type rdf:Property ;
    rdfs:label 'Channel User Phone' ;
    rdfs:comment 'Phone number of the guest in the source channel.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBySystem rdf:type rdf:Property ;
    rdfs:label 'Created By System' ;
    rdfs:comment 'Name of the source system that initially created the channel identity record.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalIdentifier rdf:type rdf:Property ;
    rdfs:label 'External Identifier' ;
    rdfs:comment 'Identifier assigned to the guest in the source system (e.g., email address, loyalty card number, device ID).' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'Category describing the nature of the external identifier.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestAccount rdf:type rdf:Property ;
    rdfs:label 'Is Test Account' ;
    rdfs:comment 'Indicates whether the record belongs to a test or sandbox account.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedBySystem rdf:type rdf:Property ;
    rdfs:label 'Last Updated By System' ;
    rdfs:comment 'Name of the system that performed the most recent update.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'When the external identifier was last verified as belonging to the guest.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privacyStatus rdf:type rdf:Property ;
    rdfs:label 'Privacy Status' ;
    rdfs:comment 'Current privacy state for the channel identity (consented, revoked, unknown).' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Monotonically increasing version number for optimistic concurrency control.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source System Created Timestamp' ;
    rdfs:comment 'Timestamp when the source system first created the external identifier.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source System Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent change to the external identifier in the source system.' ;
    rdfs:domain ind:ChannelIdentity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Host Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Guest Flow Management records which host/hostess greeted the guest, essential for staffing analysis and guest experience metrics.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:registrationUnitId rdf:type rdf:Property ;
    rdfs:label 'Registration Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: Unit-level digital adoption reporting tracks where digital accounts were created (kiosk, in-store tablet, drive-thru) for marketing ROI and technology investment decisions. Operations teams use this t' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Membership tier that determines benefits and loyalty program eligibility.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Software version of the mobile or web app used during the last login.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Guest\'s consent to receive marketing communications.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentThirdParty rdf:type rdf:Property ;
    rdfs:label 'Consent Third Party' ;
    rdfs:comment 'Guest\'s consent to share data with approved third-party partners.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used for the last login (e.g., mobile, tablet).' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Digital Account Status' ;
    rdfs:comment 'Current operational state of the digital account.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedLoginAttempts rdf:type rdf:Property ;
    rdfs:label 'Failed Login Attempts' ;
    rdfs:comment 'Count of consecutive unsuccessful login attempts since the last successful login.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Date-time of the most recent successful authentication to the digital account.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lockout Timestamp' ;
    rdfs:comment 'Timestamp when the account was locked due to security policy; null if not locked.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passwordLastChanged rdf:type rdf:Property ;
    rdfs:label 'Password Last Changed' ;
    rdfs:comment 'Date when the account password was most recently updated.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privacyOptOut rdf:type rdf:Property ;
    rdfs:label 'Privacy Opt Out' ;
    rdfs:comment 'Indicates whether the guest has opted out of data collection beyond required operational purposes.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'Channel through which the guest originally registered the digital account.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twoFactorEnabled rdf:type rdf:Property ;
    rdfs:label 'Two Factor Enabled' ;
    rdfs:comment 'Indicates whether two-factor authentication is active for the account.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique login name chosen by the guest for digital access.' ;
    rdfs:domain ind:DigitalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionCenterId rdf:type rdf:Property ;
    rdfs:label 'Distribution Center Id' ;
    rdfs:comment 'Foreign key linking to supply.distribution_center. Business justification: Assigning each franchisee to a primary distribution center supports logistics planning and delivery scheduling reports.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DistributionCenter .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Reported annual gross revenue of the franchisee.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageUnitVolume rdf:type rdf:Property ;
    rdfs:label 'Average Unit Volume' ;
    rdfs:comment 'Average sales volume per unit for the franchisee.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Credit rating assigned to the franchisee by a rating agency. [ENUM-REF-CANDIDATE: aaa|aa|a|bbb|bb|b|ccc|cc|c|d — promote to reference product]' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date the franchisee entity was legally formed.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fddDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Fdd Disclosure Status' ;
    rdfs:comment 'Status of the Franchise Disclosure Document compliance for the franchisee.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodSafetyCertified rdf:type rdf:Property ;
    rdfs:label 'Food Safety Certified' ;
    rdfs:comment 'Indicates whether the franchisee holds a current food safety certification (e.g., ServSafe).' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Amount' ;
    rdfs:comment 'Initial fee paid by the franchisee for the franchise rights.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseeNumber rdf:type rdf:Property ;
    rdfs:label 'Franchisee Number' ;
    rdfs:comment 'Unique business identifier assigned to the franchisee for internal tracking.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseeStatus rdf:type rdf:Property ;
    rdfs:label 'Franchisee Status' ;
    rdfs:comment 'Current lifecycle status of the franchisee partnership.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseeType rdf:type rdf:Property ;
    rdfs:label 'Franchisee Type' ;
    rdfs:comment 'Legal structure of the franchisee entity.' ;
    rdfs:domain ind:Franchisee ;
    rdf:type owl:DatatypeProperty ;
