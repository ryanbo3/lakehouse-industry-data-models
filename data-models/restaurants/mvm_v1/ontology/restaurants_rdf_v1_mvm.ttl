ind:homeUnitId rdf:type rdf:Property ;
    rdfs:label 'Home Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: Unit-level LTV attribution is required for franchisee royalty calculations and unit-level revenue reporting. Finance teams attribute guest lifetime value to a home unit to measure unit contribution to' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:primaryLifetimeGuestProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifetime Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest to whom this lifetime value belongs.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:averageTransactionsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Average Transactions Per Month' ;
    rdfs:comment 'Mean count of transactions the guest completes each month.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentOptIn rdf:type rdf:Property ;
    rdfs:label 'Consent Opt In' ;
    rdfs:comment 'True if the guest has opted in to data collection and marketing communications.' ;
    rdfs:domain ind:Guest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRefreshCycle rdf:type rdf:Property ;
    rdfs:label 'Data Refresh Cycle' ;
    rdfs:comment 'Scheduled frequency at which the LTV metrics are recomputed.' ;
    rdfs:domain ind:LifetimeValue ;
    rdf:type owl:DatatypeProperty ;
