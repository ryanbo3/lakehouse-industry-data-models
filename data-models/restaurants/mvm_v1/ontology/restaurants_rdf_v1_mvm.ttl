    rdfs:comment 'Unique identifier of the guest to whom this preference belongs.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:preferenceUnsafeMenuItemId rdf:type rdf:Property ;
    rdfs:label 'Preference Unsafe Menu Item Id' ;
    rdfs:comment 'Foreign key linking to menu.menu_item. Business justification: Real-time allergen-safe item filtering at POS and OLO requires linking a guest\'s allergen profile directly to unsafe menu items. This enables \'items to avoid\' warnings during ordering — a named food s' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuItem .

ind:preferredBrandId rdf:type rdf:Property ;
    rdfs:label 'Preferred Brand Id' ;
    rdfs:comment 'Foreign key linking to restaurant.brand. Business justification: Multi-brand operators (RBI, Yum! Brands) use brand-level preference for cross-brand marketing suppression and brand-specific loyalty segmentation. A guest may prefer Brand A over Brand B; this drives ' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:preferredUnitId rdf:type rdf:Property ;
    rdfs:label 'Preferred Unit Id' ;
    rdfs:comment 'Foreign key linking to restaurant.unit. Business justification: Location-based personalization engine uses a guest\'s preferred unit to deliver unit-specific offers, push notifications, and menu recommendations. Distinct from profile.preferred_store_unit_id — prefe' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:communicationChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Channel Preference' ;
    rdfs:comment 'Guest\'s preferred channel for receiving communications.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
