ind:laborForecastId rdf:type rdf:Property ;
    rdfs:label 'Labor Forecast Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_forecast. Business justification: Labor schedules in foodservice are built directly from labor forecasts — the projected FTE demand by daypart drives how many employees are scheduled per shift. Adding labor_forecast_id to schedule doc' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborForecast .

ind:scheduleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Employee Id' ;
    rdfs:comment 'Unique identifier of the manager or supervisor who approved the schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Manager Employee Id' ;
    rdfs:comment 'Unique identifier of the manager or supervisor who approved the schedule.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduleRestaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Schedule Restaurant Unit Id' ;
