    rdfs:comment 'Organizational role responsible for maintaining the template (e.g., Operations Manager).' ;
    rdfs:domain ind:ChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateFilePath rdf:type rdf:Property ;
    rdfs:label 'Template File Path' ;
    rdfs:comment 'File system or storage path where the template document resides.' ;
    rdfs:domain ind:ChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateFormat rdf:type rdf:Property ;
    rdfs:label 'Template Format' ;
    rdfs:comment 'File format of the stored template.' ;
    rdfs:domain ind:ChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the department budget.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Human readable name of the department.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentType rdf:type rdf:Property ;
    rdfs:label 'Department Type' ;
    rdfs:comment 'Category of department indicating its functional area (e.g., Front of House, Back of House).' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'Physical floor area occupied by the department in square feet.' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRemote rdf:type rdf:Property ;
    rdfs:label 'Is Remote' ;
    rdfs:comment 'Flag indicating if the department operates remotely (e.g., corporate functions).' ;
    rdfs:domain ind:Department ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollGroupId rdf:type rdf:Property ;
    rdfs:label 'Payroll Group Id' ;
    rdfs:comment 'Identifier of the payroll group or cost center associated with this run.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollGroup .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Total amount of taxes, benefits, and other deductions for the payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFinalized rdf:type rdf:Property ;
    rdfs:label 'Is Finalized' ;
    rdfs:comment 'Indicates whether the payroll run has been finalized and posted to the payroll ledger.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payCycle rdf:type rdf:Property ;
    rdfs:label 'Pay Cycle' ;
    rdfs:comment 'Frequency at which employees are paid for this run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'Last calendar date of the pay period covered by the payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'First calendar date of the pay period covered by the payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunDescription rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Description' ;
    rdfs:comment 'Free-text notes or description about the payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Total Employee Count' ;
    rdfs:comment 'Number of employees included in this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultBenefitPlanId rdf:type rdf:Property ;
