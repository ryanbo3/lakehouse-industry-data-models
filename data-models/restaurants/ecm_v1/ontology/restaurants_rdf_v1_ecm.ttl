ind:foodSafetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Food Safety Audit Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.food_safety_audit. Business justification: Audit findings are recorded under a specific food safety audit; adding food_safety_audit_id links findings to their audit.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyAudit .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor accountable for corrective action.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Description' ;
    rdfs:comment 'Detailed narrative of the violation or observation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'High-level domain of the finding (e.g., HACCP, sanitation).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Human-readable identifier assigned to the finding within the audit.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finding Timestamp' ;
    rdfs:comment 'Date and time when the finding was recorded during the audit.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hasAttachment rdf:type rdf:Property ;
    rdfs:label 'Has Attachment' ;
    rdfs:comment 'Indicates whether supporting documentation (photos, files) is attached.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Code or citation of the applicable regulation (e.g., FDA Food Code section).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date when the finding was closed or resolved.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Categorical severity classification of the finding.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodsafetyCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Foodsafety Corrective Action Id' ;
    rdfs:comment 'System-generated unique identifier for the corrective action record.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodsafetyCorrectiveAction .

ind:primaryFoodsafetyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Foodsafety Employee Id' ;
    rdfs:comment 'Identifier of the manager accountable for executing the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedAuditFoodSafetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Related Audit Food Safety Audit Id' ;
    rdfs:comment 'Identifier of the food safety audit that generated the finding.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyAudit .

ind:relatedFoodSafetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Related Food Safety Audit Id' ;
    rdfs:comment 'Identifier of the food safety audit that generated the finding.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodSafetyAudit .

ind:relatedHealthInspectionId rdf:type rdf:Property ;
    rdfs:label 'Related Health Inspection Id' ;
    rdfs:comment 'Identifier of the health inspection that uncovered the violation.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthInspection .

ind:relatedInspectionHealthInspectionId rdf:type rdf:Property ;
    rdfs:label 'Related Inspection Health Inspection Id' ;
    rdfs:comment 'Identifier of the health inspection that uncovered the violation.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthInspection .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Identifier of the individual who verified the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'Business identifier or code assigned to the corrective action for tracking and reporting.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionCost rdf:type rdf:Property ;
    rdfs:label 'Action Cost' ;
    rdfs:comment 'Monetary cost incurred to implement the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action as corrective, preventive, or both.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'Link to supporting documents or images attached to the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpDeviation rdf:type rdf:Property ;
    rdfs:label 'Ccp Deviation' ;
    rdfs:comment 'Indicates whether the corrective action is related to a Critical Control Point deviation.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final status indicating whether the corrective action has been closed, verified, or rejected.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date when the corrective action became effective.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Timestamp when the corrective action was created or initiated.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:foodsafetyCorrectiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Foodsafety Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action to be taken.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodsafetyCorrectiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Foodsafety Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEffective rdf:type rdf:Property ;
    rdfs:label 'Is Effective' ;
    rdfs:comment 'Indicates whether the corrective action has been determined effective after verification.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyCode rdf:type rdf:Property ;
    rdfs:label 'Party Code' ;
    rdfs:comment 'Identifier of the primary party (e.g., restaurant unit or franchise) responsible for the corrective action.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority assigned to the corrective action for scheduling and resource allocation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action should be completed.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureExceedance rdf:type rdf:Property ;
    rdfs:label 'Temperature Exceedance' ;
    rdfs:comment 'True if the action addresses a temperature limit breach.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the verification of the corrective action was performed.' ;
    rdfs:domain ind:FoodsafetyCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was effective.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointId rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Id' ;
    rdfs:comment 'Unique system-generated identifier for the critical control point.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haccpPlanId rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Id' ;
    rdfs:comment 'Foreign key linking to foodsafety.haccp_plan. Business justification: Each Critical Control Point belongs to a single HACCP plan; adding haccp_plan_id creates the required parent link.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaccpPlan .

ind:averageDeviationValue rdf:type rdf:Property ;
    rdfs:label 'Average Deviation Value' ;
    rdfs:comment 'Average magnitude of deviations observed across monitoring events.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionProcedure rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Procedure' ;
    rdfs:comment 'Standardized steps to take when a deviation from the critical limit occurs.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointCode rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Code' ;
    rdfs:comment 'Business identifier code used to reference the CCP in SOPs and audits.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointName rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Name' ;
    rdfs:comment 'Human-readable name of the critical control point.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalControlPointStatus rdf:type rdf:Property ;
    rdfs:label 'Critical Control Point Status' ;
    rdfs:comment 'Current lifecycle status of the CCP.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalLimitMax rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Max' ;
    rdfs:comment 'Upper bound of the acceptable range for the control parameter (e.g., maximum temperature).' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLimitMin rdf:type rdf:Property ;
    rdfs:label 'Critical Limit Min' ;
    rdfs:comment 'Lower bound of the acceptable range for the control parameter (e.g., minimum temperature).' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationCount rdf:type rdf:Property ;
    rdfs:label 'Deviation Count' ;
    rdfs:comment 'Cumulative number of recorded deviations from the critical limits.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haccpPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Haccp Plan Version' ;
    rdfs:comment 'Version identifier of the HACCP plan to which this CCP belongs.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Category of hazard the CCP is designed to control.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether the CCP is classified as a critical control point (true) or a control point (false).' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMonitoredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Monitored Timestamp' ;
    rdfs:comment 'Timestamp of the most recent monitoring observation.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'Timestamp of the most recent verification activity.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often the CCP is monitored.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'Technique or instrument used to monitor the CCP (e.g., calibrated thermometer).' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processStep rdf:type rdf:Property ;
    rdfs:label 'Process Step' ;
    rdfs:comment 'Operational step in the food preparation flow where the CCP applies.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'Job role accountable for monitoring and maintaining the CCP.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationFrequency rdf:type rdf:Property ;
    rdfs:label 'Verification Frequency' ;
    rdfs:comment 'How often the CCP is independently verified for compliance.' ;
    rdfs:domain ind:CriticalControlPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodRecallId rdf:type rdf:Property ;
    rdfs:label 'Food Recall Id' ;
    rdfs:comment 'System-generated unique identifier for each recall event.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FoodRecall .

ind:primaryFoodProcurementSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Food Procurement Supplier Id' ;
    rdfs:comment 'Unique identifier for the supplier in the enterprise master data.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementSupplier .

ind:affectedUnits rdf:type rdf:Property ;
    rdfs:label 'Affected Units' ;
    rdfs:comment 'Total number of units (e.g., packages) identified as potentially unsafe.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionRegion rdf:type rdf:Property ;
    rdfs:label 'Distribution Region' ;
    rdfs:comment 'Geographic region(s) where the affected product was distributed (e.g., Midwest, Northeast).' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Narrative description of the health hazard or safety issue prompting the recall.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVoluntary rdf:type rdf:Property ;
    rdfs:label 'Is Voluntary' ;
    rdfs:comment 'True if the recall was initiated voluntarily by the company.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot or batch number associated with the recalled items.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Descriptive name of the food product or ingredient subject to the recall.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicCommunicationDate rdf:type rdf:Property ;
    rdfs:label 'Public Communication Date' ;
    rdfs:comment 'Date the recall information was released to the public.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallClass rdf:type rdf:Property ;
    rdfs:label 'Recall Class' ;
    rdfs:comment 'FDA classification indicating severity: Class I (most serious), Class II, or Class III.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallClosureReason rdf:type rdf:Property ;
    rdfs:label 'Recall Closure Reason' ;
    rdfs:comment 'Reason why the recall was closed or terminated.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Recall Effective Date' ;
    rdfs:comment 'Date on which the recall became effective for the public and supply chain.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallEndDate rdf:type rdf:Property ;
    rdfs:label 'Recall End Date' ;
    rdfs:comment 'Date when the recall was closed or deemed completed; null if still open.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallInitiationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recall Initiation Timestamp' ;
    rdfs:comment 'Exact date-time when the recall was officially initiated.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Publicly assigned recall number used by regulatory agencies to track the event.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallScope rdf:type rdf:Property ;
    rdfs:label 'Recall Scope' ;
    rdfs:comment 'Geographic extent of the recall.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Recall Source System' ;
    rdfs:comment 'System where the recall record originated.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallStatus rdf:type rdf:Property ;
    rdfs:label 'Recall Status' ;
    rdfs:comment 'Current lifecycle status of the recall event.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallType rdf:type rdf:Property ;
    rdfs:label 'Recall Type' ;
    rdfs:comment 'Primary cause category for the recall such as contamination, mislabeling, or allergen issue.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Government body overseeing the recall.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Official reference number assigned by the regulatory agency.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Internal SKU or catalogue code identifying the recalled product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Legal name of the supplier providing the recalled product.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsDisposed rdf:type rdf:Property ;
    rdfs:label 'Units Disposed' ;
    rdfs:comment 'Number of recalled units that were destroyed or otherwise disposed of.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsRecalled rdf:type rdf:Property ;
    rdfs:label 'Units Recalled' ;
    rdfs:comment 'Number of units that were actually recalled from the supply chain.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsReturned rdf:type rdf:Property ;
    rdfs:label 'Units Returned' ;
    rdfs:comment 'Number of recalled units that were returned to the supplier or manufacturer.' ;
    rdfs:domain ind:FoodRecall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Identifier of the auditor who performed the audit.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplySupplierId rdf:type rdf:Property ;
    rdfs:label 'Supply Supplier Id' ;
    rdfs:comment 'Foreign key linking to supply.supply_supplier. Business justification: Food safety audits are performed on suppliers; linking audit to supplier enables audit-by-supplier reports required by regulatory compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplySupplier .

ind:allergenControlCompliant rdf:type rdf:Property ;
    rdfs:label 'Allergen Control Compliant' ;
    rdfs:comment 'Indicates compliance with allergen control requirements.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attachedDocumentsCount rdf:type rdf:Property ;
    rdfs:label 'Attached Documents Count' ;
    rdfs:comment 'Number of supporting documents attached to the audit record.' ;
    rdfs:domain ind:FoodSafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier assigned to the audit, often used in reports and communications.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Timestamp' ;
    rdfs:comment 'Date and time when the audit was performed on site.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit source: internal, third-party, or health department.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
