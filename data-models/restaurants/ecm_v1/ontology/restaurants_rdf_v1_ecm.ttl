    rdfs:range xsd:decimal .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Net weight of the item in kilograms.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'System-generated unique identifier for the purchase order line.' ;
    rdfs:domain ind:PoLine ;
