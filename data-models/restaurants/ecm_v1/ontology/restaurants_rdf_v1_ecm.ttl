ind:poHeaderProcurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Po Header Procurement Purchase Order Id' ;
    rdfs:comment 'Identifier of the parent purchase order header to which this line belongs.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
