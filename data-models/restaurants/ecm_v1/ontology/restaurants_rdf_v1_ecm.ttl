    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Length of the creative in seconds; applicable to video and audio assets.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time after which the creative should no longer be used.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the creative asset (e.g., mp4, jpg, png).' ;
