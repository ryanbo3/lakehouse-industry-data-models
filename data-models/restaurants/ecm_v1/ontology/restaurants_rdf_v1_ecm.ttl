ind:expectedCompSalesLiftPct rdf:type rdf:Property ;
    rdfs:label 'Expected Comp Sales Lift Pct' ;
    rdfs:comment 'Planned lift in comparable store sales expressed as a percentage.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLto rdf:type rdf:Property ;
