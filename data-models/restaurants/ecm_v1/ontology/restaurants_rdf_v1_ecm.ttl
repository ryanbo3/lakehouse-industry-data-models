    rdfs:comment 'Indicates if peanuts are absent, present, or may-contain in the item.' ;
    rdfs:domain ind:FoodsafetyAllergenProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Business identifier used to reference the profile in external systems.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable name for the allergen profile, typically the menu item or ingredient name.' ;
    rdfs:domain ind:Restaurants ;
