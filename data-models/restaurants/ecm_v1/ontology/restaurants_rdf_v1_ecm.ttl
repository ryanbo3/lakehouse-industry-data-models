    rdfs:comment 'Master reference table for payroll_group. Referenced by payroll_group_id.' .

# --- Attribute Properties ---
ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the invoice for payment. Used for audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Allows AP invoices for marketing media purchases to be tied to the originating campaign, supporting financial reconciliation and campaign ROI calculations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'The user ID of the person who created the invoice record in the system. Used for audit trail and accountability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the invoice for payment. Used for audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'The user ID of the person who last modified the invoice record. Used for audit trail and change accountability.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementSupplierId rdf:type rdf:Property ;
    rdfs:label 'Procurement Supplier Id' ;
    rdfs:comment 'Unique identifier for the supplier or vendor who issued this invoice. Links to vendor master data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementSupplier .

ind:restaurantLocationUnitId rdf:type rdf:Property ;
    rdfs:label 'Restaurant Location Unit Id' ;
    rdfs:comment 'Identifier for the restaurant location or unit to which this invoice expense is allocated. Used for unit-level P&L and Average Unit Volume (AUV) analysis.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:unitId rdf:type rdf:Property ;
    rdfs:label 'Unit Id' ;
    rdfs:comment 'Identifier for the restaurant location or unit to which this invoice expense is allocated. Used for unit-level P&L and Average Unit Volume (AUV) analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:vendorProcurementSupplierId rdf:type rdf:Property ;
    rdfs:label 'Vendor Procurement Supplier Id' ;
    rdfs:comment 'Unique identifier for the supplier or vendor who issued this invoice. Links to vendor master data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementSupplier .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date the invoice was approved for payment. Used for tracking approval cycle time and compliance with payment policies.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Status of the invoice approval workflow. Indicates whether the invoice has been reviewed and approved for payment by authorized personnel.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Four-character code representing the legal entity or company within the enterprise for which this invoice is recorded. Used for multi-entity consolidation and P&L reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center to which the invoice expense is allocated. Used for departmental cost tracking and management reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The date and time when the invoice record was first created in the system. Used for audit trail and record lifecycle tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the invoice amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount amount applied to the invoice, including early payment discounts, volume discounts, or promotional allowances.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The date by which payment is due to the vendor per the payment terms. Used for cash flow forecasting and aging analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'The dunning level or escalation stage for overdue invoices. Zero indicates no dunning. Higher numbers indicate escalated collection efforts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Exchange rate used to convert foreign currency invoice amounts to the company code local currency. Null for invoices in local currency.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'High-level categorization of the invoice expense type. Used for Cost of Goods Sold (COGS) percentage and Operating Expense (OpEx) tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year in which the invoice was posted. Used for monthly financial close and period-over-period analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the invoice was posted, derived from the posting date. Used for annual financial reporting and year-over-year analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which the invoice expense is posted. Used for P&L reporting and financial statement preparation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number confirming physical receipt of goods or services. Used for three-way matching.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total invoice amount before any deductions, including line item charges and taxes. Represents the full amount billed by the vendor.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the vendor issued the invoice. This is the principal business event timestamp for the invoice transaction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the invoice, such as the nature of goods or services purchased.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The vendor-assigned invoice number as printed on the supplier invoice document. This is the externally-known business identifier for the invoice.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type (standard invoice, credit memo for returns, debit memo for additional charges, prepayment, or recurring invoice).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Net invoice amount converted to the company code local currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when the invoice record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net amount payable to the vendor after applying discounts and adjustments. This is the amount that will be paid.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Code indicating whether payment is blocked and the reason for the block (e.g., pricing dispute, quantity variance, quality issue). Empty if no block is active.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date the invoice was actually paid to the vendor. Null if the invoice is unpaid.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument or method used to pay the invoice (check, ACH, wire transfer, credit card, cash).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The payment document number or transaction reference assigned when the invoice was paid. Used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Code representing the payment terms agreed with the vendor (e.g., Net 30, 2/10 Net 30). Determines due date calculation and early payment discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date the invoice was posted to the general ledger. Used for period assignment and financial reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The purchase order number against which this invoice is being verified. Used for three-way matching and spend tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'Reference to a related document such as the original invoice for a credit memo, or a contract number. Provides audit trail and document linkage.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount charged on the invoice, including sales tax, VAT, GST, or other applicable taxes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing purchase order (PO), goods receipt (GR), and invoice. Indicates whether the invoice matches the PO and GR within tolerance or has variances.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the invoice payment as required by tax regulations. Reduces the net payment to the vendor.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the accounts payable invoice line item. Primary key for the AP invoice line detail record.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apInvoiceHeaderApInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Header Ap Invoice Id' ;
    rdfs:comment 'Reference to the parent AP invoice header record. Links this line item to its parent invoice document.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the supplier contract governing pricing and terms for this purchase. Enables contract compliance validation and price variance analysis.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Normalize cost center reference by linking to cost_center master.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Replace gl_account_code with FK to gl_account for authoritative account details.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Reference to the goods receipt document confirming physical delivery of items. Critical for three-way match validation in procurement cycle.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:ingredientId rdf:type rdf:Property ;
    rdfs:label 'Ingredient Id' ;
    rdfs:comment 'Reference to the material master record for the purchased item. Links to inventory SKU for food ingredients, packaging, and supplies.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ingredient .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order for this invoice line. Used for three-way match reconciliation between PO, goods receipt, and invoice.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementPurchaseOrder .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Normalize profit center reference by linking to profit_center master.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:restaurantUnitId rdf:type rdf:Property ;
    rdfs:label 'Restaurant Unit Id' ;
    rdfs:comment 'Reference to the restaurant location that will consume or utilize this purchased item. Enables location-level COGS and OpEx analysis for unit economics.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:stockItemId rdf:type rdf:Property ;
    rdfs:label 'Stock Item Id' ;
    rdfs:comment 'Reference to the material master record for the purchased item. Links to inventory SKU for food ingredients, packaging, and supplies.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockItem .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this invoice line was approved for payment. Documents the approval event for audit trail and payment processing timing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Fixed asset number if this line represents a capital expenditure. Links invoice to asset master for depreciation tracking and asset lifecycle management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date when the goods or services were delivered to the restaurant or distribution center. Used for lead time analysis and inventory valuation timing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptLineNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Line Number' ;
    rdfs:comment 'Specific line number on the goods receipt document that this invoice line references. Enables line-level matching between GR and invoice.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order number for project or campaign-specific expense tracking. Used for CapEx projects, NRO (New Restaurant Opening), or marketing campaigns.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapex rdf:type rdf:Property ;
    rdfs:label 'Is Capex' ;
    rdfs:comment 'Boolean flag indicating whether this line item represents a capital expenditure. True for equipment, facility improvements, and long-term assets; false for operating expenses.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCogs rdf:type rdf:Property ;
    rdfs:label 'Is Cogs' ;
    rdfs:comment 'Boolean flag indicating whether this line item is classified as Cost of Goods Sold. True for food, beverage, and packaging; false for OpEx items.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Total amount for this invoice line before tax (quantity × unit price). Represents the net line value for GL posting and COGS analysis.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the invoice. Determines the ordering and position of this line in the invoice document.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the invoice line item indicating whether it represents a purchased item, service, freight charge, tax, discount, or surcharge.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Status of the three-way match reconciliation between purchase order, goods receipt, and invoice. Matched indicates successful validation; variance indicates discrepancies requiring review.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code for the purchased material. Business-readable identifier for inventory items and ingredients.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Full text description of the purchased material or service. Provides human-readable detail about the line item for reporting and analysis.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or name of the person who last modified this invoice line record. Provides accountability for changes and supports audit trail requirements.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes or comments about this invoice line. May include special instructions, variance explanations, or additional context for accounting and operations teams.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms code defining the due date calculation and early payment discount eligibility (e.g., Net 30, 2/10 Net 30). Inherited from supplier master or contract.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Number' ;
    rdfs:comment 'Specific line number on the purchase order that this invoice line references. Enables line-level matching between PO and invoice.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the material or service invoiced on this line. Used for unit price calculation and variance analysis against PO and GR quantities.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'Tax jurisdiction and rate code applied to this line item. Determines sales tax, VAT, or GST calculation based on location and product taxability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'Final total amount for this invoice line including tax and discounts (line_amount + tax_amount - discount_amount). Represents the complete line value for payment.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the invoiced quantity (e.g., EA for each, LB for pounds, CS for cases, GAL for gallons). Critical for foodservice ingredient procurement.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of measure for this line item. Used to calculate line amount and analyze price variance against PO and contract pricing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary variance between invoice line amount and expected amount based on PO and GR. Positive values indicate overcharges; negative values indicate undercharges requiring investigation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation or reason code for any variance between invoice and expected amounts. Documents price changes, quantity discrepancies, or billing errors for audit trail.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work breakdown structure element for project accounting. Enables detailed cost tracking for capital projects, renovations, and multi-phase initiatives.' ;
    rdfs:domain ind:ApInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the person who created this invoice line record. Supports audit trail and accountability for data entry and invoice processing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Identifier for the company\'s bank account from which payment was debited. Used for cash management and bank reconciliation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the batch payment run that generated this payment. Groups multiple payments processed together.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the company\'s payment account.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or division code for cross-company reporting (e.g., QSR, casual dining, franchise operations).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date when the payment cleared the company\'s bank account and funds were debited. Null if not yet cleared.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Cost center code charged for this payment. Used for Profit and Loss (P&L) reporting and Operating Expenditure (OpEx) tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTakenAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Taken Amount' ;
    rdfs:comment 'Cash discount amount deducted from invoice total for early payment. Supports supplier relationship management and Cost of Goods Sold (COGS) optimization.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the payment amount (e.g., USD, CAD, EUR, GBP, MXN).' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account number to which payment expense is posted. Supports GAAP/IFRS compliant financial statements.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Count' ;
    rdfs:comment 'Number of invoices cleared by this payment. A single payment may settle multiple invoices.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code\'s local reporting currency.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total payment amount in document currency. Net amount remitted to vendor after discounts and adjustments.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code if payment was blocked or held for review (e.g., duplicate invoice, pricing dispute, quality issue). Null if not blocked.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Free-text description or memo field providing additional context about the payment purpose or special handling instructions.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'SAP payment document number assigned during payment run. Externally-known business identifier for this payment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to payment for processing sequence. Urgent for critical suppliers, high for preferred vendors, normal for standard terms, low for deferred payments.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of third-party payment processor or banking partner used to execute the payment (e.g., JP Morgan, Bank of America, Citibank).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment. Pending: scheduled but not yet sent. Processed: sent to bank. Cleared: funds debited from company account. Failed: rejected by bank. Cancelled: voided before processing. Reversed: reversed after clearing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of payment purpose. Vendor invoice for goods/services, credit memo for returns, down payment for Capital Expenditure (CapEx) projects, advance payment for future delivery, expense reimbursement for employee-paid vendor costs.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center code for internal management reporting. Used for segment profitability analysis and Earnings Before Interest Taxes Depreciation and Amortization (EBITDA) tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Bank reconciliation status indicating whether payment has been matched to bank statement. Unreconciled: not yet matched. Reconciled: matched to bank statement. Exception: discrepancy found. Pending review: awaiting manual review.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceEmail rdf:type rdf:Property ;
    rdfs:label 'Remittance Email' ;
    rdfs:comment 'Vendor email address to which remittance advice is sent. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'Date when funds are expected to be available in the vendor\'s account. Used for cash flow forecasting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Vendor\'s bank account number or payment account identifier used for remittance.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Legal name of the vendor receiving payment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable invoice record. Primary key.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerProfileId rdf:type rdf:Property ;
    rdfs:label 'Customer Profile Id' ;
    rdfs:comment 'Identifier of the customer or franchisee being billed. Links to customer master data for billing party details.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:franchiseeId rdf:type rdf:Property ;
    rdfs:label 'Franchisee Id' ;
    rdfs:comment 'Identifier of the franchisee when the invoice is for royalty or franchise fee billing. Null for non-franchise revenue streams.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:locationUnitId rdf:type rdf:Property ;
    rdfs:label 'Location Unit Id' ;
    rdfs:comment 'Restaurant location associated with the invoice when billing is location-specific (e.g., royalty based on location sales). Null for corporate-level billings.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Unit .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Identifier of the customer or franchisee being billed. Links to customer master data for billing party details.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Manual adjustments applied to the invoice for credits, rebates, or billing corrections. Can be positive or negative.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address for invoice mailing. Includes street number and name.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address for suite, apartment, or building information. Optional field.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address. Used for invoice mailing and tax jurisdiction determination.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Name of the primary billing contact at the customer or franchisee organization. Used for invoice delivery and payment inquiries.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code for the billing address. Used for international invoicing and tax compliance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Email' ;
    rdfs:comment 'Email address for electronic invoice delivery and billing communications. Primary channel for invoice distribution.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the period covered by this invoice. Used for royalty and franchise fee revenue recognition alignment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this invoice. Relevant for royalty invoices based on monthly or weekly sales performance.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address. Required for invoice delivery and tax jurisdiction determination.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province code for the billing address. Used for tax calculation and regulatory reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User ID or name of the person who created the invoice record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date the most recent dunning notice was sent to the customer. Used to track collection activity and determine next dunning action.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or name of the person who last modified the invoice record. Used for change tracking and accountability.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid amount on the invoice. Updated as payments are received and applied. Zero when invoice is fully paid.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'Reference number or identifier provided to customer for payment remittance. Used for automated payment matching and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date when revenue from this invoice is recognized for financial reporting purposes. May differ from invoice date per GAAP/IFRS revenue recognition rules.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ar Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable payment record. Primary key.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The ACH network trace number for ACH payments. Enables tracking and reconciliation of electronic payments.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been allocated to specific invoices. Used to track payment application progress.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The check number for check payments. Null for electronic payment methods. Used for audit trails and bank reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsoImpactDays rdf:type rdf:Property ;
    rdfs:label 'Dso Impact Days' ;
    rdfs:comment 'The number of days between invoice due date and payment receipt date. Used to calculate DSO metrics and monitor collection efficiency.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The payment amount converted to the company code functional currency using the exchange rate. Used for consolidated financial reporting.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The business date when the payment was received and recorded in the AR system. Used for Days Sales Outstanding (DSO) calculation and revenue recognition.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Customer-provided reference number or remittance advice identifier. Used to match payments to invoices during application.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date when the payment was reversed. Null for non-reversed payments. Used for audit trails and financial period corrections.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this payment has been reversed. True if reversed, False if active. Reversed payments remain in history for audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for payment reversal (e.g., NSF - non-sufficient funds, duplicate entry, customer dispute, bank error). Null for non-reversed payments. [ENUM-REF-CANDIDATE: NSF|duplicate|dispute|bank_error|wrong_account|fraud|other — promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'The payment processor transaction identifier for card or digital wallet payments. Used for chargeback management and reconciliation.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that remains unallocated to invoices. Represents cash on account or overpayments requiring future application.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Wire Confirmation Number' ;
    rdfs:comment 'Bank-provided confirmation or trace number for wire transfer payments. Used for payment verification and dispute resolution.' ;
    rdfs:domain ind:ArPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDepreciationId rdf:type rdf:Property ;
    rdfs:label 'Asset Depreciation Id' ;
    rdfs:comment 'Unique identifier for the asset depreciation posting record. Primary key for the asset_depreciation product.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset being depreciated. Links to the fixed asset master record in SAP FI-AA.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the franchise entity that owns or operates the asset. Null for company-owned assets. Supports franchise vs. company-owned asset segmentation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total accumulated depreciation for this asset in this depreciation area as of the end of this fiscal period. Cumulative sum of all prior depreciation postings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionValue rdf:type rdf:Property ;
    rdfs:label 'Acquisition Value' ;
    rdfs:comment 'Original acquisition or construction cost of the fixed asset in this depreciation area. Basis for depreciation calculation.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetAcquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Asset Acquisition Date' ;
    rdfs:comment 'Date on which the fixed asset was acquired or placed in service. Determines the start of depreciation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'Asset class code categorizing the fixed asset (e.g., building, kitchen equipment, furniture, vehicles, leasehold improvements). Determines default depreciation parameters and GL account assignments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Short textual description of the fixed asset (e.g., \'Fryer - Kitchen Station 3\', \'POS Terminal - Front Counter\'). Provides business context for the asset.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetRetirementDate rdf:type rdf:Property ;
    rdfs:label 'Asset Retirement Date' ;
    rdfs:comment 'Date on which the fixed asset was retired, sold, or scrapped. Null if the asset is still in service. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Serial Number' ;
    rdfs:comment 'Manufacturer serial number or unique identifier for the physical asset. Used for equipment tracking and warranty management.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Depreciation Amount' ;
    rdfs:comment 'Periodic depreciation expense amount posted for this asset in this fiscal period and depreciation area. Expressed in the company code currency.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Depreciation area code indicating the valuation view: 01=Book Depreciation (GAAP), 10=Tax Depreciation, 15=IFRS, 20=Cost Accounting, 30=Consolidated, 40=Group Valuation. Supports parallel accounting requirements.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'Four-character code defining the depreciation calculation method (e.g., straight-line, declining balance, units of production). Controls depreciation calculation logic in SAP FI-AA.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Business-friendly name of the depreciation calculation method applied. Derived from depreciation_key for reporting clarity.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRunDate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Date' ;
    rdfs:comment 'Date on which the depreciation calculation batch job was executed. May differ from posting_date in case of backdated runs. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Status' ;
    rdfs:comment 'Status of the depreciation posting: posted=successfully posted to GL, planned=calculated but not yet posted, reversed=posting reversed due to correction, adjusted=manual adjustment applied.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP FI document number for the depreciation posting. Links to the GL document for audit trail and drill-down.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountAccumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Gl Account Accumulated Depreciation' ;
    rdfs:comment 'GL account number to which the accumulated depreciation is credited. Contra-asset account on the balance sheet.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDepreciationExpense rdf:type rdf:Property ;
    rdfs:label 'Gl Account Depreciation Expense' ;
    rdfs:comment 'GL account number to which the depreciation expense is debited. Typically a P&L expense account.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the asset has been tested for impairment and an impairment loss has been recognized. True if impaired, False otherwise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'Cumulative impairment loss recognized for this asset in this depreciation area. Null if no impairment has been recorded.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Net book value of the asset as of the end of this fiscal period. Calculated as acquisition_value minus accumulated_depreciation. Represents the carrying amount on the balance sheet.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Remaining Useful Life Years' ;
    rdfs:comment 'Remaining useful life of the asset in years as of the end of this fiscal period. Calculated as useful_life_years minus elapsed depreciation periods.' ;
    rdfs:domain ind:AssetDepreciation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'SAP FI document number of the reversal posting if this depreciation has been reversed. Null if not reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Estimated useful life of the asset in years as configured in the depreciation key for this depreciation area. Used for straight-line and other time-based depreciation methods.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankId rdf:type rdf:Property ;
    rdfs:label 'House Bank Id' ;
    rdfs:comment 'SAP house bank identifier. Groups multiple accounts under a single banking relationship for payment processing and cash management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HouseBank .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder as registered with the bank. Typically matches the legal entity name but may differ for special-purpose accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The legal name or title of the bank account as registered with the financial institution.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The bank account number. Stored in masked or encrypted format for PCI DSS compliance. Restricted access required.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the bank account. Active accounts are available for transactions; inactive accounts are dormant but not closed; closed accounts are permanently terminated; frozen accounts are temporarily blocked; pending activation accounts are awaiting setup completion.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the bank account by its primary business purpose: operating (daily transactions), payroll (employee payments), concentration (cash pooling), zero-balance (subsidiary sweep), escrow (restricted funds), reserve (regulatory or contractual hold).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'Country-specific bank identifier. In the US this is the ABA routing number; in other countries it may be a sort code, bank code, or clearing number.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Delivery Method' ;
    rdfs:comment 'How bank statements are delivered: electronic (email or portal), paper (postal mail), or both.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'Full street address of the bank branch. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held, if applicable.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPoolGroup rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Group' ;
    rdfs:comment 'Identifier for the cash pooling or notional pooling group this account belongs to. Used for multi-entity liquidity management and interest optimization.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'The date the bank account was closed or terminated. Null for active accounts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166 country code where the bank account is domiciled (e.g., USA, CAN, MEX, GBR).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dualSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Signature Required Flag' ;
    rdfs:comment 'Indicates whether two authorized signatories are required for transactions above a certain threshold. True if dual control is mandated; false otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dualSignatureThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Dual Signature Threshold Amount' ;
    rdfs:comment 'The monetary threshold above which dual signature is required. Null if dual signature is not applicable or always required.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:electronicBankingCode rdf:type rdf:Property ;
    rdfs:label 'Electronic Banking Code' ;
    rdfs:comment 'Identifier or login ID for online banking or electronic funds transfer systems. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number for accounts in IBAN-participating countries. Up to 34 alphanumeric characters. Restricted due to account identification sensitivity.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'Annual interest rate applied to the account balance, expressed as a percentage. May be positive for interest-bearing accounts or negative for fee-based accounts.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date of the most recent successful bank reconciliation for this account.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Amount' ;
    rdfs:comment 'Minimum balance required to avoid fees or maintain account status. Null if no minimum is required.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'The date the bank account was opened with the financial institution.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Flag' ;
    rdfs:comment 'Indicates whether the account has an overdraft or line of credit facility. True if overdraft is available; false otherwise.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit Amount' ;
    rdfs:comment 'Maximum overdraft or credit line available on this account. Null if no overdraft facility exists.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this account (e.g., ACH, wire, check, EFT, SEPA). [ENUM-REF-CANDIDATE: ACH|wire|check|EFT|SEPA|BACS|CHAPS|RTP — promote to reference product]' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary bank contact. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or contact person at the bank for this account.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Phone number of the primary bank contact. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'How often this bank account is reconciled against the general ledger: daily (high-volume operating accounts), weekly (moderate activity), monthly (low activity or reserve accounts).' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryList rdf:type rdf:Property ;
    rdfs:label 'Signatory List' ;
    rdfs:comment 'Comma-separated list of employee IDs or names authorized to sign checks or approve wire transfers on this account. Confidential for fraud prevention.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'Bank Identifier Code (BIC) or SWIFT code for international wire transfers. 8 or 11 character alphanumeric code identifying the bank and branch.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Line Id' ;
    rdfs:comment 'Unique identifier for the bank statement line item. Primary key for this entity.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankStatementId rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Id' ;
    rdfs:comment 'Reference to the parent bank statement header containing this line item.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatement .

ind:posSettlementBatchId rdf:type rdf:Property ;
    rdfs:label 'Pos Settlement Batch Id' ;
    rdfs:comment 'Reference to the POS settlement batch that generated this deposit. Used to match bank deposits to daily POS sales.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosSettlementBatch .

ind:reversedLineBankStatementLineId rdf:type rdf:Property ;
    rdfs:label 'Reversed Line Bank Statement Line Id' ;
    rdfs:comment 'Reference to the original bank statement line that this transaction reverses, if applicable.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankStatementLine .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary amount of the bank transaction in the statement currency. Always positive; sign is indicated by transaction_type.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the bank to this transaction. Used for bank inquiries and dispute resolution.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP document number of the GL posting that cleared this bank statement line. Used for audit trail and drill-down.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Status of the bank statement line in the reconciliation process. Indicates whether the transaction has been matched to GL postings.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'Bank account number of the counterparty. May be masked or partial depending on bank reporting.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Code' ;
    rdfs:comment 'Bank identifier for the counterparty financial institution (e.g., routing number, SWIFT code, sort code).' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the party on the other side of the transaction (payer for credits, payee for debits). Used for matching and reconciliation.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudDetectionRule rdf:type rdf:Property ;
    rdfs:label 'Fraud Detection Rule' ;
    rdfs:comment 'Name or code of the fraud detection rule that triggered the fraud flag, if applicable.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicator that this transaction has been flagged for potential fraud or suspicious activity requiring investigation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importTimestamp rdf:type rdf:Property ;
    rdfs:label 'Import Timestamp' ;
    rdfs:comment 'Timestamp when this bank statement line was imported into SAP S/4HANA from the electronic bank statement file.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential line number within the bank statement, used for ordering and reference.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center assignment for segment reporting and P&L analysis. May represent a restaurant unit or brand.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Difference Amount' ;
    rdfs:comment 'Difference amount identified during reconciliation between bank statement and GL postings. Zero when fully reconciled.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Code' ;
    rdfs:comment 'Bank-specific transaction code identifying the type of banking operation (e.g., wire transfer, check deposit, ACH, card settlement). Maps to BAI or MT940 transaction codes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The actual date the transaction occurred at the bank. Represents the real-world business event timestamp.' ;
    rdfs:domain ind:BankStatementLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Description' ;
    rdfs:comment 'Narrative description of the transaction provided by the bank, including purpose and additional details.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Indicates whether the transaction is a credit (incoming funds) or debit (outgoing funds) to the bank account.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique identifier for the budget record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the individual or committee that approved this budget line (e.g., CFO, Budget Committee, Regional Director).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Amount' ;
    rdfs:comment 'The baseline or prior-year budget amount used as a reference point for variance analysis and year-over-year comparisons.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Code representing the restaurant brand or concept to which this budget applies (e.g., QSR Brand A, Casual Dining Brand B).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level categorization of the budget line for reporting and analysis purposes (e.g., Store Operations, Corporate Overhead, Franchise Support, New Restaurant Opening).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current approval and lifecycle status of the budget record. Draft indicates work in progress, Submitted indicates pending approval, Approved indicates finalized, Rejected indicates not approved, Locked indicates no further changes allowed.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget line by expense or revenue category. OpEx (Operating Expenditure), CapEx (Capital Expenditure), Labor, Food Cost, Revenue, COGS (Cost of Goods Sold), Marketing, R&M (Repairs and Maintenance). [ENUM-REF-CANDIDATE: opex|capex|labor|food_cost|revenue|cogs|marketing|rm — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationEntity rdf:type rdf:Property ;
    rdfs:label 'Consolidation Entity' ;
    rdfs:comment 'Legal entity or consolidation unit for multi-entity financial consolidation and GAAP/IFRS reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this budget record ceases to be effective. Null for open-ended budgets.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this budget record becomes effective and applicable for financial planning and reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nroFlag rdf:type rdf:Property ;
    rdfs:label 'Nro Flag' ;
    rdfs:comment 'Boolean flag indicating whether this budget line is associated with a New Restaurant Opening (NRO) project. True if NRO-related, False otherwise.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nroProjectCode rdf:type rdf:Property ;
    rdfs:label 'Nro Project Code' ;
    rdfs:comment 'Unique project code for the New Restaurant Opening initiative if this budget line is NRO-related. Null for non-NRO budgets.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the budget applies to a company-owned location, a franchise location, or a joint venture.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code for regional budget aggregation and reporting (e.g., Northeast, Southwest, EMEA, APAC).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Detailed subcategory within the budget category for granular expense or revenue classification (e.g., Utilities, Rent, Advertising, Training).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Pct' ;
    rdfs:comment 'The acceptable variance threshold percentage for budget-to-actual reporting. Variances exceeding this threshold trigger alerts or reviews.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Version of the budget record indicating whether it is the original budget, a revised budget, a forecast, a reforecast, or the final approved budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique identifier for the budget line item. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:budgetPlanBudgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Budget Id' ;
    rdfs:comment 'Reference to the parent budget plan that contains this line item.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:contractLineId rdf:type rdf:Property ;
    rdfs:label 'Contract Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.contract_line. Business justification: REQUIRED: Budget lines often correspond to specific contract line items for capex projects, enabling variance analysis and audit trails.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractLine .

ind:allocationDriver rdf:type rdf:Property ;
    rdfs:label 'Allocation Driver' ;
    rdfs:comment 'Business metric or driver used as the basis for allocation (e.g., revenue, transaction count, square footage, headcount). Null if allocation_method is direct.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or calculate this budget line (e.g., direct assignment, proportional allocation based on revenue, driver-based using transaction volume, zero-based budgeting, incremental from prior year).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPercentageTarget rdf:type rdf:Property ;
    rdfs:label 'Budget Percentage Target' ;
    rdfs:comment 'Target percentage of revenue or total budget that this line represents (e.g., COGS% target of 30.00, Labor% target of 25.00). Used for ratio-based budgeting and variance analysis.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Budget Subcategory' ;
    rdfs:comment 'Detailed subcategory within the budget category for granular tracking (e.g., within labor: FOH labor, BOH labor, management labor; within food cost: protein, produce, dairy).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version or type of budget this line represents (original annual budget, mid-year revision, rolling forecast, or actual results for comparison).' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypart rdf:type rdf:Property ;
    rdfs:label 'Daypart' ;
    rdfs:comment 'Service period or daypart for which this budget line applies. Supports daypart-level labor budgeting and revenue planning. Null if not daypart-specific.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Budgeted monetary amount for this line item in the specified currency. Represents the target spend or revenue for the fiscal period.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTarget rdf:type rdf:Property ;
    rdfs:label 'Quantity Target' ;
    rdfs:comment 'Budgeted quantity or volume for non-monetary metrics (e.g., labor hours, transaction count, covers, units sold). Null for purely monetary budget lines.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'Absolute monetary variance threshold that triggers alerts or requires management review. Null if no threshold is set.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'Percentage variance threshold that triggers alerts or requires management review. Null if no threshold is set.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capexProjectId rdf:type rdf:Property ;
    rdfs:label 'Capex Project Id' ;
    rdfs:comment 'Unique identifier for the capital expenditure project record. Primary key.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapexProject .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to realestate.facility. Business justification: Needed for capital-expenditure planning linking each capex project to the specific facility it upgrades, used in CAPEX approval and facility budgeting processes.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Capitalization Date' ;
    rdfs:comment 'Actual date when the project was capitalized and assets placed in service. Null if not yet capitalized.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when project work was completed and assets were ready for use. Null if project is still in progress.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Cumulative actual expenditures posted to the project to date. Includes invoiced costs, accruals, and internal labor capitalized.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual or committee that approved the project (e.g., CFO, CapEx Committee, Board of Directors).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital budget approved for this project by the CapEx governance committee or executive leadership. Represents the authorized spending limit.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aucGlAccount rdf:type rdf:Property ;
    rdfs:label 'Auc Gl Account' ;
    rdfs:comment 'General ledger account number for the Asset Under Construction balance sheet line item. Costs accumulate here until capitalization.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business case rationale for the capital investment, including strategic alignment, expected benefits, and financial analysis.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for project cancellation if status is cancelled. Null for active or completed projects.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexCategory rdf:type rdf:Property ;
    rdfs:label 'Capex Category' ;
    rdfs:comment 'Strategic classification of the CapEx investment. Growth = revenue expansion, maintenance = asset replacement, compliance = regulatory requirement, efficiency = cost reduction, strategic = competitive positioning.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total committed costs via purchase orders and contracts not yet invoiced. Used for budget consumption tracking and forecasting.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Expected Capitalization Date' ;
    rdfs:comment 'Planned date when the project will be capitalized and transferred from AUC to fixed assets, triggering depreciation start.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Expected number of months to recover the capital investment through incremental cash flows or cost savings.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion as defined in the project plan.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the project scope, objectives, and deliverables.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Project Manager Email' ;
    rdfs:comment 'Corporate email address of the project manager for communication and escalation.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Full name of the project manager responsible for execution and delivery.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Human-readable name of the capital project (e.g., \'NRO - Dallas Market Street\', \'Remodel - Chicago Loop Kitchen Upgrade\').' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Business identifier for the CapEx project as assigned in SAP PS. Externally visible project code used in financial reporting and approvals.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Current phase of the project lifecycle. Initiation = business case development, design = architectural/engineering, procurement = vendor selection, construction = build-out, commissioning = testing and handover, closeout = final accounting and asset transfer.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Official start date of the project, typically when budget is approved and work begins.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the CapEx project. Planning = under development, approved = budget authorized, in_progress = construction/implementation underway, on_hold = temporarily suspended, completed = work finished, cancelled = terminated before completion, closed = financially closed and capitalized. [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project. NRO = New Restaurant Opening, remodel = major renovation, equipment_replacement = asset refresh, technology_infrastructure = IT/POS systems, maintenance_capex = major repairs capitalized, facility_expansion = capacity additions.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Calculated remaining budget: approved_budget_amount minus (actual_spend_amount + committed_cost_amount). Indicates available funds.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk assessment for the project based on complexity, budget size, timeline, and dependencies. Used for governance oversight.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Roi Target Percent' ;
    rdfs:comment 'Target return on investment percentage established during project approval. Used for post-implementation performance evaluation.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Executive sponsor or business owner accountable for project outcomes and ROI realization.' ;
    rdfs:domain ind:CapexProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercent rdf:type rdf:Property ;
    rdfs:label 'Variance Percent' ;
    rdfs:comment 'Budget variance as a percentage of approved budget: (variance_amount / approved_budget_amount) * 100.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the cost allocation record. Primary key.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationRuleId rdf:type rdf:Property ;
    rdfs:label 'Allocation Rule Id' ;
    rdfs:comment 'The specific allocation rule or assessment within the cycle that governs how costs are distributed. Defines sender-receiver relationships and allocation basis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AllocationRule .

ind:senderGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Sender Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Replace cost allocation GL account code fields with FKs to gl_account for accurate allocation tracking.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:userEmployeeId rdf:type rdf:Property ;
    rdfs:label 'User Employee Id' ;
    rdfs:comment 'The SAP user ID of the person or system account that executed the allocation run.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Amount' ;
    rdfs:comment 'The monetary amount allocated from the sender cost center to the receiver cost center in this record. This is the product of total sender cost and allocation percentage.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisType rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Type' ;
    rdfs:comment 'The method or driver used to allocate costs. Common bases include headcount (FTE), revenue (AUV), square footage, transaction count (ADT), labor hours, fixed percentage, or custom formula. [ENUM-REF-CANDIDATE: headcount|revenue|square_footage|transaction_count|labor_hours|fixed_percentage|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationBasisValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Value' ;
    rdfs:comment 'The quantity or weight of the allocation basis for the receiver. For example, if basis is headcount, this is the FTE count; if revenue, this is the AUV amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Batch Number' ;
    rdfs:comment 'The batch or job identifier for the allocation run. All allocations executed in the same cycle run share the same batch ID for traceability.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationCycleCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Cycle Code' ;
    rdfs:comment 'The identifier of the allocation cycle or segment that defines the allocation rules and sequence. Examples: CORP_OH (corporate overhead), IT_ALLOC (IT cost allocation), MKT_FUND (marketing fund distribution).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDescription rdf:type rdf:Property ;
    rdfs:label 'Allocation Description' ;
    rdfs:comment 'Free-text description of the allocation. May include details about the allocation purpose, sender service, or special instructions.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Document Number' ;
    rdfs:comment 'The SAP document number assigned to this cost allocation posting. Used for audit trail and reversal reference.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of the sender cost center total that is allocated to this receiver. Calculated as receiver basis value divided by total basis value across all receivers. Expressed as decimal (e.g., 0.0523 for 5.23%).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationRunDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Run Date' ;
    rdfs:comment 'The date on which the allocation cycle was executed. May differ from posting date if batch processing is used.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'The current status of the allocation record. Posted indicates successful posting; reversed indicates the allocation was reversed; parked indicates saved but not posted; error indicates posting failure.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'The CO allocation method used. Assessment allocates costs without detail traceability; distribution maintains sender cost element detail; periodic reposting moves costs between cost centers; settlement closes internal orders or projects.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The controlling area in which this allocation is executed. Represents the organizational unit for cost accounting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'The controlling cost element that classifies the nature of the allocated cost (e.g., IT services, HR services, rent, utilities). Used for cost type analysis.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'The ownership model of the receiver restaurant unit. Company-owned units receive full allocations; franchise units may receive limited allocations per franchise agreement.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Center Code' ;
    rdfs:comment 'The cost center to which costs are being allocated. Typically a restaurant unit cost center or operational department that consumes the shared service.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverCostCenterName rdf:type rdf:Property ;
    rdfs:label 'Receiver Cost Center Name' ;
    rdfs:comment 'The descriptive name of the receiver cost center. Denormalized for reporting convenience.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Receiver Profit Center Code' ;
    rdfs:comment 'The profit center to which the allocated cost is assigned. Used for segment reporting and restaurant-level P&L.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Center Code' ;
    rdfs:comment 'The cost center from which costs are being allocated. Typically a shared service or corporate overhead cost center (e.g., IT, HR, Finance, Marketing Fund).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderCostCenterName rdf:type rdf:Property ;
    rdfs:label 'Sender Cost Center Name' ;
    rdfs:comment 'The descriptive name of the sender cost center. Denormalized for reporting convenience.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeId rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Id' ;
    rdfs:comment 'The identifier of the node in the cost center standard hierarchy. Used to roll up costs from individual units to regions to divisions to corporate totals for consolidated P&L reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HierarchyNode .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key reference to the physical location or restaurant unit profile. Links cost center to real estate, address, and site selection data. Nullable for non-location-based cost centers (e.g., corporate departments).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to franchise.territory. Business justification: Cost allocation and budgeting are performed per territory; linking cost_center to territory enables territory-level expense reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual budget amount for this cost center in local currency. Used for variance analysis, Labor% and COGS% target setting, and OpEx control. Updated during annual budgeting cycles and mid-year reforecasts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'The fiscal year for which the budget_amount is applicable. Enables multi-year budget tracking and year-over-year variance analysis.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'The SAP business area classification. Used to segment financial reporting by line of business (e.g., QSR, casual dining, catering, franchise operations) for multi-brand or multi-format portfolios.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capex Eligible Flag' ;
    rdfs:comment 'Indicates whether this cost center is eligible to receive capital expenditure allocations. True for restaurant units (equipment, R&M), distribution centers, and major corporate facilities. False for pure administrative departments. Used to distinguish CapEx from OpEx in financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cogsPercentTarget rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent Target' ;
    rdfs:comment 'The target COGS% (cost of goods sold as a percentage of revenue) for this cost center. Critical KPI for food cost management. Typical QSR targets range from 25-35%. Used for menu engineering, pricing strategy, and supplier negotiations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'High-level categorization of the cost center\'s role. Revenue-generating centers (FOH, BOH) directly contribute to sales; support centers (maintenance, training) enable operations; administrative centers (HR, finance) provide governance; overhead centers (facilities, utilities) are indirect; capital project centers track CapEx initiatives.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Free-text description providing additional context about this cost center\'s purpose, scope, or special characteristics. Used for documentation and reporting clarity.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full business name of the cost center (e.g., \'Store #1234 - Downtown Chicago\', \'Regional Office - Midwest\', \'Corporate HR Department\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept cost postings; inactive centers are temporarily disabled; pending centers are awaiting approval; closed centers are permanently retired; suspended centers are on hold; planned centers are scheduled for future activation (e.g., NRO pipeline).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by organizational function. Restaurant units are individual QSR locations; regional offices manage geographic territories; corporate departments are headquarters functions; shared service centers provide centralized support; distribution centers handle supply chain; franchise support manages franchisee relations.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLanes rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lanes' ;
    rdfs:comment 'The number of drive-thru lanes at this location. Nullable for non-DT formats. Critical for SOS (Speed of Service) analysis, throughput capacity planning, and DT-specific cost allocation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatCode rdf:type rdf:Property ;
    rdfs:label 'Format Code' ;
    rdfs:comment 'The restaurant format classification. Examples: DT (Drive-Thru), DINE_IN, KIOSK, FOOD_COURT, AIRPORT, GHOST_KITCHEN. Used for format-specific cost benchmarking, throughput analysis, and real estate site selection.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Flag' ;
    rdfs:comment 'Indicates whether this cost center represents a franchise-owned unit (true) or a company-owned unit (false). Critical for revenue recognition (royalty income vs direct sales), P&L consolidation, and franchise compliance tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'The functional area classification for cross-company-code reporting. Typical values include operations, marketing, R&D, administration, IT, finance. Used for functional P&L views and OpEx analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborPercentTarget rdf:type rdf:Property ;
    rdfs:label 'Labor Percent Target' ;
    rdfs:comment 'The target Labor% (labor cost as a percentage of revenue) for this cost center. Critical KPI for restaurant operations. Typical QSR targets range from 20-30%. Used for workforce scheduling optimization and P&L performance evaluation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The user ID of the person who last modified this cost center record. Used for audit trails and change accountability.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The timestamp when this cost center record was last updated. Used for change tracking and data freshness validation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:opexAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Opex Allocation Method' ;
    rdfs:comment 'The method used to allocate shared operating expenses to this cost center. Direct costs are posted directly; allocated methods distribute corporate overhead based on revenue, headcount, square footage, transaction volume, or fixed percentages. Used for full-absorption P&L reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'The cost center code of the immediate parent in the organizational hierarchy. Nullable for top-level cost centers. Enables recursive hierarchy traversal for regional and corporate rollups.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'The number of customer seats available at this cost center location. Nullable for non-dine-in formats (drive-thru only, ghost kitchens). Used for cover count analysis, table turn calculations, and throughput benchmarking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'The total interior square footage of this cost center facility. Used for OpEx allocation (utilities, CAM charges), productivity metrics (sales per square foot), and real estate valuation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center becomes effective and can accept cost postings. Aligns with NRO (New Restaurant Opening) dates for restaurant units or organizational change effective dates for corporate centers.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date through which this cost center remains effective. Nullable for open-ended cost centers. Populated when a restaurant closes, a department is dissolved, or a regional office is consolidated.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialPeriodId rdf:type rdf:Property ;
    rdfs:label 'Financial Period Id' ;
    rdfs:comment 'Unique identifier for the financial period record. Primary key.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:comparativePriorPeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparative Prior Period Id' ;
    rdfs:comment 'Foreign key reference to the immediately preceding period (e.g., prior month). Used for sequential period-over-period analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:comparativePriorYearPeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparative Prior Year Period Id' ;
    rdfs:comment 'Foreign key reference to the equivalent period in the prior fiscal year. Used for year-over-year comparative analysis and SSS reporting.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialPeriod .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Two-character code identifying the ledger (leading ledger for primary GAAP, non-leading ledger for parallel IFRS, special purpose ledger for management reporting). Supports multi-GAAP parallel accounting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'Accounting standard applied in this ledger: US_GAAP (United States Generally Accepted Accounting Principles), IFRS (International Financial Reporting Standards), local_GAAP (country-specific standards), management (internal reporting).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentPostingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether adjustment postings (corrections, reclassifications) are allowed in this period after initial close. Used for controlled reopening during audit or correction cycles.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Reason code or description for why the period is an adjustment period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Required Flag' ;
    rdfs:comment 'Indicates whether this period is subject to external audit review. Typically true for year-end periods and quarterly periods for publicly traded entities.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Flag' ;
    rdfs:comment 'True if changes to this period are tracked for audit purposes.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarDaysCount rdf:type rdf:Property ;
    rdfs:label 'Calendar Days Count' ;
    rdfs:comment 'Total number of calendar days in the period. Used for daily average calculations and period normalization in financial analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'Month number (1-12) in the calendar year.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'Quarter number (1-4) in the calendar year.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'Gregorian calendar year of the period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeActualDate rdf:type rdf:Property ;
    rdfs:label 'Close Actual Date' ;
    rdfs:comment 'Actual date when the period-end close process was completed and the period status changed to closed. Null if period is still open.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Close Scheduled Date' ;
    rdfs:comment 'Target date for completing the period-end close process. Used for close calendar planning and tracking adherence to financial reporting deadlines.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Close Variance Days' ;
    rdfs:comment 'Number of days between scheduled and actual close date (positive if late, negative if early). Used to track period-end close efficiency and identify process improvement opportunities.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationGroupCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group Code' ;
    rdfs:comment 'Code identifying the consolidation group for multi-entity reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Required Flag' ;
    rdfs:comment 'Indicates whether this period requires multi-entity consolidation processing. True for periods where intercompany eliminations and group reporting are performed.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayCount rdf:type rdf:Property ;
    rdfs:label 'Day Count' ;
    rdfs:comment 'Total count of calendar days covered by the period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Last calendar day of the financial period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateToReporting rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Reporting' ;
    rdfs:comment 'Conversion rate from functional currency to reporting currency for the period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'Type of exchange rate applied for currency translation in this period: average (period average rate for P&L), closing (period-end rate for balance sheet), budget (planning rate), historical (acquisition date rate for fixed assets).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Financial Period Description' ;
    rdfs:comment 'Optional free-text description of the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementType rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Type' ;
    rdfs:comment 'Type of financial statement the period primarily supports.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Month number (1-12) within the fiscal year.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Code' ;
    rdfs:comment 'Standard code used by SAP for the fiscal period (e.g., "2023P01").' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Quarter number (1-4) within the fiscal year.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character code defining the fiscal calendar structure (number of periods, special periods, year-end rules) used by the company code. Determines how the fiscal year is divided into posting periods.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayIndicator rdf:type rdf:Property ;
    rdfs:label 'Holiday Indicator' ;
    rdfs:comment 'Degree to which holidays affect the period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'True if the period is used for post-close adjustments.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'True if this period is the active reporting period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'True if the period values are based on estimates rather than actuals.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHolidayPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Holiday Period' ;
    rdfs:comment 'True if the period includes a recognized holiday schedule.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterim rdf:type rdf:Property ;
    rdfs:label 'Is Interim' ;
    rdfs:comment 'True if the period is an interim (non-full) reporting period.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger: leading (primary GAAP ledger for statutory reporting), non_leading (parallel IFRS or local GAAP ledger), special_purpose (management or segment reporting ledger).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockFlag rdf:type rdf:Property ;
    rdfs:label 'Lock Flag' ;
    rdfs:comment 'True when the period is locked for posting to prevent changes.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCategory rdf:type rdf:Property ;
    rdfs:label 'Period Category' ;
    rdfs:comment 'Business classification of the period data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date of the financial period. Defines the end of the posting window for transactions assigned to this period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodKey rdf:type rdf:Property ;
    rdfs:label 'Period Key' ;
    rdfs:comment 'Compact code representing the period (e.g., FY2023Q1, FY2023M04).' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name or label for the period (e.g., \'January 2024\', \'Q1 FY2024\', \'Period 13 - Year-End Adjustments\'). Used for reporting and user interface display.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential period number within the fiscal year (typically 1-12 for monthly periods, or 1-13 for 4-4-5 retail calendars). Special periods (13, 14, 15, 16) used for year-end adjustments.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Period Sequence Number' ;
    rdfs:comment 'Sequential order of the period within its fiscal year.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date of the financial period. Defines the beginning of the posting window for transactions assigned to this period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current posting status of the period: not_opened (future period, no posting allowed), open (active posting allowed), closed (period-end close completed, limited posting), locked (archived, no posting allowed).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the period: regular (standard posting period), special (year-end adjustment period 13-16), or adjustment (mid-year correction period).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether new transactions can be posted to this period. True if period is open for posting, false if closed or locked.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarterNumber rdf:type rdf:Property ;
    rdfs:label 'Quarter Number' ;
    rdfs:comment 'Fiscal quarter number (1-4) to which this period belongs. Supports quarterly financial reporting and Same-Store Sales (SSS) analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for consolidated financial reporting in this period (e.g., USD for US Dollar, EUR for Euro). Used for multi-currency consolidation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Flag' ;
    rdfs:comment 'True if the period is used for segment-level reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Originating system that defines the period (e.g., SAP S/4HANA).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sssEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Sss Eligible Flag' ;
    rdfs:comment 'Indicates whether this period is eligible for Same-Store Sales (SSS) or Comparable Store Sales (Comp Sales) analysis. Typically true for periods where stores have been open for at least 12-13 months.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'First calendar day of the financial period.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Flag' ;
    rdfs:comment 'True if the period is used for tax reporting calculations.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Period Flag' ;
    rdfs:comment 'Indicates whether this period is a tax reporting period requiring submission of tax returns (e.g., quarterly estimated tax, annual tax filing). Used for tax compliance tracking.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'Number of business working days in the period, excluding weekends and holidays. Used for normalizing operational metrics and labor cost analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearPeriodKey rdf:type rdf:Property ;
    rdfs:label 'Year Period Key' ;
    rdfs:comment 'Concatenated key combining fiscal year and period number (format: YYYYPPP, e.g., 2024001 for FY2024 Period 1). Used for sorting and comparative period analysis.' ;
    rdfs:domain ind:FinancialPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager responsible for the custody and maintenance of the asset. Supports accountability and asset stewardship.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total capitalized cost of the fixed asset at acquisition including purchase price, installation, freight, and other directly attributable costs. Recorded in USD.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the fixed asset was acquired or placed into service. Used as the start date for depreciation calculations and useful life tracking.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. Determines whether depreciation is active and whether the asset appears on the balance sheet. [ENUM-REF-CANDIDATE: active|in_service|under_construction|retired|disposed|impaired|held_for_sale — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubclass rdf:type rdf:Property ;
    rdfs:label 'Asset Subclass' ;
    rdfs:comment 'Detailed sub-classification within the asset class for granular tracking (e.g., \'Fryers\', \'Grills\', \'KDS Units\' under kitchen_equipment).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexProjectCode rdf:type rdf:Property ;
    rdfs:label 'Capex Project Code' ;
    rdfs:comment 'Reference code linking the asset to the originating capital expenditure project or budget line item. Supports CapEx tracking and ROI analysis.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the asset was retired, sold, or otherwise disposed of. Triggers final depreciation calculation and removal from active asset register.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method by which the asset was disposed of. Determines accounting treatment and tax implications for gain/loss recognition.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Cash or fair value received from the sale or disposal of the asset. Used to calculate gain or loss on disposal for P&L reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Amount of impairment loss recognized when the asset\'s carrying value exceeds its fair value or value in use. Recorded as a non-cash charge to P&L.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number for property and casualty insurance covering the asset. Used for claims processing and risk management.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Inventory Date' ;
    rdfs:comment 'Date of the most recent physical verification or audit of the asset. Supports SOX compliance and internal control over fixed assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Lease Indicator' ;
    rdfs:comment 'Flag indicating whether the asset is subject to a lease agreement (finance lease or operating lease under ASC 842 / IFRS 16). Determines right-of-use asset treatment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the equipment manufacturer or brand (e.g., Vulcan, Hobart, NCR). Supports vendor performance analysis and standardization initiatives.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model number or SKU for the asset. Used for parts ordering, service manuals, and replacement planning.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Subtracted from acquisition cost to determine depreciable base.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number for the asset. Used for warranty claims, service tracking, and theft recovery.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty expires. Used to plan for extended service contracts and budget for repairs and maintenance (R&M).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts framework this account belongs to. Supports multiple COA structures for different regions or business units.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:parentAccountGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Gl Account Id' ;
    rdfs:comment 'Reference to the parent account in the account hierarchy for roll-up reporting. Null for top-level accounts. Enables multi-level account group hierarchies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for accounts that manage balances in a specific currency (e.g., \'USD\', \'EUR\', \'GBP\'). Null for accounts managed only in company code currency.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed business description of the account purpose, usage guidelines, and what types of transactions should be posted to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group code that defines the account\'s characteristics, field status, and number range. Controls account behavior and validation rules in SAP S/4HANA.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Account Number' ;
    rdfs:comment 'Alternative or legacy account code used for cross-reference, migration mapping, or external reporting (e.g., mapping to previous ERP system account numbers).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Specific balance sheet line item classification for asset, liability, and equity accounts. Set to \'not_applicable\' for P&L (Profit and Loss) accounts (revenue/expense).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification of this account for cash flow statement presentation: \'operating\' for operational cash flows, \'investing\' for CapEx (Capital Expenditure) and asset transactions, \'financing\' for debt and equity, \'not_applicable\' for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'Mapped account number used in corporate consolidation reporting to standardize accounts across multiple legal entities and chart of accounts structures.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of cost element: \'primary\' for costs posted from external transactions (FI to CO), \'secondary\' for internal allocations and assessments, \'not_applicable\' if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Flag indicating whether this GL account is also defined as a cost element in SAP Controlling (CO) module for cost center and internal order postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group code that controls which fields are required, optional, or suppressed when posting transactions to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Category' ;
    rdfs:comment 'Detailed sub-classification within the account type for financial statement presentation (e.g., \'Current Assets\', \'Long-Term Liabilities\', \'Operating Revenue\', \'Cost of Goods Sold (COGS)\', \'Selling General and Administrative (SG&A)\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Business function or operational area this account supports (e.g., \'Restaurant Operations\', \'Franchise\', \'Supply Chain\', \'Marketing\', \'Corporate\', \'Real Estate\'). Used for segment reporting and management accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Gaap Account Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used in GAAP-compliant financial statements. Supports dual-ledger reporting for companies reporting under both GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Ifrs Account Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used in IFRS-compliant financial statements. Supports dual-ledger reporting for companies reporting under both GAAP and IFRS.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this account is used for intercompany transactions between legal entities that require elimination during consolidation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Indicator' ;
    rdfs:comment 'Flag indicating whether individual line item details are stored and displayed for this account. True for most operational accounts; false for summary accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Indicator' ;
    rdfs:comment 'Flag indicating whether this account uses open item management for tracking and clearing individual transactions (e.g., for clearing accounts, suspense accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Granularity level at which budget planning and forecasting is performed for this account (e.g., \'corporate\', \'region\', \'restaurant\', \'cost_center\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Indicator' ;
    rdfs:comment 'Flag indicating whether direct transaction postings are allowed to this account. False for summary/header accounts that only receive totals from sub-accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Classification' ;
    rdfs:comment 'Specific P&L statement line item classification for revenue and expense accounts (e.g., \'Sales Revenue\', \'COGS (Cost of Goods Sold)\', \'Labor Cost\', \'Occupancy Cost\', \'EBITDA (Earnings Before Interest Taxes Depreciation and Amortization)\'). Null for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a reconciliation account (subledger control account) that summarizes detailed transactions from AP (Accounts Payable), AR (Accounts Receivable), or FA (Fixed Assets) subledgers.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentReportingIndicator rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Indicator' ;
    rdfs:comment 'Flag indicating whether transactions posted to this account are included in segment reporting for business unit, geographic, or product line analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP sort key that determines the default sorting and grouping of line items posted to this account (e.g., by posting date, document number, or business partner).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Statistical Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a statistical account used for tracking non-monetary quantities (e.g., headcount, transaction counts, cover counts) without affecting financial balances.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment classification for this account (e.g., \'taxable_revenue\', \'non_taxable_revenue\', \'input_tax\', \'output_tax\', \'exempt\'). Used for sales tax, VAT, and GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Intercompany Transaction Id' ;
    rdfs:comment 'Unique identifier for the intercompany transaction record. Primary key.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendingGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Sending Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Replace string GL account references with FKs to gl_account for intercompany transaction clarity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:sendingLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Sending Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: Intercompany transactions belong to sending and receiving legal entities; replace string codes with proper FK to legal_entity for referential integrity.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document or invoice that originated the intercompany transaction. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationDate rdf:type rdf:Property ;
    rdfs:label 'Elimination Date' ;
    rdfs:comment 'The date on which the intercompany transaction was eliminated during the consolidation process. Null if not yet eliminated. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Boolean flag indicating whether this intercompany transaction has been eliminated in the consolidated financial statements. True if eliminated, False if not yet eliminated.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'The transaction amount converted to the group reporting currency for consolidated financial statements and intercompany elimination.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the group reporting currency used for consolidation (typically USD for Restaurants).' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the local currency of the sending company code.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingIndicator rdf:type rdf:Property ;
    rdfs:label 'Netting Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this transaction is part of an intercompany netting arrangement where offsetting balances are settled periodically. True if netting applies, False otherwise.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationPeriod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Period' ;
    rdfs:comment 'The fiscal period (YYYY-MM format) in which the intercompany transaction is scheduled for or has completed reconciliation.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The actual date on which the intercompany transaction was settled or paid. Null if not yet settled. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary value of the intercompany transaction in the transaction currency, before any adjustments or eliminations.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the intercompany transaction was originally denominated.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the intercompany transaction indicating its processing and reconciliation state.' ;
    rdfs:domain ind:IntercompanyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry record. Primary key for the journal entry header in SAP S/4HANA FI-GL.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'SAP user ID of the person who approved this journal entry for posting. Populated only for entries requiring approval workflow. Used for segregation of duties compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approverUserId rdf:type rdf:Property ;
    rdfs:label 'Approver User Id' ;
    rdfs:comment 'SAP user ID of the person who approved this journal entry for posting. Populated only for entries requiring approval workflow. Used for segregation of duties compliance.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified User Employee Id' ;
    rdfs:comment 'SAP user ID of the person who last modified this journal entry header (e.g., added notes, changed status). Blank if never modified after initial posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'SAP user ID of the person or system account that posted this journal entry. Used for audit trail and segregation of duties monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentPeriodIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Period Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry was posted in a special adjustment period (periods 13-16) for year-end close. True if adjustment period; False if regular period.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Exact date and time when the journal entry was approved. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if no approval required or not yet approved.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditClass rdf:type rdf:Property ;
    rdfs:label 'Audit Class' ;
    rdfs:comment 'Classification of the journal entry for audit sampling and risk assessment. Values: standard (routine posting), high_risk (unusual or large amount), manual_adjustment (manual journal entry requiring scrutiny), system_generated (automated posting).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselinePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Payment Date' ;
    rdfs:comment 'The baseline date from which payment terms are calculated (typically document date or posting date). Used to determine net due date and discount periods. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchInputSession rdf:type rdf:Property ;
    rdfs:label 'Batch Input Session' ;
    rdfs:comment 'Name of the batch input session if this journal entry was posted via batch processing (e.g., mass upload, automated interface). Blank for manually posted entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationTransactionType rdf:type rdf:Property ;
    rdfs:label 'Consolidation Transaction Type' ;
    rdfs:comment 'Three-character code classifying the journal entry for consolidation purposes (e.g., 100=standard posting, 200=intercompany elimination, 300=currency translation adjustment, 400=consolidation adjustment). Used in multi-entity financial consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentHeaderText rdf:type rdf:Property ;
    rdfs:label 'Document Header Text' ;
    rdfs:comment 'Free-text description or memo entered at the document header level. Provides business context for the journal entry (e.g., \'Monthly depreciation run\', \'Accrual for Q4 marketing expenses\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character code classifying the nature of the accounting document (e.g., SA=GL account document, KR=vendor invoice, DR=customer invoice, AB=accounting document, AA=asset posting). Controls number ranges and posting keys.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the document was entered into the SAP system by the user. Used for audit trail and processing time analysis. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ledgerGroup rdf:type rdf:Property ;
    rdfs:label 'Ledger Group' ;
    rdfs:comment 'Two-character code identifying the ledger in which this entry is posted (e.g., 0L=leading ledger for GAAP, 2L=IFRS ledger, 3L=management ledger). Supports parallel accounting for multiple reporting standards.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDueDate rdf:type rdf:Property ;
    rdfs:label 'Net Due Date' ;
    rdfs:comment 'The calculated due date for payment based on payment terms and baseline date. Used for cash flow forecasting and AP/AR aging. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parkedIndicator rdf:type rdf:Property ;
    rdfs:label 'Parked Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry is in parked status (saved but not yet posted). True if parked; False if posted. Parked documents do not update GL balances until posted.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit numeric code that controls the type of posting (debit or credit) and the account type (e.g., 40=debit GL, 50=credit GL, 01=debit customer, 31=debit vendor). Determines field status and processing logic.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Exact date and time when the journal entry was posted to the general ledger. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX. Used for audit trail and real-time reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True. Maintains audit trail for accrual reversals and error corrections.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the originating system for this journal entry (e.g., SAP_ECC, SAP_S4, LEGACY_GL, COUPA, WORKDAY). Used for data lineage and interface reconciliation.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingDate rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Date' ;
    rdfs:comment 'The date used for tax reporting purposes (may differ from posting date based on jurisdiction rules). Used for VAT/GST returns and sales tax filings. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Four-character company code of the intercompany trading partner. Populated only when intercompany_indicator is True. Used for intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current state of the journal entry in the approval workflow. Values: draft (initial entry), pending_approval (submitted for review), approved (authorized but not posted), posted (final state in GL), rejected (not approved), cancelled (voided before posting).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for granular GL transaction tracking.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'Transaction amount in the original document currency. Used for multi-currency transactions before conversion to local currency.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'Transaction amount converted to the local reporting currency of the legal entity. Used for consolidated financial statements.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-text assignment field for additional reference information. Often used for invoice numbers, PO numbers, or internal tracking codes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Baseline date for payment terms calculation. Typically the invoice date or goods receipt date.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line is a debit (D) or credit (C) entry. Fundamental to double-entry bookkeeping.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the document currency (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Descriptive text explaining the purpose or nature of this journal entry line. Provides business context for the transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'Single-character code for special GL transactions (e.g., down payments, guarantees, bills of exchange). Blank for standard postings.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Trading partner code for intercompany transactions. Identifies the counterparty legal entity for consolidation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userName rdf:type rdf:Property ;
    rdfs:label 'User Name' ;
    rdfs:comment 'SAP user ID of the person who created this journal entry line. Audit trail for accountability.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the parent legal entity in the corporate hierarchy. Null for the ultimate parent company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Foreign key reference to the top-level parent entity in the corporate structure. Used for ultimate consolidation and group reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting framework used for financial statement preparation. GAAP for US entities, IFRS for international, or local statutory standards.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the legal entity\'s registered office address as filed with corporate registry.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the legal entity\'s registered office address (suite, floor, building name).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality of the legal entity\'s registered office.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Method used to consolidate this entity\'s financial results into group reporting. Full for subsidiaries, equity for associates, none for non-consolidated entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP S/4HANA organizational unit for cost accounting, internal reporting, and profitability analysis. May span multiple company codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP S/4HANA organizational unit for managing customer credit limits and credit exposure across one or more company codes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date the legal entity was officially dissolved or ceased operations. Null for active entities.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet for business credit and supplier management.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this legal entity record is effective for financial posting and reporting. Used for time-dependent organizational changes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date until which this legal entity record is effective. Null for currently active entities. Used for historical tracking of organizational changes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity. Active entities post transactions; inactive entities are retained for historical reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity structure. Determines ownership model, consolidation treatment, and reporting obligations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the end of the entity\'s fiscal year. 12 = December for calendar year entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date the legal entity was officially registered or incorporated with the governing jurisdiction.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Flag' ;
    rdfs:comment 'Indicates whether this entity participates in automated intercompany clearing and reconciliation processes for intra-group transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is incorporated and legally domiciled.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionStateProvince rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State Province' ;
    rdfs:comment 'State, province, or sub-national jurisdiction where the entity is registered. Relevant for federal systems (USA, Canada, etc.).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the entity as filed with government authorities. Used on official financial statements, tax filings, and legal contracts.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier issued by the Global LEI Foundation for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the parent entity. 100.00 for wholly-owned subsidiaries, less for joint ventures or minority interests.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the legal entity\'s registered office.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Flag' ;
    rdfs:comment 'Indicates whether profit center assignment is mandatory for all financial postings in this legal entity. True enforces segment reporting compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration or incorporation number assigned by the jurisdiction\'s corporate registry.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this entity is subject to segment reporting requirements under GAAP ASC 280 or IFRS 8.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or trade name used for internal reporting and operational reference.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region of the legal entity\'s registered office.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identifier (EIN in USA, VAT number in EU, etc.) used for tax filing and reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'VAT or GST registration number for entities operating in jurisdictions with value-added tax systems. Used for tax reporting and invoice compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCloseId rdf:type rdf:Property ;
    rdfs:label 'Period Close Id' ;
    rdfs:comment 'Unique identifier for the financial period close record.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sign Off User Employee Id' ;
    rdfs:comment 'The system user ID of the person who signed off on the period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Posting Status' ;
    rdfs:comment 'Status of accrual journal entries posting for the period (e.g., payroll accruals, utility accruals, rent accruals).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'The actual date when the period close was completed and signed off.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustmentEntryCount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Entry Count' ;
    rdfs:comment 'The number of manual journal entries posted during the period close process.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Ap Reconciliation Status' ;
    rdfs:comment 'Status of accounts payable sub-ledger reconciliation to general ledger for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Reconciliation Status' ;
    rdfs:comment 'Status of accounts receivable sub-ledger reconciliation to general ledger for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Readiness Flag' ;
    rdfs:comment 'Indicates whether the period close documentation and supporting evidence are ready for internal or external audit review.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Reconciliation Status' ;
    rdfs:comment 'Status of bank account reconciliation activities for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Completed Timestamp' ;
    rdfs:comment 'The date and time when the period close process was fully completed and locked.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Close Duration Hours' ;
    rdfs:comment 'The total number of hours elapsed from close initiation to completion, used for process efficiency tracking.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Initiated Timestamp' ;
    rdfs:comment 'The date and time when the period close process was initiated.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closePhase rdf:type rdf:Property ;
    rdfs:label 'Close Phase' ;
    rdfs:comment 'The specific phase of the period close workflow (pre-close activities, soft close for preliminary reporting, hard close for final lock, post-close adjustments).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeStatus rdf:type rdf:Property ;
    rdfs:label 'Close Status' ;
    rdfs:comment 'Current status of the period close process indicating the phase of completion. [ENUM-REF-CANDIDATE: not_started|in_progress|pre_close|soft_close|hard_close|completed|reopened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationRunStatus rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Status' ;
    rdfs:comment 'Status of the fixed asset depreciation calculation and posting run for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCount rdf:type rdf:Property ;
    rdfs:label 'Exception Count' ;
    rdfs:comment 'The number of reconciliation exceptions or issues identified during the period close process.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialStatementStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Status' ;
    rdfs:comment 'Status of Profit and Loss (P&L), balance sheet, and cash flow statement preparation and approval for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Gl Account Reconciliation Status' ;
    rdfs:comment 'Status of general ledger account reconciliation activities for balance sheet and income statement accounts.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Intercompany Reconciliation Status' ;
    rdfs:comment 'Status of intercompany transaction reconciliation and elimination entries for multi-entity consolidation.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Status' ;
    rdfs:comment 'Status of inventory valuation and Cost of Goods Sold (COGS) calculation for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingFundAccrualStatus rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Accrual Status' ;
    rdfs:comment 'Status of marketing fund contribution accrual calculation and posting for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Reopen Authorized By' ;
    rdfs:comment 'The name of the senior finance leader who authorized the reopening of the closed period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenReason rdf:type rdf:Property ;
    rdfs:label 'Reopen Reason' ;
    rdfs:comment 'The business justification for reopening a previously closed period (e.g., audit adjustment, error correction, late invoice).' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reopen Timestamp' ;
    rdfs:comment 'The date and time when the period was reopened after initial close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleControllerEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller Email' ;
    rdfs:comment 'The email address of the financial controller responsible for this period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleControllerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Controller Name' ;
    rdfs:comment 'The name of the financial controller responsible for executing and signing off on this period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAccrualStatus rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Status' ;
    rdfs:comment 'Status of franchise royalty income accrual calculation and posting for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCloseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Close Date' ;
    rdfs:comment 'The target date by which the period close should be completed according to the financial calendar.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'The date and time when the responsible controller formally signed off on the completed period close.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxProvisionStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Provision Status' ;
    rdfs:comment 'Status of income tax provision calculation and posting for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Variance Analysis Status' ;
    rdfs:comment 'Status of budget-to-actual variance analysis and commentary preparation for the period.' ;
    rdfs:domain ind:PeriodClose ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentProfitCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Id' ;
    rdfs:comment 'Reference to the parent profit center in the organizational hierarchy. Enables recursive roll-up for regional and brand-level P&L aggregation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:aovTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Aov Target Amount' ;
    rdfs:comment 'Target annual revenue for this profit center expressed in the profit center\'s functional currency. Used for AUV benchmarking and performance variance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date the profit center ceased operations. Null for active profit centers. Used for historical P&L analysis and closed-unit portfolio reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Business reason for profit center closure (e.g., lease expiration, underperformance, market exit, franchise termination). Used for portfolio optimization analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnitCode rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit Code' ;
    rdfs:comment 'Code identifying the consolidation unit for multi-entity financial consolidation. Used in GAAP/IFRS-compliant consolidated financial statement preparation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroupCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group Code' ;
    rdfs:comment 'Code of the cost center group associated with this profit center. Links profit center P&L to underlying cost center actuals for COGS and OpEx analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaTargetAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Target Amount' ;
    rdfs:comment 'Target EBITDA for this profit center expressed in the profit center\'s functional currency. Used for profitability benchmarking and executive performance evaluation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Region Code' ;
    rdfs:comment 'Code representing the geographic region (e.g., Northeast, Southwest, EMEA, APAC). Used for regional P&L consolidation and market performance analysis.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Flag indicating whether the profit center is locked for transaction posting. Locked centers cannot receive new P&L entries but remain visible for historical reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingFundRatePercent rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Rate Percent' ;
    rdfs:comment 'Marketing fund contribution rate percentage for franchise profit centers. Represents the percentage of gross sales contributed to the brand marketing fund.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'Functional category of the profit center. Operating centers generate direct revenue; non-operating centers represent overhead or shared services allocated to operating units.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full descriptive name of the profit center (e.g., \'Downtown Chicago QSR Unit 1234\', \'Northeast Regional Franchise Group\', \'Company-Owned Casual Dining Segment\').' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center. Active centers participate in P&L reporting; inactive centers are excluded from current period consolidation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Percent' ;
    rdfs:comment 'Royalty rate percentage applied to franchise profit centers. Represents the percentage of gross sales remitted to the franchisor as ongoing royalty income.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the profit center by business segment type. Determines the level of P&L aggregation and reporting hierarchy.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the primary tax jurisdiction for this profit center. Determines applicable sales tax, VAT, and income tax treatment in P&L reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyAccrualId rdf:type rdf:Property ;
    rdfs:label 'Royalty Accrual Id' ;
    rdfs:comment 'Unique identifier for the royalty accrual record. Primary key.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Identifier of the franchise agreement governing this royalty accrual. Links to the franchise agreement master data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:originalAccrualRoyaltyAccrualId rdf:type rdf:Property ;
    rdfs:label 'Original Accrual Royalty Accrual Id' ;
    rdfs:comment 'Reference to the original royalty_accrual_id being adjusted, if this is an adjustment entry. Null for original accruals.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RoyaltyAccrual .

ind:royaltyRevenueGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Royalty Revenue Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Replace royalty accrual GL account strings with FKs to gl_account for accurate revenue and receivable tracking.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accrualPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period End Date' ;
    rdfs:comment 'End date of the period for which royalty is being accrued. Defines the boundary of the revenue recognition period.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Start Date' ;
    rdfs:comment 'Start date of the period for which royalty is being accrued. Typically the first day of a week, month, or quarter depending on royalty calculation frequency.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accruedRoyaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Accrued Royalty Amount' ;
    rdfs:comment 'Total royalty amount accrued for the period, calculated as royalty_base_net_sales multiplied by royalty_rate_percent. Represents the franchise royalty revenue to be recognized.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Indicator' ;
    rdfs:comment 'Flag indicating whether this accrual is an adjustment to a prior period accrual. True if this is a correction or adjustment entry.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franconnectCalculationReference rdf:type rdf:Property ;
    rdfs:label 'Franconnect Calculation Reference' ;
    rdfs:comment 'Unique identifier of the royalty calculation in FranConnect. Used for reconciliation between FranConnect and SAP S/4HANA.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'SAP general ledger document number for the accrual posting. Used for audit trail and reconciliation back to SAP S/4HANA.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date on which the accrual was posted to the general ledger in SAP S/4HANA. May differ from recognition_date due to period-end adjustments.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingFundContribution rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Contribution' ;
    rdfs:comment 'Marketing fund contribution amount accrued for the period, typically calculated as a percentage of net sales. Separate from royalty but often collected together.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'Date on which the accrued royalty revenue was recognized in the general ledger. Null if not yet recognized.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current revenue recognition status of the accrual. Tracks the lifecycle from initial accrual through final recognition in the general ledger.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyBaseNetSales rdf:type rdf:Property ;
    rdfs:label 'Royalty Base Net Sales' ;
    rdfs:comment 'Net sales amount used as the base for calculating royalty. Typically gross sales less discounts, refunds, and allowable deductions per franchise agreement.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyFee rdf:type rdf:Property ;
    rdfs:label 'Technology Fee' ;
    rdfs:comment 'Technology fee amount accrued for the period. May be a flat fee or percentage-based, covering POS, digital ordering, and other technology services provided to franchisees.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyFeeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Technology Fee Rate Percent' ;
    rdfs:comment 'Percentage rate applied to net sales to calculate the technology fee, if applicable. May be null if technology fee is a flat amount.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Accrued Amount' ;
    rdfs:comment 'Total amount accrued for the period, including royalty, marketing fund contribution, and technology fee. Represents the total receivable from the franchisee for this period.' ;
    rdfs:domain ind:RoyaltyAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxPostingId rdf:type rdf:Property ;
    rdfs:label 'Tax Posting Id' ;
    rdfs:comment 'Unique identifier for the tax posting transaction record. Primary key.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicator that this tax posting has been flagged for review during a tax audit or compliance examination.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentLineItem rdf:type rdf:Property ;
    rdfs:label 'Document Line Item' ;
    rdfs:comment 'Line item number within the financial document that represents this specific tax posting entry.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Number' ;
    rdfs:comment 'The certificate number for tax-exempt transactions, if the transaction qualifies for exemption.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Business reason or regulatory basis for tax exemption, if applicable (e.g., resale, nonprofit, government entity).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The tax reporting period for which this posting must be included in tax filings. Format: YYYY-Q# for quarterly or YYYY-M## for monthly.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the governmental tax authority to which the tax is owed (e.g., California Department of Tax and Fee Administration, IRS).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is an input tax (tax paid on purchases) or output tax (tax collected on sales).' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Status' ;
    rdfs:comment 'Current lifecycle status of the tax posting in the filing and payment process.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRatePercent rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percent' ;
    rdfs:comment 'The tax rate percentage applied to the taxable base amount to calculate the tax amount. Stored as decimal (e.g., 8.250 for 8.25%).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax transaction by type: sales tax (collected from customers), use tax (self-assessed), VAT (value-added tax), withholding tax, excise tax, or franchise tax.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross amount subject to tax before the tax is calculated. This is the base upon which the tax rate is applied.' ;
    rdfs:domain ind:TaxPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allergenIncidentId rdf:type rdf:Property ;
    rdfs:label 'Allergen Incident Id' ;
    rdfs:comment 'System-generated unique identifier for the allergen incident record.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guestOrderId rdf:type rdf:Property ;
    rdfs:label 'Guest Order Id' ;
    rdfs:comment 'Identifier of the POS order associated with the incident, if applicable.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GuestOrder .

ind:guestProfileId rdf:type rdf:Property ;
    rdfs:label 'Guest Profile Id' ;
    rdfs:comment 'Unique identifier of the guest who reported the allergen reaction.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:lotTrackingId rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Id' ;
    rdfs:comment 'Foreign key linking to inventory.lot_tracking. Business justification: When an allergen incident involves a specific lot, linking to lot tracking provides precise traceability for recalls.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotTracking .

ind:memberId rdf:type rdf:Property ;
    rdfs:label 'Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.member. Business justification: Allergen incident handling awards loyalty points to members who report incidents; direct member link is required for points accrual and incident reporting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:menuItemId rdf:type rdf:Property ;
    rdfs:label 'Menu Item Id' ;
    rdfs:comment 'Identifier of the menu item implicated in the incident.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MenuItem .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Identifier of the employee shift during which the incident happened.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:temperatureLogId rdf:type rdf:Property ;
    rdfs:label 'Temperature Log Id' ;
    rdfs:comment 'Reference to the temperature monitoring record associated with the incident, if relevant.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TemperatureLog .

ind:allergenCode rdf:type rdf:Property ;
    rdfs:label 'Allergen Code' ;
    rdfs:comment 'Standardized code for the allergen (e.g., ISO 22000 allergen code).' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenIncidentStatus rdf:type rdf:Property ;
    rdfs:label 'Allergen Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allergenName rdf:type rdf:Property ;
    rdfs:label 'Allergen Name' ;
    rdfs:comment 'Name of the allergen involved in the incident (e.g., peanuts, shellfish).' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Narrative provided by the guest describing the allergic reaction and circumstances.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the incident complies with internal SOPs and external regulations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Planned or executed corrective measures to prevent recurrence.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaMedwatchFiled rdf:type rdf:Property ;
    rdfs:label 'Fda Medwatch Filed' ;
    rdfs:comment 'Indicates whether the incident was reported to the FDA MedWatch system.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestContactInfo rdf:type rdf:Property ;
    rdfs:label 'Guest Contact Info' ;
    rdfs:comment 'Phone number or email address used to reach the guest.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestContactMethod rdf:type rdf:Property ;
    rdfs:label 'Guest Contact Method' ;
    rdfs:comment 'Preferred method used to contact the guest for follow-up.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Actions performed at the time of the incident (e.g., administered epinephrine, called emergency services).' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level classification of the incident type.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Physical location within the restaurant where the incident occurred (e.g., kitchen, dining area).' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNotes rdf:type rdf:Property ;
    rdfs:label 'Incident Notes' ;
    rdfs:comment 'Free-form notes captured by staff during investigation.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing identifier assigned to the incident for tracking and reporting.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentResolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Resolution Timestamp' ;
    rdfs:comment 'Date and time when the incident was formally closed or resolved.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Date and time when the allergen incident was observed or reported.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationComplete rdf:type rdf:Property ;
    rdfs:label 'Investigation Complete' ;
    rdfs:comment 'Indicates whether the root-cause investigation has been completed.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigation Complete Timestamp' ;
    rdfs:comment 'Date and time when the investigation was marked complete.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRepeatIncident rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Incident' ;
    rdfs:comment 'Indicates whether a similar allergen incident has been recorded previously at the same location.' ;
    rdfs:domain ind:AllergenIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the regulatory notification was submitted.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of required notifications to regulatory bodies (e.g., FDA MedWatch).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the staff member who logged the incident.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified underlying cause of the allergen exposure (e.g., cross-contamination, mislabeling).' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Numeric representation of incident severity (e.g., 1-5 scale) for analytics.' ;
    rdfs:domain ind:Foodsafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the incident record.' ;
