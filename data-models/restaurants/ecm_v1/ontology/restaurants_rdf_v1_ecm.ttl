    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Cubic Meters' ;
    rdfs:comment 'Total usable storage volume of the center in cubic meters.' ;
