    rdfs:range xsd:string .

ind:egg rdf:type rdf:Property ;
    rdfs:label 'Egg' ;
    rdfs:comment 'Indicates if egg is absent, present, or may-contain in the item.' ;
    rdfs:domain ind:FoodsafetyAllergenProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fish rdf:type rdf:Property ;
    rdfs:label 'Fish' ;
    rdfs:comment 'Indicates if fish is absent, present, or may-contain in the item.' ;
    rdfs:domain ind:FoodsafetyAllergenProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodsafetyAllergenProfileStatus rdf:type rdf:Property ;
