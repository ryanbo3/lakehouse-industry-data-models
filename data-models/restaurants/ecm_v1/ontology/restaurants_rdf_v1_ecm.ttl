    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Approval Status' ;
    rdfs:comment 'Legal department approval outcome for the creative.' ;
    rdfs:domain ind:AdCreative ;
