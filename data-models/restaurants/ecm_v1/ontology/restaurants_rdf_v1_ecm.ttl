ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Required for the Campaign Ownership Report that tracks which employee owns each marketing campaign, a standard operational metric in restaurant marketing.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAdtLiftPct rdf:type rdf:Property ;
    rdfs:label 'Actual Adt Lift Pct' ;
    rdfs:comment 'Measured increase in Average Daily Transactions after campaign execution.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCompSalesLiftPct rdf:type rdf:Property ;
    rdfs:label 'Actual Comp Sales Lift Pct' ;
    rdfs:comment 'Measured lift in comparable store sales after campaign execution.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
