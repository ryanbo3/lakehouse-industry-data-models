    rdfs:domain ind:FoodsafetyAllergenProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date the allergen profile was last reviewed for accuracy.' ;
    rdfs:domain ind:Restaurants ;
