ind:deliveryStockLocationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Stock Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_location. Business justification: POs must specify the receiving stock location to schedule receiving, temperature control, and HACCP monitoring.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockLocation .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Internal classification of the purchase order line items (e.g., FOOD, PACKAGING, EQUIPMENT).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Physical address of the delivery location for the purchase order.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Amount' ;
    rdfs:comment 'Cost of transportation and shipping associated with the purchase order.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalComments rdf:type rdf:Property ;
    rdfs:label 'Internal Comments' ;
    rdfs:comment 'Internal remarks visible only to authorized personnel.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'True if the purchase order aggregates multiple requisitions or suppliers.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUrgent rdf:type rdf:Property ;
    rdfs:label 'Is Urgent' ;
    rdfs:comment 'Indicates whether the purchase order requires expedited processing.' ;
    rdfs:domain ind:ProcurementPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Received Timestamp' ;
