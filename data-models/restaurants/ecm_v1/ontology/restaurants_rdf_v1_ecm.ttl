    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeType rdf:type rdf:Property ;
    rdfs:label 'Creative Type' ;
    rdfs:comment 'Category of the creative asset indicating its media form.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Dam Reference Code' ;
    rdfs:comment 'Identifier of the asset within the Digital Asset Management system.' ;
