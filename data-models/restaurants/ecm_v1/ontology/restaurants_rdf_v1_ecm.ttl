ind:productId rdf:type rdf:Property ;
    rdfs:label 'Product Id' ;
    rdfs:comment 'Unique identifier of the product or SKU referenced by this line.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Product .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'Total amount for the line before discounts and taxes (ordered_quantity * unit_price).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Invoice Timestamp' ;
    rdfs:comment 'Timestamp when the line was invoiced.' ;
    rdfs:domain ind:PoLine ;
