ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the creative file in bytes.' ;
    rdfs:domain ind:AdCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether the creative has been archived and is no longer active.' ;
