ind:scheduledPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Payment Amount' ;
    rdfs:comment 'The originally scheduled or expected payment amount per the lease agreement for this period.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The total amount paid in this rent payment transaction, including base rent, CAM, taxes, insurance, and any other charges.' ;
    rdfs:domain ind:RentPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rent Schedule Id' ;
    rdfs:comment 'Unique identifier for the rent schedule record. Primary key. Represents one billing period for one lease agreement.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:camReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Cam Reconciliation Flag' ;
    rdfs:comment 'Indicates whether this billing period includes a CAM reconciliation adjustment, where estimated CAM charges are trued up to actual landlord expenses.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'The annual escalation rate applied to base rent for this period, expressed as a decimal (e.g., 0.0300 for 3% annual increase). Null if escalation type is none or stepped.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'The method by which base rent increases over the lease term. Fixed = predetermined amount, CPI = Consumer Price Index linked, Percentage = annual percentage increase, Stepped = scheduled step increases, None = flat rent.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestExpense rdf:type rdf:Property ;
    rdfs:label 'Interest Expense' ;
    rdfs:comment 'The interest expense component of the lease payment for this period under IFRS 16 / ASC 842 finance lease accounting. Calculated using the incremental borrowing rate.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseAccountingClassification rdf:type rdf:Property ;
    rdfs:label 'Lease Accounting Classification' ;
    rdfs:comment 'The accounting treatment classification for this lease under IFRS 16 / ASC 842. Operating leases recognize rent expense; finance leases recognize depreciation and interest expense.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiabilityReduction rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Reduction' ;
    rdfs:comment 'The portion of the total occupancy cost that reduces the lease liability on the balance sheet for this period under IFRS 16 / ASC 842. Represents principal payment component.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyCostPercentage rdf:type rdf:Property ;
    rdfs:label 'Occupancy Cost Percentage' ;
    rdfs:comment 'The total occupancy cost as a percentage of restaurant sales for this period, calculated as (total_occupancy_cost / reported_sales_amount). Key performance metric for site profitability. Null if sales not reported.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRentAmount rdf:type rdf:Property ;
    rdfs:label 'Percentage Rent Amount' ;
    rdfs:comment 'The calculated percentage rent due for this billing period based on actual sales performance exceeding the threshold. Zero if sales did not exceed threshold or lease has no percentage rent clause.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propertyAddress rdf:type rdf:Property ;
    rdfs:label 'Property Address' ;
    rdfs:comment 'The full street address of the leased restaurant property for this rent schedule. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realEstateTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Real Estate Tax Amount' ;
    rdfs:comment 'The tenant\'s proportionate share of property taxes for this billing period. May be estimated monthly and reconciled annually based on actual tax assessments.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentPerSquareFoot rdf:type rdf:Property ;
    rdfs:label 'Rent Per Square Foot' ;
    rdfs:comment 'The base rent amount divided by square footage for this billing period, expressed as cost per square foot. Key benchmarking metric for real estate portfolio management.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Reported Sales Amount' ;
    rdfs:comment 'The gross sales revenue reported to the landlord for this billing period, used to calculate percentage rent. Confidential business performance data. Null if sales reporting is not required.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightOfUseAssetDepreciation rdf:type rdf:Property ;
    rdfs:label 'Right Of Use Asset Depreciation' ;
    rdfs:comment 'The depreciation expense for the right-of-use asset for this period under IFRS 16 / ASC 842. Typically straight-line over the lease term.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sales Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the tenant is contractually required to report sales revenue to the landlord for this billing period, typically for percentage rent calculation or lease compliance.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReconciliationFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reconciliation Flag' ;
    rdfs:comment 'Indicates whether this billing period includes a real estate tax reconciliation adjustment, where estimated tax charges are trued up to actual property tax assessments.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalOccupancyCost rdf:type rdf:Property ;
    rdfs:label 'Total Occupancy Cost' ;
    rdfs:comment 'The sum of all rent and occupancy charges for this billing period: base rent + percentage rent + CAM + real estate tax + insurance + other charges. Represents total cash outflow for occupancy.' ;
    rdfs:domain ind:RentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibilityScore rdf:type rdf:Property ;
    rdfs:label 'Accessibility Score' ;
    rdfs:comment 'Quantitative assessment of ease of ingress and egress, typically scored 0-100. Considers turn lanes, traffic signals, median cuts, and parking availability.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Building Square Footage' ;
    rdfs:comment 'Total interior square footage of the restaurant building. Used for lease valuation, R&M (Repairs and Maintenance) budgeting, and utility forecasting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyTrafficCount rdf:type rdf:Property ;
    rdfs:label 'Daily Traffic Count' ;
    rdfs:comment 'Average daily vehicle or pedestrian traffic count passing the site. Critical visibility and accessibility metric for site selection scoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruCapable rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Capable' ;
    rdfs:comment 'Indicates whether the site configuration and zoning permit a drive-thru lane. Critical for QSR (Quick-Service Restaurant) operational model and throughput forecasting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date on which the lease agreement becomes effective and rent obligations begin. Critical for IFRS 16 / ASC 842 right-of-use asset recognition.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiration Date' ;
    rdfs:comment 'Date on which the current lease term expires. Used for lease renewal planning, portfolio optimization, and financial forecasting.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage of the site within the NRO (New Restaurant Opening) pipeline or existing portfolio lifecycle. Drives workflow, reporting, and financial treatment. [ENUM-REF-CANDIDATE: prospecting|under_negotiation|approved|under_construction|active|temporarily_closed|closed|disposed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Lot Square Footage' ;
    rdfs:comment 'Total land area of the site parcel in square feet. Used for property valuation, CAM (Common Area Maintenance) calculations, and site development planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Demographic and geographic market segment classification. Drives menu mix, pricing strategy, and operational model selection.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyBaseRent rdf:type rdf:Property ;
    rdfs:label 'Monthly Base Rent' ;
    rdfs:comment 'Fixed monthly rent payment obligation under the lease agreement, excluding variable charges. Used for P&L (Profit and Loss) forecasting and lease liability calculation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyCamCharges rdf:type rdf:Property ;
    rdfs:label 'Monthly Cam Charges' ;
    rdfs:comment 'Monthly charges for common area maintenance, property taxes, and insurance allocated to the tenant. Variable component of total occupancy cost.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Legal ownership structure of the site. Determines accounting treatment under IFRS 16 / ASC 842 lease standards and CapEx (Capital Expenditure) responsibility.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingSpaces rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces' ;
    rdfs:comment 'Number of dedicated parking spaces available at the site. Must meet local zoning minimums and impacts customer accessibility scoring.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedAuv rdf:type rdf:Property ;
    rdfs:label 'Projected Auv' ;
    rdfs:comment 'Forecasted annual sales volume for the site based on site selection model. Used for NRO (New Restaurant Opening) approval and ROI (Return on Investment) analysis.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name or designation for the site, often incorporating location landmarks or address elements for easy identification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteNumber rdf:type rdf:Property ;
    rdfs:label 'Site Number' ;
    rdfs:comment 'Externally-known unique business identifier for the site, used across real estate, operations, and finance systems. Typically assigned during site prospecting phase.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Physical configuration and placement classification of the site within its development or property. Critical for site selection scoring and operational model determination. [ENUM-REF-CANDIDATE: freestanding|inline|endcap|pad|food_court|airport|travel_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapexInvestment rdf:type rdf:Property ;
    rdfs:label 'Total Capex Investment' ;
    rdfs:comment 'Total capital investment for site development, including land acquisition, construction, equipment, and pre-opening costs. Used for ROI calculation and capital planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visibilityScore rdf:type rdf:Property ;
    rdfs:label 'Visibility Score' ;
    rdfs:comment 'Quantitative assessment of site visibility from primary traffic routes, typically scored 0-100. Incorporates signage sightlines, obstructions, and approach angles.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Local government zoning designation for the site parcel. Determines permitted uses, building restrictions, and signage allowances.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitePermitId rdf:type rdf:Property ;
    rdfs:label 'Site Permit Id' ;
    rdfs:comment 'Unique identifier for the site permit record.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date the permit application was initially submitted.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File system path or storage identifier for the permit document.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePaidFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Paid Flag' ;
    rdfs:comment 'Indicates whether the permit fee has been paid.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Date' ;
    rdfs:comment 'Date the permit fee was paid.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Due Date' ;
    rdfs:comment 'Date by which the required inspection must be completed.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates if an inspection is required for this permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the most recent inspection.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSchedule rdf:type rdf:Property ;
    rdfs:label 'Inspection Schedule' ;
    rdfs:comment 'Scheduled date(s) or frequency for required inspections.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Governmental or municipal authority that issues the permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionComments rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Comments' ;
    rdfs:comment 'Comments recorded during the last inspection.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionObserver rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Observer' ;
    rdfs:comment 'Name or identifier of the person/agency who performed the last inspection.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitCategory rdf:type rdf:Property ;
    rdfs:label 'Permit Category' ;
    rdfs:comment 'High-level category of the permit purpose.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Permit Expiry Timestamp' ;
    rdfs:comment 'Exact timestamp when the permit expires.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitFee rdf:type rdf:Property ;
    rdfs:label 'Permit Fee' ;
    rdfs:comment 'Fee charged for the permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitIssueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Timestamp' ;
    rdfs:comment 'Exact timestamp when the permit was officially issued.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitSubtype rdf:type rdf:Property ;
    rdfs:label 'Permit Subtype' ;
    rdfs:comment 'More specific subtype of the permit, if applicable.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Category of the permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date by which the permit must be renewed.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates if the permit requires renewal.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date the permit was revoked, if applicable.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sitePermitStatus rdf:type rdf:Property ;
    rdfs:label 'Site Permit Status' ;
    rdfs:comment 'Overall lifecycle status of the permit record.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the permit application was formally submitted to the authority.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteSelectionId rdf:type rdf:Property ;
    rdfs:label 'Site Selection Id' ;
    rdfs:comment 'Unique surrogate key for each site selection evaluation record.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Employee Id' ;
    rdfs:comment 'Employee or executive who approved the site selection.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'System user who last updated the record.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySiteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Site Employee Id' ;
    rdfs:comment 'Employee responsible for leading the evaluation.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternarySiteLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Site Last Modified By User Employee Id' ;
    rdfs:comment 'System user who last updated the record.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteMasterSiteId rdf:type rdf:Property ;
    rdfs:label 'Site Master Site Id' ;
    rdfs:comment 'Reference to the master record of the candidate location.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:tertiarySiteCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Site Created By User Employee Id' ;
    rdfs:comment 'System user who created the record.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auvProjection rdf:type rdf:Property ;
    rdfs:label 'Auv Projection' ;
    rdfs:comment 'Projected average weekly sales per unit (in local currency).' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cannibalizationRiskScore rdf:type rdf:Property ;
    rdfs:label 'Cannibalization Risk Score' ;
    rdfs:comment 'Score (1-10) estimating risk of cannibalizing existing stores.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionScore rdf:type rdf:Property ;
    rdfs:label 'Competition Score' ;
    rdfs:comment 'Score (1-10) indicating competitive pressure in the trade area.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceHaccpFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Haccp Flag' ;
    rdfs:comment 'Indicates whether the site meets HACCP food-safety requirements.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date the evaluation committee rendered its final decision.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:demographicScore rdf:type rdf:Property ;
    rdfs:label 'Demographic Score' ;
    rdfs:comment 'Numeric score (1-10) reflecting demographic suitability.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalImpactScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Score' ;
    rdfs:comment 'Score (1-10) assessing environmental sustainability considerations.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCode rdf:type rdf:Property ;
    rdfs:label 'Evaluation Code' ;
    rdfs:comment 'Human-readable code assigned to the evaluation for tracking and reference.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStage rdf:type rdf:Property ;
    rdfs:label 'Evaluation Stage' ;
    rdfs:comment 'Most recent stage of the evaluation workflow.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Timestamp' ;
    rdfs:comment 'Timestamp when the evaluation process was initiated.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Expected Employee Count' ;
    rdfs:comment 'Projected number of staff required to operate the site.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedFte rdf:type rdf:Property ;
    rdfs:label 'Expected Fte' ;
    rdfs:comment 'Projected full-time equivalent labor units.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketShareEstimatePercent rdf:type rdf:Property ;
    rdfs:label 'Market Share Estimate Percent' ;
    rdfs:comment 'Projected share of the local market captured by the new site.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallSiteScore rdf:type rdf:Property ;
    rdfs:label 'Overall Site Score' ;
    rdfs:comment 'Weighted composite score summarizing all evaluation criteria.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAnnualSales rdf:type rdf:Property ;
    rdfs:label 'Projected Annual Sales' ;
    rdfs:comment 'Estimated total sales for the first fiscal year.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCapexAmount rdf:type rdf:Property ;
    rdfs:label 'Projected Capex Amount' ;
    rdfs:comment 'Projected CAPEX specific to construction, equipment, and fit-out.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedCogsPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Cogs Percent' ;
    rdfs:comment 'Estimated COGS as a percentage of sales.' ;
    rdfs:domain ind:Realestate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Projected Investment Amount' ;
    rdfs:comment 'Estimated total capital required to open the site.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedLaborPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Labor Percent' ;
    rdfs:comment 'Estimated labor cost as a percentage of sales.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Roi Percent' ;
    rdfs:comment 'Estimated ROI expressed as a percentage over the analysis horizon.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating why a site was rejected.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqft' ;
    rdfs:comment 'Total usable square footage of the candidate location.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteSelectionStatus rdf:type rdf:Property ;
    rdfs:label 'Site Selection Status' ;
    rdfs:comment 'Current lifecycle status of the site selection evaluation.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficScore rdf:type rdf:Property ;
    rdfs:label 'Traffic Score' ;
    rdfs:comment 'Numeric score (1-10) based on vehicle and foot traffic analysis.' ;
    rdfs:domain ind:SiteSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageHouseholdSize rdf:type rdf:Property ;
    rdfs:label 'Average Household Size' ;
    rdfs:comment 'Mean number of individuals per household in the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageIncomePerCapita rdf:type rdf:Property ;
    rdfs:label 'Average Income Per Capita' ;
    rdfs:comment 'Mean individual income within the trade area, expressed in US dollars.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitionCount rdf:type rdf:Property ;
    rdfs:label 'Competition Count' ;
    rdfs:comment 'Count of direct competitor locations inside the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitionNames rdf:type rdf:Property ;
    rdfs:label 'Competition Names' ;
    rdfs:comment 'Names of competing restaurant brands present in the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataVintageDate rdf:type rdf:Property ;
    rdfs:label 'Data Vintage Date' ;
    rdfs:comment 'Reference date indicating the snapshot date of the demographic and traffic data.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daytimePopulation rdf:type rdf:Property ;
    rdfs:label 'Daytime Population' ;
    rdfs:comment 'Estimated total population present in the trade area during typical business hours.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Employment Rate Percent' ;
    rdfs:comment 'Percentage of the working-age population that is employed.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketShareScore rdf:type rdf:Property ;
    rdfs:label 'Market Share Score' ;
    rdfs:comment 'Analyst-derived score (0-100) indicating the site’s potential market share.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medianAge rdf:type rdf:Property ;
    rdfs:label 'Median Age' ;
    rdfs:comment 'Median age of residents within the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medianHouseholdIncome rdf:type rdf:Property ;
    rdfs:label 'Median Household Income' ;
    rdfs:comment 'Median annual household income in US dollars for households within the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Technique applied to generate the trade area boundaries (drive-time, radius, or Voronoi).' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationDensityPerSqMile rdf:type rdf:Property ;
    rdfs:label 'Population Density Per Sq Mile' ;
    rdfs:comment 'Number of people per square mile in the primary trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBoundaryDriveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Primary Boundary Drive Time Minutes' ;
    rdfs:comment 'Maximum travel time in minutes for the primary trade area; null if not applicable.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryBoundaryGeojson rdf:type rdf:Property ;
    rdfs:label 'Primary Boundary Geojson' ;
    rdfs:comment 'GeoJSON representation of the primary trade-area polygon.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryBoundaryRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Primary Boundary Radius Miles' ;
    rdfs:comment 'Radius in miles for a circular primary trade area; null if not applicable.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residentialPopulation rdf:type rdf:Property ;
    rdfs:label 'Residential Population' ;
    rdfs:comment 'Count of people who reside in the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryBoundaryDriveTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Secondary Boundary Drive Time Minutes' ;
    rdfs:comment 'Maximum travel time in minutes for the secondary trade area; null if not applicable.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryBoundaryGeojson rdf:type rdf:Property ;
    rdfs:label 'Secondary Boundary Geojson' ;
    rdfs:comment 'GeoJSON representation of the secondary trade-area polygon.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryBoundaryRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Secondary Boundary Radius Miles' ;
    rdfs:comment 'Radius in miles for a circular secondary trade area; null if not applicable.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeAreaName rdf:type rdf:Property ;
    rdfs:label 'Trade Area Name' ;
    rdfs:comment 'Descriptive label used by analysts and planners to identify the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeAreaStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Area Status' ;
    rdfs:comment 'Indicates whether the trade area is currently used for planning, retired, or archived.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficAdt rdf:type rdf:Property ;
    rdfs:label 'Traffic Adt' ;
    rdfs:comment 'Average number of vehicles passing per day on primary arteries within the trade area.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficPeakHour rdf:type rdf:Property ;
    rdfs:label 'Traffic Peak Hour' ;
    rdfs:comment 'Maximum vehicle count observed during the busiest hour of the day.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment 'Five-digit (or ZIP+4) postal code of the restaurant location.' ;
    rdfs:domain ind:TradeArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaManagementId rdf:type rdf:Property ;
    rdfs:label 'Area Management Id' ;
    rdfs:comment 'Unique identifier for the area management record. Primary key.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAreaAreaManagementId rdf:type rdf:Property ;
    rdfs:label 'Parent Area Area Management Id' ;
    rdfs:comment 'Identifier of the parent area in the management hierarchy. Null for top-level areas.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AreaManagement .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Business identifier code for the area or district. Used in operational reporting and area manager assignment.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Descriptive name of the area or district (e.g., \'Northeast Metro\', \'Southern California Region\').' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaStatus rdf:type rdf:Property ;
    rdfs:label 'Area Status' ;
    rdfs:comment 'Current operational status of the area management record.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the area management level within the organizational hierarchy.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auvTarget rdf:type rdf:Property ;
    rdfs:label 'Auv Target' ;
    rdfs:comment 'Target Average Unit Volume (AUV) for restaurants in this area, representing expected annual sales per unit.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyOwnedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Company Owned Unit Count' ;
    rdfs:comment 'Number of company-owned restaurant units within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csatTargetScore rdf:type rdf:Property ;
    rdfs:label 'Csat Target Score' ;
    rdfs:comment 'Target Customer Satisfaction (CSAT) score for this area, typically measured on a scale of 0-100.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Flag' ;
    rdfs:comment 'Indicates whether this area is governed by a franchise area development agreement.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseUnitCount rdf:type rdf:Property ;
    rdfs:label 'Franchise Unit Count' ;
    rdfs:comment 'Number of franchised restaurant units within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingFundContributionPercent rdf:type rdf:Property ;
    rdfs:label 'Marketing Fund Contribution Percent' ;
    rdfs:comment 'Percentage of sales contributed to the marketing fund by units in this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsTargetScore rdf:type rdf:Property ;
    rdfs:label 'Nps Target Score' ;
    rdfs:comment 'Target Net Promoter Score (NPS) for this area, measuring customer loyalty and likelihood to recommend.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nroTargetCount rdf:type rdf:Property ;
    rdfs:label 'Nro Target Count' ;
    rdfs:comment 'Target number of New Restaurant Openings (NRO) planned for this area within the current fiscal year.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sssTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sss Target Percent' ;
    rdfs:comment 'Target Same-Store Sales (SSS) growth percentage for this area, used to measure year-over-year comparable store performance.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Boundary Description' ;
    rdfs:comment 'Textual description of the geographic or operational boundaries defining this area (e.g., \'All units within 50 miles of downtown Chicago\').' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total number of restaurant units (company-owned and franchised) within this area.' ;
    rdfs:domain ind:AreaManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandStandardId rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Id' ;
    rdfs:comment 'Unique identifier for the brand standard record. Primary key.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandStandard .

ind:supersededByStandardBrandStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Standard Brand Standard Id' ;
    rdfs:comment 'Reference to the brand_standard_id of the newer standard that replaces this one. Null if this standard is current and has not been superseded.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandStandard .

ind:applicableFormat rdf:type rdf:Property ;
    rdfs:label 'Applicable Format' ;
    rdfs:comment 'Restaurant format(s) to which this brand standard applies. QSR (Quick-Service Restaurant) for fast food, casual for casual dining, fine_dining for upscale establishments, or combinations/all formats. [ENUM-REF-CANDIDATE: all|qsr|casual|fine_dining|qsr_casual|qsr_fine_dining|casual_fine_dining — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Applicable Ownership Model' ;
    rdfs:comment 'Ownership model(s) to which this standard applies: company-owned units, franchised units, or all units regardless of ownership.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Expected frequency at which compliance with this standard should be audited or inspected (e.g., daily temperature logs, monthly cleanliness audits, annual safety inspections). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi_annual|annual|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Status' ;
    rdfs:comment 'Current lifecycle status of the brand standard. Active standards are in force. Inactive standards are no longer enforced. Draft standards are under development. Under_review standards are being revised. Superseded standards have been replaced by a newer version.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the external organization or authority that issues the required certification (e.g., National Restaurant Association ServSafe, OSHA, Local Health Department). Null if no certification is required.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether staff must obtain a formal certification to perform tasks related to this standard (e.g., ServSafe Food Handler certification for food safety standards). True if certification is mandatory, False otherwise.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Level' ;
    rdfs:comment 'Enforcement level of the standard. Mandatory standards must be met for operational compliance and are subject to audit consequences. Recommended standards are best practices encouraged but not enforced. Aspirational standards represent future-state goals.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyReference rdf:type rdf:Property ;
    rdfs:label 'Governing Body Reference' ;
    rdfs:comment 'External regulatory or industry body that mandates or influences this standard (e.g., FDA, USDA, OSHA, NRA ServSafe, Local Health Department, ISO 22000). Null if the standard is purely internal.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Facing Flag' ;
    rdfs:comment 'Indicates whether this standard directly impacts the guest experience and is visible or perceptible to customers (e.g., FOH cleanliness, service speed, food presentation). True if guest-facing, False if back-of-house or internal only.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Method by which compliance with this standard is assessed: direct observation (visual inspection), checklist (structured audit form), measurement (thermometer, timer), testing (lab analysis, swab test), documentation review (log verification), or guest feedback (CSAT, NPS).' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceConsequence rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Consequence' ;
    rdfs:comment 'Consequence or remediation action triggered when a unit fails to meet this standard. Ranges from warnings and corrective action plans to financial penalties, operational suspension, or franchise termination for critical violations.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Internal department or functional area responsible for defining, maintaining, and enforcing this brand standard (e.g., Food Safety, Operations, Quality Assurance, Franchise Development, Marketing).' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sop Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the detailed SOP document that operationalizes this brand standard. May be a document management system ID, SharePoint link, or file path.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'High-level classification of the brand standard into operational domains: food quality (taste, temperature, freshness), food safety (HACCP compliance, contamination prevention), cleanliness (sanitation, hygiene), service excellence (guest interaction, speed of service), brand presentation (signage, uniforms, decor), workplace safety (OSHA compliance, injury prevention), or equipment maintenance (preventive maintenance, calibration). [ENUM-REF-CANDIDATE: food_quality|food_safety|cleanliness|service_excellence|brand_presentation|workplace_safety|equipment_maintenance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Unique business identifier code for the brand standard, typically following a category-number pattern (e.g., FS-001 for Food Safety standard 001, CL-042 for Cleanliness standard 042).' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDescription rdf:type rdf:Property ;
    rdfs:label 'Standard Description' ;
    rdfs:comment 'Detailed narrative description of the brand standard, including the specific requirement, rationale, and expected outcome. May reference specific procedures, thresholds, or quality criteria.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Full descriptive name of the brand standard (e.g., \'Proper Handwashing Protocol\', \'Drive-Thru Speed of Service Target\', \'Uniform and Appearance Guidelines\').' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Target Metric Unit' ;
    rdfs:comment 'Unit of measure for the target metric value (e.g., degrees Fahrenheit, seconds, percentage, count). Null if the standard does not have a quantitative metric.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Specific quantitative or qualitative target that defines compliance with this standard (e.g., \'Food temperature >= 165°F\', \'Speed of Service <= 90 seconds\', \'Cleanliness score >= 95%\', \'Zero critical violations\'). Null if the standard is qualitative without a numeric threshold.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModuleReference rdf:type rdf:Property ;
    rdfs:label 'Training Module Reference' ;
    rdfs:comment 'Reference identifier to the training module or course that covers this brand standard. May be an LMS (Learning Management System) course ID or training document reference. Null if no formal training module exists.' ;
    rdfs:domain ind:BrandStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConfigId rdf:type rdf:Property ;
    rdfs:label 'Capacity Config Id' ;
    rdfs:comment 'Unique identifier for the capacity configuration record. Primary key.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaCompliantSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Seating Count' ;
    rdfs:comment 'Number of seating positions that meet ADA accessibility requirements for guests with disabilities.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgPartySize rdf:type rdf:Property ;
    rdfs:label 'Avg Party Size' ;
    rdfs:comment 'Average number of guests per dining party used for capacity planning and labor forecasting.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Bar Seating Count' ;
    rdfs:comment 'Number of seats available at the bar or counter service area.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Config Effective Date' ;
    rdfs:comment 'The date from which this capacity configuration becomes effective for the restaurant unit.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configEndDate rdf:type rdf:Property ;
    rdfs:label 'Config End Date' ;
    rdfs:comment 'The date on which this capacity configuration ceases to be effective. Null indicates the configuration is currently active.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:configNotes rdf:type rdf:Property ;
    rdfs:label 'Config Notes' ;
    rdfs:comment 'Free-text notes documenting special considerations, constraints, or context for this capacity configuration.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle status of the capacity configuration record.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterServicePositions rdf:type rdf:Property ;
    rdfs:label 'Counter Service Positions' ;
    rdfs:comment 'Number of staffed counter service positions available for order taking and guest interaction.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curbsidePickupSpaces rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Spaces' ;
    rdfs:comment 'Number of designated parking spaces available for curbside pickup and online ordering (OLO) fulfillment.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStagingCapacity rdf:type rdf:Property ;
    rdfs:label 'Delivery Staging Capacity' ;
    rdfs:comment 'Number of completed delivery orders that can be staged simultaneously in the designated pickup area for third-party delivery (3PD) drivers.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruSosTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Sos Target Seconds' ;
    rdfs:comment 'Target time in seconds for drive-thru order fulfillment from order point to pickup window.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:driveThruStackingCapacity rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Stacking Capacity' ;
    rdfs:comment 'Maximum number of vehicles that can queue in the drive-thru lane before reaching the order point.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireCodeOccupancyLimit rdf:type rdf:Property ;
    rdfs:label 'Fire Code Occupancy Limit' ;
    rdfs:comment 'Maximum number of occupants (guests and staff) permitted in the facility as determined by local fire safety regulations.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthPermitCapacity rdf:type rdf:Property ;
    rdfs:label 'Health Permit Capacity' ;
    rdfs:comment 'Maximum seating capacity approved by the local health department on the restaurant operating permit.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indoorSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Indoor Seating Capacity' ;
    rdfs:comment 'Total number of indoor seats available for guest dining in the Front of House (FOH) area.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kioskCount rdf:type rdf:Property ;
    rdfs:label 'Kiosk Count' ;
    rdfs:comment 'Number of self-service ordering kiosks available in the Front of House (FOH) for guest order placement.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitchenProductionCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Kitchen Production Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of orders the Back of House (BOH) kitchen can produce per hour at full operational capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborStaffingRatio rdf:type rdf:Property ;
    rdfs:label 'Labor Staffing Ratio' ;
    rdfs:comment 'Target ratio of Full-Time Equivalent (FTE) staff to seating capacity or covers, used for workforce scheduling and labor cost planning.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxCoverCountBreakfast rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Breakfast' ;
    rdfs:comment 'Maximum number of guest covers (individual diners) that can be served during the breakfast daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountDinner rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Dinner' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the dinner daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountLateNight rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Late Night' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the late night daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxCoverCountLunch rdf:type rdf:Property ;
    rdfs:label 'Max Cover Count Lunch' ;
    rdfs:comment 'Maximum number of guest covers that can be served during the lunch daypart based on seating and throughput capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outdoorSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Outdoor Seating Capacity' ;
    rdfs:comment 'Total number of outdoor or patio seats available for guest dining.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakHourThroughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Throughput Capacity' ;
    rdfs:comment 'Maximum number of guest transactions or covers that can be processed during the busiest hour of operation.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateDiningCapacity rdf:type rdf:Property ;
    rdfs:label 'Private Dining Capacity' ;
    rdfs:comment 'Total seating capacity in private dining rooms or event spaces within the restaurant.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tableTurnTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Table Turn Target Minutes' ;
    rdfs:comment 'Target time in minutes for a complete table turn cycle from guest seating to table reset for the next guest.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Seating Capacity' ;
    rdfs:comment 'Aggregate seating capacity across all dining areas including indoor, outdoor, bar, and private dining.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Usd' ;
    rdfs:comment 'Original purchase price paid for the equipment asset in US dollars, used for CapEx (Capital Expenditure) tracking and depreciation calculations.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetConditionRating rdf:type rdf:Property ;
    rdfs:label 'Asset Condition Rating' ;
    rdfs:comment 'Current physical and operational condition assessment of the equipment asset based on inspection and performance criteria.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Externally visible unique asset tag or barcode identifier affixed to the equipment for tracking and inventory purposes.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Expiry Date' ;
    rdfs:comment 'Date when the current compliance certification expires and recertification or inspection is required.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Number' ;
    rdfs:comment 'Certification or approval number from regulatory bodies (FDA, NSF, UL, OSHA) confirming the equipment meets safety and sanitation standards.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCategory rdf:type rdf:Property ;
    rdfs:label 'Equipment Category' ;
    rdfs:comment 'High-level classification grouping equipment by operational domain (cooking, refrigeration, POS systems, etc.). [ENUM-REF-CANDIDATE: cooking|refrigeration|food_prep|beverage|pos_system|kitchen_display|sanitation|hvac — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or designation of the equipment asset (e.g., Fryer Station 1, POS Terminal 3, Walk-in Cooler).' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Category of equipment asset distinguishing its primary function within BOH (Back of House) or FOH (Front of House) operations. [ENUM-REF-CANDIDATE: fryer|grill|oven|refrigeration_unit|freezer|ice_machine|pos_terminal|kds_display|espresso_machine|beverage_dispenser|dishwasher|ventilation_hood|warming_cabinet|prep_table — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the equipment asset was installed and commissioned at the restaurant location.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Most recent date when preventive maintenance or repair service was performed on this equipment asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTemperatureCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Temperature Check Timestamp' ;
    rdfs:comment 'Most recent date and time when temperature was verified for temperature-critical equipment, supporting food safety audit trails.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the lease or rental agreement for this equipment expires, requiring renewal or return of the asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Physical zone within the restaurant where the equipment is installed: BOH (Back of House), FOH (Front of House), Drive-Thru, Storage, or Outdoor.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Maintenance Frequency Days' ;
    rdfs:comment 'Number of days between scheduled preventive maintenance services as defined by manufacturer guidelines or internal SOPs.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle status indicating whether the equipment is actively in use, under maintenance, or retired from service.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerConsumptionWatts rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Watts' ;
    rdfs:comment 'Rated electrical power consumption of the equipment in watts under normal operating conditions, used for energy cost forecasting.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementCostUsd rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Usd' ;
    rdfs:comment 'Estimated current market cost to replace this equipment asset with a comparable new unit, used for R&M (Repairs and Maintenance) budgeting and insurance valuation.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Service Contract Number' ;
    rdfs:comment 'Reference number of the active service or maintenance contract covering this equipment asset, if applicable.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Critical Flag' ;
    rdfs:comment 'Indicates whether this equipment maintains temperature-sensitive food products and requires continuous monitoring for HACCP (Hazard Analysis Critical Control Points) compliance.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxF rdf:type rdf:Property ;
    rdfs:label 'Temperature Max F' ;
    rdfs:comment 'Maximum safe operating temperature threshold in Fahrenheit for temperature-critical equipment, above which food safety is compromised.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinF rdf:type rdf:Property ;
    rdfs:label 'Temperature Min F' ;
    rdfs:comment 'Minimum safe operating temperature threshold in Fahrenheit for temperature-critical equipment, below which food safety is compromised.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage ends, after which repairs and parts are at the restaurant\'s expense.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date when the manufacturer or vendor warranty coverage begins for this equipment asset.' ;
    rdfs:domain ind:EquipmentAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formatConfigId rdf:type rdf:Property ;
    rdfs:label 'Format Config Id' ;
    rdfs:comment 'Unique identifier for the restaurant format configuration record. Primary key.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alcoholServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Service Flag' ;
    rdfs:comment 'Indicates whether the restaurant format is licensed and configured to serve alcoholic beverages.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bohCookingLineCount rdf:type rdf:Property ;
    rdfs:label 'Boh Cooking Line Count' ;
    rdfs:comment 'Number of cooking lines or production stations in the Back of House (BOH) kitchen.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bohKitchenSqFt rdf:type rdf:Property ;
    rdfs:label 'Boh Kitchen Sq Ft' ;
    rdfs:comment 'Total square footage of the Back of House (BOH) kitchen and food preparation area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bohPrepStationCount rdf:type rdf:Property ;
    rdfs:label 'Boh Prep Station Count' ;
    rdfs:comment 'Number of food preparation stations in the Back of House (BOH) kitchen.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandStandardComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Compliance Status' ;
    rdfs:comment 'Current compliance status of the format configuration against brand standards and Standard Operating Procedures (SOPs).' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakfastDaypartFlag rdf:type rdf:Property ;
    rdfs:label 'Breakfast Daypart Flag' ;
    rdfs:comment 'Indicates whether the restaurant format operates during the breakfast daypart and serves breakfast menu items.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:configVersion rdf:type rdf:Property ;
    rdfs:label 'Config Version' ;
    rdfs:comment 'Version identifier for this format configuration, used to track changes and updates over time.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverCountCapacityPerDaypart rdf:type rdf:Property ;
    rdfs:label 'Cover Count Capacity Per Daypart' ;
    rdfs:comment 'Maximum number of covers (individual meals served) the restaurant can accommodate during a single daypart (breakfast, lunch, dinner) based on seating and throughput.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curbsidePickupEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Curbside Pickup Enabled Flag' ;
    rdfs:comment 'Indicates whether the restaurant format supports curbside pickup service for online orders.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diningFormatType rdf:type rdf:Property ;
    rdfs:label 'Dining Format Type' ;
    rdfs:comment 'The primary dining format classification of the restaurant unit: Quick-Service Restaurant (QSR), fast-casual, casual dining, or fine-dining.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLaneConfig rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lane Config' ;
    rdfs:comment 'Drive-Thru (DT) lane configuration: none (no drive-thru), single lane, dual lane, or triple lane.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruWindowCount rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Window Count' ;
    rdfs:comment 'Number of Drive-Thru (DT) service windows available for order pickup.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohBarSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Foh Bar Seating Count' ;
    rdfs:comment 'Number of bar seats available in the Front of House (FOH) area, if applicable.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohOutdoorSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Foh Outdoor Seating Count' ;
    rdfs:comment 'Number of outdoor patio or sidewalk seats available in the Front of House (FOH) area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Foh Seating Capacity' ;
    rdfs:comment 'Total number of guest seats available in the Front of House (FOH) dining area, including indoor and outdoor seating.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fohTableCount rdf:type rdf:Property ;
    rdfs:label 'Foh Table Count' ;
    rdfs:comment 'Total number of dining tables in the Front of House (FOH) area.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'Human-readable name or label for this format configuration (e.g., \'Standard QSR with DT\', \'Urban Fast-Casual\').' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kdsScreenCount rdf:type rdf:Property ;
    rdfs:label 'Kds Screen Count' ;
    rdfs:comment 'Number of Kitchen Display System (KDS) screens installed in the Back of House (BOH) for order routing and production management.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRemodelDate rdf:type rdf:Property ;
    rdfs:label 'Last Remodel Date' ;
    rdfs:comment 'Date of the most recent remodel or renovation that affected the format configuration of the restaurant.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateNightDaypartFlag rdf:type rdf:Property ;
    rdfs:label 'Late Night Daypart Flag' ;
    rdfs:comment 'Indicates whether the restaurant format operates during late-night hours (typically after 10 PM).' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oloEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Olo Enabled Flag' ;
    rdfs:comment 'Indicates whether the restaurant format supports Online Ordering (OLO) through web or mobile app channels.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingSpaceCount rdf:type rdf:Property ;
    rdfs:label 'Parking Space Count' ;
    rdfs:comment 'Number of parking spaces available for guest use at the restaurant location.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posTerminalCount rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count' ;
    rdfs:comment 'Number of Point of Sale (POS) terminals installed for order capture and payment processing.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceModel rdf:type rdf:Property ;
    rdfs:label 'Service Model' ;
    rdfs:comment 'Primary service delivery model: counter service, table service, drive-thru, self-service kiosk, or hybrid combination.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sosBenchmarkSeconds rdf:type rdf:Property ;
    rdfs:label 'Sos Benchmark Seconds' ;
    rdfs:comment 'Target Speed of Service (SOS) benchmark in seconds from order placement to order delivery, based on format and service model.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:throughputCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Per Hour' ;
    rdfs:comment 'Maximum number of customer transactions the restaurant can process per hour under optimal conditions, based on format configuration.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:twentyFourHourOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Operation Flag' ;
    rdfs:comment 'Indicates whether the restaurant operates 24 hours per day, 7 days per week.' ;
    rdfs:domain ind:FormatConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Building Ownership Type' ;
    rdfs:comment 'Type of ownership or lease arrangement for the restaurant building. Impacts financial reporting and CapEx decisions.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRadiusKm rdf:type rdf:Property ;
    rdfs:label 'Delivery Radius Km' ;
    rdfs:comment 'Maximum delivery radius in kilometers for online ordering and third-party delivery services. Configured per location based on geography and capacity.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dmaCode rdf:type rdf:Property ;
    rdfs:label 'Dma Code' ;
    rdfs:comment 'Nielsen Designated Market Area code identifying the media market. Used for marketing campaign planning and regional media analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driveThruLaneCount rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Lane Count' ;
    rdfs:comment 'Number of drive-thru lanes at the restaurant. Critical for throughput capacity planning and speed of service benchmarking.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the restaurant location if applicable. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasAccessibleParking rdf:type rdf:Property ;
    rdfs:label 'Has Accessible Parking' ;
    rdfs:comment 'Indicates whether the restaurant has ADA-compliant accessible parking spaces. Required for regulatory compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasDriveThru rdf:type rdf:Property ;
    rdfs:label 'Has Drive Thru' ;
    rdfs:comment 'Indicates whether the restaurant has drive-thru service capability. Key differentiator for QSR format and operational model.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPatioSeating rdf:type rdf:Property ;
    rdfs:label 'Has Patio Seating' ;
    rdfs:comment 'Indicates whether the restaurant has outdoor patio seating available. Impacts cover count and seasonal capacity.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPlayground rdf:type rdf:Property ;
    rdfs:label 'Has Playground' ;
    rdfs:comment 'Indicates whether the restaurant has a children\'s playground. Differentiator for family-oriented locations.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasRestroom rdf:type rdf:Property ;
    rdfs:label 'Has Restroom' ;
    rdfs:comment 'Indicates whether the restaurant has customer restroom facilities. Impacts guest experience and local health code compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasWheelchairAccess rdf:type rdf:Property ;
    rdfs:label 'Has Wheelchair Access' ;
    rdfs:comment 'Indicates whether the restaurant has wheelchair-accessible entrances and facilities. Required for ADA compliance.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasWifi rdf:type rdf:Property ;
    rdfs:label 'Has Wifi' ;
    rdfs:comment 'Indicates whether the restaurant offers guest WiFi service. Enhances guest experience and supports digital ordering.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'Locale identifier for language and regional formatting preferences. Used for menu display, signage, and customer communications.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotSizeSqft rdf:type rdf:Property ;
    rdfs:label 'Lot Size Sqft' ;
    rdfs:comment 'Total lot size in square feet including building, parking, and landscaping. Used for site selection and property management.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Total number of parking spaces available at or near the restaurant location. Influences site selection and accessibility.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patioSeatCount rdf:type rdf:Property ;
    rdfs:label 'Patio Seat Count' ;
    rdfs:comment 'Number of seats available on the outdoor patio. Used for capacity planning and table turn analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proximityToAirportKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Airport Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest airport. Influences traveler traffic and site classification.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proximityToHighwayKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Highway Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest major highway. Used for site selection and trade area analysis.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proximityToMallKm rdf:type rdf:Property ;
    rdfs:label 'Proximity To Mall Km' ;
    rdfs:comment 'Distance in kilometers from the restaurant to the nearest shopping mall. Impacts foot traffic and co-location strategy.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteClosedDate rdf:type rdf:Property ;
    rdfs:label 'Site Closed Date' ;
    rdfs:comment 'Date when the restaurant location permanently closed. Used for portfolio analysis and historical reporting.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Site Opened Date' ;
    rdfs:comment 'Date when the restaurant location first opened for business. Used for NRO tracking, maturity analysis, and comp sales calculations.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current operational status of the restaurant site. Used for reporting, site portfolio management, and NRO tracking.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the restaurant location. Used for daypart scheduling, operating hours, and time-based reporting.' ;
    rdfs:domain ind:LocationProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursId rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Id' ;
    rdfs:comment 'Unique identifier for the operating hours record. Primary key.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborSchedulingTemplateId rdf:type rdf:Property ;
    rdfs:label 'Labor Scheduling Template Id' ;
    rdfs:comment 'Identifier of the labor scheduling template associated with these operating hours. Links to workforce scheduling system for Full-Time Equivalent (FTE) planning and shift assignment.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchedulingTemplate .

ind:closeTime rdf:type rdf:Property ;
    rdfs:label 'Close Time' ;
    rdfs:comment 'The time the restaurant closes for the specified day and daypart, in 24-hour HH:mm format (e.g., 22:00). May extend past midnight for late-night operations.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'The day of the week for which these operating hours are defined. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowCloseTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Close Time' ;
    rdfs:comment 'The time the restaurant stops accepting delivery orders (Online Ordering (OLO) and Third-Party Delivery (3PD)), in 24-hour HH:mm format. May differ from dine-in hours.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowOpenTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Open Time' ;
    rdfs:comment 'The time the restaurant begins accepting delivery orders (Online Ordering (OLO) and Third-Party Delivery (3PD)), in 24-hour HH:mm format. May differ from dine-in hours.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driveThruCloseTime rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Close Time' ;
    rdfs:comment 'The time the Drive-Thru (DT) lane closes, in 24-hour HH:mm format. May differ from Front of House (FOH) close time for QSR (Quick-Service Restaurant) units.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driveThruOpenTime rdf:type rdf:Property ;
    rdfs:label 'Drive Thru Open Time' ;
    rdfs:comment 'The time the Drive-Thru (DT) lane opens, in 24-hour HH:mm format. May differ from Front of House (FOH) open time for QSR (Quick-Service Restaurant) units.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedCoverCount rdf:type rdf:Property ;
    rdfs:label 'Expected Cover Count' ;
    rdfs:comment 'The expected number of covers (individual diners served) during this daypart for casual and fine-dining establishments. Used for labor scheduling and inventory planning.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedTableTurnCount rdf:type rdf:Property ;
    rdfs:label 'Expected Table Turn Count' ;
    rdfs:comment 'The expected number of table turns (times a table is occupied and vacated) during this daypart for casual and fine-dining establishments. Used for capacity planning and revenue forecasting.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayName rdf:type rdf:Property ;
    rdfs:label 'Holiday Name' ;
    rdfs:comment 'The name of the holiday for which this schedule override applies (e.g., Christmas, Thanksgiving, New Year\'s Day). Null if not a holiday override.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayScheduleOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Schedule Override Flag' ;
    rdfs:comment 'Indicates whether these operating hours represent a holiday schedule override. True if this is a holiday exception, False for regular schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is24HourOperation rdf:type rdf:Property ;
    rdfs:label 'Is 24 Hour Operation' ;
    rdfs:comment 'Indicates whether the restaurant operates 24 hours a day for the specified day. True if open continuously, False otherwise.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClosed rdf:type rdf:Property ;
    rdfs:label 'Is Closed' ;
    rdfs:comment 'Indicates whether the restaurant is closed for the specified day and daypart. True if closed, False if open.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastOrderCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Last Order Cutoff Time' ;
    rdfs:comment 'The time by which the last order must be placed before the restaurant stops accepting new orders, in 24-hour HH:mm format. Used for Online Ordering (OLO) and Third-Party Delivery (3PD) routing.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openTime rdf:type rdf:Property ;
    rdfs:label 'Open Time' ;
    rdfs:comment 'The time the restaurant opens for the specified day and daypart, in 24-hour HH:mm format (e.g., 06:00).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'The current lifecycle status of this operating hours record. Active schedules are in effect; pending schedules are future-dated; expired schedules are past their end date; suspended schedules are temporarily disabled.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Flag' ;
    rdfs:comment 'Indicates whether these operating hours represent a seasonal adjustment (e.g., extended summer hours, reduced winter hours). True if seasonal, False for standard schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonalPeriodName rdf:type rdf:Property ;
    rdfs:label 'Seasonal Period Name' ;
    rdfs:comment 'The name of the seasonal period for which this schedule adjustment applies (e.g., Summer, Winter, Back-to-School). Null if not a seasonal adjustment.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialEventName rdf:type rdf:Property ;
    rdfs:label 'Special Event Name' ;
    rdfs:comment 'The name of the special event for which these operating hours apply (e.g., Super Bowl Sunday, Local Festival, Grand Opening). Null if not a special event schedule.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSpeedOfServiceSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Speed Of Service Seconds' ;
    rdfs:comment 'The target Speed of Service (SOS) in seconds for this daypart. Represents the benchmark time from order placement to order fulfillment. Used for operational performance tracking.' ;
    rdfs:domain ind:OperatingHours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:opsVisitId rdf:type rdf:Property ;
    rdfs:label 'Ops Visit Id' ;
    rdfs:comment 'Unique identifier for the operational field visit record. Primary key.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpsVisit .

ind:checklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Id' ;
    rdfs:comment 'Identifier of the standardized checklist or audit template used during the operational visit to ensure consistent evaluation criteria.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChecklistTemplate .

ind:primaryOpsVisitorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ops Visitor Employee Id' ;
    rdfs:comment 'Employee identifier of the individual who conducted the operational visit, linking to the workforce management system.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checklistCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Percentage' ;
    rdfs:comment 'Percentage of checklist items completed during the operational visit, indicating thoroughness of the inspection.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which all corrective actions identified during the visit must be completed and verified.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether corrective actions are required as a result of findings from the operational visit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerCountObserved rdf:type rdf:Property ;
    rdfs:label 'Customer Count Observed' ;
    rdfs:comment 'Approximate number of customers served or present during the operational visit, providing context for throughput and service observations.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartObserved rdf:type rdf:Property ;
    rdfs:label 'Daypart Observed' ;
    rdfs:comment 'The daypart (e.g., breakfast, lunch, dinner, late night) during which the operational visit was conducted, relevant for assessing performance during specific service periods.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpVisitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Visit Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a follow-up visit is required to verify corrective action completion.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpVisitScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Visit Scheduled Date' ;
    rdfs:comment 'Scheduled date for a follow-up operational visit to verify that corrective actions have been implemented and findings have been resolved.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foodQualityScore rdf:type rdf:Property ;
    rdfs:label 'Food Quality Score' ;
    rdfs:comment 'Sub-score evaluating the quality, freshness, preparation, and presentation of food items during the visit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallVisitScore rdf:type rdf:Property ;
    rdfs:label 'Overall Visit Score' ;
    rdfs:comment 'Composite score representing the overall performance of the restaurant unit during the operational visit, typically on a 0-100 scale.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Sub-score assessing food safety compliance, Hazard Analysis Critical Control Points (HACCP) adherence, and workplace safety standards during the visit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedScore rdf:type rdf:Property ;
    rdfs:label 'Speed Score' ;
    rdfs:comment 'Sub-score measuring the Speed of Service (SOS), ticket time, and throughput efficiency during the visit, benchmarked against brand standards.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffCountObserved rdf:type rdf:Property ;
    rdfs:label 'Staff Count Observed' ;
    rdfs:comment 'Number of staff members (Full-Time Equivalent or FTE) observed working during the visit, relevant for labor efficiency and service quality assessment.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitCategory rdf:type rdf:Property ;
    rdfs:label 'Visit Category' ;
    rdfs:comment 'Broad category of the operational visit indicating whether it is routine, targeted at specific issues, driven by customer complaints, regulatory-mandated, or pre-opening inspection.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit End Timestamp' ;
    rdfs:comment 'The precise date and time when the operational visit concluded, marking the completion of the on-site inspection or audit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitNotes rdf:type rdf:Property ;
    rdfs:label 'Visit Notes' ;
    rdfs:comment 'Free-text field capturing detailed observations, comments, recommendations, and contextual information from the operational visit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Visit Priority Level' ;
    rdfs:comment 'Priority classification of the operational visit based on the severity of findings, risk level, or strategic importance of the restaurant unit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit Start Timestamp' ;
    rdfs:comment 'The precise date and time when the operational visit began, capturing the start of the on-site inspection or audit.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the operational visit indicating whether it is scheduled, in progress, completed, cancelled, or rescheduled.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorName rdf:type rdf:Property ;
    rdfs:label 'Visitor Name' ;
    rdfs:comment 'Full name of the individual who conducted the operational visit, typically an area manager, brand consultant, or corporate operations team member.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitorRole rdf:type rdf:Property ;
    rdfs:label 'Visitor Role' ;
    rdfs:comment 'Job title or role of the individual who conducted the visit, such as Area Manager, Brand Consultant, Operations Director, or Quality Assurance Specialist.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Description of weather conditions during the visit, which may impact customer traffic, throughput, and operational performance observations.' ;
    rdfs:domain ind:OpsVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opsVisitFindingId rdf:type rdf:Property ;
    rdfs:label 'Ops Visit Finding Id' ;
    rdfs:comment 'Unique identifier for the operational visit finding record. Primary key.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingOpsVisitFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Ops Visit Finding Id' ;
    rdfs:comment 'Reference to the ops_visit_finding_id of the prior occurrence if this is a repeat finding. Enables tracking of finding recurrence patterns and corrective action effectiveness.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpsVisitFinding .

ind:primaryOpsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ops Employee Id' ;
    rdfs:comment 'Name of the manager or executive who approved the waiver. Populated only when status is waived. Used for accountability and audit trail.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:brandStandardCode rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Code' ;
    rdfs:comment 'Reference code for the specific brand standard or SOP (Standard Operating Procedure) that was violated or not met. Links to the brand standards repository for detailed requirement documentation.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardName rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Name' ;
    rdfs:comment 'Human-readable name of the brand standard or SOP that was violated. Examples: Hand Washing Protocol, Temperature Log Maintenance, Uniform and Appearance Standard, Drive-Thru Speed of Service.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Flag' ;
    rdfs:comment 'Indicates whether the required corrective action has been completed and verified. True when action is complete and verified; False when pending or in progress.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed and verified. Populated when corrective_action_completed_flag is set to True. Used to calculate resolution time and track overdue items.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was completed satisfactorily. Options include on-site inspection by field manager, photographic evidence submitted by unit, document review, manager attestation, or scheduled follow-up visit.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Organizational level to which this finding has been escalated. Unit: handled at restaurant level. Area: escalated to area manager. Region: escalated to regional director. Corporate: escalated to corporate compliance or executive leadership.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether this finding requires escalation beyond the restaurant unit level to area management, regional leadership, or corporate compliance. True for critical findings, repeat major findings, or regulatory violations requiring senior leadership notification.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Usd' ;
    rdfs:comment 'Estimated financial impact of the finding in US dollars. May include cost of waste, potential fines, equipment repair costs, or revenue impact from service disruption. Used for prioritization and ROI analysis of corrective actions.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the observed finding. Captures what was observed, where it was observed, and the specific condition or behavior that triggered the finding. Free-text field for auditor notes.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Sequence Number' ;
    rdfs:comment 'Sequential ordering of findings within the parent visit. Used to maintain the order in which findings were recorded during the field visit.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingSubcategory rdf:type rdf:Property ;
    rdfs:label 'Finding Subcategory' ;
    rdfs:comment 'Detailed sub-classification within the finding category. Examples: temperature_control, hand_washing, equipment_calibration, uniform_compliance, waste_tracking. Provides granular segmentation for trend analysis.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Guest Impact Flag' ;
    rdfs:comment 'Indicates whether this finding has direct impact on guest experience, satisfaction, or safety. True if the finding affects FOH (Front of House) operations, service quality, food safety, or guest-facing brand standards; False if it is purely BOH (Back of House) or administrative.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opsVisitFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Ops Visit Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open: newly recorded, awaiting action. In Progress: corrective action underway. Resolved: action completed, awaiting verification. Closed: verified and complete. Waived: finding acknowledged but action waived with justification.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Url' ;
    rdfs:comment 'URL or file path to photographic evidence documenting the finding. Used for visual verification, training purposes, and dispute resolution. Links to document management system or cloud storage.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Violation Flag' ;
    rdfs:comment 'Indicates whether this finding constitutes a violation of regulatory requirements (FDA, OSHA, local health department). True if the finding violates a legal or regulatory standard; False if it is an internal brand standard deviation only.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a repeat of a previously identified issue at this restaurant unit. True if the same or similar finding was recorded in a prior visit; False if this is the first occurrence. Used to identify systemic compliance gaps.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatOccurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Occurrence Count' ;
    rdfs:comment 'Number of times this specific finding has been recorded at this restaurant unit. Incremented each time the same finding is observed in subsequent visits. Used for escalation and intervention triggers.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual assigned responsibility for completing the corrective action. Typically the restaurant general manager, area manager, or specific department lead depending on the finding category.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Role' ;
    rdfs:comment 'Job title or role of the individual responsible for the corrective action. Examples: General Manager, Kitchen Manager, Area Manager, Facilities Manager, Training Coordinator.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date when the waiver was approved. Populated only when status is waived.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Justification for waiving the corrective action requirement. Populated only when status is waived. Requires approval from authorized manager and documentation of business rationale.' ;
    rdfs:domain ind:OpsVisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Performance Period Id' ;
    rdfs:comment 'Unique identifier for the performance period record. Primary key for the performance period entity.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformancePeriod .

ind:priorPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Period Id' ;
    rdfs:comment 'Reference to the immediately preceding performance period of the same type. Used for sequential period-over-period trending and variance analysis.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformancePeriod .

ind:priorYearPeriodId rdf:type rdf:Property ;
    rdfs:label 'Prior Year Period Id' ;
    rdfs:comment 'Reference to the corresponding performance period from the prior fiscal year. Used for year-over-year variance analysis and SSS calculations.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformancePeriod .

ind:auvCalculationWindowMonths rdf:type rdf:Property ;
    rdfs:label 'Auv Calculation Window Months' ;
    rdfs:comment 'The number of trailing months used to calculate Average Unit Volume (AUV) for this period. Typically 12 months for annual AUV or 3 months for quarterly AUV. Defines the rolling window for revenue averaging.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessDayCount rdf:type rdf:Property ;
    rdfs:label 'Business Day Count' ;
    rdfs:comment 'The number of operating days in this performance period, excluding holidays and closures. Used for calculating business-day-adjusted metrics.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compSalesEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Eligible Flag' ;
    rdfs:comment 'Indicates whether this period qualifies for comparable sales analysis. Synonymous with SSS eligibility; requires 12+ months of continuous operation for year-over-year performance comparison.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week' ;
    rdfs:comment 'Week number (1-53) of the fiscal year for the period.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Flag' ;
    rdfs:comment 'Indicates whether this period contains one or more major holidays that significantly impact restaurant traffic and sales patterns. Used for seasonality adjustments and forecasting.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayList rdf:type rdf:Property ;
    rdfs:label 'Holiday List' ;
    rdfs:comment 'Comma-separated list of major holidays occurring within this performance period (e.g., \'Thanksgiving, Black Friday\'). Used for detailed seasonality analysis and promotional planning.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeapYear rdf:type rdf:Property ;
    rdfs:label 'Is Leap Year' ;
    rdfs:comment 'Indicates whether the fiscal year for this period is a leap year (366 days). Used for accurate day-count adjustments in financial calculations.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performancePeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Period Status' ;
    rdfs:comment 'Current lifecycle status of the period record.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCloseDate rdf:type rdf:Property ;
    rdfs:label 'Period Close Date' ;
    rdfs:comment 'The date on which the performance period was officially closed for reporting. Represents when preliminary financial and operational results were finalized.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business-friendly code used to reference the period in reports and systems.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodDurationDays rdf:type rdf:Property ;
    rdfs:label 'Period Duration Days' ;
    rdfs:comment 'Number of calendar days covered by the period (derived from start and end dates).' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodLockDate rdf:type rdf:Property ;
    rdfs:label 'Period Lock Date' ;
    rdfs:comment 'The date on which the performance period was locked, preventing any further transactional or adjustment entries. Ensures data integrity for audited financial reporting.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Statistical index representing the expected seasonal variation for this period relative to the annual average (1.00 = average, >1.00 = above average, <1.00 = below average). Used for demand forecasting and labor planning.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'The ISO week number (1-53) within the calendar year. Used for weekly performance tracking and labor scheduling alignment.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementTerminalId rdf:type rdf:Property ;
    rdfs:label 'Replacement Terminal Id' ;
    rdfs:comment 'Identifier of the POS terminal that replaced this unit, if applicable.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosTerminal .

ind:assignedStation rdf:type rdf:Property ;
    rdfs:label 'Assigned Station' ;
    rdfs:comment 'Physical station or service point where the terminal is deployed (e.g., FOH counter, DT window 1, DT window 2, bar, patio, expo).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashDrawerAttached rdf:type rdf:Property ;
    rdfs:label 'Cash Drawer Attached' ;
    rdfs:comment 'Indicates whether a cash drawer is attached to this POS terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the POS terminal was decommissioned and removed from active service.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Identifier of the encryption key used to secure transaction data on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version of the firmware currently running on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Number' ;
    rdfs:comment 'Numeric floor level of the terminal location, useful for multi-story venues.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hardwareModel rdf:type rdf:Property ;
    rdfs:label 'Hardware Model' ;
    rdfs:comment 'Manufacturer model number or designation of the physical POS terminal hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Audit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance or security audit performed on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastPciAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Pci Audit Date' ;
    rdfs:comment 'Date of the most recent PCI DSS compliance audit or assessment for this terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSoftwareUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Software Update Date' ;
    rdfs:comment 'Date of the most recent software update or patch applied to the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-form description of where the terminal is situated within the restaurant (e.g., "Front Counter – Station 3").' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macAddress rdf:type rdf:Property ;
    rdfs:label 'Mac Address' ;
    rdfs:comment 'Hardware MAC address of the POS terminal network interface.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Company that produced the POS terminal hardware.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Physical or logical network connection type used by the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Planned date for the next routine maintenance.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPciAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Pci Audit Date' ;
    rdfs:comment 'Scheduled date for the next PCI DSS compliance audit or assessment.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethodsSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Supported' ;
    rdfs:comment 'Comma-separated list of payment method codes the terminal can accept (e.g., "credit,debit,cash,applepay").' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessingCapability rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Capability' ;
    rdfs:comment 'Comma-separated list of payment methods supported by this terminal (e.g., credit, debit, NFC, gift_card, mobile_wallet).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessingVendor rdf:type rdf:Property ;
    rdfs:label 'Payment Processing Vendor' ;
    rdfs:comment 'Name of the third-party processor handling card authorizations for this terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Status' ;
    rdfs:comment 'Current PCI DSS compliance status of the terminal for secure payment processing.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalStatus rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Status' ;
    rdfs:comment 'Current lifecycle status of the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printerAttached rdf:type rdf:Property ;
    rdfs:label 'Printer Attached' ;
    rdfs:comment 'Indicates whether a receipt printer is attached to this POS terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityCompliance rdf:type rdf:Property ;
    rdfs:label 'Security Compliance' ;
    rdfs:comment 'Compliance certification applicable to the terminal\'s payment processing.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Current version of the Oracle MICROS POS software installed on the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the station area: Front of House (FOH), Back of House (BOH), Drive-Thru (DT), kiosk, or mobile.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsChip rdf:type rdf:Property ;
    rdfs:label 'Supports Chip' ;
    rdfs:comment 'Indicates whether the terminal can read EMV chip cards.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsContactless rdf:type rdf:Property ;
    rdfs:label 'Supports Contactless' ;
    rdfs:comment 'Indicates whether the terminal can process contactless (NFC) payments.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsCreditCard rdf:type rdf:Property ;
    rdfs:label 'Supports Credit Card' ;
    rdfs:comment 'Indicates whether the terminal can process credit card payments.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsDebitCard rdf:type rdf:Property ;
    rdfs:label 'Supports Debit Card' ;
    rdfs:comment 'Indicates whether the terminal can process debit card payments.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsGiftCard rdf:type rdf:Property ;
    rdfs:label 'Supports Gift Card' ;
    rdfs:comment 'Indicates whether the terminal can process gift card payments.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsMagstripe rdf:type rdf:Property ;
    rdfs:label 'Supports Magstripe' ;
    rdfs:comment 'Indicates whether the terminal can read magnetic stripe cards.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsMobileWallet rdf:type rdf:Property ;
    rdfs:label 'Supports Mobile Wallet' ;
    rdfs:comment 'Indicates whether the terminal supports mobile wallet payments.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsNfc rdf:type rdf:Property ;
    rdfs:label 'Supports Nfc' ;
    rdfs:comment 'Indicates whether the terminal supports contactless NFC payments (e.g., Apple Pay, Google Pay).' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOlo rdf:type rdf:Property ;
    rdfs:label 'Supports Olo' ;
    rdfs:comment 'Indicates whether the terminal can process online orders placed through digital channels.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsQr rdf:type rdf:Property ;
    rdfs:label 'Supports Qr' ;
    rdfs:comment 'Indicates whether the terminal can scan QR codes for payment or ordering.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsThirdPartyDelivery rdf:type rdf:Property ;
    rdfs:label 'Supports Third Party Delivery' ;
    rdfs:comment 'Indicates whether the terminal can process orders from third-party delivery platforms.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Code' ;
    rdfs:comment 'Business identifier or asset tag used in inventory and reporting.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Terminal Currency Code' ;
    rdfs:comment 'ISO 4217 currency code used for transactions processed by this terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalName rdf:type rdf:Property ;
    rdfs:label 'Terminal Name' ;
    rdfs:comment 'Human-readable name assigned to the terminal for operational identification.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalNumber rdf:type rdf:Property ;
    rdfs:label 'Terminal Number' ;
    rdfs:comment 'Business-facing terminal number or code used for operational identification and reporting.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalType rdf:type rdf:Property ;
    rdfs:label 'Terminal Type' ;
    rdfs:comment 'Classification of the POS terminal by its operational role and form factor.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zone rdf:type rdf:Property ;
    rdfs:label 'Zone' ;
    rdfs:comment 'Area of the restaurant where the terminal operates.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renovationProjectId rdf:type rdf:Property ;
    rdfs:label 'Renovation Project Id' ;
    rdfs:comment 'Unique identifier for the renovation project. Primary key.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualAuvLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Auv Lift Percent' ;
    rdfs:comment 'Actual measured percentage increase in Average Unit Volume (AUV) achieved post-renovation, typically measured 6-12 months after completion.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCapexUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Capex Usd' ;
    rdfs:comment 'Actual total capital expenditure incurred for the renovation project in US dollars.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Flag' ;
    rdfs:comment 'Indicates whether the renovation project includes ADA compliance upgrades to meet accessibility requirements.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:architectFirmName rdf:type rdf:Property ;
    rdfs:label 'Architect Firm Name' ;
    rdfs:comment 'Name of the architectural firm that designed the renovation plans.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Brand Standard Version' ;
    rdfs:comment 'Version of the brand standards and design guidelines being implemented in this renovation project.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Usd' ;
    rdfs:comment 'Difference between actual and estimated CapEx (actual minus estimated) in US dollars, indicating over or under budget performance.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buildingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Building Permit Number' ;
    rdfs:comment 'Official building permit number issued by local authorities for the renovation work.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDurationDays rdf:type rdf:Property ;
    rdfs:label 'Closure Duration Days' ;
    rdfs:comment 'Number of days the restaurant was closed to customers during the renovation project.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor License Number' ;
    rdfs:comment 'State or local license number of the contractor performing the renovation work.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the primary general contractor or construction firm responsible for executing the renovation project.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyEfficiencyUpgradeFlag rdf:type rdf:Property ;
    rdfs:label 'Energy Efficiency Upgrade Flag' ;
    rdfs:comment 'Indicates whether the renovation includes energy efficiency improvements such as LED lighting, HVAC upgrades, or insulation enhancements.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCapexUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Capex Usd' ;
    rdfs:comment 'Estimated total capital expenditure budget for the renovation project in US dollars.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAuvLiftPercent rdf:type rdf:Property ;
    rdfs:label 'Expected Auv Lift Percent' ;
    rdfs:comment 'Expected percentage increase in Average Unit Volume (AUV) following completion of the renovation project.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Final Inspection Date' ;
    rdfs:comment 'Date when the final building inspection was completed and the renovation was approved for occupancy.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financingMethod rdf:type rdf:Property ;
    rdfs:label 'Financing Method' ;
    rdfs:comment 'Method used to finance the renovation project (corporate funds, franchise funded, loan, lease, mixed).' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partialClosureFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Closure Flag' ;
    rdfs:comment 'Indicates whether the restaurant remained partially operational during renovation (True) or was fully closed (False).' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectPriority rdf:type rdf:Property ;
    rdfs:label 'Project Priority' ;
    rdfs:comment 'Business priority level assigned to the renovation project for resource allocation and scheduling decisions.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPaybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Roi Payback Period Months' ;
    rdfs:comment 'Estimated number of months required to recover the renovation investment through increased revenue and operational savings.' ;
    rdfs:domain ind:RenovationProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sosMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Sos Measurement Id' ;
    rdfs:comment 'Unique identifier for each speed-of-service measurement event. Primary key for the SOS measurement transactional record.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daypartId rdf:type rdf:Property ;
    rdfs:label 'Daypart Id' ;
    rdfs:comment 'Identifier of the daypart during which this measurement occurred (breakfast, lunch, dinner, late-night). Links to daypart reference data.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Daypart .

ind:equipmentIssueFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Issue Flag' ;
    rdfs:comment 'Boolean indicator of whether any equipment malfunction or issue was reported during this service event. True if equipment issue was logged; False otherwise.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guestSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Guest Satisfaction Rating' ;
    rdfs:comment 'Customer Satisfaction (CSAT) rating provided by the guest for this service event, typically on a scale of 1-5. Captured via receipt survey, mobile app feedback, or kiosk prompt.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementQualityScore rdf:type rdf:Property ;
    rdfs:label 'Measurement Quality Score' ;
    rdfs:comment 'Data quality score for this measurement record, ranging from 0.00 to 1.00. Reflects completeness, accuracy, and reliability of the captured timing data. Lower scores indicate potential data quality issues.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderComplexityScore rdf:type rdf:Property ;
    rdfs:label 'Order Complexity Score' ;
    rdfs:comment 'Calculated complexity score for the order based on item count, customizations, and preparation requirements. Higher scores indicate more complex orders that may require longer service times.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderToDeliveryTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Order To Delivery Time Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from order placement to order delivered to guest. Includes preparation time plus handoff time. End-to-end service time metric.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderToReadyTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Order To Ready Time Seconds' ;
    rdfs:comment 'Elapsed time in seconds from order placement to order ready for pickup or delivery. Measured from POS order entry timestamp to Kitchen Display System (KDS) completion timestamp.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Period Flag' ;
    rdfs:comment 'Boolean indicator of whether the measurement occurred during a designated peak service period. True for peak hours; False for off-peak hours.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueDepthCount rdf:type rdf:Property ;
    rdfs:label 'Queue Depth Count' ;
    rdfs:comment 'Number of vehicles or guests in the service queue at the time of measurement. Indicates throughput capacity and congestion level.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queueWaitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Queue Wait Time Seconds' ;
    rdfs:comment 'Time in seconds the guest or vehicle spent waiting in queue before placing order. Applicable primarily to Drive-Thru (DT) and counter service channels.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Flag' ;
    rdfs:comment 'Boolean indicator of whether service recovery actions were taken for this order due to SOS delays or other service failures. True if recovery actions were applied; False otherwise.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffCountOnDuty rdf:type rdf:Property ;
    rdfs:label 'Staff Count On Duty' ;
    rdfs:comment 'Number of Full-Time Equivalent (FTE) staff members on duty in the service area at the time of measurement. Used to correlate staffing levels with SOS performance.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMetFlag rdf:type rdf:Property ;
    rdfs:label 'Target Met Flag' ;
    rdfs:comment 'Boolean indicator of whether the SOS measurement met or exceeded the target benchmark. True if actual time was at or below target; False if actual time exceeded target.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetVarianceSeconds rdf:type rdf:Property ;
    rdfs:label 'Target Variance Seconds' ;
    rdfs:comment 'Difference in seconds between actual order-to-delivery time and the SOS target benchmark. Positive values indicate slower than target; negative values indicate faster than target.' ;
    rdfs:domain ind:SosMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tableTurnLogId rdf:type rdf:Property ;
    rdfs:label 'Table Turn Log Id' ;
    rdfs:comment 'Unique identifier for each table turn event record. Primary key for the table turn log.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servicePeriodId rdf:type rdf:Property ;
    rdfs:label 'Service Period Id' ;
    rdfs:comment 'Identifier linking to the specific service period definition. Provides detailed service window context beyond daypart classification.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformancePeriod .

ind:checkPresentedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Presented Timestamp' ;
    rdfs:comment 'Date and time when the check was presented to the guest. Indicates the end of the dining experience and start of payment processing.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkToClearedMinutes rdf:type rdf:Property ;
    rdfs:label 'Check To Cleared Minutes' ;
    rdfs:comment 'Time in minutes from check presentation to table cleared. Measures payment processing and table reset efficiency.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Check Total Amount' ;
    rdfs:comment 'Total dollar amount of the check for this table turn. Used to calculate revenue per table turn and average check value (ACV) by turn time.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverCount rdf:type rdf:Property ;
    rdfs:label 'Cover Count' ;
    rdfs:comment 'Number of guests seated at the table for this turn. Critical metric for capacity planning and revenue per available seat hour (RevPASH) analysis.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryToCheckMinutes rdf:type rdf:Property ;
    rdfs:label 'Delivery To Check Minutes' ;
    rdfs:comment 'Time in minutes from food delivery to check presentation. Represents the dining and service interaction period.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foodDeliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Food Delivered Timestamp' ;
    rdfs:comment 'Date and time when food was delivered to the table. Used to calculate kitchen ticket time and overall speed of service (SOS) from order to delivery.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isPeakPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Peak Period' ;
    rdfs:comment 'Indicates whether this table turn occurred during a peak service period (True) or off-peak (False). Used to benchmark turn times against service volume.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderToDeliveryMinutes rdf:type rdf:Property ;
    rdfs:label 'Order To Delivery Minutes' ;
    rdfs:comment 'Time in minutes from order placement to food delivery. Measures BOH (Back of House) kitchen speed and KDS (Kitchen Display System) ticket time.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Completed Timestamp' ;
    rdfs:comment 'Date and time when payment was completed and processed. Marks the financial close of the table turn.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reservationFlag rdf:type rdf:Property ;
    rdfs:label 'Reservation Flag' ;
    rdfs:comment 'Indicates whether this table turn was for a reserved party (True) or walk-in (False). Used to analyze reservation vs walk-in turn time differences.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenuePerCover rdf:type rdf:Property ;
    rdfs:label 'Revenue Per Cover' ;
    rdfs:comment 'Average revenue per guest cover for this table turn. Calculated as check_total_amount divided by cover_count. Key metric for per-guest revenue analysis.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Seating Timestamp' ;
    rdfs:comment 'Date and time when guests were seated at the table. Marks the start of the table turn cycle and is used to calculate total turn time.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatingToOrderMinutes rdf:type rdf:Property ;
    rdfs:label 'Seating To Order Minutes' ;
    rdfs:comment 'Time in minutes from guest seating to order placement. Measures FOH greeting and order-taking efficiency.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serverStation rdf:type rdf:Property ;
    rdfs:label 'Server Station' ;
    rdfs:comment 'The FOH station or section assignment for the server handling this table. Used for workload balancing and station performance analysis.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sosTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sos Target Minutes' ;
    rdfs:comment 'Target table turn time in minutes for this daypart and restaurant format. Used to measure actual performance against SOS benchmarks.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sosVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Sos Variance Minutes' ;
    rdfs:comment 'Variance between actual total turn time and SOS target in minutes. Positive values indicate slower than target; negative values indicate faster than target.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialOccasionFlag rdf:type rdf:Property ;
    rdfs:label 'Special Occasion Flag' ;
    rdfs:comment 'Indicates whether this table turn was for a special occasion (birthday, anniversary, celebration). Special occasions may have longer turn times due to enhanced service.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tableCapacity rdf:type rdf:Property ;
    rdfs:label 'Table Capacity' ;
    rdfs:comment 'Maximum seating capacity of the table. Used to calculate table utilization percentage (cover_count / table_capacity).' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tableClearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Table Cleared Timestamp' ;
    rdfs:comment 'Date and time when the table was cleared and reset for the next party. Marks the end of the table turn cycle and availability for next seating.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tableSection rdf:type rdf:Property ;
    rdfs:label 'Table Section' ;
    rdfs:comment 'The physical section or zone of the restaurant where the table is located (e.g., main dining, patio, bar area). Used for section-level throughput analysis.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTurnTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Turn Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from seating to table cleared. Primary metric for table turn rate analysis and throughput optimization. Calculated as the difference between table_cleared_timestamp and seating_timestamp.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turnDate rdf:type rdf:Property ;
    rdfs:label 'Turn Date' ;
    rdfs:comment 'Business date on which the table turn occurred. Used for daily table turn rate reporting and trend analysis. May differ from seating_timestamp date for late-night service.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:turnSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Turn Sequence Number' ;
    rdfs:comment 'Sequential number indicating which turn this represents for the table during the service period (1st turn, 2nd turn, etc.). Used to track table utilization throughout the day.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnStatus rdf:type rdf:Property ;
    rdfs:label 'Turn Status' ;
    rdfs:comment 'Current status of the table turn event. Completed indicates normal turn cycle; incomplete indicates missing timestamps; voided indicates cancelled service; abandoned indicates guests left before service completion.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Time Minutes' ;
    rdfs:comment 'Time in minutes that the party waited before being seated. Used to correlate wait times with table turn efficiency and guest satisfaction.' ;
    rdfs:domain ind:TableTurnLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputBenchmarkId rdf:type rdf:Property ;
    rdfs:label 'Throughput Benchmark Id' ;
    rdfs:comment 'Unique identifier for the throughput benchmark record. Primary key for this entity.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'Source or origin of the benchmark definition. Corporate_standard = company-wide standard, franchise_agreement = defined in franchise contract, regional_target = regional operations target, unit_specific = customized for individual unit, industry_benchmark = derived from industry standards.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkType rdf:type rdf:Property ;
    rdfs:label 'Benchmark Type' ;
    rdfs:comment 'Classification of the benchmark: target = standard operational target, minimum = minimum acceptable performance, maximum = maximum achievable performance, stretch = aspirational goal for high-performing units.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCapacityConstraint rdf:type rdf:Property ;
    rdfs:label 'Equipment Capacity Constraint' ;
    rdfs:comment 'Description of any equipment capacity constraints (e.g., grill capacity, fryer capacity, KDS screen count) that limit throughput for this service channel and daypart.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborFteRequirement rdf:type rdf:Property ;
    rdfs:label 'Labor Fte Requirement' ;
    rdfs:comment 'Number of Full-Time Equivalent (FTE) staff required to achieve the target throughput for this service channel and daypart. Used for workforce scheduling and labor planning.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offPeakMultiplier rdf:type rdf:Property ;
    rdfs:label 'Off Peak Multiplier' ;
    rdfs:comment 'Multiplier applied to base throughput targets during off-peak hours for this service channel and daypart. Used to adjust capacity expectations during low-demand periods.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourMultiplier rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Multiplier' ;
    rdfs:comment 'Multiplier applied to base throughput targets during peak hours for this service channel and daypart. Used to adjust capacity expectations during high-demand periods.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queueLengthThreshold rdf:type rdf:Property ;
    rdfs:label 'Queue Length Threshold' ;
    rdfs:comment 'Maximum acceptable queue length (number of waiting customers or orders) for this service channel and daypart before operational intervention is required.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sosComplianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Sos Compliance Threshold Pct' ;
    rdfs:comment 'Percentage threshold for Speed of Service (SOS) compliance. Represents the minimum percentage of orders that must meet the target ticket time to be considered compliant.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAcv rdf:type rdf:Property ;
    rdfs:label 'Target Acv' ;
    rdfs:comment 'Target Average Check Value (ACV) in local currency for this service channel and daypart. Represents the expected revenue per transaction.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAdt rdf:type rdf:Property ;
    rdfs:label 'Target Adt' ;
    rdfs:comment 'Target Average Daily Transactions (ADT) for this service channel and daypart. Represents the expected number of transactions per day.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAtc rdf:type rdf:Property ;
    rdfs:label 'Target Atc' ;
    rdfs:comment 'Target Average Transaction Count (ATC) for this service channel and daypart. Represents the expected number of items per transaction.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCoverCountCapacity rdf:type rdf:Property ;
    rdfs:label 'Target Cover Count Capacity' ;
    rdfs:comment 'Maximum number of covers (individual servings) that can be served simultaneously for this service channel and daypart, based on FOH (Front of House) and BOH (Back of House) capacity constraints.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTableTurnMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Table Turn Minutes' ;
    rdfs:comment 'Target time in minutes for a table turn (time from guest seating to table availability for next guest). Applicable primarily to dine-in service channels in casual and fine-dining formats.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetThroughputCoversPerHour rdf:type rdf:Property ;
    rdfs:label 'Target Throughput Covers Per Hour' ;
    rdfs:comment 'Target number of customer covers (individual servings) that should be served per hour for this service channel and daypart. Used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetThroughputTransactionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Target Throughput Transactions Per Hour' ;
    rdfs:comment 'Target number of transactions (orders) that should be processed per hour for this service channel and daypart. Used for operational performance benchmarking.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputBenchmarkStatus rdf:type rdf:Property ;
    rdfs:label 'Throughput Benchmark Status' ;
    rdfs:comment 'Current lifecycle status of the throughput benchmark record. Active = currently in use, inactive = temporarily disabled, draft = under review, archived = historical record.' ;
    rdfs:domain ind:ThroughputBenchmark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageCoverCount rdf:type rdf:Property ;
    rdfs:label 'Average Cover Count' ;
    rdfs:comment 'Average number of guests (covers) served per day. Used for labor planning and revenue forecasting in table-service restaurants.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageUnitVolumeUsd rdf:type rdf:Property ;
    rdfs:label 'Average Unit Volume Usd' ;
    rdfs:comment 'Average annual sales revenue for this unit in US dollars. Key performance metric for franchise valuation and benchmarking.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conceptType rdf:type rdf:Property ;
    rdfs:label 'Concept Type' ;
    rdfs:comment 'The restaurant format classification. QSR (Quick-Service Restaurant) for fast food, casual dining for table service, fast casual for counter service with higher quality, fine dining for upscale full service, food court for mall locations, ghost kitchen for delivery-only.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daypartSchedule rdf:type rdf:Property ;
    rdfs:label 'Daypart Schedule' ;
    rdfs:comment 'Structured schedule defining daypart time windows (breakfast, lunch, dinner, late night) for menu and pricing management.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haccpCertified rdf:type rdf:Property ;
    rdfs:label 'Haccp Certified' ;
    rdfs:comment 'Indicates whether this unit maintains current HACCP certification for food safety management.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasOnlineOrdering rdf:type rdf:Property ;
    rdfs:label 'Has Online Ordering' ;
    rdfs:comment 'Indicates whether this unit supports online ordering through web or mobile app channels.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasThirdPartyDelivery rdf:type rdf:Property ;
    rdfs:label 'Has Third Party Delivery' ;
    rdfs:comment 'Indicates whether this unit is enabled for third-party delivery services such as DoorDash, Uber Eats, or Grubhub.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kdsStationCount rdf:type rdf:Property ;
    rdfs:label 'Kds Station Count' ;
    rdfs:comment 'Number of KDS stations installed in the BOH for order routing and kitchen workflow management.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the unit, typically formatted as day ranges with time windows (e.g., Mon-Fri 6:00-22:00, Sat-Sun 7:00-23:00).' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Pos System Version' ;
    rdfs:comment 'Version identifier of the POS system software deployed at this unit.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameStoreSalesPct rdf:type rdf:Property ;
    rdfs:label 'Same Store Sales Pct' ;
    rdfs:comment 'Year-over-year comparable store sales growth percentage. Measures organic growth for units open at least 12 months.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:speedOfServiceSeconds rdf:type rdf:Property ;
    rdfs:label 'Speed Of Service Seconds' ;
    rdfs:comment 'Average time in seconds from order placement to order delivery. Critical QSR operational metric for customer satisfaction.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tableTurnRate rdf:type rdf:Property ;
    rdfs:label 'Table Turn Rate' ;
    rdfs:comment 'Average number of times a table is occupied by different parties during a service period. Relevant for casual and fine-dining concepts.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:throughputCapacityOrdersPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Orders Per Hour' ;
    rdfs:comment 'Maximum number of customer orders this unit can process per hour at peak efficiency, based on equipment and staffing design.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'The customer-facing name of the restaurant unit as displayed on signage and marketing materials.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Business identifier for the restaurant unit. Externally-known unique code used across operational systems and franchise communications.' ;
    rdfs:domain ind:Unit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOwnershipId rdf:type rdf:Property ;
    rdfs:label 'Unit Ownership Id' ;
    rdfs:comment 'Unique identifier for each unit ownership record. Primary key for the unit ownership history table.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchisePartnerFranchiseeId rdf:type rdf:Property ;
    rdfs:label 'Franchise Partner Franchisee Id' ;
    rdfs:comment 'Reference to the franchise partner master record when ownership_type is franchised, licensed, joint_venture, master_franchise, or area_development. Null for company-owned units.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchisee .

ind:primaryUnitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Unit Employee Id' ;
    rdfs:comment 'The identifier of the user who created this ownership record. Used for audit trail and accountability.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaDevelopmentAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Area Development Agreement Flag' ;
    rdfs:comment 'Indicates whether this ownership is part of a multi-unit area development agreement. Used for franchise development tracking and compliance reporting.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialReportingEntityCode rdf:type rdf:Property ;
    rdfs:label 'Financial Reporting Entity Code' ;
    rdfs:comment 'The code identifying the financial reporting entity for P&L consolidation. Maps to the ERP system company code or business unit for financial reporting.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Expiration Date' ;
    rdfs:comment 'The expiration date of the franchise agreement. Used for renewal planning and compliance tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'The legal agreement number governing this franchise ownership arrangement. Null for company-owned units. Used for compliance tracking and legal reference.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Start Date' ;
    rdfs:comment 'The start date of the franchise agreement governing this ownership. May differ from ownership_effective_start_date if ownership transferred mid-agreement.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialFranchiseFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Initial Franchise Fee Usd' ;
    rdfs:comment 'The one-time initial franchise fee paid at the start of this ownership arrangement. Null for company-owned units. Used for revenue recognition and franchise economics analysis.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jointVenturePartnerName rdf:type rdf:Property ;
    rdfs:label 'Joint Venture Partner Name' ;
    rdfs:comment 'The name of the joint venture partner if ownership_type is joint_venture. Used for partnership management and financial reporting.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Audit Date' ;
    rdfs:comment 'The date of the most recent compliance audit for this ownership arrangement. Used for audit scheduling and compliance tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterFranchiseFlag rdf:type rdf:Property ;
    rdfs:label 'Master Franchise Flag' ;
    rdfs:comment 'Indicates whether this ownership operates under a master franchise arrangement with sub-franchising rights. Used for franchise hierarchy management and royalty flow tracking.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextComplianceAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Audit Due Date' ;
    rdfs:comment 'The scheduled date for the next compliance audit. Used for audit planning and compliance management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingEntityLegalName rdf:type rdf:Property ;
    rdfs:label 'Operating Entity Legal Name' ;
    rdfs:comment 'The full legal name of the entity that owns and operates this restaurant unit. Used for legal compliance, tax reporting, and franchise agreement documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingLicenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Operating License Expiration Date' ;
    rdfs:comment 'The expiration date of the operating license. Used for renewal tracking and compliance management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Operating License Number' ;
    rdfs:comment 'The business operating license number issued by local authorities for this ownership entity. Used for regulatory compliance and legal documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipEffectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective End Date' ;
    rdfs:comment 'The date on which this ownership arrangement ended or will end. Null for current active ownership. Used to close out royalty periods and finalize P&L attribution.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipEffectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Effective Start Date' ;
    rdfs:comment 'The date on which this ownership arrangement became effective. Used to determine royalty calculation periods and P&L attribution windows.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipNotes rdf:type rdf:Property ;
    rdfs:label 'Ownership Notes' ;
    rdfs:comment 'Free-text notes capturing additional context about this ownership arrangement, including special terms, conditions, or historical information.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Ownership Record Number' ;
    rdfs:comment 'Business-facing unique identifier for this ownership record, used in franchise agreements and legal documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipTransferDate rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Date' ;
    rdfs:comment 'The date on which ownership was transferred from a previous owner to the current owner. Used for historical tracking and transfer analysis.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousOwnerName rdf:type rdf:Property ;
    rdfs:label 'Previous Owner Name' ;
    rdfs:comment 'The name of the previous owner if this ownership record represents a transfer or resale. Used for historical tracking and franchise relationship management.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Transfer Approved By' ;
    rdfs:comment 'The name or identifier of the franchisor representative who approved the ownership transfer. Used for audit trail and compliance documentation.' ;
    rdfs:domain ind:UnitOwnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Unit Performance Id' ;
    rdfs:comment 'Unique identifier for the unit performance record. Primary key for this periodic operational and financial performance snapshot.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acvAmount rdf:type rdf:Property ;
    rdfs:label 'Acv Amount' ;
    rdfs:comment 'Average Check Value (ACV) - average revenue per customer transaction during the performance period. Calculated as total revenue divided by transaction count.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adtCount rdf:type rdf:Property ;
    rdfs:label 'Adt Count' ;
    rdfs:comment 'Average Daily Transactions (ADT) - average number of customer transactions processed per day during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcCount rdf:type rdf:Property ;
    rdfs:label 'Atc Count' ;
    rdfs:comment 'Average Transaction Count (ATC) - total number of customer transactions during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aucAmount rdf:type rdf:Property ;
    rdfs:label 'Auc Amount' ;
    rdfs:comment 'Average Unit Volume (AUV) - total revenue generated by the restaurant unit during the performance period. Key metric for unit-level revenue performance.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cogsPercent rdf:type rdf:Property ;
    rdfs:label 'Cogs Percent' ;
    rdfs:comment 'Cost of Goods Sold (COGS) Percentage - COGS as a percentage of total revenue. Key metric for food cost management.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Amount' ;
    rdfs:comment 'Comparable Store Sales (Comp Sales) - revenue for the current period for units that were operational in both the current and prior comparison period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compSalesVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Comp Sales Variance Amount' ;
    rdfs:comment 'Variance in Comparable Store Sales between current period and prior period, expressed as an absolute amount.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ebitdaAmount rdf:type rdf:Property ;
    rdfs:label 'Ebitda Amount' ;
    rdfs:comment 'Earnings Before Interest, Taxes, Depreciation, and Amortization (EBITDA) - key profitability metric for unit-level P&L management.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Revenue Amount' ;
    rdfs:comment 'Gross revenue before any deductions (discounts, promotions, refunds, voids) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost including wages, benefits, and payroll taxes for the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborPercent rdf:type rdf:Property ;
    rdfs:label 'Labor Percent' ;
    rdfs:comment 'Labor Cost Percentage - total labor cost as a percentage of total revenue. Key metric for workforce efficiency.' ;
    rdfs:domain ind:Restaurants ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Marketing Expense Amount' ;
    rdfs:comment 'Marketing and promotional expenses allocated to this unit during the performance period, including local store marketing and national campaign contributions.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Income Amount' ;
    rdfs:comment 'Net income (profit after all expenses, taxes, interest, depreciation, and amortization) for the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue after deducting discounts, promotions, refunds, and voids during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingIncomeAmount rdf:type rdf:Property ;
    rdfs:label 'Operating Income Amount' ;
    rdfs:comment 'Operating income (revenue minus operating expenses) for the performance period. Excludes interest, taxes, depreciation, and amortization.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Status of the performance record indicating whether the data is draft, preliminary, final, revised, or archived.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Rent Expense Amount' ;
    rdfs:comment 'Rent or lease expense for the restaurant facility during the performance period. Includes base rent and Common Area Maintenance (CAM) charges for leased locations.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Rm Expense Amount' ;
    rdfs:comment 'Repairs and Maintenance (R&M) expense for equipment, facilities, and infrastructure during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sssGrowthPercent rdf:type rdf:Property ;
    rdfs:label 'Sss Growth Percent' ;
    rdfs:comment 'Same-Store Sales (SSS) growth percentage comparing current period revenue to the same period in the prior year for units open at least 12 months. Excludes new restaurant openings.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOperatingExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Operating Expenses Amount' ;
    rdfs:comment 'Total operating expenses including COGS, labor, utilities, rent, repairs and maintenance, and other operational costs.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilityExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Utility Expense Amount' ;
    rdfs:comment 'Total utility expenses (electricity, gas, water, waste disposal) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteAmount rdf:type rdf:Property ;
    rdfs:label 'Waste Amount' ;
    rdfs:comment 'Total cost of food waste (spoilage, preparation errors, expired inventory) during the performance period.' ;
    rdfs:domain ind:UnitPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Unit Status History Id' ;
    rdfs:comment 'Unique identifier for each unit status history record. Primary key for the unit status history tracking entity.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By User Employee Id' ;
    rdfs:comment 'System user identifier of the individual who recorded or approved the status change. Used for audit trail and accountability.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualReopenDate rdf:type rdf:Property ;
    rdfs:label 'Actual Reopen Date' ;
    rdfs:comment 'The actual date when the restaurant unit returned to active status. Used to measure variance against expected reopen date and assess project execution.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether the status change required formal approval from corporate leadership, franchise partner, or regulatory authority before implementation.' ;
    rdfs:domain ind:Restaurant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureType rdf:type rdf:Property ;
    rdfs:label 'Closure Type' ;
    rdfs:comment 'Classification of the closure event distinguishing between planned maintenance closures, emergency shutdowns, regulatory actions, and other closure scenarios. [ENUM-REF-CANDIDATE: planned|unplanned|emergency|seasonal|regulatory|voluntary|involuntary — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact' ;
    rdfs:comment 'Projected financial impact on unit revenue during the status period, expressed in local currency. Used for financial planning and P&L forecasting.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReopenDate rdf:type rdf:Property ;
    rdfs:label 'Expected Reopen Date' ;
    rdfs:comment 'Anticipated date when the restaurant unit is expected to return to active status following a temporary closure or renovation. Null if not applicable or unknown.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grandOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Grand Opening Date' ;
    rdfs:comment 'Official grand opening date for the restaurant unit. Marks the beginning of full operational status and SSS eligibility countdown.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthDepartmentCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Health Department Case Number' ;
    rdfs:comment 'Official case or incident number assigned by the local health department if the status change was triggered by a health inspection failure or food safety violation.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnFranchiseAgreement rdf:type rdf:Property ;
    rdfs:label 'Impact On Franchise Agreement' ;
    rdfs:comment 'Description of how this status change affects the franchise agreement terms, royalty obligations, or compliance requirements. Relevant for franchise partner relations and legal review.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'The party or department that initiated the status change. Identifies accountability and decision authority for lifecycle transitions. [ENUM-REF-CANDIDATE: corporate_operations|franchise_partner|health_department|real_estate|finance|legal|system — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSssEligible rdf:type rdf:Property ;
    rdfs:label 'Is Sss Eligible' ;
    rdfs:comment 'Indicates whether the restaurant unit is eligible for inclusion in Same-Store Sales (SSS) calculations during this status period. Typically requires 12+ months of continuous active operation.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when formal notification of the status change was communicated to relevant stakeholders including franchise partners, corporate operations, and regulatory bodies.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status of the restaurant unit immediately prior to this status change. Enables transition analysis and lifecycle pattern identification.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renovationScope rdf:type rdf:Property ;
    rdfs:label 'Renovation Scope' ;
    rdfs:comment 'Classification of the renovation or remodel scope when the status change is related to facility improvements. Impacts expected duration and capital expenditure (CapEx) tracking.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softOpenStartDate rdf:type rdf:Property ;
    rdfs:label 'Soft Open Start Date' ;
    rdfs:comment 'Date when the restaurant unit began soft-open operations prior to the official grand opening. Used to track pre-launch performance and operational readiness.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitStatusHistoryStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status History Status' ;
    rdfs:comment 'Current operational status of the restaurant unit at this point in the lifecycle. Determines eligibility for Same-Store Sales (SSS) calculations and operational reporting.' ;
    rdfs:domain ind:UnitStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryId rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Id' ;
    rdfs:comment 'Unique surrogate key for the commodity category. [_canonical_skip_reason: inferred role REFERENCE_LOOKUP, no minimum categories required]' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Average Cost Per Unit' ;
    rdfs:comment 'Average monetary cost (in base currency) for a single unit of commodity within the category, used for budgeting and spend analysis.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Code' ;
    rdfs:comment 'Unique alphanumeric code that represents the commodity category across enterprise systems.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Description' ;
    rdfs:comment 'Detailed textual description providing context, typical items, and usage notes for the category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryName rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Name' ;
    rdfs:comment 'Descriptive name used by business users to identify the category (e.g., "Fresh Produce", "Dry Goods").' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Status' ;
    rdfs:comment 'Current lifecycle status of the commodity category.' ;
    rdfs:domain ind:CommodityCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFda rdf:type rdf:Property ;
    rdfs:label 'Compliance Fda' ;
    rdfs:comment 'Indicates whether items in this category meet FDA food safety regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceHaccp rdf:type rdf:Property ;
    rdfs:label 'Compliance Haccp' ;
    rdfs:comment 'Indicates whether items in this category adhere to HACCP safety standards.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLeafCategory rdf:type rdf:Property ;
