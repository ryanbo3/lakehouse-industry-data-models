    rdfs:range xsd:decimal .

ind:isLate rdf:type rdf:Property ;
    rdfs:label 'Is Late' ;
    rdfs:comment 'True if actual delivery date is later than expected delivery date.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isThreeWayMatch rdf:type rdf:Property ;
    rdfs:label 'Is Three Way Match' ;
    rdfs:comment 'Indicates whether PO, receipt, and invoice have been fully matched.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
